    })
    
    mask = (df[feat1_name] == df[feat1_name].iloc[0]) & (df[feat2_name] == df[feat2_name].iloc[0])
    group1 = df.loc[mask, outcome_col]
    group2 = df.loc[~mask, outcome_col]
    
    if len(group1) > 0 and len(group2) > 0:
