                for outcome in outcomes:
                    hypothesis_id = f"h{iteration_num}_{treatment}_{modifier}_outcome"
                    hypothesis_text = f"The effect of {treatment} on {outcome} varies by {modifier}."
                    iteration["proposed_hypotheses"].append({
                        "id": hypothesis_id,
