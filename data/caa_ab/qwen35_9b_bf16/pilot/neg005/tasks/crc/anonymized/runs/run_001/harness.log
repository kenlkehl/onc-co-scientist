if main_effects:
    top_effect = main_effects[0]
    summary_lines.append(f\"1. The strongest feature-outcome association is with {top_effect['feature']} (effect={safe_fmt(top_effect['effect'], 3)}, p={safe_fmt(top_effect['p_value'], 4)}).\")
else:
