"""
End-to-end CRC oncology dataset analysis script.
Follows the protocol: propose hypotheses, test them, refine across iterations.
"""

import json
import pandas as pd
import numpy as np
from scipy import stats
from typing import Dict, List, Any, Tuple, Optional

# Load dataset
