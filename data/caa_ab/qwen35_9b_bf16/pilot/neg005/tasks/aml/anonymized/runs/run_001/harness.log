        sig = p_val < ALPHA if p_val is not None else False
        summary = f\"t={fmt_num(t_stat, 2)}, mean={fmt_num(mean1, 2)} vs {fmt_num(mean0, 2)} (p={fmt_pval(p_val)}, {'sig' if sig else 'ns'})\"
