            analysis = {
                \"hypothesis_ids\": [hyp_id, f\"h8_{feature}_{outcome}\"],
                \"result_summary\": f\"Feature {feature}: rate={safe_format(rate1)} vs {safe_format(rate0)}, effect={safe_format(effect)}, p={safe_format(p_value)}.\",
                \"p_value\": p_value,
