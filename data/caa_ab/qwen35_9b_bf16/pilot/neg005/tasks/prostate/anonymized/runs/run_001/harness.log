                hyp_id = f\"h5_{analysis['hypothesis_ids'][0]}\"
                hyp_text = f\"Refined: The effect of {analysis['hypothesis_ids'][0].split('_')[1]} on {analysis['hypothesis_ids'][0].split('_')[2]} is robust across subgroups.\"
                
                analysis2 = {
