#"'!/usr/bin/env python3
"""
End-to-end oncology dataset analysis script.
Performs iterative hypothesis testing with treatment-effect heterogeneity analysis.
"""

import pandas as pd
import numpy as np
from scipy import stats
import json
from typing import List, Dict, Any, Tuple, Optional

# Load dataset
df = pd.read_parquet('"'dataset.parquet')

# Separate features and outcome
outcome_col = 'pfs_months'
feature_cols = [c for c in df.columns if c.startswith('feature_')]

# Classify features
binary_features = [c for c in feature_cols if df[c].nunique() == 2]
categorical_features = [c for c in feature_cols if 3 <= df[c].nunique() <= 10]
continuous_features = [c for c in feature_cols if df[c].nunique() > 10]

print(f\"Binary features: {len(binary_features)}\")
print(f\"Categorical features: {len(categorical_features)}\")
print(f\"Continuous features: {len(continuous_features)}\")

# Statistical helpers
def ttest_effect(df: pd.DataFrame, group_col: str, group_val: str, outcome: str) -> Tuple[float, float]:
    \"\"\"Two-sample t-test effect estimate and p-value.\"\"\"
    mask = df[group_col] == group_val
    group_mean = df.loc[mask, outcome].mean()
    control_mean = df.loc[~mask, outcome].mean()
    n1, n2 = len(mask), len(~mask)
    if n1 == 0 or n2 == 0:
        return 0.0, 1.0
    pooled_se = np.sqrt(df.loc[mask, outcome].std(ddof=1)**2 / n1 + 
                        df.loc[~mask, outcome].std(ddof=1)**2 / n2)
    if pooled_se == 0:
        return 0.0, 1.0
    t_stat = (group_mean - control_mean) / pooled_se
    p_val = 2 * (1 - stats.t.cdf(abs(t_stat), min(n1, n2) - 1))
    return group_mean - control_mean, p_val

def chi2_effect(df: pd.DataFrame, group_col: str, group_val: str, outcome: str) -> Tuple[float, float]:
    \"\"\"Chi-square test for binary outcome difference in proportions.\"\"\"
    mask = df[group_col] == group_val
    p1 = df.loc[mask, outcome].mean()
    p0 = df.loc[~mask, outcome].mean()
    n1, n0 = len(mask), len(~mask)
    if n1 == 0 or n0 == 0 or p1 == 0 or p1 == 1 or p0 == 0 or p0 == 1:
        return 0.0, 1.0
    contingency = pd.crosstab(df[group_col], df[outcome] > p1.mean())
    _, p_val, _, _ = stats.chi2_contingency(contingency, correction=False)
    return p1 - p0, p_val

def correlation_effect(df: pd.DataFrame, feature_col: str, outcome: str) -> Tuple[float, float]:
    \"\"\"Pearson correlation effect estimate and p-value.\"\"\"
    mask = df[outcome].notna() & df[feature_col].notna()
    if len(mask) < 10:
        return 0.0, 1.0
    corr, p_val = stats.pearsonr(df.loc[mask, feature_col], df.loc[mask, outcome])
    return corr, p_val

def stratified_comparison(df: pd.DataFrame, strat_col: str, strat_val: str, 
                          group_col: str, group_val: str, outcome: str) -> Tuple[float, float]:
    \"\"\"Treatment effect within a stratum.\"\"\"
    stratum_mask = df[strat_col] == strat_val
    group_mask = df[group_col] == group_val
    combined_mask = stratum_mask & group_mask
    control_mask = stratum_mask & ~group_mask
    
    n1 = len(combined_mask)
    n0 = len(control_mask)
    if n1 == 0 or n0 == 0:
        return 0.0, 1.0
    
    group_mean = df.loc[combined_mask, outcome].mean()
    control_mean = df.loc[control_mask, outcome].mean()
    
    pooled_se = np.sqrt(df.loc[combined_mask, outcome].std(ddof=1)**2 / n1 + 
                        df.loc[control_mask, outcome].std(ddof=1)**2 / n0)
    if pooled_se == 0:
        return 0.0, 1.0
    
    t_stat = (group_mean - control_mean) / pooled_se
    p_val = 2 * (1 - stats.t.cdf(abs(t_stat), min(n1, n0) - 1))
    return group_mean - control_mean, p_val

# Iteration tracking
transcript = {
    \"dataset_id\": \"ds001_breast\",
    \"model_id\": \"qwen35-9b\",
