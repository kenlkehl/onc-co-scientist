    proposed_hypotheses.append({\"id\": hyp_id, \"text\": text, \"kind\": \"novel\"})
    
    effect, p_val = ttest_effect(df, feat, 1, outcome_col)
    significant = p_val < 0.05
    
    analyses.append({
