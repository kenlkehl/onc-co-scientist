        group1 = df[(df[modifier] == 1) & (df[treatment] == 1)][OUTCOME]
        group2 = df[(df[modifier] == 1) & (df[treatment] == 0)][OUTCOME]
        group3 = df[(df[modifier] == 0) & (df[treatment] == 1)][OUTCOME]
