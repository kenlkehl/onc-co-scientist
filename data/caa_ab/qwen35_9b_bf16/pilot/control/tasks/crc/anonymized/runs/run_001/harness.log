        \"kind\": \"refined\"
    })
    
    analysis = {
        \"hypothesis_ids\": [hypothesis_id],
        \"result_summary\": f\"Interaction effect: {interaction_effect:+.3f} (p={p_value:.4f}, significant={p_value < 0.05}). Best treatment-effect modifier pair found.\",
        \"effect_estimate\": interaction_effect,
        \"p_value\": p_value,
        \"significant\": p_value < 0.05
    }
    iteration_10[\"analyses\"].append(analysis)

transcript[\"iterations\"].append(iteration_10)

# Write transcript.json
with open('transcript.json', 'w') as f:
    json.dump(transcript, f, indent=2)
print(\"Wrote transcript.json\")

# Generate analysis_summary.txt
summary_lines = [
    \"=\" * 80,
    \"ONCOLOGY COHORT ANALYSIS SUMMARY\",
