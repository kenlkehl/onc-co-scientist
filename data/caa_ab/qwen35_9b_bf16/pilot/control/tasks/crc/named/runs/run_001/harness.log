#"'!/usr/bin/env python3
"""
End-to-end oncology dataset analysis script.
Performs iterative hypothesis generation, testing, and refinement.
Outputs transcript.json and analysis_summary.txt.
"""

import json
import os
from scipy import stats
import pandas as pd
import numpy as np

# Paths
WORKDIR = os.path.dirname(os.path.abspath(__file__))
DATASET_PATH = os.path.join(WORKDIR, '"'dataset.parquet')
TRANSCRIPT_PATH = os.path.join(WORKDIR, 'transcript.json')
SUMMARY_PATH = os.path.join(WORKDIR, 'analysis_summary.txt')

# Load dataset
print(\"Loading dataset...\")
df = pd.read_parquet(DATASET_PATH)
print(f\"Loaded {len(df)} patients with {len(df.columns)} columns\")

# Column definitions from dataset_description.md
FEATURE_COLS = [
    'age_years', 'sex_female', 'ecog_ps', 'stage_iv', 'right_sided_primary',
    'kras_mutation', 'nras_mutation', 'braf_v600e', 'msi_high', 'her2_amplified',
    'ntrk_fusion', 'cea_ng_ml', 'albumin_g_dl', 'ldh_u_l', 'weight_loss_pct_6mo',
    'crp_mg_l', 'nlr', 'hemoglobin_g_dl', 'alkaline_phosphatase_u_l', 'ast_u_l',
    'alt_u_l', 'total_bilirubin_mg_dl', 'creatinine_mg_dl', 'bun_mg_dl',
    'sodium_meq_l', 'potassium_meq_l', 'calcium_mg_dl'
]

TREATMENT_COLS = [
    'treatment_cetuximab', 'treatment_bevacizumab', 'treatment_pembrolizumab',
    'treatment_encorafenib', 'treatment_trastuzumab_tucatinib', 'treatment_regorafenib'
]

OUTCOME_COLS = ['pfs_months']

# Helper functions
def compute_effect(df, feature_col, feature_value, outcome_col):
    \"\"\"Compute effect estimate using boolean mask comparison.\"\"\"
    mask = df[feature_col] == feature_value
    group1 = df.loc[mask, outcome_col]
    group0 = df.loc[~mask, outcome_col]
    if len(group1) == 0 or len(group0) == 0:
        return None, None
    effect = group1.mean() - group0.mean()
    return effect, group1.mean(), group0.mean()

def compute_chi2_effect(df, feature_col, feature_value, outcome_col):
    \"\"\"Compute chi-square effect for binary/categorical outcomes.\"\"\"
    mask = df[feature_col] == feature_value
    group1 = df.loc[mask, outcome_col]
    group0 = df.loc[~mask, outcome_col]
    if len(group1) == 0 or len(group0) == 0:
        return None, None, None
    p1 = group1.mean()
    p0 = group0.mean()
    total = len(group1) + len(group0)
    n1 = len(group1)
    n0 = len(group0)
    expected_p = (n1 * p1 + n0 * p0) / total
    if expected_p == 0 or expected_p == 1:
        return None, None, None
    chi2, p_val, _, _ = stats.chi2_contingency(
        [[n1 * p1, n1 * (1 - p1)], [n0 * p0, n0 * (1 - p0)]],
        correction=False
    )
    effect = p1 - p0
    return effect, p_val, p1, p0

def run_ttest(df, feature_col, feature_value, outcome_col):
    \"\"\"Run t-test for continuous outcomes.\"\"\"
    mask = df[feature_col] == feature_value
    group1 = df.loc[mask, outcome_col]
    group0 = df.loc[~mask, outcome_col]
    if len(group1) < 2 or len(group0) < 2:
        return None, None, None
    t_stat, p_val = stats.ttest_ind(group1, group0)
    effect = group1.mean() - group0.mean()
    return effect, p_val, group1.mean(), group0.mean()

def run_mannwhitney(df, feature_col, feature_value, outcome_col):
    \"\"\"Run Mann-Whitney U test for non-parametric comparison.\"\"\"
    mask = df[feature_col] == feature_value
    group1 = df.loc[mask, outcome_col]
    group0 = df.loc[~mask, outcome_col]
    if len(group1) < 2 or len(group0) < 2:
        return None, None, None
    u_stat, p_val = stats.mannwhitneyu(group1, group0, alternative='two-sided')
    effect = group1.mean() - group0.mean()
    return effect, p_val, group1.mean(), group0.mean()

def run_fisher_exact(df, feature_col, feature_value, outcome_col):
    \"\"\"Run Fisher's exact test for binary outcomes.\"\"\"
    mask = df[feature_col] == feature_value
    group1 = df.loc[mask, outcome_col]
    group0 = df.loc[~mask, outcome_col]
    if len(group1) == 0 or len(group0) == 0:
        return None, None, None, None
    p1 = group1.mean()
    p0 = group0.mean()
    n1 = len(group1)
    n0 = len(group0)
    contingency = [[int(n1 * p1), int(n1 * (1 - p1))], [int(n0 * p0), int(n0 * (1 - p0))]]
    try:
        odds_ratio, p_val, _, _ = stats.fisher_exact(contingency)
    except:
        p_val = 1.0
    effect = p1 - p0
    return effect, p_val, p1, p0

def run_regression(df, treatment_col, outcome_col, subgroup_cols=None):
    \"\"\"Run linear regression with optional interactions.\"\"\"
    if subgroup_cols:
        # Create interaction terms
        for col in subgroup_cols:
            df[f'{treatment_col}_{col}'] = df[treatment_col] * df[col]
        model = df[[treatment_col] + subgroup_cols + [outcome_col]]
        X = model.drop(columns=[outcome_col])
        y = model[outcome_col]
        from sklearn.linear_model import LinearRegression
        reg = LinearRegression().fit(X, y)
        coef = reg.coef_
        intercept = reg.intercept_
        # Find treatment coefficient index
        try:
            t_idx = X.columns.tolist().index(treatment_col)
            t_coef = float(coef[t_idx])
        except:
            t_coef = 0.0
        # Find interaction coefficients
        interactions = {}
        for col in subgroup_cols:
            try:
                int_idx = X.columns.tolist().index(f'{treatment_col}_{col}')
                interactions[col] = float(coef[int_idx])
            except:
                pass
        # Calculate p-value for treatment effect
        import statsmodels.api as sm
        X_const = sm.add_constant(X)
        model_sm = sm.OLS(y, X_const).fit()
        p_val = float(model_sm.pvalues[treatment_col])
        return t_coef, p_val, interactions
    else:
        # Simple regression
        model = df[[treatment_col, outcome_col]]
        X = model.drop(columns=[outcome_col])
        y = model[outcome_col]
        from sklearn.linear_model import LinearRegression
        reg = LinearRegression().fit(X, y)
        t_coef = float(reg.coef_[0])
        intercept = float(reg.intercept_)
        import statsmodels.api as sm
        X_const = sm.add_constant(X)
        model_sm = sm.OLS(y, X_const).fit()
        p_val = float(model_sm.pvalues[treatment_col])
        return t_coef, p_val, {}

def run_interaction_screen(df, treatment_col, outcome_col, subgroup_cols):
    \"\"\"Screen for treatment-by-subgroup interactions.\"\"\"
    results = {}
    for col in subgroup_cols:
        # Simple interaction: compare treatment effect in high vs low subgroup
        high_mask = df[col] > df[col].median()
        low_mask = df[col] <= df[col].median()
        
        # Treatment effect in high subgroup
        high_treat_mask = df[treatment_col] == 1
        high_treat = df.loc[high_mask & high_treat_mask, outcome_col]
        high_ctrl = df.loc[high_mask & (~high_treat_mask), outcome_col]
        high_effect = high_treat.mean() - high_ctrl.mean() if len(high_treat) > 0 and len(high_ctrl) > 0 else None
        
        # Treatment effect in low subgroup
        low_treat = df.loc[low_mask & high_treat_mask, outcome_col]
        low_ctrl = df.loc[low_mask & (~high_treat_mask), outcome_col]
        low_effect = low_treat.mean() - low_ctrl.mean() if len(low_treat) > 0 and len(low_ctrl) > 0 else None
        
        if high_effect is not None and low_effect is not None:
            interaction = high_effect - low_effect
            # Test if interaction is significant
            from scipy.stats import ttest_ind
            try:
                _, p_int = ttest_ind(high_treat, high_ctrl)
                _, p_int_low = ttest_ind(low_treat, low_ctrl)
                # Simple interaction test
                combined = pd.concat([high_treat, high_ctrl, low_treat, low_ctrl], ignore_index=True)
                _, p_int = ttest_ind(combined, combined)
                p_int = 1.0  # Placeholder
            except:
                p_int = 1.0
            results[col] = {'effect_high': float(high_effect), 'effect_low': float(low_effect), 'interaction': float(interaction), 'p_int': p_int}
    return results

