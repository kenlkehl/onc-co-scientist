    ctrl = df.loc[mask & (df['treatment_cetuximab'] == 0), 'pfs_months']
    
    if len(treat) > 0 and len(ctrl) > 0:
        effect = treat.mean() - ctrl.mean()
        _, p_val = ttest_ind(treat, ctrl)
