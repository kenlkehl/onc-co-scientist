    effect_00 = df.loc[(df[mod1] == 0) & (df[mod2] == 0) & (df[\"treatment_7plus3\"] == 1), outcomes[0]].mean()
    
    # Average interaction effect
    interaction_effect = (effect_11 + effect_01) - (effect_10 + effect_00)
    
