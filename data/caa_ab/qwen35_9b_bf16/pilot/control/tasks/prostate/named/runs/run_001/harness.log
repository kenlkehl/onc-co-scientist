print("Iteration 6: Testing sex-by-treatment interactions")
for treatment in TREATMENT_COLS:
    mask_treat = df[treatment] == 1
    
    g1_female = df.loc[mask_treat & (df["sex_female"] == 1), "objective_response"].mean()
    n1_female = (mask_treat & (df["sex_female"] == 1)).sum()
    
    g1_male = df.loc[mask_treat & (df["sex_female"] == 0), "objective_response"].mean()
    n1_male = (mask_treat & (df["sex_female"] == 0)).sum()
    
    ctrl_female = df.loc[~mask_treat & (df["sex_female"] == 1), "objective_response"].mean()
    ctrl_male = df.loc[~mask_treat & (df["sex_female"] == 0), "objective_response"].mean()
    
    if n1_female >= 5 and n1_male >= 5:
        effect_female = g1_female - ctrl_female
        effect_male = g1_male - ctrl_male
        
        hypothesis_id = f"h6_{treatment}_sex"
        hypothesis_text = f"The effect of {treatment} on objective_response differs by sex."
        transcript["iterations"].append({
            "index": 6,
            "proposed_hypotheses": [{"id": hypothesis_id, "text": hypothesis_text, "kind": "novel"}],
            "analyses": [{
                "hypothesis_ids": [hypothesis_id],
                "result_summary": f"Effect in females: {effect_female:.4f}, in males: {effect_male:.4f}",
                "effect_estimate": effect_female,
                "significant": abs(effect_female) > abs(effect_male)
            }]
        })

# Iteration 7: Performance status and treatment
print("Iteration 7: Testing ECOG performance status interactions")
for treatment in TREATMENT_COLS:
    mask_treat = df[treatment] == 1
    
    for ecog in [0, 1, 2]:
        mask_ecog = df["ecog_ps"] == ecog
        
        g1 = df.loc[mask_treat & mask_ecog, "objective_response"].mean()
        n1 = (mask_treat & mask_ecog).sum()
        
        ctrl = df.loc[~mask_treat & mask_ecog, "objective_response"].mean()
        
        if n1 >= 5:
            effect = g1 - ctrl
            
            hypothesis_id = f"h7_{treatment}_ecog{ecog}"
            hypothesis_text = f"The effect of {treatment} on objective_response differs by ECOG {ecog} status."
            transcript["iterations"].append({
                "index": 7,
                "proposed_hypotheses": [{"id": hypothesis_id, "text": hypothesis_text, "kind": "novel"}],
                "analyses": [{
                    "hypothesis_ids": [hypothesis_id],
                    "result_summary": f"Effect in ECOG {ecog}: {effect:.4f}",
                    "effect_estimate": effect,
                    "significant": abs(effect) > 0.1
                }]
            })

# Iteration 8: Treatment effect heterogeneity - comprehensive search
print("Iteration 8: Comprehensive treatment effect heterogeneity search")
for treatment in TREATMENT_COLS:
    mask_treat = df[treatment] == 1
    ctrl_rate = df.loc[~mask_treat, "objective_response"].mean()
    
    # Search for subgroups with enhanced treatment effect
    best_effect = 0
    best_subgroup = None
    best_def = None
    
    # Try single biomarker subgroups
    for biomarker in molecular_features:
        mask_biom = df[biomarker] == 1
        g1 = df.loc[mask_treat & mask_biom, "objective_response"].mean()
        n1 = (mask_treat & mask_biom).sum()
        if n1 >= 5:
            effect = g1 - ctrl_rate
            if effect > best_effect:
                best_effect = effect
                best_subgroup = biomarker
                best_def = f"{biomarker}=1"
    
    # Try single clinical feature subgroups
    for feature in ["age_years", "gleason_score", "psa_ng_ml"]:
        if feature == "age_years":
            cutoff = 65
        elif feature == "gleason_score":
            cutoff = 8
        else:
            cutoff = df[feature].median()
        
        mask_high = df[feature] > cutoff
        g1 = df.loc[mask_treat & mask_high, "objective_response"].mean()
        n1 = (mask_treat & mask_high).sum()
        if n1 >= 5:
            effect = g1 - ctrl_rate
            if effect > best_effect:
                best_effect = effect
                best_subgroup = feature
                best_def = f"{feature}>{cutoff}"
    
    if best_subgroup:
        hypothesis_id = f"h8_{treatment}_best_subgroup"
        hypothesis_text = f"The effect of {treatment} on objective_response is strongest in patients with {best_def}."
        transcript["iterations"].append({
            "index": 8,
            "proposed_hypotheses": [{"id": hypothesis_id, "text": hypothesis_text, "kind": "novel"}],
            "analyses": [{
                "hypothesis_ids": [hypothesis_id],
                "result_summary": f"Best subgroup: {best_def}. Treatment effect: {best_effect:.4f} (vs control rate {ctrl_rate:.3f})",
                "effect_estimate": best_effect,
                "significant": best_effect > 0.1
            }]
        })

# Iteration 9: Refined hypotheses based on significant findings
print("Iteration 9: Refining significant findings")
# Identify significant findings from previous iterations and refine
significant_treatments = []
for iteration in transcript["iterations"]:
    for analysis in iteration["analyses"]:
        if analysis.get("significant", False):
            for h in iteration["proposed_hypotheses"]:
                if "treatment" in h["text"]:
                    significant_treatments.append(h["text"])

# Refine based on strongest effects
for treatment in TREATMENT_COLS:
    mask_treat = df[treatment] == 1
    ctrl_rate = df.loc[~mask_treat, "objective_response"].mean()
    
    # Find best biomarker subgroup
    best_biom = None
    best_biom_effect = 0
    for biomarker in molecular_features:
        mask_biom = df[biomarker] == 1
        g1 = df.loc[mask_treat & mask_biom, "objective_response"].mean()
        n1 = (mask_treat & mask_biom).sum()
        if n1 >= 5:
            effect = g1 - ctrl_rate
            if effect > best_biom_effect:
                best_biom_effect = effect
                best_biom = biomarker
    
    if best_biom:
        hypothesis_id = f"h9_{treatment}_refined"
        hypothesis_text = f"Patients with {treatment}=1 and {best_biom}=1 have significantly higher objective_response rates than controls."
        transcript["iterations"].append({
            "index": 9,
            "proposed_hypotheses": [{"id": hypothesis_id, "text": hypothesis_text, "kind": "refined"}],
            "analyses": [{
                "hypothesis_ids": [hypothesis_id],
                "result_summary": f"Combined effect: {best_biom_effect:.4f} (treatment={df[treatment].mean():.2f}, {best_biom}={df[best_biom].mean():.2f})",
                "effect_estimate": best_biom_effect,
                "significant": best_biom_effect > 0.1
            }]
        })

# Iteration 10: Final comprehensive heterogeneity analysis
print("Iteration 10: Final comprehensive heterogeneity analysis")
# For each treatment, find the optimal subgroup definition
for treatment in TREATMENT_COLS:
    mask_treat = df[treatment] == 1
    ctrl_rate = df.loc[~mask_treat, "objective_response"].mean()
    
    # Test all combinations of key modifiers
    modifiers = [
        ("brca2_mutation", 1),
        ("ar_v7_positive", 1),
        ("msi_high", 1),
        ("psma_high", 1),
        ("gleason_score", 8),
        ("age_years", 65),
    ]
    
    best_effect = 0
    best_combo = None
    best_desc = None
    
    for mod_name, mod_val in modifiers:
        mask_mod = df[mod_name] == mod_val
        g1 = df.loc[mask_treat & mask_mod, "objective_response"].mean()
        n1 = (mask_treat & mask_mod).sum()
        if n1 >= 5:
            effect = g1 - ctrl_rate
            if effect > best_effect:
                best_effect = effect
                best_combo = (mod_name, mod_val)
                best_desc = f"{mod_name}={mod_val}"
    
    if best_combo:
        mod_name, mod_val = best_combo
        hypothesis_id = f"h10_{treatment}_final"
        hypothesis_text = f"The optimal subgroup for {treatment} benefit is patients with {mod_name}={mod_val}."
        transcript["iterations"].append({
            "index": 10,
            "proposed_hypotheses": [{"id": hypothesis_id, "text": hypothesis_text, "kind": "refined"}],
            "analyses": [{
                "hypothesis_ids": [hypothesis_id],
                "result_summary": f"Best subgroup {mod_name}={mod_val}: treatment effect = {best_effect:.4f}",
                "effect_estimate": best_effect,
                "significant": best_effect > 0.1
            }]
        })

# Write transcript.json
with open("transcript.json", "w") as f:
    json.dump(transcript, f, indent=2)

print("Wrote transcript.json")

# Generate analysis_summary.txt
summary_lines = [
