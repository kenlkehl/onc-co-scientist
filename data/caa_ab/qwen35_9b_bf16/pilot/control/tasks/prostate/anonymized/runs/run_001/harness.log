if len(top_binary) >= 2:
    X_cols = top_binary
    y = df[outcome_col]
    
    # Simple OLS using statsmodels if available, otherwise manual
    try:
        import statsmodels.api as sm
        X = sm.add_constant(df[X_cols])
        model = sm.OLS(y, X).fit()
        
        # Extract coefficients
        results = []
        for col in X_cols:
