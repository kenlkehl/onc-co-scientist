}
transcript['iterations'].append(iteration_1)

print(f\"Iteration 1 complete. Significant results: {[a['significant'] for a in iteration_1_analyses]}\")

# Iteration 2: Treatment effect heterogeneity - test interactions
print(\"\\nIteration 2: Testing treatment effect heterogeneity...\")

# Test if feature_006 (histology) modifies the effect of feature_014 (stage)
iteration_2_hypotheses = [
    {'id': 'h9', 'text': 'The effect of feature_014 on pfs_months differs by feature_006 (histology).'},
