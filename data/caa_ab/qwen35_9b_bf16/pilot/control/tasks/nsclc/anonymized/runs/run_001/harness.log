    'result_summary': f'Effect of feature_023 on pfs_months: adeno={effect_023_adeno:.2f}, squamous={effect_023_squamous:.2f}. Difference={effect_diff_023:.2f}.',
    'p_value': p_value_023,
    'effect_estimate': effect_diff_023,
    'significant': p_value_023 < 0.05
})

iteration_2 = {
    'index': 2,
