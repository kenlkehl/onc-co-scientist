import pandas as pd
import numpy as np
from scipy import stats
import json
from typing import List, Dict, Any, Tuple

# Load dataset
df = pd.read_parquet('dataset.parquet')

# Define iteration plan
# We'll run up to 10 iterations with focused hypotheses
# Iteration 1: Main effects for strongly correlated features
# Iteration 2: Treatment effect heterogeneity for pfs_months
# Iteration 3: Interaction effects
# Iteration 4+: Refine based on results

def compute_effect(df: pd.DataFrame, feature: str, outcome: str, 
                   group_value=None, method: str = 'diff') -> Tuple[float, float]:
    \"\"\"
    Compute effect estimate and p-value for a hypothesis.
    method: 'diff' for mean difference, 'rate' for rate difference, 'ttest' for t-test
    \"\"\"
    if group_value is not None:
        mask = df[feature] == group_value
        other_mask = df[feature] "'!= group_value
        
        group_vals = df.loc[mask, outcome]
        other_vals = df.loc[other_mask, outcome]
        
        if method == '"'diff':
            effect = group_vals.mean() - other_vals.mean()
            # 2-sample t-test
            t_stat, p_value = stats.ttest_ind(group_vals, other_vals)
        elif method == 'ttest':
            t_stat, p_value = stats.ttest_ind(group_vals, other_vals)
            effect = group_vals.mean() - other_vals.mean()
        else:
            raise ValueError(f\"Unknown method: {method}\")
    else:
        raise ValueError(\"group_value must be specified for this function\")
    
    return float(effect), float(p_value)

def compute_rate_effect(df: pd.DataFrame, feature: str, outcome: str,
                        group_value=None) -> Tuple[float, float]:
    \"\"\"
    Compute rate difference for binary outcome.
    \"\"\"
    if group_value is not None:
        mask = df[feature] == group_value
        other_mask = df[feature] "'!= group_value
        
        group_vals = df.loc[mask, outcome]
        other_vals = df.loc[other_mask, outcome]
        
        # Build 2x2 table
        n1 = len(group_vals)
        n2 = len(other_vals)
        x1 = int((group_vals == 1).sum()) if group_vals.dtype in [int, np.int64] else int(group_vals.mean() * n1)
        x2 = int((other_vals == 1).sum()) if other_vals.dtype in [int, np.int64] else int(other_vals.mean() * n2)
        
        # Rate difference
        rate1 = x1 / n1 if n1 > 0 else 0
        rate2 = x2 / n2 if n2 > 0 else 0
        effect = rate1 - rate2
        
        # Chi-square test
        contingency = pd.DataFrame({
            '"'Yes': [x1, n1 - x1],
            'No': [x2, n2 - x2]
        })
        _, p_value, _, _ = stats.chi2_contingency(contingency, correction=False)
    else:
        raise ValueError(\"group_value must be specified\")
    
    return float(effect), float(p_value)

def run_analysis(df: pd.DataFrame, feature: str, outcome: str, 
                 group_value=None, method: str = 'diff', 
                 hypothesis_text: str = None) -> Dict[str, Any]:
    \"\"\"Run a single analysis and return results.\"\"\"
    if hypothesis_text is None:
        hypothesis_text = f\"Mean {outcome} differs between patients with {feature}={group_value} and those without.\"
    
    if method == 'diff':
        effect, p_value = compute_effect(df, feature, outcome, group_value, method)
    elif method == 'rate':
        effect, p_value = compute_rate_effect(df, feature, outcome, group_value)
    else:
        raise ValueError(f\"Unknown method: {method}\")
    
    significant = p_value < 0.05
    
    return {
        'effect_estimate': effect,
        'p_value': p_value,
        'significant': significant,
        'hypothesis_text': hypothesis_text
    }

# Initialize transcript
transcript = {
    'dataset_id': 'ds001_nsclc',
    'model_id': 'qwen35-9b',
    'harness_id': 'codex-cli@1.0.0',
    'max_iterations': 10,
    'iterations': []
}

# Iteration 1: Main effects for strongly correlated features
print(\"Iteration 1: Testing main effects for strongly correlated features...\")

iteration_1_hypotheses = [
    {'id': 'h1', 'text': 'Mean pfs_months is higher for patients with feature_015=32.3 compared to other feature_015 values.'},
    {'id': 'h2', 'text': 'Mean pfs_months is lower for patients with feature_014=2 compared to feature_014=0.'},
    {'id': 'h3', 'text': 'Mean pfs_months is lower for patients with feature_023=1 compared to feature_023=0.'},
    {'id': 'h4', 'text': 'Mean pfs_months is lower for patients with feature_011=1 compared to feature_011=0.'},
    {'id': 'h5', 'text': 'Mean pfs_months is higher for patients with feature_016=1 compared to feature_016=0.'},
    {'id': 'h6', 'text': 'Mean pfs_months is lower for patients with feature_028=1 compared to feature_028=0.'},
    {'id': 'h7', 'text': 'Mean pfs_months is higher for patients with feature_006=adenocarcinoma compared to squamous.'},
    {'id': 'h8', 'text': 'Mean pfs_months is lower for patients with feature_001=former compared to never.'},
]

iteration_1_analyses = []
for hyp in iteration_1_hypotheses:
    result = run_analysis(df, hyp['id'].split('_')[1] if '_' in hyp['id'] else hyp['id'], 'pfs_months', 
                          group_value=hyp['text'].split('=')[1].split()[0] if '=' in hyp['text'] else None)
    result['hypothesis_ids'] = [hyp['id']]
    iteration_1_analyses.append(result)

iteration_1 = {
    'index': 1,
    'proposed_hypotheses': iteration_1_hypotheses,
