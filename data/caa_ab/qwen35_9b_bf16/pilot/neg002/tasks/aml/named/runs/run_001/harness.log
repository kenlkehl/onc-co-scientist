#"'!/usr/bin/env python
"""
End-to-end oncology dataset analysis script.
Performs iterative hypothesis generation, testing, and refinement.
Outputs transcript.json and analysis_summary.txt.
"""

import json
import numpy as np
import pandas as pd
from scipy import stats
from typing import Dict, List, Any, Tuple

# Load dataset
df = pd.read_parquet('"'dataset.parquet')

# Helper: convert to JSON-serializable types
def to_jsonable(obj: Any) -> Any:
    if isinstance(obj, np.ndarray):
        return obj.tolist()
    elif isinstance(obj, (np.integer, np.int64, np.int32)):
        return int(obj)
    elif isinstance(obj, (np.floating, np.float64, np.float32)):
        return float(obj)
    elif isinstance(obj, np.bool_):
        return bool(obj)
    elif isinstance(obj, float):
        if np.isnan(obj) or np.isinf(obj):
            return None
        return obj
    elif isinstance(obj, bool):
        return obj
    elif isinstance(obj, dict):
        return {k: to_jsonable(v) for k, v in obj.items()}
    elif isinstance(obj, (list, tuple)):
        return [to_jsonable(x) for x in obj]
    return obj

# Statistical helpers returning dictionaries for stable shapes
def compare_rates(df: pd.DataFrame, feature: str, feature_val: str, outcome: str) -> Dict[str, float]:
    \"\"\"Compare outcome rates between two groups using boolean mask.\"\"\"
    mask = df[feature] == feature_val
    rate_treated = df.loc[mask, outcome].mean()
    rate_control = df.loc[~mask, outcome].mean()
    # Build 2x2 table
    n_treated = mask.sum()
    n_control = (~mask).sum()
    resp_treated = df.loc[mask, outcome].sum()
    resp_control = df.loc[~mask, outcome].sum()
    table = np.array([[resp_treated, n_treated - resp_treated],
                      [resp_control, n_control - resp_control]])
    _, p_val, _, _ = stats.chi2_contingency(table, correction=False)
    effect = rate_treated - rate_control
    return {
        'rate_treated': float(rate_treated),
        'rate_control': float(rate_control),
        'effect_estimate': float(effect),
        'p_value': float(p_val),
        'significant': float(p_val) < 0.05,
        'n_treated': int(n_treated),
        'n_control': int(n_control)
    }

def compare_means(df: pd.DataFrame, feature: str, feature_val: str, outcome: str) -> Dict[str, float]:
    \"\"\"Compare outcome means between two groups using boolean mask.\"\"\"
    mask = df[feature] == feature_val
    mean_treated = df.loc[mask, outcome].mean()
    mean_control = df.loc[~mask, outcome].mean()
    effect = mean_treated - mean_control
    _, p_val = stats.ttest_ind(df.loc[mask, outcome], df.loc[~mask, outcome])
    return {
        'mean_treated': float(mean_treated),
        'mean_control': float(mean_control),
        'effect_estimate': float(effect),
        'p_value': float(p_val),
        'significant': float(p_val) < 0.05
    }

def test_treatment_effect(df: pd.DataFrame, treatment: str, outcome: str) -> Dict[str, float]:
    \"\"\"Test treatment effect on outcome using logistic regression.\"\"\"
    mask = df[treatment] == 1
    rate_treated = df.loc[mask, outcome].mean()
    rate_control = df.loc[~mask, outcome].mean()
    effect = rate_treated - rate_control
    _, p_val = stats.ttest_ind(df.loc[mask, outcome], df.loc[~mask, outcome])
    return {
        'rate_treated': float(rate_treated),
        'rate_control': float(rate_control),
        'effect_estimate': float(effect),
        'p_value': float(p_val),
        'significant': float(p_val) < 0.05
    }

def test_interaction(df: pd.DataFrame, treatment: str, modifier: str, outcome: str) -> Dict[str, float]:
    \"\"\"Test treatment-by-modifier interaction using stratified analysis.\"\"\"
    results = {}
    for mod_val in sorted(df[modifier].unique()):
        mask = (df[treatment] == 1) & (df[modifier] == mod_val)
        if mask.sum() > 0:
            rate = df.loc[mask, outcome].mean()
            results[f'{mod_val}'] = rate
    # Compare treatment effect across modifiers
    if len(results) >= 2:
        rates = list(results.values())
        effect_diff = max(rates) - min(rates)
        # Simple test: compare treatment effects in each stratum
        effects = []
        for mod_val in sorted(df[modifier].unique()):
            mask_t = (df[treatment] == 1) & (df[modifier] == mod_val)
            mask_c = (df[treatment] == 0) & (df[modifier] == mod_val)
            if mask_t.sum() > 0 and mask_c.sum() > 0:
                eff = df.loc[mask_t, outcome].mean() - df.loc[mask_c, outcome].mean()
                effects.append(eff)
        if len(effects) >= 2:
            effect_diff = max(effects) - min(effects)
            # Test if effects differ using interaction term
            model = df[['treatment_' + treatment.replace('treatment_', ''), 'modifier_' + modifier.replace('modifier_', ''), 'outcome']].copy()
            # Simplified: just report effect difference
            pass
    return {
        'stratum_rates': {k: float(v) for k, v in results.items()},
        'effect_difference': float(effect_diff),
        'significant': False  # Would need proper interaction test
    }

# Initialize transcript
transcript = {
    'dataset_id': 'ds001_aml',
    'model_id': 'qwen35-9b',
    'harness_id': 'codex-cli@pilot',
    'max_iterations': 10,
    'iterations': []
}

# Define features to analyze
treatments = ['treatment_midostaurin', 'treatment_gilteritinib', 'treatment_ivosidenib', 
              'treatment_enasidenib', 'treatment_venetoclax_azacitidine', 'treatment_7plus3']
modifiers = ['age_years', 'sex_female', 'ecog_ps', 'secondary_aml', 'unfit_for_intensive',
