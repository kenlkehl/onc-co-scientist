        hypothesis_text = f\"The effect of {treatment} on {OUTCOMES[0]} is strongest in patients with {best_modifier['feature']}={best_modifier['feature'].split('=')[-1] if '=' in str(best_modifier['feature']) else 'present'} (correlation={best_modifier['correlation_with_effect']:.4f}, p={best_modifier['p_correlation']:.4f}).\"
        iteration9_hypotheses.append({
