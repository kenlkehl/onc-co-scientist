            f2 = sig_ids[j].replace(\"h\", \"feature_\")
            
            # Test interaction: effect of f1 on outcome within f2 groups
            mask_f2_1 = df[f2] == 1
            mask_f2_0 = df[f2] == 0
            
            # Within f2=1 group
            mean1_f2_1, mean0_f2_1, eff_f2_1, p_f2_1 = compare_means(df[mask_f2_1], f1, OUTCOME)
            # Within f2=0 group
