            \"kind\": \"novel\"
        })
    
    # Iteration 6: Prognostic factors interactions
    elif iteration_index == 5:
        # Stage IV x Brain mets
        hypotheses.append({
            \"id\": f\"h{iteration_index + 1}_stage_brain\",
