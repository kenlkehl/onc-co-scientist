    \"proposed_hypotheses\": hypotheses,
    \"analyses\": analyses
})

# Iteration 2: Main effects - clinical features on PFS
iteration += 1
hypotheses = []
analyses = []

for f in ['age_years', 'ecog_ps', 'stage_iv', 'nlr']:
    h_id = f\"h{iteration}_{f.replace('_', '')}\"
    hypotheses.append({
        \"id\": h_id,
