    transcript = {
        \"dataset_id\": DATASET_ID,
        \"model_id\": \"codex-cli\",
        \"harness_id\": \"codex-cli@1.0.0\",
        \"max_iterations\": MAX_ITERATIONS,
        \"iterations\": []
    }
    
