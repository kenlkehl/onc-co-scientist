# Helper: run linear regression
def run_regression(df, outcome, *predictors):
    """
    Run a simple linear regression.
    Returns dict with coefficients and p-values.
    """
    X = df[predictors].values
    y = df[outcome].values
    
    # Add intercept
    X_with_intercept = np.column_stack([np.ones(len(X)), X])
    
    # OLS regression
    try:
        coeffs, residuals, rank, s = np.linalg.lstsq(X_with_intercept, y, rcond=None)
        intercept = coeffs[0]
        slopes = coeffs[1:]
        
        # Compute standard errors and p-values (simplified)
        # This is a rough approximation
        n = len(y)
        p = len(predictors) + 1  # including intercept
        
        # Residual variance
        rss = np.sum((y - (intercept + X @ slopes)) ** 2)
        mse = rss / (n - p)
        
        # Standard errors
        se = np.sqrt(np.diag(np.linalg.inv(X_with_intercept.T @ X_with_intercept) * mse))
        
        # t-statistics and p-values
        t_stats = (slopes / se[1:]) if len(se) > 1 else np.array([])
        
        # Approximate p-values using t-distribution
        p_values = []
        for t_stat in t_stats:
            # Use normal approximation for large samples
            p_val = 2 * (1 - stats.norm.cdf(abs(t_stat)))
            p_values.append(float(p_val))
        
        return {
            "intercept": float(intercept),
            "coefficients": {pred: float(s) for pred, s in zip(predictors, slopes)},
            "p_values": p_values,
            "r_squared": 1 - rss / np.sum((y - np.mean(y)) ** 2),
        }
    except Exception as e:
        return {"error": str(e)}

# Helper: JSON-serializable transcript converter
def to_jsonable(obj):
    """Convert object to JSON-serializable format."""
    if isinstance(obj, dict):
        return {k: to_jsonable(v) for k, v in obj.items()}
    elif isinstance(obj, list):
        return [to_jsonable(item) for item in obj]
    elif isinstance(obj, np.integer):
        return int(obj)
    elif isinstance(obj, np.floating):
        return float(obj)
    elif isinstance(obj, np.ndarray):
        return obj.tolist()
    elif isinstance(obj, (np.bool_, bool)):
        return bool(obj)
    elif isinstance(obj, (np.float64, np.float32)):
        return float(obj)
    elif isinstance(obj, (np.int64, np.int32)):
        return int(obj)
    elif isinstance(obj, float):
        if np.isnan(obj) or np.isinf(obj):
            return "NA"
        return obj
    elif isinstance(obj, (str, int, float, bool, type(None))):
        return obj
    else:
        return str(obj)

