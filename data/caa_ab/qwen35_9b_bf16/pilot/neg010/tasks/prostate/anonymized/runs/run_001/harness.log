feat = 'feature_016'
unique_vals = df[feat].unique()
print(f'Unique values: {len(unique_vals)}')

# Get first value as reference
ref_val = unique_vals[0]
ref_mask = df[feat] == ref_val
ref_group = df.loc[ref_mask, outcome_col]
ref_mean = ref_group.mean()
ref_n = len(ref_group)
print(f'Reference ({ref_val}): mean={ref_mean:.4f}, n={ref_n}')

# Get first level's mean
level1_mask = df[feat] == unique_vals[1]
level1_group = df.loc[level1_mask, outcome_col]
level1_mean = level1_group.mean()
level1_n = len(level1_group)
print(f'Level {unique_vals[1]}: mean={level1_mean:.4f}, n={level1_n}')

# T-test
t_stat, p_val = stats.ttest_ind(level1_group, ref_group)
effect = level1_mean - ref_mean
print(f'T-test: t={t_stat:.4f}, p={p_val:.4f}')
print(f'Effect: {effect:.4f}')
