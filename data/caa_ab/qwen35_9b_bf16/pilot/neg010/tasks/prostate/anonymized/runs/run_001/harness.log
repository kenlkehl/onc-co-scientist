#"'!/usr/bin/env python3
"""
End-to-end oncology dataset analysis script.
Performs iterative hypothesis generation, testing, and refinement.
Outputs transcript.json and analysis_summary.txt.
"""

import json
import pandas as pd
import numpy as np
from scipy import stats
from pathlib import Path

# Configuration
DATA_PATH = Path("dataset.parquet")
OUTPUT_DIR = Path(".")
MAX_ITERATIONS = 10
ALPHA = 0.05

# Load data
print("Loading dataset...")
df = pd.read_parquet(DATA_PATH)
print(f"Dataset shape: {df.shape}")

# Separate features and outcome
outcome_col = "objective_response"
feature_cols = [c for c in df.columns if c.startswith("feature_")]

# Helper functions
def safe_float(val):
    """Convert to float, handling None/NaN."""
    if val is None or (isinstance(val, float) and np.isnan(val)):
        return None
    return float(val)

def compute_effect_and_p(feature, outcome, df, method="ttest"):
    """
    Compute effect estimate and p-value for feature-outcome comparison.
    Returns dict with effect_estimate, p_value, significant, result_summary.
    """
    mask = df[feature] == 1
    group1 = df.loc[mask, outcome]
    group0 = df.loc[~mask, outcome]
    
    n1, n0 = len(group1), len(group0)
    
    if n1 == 0 or n0 == 0:
        return {
            "effect_estimate": None,
            "p_value": None,
            "significant": None,
            "result_summary": f"Insufficient data: {n1} vs {n0} observations"
        }
    
    if method == "ttest":
        # Two-sample t-test
        t_stat, p_val = stats.ttest_ind(group1, group0)
        effect = group1.mean() - group0.mean()
    elif method == "chi2":
        # Chi-square test for binary outcome
        cont_table = pd.crosstab(df[feature], df[outcome])
        chi2, p_val, dof, expected = stats.chi2_contingency(cont_table, correction=False)
        # Effect: difference in proportions
        prop1 = (cont_table.loc[1, 1] if 1 in cont_table.index and 1 in cont_table.columns else 0) / n1
        prop0 = (cont_table.loc[0, 1] if 0 in cont_table.index and 1 in cont_table.columns else 0) / n0
        effect = prop1 - prop0
    elif method == "correlation":
        # Pearson correlation for continuous features
        corr, p_val = stats.pearsonr(df[feature], df[outcome])
        effect = corr
    else:
        return {"error": f"Unknown method: {method}"}
    
    significant = p_val < ALPHA
    
    summary = f"Effect estimate: {effect:.4f}, p-value: {p_val:.4f}"
    if significant:
        summary += " (significant)"
    
    return {
        "effect_estimate": safe_float(effect),
        "p_value": safe_float(p_val),
        "significant": bool(significant),
        "result_summary": summary
    }

def compute_categorical_effect(feature, outcome, df):
    """
    Compute effect for categorical feature using boolean-mask approach.
    Returns dict with effect_estimate, p_value, significant, result_summary.
    """
    # Get unique values
    unique_vals = df[feature].unique()
    
    results = []
    for val in unique_vals:
        mask = df[feature] == val
        group = df.loc[mask, outcome]
        n = len(group)
        if n == 0:
            continue
        
        # Compare to reference (first value)
        ref_val = unique_vals[0]
        ref_mask = df[feature] == ref_val
        ref_group = df.loc[ref_mask, outcome]
        ref_n = len(ref_group)
        
        if ref_n == 0:
            continue
        
        if ref_n == 1 or n == 1:
            # Use Fisher'"'s exact test for small samples
            table = pd.crosstab(df[feature], df[outcome])
            _, p_val = stats.fisher_exact(table)
            # Effect: difference in proportions
            prop = (table.loc[val, 1] if val in table.index and 1 in table.columns else 0) / n
            ref_prop = (table.loc[ref_val, 1] if ref_val in table.index and 1 in table.columns else 0) / ref_n
            effect = prop - ref_prop
        else:
            # Two-sample t-test
            t_stat, p_val = stats.ttest_ind(group, ref_group)
            effect = group.mean() - ref_group.mean()
        
        significant = p_val < ALPHA
        results.append({
            \"value\": val,
            \"n\": n,
            \"mean\": group.mean(),
            \"effect\": effect,
            \"p_value\": p_val,
            \"significant\": significant
        })
    
    # Return overall effect (difference from reference)
    if results:
        ref_mean = df.loc[df[feature] == unique_vals[0], outcome].mean()
        overall_effect = results[0][\"mean\"] - ref_mean
        overall_p = results[0][\"p_value\"]
        overall_sig = results[0][\"significant\"]
    else:
        overall_effect = None
        overall_p = None
        overall_sig = None
    
    summary = f\"Effect vs reference ({unique_vals[0]}): {overall_effect:.4f}, p={overall_p:.4f}\"
    if overall_sig:
        summary += \" (significant)\"
    
    return {
        \"effect_estimate\": safe_float(overall_effect),
        \"p_value\": safe_float(overall_p),
        \"significant\": bool(overall_sig),
        \"result_summary\": summary,
        \"categorical_details\": results
    }

def screen_interactions(df, treatment_feature, outcome, candidate_modifiers, top_k=10):
    \"\"\"
    Screen for treatment-by-modifier interactions.
    Returns list of (modifier, interaction_effect, p_value, significant) tuples.
    \"\"\"
    interactions = []
    
    for modifier in candidate_modifiers:
        # Main treatment effect
        treat_mask = df[treatment_feature] == 1
        treat_group = df.loc[treat_mask, outcome]
        no_treat_group = df.loc[~treat_mask, outcome]
        
        if len(treat_group) < 10 or len(no_treat_group) < 10:
            continue
        
        # Treatment effect in overall population
        treat_effect = treat_group.mean() - no_treat_group.mean()
        
        # Treatment effect stratified by modifier
        for mod_val in df[modifier].unique():
            mod_mask = df[modifier] == mod_val
            mod_treat = df.loc[treat_mask & mod_mask, outcome]
            mod_no_treat = df.loc[~treat_mask & mod_mask, outcome]
            
            if len(mod_treat) < 5 or len(mod_no_treat) < 5:
                continue
            
            mod_treat_effect = mod_treat.mean() - mod_no_treat.mean()
            
            # Interaction effect (difference in treatment effects)
            interaction = mod_treat_effect - treat_effect
            
            # Test interaction
            # Create interaction term
            df[\"treat_mod\"] = (df[treatment_feature] == 1) & (df[modifier] == mod_val)
            df[\"no_treat_mod\"] = (df[treatment_feature] == 0) & (df[modifier] == mod_val)
            
            # Compare treatment effect in modifier group vs overall
            t_stat, p_val = stats.ttest_ind(mod_treat, mod_no_treat)
            
            interactions.append({
                \"modifier\": modifier,
                \"modifier_value\": mod_val,
                \"treatment_effect_in_group\": mod_treat_effect,
                \"overall_treatment_effect\": treat_effect,
                \"interaction_effect\": interaction,
                \"p_value\": p_val,
                \"significant\": p_val < ALPHA
            })
    
    # Sort by significance (p-value)
    interactions.sort(key=lambda x: x[\"p_value\"])
    return interactions[:top_k]

# Initialize transcript
transcript = {
    \"dataset_id\": \"ds001_prostate\",
    \"model_id\": \"qwen35-9b-bf16\",
    \"harness_id\": \"codex-cli@pilot\",
    \"max_iterations\": MAX_ITERATIONS,
    \"iterations\": []
}

# Iteration 1: Main effects screening
print(\"\\n=== Iteration 1: Main effects screening ===\")

# Binary features
binary_features = [c for c in feature_cols if df[c].nunique() == 2]
print(f\"Binary features: {len(binary_features)}\")

# Continuous features
continuous_features = [c for c in feature_cols if df[c].dtype in ['float64'] and df[c].nunique() > 2]
print(f\"Continuous features: {len(continuous_features)}\")

# Categorical features (3+ levels)
categorical_features = [c for c in feature_cols if df[c].nunique() > 2 and df[c].dtype in ['int64', 'float64']]
print(f\"Categorical features: {len(categorical_features)}\")

iteration_results = []

# Test binary features
print(\"Testing binary features...\")
for i, feat in enumerate(binary_features[:15]):  # Limit to 15
    result = compute_effect_and_p(feat, outcome_col, df, method=\"chi2\")
    result[\"hypothesis_id\"] = f\"h1_{i+1}\"
    result[\"feature\"] = feat
    iteration_results.append(result)
    print(f\"  {feat}: effect={result['effect_estimate']}, p={result['p_value']}, sig={result['significant']}\")

# Test continuous features (correlation)
print(\"Testing continuous features...\")
for i, feat in enumerate(continuous_features[:15]):
    result = compute_effect_and_p(feat, outcome_col, df, method=\"correlation\")
    result[\"hypothesis_id\"] = f\"h1_{len(binary_features[:15])+i+1}\"
    result[\"feature\"] = feat
    iteration_results.append(result)
    print(f\"  {feat}: effect={result['effect_estimate']}, p={result['p_value']}, sig={result['significant']}\")

# Test categorical features
print(\"Testing categorical features...\")
for i, feat in enumerate(categorical_features[:15]):
    result = compute_categorical_effect(feat, outcome_col, df)
    result[\"hypothesis_id\"] = f\"h1_{len(binary_features[:15])+len(continuous_features[:15])+i+1}\"
    result[\"feature\"] = feat
    iteration_results.append(result)
    print(f\"  {feat}: effect={result['effect_estimate']}, p={result['p_value']}, sig={result['significant']}\")

# Create iteration record
iteration_record = {
    \"index\": 1,
    \"proposed_hypotheses\": [
        {
            \"id\": f\"h1_{i+1}\",
            \"text\": f\"Feature {feat} is associated with objective_response.\",
            \"kind\": \"novel\"
        }
        for i, r in enumerate(iteration_results)
        for feat in [r[\"feature\"]]
    ],
    \"analyses\": iteration_results
}

transcript[\"iterations\"].append(iteration_record)

# Identify significant findings
significant_findings = [r for r in iteration_results if r[\"significant\"]]
print(f\"\\nSignificant findings: {len(significant_findings)}\")

# Iteration 2: Focus on significant binary features
print(\"\\n=== Iteration 2: Deep dive on significant binary features ===\")

if significant_findings:
    sig_binary = [r for r in significant_findings if r[\"feature\"] in binary_features]
    print(f\"Significant binary features: {len(sig_binary)}\")
    
    iteration_results = []
    for i, r in enumerate(sig_binary[:5]):
        feat = r[\"feature\"]
        # More detailed analysis
        mask = df[feat] == 1
        group1 = df.loc[mask, outcome_col]
        group0 = df.loc[~mask, outcome_col]
        
        t_stat, p_val = stats.ttest_ind(group1, group0)
        effect = group1.mean() - group0.mean()
        
        result = {
            \"hypothesis_id\": f\"h2_{i+1}\",
            \"feature\": feat,
            \"effect_estimate\": safe_float(effect),
            \"p_value\": safe_float(p_val),
            \"significant\": bool(p_val < ALPHA),
            \"result_summary\": f\"Mean outcome: {group1.mean():.4f} vs {group0.mean():.4f}, p={p_val:.4f}\"
        }
        iteration_results.append(result)
        print(f\"  {feat}: effect={result['effect_estimate']}, p={result['p_value']}\")
    
    iteration_record = {
        \"index\": 2,
        \"proposed_hypotheses\": [
            {
                \"id\": f\"h2_{i+1}\",
