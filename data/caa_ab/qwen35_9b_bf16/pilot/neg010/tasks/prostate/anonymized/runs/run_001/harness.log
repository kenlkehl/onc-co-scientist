import pandas as pd
import numpy as np
from scipy import stats

df = pd.read_parquet('dataset.parquet')
outcome_col = 'objective_response'

# Test feature_001 (3 levels) - compute effect
feat = 'feature_001'
unique_vals = df[feat].unique()
print(f'Unique values: {unique_vals}')

# Get proportions for each level
for val in unique_vals:
    mask = df[feat] == val
    n = len(df.loc[mask, outcome_col])
    prop = (df.loc[mask, outcome_col] == 1).mean()
    print(f'Level {val}: n={n}, prop={prop:.4f}')

# Reference level 0
ref_prop = (df.loc[df[feat] == 0, outcome_col] == 1).mean()
print(f'Reference (0) proportion: {ref_prop:.4f}')

# Effect for level 1
level1_prop = (df.loc[df[feat] == 1, outcome_col] == 1).mean()
