    summary_lines.append(\"  - The features examined are not predictive of the outcome\")
    summary_lines.append(\"  - More sophisticated modeling approaches may be needed\")

summary_lines.append(\"\")
summary_lines.append(\"=\" * 70)
summary_lines.append(\"END OF ANALYSIS SUMMARY\")
summary_lines.append(\"=\" * 70)

# Write summary
with open(OUTPUT_DIR / \"analysis_summary.txt\", \"w\") as f:
