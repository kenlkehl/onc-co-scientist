+function snappyUncompress(input, expected) {
+  let pos = 0;
+  function readVarint() {
+    let shift = 0;
+    let out = 0;
+    while (true) {
+      const b = input[pos++];
+      out |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return out;
+  }
+  const len = readVarint();
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let litLen = tag >> 2;
+      if (litLen < 60) {
+        litLen += 1;
+      } else {
+        const n = litLen - 59;
+        litLen = 1;
+        let v = 0;
+        for (let i = 0; i < n; i++) v |= input[pos++] << (8 * i);
+        litLen = v + 1;
+      }
+      input.copy(out, op, pos, pos + litLen);
+      pos += litLen;
+      op += litLen;
+    } else {
