+      return;
+    }
+    if (t === 8) {
+      this.binaryBuffer();
+      return;
+    }
+    if (t === 9 || t === 10) {
+      const h = this.byte();
+      let size = h >> 4;
+      const et = h & 0xf;
+      if (size === 15) size = Number(this.varint());
+      for (let i = 0; i < size; i++) this.skip(et);
+      return;
+    }
+    if (t === 11) {
+      const h = this.byte();
+      if (h === 0) return;
+      const size = Number(this.varint());
+      const kt = (h >> 4) & 0xf;
+      const vt = h & 0xf;
+      for (let i = 0; i < size; i++) {
+        this.skip(kt);
+        this.skip(vt);
