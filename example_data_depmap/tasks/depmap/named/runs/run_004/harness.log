+  const kHighAneu = data.aneuploidy_score.map((v) => v >= quantile(data.aneuploidy_score, 0.75) ? 1 : 0);
+  const kLowCas9 = data.cas9_activity_score.map((v) => v <= quantile(data.cas9_activity_score, 0.25) ? 1 : 0);
+  const kLineageLung = data.lineage.map((v) => v === "lung" ? 1 : 0);
+  regression.KIF18A_interaction = (() => {
+    const cols = [Array(N).fill(1), kHighAneu, kLowCas9, kLineageLung, kHighAneu.map((v, i) => v * kLowCas9[i]), kHighAneu.map((v, i) => v * kLineageLung[i])];
+    const names = ["Intercept", "aneuploidy_score>=Q75", "cas9_activity_score<=Q25", "lineage=lung", "high_aneuploidy:low_cas9", "high_aneuploidy:lung"];
+    const fit = ols(data.dependency_KIF18A, cols);
+    return names.map((name, i) => ({ name, beta: fit.beta[i], se: fit.se[i], z: fit.z[i], p: fit.p[i] }));
+  })();
+
+  const summaries = {};
+  for (const c of columns) {
+    if (outcomes.includes(c) || c.startsWith("dependency_")) {
+      summaries[c] = { mean: mean(data[c]), sd: Math.sqrt(variance(data[c])) };
+    }
+  }
+  const counts = {};
+  for (const c of ["lineage", "lineage_subtype", "culture_type", "screen_batch"]) {
+    counts[c] = {};
+    for (const v of data[c]) counts[c][v] = (counts[c][v] || 0) + 1;
+  }
+
+  const results = { counts, summaries, single, pairs, triples, regression };
+  fs.writeFileSync("analysis_results.json", JSON.stringify(results, null, 2));
+  console.log(JSON.stringify({
+    counts,
+    topSingles: Object.fromEntries(outcomes.map((o) => [o, single[o].slice(0, 5)])),
+    topPairs: Object.fromEntries(outcomes.map((o) => [o, pairs[o].slice(0, 5)])),
+    topTriples: triples,
+    regression,
+  }, null, 2));
+}
