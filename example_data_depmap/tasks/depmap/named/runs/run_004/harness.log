+  varint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      out |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
