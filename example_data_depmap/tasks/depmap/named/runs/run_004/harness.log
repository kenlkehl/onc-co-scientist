+      6: (_, o) => (o.converted_type = reader.i32()),
+      7: (_, o) => (o.scale = reader.i32()),
+      8: (_, o) => (o.precision = reader.i32()),
+      9: (_, o) => (o.field_id = reader.i32()),
+      10: (t) => reader.skip(t),
