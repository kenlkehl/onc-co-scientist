+    const h = this.byte();
+    let size = h >> 4;
+    const et = h & 0xf;
+    if (size === 15) size = Number(this.varint());
+    const out = [];
+    for (let i = 0; i < size; i++) out.push(readElem(et));
+    return out;
+  }
+  struct(handlers) {
+    let last = 0;
+    const out = {};
+    while (true) {
+      const h = this.byte();
+      const t = h & 0xf;
+      if (t === 0) break;
+      const delta = h >> 4;
