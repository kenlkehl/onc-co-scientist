+
+function twoGroup(y, mask) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) {
+      n1 += 1;
+      s1 += y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) ss1 += (y[i] - m1) ** 2;
+    else ss0 += (y[i] - m0) ** 2;
+  }
+  const v1 = ss1 / (n1 - 1);
+  const v0 = ss0 / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
