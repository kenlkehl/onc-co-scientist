const fs = require('fs');
const b = fs.readFileSync('dataset.parquet');
console.log('len', b.length, 'magic start', b.subarray(0,4).toString(), 'magic end', b.subarray(b.length-4).toString());
const metaLen = b.readUInt32LE(b.length-8);
console.log('metadata length', metaLen, 'offset', b.length-8-metaLen);
const meta = b.subarray(b.length-8-metaLen, b.length-8);
let pos=0;
function readByte(){return meta[pos++];}
function readVarint(){let shift=0, result=0n; while(true){const byte=BigInt(readByte()); result |= (byte & 0x7fn) << BigInt(shift); if((byte & 0x80n)===0n) break; shift += 7;} return result;}
function zigzag(n){return (n >> 1n) "'^ (-(n & 1n));}
function readI32(){return Number(zigzag(readVarint()));}
function readI64(){return zigzag(readVarint());}
function readDouble(){const v=meta.readDoubleLE(pos); pos+=8; return v;}
function readBinary(){const n=Number(readVarint()); const s=meta.subarray(pos,pos+n); pos+=n; return s.toString('"'utf8');}
function skipType(t){
  if(t===0) return;
  if(t===1 || t===2) return;
  if(t===3) {pos++; return;}
  if(t===4 || t===5) {readI32(); return;}
  if(t===6) {readI64(); return;}
  if(t===7) {pos+=8; return;}
  if(t===8) {readBinary(); return;}
  if(t===9 || t===10) {const h=readByte(); let size=h>>4, et=h&0xf; if(size===15) size=Number(readVarint()); for(let i=0;i<size;i++) skipType(et); return;}
  if(t===11) {let h=readByte(); if(h===0) return; let size=Number(readVarint()); let kt=(h>>4)&0xf, vt=h&0xf; for(let i=0;i<size;i++){skipType(kt); skipType(vt);} return;}
  if(t===12) {readStruct({}); return;}
  throw new Error('skip type '+t+' pos '+pos);
}
function readStruct(handlers){let last=0; const out={}; while(true){const h=readByte(); const t=h&0xf; if(t===0) break; const delta=h>>4; let fid; if(delta===0) fid=readI32(); else fid=last+delta; last=fid; if(handlers[fid]) handlers[fid](t,out,fid); else skipType(t);} return out;}
function readList(readElem){const h=readByte(); let size=h>>4, et=h&0xf; if(size===15) size=Number(readVarint()); const arr=[]; for(let i=0;i<size;i++) arr.push(readElem(et)); return arr;}
function readStringList(){return readList(et=>{if(et"'!==8) throw new Error('"'expected string list elem '+et); return readBinary();});}
function readI32List(){return readList(et=>{if(et"'!==5) throw new Error('"'expected i32 elem '+et); return readI32();});}
function schemaElement(){return readStruct({1:(t,o)=>o.type=readI32(),2:(t,o)=>o.type_length=readI32(),3:(t,o)=>o.repetition_type=readI32(),4:(t,o)=>o.name=readBinary(),5:(t,o)=>o.num_children=readI32(),6:(t,o)=>o.converted_type=readI32(),7:(t,o)=>o.scale=readI32(),8:(t,o)=>o.precision=readI32(),9:(t,o)=>o.field_id=readI32(),10:(t,o)=>skipType(t)});}
function columnMeta(){return readStruct({1:(t,o)=>o.type=readI32(),2:(t,o)=>o.encodings=readI32List(),3:(t,o)=>o.path_in_schema=readStringList(),4:(t,o)=>o.codec=readI32(),5:(t,o)=>o.num_values=Number(readI64()),6:(t,o)=>o.total_uncompressed_size=Number(readI64()),7:(t,o)=>o.total_compressed_size=Number(readI64()),8:(t,o)=>skipType(t),9:(t,o)=>o.data_page_offset=Number(readI64()),10:(t,o)=>o.index_page_offset=Number(readI64()),11:(t,o)=>o.dictionary_page_offset=Number(readI64()),12:(t,o)=>skipType(t),13:(t,o)=>skipType(t),14:(t,o)=>o.bloom_filter_offset=Number(readI64())});}
function columnChunk(){return readStruct({1:(t,o)=>o.file_path=readBinary(),2:(t,o)=>o.file_offset=Number(readI64()),3:(t,o)=>o.meta_data=columnMeta(),4:(t,o)=>o.offset_index_offset=Number(readI64()),5:(t,o)=>o.offset_index_length=readI32(),6:(t,o)=>o.column_index_offset=Number(readI64()),7:(t,o)=>o.column_index_length=readI32(),8:(t,o)=>skipType(t),9:(t,o)=>skipType(t)});}
function rowGroup(){return readStruct({1:(t,o)=>o.columns=readList(et=>columnChunk()),2:(t,o)=>o.total_byte_size=Number(readI64()),3:(t,o)=>o.num_rows=Number(readI64()),4:(t,o)=>skipType(t),5:(t,o)=>o.file_offset=Number(readI64()),6:(t,o)=>o.total_compressed_size=Number(readI64()),7:(t,o)=>o.ordinal=readI32()});}
