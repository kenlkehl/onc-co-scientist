+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) if (mask[i]) {
+      s += arr[i];
+      n += 1;
+    }
+  } else {
+    for (const v of arr) {
+      s += v;
+      n += 1;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, mask = null, mu = null) {
+  if (mu === null) mu = mean(arr, mask);
+  let ss = 0;
+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) if (mask[i]) {
+      const d = arr[i] - mu;
+      ss += d * d;
+      n += 1;
+    }
+  } else {
+    for (const v of arr) {
+      const d = v - mu;
+      ss += d * d;
+      n += 1;
+    }
+  }
+  return ss / (n - 1);
+}
+
+function normalCdf(x) {
+  // Abramowitz-Stegun approximation.
+  const sign = x < 0 ? -1 : 1;
+  const z = Math.abs(x) / Math.sqrt(2);
+  const t = 1 / (1 + 0.3275911 * z);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const erf = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-z * z);
+  return 0.5 * (1 + sign * erf);
+}
+
+function pFromZ(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function twoGroup(y, mask) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) {
+      n1 += 1;
+      s1 += y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) ss1 += (y[i] - m1) ** 2;
+    else ss0 += (y[i] - m0) ** 2;
+  }
+  const v1 = ss1 / (n1 - 1);
+  const v0 = ss0 / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, z, p: pFromZ(z) };
