@@ -0,0 +1,824 @@
+const fs = require("fs");
+
+const DATA_FILE = "dataset.parquet";
+const N = 50000;
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+  byte() {
+    return this.buf[this.pos++];
+  }
+  varint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      out |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return out;
+  }
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+  i64() {
+    return this.zigzag(this.varint());
+  }
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  binaryBuffer() {
+    const n = Number(this.varint());
+    const s = this.buf.subarray(this.pos, this.pos + n);
+    this.pos += n;
+    return s;
+  }
+  binary() {
+    return this.binaryBuffer().toString("utf8");
+  }
+  skip(t) {
+    if (t === 0) return;
+    if (t === 1 || t === 2) return;
+    if (t === 3) {
+      this.pos += 1;
+      return;
+    }
+    if (t === 4 || t === 5) {
+      this.i32();
+      return;
+    }
+    if (t === 6) {
+      this.i64();
+      return;
+    }
+    if (t === 7) {
+      this.pos += 8;
+      return;
+    }
+    if (t === 8) {
+      this.binaryBuffer();
+      return;
+    }
+    if (t === 9 || t === 10) {
+      const h = this.byte();
+      let size = h >> 4;
+      const et = h & 0xf;
+      if (size === 15) size = Number(this.varint());
+      for (let i = 0; i < size; i++) this.skip(et);
+      return;
+    }
+    if (t === 11) {
+      const h = this.byte();
+      if (h === 0) return;
+      const size = Number(this.varint());
+      const kt = (h >> 4) & 0xf;
+      const vt = h & 0xf;
+      for (let i = 0; i < size; i++) {
+        this.skip(kt);
+        this.skip(vt);
+      }
+      return;
+    }
+    if (t === 12) {
+      this.struct({});
+      return;
+    }
+    throw new Error(`Cannot skip compact type ${t} at ${this.pos}`);
+  }
+  list(readElem) {
+    const h = this.byte();
+    let size = h >> 4;
+    const et = h & 0xf;
+    if (size === 15) size = Number(this.varint());
+    const out = [];
+    for (let i = 0; i < size; i++) out.push(readElem(et));
+    return out;
+  }
+  struct(handlers) {
+    let last = 0;
+    const out = {};
+    while (true) {
+      const h = this.byte();
+      const t = h & 0xf;
+      if (t === 0) break;
+      const delta = h >> 4;
+      const fid = delta === 0 ? this.i32() : last + delta;
+      last = fid;
+      if (handlers[fid]) handlers[fid](t, out);
+      else this.skip(t);
+    }
+    return out;
+  }
+}
+
+function snappyUncompress(input, expected) {
+  let pos = 0;
+  function readVarint() {
+    let shift = 0;
+    let out = 0;
+    while (true) {
+      const b = input[pos++];
+      out |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return out;
+  }
+  const len = readVarint();
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let litLen = tag >> 2;
+      if (litLen < 60) {
+        litLen += 1;
+      } else {
+        const n = litLen - 59;
+        litLen = 1;
+        let v = 0;
+        for (let i = 0; i < n; i++) v |= input[pos++] << (8 * i);
+        litLen = v + 1;
