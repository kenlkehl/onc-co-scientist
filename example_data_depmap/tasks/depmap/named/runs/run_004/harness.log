+      let pos = 0;
+      const num = h.data_page_header.num_values;
+      // Optional scalar columns: definition levels are RLE hybrid with a 4-byte byte length.
+      const defLen = body.readUInt32LE(pos);
+      pos += 4;
+      const defs = readHybrid(body, pos, 1, num, defLen);
+      pos = defs.pos;
+      if (defs.values.some((v) => v !== 1)) {
+        throw new Error("Unexpected null definition level in no-missing dataset");
+      }
+      if (h.data_page_header.encoding === 8) {
+        const width = body[pos++];
+        const ids = readHybrid(body, pos, width, num);
+        for (const id of ids.values) values.push(dictionary[id]);
+      } else if (h.data_page_header.encoding === 0) {
+        values.push(...plainValues(body.subarray(pos), type, num));
+      } else {
+        throw new Error(`Unsupported data page encoding ${h.data_page_header.encoding}`);
+      }
+    } else if (h.type === 3) {
+      throw new Error("DataPageV2 not implemented");
+    } else {
+      throw new Error(`Unsupported page type ${h.type}`);
+    }
+    offset = bodyStart + h.compressed_page_size;
+  }
+  return values;
+}
+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) if (mask[i]) {
+      s += arr[i];
+      n += 1;
+    }
+  } else {
+    for (const v of arr) {
+      s += v;
+      n += 1;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, mask = null, mu = null) {
+  if (mu === null) mu = mean(arr, mask);
+  let ss = 0;
+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) if (mask[i]) {
+      const d = arr[i] - mu;
+      ss += d * d;
+      n += 1;
+    }
+  } else {
+    for (const v of arr) {
+      const d = v - mu;
+      ss += d * d;
+      n += 1;
+    }
+  }
+  return ss / (n - 1);
+}
+
+function normalCdf(x) {
+  // Abramowitz-Stegun approximation.
+  const sign = x < 0 ? -1 : 1;
+  const z = Math.abs(x) / Math.sqrt(2);
+  const t = 1 / (1 + 0.3275911 * z);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const erf = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-z * z);
+  return 0.5 * (1 + sign * erf);
+}
+
+function pFromZ(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function twoGroup(y, mask) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) {
+      n1 += 1;
+      s1 += y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) ss1 += (y[i] - m1) ** 2;
+    else ss0 += (y[i] - m0) ** 2;
+  }
+  const v1 = ss1 / (n1 - 1);
+  const v0 = ss0 / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, z, p: pFromZ(z) };
+}
+
+function totalStats(y) {
+  let sum = 0;
+  let sumsq = 0;
+  for (const v of y) {
+    sum += v;
+    sumsq += v * v;
+  }
+  return { n: y.length, sum, sumsq };
+}
+
+function twoGroupIndex(y, idx, totals = null) {
+  if (!totals) totals = totalStats(y);
+  const n1 = idx.length;
+  const n0 = totals.n - n1;
+  let s1 = 0;
+  let ss1 = 0;
+  for (const i of idx) {
+    const v = y[i];
+    s1 += v;
+    ss1 += v * v;
+  }
+  const s0 = totals.sum - s1;
+  const ss0 = totals.sumsq - ss1;
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - (s1 * s1) / n1) / (n1 - 1);
+  const v0 = (ss0 - (s0 * s0) / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, z, p: pFromZ(z) };
+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(M[r][col]) > Math.abs(M[pivot][col])) pivot = r;
+    if (Math.abs(M[pivot][col]) < 1e-12) throw new Error("singular matrix");
+    if (pivot !== col) [M[pivot], M[col]] = [M[col], M[pivot]];
+    const div = M[col][col];
+    for (let c = 0; c < 2 * n; c++) M[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = M[r][col];
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= f * M[col][c];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function ols(y, cols) {
+  const n = y.length;
+  const p = cols.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = cols[a][i];
+      xty[a] += xa * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += xa * cols[b][i];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += beta[j] * cols[j][i];
+    rss += (y[i] - pred) ** 2;
+  }
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const z = beta.map((b, i) => b / se[i]);
+  const pvals = z.map(pFromZ);
+  return { beta, se, z, p: pvals, rss };
+}
+
+function standardize(x) {
+  const mu = mean(x);
+  const sd = Math.sqrt(variance(x, null, mu));
+  return x.map((v) => (v - mu) / sd);
+}
+
+function quantile(x, q) {
+  const s = [...x].sort((a, b) => a - b);
+  const idx = (s.length - 1) * q;
+  const lo = Math.floor(idx);
+  const hi = Math.ceil(idx);
+  if (lo === hi) return s[lo];
+  return s[lo] * (hi - idx) + s[hi] * (idx - lo);
+}
+
+function maskFromPredicate(data, pred) {
+  return Array.from({ length: N }, (_, i) => pred(i, data));
+}
+
+function maskAnd(a, b) {
+  return a.map((v, i) => v && b[i]);
+}
+
+function maskNot(a) {
+  return a.map((v) => !v);
+}
+
+function countMask(m) {
+  return m.reduce((s, v) => s + (v ? 1 : 0), 0);
+}
+
+function makeFeatureMasks(data) {
+  const masks = [];
+  function addMask(item) {
+    item.idx = [];
+    for (let i = 0; i < item.mask.length; i++) if (item.mask[i]) item.idx.push(i);
+    item.n = item.idx.length;
+    masks.push(item);
+  }
+  const categorical = ["lineage", "lineage_subtype", "culture_type", "screen_batch"];
+  for (const c of categorical) {
+    const levels = [...new Set(data[c])];
+    for (const level of levels) {
+      const m = data[c].map((v) => v === level);
+      if (countMask(m) >= 250) addMask({ name: `${c}=${level}`, mask: m });
+    }
+  }
+  const binary = [
+    "kras_mutation", "braf_v600e", "egfr_amplification", "erbb2_amplification",
+    "pik3ca_mutation", "apc_mutation", "smad4_loss", "nf1_loss", "rb1_loss",
+    "myc_amplification", "cdkn2a_loss", "pten_loss", "stk11_loss", "brca2_loss", "msi_high"
+  ];
+  for (const c of binary) {
+    const m = data[c].map((v) => v === 1);
+    if (countMask(m) >= 250) addMask({ name: `${c}=1`, mask: m });
+  }
+  const continuous = [
+    "media_serum_pct", "cas9_activity_score", "growth_rate_doublings_per_day", "ploidy",
+    "aneuploidy_score", "mutation_burden", "wnt_activity_score", "emt_score",
+    "stemness_score", "ifn_gamma_signature", "hypoxia_score", "copy_number_8q24",
+    "copy_number_9p21", "rnaseq_MYC_log2_tpm", "rnaseq_AXL_log2_tpm",
+    "rnaseq_SLFN11_log2_tpm", "rnaseq_ASCL2_log2_tpm"
+  ];
+  for (const c of continuous) {
+    const q25 = quantile(data[c], 0.25);
+    const q75 = quantile(data[c], 0.75);
+    addMask({ name: `${c}>=Q75(${q75.toFixed(3)})`, mask: data[c].map((v) => v >= q75), feature: c, threshold: q75, direction: "high" });
+    addMask({ name: `${c}<=Q25(${q25.toFixed(3)})`, mask: data[c].map((v) => v <= q25), feature: c, threshold: q25, direction: "low" });
+  }
+  return masks;
+}
+
+function topSingleSubgroups(data, outcomes, masks) {
+  const out = {};
+  for (const yname of outcomes) {
+    const y = data[yname];
+    const totals = totalStats(y);
+    const rows = [];
+    for (const item of masks) {
+      const n1 = item.n;
+      if (n1 < 250 || n1 > N - 250) continue;
+      const r = twoGroupIndex(y, item.idx, totals);
+      rows.push({ outcome: yname, subgroup: item.name, ...r });
+    }
+    rows.sort((a, b) => a.effect - b.effect);
+    out[yname] = rows.slice(0, 20);
+  }
+  return out;
+}
+
+function pairSearch(data, outcome, masks, topN = 18) {
+  const y = data[outcome];
+  const totals = totalStats(y);
+  const candidates = [];
+  for (let i = 0; i < masks.length; i++) {
+    for (let j = i + 1; j < masks.length; j++) {
+      const a = masks[i].idx.length <= masks[j].idx.length ? masks[i] : masks[j];
+      const b = a === masks[i] ? masks[j] : masks[i];
+      const idx = [];
+      for (const row of a.idx) if (b.mask[row]) idx.push(row);
+      const n1 = idx.length;
+      if (n1 < 250 || n1 > N - 250) continue;
+      const r = twoGroupIndex(y, idx, totals);
+      candidates.push({ outcome, subgroup: `${masks[i].name} AND ${masks[j].name}`, parts: [masks[i].name, masks[j].name], ...r });
+    }
+  }
+  candidates.sort((a, b) => a.effect - b.effect);
+  return candidates.slice(0, topN);
+}
+
+function tripleSearch(data, outcome, baseParts, masks, topN = 10) {
+  const y = data[outcome];
+  const totals = totalStats(y);
+  const baseNames = new Set(baseParts);
+  const baseMask = masks.filter((x) => baseNames.has(x.name)).reduce((acc, x) => (acc ? maskAnd(acc, x.mask) : x.mask), null);
+  const baseIdx = [];
+  for (let i = 0; i < baseMask.length; i++) if (baseMask[i]) baseIdx.push(i);
+  const candidates = [];
+  for (const item of masks) {
+    if (baseNames.has(item.name)) continue;
+    const idx = [];
+    for (const row of baseIdx) if (item.mask[row]) idx.push(row);
+    const n1 = idx.length;
+    if (n1 < 150 || n1 > N - 150) continue;
+    const r = twoGroupIndex(y, idx, totals);
+    candidates.push({ outcome, subgroup: `${[...baseParts, item.name].join(" AND ")}`, parts: [...baseParts, item.name], ...r });
+  }
+  candidates.sort((a, b) => a.effect - b.effect);
+  return candidates.slice(0, topN);
+}
+
+function main() {
+  const file = fs.readFileSync(DATA_FILE);
+  const footer = readFooter(file);
+  const columns = footer.schema.slice(1).map((s) => s.name);
+  const rg = footer.row_groups[0];
+  const data = {};
+  for (let i = 0; i < columns.length; i++) {
+    data[columns[i]] = decodeColumn(file, rg.columns[i].meta_data);
+    if (data[columns[i]].length !== N) throw new Error(`${columns[i]} decoded ${data[columns[i]].length}`);
+    console.error(`decoded ${columns[i]}`);
+  }
+  const outcomes = columns.filter((c) => c.startsWith("dependency_"));
+  const featureMasks = makeFeatureMasks(data);
+  console.error(`made ${featureMasks.length} feature masks`);
+  const maskByName = Object.fromEntries(featureMasks.map((m) => [m.name, m]));
+  const single = topSingleSubgroups(data, outcomes, featureMasks);
+  console.error("single-feature scans complete");
+  const pairs = {};
+  for (const outcome of outcomes) {
+    const focusedMasks = single[outcome].slice(0, 16).map((r) => maskByName[r.subgroup]).filter(Boolean);
+    pairs[outcome] = pairSearch(data, outcome, focusedMasks, 12);
+    console.error(`pair scan complete ${outcome}`);
+  }
+  const triples = {
+    dependency_KIF18A: tripleSearch(data, "dependency_KIF18A", pairs.dependency_KIF18A[0].parts, featureMasks, 12),
+  };
+  console.error("triple scan complete");
+
+  const zcols = {};
+  for (const c of [
+    "media_serum_pct", "cas9_activity_score", "growth_rate_doublings_per_day", "ploidy",
+    "aneuploidy_score", "mutation_burden", "wnt_activity_score", "emt_score",
+    "stemness_score", "ifn_gamma_signature", "hypoxia_score", "copy_number_8q24",
+    "copy_number_9p21", "rnaseq_MYC_log2_tpm", "rnaseq_AXL_log2_tpm",
+    "rnaseq_SLFN11_log2_tpm", "rnaseq_ASCL2_log2_tpm"
+  ]) zcols[c] = standardize(data[c]);
+  console.error("standardized continuous covariates");
+
+  const regression = {};
+  function regOne(outcome, vars) {
+    const cols = [Array(N).fill(1)];
+    const names = ["Intercept"];
+    for (const v of vars) {
+      if (v.type === "raw") {
+        cols.push(data[v.name].map((x) => Number(x)));
+        names.push(v.name);
+      } else if (v.type === "std") {
+        cols.push(zcols[v.name]);
+        names.push(`${v.name}_z`);
+      } else if (v.type === "cat") {
+        cols.push(data[v.name].map((x) => x === v.level ? 1 : 0));
+        names.push(`${v.name}=${v.level}`);
+      } else if (v.type === "interaction") {
+        cols.push(v.a.map((x, i) => x * v.b[i]));
+        names.push(v.name);
+      }
+    }
+    const fit = ols(data[outcome], cols);
+    return names.map((name, i) => ({ name, beta: fit.beta[i], se: fit.se[i], z: fit.z[i], p: fit.p[i] }));
+  }
+  regression.BRAF = regOne("dependency_BRAF", [{ type: "raw", name: "braf_v600e" }]);
+  regression.EGFR = regOne("dependency_EGFR", [{ type: "raw", name: "egfr_amplification" }]);
+  regression.ERBB2 = regOne("dependency_ERBB2", [{ type: "raw", name: "erbb2_amplification" }]);
+  regression.KRAS = regOne("dependency_KRAS", [{ type: "raw", name: "kras_mutation" }]);
+  regression.RIT1 = regOne("dependency_RIT1", [{ type: "raw", name: "nf1_loss" }, { type: "raw", name: "kras_mutation" }]);
+  regression.TMED10 = regOne("dependency_TMED10", [{ type: "raw", name: "cdkn2a_loss" }]);
+  regression.DHX9 = regOne("dependency_DHX9", [{ type: "std", name: "rnaseq_SLFN11_log2_tpm" }]);
+  regression.POLR2A = regOne("dependency_POLR2A", [{ type: "std", name: "copy_number_9p21" }]);
+  regression.RPL11 = regOne("dependency_RPL11", [{ type: "raw", name: "myc_amplification" }, { type: "std", name: "rnaseq_MYC_log2_tpm" }]);
+  console.error("basic regressions complete");
+
+  const kHighAneu = data.aneuploidy_score.map((v) => v >= quantile(data.aneuploidy_score, 0.75) ? 1 : 0);
+  const kLowCas9 = data.cas9_activity_score.map((v) => v <= quantile(data.cas9_activity_score, 0.25) ? 1 : 0);
+  const kLineageLung = data.lineage.map((v) => v === "lung" ? 1 : 0);
+  regression.KIF18A_interaction = (() => {
+    const cols = [Array(N).fill(1), kHighAneu, kLowCas9, kLineageLung, kHighAneu.map((v, i) => v * kLowCas9[i]), kHighAneu.map((v, i) => v * kLineageLung[i])];
+    const names = ["Intercept", "aneuploidy_score>=Q75", "cas9_activity_score<=Q25", "lineage=lung", "high_aneuploidy:low_cas9", "high_aneuploidy:lung"];
+    const fit = ols(data.dependency_KIF18A, cols);
+    return names.map((name, i) => ({ name, beta: fit.beta[i], se: fit.se[i], z: fit.z[i], p: fit.p[i] }));
+  })();
+  console.error("interaction regression complete");
+
+  const summaries = {};
+  for (const c of columns) {
+    if (outcomes.includes(c) || c.startsWith("dependency_")) {
+      summaries[c] = { mean: mean(data[c]), sd: Math.sqrt(variance(data[c])) };
+    }
+  }
+  const counts = {};
+  for (const c of ["lineage", "lineage_subtype", "culture_type", "screen_batch"]) {
+    counts[c] = {};
+    for (const v of data[c]) counts[c][v] = (counts[c][v] || 0) + 1;
+  }
+
+  const results = { counts, summaries, single, pairs, triples, regression };
+  fs.writeFileSync("analysis_results.json", JSON.stringify(results, null, 2));
+  console.log(JSON.stringify({
+    counts,
+    topSingles: Object.fromEntries(outcomes.map((o) => [o, single[o].slice(0, 5)])),
+    topPairs: Object.fromEntries(outcomes.map((o) => [o, pairs[o].slice(0, 5)])),
+    topTriples: triples,
+    regression,
+  }, null, 2));
+}
+
+main();

diff --git a/example_data_depmap/tasks/depmap/named/parquet_depmap_analysis.js b/example_data_depmap/tasks/depmap/named/parquet_depmap_analysis.js
new file mode 100644
index 0000000000000000000000000000000000000000..ed785071b454588ba72d1d39c5af3447fe96d5a6
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/named/parquet_depmap_analysis.js
@@ -0,0 +1,829 @@
+const fs = require("fs");
+
+const DATA_FILE = "dataset.parquet";
+const N = 50000;
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+  byte() {
+    return this.buf[this.pos++];
+  }
+  varint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      out |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return out;
+  }
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+  i64() {
+    return this.zigzag(this.varint());
+  }
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  binaryBuffer() {
+    const n = Number(this.varint());
+    const s = this.buf.subarray(this.pos, this.pos + n);
+    this.pos += n;
+    return s;
+  }
+  binary() {
+    return this.binaryBuffer().toString("utf8");
+  }
+  skip(t) {
+    if (t === 0) return;
+    if (t === 1 || t === 2) return;
+    if (t === 3) {
+      this.pos += 1;
+      return;
+    }
+    if (t === 4 || t === 5) {
+      this.i32();
+      return;
+    }
+    if (t === 6) {
+      this.i64();
+      return;
+    }
+    if (t === 7) {
+      this.pos += 8;
+      return;
+    }
+    if (t === 8) {
+      this.binaryBuffer();
+      return;
+    }
+    if (t === 9 || t === 10) {
+      const h = this.byte();
+      let size = h >> 4;
+      const et = h & 0xf;
+      if (size === 15) size = Number(this.varint());
+      for (let i = 0; i < size; i++) this.skip(et);
+      return;
+    }
+    if (t === 11) {
+      const h = this.byte();
+      if (h === 0) return;
+      const size = Number(this.varint());
+      const kt = (h >> 4) & 0xf;
+      const vt = h & 0xf;
+      for (let i = 0; i < size; i++) {
+        this.skip(kt);
+        this.skip(vt);
+      }
+      return;
+    }
+    if (t === 12) {
+      this.struct({});
+      return;
+    }
+    throw new Error(`Cannot skip compact type ${t} at ${this.pos}`);
+  }
+  list(readElem) {
+    const h = this.byte();
+    let size = h >> 4;
+    const et = h & 0xf;
+    if (size === 15) size = Number(this.varint());
+    const out = [];
+    for (let i = 0; i < size; i++) out.push(readElem(et));
+    return out;
+  }
+  struct(handlers) {
+    let last = 0;
+    const out = {};
+    while (true) {
+      const h = this.byte();
