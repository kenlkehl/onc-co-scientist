+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) if (mask[i]) {
+      s += arr[i];
+      n += 1;
+    }
+  } else {
+    for (const v of arr) {
+      s += v;
+      n += 1;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, mask = null, mu = null) {
+  if (mu === null) mu = mean(arr, mask);
+  let ss = 0;
+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) if (mask[i]) {
+      const d = arr[i] - mu;
+      ss += d * d;
+      n += 1;
+    }
+  } else {
+    for (const v of arr) {
+      const d = v - mu;
+      ss += d * d;
+      n += 1;
+    }
+  }
+  return ss / (n - 1);
