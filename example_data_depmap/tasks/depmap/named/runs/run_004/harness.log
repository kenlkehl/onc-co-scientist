+
+function snappyUncompress(input, expected) {
+  let pos = 0;
+  function readVarint() {
+    let shift = 0;
+    let out = 0;
+    while (true) {
+      const b = input[pos++];
+      out |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return out;
+  }
