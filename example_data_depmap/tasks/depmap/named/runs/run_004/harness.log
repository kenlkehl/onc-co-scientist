print(df[outcomes].describe().T.to_string())
print('\\nbinary feature prevalences')
for c in df.columns:
    if df[c].dtype == bool or set(pd.unique(df[c])).issubset({0,1,False,True}):
        if c not in outcomes:
            print(c, df[c].mean())
