+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let litLen = tag >> 2;
+      if (litLen < 60) {
+        litLen += 1;
+      } else {
+        const n = litLen - 59;
+        litLen = 1;
+        let v = 0;
+        for (let i = 0; i < n; i++) v |= input[pos++] << (8 * i);
+        litLen = v + 1;
+      }
+      input.copy(out, op, pos, pos + litLen);
+      pos += litLen;
+      op += litLen;
+    } else {
