+  for (const yName of outcomeNames) {
+    const single = outcomeAnalyses[yName].topSingles[0];
+    const pair = outcomeAnalyses[yName].topPairs[0];
+    summaryLines.push(
+      `- ${yName}: best single predicate was ${single.pred.text}, mean ${fmt(single.mean1)} vs ${fmt(single.mean0)} (effect ${fmt(single.effect)}, p=${ptxt(single.p)}). Best pair was ${pair.a.pred.text} AND ${pair.b.pred.text}, mean ${fmt(pair.subgroup.mean1)} vs ${fmt(pair.subgroup.mean0)} (effect ${fmt(pair.subgroup.effect)}, interaction ${fmt(pair.interaction)}, interaction p=${ptxt(pair.p)}).`
+    );
+  }
+  summaryLines.push("");
+  summaryLines.push("Iteration-by-iteration synthesis:");
+  for (const it of iterations) {
+    summaryLines.push(`Iteration ${it.index}:`);
+    for (const hyp of it.proposed_hypotheses) summaryLines.push(`  Hypothesis ${hyp.id}: ${hyp.text}`);
+    for (const an of it.analyses) summaryLines.push(`  Result for ${an.hypothesis_ids.join(",")}: ${an.result_summary}`);
+  }
+  summaryLines.push("");
+  summaryLines.push("Conclusions:");
+  summaryLines.push("Classical oncogene dependencies were strongly supported: BRAF dependency tracked braf_v600e, EGFR dependency tracked egfr_amplification, ERBB2 dependency tracked erbb2_amplification, and KRAS dependency tracked kras_mutation. The pairwise screens sharpened some of these into lineage or subtype contexts, although not every pair had a statistically significant interaction term beyond the strong single-driver effect.");
+  const noncanonicalContexts = ["dependency_RIT1", "dependency_KIF18A", "dependency_TMED10", "dependency_DHX9", "dependency_POLR2A", "dependency_RPL11"]
+    .map((yName) => {
+      const pair = outcomeAnalyses[yName].topPairs[0];
+      return `${yName} in ${pair.a.pred.text} AND ${pair.b.pred.text}`;
+    })
+    .join("; ");
+  summaryLines.push(`Other dependencies showed distinct contexts in the final subgroup screen: ${noncanonicalContexts}. The best-supported effects are the signed subgroup differences reported above; weak starting ideas that were not supported were not retained as final conclusions.`);
+  summaryLines.push("All dependency outcomes received at least one systematic heterogeneity screen; all final refined subgroup hypotheses state the complete pair of predicates selected by that screen.");
+
+  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2) + "\n", "utf8");
+  fs.writeFileSync("analysis_summary.txt", summaryLines.join("\n") + "\n", "utf8");
+
+  console.log(`Wrote transcript.json and analysis_summary.txt`);
+  console.log(`Predicates screened: ${predicates.length}`);
+  for (const yName of outcomeNames) {
+    const s = outcomeAnalyses[yName].topSingles[0];
+    const p = outcomeAnalyses[yName].topPairs[0];
+    console.log(`${yName}: single ${s.pred.short} effect=${fmt(s.effect)} p=${ptxt(s.p)}; pair ${p.a.pred.short} & ${p.b.pred.short} effect=${fmt(p.subgroup.effect)} int=${fmt(p.interaction)} int_p=${ptxt(p.p)}`);
+  }
