+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(z) {
+  return 0.5 * (1 + erf(z / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  if (!Number.isFinite(z)) return 1;
+  const az = Math.abs(z);
+  if (az > 37) return 1e-300;
+  return Math.max(2 * (1 - normalCdf(az)), 1e-300);
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 100 || (Math.abs(x) > 0 && Math.abs(x) < 0.001)) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function ptxt(p) {
+  if (p <= 1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function quantile(values, q) {
+  const sorted = [...values].sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] * (hi - pos) + sorted[hi] * (pos - lo);
+}
+
+function uniqueValues(values) {
+  return [...new Set(values)];
+}
+
+function makeMask(n, pred) {
+  const mask = new Uint8Array(n);
+  let count = 0;
+  for (let i = 0; i < n; i++) {
+    if (pred(i)) {
+      mask[i] = 1;
+      count++;
+    }
+  }
+  return { mask, count };
+}
+
+function compareMask(y, mask) {
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    const v = y[i];
+    if (mask[i]) {
+      n1++;
+      s1 += v;
+      ss1 += v * v;
+    } else {
+      n0++;
+      s0 += v;
+      ss0 += v * v;
+    }
+  }
+  const mean1 = s1 / n1;
+  const mean0 = s0 / n0;
+  const var1 = varianceFromSums(s1, ss1, n1);
+  const var0 = varianceFromSums(s0, ss0, n0);
+  const se = Math.sqrt(var1 / n1 + var0 / n0);
+  const effect = mean1 - mean0;
+  const z = effect / se;
+  const p = pFromZ(z);
+  return { n1, n0, mean1, mean0, var1, var0, effect, se, z, p, significant: p < 0.05 };
+}
+
+function linearRegression(y, x) {
+  const n = y.length;
+  let sx = 0, sy = 0, sxx = 0, sxy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+    sxx += x[i] * x[i];
+    sxy += x[i] * y[i];
+  }
+  const xbar = sx / n;
+  const ybar = sy / n;
+  const sxxc = sxx - n * xbar * xbar;
+  const sxyc = sxy - n * xbar * ybar;
+  const slope = sxyc / sxxc;
+  const intercept = ybar - slope * xbar;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    rss += e * e;
+  }
+  const mse = rss / (n - 2);
+  const se = Math.sqrt(mse / sxxc);
+  const z = slope / se;
+  const p = pFromZ(z);
+  return { slope, intercept, se, z, p, significant: p < 0.05 };
+}
+
+function interactionStats(y, maskA, maskB) {
+  const cells = [
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+  ];
+  for (let i = 0; i < y.length; i++) {
+    const idx = (maskA[i] ? 2 : 0) + (maskB[i] ? 1 : 0);
+    const v = y[i];
+    cells[idx].n++;
+    cells[idx].s += v;
+    cells[idx].ss += v * v;
+  }
+  if (cells.some((c) => c.n < 25)) return null;
+  for (const c of cells) {
+    c.mean = c.s / c.n;
+    c.var = varianceFromSums(c.s, c.ss, c.n);
+  }
+  const interaction = cells[3].mean - cells[2].mean - cells[1].mean + cells[0].mean;
+  let rss = 0;
+  let df = 0;
+  for (const c of cells) {
+    rss += c.var * (c.n - 1);
+    df += c.n - 1;
+  }
+  const mse = rss / df;
+  const se = Math.sqrt(mse * (1 / cells[3].n + 1 / cells[2].n + 1 / cells[1].n + 1 / cells[0].n));
+  const z = interaction / se;
+  const p = pFromZ(z);
+  const both = cells[3];
+  const rest = {
+    n: cells[0].n + cells[1].n + cells[2].n,
+    s: cells[0].s + cells[1].s + cells[2].s,
+    ss: cells[0].ss + cells[1].ss + cells[2].ss,
+  };
+  rest.mean = rest.s / rest.n;
+  rest.var = varianceFromSums(rest.s, rest.ss, rest.n);
+  const subgroupEffect = both.mean - rest.mean;
+  const subgroupSe = Math.sqrt(both.var / both.n + rest.var / rest.n);
+  const subgroupZ = subgroupEffect / subgroupSe;
+  const subgroup = {
+    n1: both.n,
+    n0: rest.n,
+    mean1: both.mean,
+    mean0: rest.mean,
+    var1: both.var,
+    var0: rest.var,
+    effect: subgroupEffect,
+    se: subgroupSe,
+    z: subgroupZ,
+    p: pFromZ(subgroupZ),
+    significant: pFromZ(subgroupZ) < 0.05,
+  };
+  return { cells, interaction, se, z, p, subgroup };
+}
+
+function buildPredicates(cols, n, featureNames) {
+  const predicates = [];
+  const categorical = new Set(["lineage", "lineage_subtype", "culture_type", "screen_batch"]);
+  for (const name of featureNames) {
+    const values = cols[name];
+    const uniq = uniqueValues(values);
+    if (categorical.has(name)) {
+      for (const level of uniq) {
+        const { mask, count } = makeMask(n, (i) => values[i] === level);
+        if (count >= 200 && count <= n - 200) {
+          predicates.push({
+            id: `${name}=${level}`,
+            text: `\`${name}\` is ${JSON.stringify(level)}`,
+            short: `${name}=${level}`,
+            mask,
+            count,
+            variable: name,
+          });
+        }
+      }
+    } else if (uniq.length <= 3 && uniq.every((v) => Number.isFinite(v))) {
+      for (const level of uniq) {
+        const { mask, count } = makeMask(n, (i) => values[i] === level);
+        if (count >= 200 && count <= n - 200) {
+          predicates.push({
+            id: `${name}=${level}`,
+            text: `\`${name}\` equals ${level}`,
+            short: `${name}=${level}`,
+            mask,
+            count,
+            variable: name,
+          });
+        }
+      }
+    } else if (uniq.every((v) => Number.isFinite(v))) {
+      const q25 = quantile(values, 0.25);
+      const q75 = quantile(values, 0.75);
+      const hi = makeMask(n, (i) => values[i] >= q75);
+      const lo = makeMask(n, (i) => values[i] <= q25);
+      predicates.push({
+        id: `${name}>=${q75}`,
+        text: `\`${name}\` is high (>= ${fmt(q75, 3)})`,
+        short: `${name}>=q75`,
+        mask: hi.mask,
+        count: hi.count,
+        variable: name,
+        threshold: q75,
+      });
+      predicates.push({
+        id: `${name}<=${q25}`,
+        text: `\`${name}\` is low (<= ${fmt(q25, 3)})`,
+        short: `${name}<=q25`,
+        mask: lo.mask,
+        count: lo.count,
+        variable: name,
+        threshold: q25,
+      });
+    }
+  }
+  return predicates;
+}
+
+function analyzeOutcome(cols, yName, predicates, n) {
+  const y = cols[yName];
+  const single = [];
+  for (const pred of predicates) {
+    const stat = compareMask(y, pred.mask);
+    single.push({ pred, ...stat });
+  }
+  single.sort((a, b) => a.mean1 - b.mean1);
+
+  const candidatePool = [...single].filter((s) => s.n1 >= 200 && s.n0 >= 200);
+  const pairResults = [];
+  for (let a = 0; a < candidatePool.length; a++) {
+    for (let b = a + 1; b < candidatePool.length; b++) {
+      const pa = candidatePool[a].pred;
+      const pb = candidatePool[b].pred;
+      if (pa.variable === pb.variable) continue;
+      const inter = interactionStats(y, pa.mask, pb.mask);
+      if (!inter || inter.subgroup.n1 < 100 || inter.subgroup.n0 < 100) continue;
+      pairResults.push({ a: candidatePool[a], b: candidatePool[b], ...inter });
+    }
+  }
+  pairResults.sort((x, y) => {
+    const xScore = x.subgroup.mean1 + 0.35 * x.interaction;
+    const yScore = y.subgroup.mean1 + 0.35 * y.interaction;
+    return xScore - yScore;
+  });
+
+  const continuous = predicates.filter((p) => p.short.endsWith(">=q75") || p.short.endsWith("<=q25"));
+  const lineageSingles = single.filter((s) => s.pred.variable === "lineage").sort((a, b) => a.mean1 - b.mean1);
+  return {
+    yName,
+    mean: mean(y),
+    sd: Math.sqrt(varianceFromSums(y.reduce((a, v) => a + v, 0), y.reduce((a, v) => a + v * v, 0), y.length)),
+    single,
+    topSingles: single.slice(0, 8),
+    topPairs: pairResults.slice(0, 8),
+    lineageSingles: lineageSingles.slice(0, 6),
+    continuousCount: continuous.length,
+  };
+}
+
+function safeEffect(e) {
+  if (!Number.isFinite(e)) return null;
+  return Number(e.toPrecision(8));
+}
+
+function makeAnalysis(hypIds, code, summary, stat, extra = {}) {
+  return {
+    hypothesis_ids: hypIds,
+    code,
+    result_summary: summary,
+    p_value: safeEffect(stat.p),
+    effect_estimate: safeEffect(stat.effect ?? stat.slope ?? stat.interaction),
+    significant: stat.p < 0.05,
+    ...extra,
+  };
+}
