+function readStruct(r, handlers) {
+  const obj = {};
+  r.push();
+  while (true) {
+    const f = r.field();
+    if (!f) break;
+    if (handlers[f.fid]) handlers[f.fid](r, f.type, obj);
+    else r.skip(f.type);
+  }
+  r.pop();
+  return obj;
+}
+
