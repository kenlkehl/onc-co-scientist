+        return;
+      case 4:
+      case 5:
+        this.i32();
+        return;
+      case 6:
+        this.i64();
+        return;
+      case 7:
+        this.dbl();
+        return;
+      case 8:
+        this.bin();
+        return;
+      case 9:
+      case 10: {
