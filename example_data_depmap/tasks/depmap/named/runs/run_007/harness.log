+  }
+
+  const h = {};
+  const iterations = [];
+
+  h.h1 = {
+    id: "h1",
+    text: "Cell lines with `braf_v600e` equals 1 have more negative `dependency_BRAF` scores than cell lines with `braf_v600e` equals 0.",
+    kind: "novel",
+  };
+  const braf = statFor("dependency_BRAF", "braf_v600e=1");
+  const brafLineage = topPair("dependency_BRAF", "braf_v600e=1");
+  h.h2 = {
+    id: "h2",
+    text: `The strongest BRAF dependency subgroup is cell lines where ${brafLineage.a.pred.text} and ${brafLineage.b.pred.text}; this subgroup has more negative \`dependency_BRAF\` than all other cell lines.`,
+    kind: "refined",
+  };
+  iterations.push({
+    index: 1,
+    proposed_hypotheses: [h.h1, h.h2],
+    analyses: [
+      makeAnalysis(
+        ["h1"],
+        "Welch comparison: dependency_BRAF by braf_v600e == 1 versus 0.",
+        `Mean dependency_BRAF was ${fmt(braf.mean1)} when braf_v600e=1 (n=${braf.n1}) versus ${fmt(braf.mean0)} otherwise; effect=${fmt(braf.effect)}, p=${ptxt(braf.p)}.`,
+        braf,
+        { n_subgroup: braf.n1, mean_subgroup: safeEffect(braf.mean1), mean_reference: safeEffect(braf.mean0) }
+      ),
+      makeAnalysis(
+        ["h2"],
+        `Systematic pairwise subgroup screen over ${predicates.length} feature predicates; reported top BRAF pair.`,
+        `Top BRAF subgroup screen result: ${brafLineage.a.pred.text} AND ${brafLineage.b.pred.text} had mean dependency_BRAF ${fmt(brafLineage.subgroup.mean1)} (n=${brafLineage.subgroup.n1}) versus ${fmt(brafLineage.subgroup.mean0)} otherwise; subgroup effect=${fmt(brafLineage.subgroup.effect)}, interaction=${fmt(brafLineage.interaction)}, interaction p=${ptxt(brafLineage.p)}.`,
+        brafLineage.subgroup,
+        { interaction_effect_estimate: safeEffect(brafLineage.interaction), interaction_p_value: safeEffect(brafLineage.p) }
+      ),
+    ],
+  });
+
+  h.h3 = {
+    id: "h3",
+    text: "Cell lines with `egfr_amplification` equals 1 have more negative `dependency_EGFR` scores than cell lines without `egfr_amplification`.",
+    kind: "novel",
+  };
+  const egfr = statFor("dependency_EGFR", "egfr_amplification=1");
+  const egfrPair = topPair("dependency_EGFR", "egfr_amplification=1");
+  h.h4 = {
+    id: "h4",
+    text: `EGFR dependency is concentrated in the subgroup where ${egfrPair.a.pred.text} and ${egfrPair.b.pred.text}; this subgroup has more negative \`dependency_EGFR\` than other cell lines.`,
+    kind: "refined",
+  };
+  iterations.push({
+    index: 2,
+    proposed_hypotheses: [h.h3, h.h4],
+    analyses: [
+      makeAnalysis(
+        ["h3"],
+        "Welch comparison: dependency_EGFR by egfr_amplification == 1 versus 0.",
+        `Mean dependency_EGFR was ${fmt(egfr.mean1)} for egfr_amplification=1 (n=${egfr.n1}) versus ${fmt(egfr.mean0)} otherwise; effect=${fmt(egfr.effect)}, p=${ptxt(egfr.p)}.`,
+        egfr,
+        { n_subgroup: egfr.n1, mean_subgroup: safeEffect(egfr.mean1), mean_reference: safeEffect(egfr.mean0) }
+      ),
+      makeAnalysis(
+        ["h4"],
+        `Systematic pairwise subgroup screen over ${predicates.length} feature predicates; reported top EGFR pair.`,
+        `Top EGFR subgroup screen result: ${egfrPair.a.pred.text} AND ${egfrPair.b.pred.text} had mean dependency_EGFR ${fmt(egfrPair.subgroup.mean1)} (n=${egfrPair.subgroup.n1}) versus ${fmt(egfrPair.subgroup.mean0)} otherwise; subgroup effect=${fmt(egfrPair.subgroup.effect)}, interaction=${fmt(egfrPair.interaction)}, interaction p=${ptxt(egfrPair.p)}.`,
