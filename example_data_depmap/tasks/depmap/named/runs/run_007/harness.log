+const fs = require("fs");
+
+const DATASET_ID = "ds001_depmap";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-direct-js-parquet@2026-05-04";
+const MAX_ITERATIONS = 10;
+
+class CompactReader {
+  constructor(buffer, offset = 0) {
+    this.b = buffer;
+    this.i = offset;
+    this.last = [];
+  }
+  byte() {
+    if (this.i >= this.b.length) throw new Error("Unexpected EOF");
+    return this.b[this.i++];
+  }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const x = this.byte();
+      result |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  i32() {
+    return this.zigzag(this.varint());
+  }
+  i64() {
+    const n = this.varint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  bin() {
+    const len = Number(this.varint());
+    const out = this.b.slice(this.i, this.i + len);
+    this.i += len;
+    return out;
+  }
+  str() {
+    return this.bin().toString("utf8");
+  }
+  dbl() {
+    const v = this.b.readDoubleLE(this.i);
+    this.i += 8;
+    return v;
+  }
+  flt() {
+    const v = this.b.readFloatLE(this.i);
+    this.i += 4;
+    return v;
+  }
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const etype = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, etype };
+  }
+  field() {
+    const h = this.byte();
+    if (h === 0) return null;
+    const type = h & 0x0f;
+    const delta = h >> 4;
+    let fid;
+    if (delta === 0) fid = this.i32();
+    else fid = (this.last[this.last.length - 1] || 0) + delta;
+    this.last[this.last.length - 1] = fid;
+    return { type, fid };
+  }
+  push() {
+    this.last.push(0);
+  }
+  pop() {
+    this.last.pop();
+  }
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.byte();
+        return;
+      case 4:
+      case 5:
+        this.i32();
+        return;
+      case 6:
+        this.i64();
+        return;
+      case 7:
+        this.dbl();
+        return;
+      case 8:
+        this.bin();
+        return;
+      case 9:
+      case 10: {
+        const { size, etype } = this.listHeader();
+        for (let j = 0; j < size; j++) this.skip(etype);
+        return;
+      }
+      case 11: {
+        const size = Number(this.varint());
+        if (size > 0) {
+          const ktvt = this.byte();
+          const kt = ktvt >> 4;
+          const vt = ktvt & 0x0f;
+          for (let j = 0; j < size; j++) {
+            this.skip(kt);
+            this.skip(vt);
+          }
+        }
+        return;
+      }
+      case 12:
+        this.push();
+        while (true) {
+          const f = this.field();
+          if (!f) break;
+          this.skip(f.type);
+        }
+        this.pop();
+        return;
+      case 13:
+        this.flt();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.i}`);
+    }
+  }
+}
+
+function readStruct(r, handlers) {
+  const obj = {};
+  r.push();
+  while (true) {
+    const f = r.field();
+    if (!f) break;
+    if (handlers[f.fid]) handlers[f.fid](r, f.type, obj);
+    else r.skip(f.type);
+  }
+  r.pop();
+  return obj;
+}
+
+function readList(r, itemReader) {
+  const { size, etype } = r.listHeader();
+  const out = [];
+  for (let j = 0; j < size; j++) out.push(itemReader(r, etype));
+  return out;
+}
+
+function intList(r) {
+  return readList(r, (rr) => rr.i32());
+}
+
+function strList(r) {
+  return readList(r, (rr) => rr.str());
+}
+
+function schemaElement(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.type = r.i32()),
+    2: (r, t, o) => (o.type_length = r.i32()),
+    3: (r, t, o) => (o.repetition_type = r.i32()),
+    4: (r, t, o) => (o.name = r.str()),
+    5: (r, t, o) => (o.num_children = r.i32()),
+    6: (r, t, o) => (o.converted_type = r.i32()),
+    7: (r, t, o) => (o.scale = r.i32()),
+    8: (r, t, o) => (o.precision = r.i32()),
+    9: (r, t, o) => (o.field_id = r.i32()),
+  });
+}
+
+function columnMeta(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.type = r.i32()),
+    2: (r, t, o) => (o.encodings = intList(r)),
+    3: (r, t, o) => (o.path = strList(r)),
+    4: (r, t, o) => (o.codec = r.i32()),
+    5: (r, t, o) => (o.num_values = Number(r.i64())),
+    6: (r, t, o) => (o.total_uncompressed_size = Number(r.i64())),
+    7: (r, t, o) => (o.total_compressed_size = Number(r.i64())),
+    9: (r, t, o) => (o.data_page_offset = Number(r.i64())),
+    10: (r, t, o) => (o.index_page_offset = Number(r.i64())),
+    11: (r, t, o) => (o.dictionary_page_offset = Number(r.i64())),
+  });
+}
+
+function columnChunk(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.file_path = r.str()),
+    2: (r, t, o) => (o.file_offset = Number(r.i64())),
+    3: (r, t, o) => (o.meta = columnMeta(r)),
+  });
+}
+
+function rowGroup(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.columns = readList(r, (rr) => columnChunk(rr))),
+    2: (r, t, o) => (o.total_byte_size = Number(r.i64())),
+    3: (r, t, o) => (o.num_rows = Number(r.i64())),
+    5: (r, t, o) => (o.file_offset = Number(r.i64())),
+    6: (r, t, o) => (o.total_compressed_size = Number(r.i64())),
+  });
+}
+
+function fileMeta(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.version = r.i32()),
+    2: (r, t, o) => (o.schema = readList(r, (rr) => schemaElement(rr))),
+    3: (r, t, o) => (o.num_rows = Number(r.i64())),
+    4: (r, t, o) => (o.row_groups = readList(r, (rr) => rowGroup(rr))),
+    6: (r, t, o) => (o.created_by = r.str()),
+  });
+}
+
+function dataPageHeader(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.num_values = r.i32()),
+    2: (r, t, o) => (o.encoding = r.i32()),
+    3: (r, t, o) => (o.definition_level_encoding = r.i32()),
+    4: (r, t, o) => (o.repetition_level_encoding = r.i32()),
+  });
+}
+
+function dictionaryPageHeader(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.num_values = r.i32()),
+    2: (r, t, o) => (o.encoding = r.i32()),
+    3: (r, t, o) => (o.is_sorted = t === 1 ? true : t === 2 ? false : Boolean(r.i32())),
+  });
+}
+
+function dataPageHeaderV2(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.num_values = r.i32()),
+    2: (r, t, o) => (o.num_nulls = r.i32()),
+    3: (r, t, o) => (o.num_rows = r.i32()),
+    4: (r, t, o) => (o.encoding = r.i32()),
+    5: (r, t, o) => (o.definition_levels_byte_length = r.i32()),
+    6: (r, t, o) => (o.repetition_levels_byte_length = r.i32()),
+    7: (r, t, o) => (o.is_compressed = t === 1 ? true : t === 2 ? false : Boolean(r.i32())),
+  });
+}
+
+function pageHeader(buffer, offset) {
+  const r = new CompactReader(buffer, offset);
+  const h = readStruct(r, {
+    1: (r, t, o) => (o.type = r.i32()),
+    2: (r, t, o) => (o.uncompressed_page_size = r.i32()),
+    3: (r, t, o) => (o.compressed_page_size = r.i32()),
+    5: (r, t, o) => (o.data_page_header = dataPageHeader(r)),
+    7: (r, t, o) => (o.dictionary_page_header = dictionaryPageHeader(r)),
+    8: (r, t, o) => (o.data_page_header_v2 = dataPageHeaderV2(r)),
+  });
+  h.header_len = r.i - offset;
+  h.data_start = r.i;
+  return h;
+}
+
+function readUnsignedVarint(buffer, state) {
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = buffer[state.pos++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return result;
+}
+
+function snappyUncompress(input, expectedSize) {
+  const state = { pos: 0 };
+  const outLen = readUnsignedVarint(input, state);
+  const out = Buffer.alloc(outLen);
+  let op = 0;
+  while (state.pos < input.length) {
+    const tag = input[state.pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let len;
+      if (lenCode < 60) {
+        len = lenCode + 1;
+      } else {
+        const nbytes = lenCode - 59;
+        let v = 0;
+        for (let j = 0; j < nbytes; j++) v |= input[state.pos++] << (8 * j);
+        len = v + 1;
+      }
+      input.copy(out, op, state.pos, state.pos + len);
+      state.pos += len;
+      op += len;
+    } else {
+      let len, offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[state.pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[state.pos] | (input[state.pos + 1] << 8);
+        state.pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset =
+          input[state.pos] |
+          (input[state.pos + 1] << 8) |
+          (input[state.pos + 2] << 16) |
+          (input[state.pos + 3] << 24);
+        state.pos += 4;
+      }
+      for (let j = 0; j < len; j++) out[op + j] = out[op - offset + j];
+      op += len;
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch ${op} != ${outLen}`);
+  if (expectedSize != null && outLen !== expectedSize) {
+    throw new Error(`Snappy expected ${expectedSize} but got ${outLen}`);
+  }
+  return out;
+}
+
+function decompress(codec, pageBytes, expectedSize) {
+  if (codec === 0) return pageBytes;
+  if (codec === 1) return snappyUncompress(pageBytes, expectedSize);
+  throw new Error(`Unsupported compression codec ${codec}`);
+}
+
+function decodePlainValues(type, payload, count) {
+  const values = [];
+  let pos = 0;
+  if (type === 6) {
+    for (let i = 0; i < count; i++) {
+      const len = payload.readInt32LE(pos);
+      pos += 4;
+      values.push(payload.slice(pos, pos + len).toString("utf8"));
+      pos += len;
+    }
+  } else if (type === 5) {
+    for (let i = 0; i < count; i++, pos += 8) values.push(payload.readDoubleLE(pos));
+  } else if (type === 2) {
+    for (let i = 0; i < count; i++, pos += 8) values.push(Number(payload.readBigInt64LE(pos)));
+  } else if (type === 1) {
+    for (let i = 0; i < count; i++, pos += 4) values.push(payload.readInt32LE(pos));
+  } else if (type === 0) {
+    for (let i = 0; i < count; i++) values.push(Boolean((payload[Math.floor(i / 8)] >> (i % 8)) & 1));
+  } else {
+    throw new Error(`Unsupported plain parquet type ${type}`);
+  }
+  return values;
+}
+
+function readLittleInt(buffer, pos, width) {
+  let value = 0;
+  for (let j = 0; j < width; j++) value |= buffer[pos + j] << (8 * j);
+  return value;
+}
+
+function decodeRleBitpackedWithPosition(payload, bitWidth, count) {
+  if (bitWidth === 0) return { values: new Array(count).fill(0), position: 0 };
+  const out = [];
+  const state = { pos: 0 };
+  const byteWidth = Math.ceil(bitWidth / 8);
+  while (out.length < count && state.pos < payload.length) {
+    const header = readUnsignedVarint(payload, state);
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      const value = readLittleInt(payload, state.pos, byteWidth);
+      state.pos += byteWidth;
+      for (let j = 0; j < runLen && out.length < count; j++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bitPos = state.pos * 8;
+      for (let j = 0; j < total && out.length < count; j++) {
+        let value = 0;
+        for (let bit = 0; bit < bitWidth; bit++) {
+          const byte = payload[bitPos >> 3];
+          const b = (byte >> (bitPos & 7)) & 1;
+          value |= b << bit;
+          bitPos++;
+        }
+        out.push(value);
+      }
+      state.pos += Math.ceil((total * bitWidth) / 8);
+    }
+  }
+  if (out.length !== count) throw new Error(`Decoded ${out.length} values, expected ${count}`);
+  return { values: out, position: state.pos };
+}
+
+function decodeRleBitpacked(payload, bitWidth, count) {
+  return decodeRleBitpackedWithPosition(payload, bitWidth, count).values;
+}
+
+function readParquet(path) {
+  const buffer = fs.readFileSync(path);
+  if (buffer.slice(0, 4).toString() !== "PAR1" || buffer.slice(buffer.length - 4).toString() !== "PAR1") {
+    throw new Error("Not a Parquet file");
+  }
+  const footerLen = buffer.readUInt32LE(buffer.length - 8);
+  const meta = fileMeta(new CompactReader(buffer, buffer.length - 8 - footerLen));
+  const fieldSchemas = meta.schema.slice(1);
+  const rowGroup = meta.row_groups[0];
+  const columns = {};
+  for (let colIndex = 0; colIndex < rowGroup.columns.length; colIndex++) {
+    const col = rowGroup.columns[colIndex].meta;
+    const field = fieldSchemas[colIndex];
+    const name = col.path[col.path.length - 1];
+    const values = [];
+    let dict = null;
+    let offset = col.dictionary_page_offset || col.data_page_offset;
+    while (values.length < col.num_values) {
+      const h = pageHeader(buffer, offset);
+      const compressed = buffer.slice(h.data_start, h.data_start + h.compressed_page_size);
+      const payload = decompress(col.codec, compressed, h.uncompressed_page_size);
+      if (h.type === 2) {
+        dict = decodePlainValues(col.type, payload, h.dictionary_page_header.num_values);
+      } else if (h.type === 0) {
+        const count = h.data_page_header.num_values;
+        let valuePayload = payload;
+        if (field.repetition_type === 1) {
+          let decodedLevels = decodeRleBitpackedWithPosition(payload, 1, count);
+          let levelEnd = decodedLevels.position;
+          if (decodedLevels.values.some((v) => v !== 1) && payload.length >= 4) {
+            const prefixedLen = payload.readInt32LE(0);
+            if (prefixedLen > 0 && prefixedLen < payload.length) {
+              decodedLevels = decodeRleBitpackedWithPosition(payload.slice(4, 4 + prefixedLen), 1, count);
+              levelEnd = 4 + prefixedLen;
+            }
+          }
+          if (decodedLevels.values.some((v) => v !== 1)) {
+            throw new Error(`Null values are not supported in ${name}`);
+          }
+          valuePayload = payload.slice(levelEnd);
+        }
+        if (h.data_page_header.encoding === 8 || h.data_page_header.encoding === 3) {
+          if (!dict) throw new Error(`Dictionary missing for ${name}`);
+          const bitWidth = valuePayload[0];
+          const indices = decodeRleBitpacked(valuePayload.slice(1), bitWidth, count);
+          for (const idx of indices) values.push(dict[idx]);
+        } else if (h.data_page_header.encoding === 0) {
+          values.push(...decodePlainValues(col.type, valuePayload, count));
+        } else {
+          throw new Error(`Unsupported data encoding ${h.data_page_header.encoding} for ${name}`);
+        }
+      } else if (h.type === 3) {
+        const header = h.data_page_header_v2;
+        let data = payload;
+        const levelBytes = (header.definition_levels_byte_length || 0) + (header.repetition_levels_byte_length || 0);
+        if (levelBytes > 0) data = data.slice(levelBytes);
+        if (header.encoding === 8 || header.encoding === 3) {
+          const bitWidth = data[0];
+          const indices = decodeRleBitpacked(data.slice(1), bitWidth, header.num_values);
+          for (const idx of indices) values.push(dict[idx]);
+        } else if (header.encoding === 0) {
+          values.push(...decodePlainValues(col.type, data, header.num_values));
+        } else {
+          throw new Error(`Unsupported v2 encoding ${header.encoding} for ${name}`);
+        }
+      } else {
+        throw new Error(`Unsupported page type ${h.type}`);
+      }
+      offset = h.data_start + h.compressed_page_size;
+    }
+    if (values.length !== col.num_values) throw new Error(`${name}: expected ${col.num_values}, got ${values.length}`);
+    columns[name] = values;
+  }
+  return { meta, columns, schema: fieldSchemas, n: meta.num_rows };
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function varianceFromSums(sum, sumSq, n) {
+  if (n <= 1) return 0;
+  return Math.max((sumSq - (sum * sum) / n) / (n - 1), 0);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(z) {
+  return 0.5 * (1 + erf(z / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  if (!Number.isFinite(z)) return 1;
+  const az = Math.abs(z);
+  if (az > 37) return 1e-300;
+  return Math.max(2 * (1 - normalCdf(az)), 1e-300);
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 100 || (Math.abs(x) > 0 && Math.abs(x) < 0.001)) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function ptxt(p) {
+  if (p <= 1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function quantile(values, q) {
+  const sorted = [...values].sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] * (hi - pos) + sorted[hi] * (pos - lo);
+}
+
+function uniqueValues(values) {
+  return [...new Set(values)];
+}
+
+function makeMask(n, pred) {
+  const mask = new Uint8Array(n);
+  let count = 0;
+  for (let i = 0; i < n; i++) {
+    if (pred(i)) {
+      mask[i] = 1;
+      count++;
+    }
+  }
+  return { mask, count };
+}
+
+function compareMask(y, mask) {
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    const v = y[i];
+    if (mask[i]) {
+      n1++;
+      s1 += v;
+      ss1 += v * v;
+    } else {
+      n0++;
+      s0 += v;
+      ss0 += v * v;
+    }
+  }
+  const mean1 = s1 / n1;
+  const mean0 = s0 / n0;
+  const var1 = varianceFromSums(s1, ss1, n1);
+  const var0 = varianceFromSums(s0, ss0, n0);
+  const se = Math.sqrt(var1 / n1 + var0 / n0);
+  const effect = mean1 - mean0;
+  const z = effect / se;
+  const p = pFromZ(z);
+  return { n1, n0, mean1, mean0, var1, var0, effect, se, z, p, significant: p < 0.05 };
+}
+
+function linearRegression(y, x) {
+  const n = y.length;
+  let sx = 0, sy = 0, sxx = 0, sxy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+    sxx += x[i] * x[i];
+    sxy += x[i] * y[i];
+  }
+  const xbar = sx / n;
+  const ybar = sy / n;
+  const sxxc = sxx - n * xbar * xbar;
+  const sxyc = sxy - n * xbar * ybar;
+  const slope = sxyc / sxxc;
+  const intercept = ybar - slope * xbar;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    rss += e * e;
+  }
+  const mse = rss / (n - 2);
+  const se = Math.sqrt(mse / sxxc);
+  const z = slope / se;
+  const p = pFromZ(z);
+  return { slope, intercept, se, z, p, significant: p < 0.05 };
+}
+
+function interactionStats(y, maskA, maskB) {
+  const cells = [
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+  ];
+  for (let i = 0; i < y.length; i++) {
+    const idx = (maskA[i] ? 2 : 0) + (maskB[i] ? 1 : 0);
+    const v = y[i];
+    cells[idx].n++;
+    cells[idx].s += v;
+    cells[idx].ss += v * v;
+  }
+  if (cells.some((c) => c.n < 25)) return null;
+  for (const c of cells) {
+    c.mean = c.s / c.n;
+    c.var = varianceFromSums(c.s, c.ss, c.n);
+  }
+  const interaction = cells[3].mean - cells[2].mean - cells[1].mean + cells[0].mean;
+  let rss = 0;
+  let df = 0;
+  for (const c of cells) {
+    rss += c.var * (c.n - 1);
+    df += c.n - 1;
+  }
+  const mse = rss / df;
+  const se = Math.sqrt(mse * (1 / cells[3].n + 1 / cells[2].n + 1 / cells[1].n + 1 / cells[0].n));
+  const z = interaction / se;
+  const p = pFromZ(z);
+  const bothMask = new Uint8Array(y.length);
+  for (let i = 0; i < y.length; i++) bothMask[i] = maskA[i] && maskB[i] ? 1 : 0;
+  const subgroup = compareMask(y, bothMask);
+  return { cells, interaction, se, z, p, subgroup };
+}
+
+function buildPredicates(cols, n, featureNames) {
+  const predicates = [];
+  const categorical = new Set(["lineage", "lineage_subtype", "culture_type", "screen_batch"]);
+  for (const name of featureNames) {
+    const values = cols[name];
+    const uniq = uniqueValues(values);
+    if (categorical.has(name)) {
+      for (const level of uniq) {
+        const { mask, count } = makeMask(n, (i) => values[i] === level);
+        if (count >= 200 && count <= n - 200) {
+          predicates.push({
+            id: `${name}=${level}`,
+            text: `\`${name}\` is ${JSON.stringify(level)}`,
+            short: `${name}=${level}`,
+            mask,
+            count,
+            variable: name,
+          });
+        }
+      }
+    } else if (uniq.length <= 3 && uniq.every((v) => Number.isFinite(v))) {
+      for (const level of uniq) {
+        const { mask, count } = makeMask(n, (i) => values[i] === level);
+        if (count >= 200 && count <= n - 200) {
+          predicates.push({
+            id: `${name}=${level}`,
+            text: `\`${name}\` equals ${level}`,
+            short: `${name}=${level}`,
+            mask,
+            count,
+            variable: name,
+          });
+        }
+      }
+    } else if (uniq.every((v) => Number.isFinite(v))) {
+      const q25 = quantile(values, 0.25);
+      const q75 = quantile(values, 0.75);
+      const hi = makeMask(n, (i) => values[i] >= q75);
+      const lo = makeMask(n, (i) => values[i] <= q25);
+      predicates.push({
+        id: `${name}>=${q75}`,
+        text: `\`${name}\` is high (>= ${fmt(q75, 3)})`,
+        short: `${name}>=q75`,
+        mask: hi.mask,
+        count: hi.count,
+        variable: name,
+        threshold: q75,
+      });
+      predicates.push({
+        id: `${name}<=${q25}`,
+        text: `\`${name}\` is low (<= ${fmt(q25, 3)})`,
+        short: `${name}<=q25`,
+        mask: lo.mask,
+        count: lo.count,
+        variable: name,
+        threshold: q25,
+      });
+    }
+  }
+  return predicates;
+}
+
+function analyzeOutcome(cols, yName, predicates, n) {
+  const y = cols[yName];
+  const single = [];
+  for (const pred of predicates) {
+    const stat = compareMask(y, pred.mask);
+    single.push({ pred, ...stat });
+  }
+  single.sort((a, b) => a.mean1 - b.mean1);
+
+  const candidatePool = [...single]
+    .filter((s) => s.n1 >= 200 && s.n0 >= 200)
+    .sort((a, b) => a.effect - b.effect)
+    .slice(0, 42);
+  const pairResults = [];
+  for (let a = 0; a < candidatePool.length; a++) {
+    for (let b = a + 1; b < candidatePool.length; b++) {
+      const pa = candidatePool[a].pred;
+      const pb = candidatePool[b].pred;
+      if (pa.variable === pb.variable) continue;
+      const inter = interactionStats(y, pa.mask, pb.mask);
+      if (!inter || inter.subgroup.n1 < 100 || inter.subgroup.n0 < 100) continue;
+      pairResults.push({ a: candidatePool[a], b: candidatePool[b], ...inter });
+    }
+  }
+  pairResults.sort((x, y) => {
+    const xScore = x.subgroup.mean1 + 0.35 * x.interaction;
+    const yScore = y.subgroup.mean1 + 0.35 * y.interaction;
+    return xScore - yScore;
+  });
+
+  const continuous = predicates.filter((p) => p.short.endsWith(">=q75") || p.short.endsWith("<=q25"));
+  const lineageSingles = single.filter((s) => s.pred.variable === "lineage").sort((a, b) => a.mean1 - b.mean1);
+  return {
+    yName,
+    mean: mean(y),
+    sd: Math.sqrt(varianceFromSums(y.reduce((a, v) => a + v, 0), y.reduce((a, v) => a + v * v, 0), y.length)),
+    single,
+    topSingles: single.slice(0, 8),
+    topPairs: pairResults.slice(0, 8),
+    lineageSingles: lineageSingles.slice(0, 6),
+    continuousCount: continuous.length,
+  };
+}
+
+function safeEffect(e) {
+  if (!Number.isFinite(e)) return null;
+  return Number(e.toPrecision(8));
+}
+
+function makeAnalysis(hypIds, code, summary, stat, extra = {}) {
+  return {
+    hypothesis_ids: hypIds,
+    code,
+    result_summary: summary,
+    p_value: safeEffect(stat.p),
+    effect_estimate: safeEffect(stat.effect ?? stat.slope ?? stat.interaction),
+    significant: stat.p < 0.05,
+    ...extra,
+  };
+}
+
+function main() {
+  const { columns: cols, n } = readParquet("dataset.parquet");
+  const names = Object.keys(cols);
+  const outcomeNames = names.filter((x) => x.startsWith("dependency_"));
+  const featureNames = names.filter((x) => x !== "cell_line_id" && !x.startsWith("dependency_"));
+  const predicates = buildPredicates(cols, n, featureNames);
+  const outcomeAnalyses = {};
