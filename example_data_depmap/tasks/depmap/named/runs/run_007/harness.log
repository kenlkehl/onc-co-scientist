+function readLittleInt(buffer, pos, width) {
+  let value = 0;
+  for (let j = 0; j < width; j++) value |= buffer[pos + j] << (8 * j);
+  return value;
+}
+
+function decodeRleBitpackedWithPosition(payload, bitWidth, count) {
+  if (bitWidth === 0) return { values: new Array(count).fill(0), position: 0 };
+  const out = [];
+  const state = { pos: 0 };
+  const byteWidth = Math.ceil(bitWidth / 8);
+  while (out.length < count && state.pos < payload.length) {
+    const header = readUnsignedVarint(payload, state);
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      const value = readLittleInt(payload, state.pos, byteWidth);
+      state.pos += byteWidth;
+      for (let j = 0; j < runLen && out.length < count; j++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bitPos = state.pos * 8;
+      for (let j = 0; j < total && out.length < count; j++) {
+        let value = 0;
+        for (let bit = 0; bit < bitWidth; bit++) {
+          const byte = payload[bitPos >> 3];
+          const b = (byte >> (bitPos & 7)) & 1;
+          value |= b << bit;
+          bitPos++;
+        }
+        out.push(value);
+      }
+      state.pos += Math.ceil((total * bitWidth) / 8);
+    }
+  }
+  if (out.length !== count) throw new Error(`Decoded ${out.length} values, expected ${count}`);
+  return { values: out, position: state.pos };
+}
+
+function decodeRleBitpacked(payload, bitWidth, count) {
+  return decodeRleBitpackedWithPosition(payload, bitWidth, count).values;
