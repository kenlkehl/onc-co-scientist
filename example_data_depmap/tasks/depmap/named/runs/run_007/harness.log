+  const outcomeAnalyses = {};
+  for (const yName of outcomeNames) outcomeAnalyses[yName] = analyzeOutcome(cols, yName, predicates, n);
+
+  const driverMap = {
+    dependency_BRAF: "braf_v600e=1",
+    dependency_EGFR: "egfr_amplification=1",
