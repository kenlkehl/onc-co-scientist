+  const transcript = {
+    dataset_id: DATASET_ID,
+    model_id: MODEL_ID,
+    harness_id: HARNESS_ID,
+    max_iterations: MAX_ITERATIONS,
+    iterations,
+  };
+
+  const summaryLines = [];
+  summaryLines.push(`Dataset ${DATASET_ID}: ${n} cell lines, ${featureNames.length} non-outcome features, ${outcomeNames.length} dependency outcomes.`);
+  summaryLines.push(`I used only the local task bundle. Because the sandbox blocked the requested uv-managed Python interpreter, I parsed dataset.parquet directly in Node and ran Welch mean comparisons plus systematic single-predicate and pairwise subgroup/interaction screens.`);
+  summaryLines.push("");
+  summaryLines.push("Overall strongest patterns:");
+  for (const yName of outcomeNames) {
+    const single = outcomeAnalyses[yName].topSingles[0];
+    const pair = outcomeAnalyses[yName].topPairs[0];
+    summaryLines.push(
+      `- ${yName}: best single predicate was ${single.pred.text}, mean ${fmt(single.mean1)} vs ${fmt(single.mean0)} (effect ${fmt(single.effect)}, p=${ptxt(single.p)}). Best pair was ${pair.a.pred.text} AND ${pair.b.pred.text}, mean ${fmt(pair.subgroup.mean1)} vs ${fmt(pair.subgroup.mean0)} (effect ${fmt(pair.subgroup.effect)}, interaction ${fmt(pair.interaction)}, interaction p=${ptxt(pair.p)}).`
