+        id: `${name}>=${q75}`,
+        text: `\`${name}\` is high (>= ${fmt(q75, 3)})`,
+        short: `${name}>=q75`,
+        mask: hi.mask,
+        count: hi.count,
+        variable: name,
+        threshold: q75,
+      });
+      predicates.push({
+        id: `${name}<=${q25}`,
+        text: `\`${name}\` is low (<= ${fmt(q25, 3)})`,
+        short: `${name}<=q25`,
+        mask: lo.mask,
+        count: lo.count,
+        variable: name,
+        threshold: q25,
+      });
+    }
+  }
