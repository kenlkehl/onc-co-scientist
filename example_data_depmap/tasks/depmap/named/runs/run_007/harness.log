+  if (expectedSize != null && outLen !== expectedSize) {
+    throw new Error(`Snappy expected ${expectedSize} but got ${outLen}`);
+  }
+  return out;
+}
+
+function decompress(codec, pageBytes, expectedSize) {
+  if (codec === 0) return pageBytes;
+  if (codec === 1) return snappyUncompress(pageBytes, expectedSize);
+  throw new Error(`Unsupported compression codec ${codec}`);
+}
+
+function decodePlainValues(type, payload, count) {
+  const values = [];
+  let pos = 0;
+  if (type === 6) {
+    for (let i = 0; i < count; i++) {
+      const len = payload.readInt32LE(pos);
+      pos += 4;
+      values.push(payload.slice(pos, pos + len).toString("utf8"));
+      pos += len;
+    }
+  } else if (type === 5) {
+    for (let i = 0; i < count; i++, pos += 8) values.push(payload.readDoubleLE(pos));
+  } else if (type === 2) {
+    for (let i = 0; i < count; i++, pos += 8) values.push(Number(payload.readBigInt64LE(pos)));
+  } else if (type === 1) {
+    for (let i = 0; i < count; i++, pos += 4) values.push(payload.readInt32LE(pos));
+  } else if (type === 0) {
+    for (let i = 0; i < count; i++) values.push(Boolean((payload[Math.floor(i / 8)] >> (i % 8)) & 1));
+  } else {
+    throw new Error(`Unsupported plain parquet type ${type}`);
+  }
