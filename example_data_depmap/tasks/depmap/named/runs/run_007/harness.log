diff --git a/example_data_depmap/tasks/depmap/named/analysis_runner.js b/example_data_depmap/tasks/depmap/named/analysis_runner.js
new file mode 100644
index 0000000000000000000000000000000000000000..574df650f6511ae498c5544f6f93775bcd0221e2
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/named/analysis_runner.js
@@ -0,0 +1,1207 @@
+const fs = require("fs");
+
+const DATASET_ID = "ds001_depmap";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-direct-js-parquet@2026-05-04";
+const MAX_ITERATIONS = 10;
+
+class CompactReader {
+  constructor(buffer, offset = 0) {
+    this.b = buffer;
+    this.i = offset;
+    this.last = [];
+  }
+  byte() {
+    if (this.i >= this.b.length) throw new Error("Unexpected EOF");
+    return this.b[this.i++];
+  }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const x = this.byte();
+      result |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  i32() {
+    return this.zigzag(this.varint());
+  }
+  i64() {
+    const n = this.varint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  bin() {
+    const len = Number(this.varint());
+    const out = this.b.slice(this.i, this.i + len);
+    this.i += len;
+    return out;
+  }
+  str() {
+    return this.bin().toString("utf8");
+  }
+  dbl() {
+    const v = this.b.readDoubleLE(this.i);
+    this.i += 8;
+    return v;
+  }
+  flt() {
+    const v = this.b.readFloatLE(this.i);
+    this.i += 4;
+    return v;
+  }
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const etype = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, etype };
+  }
+  field() {
+    const h = this.byte();
+    if (h === 0) return null;
+    const type = h & 0x0f;
+    const delta = h >> 4;
+    let fid;
+    if (delta === 0) fid = this.i32();
+    else fid = (this.last[this.last.length - 1] || 0) + delta;
+    this.last[this.last.length - 1] = fid;
+    return { type, fid };
+  }
+  push() {
+    this.last.push(0);
+  }
+  pop() {
+    this.last.pop();
+  }
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.byte();
+        return;
+      case 4:
+      case 5:
+        this.i32();
+        return;
+      case 6:
+        this.i64();
+        return;
+      case 7:
+        this.dbl();
+        return;
+      case 8:
+        this.bin();
+        return;
+      case 9:
+      case 10: {
+        const { size, etype } = this.listHeader();
+        for (let j = 0; j < size; j++) this.skip(etype);
+        return;
+      }
+      case 11: {
+        const size = Number(this.varint());
+        if (size > 0) {
+          const ktvt = this.byte();
+          const kt = ktvt >> 4;
+          const vt = ktvt & 0x0f;
+          for (let j = 0; j < size; j++) {
+            this.skip(kt);
+            this.skip(vt);
+          }
+        }
+        return;
+      }
+      case 12:
+        this.push();
+        while (true) {
+          const f = this.field();
+          if (!f) break;
+          this.skip(f.type);
+        }
+        this.pop();
+        return;
+      case 13:
+        this.flt();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.i}`);
+    }
+  }
+}
+
+function readStruct(r, handlers) {
+  const obj = {};
+  r.push();
+  while (true) {
+    const f = r.field();
+    if (!f) break;
+    if (handlers[f.fid]) handlers[f.fid](r, f.type, obj);
+    else r.skip(f.type);
+  }
+  r.pop();
+  return obj;
+}
+
+function readList(r, itemReader) {
+  const { size, etype } = r.listHeader();
+  const out = [];
+  for (let j = 0; j < size; j++) out.push(itemReader(r, etype));
+  return out;
+}
+
+function intList(r) {
+  return readList(r, (rr) => rr.i32());
+}
+
+function strList(r) {
+  return readList(r, (rr) => rr.str());
+}
+
+function schemaElement(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.type = r.i32()),
+    2: (r, t, o) => (o.type_length = r.i32()),
+    3: (r, t, o) => (o.repetition_type = r.i32()),
+    4: (r, t, o) => (o.name = r.str()),
+    5: (r, t, o) => (o.num_children = r.i32()),
+    6: (r, t, o) => (o.converted_type = r.i32()),
+    7: (r, t, o) => (o.scale = r.i32()),
+    8: (r, t, o) => (o.precision = r.i32()),
+    9: (r, t, o) => (o.field_id = r.i32()),
+  });
+}
+
+function columnMeta(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.type = r.i32()),
+    2: (r, t, o) => (o.encodings = intList(r)),
+    3: (r, t, o) => (o.path = strList(r)),
+    4: (r, t, o) => (o.codec = r.i32()),
+    5: (r, t, o) => (o.num_values = Number(r.i64())),
+    6: (r, t, o) => (o.total_uncompressed_size = Number(r.i64())),
+    7: (r, t, o) => (o.total_compressed_size = Number(r.i64())),
+    9: (r, t, o) => (o.data_page_offset = Number(r.i64())),
+    10: (r, t, o) => (o.index_page_offset = Number(r.i64())),
+    11: (r, t, o) => (o.dictionary_page_offset = Number(r.i64())),
+  });
+}
+
+function columnChunk(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.file_path = r.str()),
+    2: (r, t, o) => (o.file_offset = Number(r.i64())),
+    3: (r, t, o) => (o.meta = columnMeta(r)),
+  });
+}
+
+function rowGroup(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.columns = readList(r, (rr) => columnChunk(rr))),
+    2: (r, t, o) => (o.total_byte_size = Number(r.i64())),
+    3: (r, t, o) => (o.num_rows = Number(r.i64())),
+    5: (r, t, o) => (o.file_offset = Number(r.i64())),
+    6: (r, t, o) => (o.total_compressed_size = Number(r.i64())),
+  });
+}
+
+function fileMeta(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.version = r.i32()),
+    2: (r, t, o) => (o.schema = readList(r, (rr) => schemaElement(rr))),
+    3: (r, t, o) => (o.num_rows = Number(r.i64())),
+    4: (r, t, o) => (o.row_groups = readList(r, (rr) => rowGroup(rr))),
+    6: (r, t, o) => (o.created_by = r.str()),
+  });
+}
+
+function dataPageHeader(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.num_values = r.i32()),
+    2: (r, t, o) => (o.encoding = r.i32()),
+    3: (r, t, o) => (o.definition_level_encoding = r.i32()),
+    4: (r, t, o) => (o.repetition_level_encoding = r.i32()),
+  });
+}
+
+function dictionaryPageHeader(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.num_values = r.i32()),
+    2: (r, t, o) => (o.encoding = r.i32()),
+    3: (r, t, o) => (o.is_sorted = t === 1 ? true : t === 2 ? false : Boolean(r.i32())),
+  });
+}
+
+function dataPageHeaderV2(r) {
+  return readStruct(r, {
+    1: (r, t, o) => (o.num_values = r.i32()),
+    2: (r, t, o) => (o.num_nulls = r.i32()),
+    3: (r, t, o) => (o.num_rows = r.i32()),
+    4: (r, t, o) => (o.encoding = r.i32()),
+    5: (r, t, o) => (o.definition_levels_byte_length = r.i32()),
+    6: (r, t, o) => (o.repetition_levels_byte_length = r.i32()),
+    7: (r, t, o) => (o.is_compressed = t === 1 ? true : t === 2 ? false : Boolean(r.i32())),
+  });
+}
+
+function pageHeader(buffer, offset) {
+  const r = new CompactReader(buffer, offset);
+  const h = readStruct(r, {
+    1: (r, t, o) => (o.type = r.i32()),
+    2: (r, t, o) => (o.uncompressed_page_size = r.i32()),
+    3: (r, t, o) => (o.compressed_page_size = r.i32()),
+    5: (r, t, o) => (o.data_page_header = dataPageHeader(r)),
+    7: (r, t, o) => (o.dictionary_page_header = dictionaryPageHeader(r)),
+    8: (r, t, o) => (o.data_page_header_v2 = dataPageHeaderV2(r)),
+  });
+  h.header_len = r.i - offset;
+  h.data_start = r.i;
+  return h;
+}
+
+function readUnsignedVarint(buffer, state) {
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = buffer[state.pos++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return result;
+}
+
+function snappyUncompress(input, expectedSize) {
+  const state = { pos: 0 };
+  const outLen = readUnsignedVarint(input, state);
+  const out = Buffer.alloc(outLen);
+  let op = 0;
+  while (state.pos < input.length) {
+    const tag = input[state.pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let len;
+      if (lenCode < 60) {
+        len = lenCode + 1;
+      } else {
+        const nbytes = lenCode - 59;
+        let v = 0;
+        for (let j = 0; j < nbytes; j++) v |= input[state.pos++] << (8 * j);
+        len = v + 1;
+      }
+      input.copy(out, op, state.pos, state.pos + len);
+      state.pos += len;
+      op += len;
+    } else {
+      let len, offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[state.pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[state.pos] | (input[state.pos + 1] << 8);
+        state.pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset =
+          input[state.pos] |
+          (input[state.pos + 1] << 8) |
+          (input[state.pos + 2] << 16) |
+          (input[state.pos + 3] << 24);
+        state.pos += 4;
+      }
+      for (let j = 0; j < len; j++) out[op + j] = out[op - offset + j];
+      op += len;
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch ${op} != ${outLen}`);
+  if (expectedSize != null && outLen !== expectedSize) {
+    throw new Error(`Snappy expected ${expectedSize} but got ${outLen}`);
+  }
+  return out;
+}
+
+function decompress(codec, pageBytes, expectedSize) {
