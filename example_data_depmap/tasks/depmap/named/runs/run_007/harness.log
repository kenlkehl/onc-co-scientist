+    const values = cols[name];
+    const uniq = uniqueValues(values);
+    if (categorical.has(name)) {
+      for (const level of uniq) {
+        const { mask, count } = makeMask(n, (i) => values[i] === level);
+        if (count >= 200 && count <= n - 200) {
