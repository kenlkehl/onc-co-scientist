new file mode 100644
index 0000000000000000000000000000000000000000..e84202252eb5d274acc24cb5fbf4a14dbe2ee685
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/named/analysis_runner.js
@@ -0,0 +1,1189 @@
+const fs = require("fs");
+
+const DATASET_ID = "ds001_depmap";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-direct-js-parquet@2026-05-04";
+const MAX_ITERATIONS = 10;
+
+class CompactReader {
+  constructor(buffer, offset = 0) {
+    this.b = buffer;
+    this.i = offset;
+    this.last = [];
+  }
+  byte() {
+    if (this.i >= this.b.length) throw new Error("Unexpected EOF");
+    return this.b[this.i++];
+  }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const x = this.byte();
+      result |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  i32() {
+    return this.zigzag(this.varint());
+  }
+  i64() {
+    const n = this.varint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  bin() {
+    const len = Number(this.varint());
+    const out = this.b.slice(this.i, this.i + len);
+    this.i += len;
+    return out;
+  }
+  str() {
+    return this.bin().toString("utf8");
+  }
+  dbl() {
+    const v = this.b.readDoubleLE(this.i);
+    this.i += 8;
+    return v;
+  }
+  flt() {
+    const v = this.b.readFloatLE(this.i);
+    this.i += 4;
+    return v;
+  }
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const etype = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, etype };
+  }
+  field() {
+    const h = this.byte();
+    if (h === 0) return null;
+    const type = h & 0x0f;
+    const delta = h >> 4;
+    let fid;
+    if (delta === 0) fid = this.i32();
+    else fid = (this.last[this.last.length - 1] || 0) + delta;
+    this.last[this.last.length - 1] = fid;
+    return { type, fid };
+  }
+  push() {
+    this.last.push(0);
+  }
+  pop() {
+    this.last.pop();
+  }
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.byte();
+        return;
+      case 4:
+      case 5:
+        this.i32();
+        return;
+      case 6:
+        this.i64();
+        return;
+      case 7:
+        this.dbl();
+        return;
+      case 8:
+        this.bin();
+        return;
+      case 9:
+      case 10: {
+        const { size, etype } = this.listHeader();
+        for (let j = 0; j < size; j++) this.skip(etype);
+        return;
+      }
+      case 11: {
+        const size = Number(this.varint());
+        if (size > 0) {
+          const ktvt = this.byte();
+          const kt = ktvt >> 4;
+          const vt = ktvt & 0x0f;
+          for (let j = 0; j < size; j++) {
+            this.skip(kt);
+            this.skip(vt);
+          }
+        }
+        return;
+      }
+      case 12:
+        this.push();
+        while (true) {
+          const f = this.field();
+          if (!f) break;
+          this.skip(f.type);
+        }
+        this.pop();
+        return;
+      case 13:
+        this.flt();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.i}`);
+    }
+  }
+}
+
+function readStruct(r, handlers) {
+  const obj = {};
+  r.push();
+  while (true) {
+    const f = r.field();
+    if (!f) break;
+    if (handlers[f.fid]) handlers[f.fid](r, f.type, obj);
+    else r.skip(f.type);
+  }
+  r.pop();
+  return obj;
+}
