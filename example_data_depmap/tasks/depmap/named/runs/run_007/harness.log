+        id: `${name}>=${q75}`,
+        text: `\`${name}\` is high (>= ${fmt(q75, 3)})`,
+        short: `${name}>=q75`,
+        mask: hi.mask,
+        count: hi.count,
+        variable: name,
+        threshold: q75,
