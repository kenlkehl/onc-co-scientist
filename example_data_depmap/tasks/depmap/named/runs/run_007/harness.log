+    kind: "refined",
+  };
+  iterations.push({
+    index: 3,
+    proposed_hypotheses: [h.h5, h.h6],
+    analyses: [
+      makeAnalysis(
+        ["h5"],
+        "Welch comparison: dependency_ERBB2 by erbb2_amplification == 1 versus 0.",
+        `Mean dependency_ERBB2 was ${fmt(erbb2.mean1)} for erbb2_amplification=1 (n=${erbb2.n1}) versus ${fmt(erbb2.mean0)} otherwise; effect=${fmt(erbb2.effect)}, p=${ptxt(erbb2.p)}.`,
+        erbb2,
+        { n_subgroup: erbb2.n1, mean_subgroup: safeEffect(erbb2.mean1), mean_reference: safeEffect(erbb2.mean0) }
+      ),
+      makeAnalysis(
+        ["h6"],
+        `Systematic pairwise subgroup screen over ${predicates.length} feature predicates; reported top ERBB2 pair.`,
+        `Top ERBB2 subgroup screen result: ${erbb2Pair.a.pred.text} AND ${erbb2Pair.b.pred.text} had mean dependency_ERBB2 ${fmt(erbb2Pair.subgroup.mean1)} (n=${erbb2Pair.subgroup.n1}) versus ${fmt(erbb2Pair.subgroup.mean0)} otherwise; subgroup effect=${fmt(erbb2Pair.subgroup.effect)}, interaction=${fmt(erbb2Pair.interaction)}, interaction p=${ptxt(erbb2Pair.p)}.`,
+        erbb2Pair.subgroup,
+        { interaction_effect_estimate: safeEffect(erbb2Pair.interaction), interaction_p_value: safeEffect(erbb2Pair.p) }
+      ),
+    ],
+  });
+
+  h.h7 = {
+    id: "h7",
+    text: "Cell lines with `kras_mutation` equals 1 have more negative `dependency_KRAS` scores than cell lines without `kras_mutation`.",
+    kind: "novel",
+  };
+  const kras = statFor("dependency_KRAS", "kras_mutation=1");
+  const krasPair = topPair("dependency_KRAS", "kras_mutation=1");
