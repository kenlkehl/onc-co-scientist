+function interactionStats(y, maskA, maskB) {
+  const cells = [
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+    { n: 0, s: 0, ss: 0 },
+  ];
+  for (let i = 0; i < y.length; i++) {
+    const idx = (maskA[i] ? 2 : 0) + (maskB[i] ? 1 : 0);
+    const v = y[i];
+    cells[idx].n++;
+    cells[idx].s += v;
+    cells[idx].ss += v * v;
+  }
