"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs = require('fs');
const t = JSON.parse(fs.readFileSync('transcript.json', 'utf8'));
const required = ['dataset_id','model_id','harness_id','max_iterations','iterations'];
for (const k of required) if ("'!(k in t)) throw new Error('"'missing top-level '+k);
if (t.dataset_id "'!== '"'ds001_depmap') throw new Error('wrong dataset_id');
if (t.max_iterations "'!== 10) throw new Error('"'wrong max_iterations');
const ids = new Set();
for (const it of t.iterations) {
  if ("'!it.index || !Array.isArray(it.proposed_hypotheses)) throw new Error('"'bad iteration '+it.index);
  for (const h of it.proposed_hypotheses) ids.add(h.id);
}
let analyses = 0;
for (const it of t.iterations) {
  for (const a of (it.analyses || [])) {
    analyses++;
    if ("'!Array.isArray(a.hypothesis_ids) || a.hypothesis_ids.length === 0) throw new Error('"'analysis missing hypothesis_ids');
    for (const id of a.hypothesis_ids) if ("'!ids.has(id)) throw new Error('"'unknown hypothesis id '+id);
    if (typeof a.result_summary "'!== '"'string') throw new Error('analysis missing result_summary');
    if ("'!('"'p_value' in a) && "'!('"'significant' in a)) throw new Error('analysis missing p/significant');
    if ("'!('"'effect_estimate' in a)) throw new Error('analysis missing effect_estimate');
  }
}
