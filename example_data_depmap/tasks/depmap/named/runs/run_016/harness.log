function decodeColumn(meta,type){let h=parsePageHeader(meta.dictionary_page_offset);let dict=dictValues(decompress(buf.subarray(h.payloadOffset,h.payloadOffset+h.compressed),meta.codec),type,h.dict.num_values);let vals=[],off=meta.data_page_offset;while(vals.length<meta.num_values){let ph=parsePageHeader(off);let data=decompress(buf.subarray(ph.payloadOffset,ph.payloadOffset+ph.compressed),meta.codec);let p=0;let defLen=data.readInt32LE(p);p+=4+defLen;let bw=data[p++];let idx=readHybrid(data,p,ph.data.num_values,bw);for(const j of idx) vals.push(dict[j]);off=ph.payloadOffset+ph.compressed;}return vals;}
function erf(x){const sign=x<0?-1:1;x=Math.abs(x);const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911;const t=1/(1+p*x);const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x);return sign*y;}function pnorm2(z){const p=1-erf(Math.abs(z)/Math.SQRT2);return p===0?1e-300:p;}
function welch(y,mask){let n1=0,n0=0,s1=0,s0=0;for(let i=0;i<y.length;i++){if(mask[i]){n1++;s1+=y[i];}else{n0++;s0+=y[i];}}let m1=s1/n1,m0=s0/n0,v1=0,v0=0;for(let i=0;i<y.length;i++){if(mask[i]){let d=y[i]-m1;v1+=d*d;}else{let d=y[i]-m0;v0+=d*d;}}v1/=(n1-1);v0/=(n0-1);let se=Math.sqrt(v1/n1+v0/n0);let z=(m1-m0)/se;return {n:n1,mean:m1,restMean:m0,effect:m1-m0,z,p:pnorm2(z)};}
