+        if (incompatible(predicates[i], predicates[j])) continue;
+        const idx = intersect(predicates[i].idx, predicates[j].idx);
+        if (idx.length < 250) continue;
+        const st = statsForIdx(y, totalS, totalSS, idx);
+        if (st) pairs.push({ predicates: [predicates[i].text, predicates[j].text], features: [predicates[i].feature, predicates[j].feature], idx, ...st });
+      }
+    }
+    pairs.sort((a, b) => a.t - b.t);
+    const triples = [];
+    for (const pair of pairs.slice(0, 150)) {
+      for (let k = 0; k < predicates.length; k++) {
+        if (pair.features.includes(predicates[k].feature)) continue;
+        const idx = intersect(pair.idx, predicates[k].idx);
+        if (idx.length < 200) continue;
+        const st = statsForIdx(y, totalS, totalSS, idx);
+        if (st) triples.push({ predicates: [...pair.predicates, predicates[k].text], features: [...pair.features, predicates[k].feature], ...st });
+      }
+    }
+    triples.sort((a, b) => a.t - b.t);
+    const clean = rows => rows.slice(0, 10).map(({ idx, features, ...r }) => r);
+    report[ycol] = { singles: clean(singles), pairs: clean(pairs), triples: clean(triples) };
+  }
+  console.log(JSON.stringify(report, null, 2));
+}

