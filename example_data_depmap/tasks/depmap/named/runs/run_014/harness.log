+class Reader {
+  constructor(b) {
+    this.b = b;
+    this.o = 0;
+  }
+  u8() {
+    return this.b[this.o++];
+  }
+  varintBig() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = BigInt(this.u8());
+      out |= (x & 0x7fn) << shift;
+      if ((x & 0x80n) === 0n) return out;
+      shift += 7n;
+    }
+  }
+  varint() {
+    return Number(this.varintBig());
+  }
+  zigzag() {
+    const n = this.varintBig();
+    const val = (n >> 1n) ^ (-(n & 1n));
