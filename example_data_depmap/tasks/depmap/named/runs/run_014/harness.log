+        dictionary_page_offset: c.meta_data.dictionary_page_offset,
+        compressed: c.meta_data.total_compressed_size,
+        uncompressed: c.meta_data.total_uncompressed_size,
+      }))
+    }))
+  }, null, 2));
+} else if (process.argv[2] === 'peek') {
+  const table = loadTable();
+  const names = Object.keys(table);
+  console.log(`rows=${table[names[0]].length} cols=${names.length}`);
+  for (let i = 0; i < 5; i++) {
+    const row = {};
+    for (const n of names.slice(0, 12)) row[n] = table[n][i];
+    for (const n of names.slice(-10)) row[n] = table[n][i];
+    console.log(JSON.stringify(row));
+  }
+} else if (process.argv[2] === 'scan') {
+  const table = loadTable();
+  const names = Object.keys(table);
+  const n = table[names[0]].length;
+  const outcomes = names.filter(x => x.startsWith('dependency_'));
+  const features = names.filter(x => x !== 'cell_line_id' && !x.startsWith('dependency_'));
+  const binaryFeatures = features.filter(c => new Set(table[c]).size === 2 && table[c].every(v => v === 0 || v === 1));
+  const categoricalFeatures = features.filter(c => {
+    const u = new Set(table[c]);
+    return !binaryFeatures.includes(c) && u.size <= 20;
+  });
+  const continuousFeatures = features.filter(c => !binaryFeatures.includes(c) && !categoricalFeatures.includes(c));
+
+  function erf(x) {
+    const sign = x < 0 ? -1 : 1;
+    x = Math.abs(x);
+    const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+    const t = 1 / (1 + p * x);
+    const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+    return sign * y;
+  }
+  function pFromT(t) {
+    const z = Math.abs(t);
+    if (!Number.isFinite(z)) return 1;
+    if (z > 37) return 1e-300;
+    const cdf = 0.5 * (1 + erf(z / Math.SQRT2));
+    return Math.max(1e-300, Math.min(1, 2 * (1 - cdf)));
+  }
+  function summarize(y, mask) {
+    let n1 = 0, s1 = 0, ss1 = 0, n0 = 0, s0 = 0, ss0 = 0;
+    for (let i = 0; i < n; i++) {
+      const v = y[i];
+      if (mask(i)) {
+        n1++; s1 += v; ss1 += v * v;
+      } else {
+        n0++; s0 += v; ss0 += v * v;
+      }
+    }
+    const m1 = s1 / n1, m0 = s0 / n0;
+    const v1 = (ss1 - s1 * s1 / n1) / Math.max(1, n1 - 1);
+    const v0 = (ss0 - s0 * s0 / n0) / Math.max(1, n0 - 1);
+    const se = Math.sqrt(v1 / n1 + v0 / n0);
+    const t = (m1 - m0) / se;
+    return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, t, p: pFromT(t) };
+  }
+  function slopeTest(x, y) {
+    let sx = 0, sy = 0, sxx = 0, sxy = 0;
+    for (let i = 0; i < n; i++) { sx += x[i]; sy += y[i]; }
+    const mx = sx / n, my = sy / n;
+    for (let i = 0; i < n; i++) {
+      const dx = x[i] - mx, dy = y[i] - my;
+      sxx += dx * dx;
+      sxy += dx * dy;
+    }
+    const slope = sxy / sxx;
+    const intercept = my - slope * mx;
+    let rss = 0;
+    for (let i = 0; i < n; i++) {
+      const e = y[i] - intercept - slope * x[i];
+      rss += e * e;
+    }
+    const se = Math.sqrt((rss / (n - 2)) / sxx);
+    const t = slope / se;
+    return { slope, t, p: pFromT(t) };
+  }
+
+  const report = {};
+  for (const ycol of outcomes) {
+    const y = table[ycol];
+    const rows = [];
+    for (const c of binaryFeatures) {
+      const s = summarize(y, i => table[c][i] === 1);
+      rows.push({ type: 'binary', feature: c, level: 1, ...s });
+    }
+    for (const c of categoricalFeatures) {
+      const levels = [...new Set(table[c])];
+      for (const lv of levels) {
+        const s = summarize(y, i => table[c][i] === lv);
+        rows.push({ type: 'categorical', feature: c, level: lv, ...s });
+      }
+    }
+    for (const c of continuousFeatures) {
