+      type: r.type,
+      feature: r.feature,
+      level: r.level,
+      n1: r.n1,
+      n0: r.n0,
+      mean1: r.mean1,
+      mean0: r.mean0,
+      effect: r.effect,
+      t: r.t,
+      p: r.p
+    }));
+  }
+  console.log(JSON.stringify({ binaryFeatures, categoricalFeatures, continuousFeatures, report }, null, 2));
+} else if (process.argv[2] === 'subgroups') {
+  const table = loadTable();
+  const names = Object.keys(table);
+  const n = table[names[0]].length;
+  const outcomes = names.filter(x => x.startsWith('dependency_'));
+  const features = names.filter(x => x !== 'cell_line_id' && !x.startsWith('dependency_'));
+  const binaryFeatures = features.filter(c => new Set(table[c]).size === 2 && table[c].every(v => v === 0 || v === 1));
+  const categoricalFeatures = features.filter(c => {
+    const u = new Set(table[c]);
+    return !binaryFeatures.includes(c) && u.size <= 20;
+  });
+  const continuousFeatures = features.filter(c => !binaryFeatures.includes(c) && !categoricalFeatures.includes(c));
+
+  function erf(x) {
+    const sign = x < 0 ? -1 : 1;
+    x = Math.abs(x);
+    const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+    const t = 1 / (1 + p * x);
+    const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+    return sign * y;
+  }
+  function pFromT(t) {
+    const z = Math.abs(t);
+    if (!Number.isFinite(z)) return 1;
+    if (z > 37) return 1e-300;
+    const cdf = 0.5 * (1 + erf(z / Math.SQRT2));
+    return Math.max(1e-300, Math.min(1, 2 * (1 - cdf)));
+  }
+  function q(arr, prob) {
+    const s = [...arr].sort((a, b) => a - b);
+    const pos = (s.length - 1) * prob;
+    const lo = Math.floor(pos), hi = Math.ceil(pos);
+    if (lo === hi) return s[lo];
+    return s[lo] * (hi - pos) + s[hi] * (pos - lo);
+  }
+  function makeIdx(mask) {
+    const idx = [];
+    for (let i = 0; i < n; i++) if (mask(i)) idx.push(i);
+    return idx;
+  }
+  const predicates = [];
+  for (const c of binaryFeatures) {
+    predicates.push({ feature: c, text: `${c}=1`, idx: makeIdx(i => table[c][i] === 1) });
+    predicates.push({ feature: c, text: `${c}=0`, idx: makeIdx(i => table[c][i] === 0) });
+  }
+  for (const c of categoricalFeatures) {
+    for (const lv of [...new Set(table[c])]) {
+      predicates.push({ feature: c, text: `${c}=${lv}`, idx: makeIdx(i => table[c][i] === lv) });
+    }
+  }
+  for (const c of continuousFeatures) {
+    const q25 = q(table[c], 0.25);
+    const q75 = q(table[c], 0.75);
+    predicates.push({ feature: c, text: `${c}<=${q25.toFixed(3)}`, idx: makeIdx(i => table[c][i] <= q25) });
+    predicates.push({ feature: c, text: `${c}>=${q75.toFixed(3)}`, idx: makeIdx(i => table[c][i] >= q75) });
+  }
+  function intersect(a, b) {
+    const out = [];
+    let i = 0, j = 0;
+    while (i < a.length && j < b.length) {
+      if (a[i] === b[j]) { out.push(a[i]); i++; j++; }
+      else if (a[i] < b[j]) i++;
+      else j++;
+    }
+    return out;
+  }
