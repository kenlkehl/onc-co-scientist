+    return out;
+  }
+  function statsForIdx(y, totalS, totalSS, idx) {
+    const n1 = idx.length;
+    if (n1 < 100 || n1 > n - 100) return null;
+    let s1 = 0, ss1 = 0;
+    for (const i of idx) { const v = y[i]; s1 += v; ss1 += v * v; }
+    const n0 = n - n1;
+    const s0 = totalS - s1;
+    const ss0 = totalSS - ss1;
+    const m1 = s1 / n1, m0 = s0 / n0;
+    const v1 = (ss1 - s1 * s1 / n1) / Math.max(1, n1 - 1);
+    const v0 = (ss0 - s0 * s0 / n0) / Math.max(1, n0 - 1);
+    const se = Math.sqrt(v1 / n1 + v0 / n0);
+    const t = (m1 - m0) / se;
