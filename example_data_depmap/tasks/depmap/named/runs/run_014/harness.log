+const fs = require('fs');
+
+const file = 'dataset.parquet';
+const buf = fs.readFileSync(file);
+if (buf.slice(0, 4).toString() !== 'PAR1' || buf.slice(buf.length - 4).toString() !== 'PAR1') {
+  throw new Error('Not a Parquet file');
+}
+
+const footerLen = buf.readUInt32LE(buf.length - 8);
+const footer = buf.slice(buf.length - 8 - footerLen, buf.length - 8);
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+  FLOAT: 13,
+};
+
+class Reader {
+  constructor(b) {
+    this.b = b;
+    this.o = 0;
+  }
+  u8() {
+    return this.b[this.o++];
+  }
+  varintBig() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = BigInt(this.u8());
+      out |= (x & 0x7fn) << shift;
+      if ((x & 0x80n) === 0n) return out;
+      shift += 7n;
+    }
+  }
+  varint() {
+    return Number(this.varintBig());
+  }
+  zigzag() {
+    const n = this.varintBig();
+    const val = (n >> 1n) ^ (-(n & 1n));
+    return Number(val);
+  }
+  binary() {
+    const n = this.varint();
+    const s = this.b.slice(this.o, this.o + n);
+    this.o += n;
+    return s;
+  }
+  string() {
+    return this.binary().toString('utf8');
+  }
+  double() {
+    const x = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return x;
+  }
+  float() {
+    const x = this.b.readFloatLE(this.o);
+    this.o += 4;
+    return x;
+  }
+  field(last) {
+    const h = this.u8();
+    const type = h & 0x0f;
+    if (type === CT.STOP) return { type };
+    const delta = h >> 4;
+    let id;
+    if (delta === 0) id = this.zigzag();
+    else id = last + delta;
+    return { type, id };
+  }
+  listBegin() {
+    const h = this.u8();
+    let size = h >> 4;
+    const etype = h & 0x0f;
+    if (size === 15) size = this.varint();
+    return { size, etype };
+  }
+  skip(type) {
+    if (type === CT.TRUE || type === CT.FALSE) return;
+    if (type === CT.BYTE) {
+      this.u8();
+    } else if (type === CT.I16 || type === CT.I32 || type === CT.I64) {
+      this.zigzag();
+    } else if (type === CT.DOUBLE) {
+      this.o += 8;
+    } else if (type === CT.FLOAT) {
+      this.o += 4;
+    } else if (type === CT.BINARY) {
+      this.binary();
+    } else if (type === CT.LIST || type === CT.SET) {
+      const { size, etype } = this.listBegin();
+      for (let i = 0; i < size; i++) this.skip(etype);
+    } else if (type === CT.MAP) {
+      const size = this.varint();
+      if (size > 0) {
+        const types = this.u8();
+        const ktype = types >> 4;
+        const vtype = types & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(ktype);
+          this.skip(vtype);
+        }
+      }
+    } else if (type === CT.STRUCT) {
+      let last = 0;
+      while (true) {
+        const f = this.field(last);
+        if (f.type === CT.STOP) break;
+        last = f.id;
+        this.skip(f.type);
+      }
+    } else {
+      throw new Error(`Unknown compact type ${type} at ${this.o}`);
+    }
+  }
+}
+
+function readList(r, fn) {
+  const { size, etype } = r.listBegin();
+  const out = [];
+  for (let i = 0; i < size; i++) out.push(fn(r, etype));
+  return out;
+}
+
+function parseSchemaElement(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.type = r.zigzag();
+    else if (f.id === 2) x.type_length = r.zigzag();
+    else if (f.id === 3) x.repetition_type = r.zigzag();
+    else if (f.id === 4) x.name = r.string();
+    else if (f.id === 5) x.num_children = r.zigzag();
+    else if (f.id === 6) x.converted_type = r.zigzag();
+    else if (f.id === 7) x.scale = r.zigzag();
+    else if (f.id === 8) x.precision = r.zigzag();
+    else if (f.id === 9) x.field_id = r.zigzag();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseColumnMetaData(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.type = r.zigzag();
+    else if (f.id === 2) x.encodings = readList(r, rr => rr.zigzag());
+    else if (f.id === 3) x.path_in_schema = readList(r, rr => rr.string());
+    else if (f.id === 4) x.codec = r.zigzag();
+    else if (f.id === 5) x.num_values = r.zigzag();
+    else if (f.id === 6) x.total_uncompressed_size = r.zigzag();
+    else if (f.id === 7) x.total_compressed_size = r.zigzag();
+    else if (f.id === 9) x.data_page_offset = r.zigzag();
+    else if (f.id === 10) x.index_page_offset = r.zigzag();
+    else if (f.id === 11) x.dictionary_page_offset = r.zigzag();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseColumnChunk(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.file_path = r.string();
+    else if (f.id === 2) x.file_offset = r.zigzag();
+    else if (f.id === 3) x.meta_data = parseColumnMetaData(r);
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseRowGroup(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.columns = readList(r, rr => parseColumnChunk(rr));
+    else if (f.id === 2) x.total_byte_size = r.zigzag();
+    else if (f.id === 3) x.num_rows = r.zigzag();
+    else if (f.id === 5) x.file_offset = r.zigzag();
+    else if (f.id === 6) x.total_compressed_size = r.zigzag();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseFileMetaData(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.version = r.zigzag();
+    else if (f.id === 2) x.schema = readList(r, rr => parseSchemaElement(rr));
+    else if (f.id === 3) x.num_rows = r.zigzag();
+    else if (f.id === 4) x.row_groups = readList(r, rr => parseRowGroup(rr));
+    else if (f.id === 6) x.created_by = r.string();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+const meta = parseFileMetaData(new Reader(footer));
+const codecNames = ['UNCOMPRESSED', 'SNAPPY', 'GZIP', 'LZO', 'BROTLI', 'LZ4', 'ZSTD', 'LZ4_RAW'];
+const typeNames = ['BOOLEAN', 'INT32', 'INT64', 'INT96', 'FLOAT', 'DOUBLE', 'BYTE_ARRAY', 'FIXED_LEN_BYTE_ARRAY'];
+console.log(JSON.stringify({
+  version: meta.version,
+  num_rows: meta.num_rows,
+  created_by: meta.created_by,
+  schema: meta.schema.map(s => ({ name: s.name, type: typeNames[s.type] ?? s.type, rep: s.repetition_type, children: s.num_children })),
+  row_groups: meta.row_groups.map(rg => ({
+    num_rows: rg.num_rows,
+    columns: rg.columns.map(c => ({
+      path: c.meta_data.path_in_schema.join('.'),
+      type: typeNames[c.meta_data.type] ?? c.meta_data.type,
+      codec: codecNames[c.meta_data.codec] ?? c.meta_data.codec,
+      encodings: c.meta_data.encodings,
+      values: c.meta_data.num_values,
+      data_page_offset: c.meta_data.data_page_offset,
+      dictionary_page_offset: c.meta_data.dictionary_page_offset,
+      compressed: c.meta_data.total_compressed_size,
+      uncompressed: c.meta_data.total_uncompressed_size,
+    }))
+  }))
+}, null, 2));

