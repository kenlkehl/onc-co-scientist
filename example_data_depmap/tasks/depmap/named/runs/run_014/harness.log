+  const n = table[names[0]].length;
+  const outcomes = names.filter(x => x.startsWith('dependency_'));
+  const features = names.filter(x => x !== 'cell_line_id' && !x.startsWith('dependency_'));
+  const binaryFeatures = features.filter(c => new Set(table[c]).size === 2 && table[c].every(v => v === 0 || v === 1));
+  const categoricalFeatures = features.filter(c => {
+    const u = new Set(table[c]);
+    return !binaryFeatures.includes(c) && u.size <= 20;
+  });
+  const continuousFeatures = features.filter(c => !binaryFeatures.includes(c) && !categoricalFeatures.includes(c));
+
+  function erf(x) {
+    const sign = x < 0 ? -1 : 1;
+    x = Math.abs(x);
+    const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+    const t = 1 / (1 + p * x);
+    const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+    return sign * y;
+  }
+  function pFromT(t) {
+    const z = Math.abs(t);
+    if (!Number.isFinite(z)) return 1;
+    if (z > 37) return 1e-300;
+    const cdf = 0.5 * (1 + erf(z / Math.SQRT2));
+    return Math.max(1e-300, Math.min(1, 2 * (1 - cdf)));
+  }
+  function q(arr, prob) {
+    const s = [...arr].sort((a, b) => a - b);
+    const pos = (s.length - 1) * prob;
+    const lo = Math.floor(pos), hi = Math.ceil(pos);
+    if (lo === hi) return s[lo];
+    return s[lo] * (hi - pos) + s[hi] * (pos - lo);
+  }
+  function makeIdx(mask) {
+    const idx = [];
+    for (let i = 0; i < n; i++) if (mask(i)) idx.push(i);
+    return idx;
+  }
+  const predicates = [];
+  for (const c of binaryFeatures) {
+    predicates.push({ feature: c, text: `${c}=1`, idx: makeIdx(i => table[c][i] === 1) });
+    predicates.push({ feature: c, text: `${c}=0`, idx: makeIdx(i => table[c][i] === 0) });
+  }
+  for (const c of categoricalFeatures) {
+    for (const lv of [...new Set(table[c])]) {
+      predicates.push({ feature: c, text: `${c}=${lv}`, idx: makeIdx(i => table[c][i] === lv) });
+    }
+  }
+  for (const c of continuousFeatures) {
+    const q25 = q(table[c], 0.25);
+    const q75 = q(table[c], 0.75);
+    predicates.push({ feature: c, text: `${c}<=${q25.toFixed(3)}`, idx: makeIdx(i => table[c][i] <= q25) });
+    predicates.push({ feature: c, text: `${c}>=${q75.toFixed(3)}`, idx: makeIdx(i => table[c][i] >= q75) });
+  }
+  function intersect(a, b) {
+    const out = [];
+    let i = 0, j = 0;
+    while (i < a.length && j < b.length) {
+      if (a[i] === b[j]) { out.push(a[i]); i++; j++; }
+      else if (a[i] < b[j]) i++;
+      else j++;
+    }
+    return out;
+  }
+  function statsForIdx(y, totalS, totalSS, idx) {
+    const n1 = idx.length;
+    if (n1 < 100 || n1 > n - 100) return null;
+    let s1 = 0, ss1 = 0;
+    for (const i of idx) { const v = y[i]; s1 += v; ss1 += v * v; }
+    const n0 = n - n1;
+    const s0 = totalS - s1;
+    const ss0 = totalSS - ss1;
+    const m1 = s1 / n1, m0 = s0 / n0;
+    const v1 = (ss1 - s1 * s1 / n1) / Math.max(1, n1 - 1);
+    const v0 = (ss0 - s0 * s0 / n0) / Math.max(1, n0 - 1);
+    const se = Math.sqrt(v1 / n1 + v0 / n0);
+    const t = (m1 - m0) / se;
+    return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, t, p: pFromT(t) };
+  }
+  function incompatible(a, b) {
+    return a.feature === b.feature && a.text !== b.text;
+  }
+  const report = {};
+  for (const ycol of outcomes) {
+    const y = table[ycol];
+    const totalS = y.reduce((a, v) => a + v, 0);
+    const totalSS = y.reduce((a, v) => a + v * v, 0);
+    const singles = [];
+    for (let i = 0; i < predicates.length; i++) {
+      const st = statsForIdx(y, totalS, totalSS, predicates[i].idx);
+      if (st) singles.push({ predicates: [predicates[i].text], features: [predicates[i].feature], ...st });
+    }
+    singles.sort((a, b) => a.t - b.t);
+    const pairs = [];
+    for (let i = 0; i < predicates.length; i++) {
+      for (let j = i + 1; j < predicates.length; j++) {
+        if (incompatible(predicates[i], predicates[j])) continue;
+        const idx = intersect(predicates[i].idx, predicates[j].idx);
+        if (idx.length < 250) continue;
+        const st = statsForIdx(y, totalS, totalSS, idx);
+        if (st) pairs.push({ predicates: [predicates[i].text, predicates[j].text], features: [predicates[i].feature, predicates[j].feature], idx, ...st });
+      }
+    }
+    pairs.sort((a, b) => a.t - b.t);
+    const triples = [];
+    for (const pair of pairs.slice(0, 150)) {
+      for (let k = 0; k < predicates.length; k++) {
+        if (pair.features.includes(predicates[k].feature)) continue;
+        const idx = intersect(pair.idx, predicates[k].idx);
+        if (idx.length < 200) continue;
+        const st = statsForIdx(y, totalS, totalSS, idx);
+        if (st) triples.push({ predicates: [...pair.predicates, predicates[k].text], features: [...pair.features, predicates[k].feature], ...st });
+      }
+    }
+    triples.sort((a, b) => a.t - b.t);
+    const clean = rows => rows.slice(0, 10).map(({ idx, features, ...r }) => r);
+    report[ycol] = { singles: clean(singles), pairs: clean(pairs), triples: clean(triples) };
+  }
+  console.log(JSON.stringify(report, null, 2));
+}

