+    const n = this.varintBig();
+    const val = (n >> 1n) ^ (-(n & 1n));
+    return Number(val);
+  }
+  binary() {
+    const n = this.varint();
+    const s = this.b.slice(this.o, this.o + n);
+    this.o += n;
+    return s;
+  }
+  string() {
+    return this.binary().toString('utf8');
+  }
+  double() {
+    const x = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return x;
+  }
+  float() {
+    const x = this.b.readFloatLE(this.o);
+    this.o += 4;
+    return x;
+  }
+  field(last) {
+    const h = this.u8();
+    const type = h & 0x0f;
+    if (type === CT.STOP) return { type };
+    const delta = h >> 4;
+    let id;
+    if (delta === 0) id = this.zigzag();
+    else id = last + delta;
+    return { type, id };
