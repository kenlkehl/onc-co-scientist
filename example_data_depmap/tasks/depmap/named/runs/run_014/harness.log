+        literalLen = 0;
+        for (let i = 0; i < n; i++) literalLen |= input[ip++] << (8 * i);
+        literalLen += 1;
+      }
+      input.copy(out, op, ip, ip + literalLen);
+      ip += literalLen;
+      op += literalLen;
+    } else {
+      let copyLen, offset;
+      if (type === 1) {
+        copyLen = 4 + ((tag >> 2) & 0x7);
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        copyLen = 1 + (tag >> 2);
