+      pred('growth_rate_doublings_per_day', i => table.growth_rate_doublings_per_day[i]),
+    ]),
+    TMED10_adjusted: ols('dependency_TMED10', [
+      pred('growth_rate_doublings_per_day', i => table.growth_rate_doublings_per_day[i]),
+      pred('cas9_activity_score', i => table.cas9_activity_score[i]),
+      pred('nf1_loss', i => table.nf1_loss[i]),
+      pred('copy_number_8q24', i => table.copy_number_8q24[i]),
+    ]),
+  };
+  const groups = {
+    BRAF_braf_v600e: groupStats('dependency_BRAF', i => table.braf_v600e[i] === 1),
+    EGFR_amp: groupStats('dependency_EGFR', i => table.egfr_amplification[i] === 1),
+    ERBB2_amp: groupStats('dependency_ERBB2', i => table.erbb2_amplification[i] === 1),
+    KRAS_mut: groupStats('dependency_KRAS', i => table.kras_mutation[i] === 1),
+    RIT1_nf1loss: groupStats('dependency_RIT1', i => table.nf1_loss[i] === 1),
+    KIF18A_colorectal_apc_wnt_smad4loss0: groupStats('dependency_KIF18A', i => I.colorectal(i) && I.apc(i) && I.wnt_high(i) && I.smad4_loss0(i)),
+    KIF18A_smad4_suppression_contrast: contrastStats(
+      'dependency_KIF18A',
+      i => I.colorectal(i) && I.apc(i) && I.wnt_high(i) && I.smad4_loss0(i),
+      i => I.colorectal(i) && I.apc(i) && I.wnt_high(i) && I.smad4_loss1(i)
+    ),
+    DHX9_myc_expr_high: groupStats('dependency_DHX9', I.myc_expr_high),
+    POLR2A_growth_high: groupStats('dependency_POLR2A', I.growth_high),
+    RPL11_cn8q24_high: groupStats('dependency_RPL11', I.cn8q24_high),
+    RPL11_mycamp_cn8q24_high: groupStats('dependency_RPL11', i => table.myc_amplification[i] === 1 && I.cn8q24_high(i)),
+    TMED10_growth_high: groupStats('dependency_TMED10', I.growth_high),
+  };
+  console.log(JSON.stringify({ thresholds, groups, models }, null, 2));
+}

diff --git a/example_data_depmap/tasks/depmap/named/analysis_work.js b/example_data_depmap/tasks/depmap/named/analysis_work.js
new file mode 100644
index 0000000000000000000000000000000000000000..d6f4fc844e21c89eb73dd53b93b4a4b2b8cf86ba
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/named/analysis_work.js
@@ -0,0 +1,982 @@
+const fs = require('fs');
+
+const file = 'dataset.parquet';
+const buf = fs.readFileSync(file);
+if (buf.slice(0, 4).toString() !== 'PAR1' || buf.slice(buf.length - 4).toString() !== 'PAR1') {
+  throw new Error('Not a Parquet file');
+}
+
+const footerLen = buf.readUInt32LE(buf.length - 8);
+const footer = buf.slice(buf.length - 8 - footerLen, buf.length - 8);
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+  FLOAT: 13,
