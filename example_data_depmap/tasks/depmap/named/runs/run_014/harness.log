+    } else if (type === CT.FLOAT) {
+      this.o += 4;
+    } else if (type === CT.BINARY) {
+      this.binary();
+    } else if (type === CT.LIST || type === CT.SET) {
+      const { size, etype } = this.listBegin();
+      for (let i = 0; i < size; i++) this.skip(etype);
+    } else if (type === CT.MAP) {
+      const size = this.varint();
+      if (size > 0) {
+        const types = this.u8();
+        const ktype = types >> 4;
+        const vtype = types & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(ktype);
+          this.skip(vtype);
+        }
+      }
+    } else if (type === CT.STRUCT) {
+      let last = 0;
+      while (true) {
+        const f = this.field(last);
+        if (f.type === CT.STOP) break;
+        last = f.id;
+        this.skip(f.type);
+      }
+    } else {
+      throw new Error(`Unknown compact type ${type} at ${this.o}`);
+    }
+  }
+}
+
+function readList(r, fn) {
+  const { size, etype } = r.listBegin();
+  const out = [];
+  for (let i = 0; i < size; i++) out.push(fn(r, etype));
+  return out;
+}
+
+function parseSchemaElement(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.type = r.zigzag();
+    else if (f.id === 2) x.type_length = r.zigzag();
+    else if (f.id === 3) x.repetition_type = r.zigzag();
+    else if (f.id === 4) x.name = r.string();
+    else if (f.id === 5) x.num_children = r.zigzag();
+    else if (f.id === 6) x.converted_type = r.zigzag();
+    else if (f.id === 7) x.scale = r.zigzag();
+    else if (f.id === 8) x.precision = r.zigzag();
+    else if (f.id === 9) x.field_id = r.zigzag();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseColumnMetaData(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.type = r.zigzag();
+    else if (f.id === 2) x.encodings = readList(r, rr => rr.zigzag());
+    else if (f.id === 3) x.path_in_schema = readList(r, rr => rr.string());
+    else if (f.id === 4) x.codec = r.zigzag();
+    else if (f.id === 5) x.num_values = r.zigzag();
+    else if (f.id === 6) x.total_uncompressed_size = r.zigzag();
+    else if (f.id === 7) x.total_compressed_size = r.zigzag();
+    else if (f.id === 9) x.data_page_offset = r.zigzag();
+    else if (f.id === 10) x.index_page_offset = r.zigzag();
+    else if (f.id === 11) x.dictionary_page_offset = r.zigzag();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseColumnChunk(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.file_path = r.string();
+    else if (f.id === 2) x.file_offset = r.zigzag();
+    else if (f.id === 3) x.meta_data = parseColumnMetaData(r);
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseRowGroup(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.columns = readList(r, rr => parseColumnChunk(rr));
+    else if (f.id === 2) x.total_byte_size = r.zigzag();
+    else if (f.id === 3) x.num_rows = r.zigzag();
+    else if (f.id === 5) x.file_offset = r.zigzag();
+    else if (f.id === 6) x.total_compressed_size = r.zigzag();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseFileMetaData(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.version = r.zigzag();
+    else if (f.id === 2) x.schema = readList(r, rr => parseSchemaElement(rr));
+    else if (f.id === 3) x.num_rows = r.zigzag();
+    else if (f.id === 4) x.row_groups = readList(r, rr => parseRowGroup(rr));
+    else if (f.id === 6) x.created_by = r.string();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+const meta = parseFileMetaData(new Reader(footer));
+const codecNames = ['UNCOMPRESSED', 'SNAPPY', 'GZIP', 'LZO', 'BROTLI', 'LZ4', 'ZSTD', 'LZ4_RAW'];
+const typeNames = ['BOOLEAN', 'INT32', 'INT64', 'INT96', 'FLOAT', 'DOUBLE', 'BYTE_ARRAY', 'FIXED_LEN_BYTE_ARRAY'];
+
+function parseDataPageHeader(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.num_values = r.zigzag();
+    else if (f.id === 2) x.encoding = r.zigzag();
+    else if (f.id === 3) x.definition_level_encoding = r.zigzag();
+    else if (f.id === 4) x.repetition_level_encoding = r.zigzag();
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseDictionaryPageHeader(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.num_values = r.zigzag();
+    else if (f.id === 2) x.encoding = r.zigzag();
+    else if (f.id === 3) x.is_sorted = f.type === CT.TRUE ? true : (f.type === CT.FALSE ? false : Boolean(r.u8()));
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parseDataPageHeaderV2(r) {
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.num_values = r.zigzag();
+    else if (f.id === 2) x.num_nulls = r.zigzag();
+    else if (f.id === 3) x.num_rows = r.zigzag();
+    else if (f.id === 4) x.encoding = r.zigzag();
+    else if (f.id === 5) x.definition_levels_byte_length = r.zigzag();
+    else if (f.id === 6) x.repetition_levels_byte_length = r.zigzag();
+    else if (f.id === 7) x.is_compressed = f.type === CT.TRUE ? true : (f.type === CT.FALSE ? false : Boolean(r.u8()));
+    else r.skip(f.type);
+  }
+  return x;
+}
+
+function parsePageHeaderAt(offset) {
+  const r = new Reader(buf.slice(offset));
+  const x = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === CT.STOP) break;
+    last = f.id;
+    if (f.id === 1) x.type = r.zigzag();
+    else if (f.id === 2) x.uncompressed_page_size = r.zigzag();
+    else if (f.id === 3) x.compressed_page_size = r.zigzag();
+    else if (f.id === 4) x.crc = r.zigzag();
+    else if (f.id === 5) x.data_page_header = parseDataPageHeader(r);
+    else if (f.id === 7) x.dictionary_page_header = parseDictionaryPageHeader(r);
+    else if (f.id === 8) x.data_page_header_v2 = parseDataPageHeaderV2(r);
+    else r.skip(f.type);
+  }
+  x.header_size = r.o;
+  return x;
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[ip++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
+        const n = literalLen - 59;
+        literalLen = 0;
+        for (let i = 0; i < n; i++) literalLen |= input[ip++] << (8 * i);
+        literalLen += 1;
+      }
+      input.copy(out, op, ip, ip + literalLen);
+      ip += literalLen;
+      op += literalLen;
+    } else {
+      let copyLen, offset;
+      if (type === 1) {
+        copyLen = 4 + ((tag >> 2) & 0x7);
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        copyLen = 1 + (tag >> 2);
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        copyLen = 1 + (tag >> 2);
+        offset = input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24);
+        ip += 4;
+      }
+      for (let i = 0; i < copyLen; i++) out[op + i] = out[op - offset + i];
+      op += copyLen;
+    }
+  }
+  if (op !== len) throw new Error(`Snappy length mismatch: ${op} != ${len}`);
+  return out;
+}
+
+function readVarintAt(b, offset) {
+  let out = 0;
+  let shift = 0;
+  let o = offset;
+  while (true) {
+    const x = b[o++];
+    out |= (x & 0x7f) << shift;
+    if ((x & 0x80) === 0) return { value: out, offset: o };
+    shift += 7;
+  }
+}
+
+function readBits(b, bitPos, width) {
+  let x = 0;
+  for (let j = 0; j < width; j++) {
+    const byte = b[bitPos >> 3];
+    const bit = (byte >> (bitPos & 7)) & 1;
+    x |= bit << j;
+    bitPos++;
+  }
+  return { value: x, bitPos };
+}
+
+function decodeHybrid(b, offset, bitWidth, count) {
+  const values = [];
+  let o = offset;
+  while (values.length < count) {
+    const hv = readVarintAt(b, o);
+    const header = hv.value;
+    o = hv.offset;
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const bytes = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < bytes; i++) value |= b[o + i] << (8 * i);
+      o += bytes;
+      for (let i = 0; i < run && values.length < count; i++) values.push(value);
+    } else {
+      const groups = header >> 1;
+      let bitPos = o * 8;
+      const total = groups * 8;
+      for (let i = 0; i < total && values.length < count; i++) {
+        const rv = readBits(b, bitPos, bitWidth);
+        values.push(rv.value);
+        bitPos = rv.bitPos;
+      }
+      o = Math.ceil(bitPos / 8);
+    }
+  }
+  return { values, offset: o };
+}
+
+function decodePlain(b, type, count) {
+  const out = [];
+  let o = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === 5) {
+      out.push(b.readDoubleLE(o));
+      o += 8;
+    } else if (type === 2) {
+      out.push(Number(b.readBigInt64LE(o)));
+      o += 8;
+    } else if (type === 1) {
+      out.push(b.readInt32LE(o));
+      o += 4;
+    } else if (type === 6) {
+      const n = b.readInt32LE(o);
+      o += 4;
+      out.push(b.slice(o, o + n).toString('utf8'));
+      o += n;
+    } else {
+      throw new Error(`Unsupported plain type ${type}`);
+    }
+  }
+  return out;
+}
+
+function getPagePayload(pos, ph, codec) {
+  const start = pos + ph.header_size;
+  const compressed = buf.slice(start, start + ph.compressed_page_size);
+  let payload;
+  if (codec === 0) payload = compressed;
+  else if (codec === 1) payload = snappyUncompress(compressed);
+  else throw new Error(`Unsupported codec ${codec}`);
+  return { payload, next: start + ph.compressed_page_size };
+}
+
+function decodeColumn(col) {
+  const md = col.meta_data;
+  let pos = md.dictionary_page_offset ?? md.data_page_offset;
+  const end = pos + md.total_compressed_size;
+  let dictionary = null;
+  const values = [];
+  while (values.length < md.num_values && pos < end) {
+    const ph = parsePageHeaderAt(pos);
+    const { payload, next } = getPagePayload(pos, ph, md.codec);
+    pos = next;
+    if (ph.type === 2) {
+      dictionary = decodePlain(payload, md.type, ph.dictionary_page_header.num_values);
+    } else if (ph.type === 0) {
+      const h = ph.data_page_header;
+      let o = 0;
+      const defLen = payload.readInt32LE(o);
+      o += 4;
+      const def = decodeHybrid(payload.slice(o, o + defLen), 0, 1, h.num_values);
+      o += defLen;
+      const nonNull = def.values.reduce((a, x) => a + (x > 0 ? 1 : 0), 0);
+      let decoded;
+      if (h.encoding === 8 || h.encoding === 2) {
+        const bitWidth = payload[o++];
+        const ids = decodeHybrid(payload, o, bitWidth, nonNull);
+        o = ids.offset;
+        if (!dictionary) throw new Error(`Missing dictionary for ${md.path_in_schema.join('.')}`);
+        decoded = ids.values.map(id => dictionary[id]);
+      } else if (h.encoding === 0) {
+        decoded = decodePlain(payload.slice(o), md.type, nonNull);
+      } else {
+        throw new Error(`Unsupported data page encoding ${h.encoding} for ${md.path_in_schema.join('.')}`);
+      }
+      let j = 0;
+      for (const d of def.values) values.push(d > 0 ? decoded[j++] : null);
+    } else if (ph.type === 3) {
+      const h = ph.data_page_header_v2;
+      let o = 0;
+      // No repeated fields in this file, so repetition level byte length is zero.
+      o += h.repetition_levels_byte_length || 0;
+      const defSlice = payload.slice(o, o + h.definition_levels_byte_length);
+      o += h.definition_levels_byte_length;
+      const def = decodeHybrid(defSlice, 0, 1, h.num_values);
+      const nonNull = def.values.reduce((a, x) => a + (x > 0 ? 1 : 0), 0);
+      const data = payload.slice(o);
+      let decoded;
+      if (h.encoding === 8 || h.encoding === 2) {
+        const bitWidth = data[0];
+        const ids = decodeHybrid(data, 1, bitWidth, nonNull);
+        if (!dictionary) throw new Error(`Missing dictionary for ${md.path_in_schema.join('.')}`);
+        decoded = ids.values.map(id => dictionary[id]);
+      } else if (h.encoding === 0) {
+        decoded = decodePlain(data, md.type, nonNull);
+      } else {
+        throw new Error(`Unsupported data page v2 encoding ${h.encoding}`);
+      }
+      let j = 0;
+      for (const d of def.values) values.push(d > 0 ? decoded[j++] : null);
+    } else {
+      throw new Error(`Unsupported page type ${ph.type}`);
+    }
+  }
+  if (values.length !== md.num_values) throw new Error(`Value count mismatch for ${md.path_in_schema.join('.')}: ${values.length}`);
+  return values;
+}
+
+function loadTable() {
+  const rg = meta.row_groups[0];
+  const table = {};
+  for (const col of rg.columns) {
+    const name = col.meta_data.path_in_schema.join('.');
+    table[name] = decodeColumn(col);
+  }
+  return table;
+}
+
+if (process.argv[2] === 'metadata') {
+  console.log(JSON.stringify({
+    version: meta.version,
+    num_rows: meta.num_rows,
+    created_by: meta.created_by,
+    schema: meta.schema.map(s => ({ name: s.name, type: typeNames[s.type] ?? s.type, rep: s.repetition_type, children: s.num_children })),
+    row_groups: meta.row_groups.map(rg => ({
+      num_rows: rg.num_rows,
+      columns: rg.columns.map(c => ({
+        path: c.meta_data.path_in_schema.join('.'),
+        type: typeNames[c.meta_data.type] ?? c.meta_data.type,
+        codec: codecNames[c.meta_data.codec] ?? c.meta_data.codec,
+        encodings: c.meta_data.encodings,
+        values: c.meta_data.num_values,
+        data_page_offset: c.meta_data.data_page_offset,
+        dictionary_page_offset: c.meta_data.dictionary_page_offset,
+        compressed: c.meta_data.total_compressed_size,
+        uncompressed: c.meta_data.total_uncompressed_size,
+      }))
+    }))
+  }, null, 2));
+} else if (process.argv[2] === 'peek') {
+  const table = loadTable();
+  const names = Object.keys(table);
+  console.log(`rows=${table[names[0]].length} cols=${names.length}`);
+  for (let i = 0; i < 5; i++) {
+    const row = {};
+    for (const n of names.slice(0, 12)) row[n] = table[n][i];
+    for (const n of names.slice(-10)) row[n] = table[n][i];
+    console.log(JSON.stringify(row));
+  }
+} else if (process.argv[2] === 'scan') {
+  const table = loadTable();
+  const names = Object.keys(table);
+  const n = table[names[0]].length;
+  const outcomes = names.filter(x => x.startsWith('dependency_'));
+  const features = names.filter(x => x !== 'cell_line_id' && !x.startsWith('dependency_'));
+  const binaryFeatures = features.filter(c => new Set(table[c]).size === 2 && table[c].every(v => v === 0 || v === 1));
+  const categoricalFeatures = features.filter(c => {
+    const u = new Set(table[c]);
+    return !binaryFeatures.includes(c) && u.size <= 20;
+  });
+  const continuousFeatures = features.filter(c => !binaryFeatures.includes(c) && !categoricalFeatures.includes(c));
+
+  function erf(x) {
+    const sign = x < 0 ? -1 : 1;
+    x = Math.abs(x);
+    const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+    const t = 1 / (1 + p * x);
+    const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+    return sign * y;
+  }
+  function pFromT(t) {
+    const z = Math.abs(t);
+    if (!Number.isFinite(z)) return 1;
+    if (z > 37) return 1e-300;
+    const cdf = 0.5 * (1 + erf(z / Math.SQRT2));
+    return Math.max(1e-300, Math.min(1, 2 * (1 - cdf)));
+  }
+  function summarize(y, mask) {
+    let n1 = 0, s1 = 0, ss1 = 0, n0 = 0, s0 = 0, ss0 = 0;
+    for (let i = 0; i < n; i++) {
+      const v = y[i];
+      if (mask(i)) {
+        n1++; s1 += v; ss1 += v * v;
+      } else {
+        n0++; s0 += v; ss0 += v * v;
+      }
+    }
+    const m1 = s1 / n1, m0 = s0 / n0;
+    const v1 = (ss1 - s1 * s1 / n1) / Math.max(1, n1 - 1);
+    const v0 = (ss0 - s0 * s0 / n0) / Math.max(1, n0 - 1);
+    const se = Math.sqrt(v1 / n1 + v0 / n0);
+    const t = (m1 - m0) / se;
+    return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, t, p: pFromT(t) };
+  }
+  function slopeTest(x, y) {
+    let sx = 0, sy = 0, sxx = 0, sxy = 0;
+    for (let i = 0; i < n; i++) { sx += x[i]; sy += y[i]; }
+    const mx = sx / n, my = sy / n;
+    for (let i = 0; i < n; i++) {
+      const dx = x[i] - mx, dy = y[i] - my;
+      sxx += dx * dx;
+      sxy += dx * dy;
+    }
+    const slope = sxy / sxx;
+    const intercept = my - slope * mx;
+    let rss = 0;
+    for (let i = 0; i < n; i++) {
+      const e = y[i] - intercept - slope * x[i];
+      rss += e * e;
+    }
+    const se = Math.sqrt((rss / (n - 2)) / sxx);
+    const t = slope / se;
+    return { slope, t, p: pFromT(t) };
+  }
+
+  const report = {};
+  for (const ycol of outcomes) {
+    const y = table[ycol];
+    const rows = [];
+    for (const c of binaryFeatures) {
+      const s = summarize(y, i => table[c][i] === 1);
+      rows.push({ type: 'binary', feature: c, level: 1, ...s });
+    }
+    for (const c of categoricalFeatures) {
+      const levels = [...new Set(table[c])];
+      for (const lv of levels) {
+        const s = summarize(y, i => table[c][i] === lv);
+        rows.push({ type: 'categorical', feature: c, level: lv, ...s });
+      }
+    }
+    for (const c of continuousFeatures) {
+      const s = slopeTest(table[c], y);
+      rows.push({ type: 'continuous', feature: c, effect: s.slope, t: s.t, p: s.p });
+    }
+    rows.sort((a, b) => Math.abs(b.t) - Math.abs(a.t));
+    report[ycol] = rows.slice(0, 8).map(r => ({
+      type: r.type,
+      feature: r.feature,
+      level: r.level,
+      n1: r.n1,
+      n0: r.n0,
+      mean1: r.mean1,
+      mean0: r.mean0,
+      effect: r.effect,
+      t: r.t,
+      p: r.p
+    }));
+  }
+  console.log(JSON.stringify({ binaryFeatures, categoricalFeatures, continuousFeatures, report }, null, 2));
+}

