import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
print('n_features', len(features), 'n_outcomes', len(outcomes))
print('\\nfeature summary:')
for c in features:
    s=df[c]
    nun=s.nunique()
    vals=s.value_counts().head(8).to_dict() if nun<=8 else None
    print(c, 'dtype', s.dtype, 'nunique', nun, 'mean', float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, 'std', float(s.std()) if pd.api.types.is_numeric_dtype(s) else None, 'min', s.min(), 'max', s.max(), 'vals', vals)
print('\\noutcome summary:')
print(df[outcomes].agg(['mean','std','min','max']).T.to_string())
print('\\noutcome correlations:')
print(df[outcomes].corr().round(3).to_string())
