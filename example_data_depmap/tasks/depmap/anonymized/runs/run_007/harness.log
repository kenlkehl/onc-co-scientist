diff --git a/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js b/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js
new file mode 100644
index 0000000000000000000000000000000000000000..5005092f13b8fc222e485927c334fc33f5bcc092
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js
@@ -0,0 +1,202 @@
+const fs = require('fs');
+
+const buf = fs.readFileSync('dataset.parquet');
+function readU32LE(pos) { return buf.readUInt32LE(pos); }
+const magic1 = buf.subarray(0, 4).toString('ascii');
+const magic2 = buf.subarray(buf.length - 4).toString('ascii');
+const footerLen = readU32LE(buf.length - 8);
+const footerStart = buf.length - 8 - footerLen;
+console.log({ len: buf.length, magic1, magic2, footerLen, footerStart });
+
+const TC = { STOP:0, TRUE:1, FALSE:2, BYTE:3, I16:4, I32:5, I64:6, DOUBLE:7, BINARY:8, LIST:9, SET:10, MAP:11, STRUCT:12 };
+
+class Reader {
+  constructor(b, pos=0, end=b.length) { this.b=b; this.pos=pos; this.end=end; this.stack=[0]; }
+  byte(){ return this.b[this.pos++]; }
+  varintBig(){
+    let shift=0n, out=0n;
+    while(true){
+      const x=this.byte();
+      out |= BigInt(x & 0x7f) << shift;
+      if((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
+  varint(){ return Number(this.varintBig()); }
+  zigzag(n){ return (n >>> 1) ^ -(n & 1); }
+  zigzagBig(n){ return (n >> 1n) ^ (-(n & 1n)); }
+  i16(){ return this.zigzag(this.varint()); }
+  i32(){ return this.zigzag(this.varint()); }
+  i64(){ return this.zigzagBig(this.varintBig()); }
+  double(){ const v=this.b.readDoubleLE(this.pos); this.pos+=8; return v; }
+  binary(){ const n=this.varint(); const s=this.b.subarray(this.pos,this.pos+n); this.pos+=n; return s; }
+  fieldHeader(){
+    const h=this.byte();
+    const type=h & 0x0f;
+    if(type===TC.STOP) return {type, id:null};
+    const delta=h >> 4;
+    let id;
+    if(delta) id=this.stack[this.stack.length-1]+delta; else id=this.i16();
+    this.stack[this.stack.length-1]=id;
+    return {type,id};
+  }
+  listHeader(){
+    const h=this.byte();
+    let size=h>>4, type=h & 0x0f;
+    if(size===15) size=this.varint();
+    return {size,type};
+  }
+  readType(type){
+    switch(type){
+      case TC.TRUE: return true;
+      case TC.FALSE: return false;
+      case TC.BYTE: return (this.byte()<<24)>>24;
+      case TC.I16: return this.i16();
+      case TC.I32: return this.i32();
+      case TC.I64: return this.i64();
+      case TC.DOUBLE: return this.double();
+      case TC.BINARY: return this.binary().toString('utf8');
+      case TC.STRUCT: return this.readAnyStruct();
+      case TC.LIST: {
+        const {size,type:et}=this.listHeader();
+        const a=[];
+        for(let i=0;i<size;i++) a.push(this.readType(et));
+        return a;
+      }
+      case TC.SET: {
+        const {size,type:et}=this.listHeader();
+        const a=[];
+        for(let i=0;i<size;i++) a.push(this.readType(et));
+        return a;
+      }
+      case TC.MAP: {
+        const n=this.varint();
+        if(n===0) return [];
+        const ktvt=this.byte();
+        const kt=(ktvt>>4)&0x0f, vt=ktvt&0x0f;
+        const a=[];
+        for(let i=0;i<n;i++) a.push([this.readType(kt), this.readType(vt)]);
+        return a;
+      }
+      default: throw new Error('unknown compact type '+type+' at '+this.pos);
+    }
+  }
+  readAnyStruct(){
+    const out={};
+    this.stack.push(0);
+    while(true){
+      const {type,id}=this.fieldHeader();
+      if(type===TC.STOP) break;
+      out[id]=this.readType(type);
+    }
+    this.stack.pop();
+    return out;
+  }
+}
+
+function parseFileMeta(r){
+  const fm={schema:[], row_groups:[]};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) fm.version=r.readType(type);
+    else if(id===2) {
+      const lh=r.listHeader();
+      for(let i=0;i<lh.size;i++) fm.schema.push(parseSchemaElement(r));
+    } else if(id===3) fm.num_rows=Number(r.readType(type));
+    else if(id===4) {
+      const lh=r.listHeader();
+      for(let i=0;i<lh.size;i++) fm.row_groups.push(parseRowGroup(r));
+    } else if(id===6) fm.created_by=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return fm;
+}
+function parseSchemaElement(r){
+  const se={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) se.type=r.readType(type);
+    else if(id===2) se.type_length=r.readType(type);
+    else if(id===3) se.repetition_type=r.readType(type);
+    else if(id===4) se.name=r.readType(type);
+    else if(id===5) se.num_children=r.readType(type);
+    else if(id===6) se.converted_type=r.readType(type);
+    else if(id===7) se.scale=r.readType(type);
+    else if(id===8) se.precision=r.readType(type);
+    else if(id===9) se.field_id=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return se;
+}
+function parseRowGroup(r){
+  const rg={columns:[]};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1){
+      const lh=r.listHeader();
+      for(let i=0;i<lh.size;i++) rg.columns.push(parseColumnChunk(r));
+    } else if(id===2) rg.total_byte_size=Number(r.readType(type));
+    else if(id===3) rg.num_rows=Number(r.readType(type));
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return rg;
+}
+function parseColumnChunk(r){
+  const cc={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) cc.file_path=r.readType(type);
+    else if(id===2) cc.file_offset=Number(r.readType(type));
+    else if(id===3) cc.meta_data=parseColumnMetaData(r);
+    else if(id===4) cc.offset_index_offset=Number(r.readType(type));
+    else if(id===5) cc.offset_index_length=r.readType(type);
+    else if(id===6) cc.column_index_offset=Number(r.readType(type));
+    else if(id===7) cc.column_index_length=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return cc;
+}
+function parseColumnMetaData(r){
+  const md={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) md.type=r.readType(type);
+    else if(id===2) { const lh=r.listHeader(); md.encodings=[]; for(let i=0;i<lh.size;i++) md.encodings.push(r.readType(lh.type)); }
+    else if(id===3) { const lh=r.listHeader(); md.path_in_schema=[]; for(let i=0;i<lh.size;i++) md.path_in_schema.push(r.readType(lh.type)); }
+    else if(id===4) md.codec=r.readType(type);
+    else if(id===5) md.num_values=Number(r.readType(type));
+    else if(id===6) md.total_uncompressed_size=Number(r.readType(type));
+    else if(id===7) md.total_compressed_size=Number(r.readType(type));
+    else if(id===9) md.data_page_offset=Number(r.readType(type));
+    else if(id===10) md.index_page_offset=Number(r.readType(type));
+    else if(id===11) md.dictionary_page_offset=Number(r.readType(type));
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return md;
+}
+
+const r = new Reader(buf.subarray(footerStart, footerStart + footerLen));
+const meta = parseFileMeta(r);
+console.log('meta', {version: meta.version, num_rows: meta.num_rows, created_by: meta.created_by, schema_len: meta.schema.length, row_groups: meta.row_groups.length});
+console.log('schema');
+for (const s of meta.schema) console.log(s);
+for (let rg=0; rg<meta.row_groups.length; rg++) {
+  console.log('row_group', rg, {num_rows: meta.row_groups[rg].num_rows, cols: meta.row_groups[rg].columns.length});
+  for (const c of meta.row_groups[rg].columns) console.log(c.meta_data);
+}

