+function snappyUncompress(input) {
+  let pos = 0;
+  let resultLen = 0, shift = 0;
+  while (true) {
+    const b = input[pos++];
+    resultLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(resultLen);
+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let len;
+      if (lenCode < 60) {
+        len = lenCode + 1;
+      } else {
+        const bytes = lenCode - 59;
+        len = 1;
+        let v = 0;
+        for (let i=0; i<bytes; i++) v |= input[pos++] << (8*i);
+        len = v + 1;
+      }
+      input.copy(out, outPos, pos, pos + len);
+      pos += len;
+      outPos += len;
+    } else {
+      let len, offset;
+      if (type === 1) {
+        len = 4 + ((tag >> 2) & 0x7);
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = 1 + (tag >> 2);
+        offset = input[pos] | (input[pos+1] << 8);
+        pos += 2;
+      } else {
+        len = 1 + (tag >> 2);
+        offset = input[pos] | (input[pos+1] << 8) | (input[pos+2] << 16) | (input[pos+3] << 24);
+        pos += 4;
+      }
+      for (let i=0; i<len; i++) {
+        out[outPos] = out[outPos - offset];
+        outPos++;
+      }
+    }
+  }
+  if (outPos !== resultLen) throw new Error(`snappy length mismatch ${outPos} != ${resultLen}`);
+  return out;
+}
+
+function decodePlainValues(b, type, count) {
+  let pos = 0;
+  const out = new Array(count);
+  for (let i=0; i<count; i++) {
+    if (type === 5) { out[i] = b.readDoubleLE(pos); pos += 8; }
+    else if (type === 4) { out[i] = b.readFloatLE(pos); pos += 4; }
+    else if (type === 2) { out[i] = Number(b.readBigInt64LE(pos)); pos += 8; }
+    else if (type === 1) { out[i] = b.readInt32LE(pos); pos += 4; }
+    else if (type === 6) { const n=b.readUInt32LE(pos); pos += 4; out[i] = b.subarray(pos,pos+n).toString('utf8'); pos += n; }
+    else throw new Error('plain type not supported '+type);
+  }
+  return out;
