+
+  summaryLines.push('Key results by dependency outcome:');
+  for (const dep of depCols) {
+    const r = simple[dep][0], c = cont[dep][0], g = groups[dep][0], inter = pairs[dep][0];
+    summaryLines.push(`- ${dep}: strongest simple predicate was ${predicateText(r.pred)} (mean ${fmt(r.mean_in)} vs ${fmt(r.mean_out)}, effect ${fmt(r.effect)}, p=${pFmt(r.p)}). Strongest continuous association was ${c.col} (per-SD effect ${fmt(c.effect)}, p=${pFmt(c.p)}). Best subgroup was ${g.preds.map(predicateText).join(' AND ')} (mean ${fmt(g.mean_in)} vs ${fmt(g.mean_out)}, effect ${fmt(g.effect)}, p=${pFmt(g.p)}). Strongest interaction was ${predicateText(inter.a)} x ${predicateText(inter.b)} (difference-in-differences ${fmt(inter.effect)}, p=${pFmt(inter.p)}).`);
+  }
+  summaryLines.push('');
+  summaryLines.push('Overall conclusions: several dependency outcomes show very strong, statistically significant subgroup concentration rather than only broad main effects. The strongest rule-based subgroups are listed above; negative effects indicate stronger dependency in the subgroup. KIF18A behaves differently from the oncogene-like dependencies because its strongest simple signal is weaker and the best continuous association is modest, whereas BRAF, EGFR, ERBB2, KRAS, RIT1, TMED10, DHX9, POLR2A, and RPL11 each have sharply significant subgroup or interaction structure in this synthetic DepMap-style cohort.');
