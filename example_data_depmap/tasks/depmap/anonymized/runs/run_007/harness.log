+
+function meanVar(values, mask=null, want=1) {
+  let n=0, sum=0, sum2=0;
+  for (let i=0; i<values.length; i++) {
+    if (mask && mask[i] !== want) continue;
+    const v = values[i];
+    n++; sum += v; sum2 += v*v;
+  }
+  const mean = sum / n;
+  const variance = n > 1 ? Math.max(0, (sum2 - sum*sum/n) / (n-1)) : 0;
+  return {n, mean, variance, sum, sum2};
+}
+function effectForMask(mask, y) {
+  const a = meanVar(y, mask, 1);
+  const b = meanVar(y, mask, 0);
+  const effect = a.mean - b.mean;
+  const se = Math.sqrt(a.variance/a.n + b.variance/b.n);
+  const z = se > 0 ? effect / se : 0;
+  return {n_in:a.n, n_out:b.n, mean_in:a.mean, mean_out:b.mean, effect, se, z, p:pFromZ(z), significant:pFromZ(z)<0.05};
+}
+function continuousEffect(x, y) {
+  const n = x.length;
+  let sx=0, sy=0;
+  for (let i=0;i<n;i++){ sx += x[i]; sy += y[i]; }
+  const mx=sx/n, my=sy/n;
+  let sxx=0, sxy=0, rss=0;
+  for (let i=0;i<n;i++){ const dx=x[i]-mx; sxx += dx*dx; sxy += dx*(y[i]-my); }
+  const slope = sxy/sxx;
+  const intercept = my - slope*mx;
+  for (let i=0;i<n;i++){ const e = y[i] - (intercept + slope*x[i]); rss += e*e; }
+  const sigma2 = rss/(n-2);
+  const seSlope = Math.sqrt(sigma2/sxx);
+  const mean = mx;
+  const sd = Math.sqrt(sxx/(n-1));
+  const effect = slope * sd;
+  const z = seSlope>0 ? slope/seSlope : 0;
+  return {n, slope, effect, x_mean:mean, x_sd:sd, se:seSlope*sd, z, p:pFromZ(z), significant:pFromZ(z)<0.05};
+}
+function interactionEffect(aMask, bMask, y) {
+  const cells = [
+    {n:0,sum:0,sum2:0}, {n:0,sum:0,sum2:0}, {n:0,sum:0,sum2:0}, {n:0,sum:0,sum2:0}
+  ];
+  for (let i=0; i<y.length; i++) {
+    const idx = (aMask[i] ? 2 : 0) + (bMask[i] ? 1 : 0);
+    const c = cells[idx], v = y[i];
+    c.n++; c.sum += v; c.sum2 += v*v;
+  }
+  for (const c of cells) {
+    c.mean = c.sum / c.n;
+    c.variance = c.n > 1 ? Math.max(0, (c.sum2 - c.sum*c.sum/c.n)/(c.n-1)) : 0;
+  }
+  if (cells.some(c => c.n < 50)) return null;
+  const m00=cells[0].mean, m01=cells[1].mean, m10=cells[2].mean, m11=cells[3].mean;
+  const effect = (m11 - m01) - (m10 - m00);
+  const se = Math.sqrt(cells.reduce((acc,c)=>acc+c.variance/c.n,0));
+  const z = se>0 ? effect/se : 0;
+  return {cells, effect, se, z, p:pFromZ(z), significant:pFromZ(z)<0.05};
+}
+function combineMasks(preds) {
+  const n = preds[0].mask.length;
+  const out = new Uint8Array(n);
+  for (let i=0; i<n; i++) {
+    let ok = 1;
+    for (const p of preds) if (!p.mask[i]) { ok=0; break; }
+    out[i]=ok;
+  }
+  return out;
+}
+function quantile(values, q) {
+  const a = Array.from(values).sort((x,y)=>x-y);
+  const pos = (a.length - 1) * q;
+  const lo = Math.floor(pos), hi = Math.ceil(pos);
+  if (lo === hi) return a[lo];
+  return a[lo] + (a[hi]-a[lo])*(pos-lo);
+}
+function uniqueValues(values) {
+  const m = new Map();
+  for (const v of values) m.set(String(v), v);
+  return Array.from(m.values());
+}
+function fmt(x, digits=4) {
+  if (!Number.isFinite(x)) return String(x);
+  const ax = Math.abs(x);
+  if (ax > 0 && ax < 0.0001) return x.toExponential(2);
