+  const names = Object.keys(columns);
+  const depCols = names.filter(n => n.startsWith('dependency_'));
+  const featureCols = names.filter(n => n.startsWith('feature_'));
+  const n = meta.num_rows;
+
+  const predicates = [];
+  const continuous = [];
+  for (const col of featureCols) {
+    const vals = columns[col];
+    const uniq = uniqueValues(vals);
