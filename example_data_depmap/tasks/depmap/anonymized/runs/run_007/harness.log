+const TC = { STOP:0, TRUE:1, FALSE:2, BYTE:3, I16:4, I32:5, I64:6, DOUBLE:7, BINARY:8, LIST:9, SET:10, MAP:11, STRUCT:12 };
+const PTYPE = ['BOOLEAN','INT32','INT64','INT96','FLOAT','DOUBLE','BYTE_ARRAY','FIXED_LEN_BYTE_ARRAY'];
+const ENCODING = {
+  0: 'PLAIN',
+  1: 'PLAIN_DICTIONARY',
+  2: 'PLAIN_DICTIONARY',
+  3: 'RLE',
+  4: 'BIT_PACKED',
+  5: 'DELTA_BINARY_PACKED',
+  6: 'DELTA_LENGTH_BYTE_ARRAY',
