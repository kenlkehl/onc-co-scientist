+  const mx=sx/n, my=sy/n;
+  let sxx=0, sxy=0, rss=0;
+  for (let i=0;i<n;i++){ const dx=x[i]-mx; sxx += dx*dx; sxy += dx*(y[i]-my); }
+  const slope = sxy/sxx;
+  const intercept = my - slope*mx;
+  for (let i=0;i<n;i++){ const e = y[i] - (intercept + slope*x[i]); rss += e*e; }
+  const sigma2 = rss/(n-2);
+  const seSlope = Math.sqrt(sigma2/sxx);
+  const mean = mx;
+  const sd = Math.sqrt(sxx/(n-1));
+  const effect = slope * sd;
+  const z = seSlope>0 ? slope/seSlope : 0;
+  return {n, slope, effect, x_mean:mean, x_sd:sd, se:seSlope*sd, z, p:pFromZ(z), significant:pFromZ(z)<0.05};
+}
+function interactionEffect(aMask, bMask, y) {
+  const cells = [
+    {n:0,sum:0,sum2:0}, {n:0,sum:0,sum2:0}, {n:0,sum:0,sum2:0}, {n:0,sum:0,sum2:0}
+  ];
+  for (let i=0; i<y.length; i++) {
+    const idx = (aMask[i] ? 2 : 0) + (bMask[i] ? 1 : 0);
+    const c = cells[idx], v = y[i];
+    c.n++; c.sum += v; c.sum2 += v*v;
+  }
+  for (const c of cells) {
+    c.mean = c.sum / c.n;
+    c.variance = c.n > 1 ? Math.max(0, (c.sum2 - c.sum*c.sum/c.n)/(c.n-1)) : 0;
+  }
+  if (cells.some(c => c.n < 50)) return null;
+  const m00=cells[0].mean, m01=cells[1].mean, m10=cells[2].mean, m11=cells[3].mean;
+  const effect = (m11 - m01) - (m10 - m00);
+  const se = Math.sqrt(cells.reduce((acc,c)=>acc+c.variance/c.n,0));
+  const z = se>0 ? effect/se : 0;
+  return {cells, effect, se, z, p:pFromZ(z), significant:pFromZ(z)<0.05};
+}
+function combineMasks(preds) {
+  const n = preds[0].mask.length;
+  const out = new Uint8Array(n);
+  for (let i=0; i<n; i++) {
+    let ok = 1;
+    for (const p of preds) if (!p.mask[i]) { ok=0; break; }
+    out[i]=ok;
+  }
+  return out;
+}
+function quantile(values, q) {
+  const a = Array.from(values).sort((x,y)=>x-y);
+  const pos = (a.length - 1) * q;
+  const lo = Math.floor(pos), hi = Math.ceil(pos);
+  if (lo === hi) return a[lo];
+  return a[lo] + (a[hi]-a[lo])*(pos-lo);
+}
+function uniqueValues(values) {
+  const m = new Map();
+  for (const v of values) m.set(String(v), v);
+  return Array.from(m.values());
+}
+function fmt(x, digits=4) {
+  if (!Number.isFinite(x)) return String(x);
+  const ax = Math.abs(x);
+  if (ax > 0 && ax < 0.0001) return x.toExponential(2);
+  return Number(x.toFixed(digits)).toString();
+}
+function pFmt(p) {
+  if (p <= 1e-300) return '<1e-300';
+  if (p < 0.0001) return p.toExponential(2);
+  return fmt(p, 4);
+}
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1=0.254829592, a2=-0.284496736, a3=1.421413741, a4=-1.453152027, a5=1.061405429, p=0.3275911;
+  const t = 1/(1+p*x);
+  const y = 1 - (((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x);
+  return sign*y;
+}
+function pFromZ(z) {
+  const az = Math.abs(z);
+  if (az > 37) return 1e-300;
+  const p = 1 - erf(az/Math.SQRT2);
+  return Math.max(p, 1e-300);
+}
+function describeDirection(effect, outcome) {
+  return effect < 0 ? `more negative ${outcome} scores` : `less negative ${outcome} scores`;
+}
+function predicateText(pred) {
+  return pred.text;
+}
+function analysisRecord(hids, method, res, extra='') {
+  const sig = res.p < 0.05;
+  return {
+    hypothesis_ids: Array.isArray(hids) ? hids : [hids],
+    code: method,
+    result_summary: `${extra}${extra ? ' ' : ''}Effect estimate ${fmt(res.effect)}; p=${pFmt(res.p)}; significant=${sig}.`,
+    p_value: res.p,
+    effect_estimate: res.effect,
+    significant: sig
+  };
+}
+function performAnalysis(meta) {
+  const rg = meta.row_groups[0];
+  const columns = {};
+  for (let i=1; i<meta.schema.length; i++) {
+    const name = meta.schema[i].name;
+    columns[name] = decodeColumn(rg.columns[i-1], meta.schema[i]);
+  }
+  const names = Object.keys(columns);
+  const depCols = names.filter(n => n.startsWith('dependency_'));
+  const featureCols = names.filter(n => n.startsWith('feature_'));
+  const n = meta.num_rows;
+
+  const predicates = [];
+  const continuous = [];
+  for (const col of featureCols) {
+    const vals = columns[col];
+    const uniq = uniqueValues(vals);
+    if (typeof vals[0] === 'string') {
+      for (const level of uniq) {
+        const mask = new Uint8Array(n);
+        for (let i=0;i<n;i++) if (vals[i] === level) mask[i] = 1;
+        predicates.push({id:`${col}=${level}`, text:`${col} == "${level}"`, mask, source:col, kind:'categorical'});
+      }
+    } else if (uniq.length <= 6) {
+      for (const level of uniq) {
+        const mask = new Uint8Array(n);
+        for (let i=0;i<n;i++) if (vals[i] === level) mask[i] = 1;
+        predicates.push({id:`${col}=${level}`, text:`${col} == ${level}`, mask, source:col, kind:'discrete'});
+      }
+    } else {
+      continuous.push({col, values:vals});
+      const q25 = quantile(vals, 0.25), q75 = quantile(vals, 0.75);
+      const low = new Uint8Array(n), high = new Uint8Array(n);
+      for (let i=0;i<n;i++) { if (vals[i] <= q25) low[i]=1; if (vals[i] >= q75) high[i]=1; }
+      predicates.push({id:`${col}<=q25`, text:`${col} <= ${fmt(q25,3)} (bottom quartile)`, mask:low, source:col, kind:'continuous_low', threshold:q25});
+      predicates.push({id:`${col}>=q75`, text:`${col} >= ${fmt(q75,3)} (top quartile)`, mask:high, source:col, kind:'continuous_high', threshold:q75});
+    }
+  }
+  const simple = {};
+  const cont = {};
+  const pairs = {};
+  const groups = {};
+  for (const dep of depCols) {
+    const y = columns[dep];
+    simple[dep] = predicates.map(pred => ({dep, pred, ...effectForMask(pred.mask, y)}))
+      .filter(r => r.n_in >= 100 && r.n_out >= 100)
+      .sort((a,b) => Math.abs(b.effect) - Math.abs(a.effect));
+    cont[dep] = continuous.map(c => ({dep, col:c.col, ...continuousEffect(c.values, y)}))
+      .sort((a,b) => Math.abs(b.effect) - Math.abs(a.effect));
+    const topPreds = simple[dep]
+      .filter(r => r.pred.kind !== 'continuous_low' || true)
+      .slice(0, 24)
+      .map(r => r.pred);
+    const pairRows = [];
+    for (let i=0; i<topPreds.length; i++) {
+      for (let j=i+1; j<topPreds.length; j++) {
+        if (topPreds[i].source === topPreds[j].source) continue;
+        const ir = interactionEffect(topPreds[i].mask, topPreds[j].mask, y);
+        if (!ir) continue;
+        pairRows.push({dep, a:topPreds[i], b:topPreds[j], ...ir});
+      }
+    }
+    pairs[dep] = pairRows.sort((a,b) => Math.abs(b.effect) - Math.abs(a.effect));
+    const groupRows = [];
+    for (let i=0; i<topPreds.length; i++) {
+      groupRows.push({preds:[topPreds[i]], ...effectForMask(topPreds[i].mask, y)});
+      for (let j=i+1; j<topPreds.length; j++) {
+        if (topPreds[i].source === topPreds[j].source) continue;
+        const mask2 = combineMasks([topPreds[i], topPreds[j]]);
+        const r2 = effectForMask(mask2, y);
+        if (r2.n_in >= 150 && r2.n_out >= 150) groupRows.push({preds:[topPreds[i], topPreds[j]], ...r2});
+        for (let k=j+1; k<Math.min(topPreds.length, 16); k++) {
+          if (new Set([topPreds[i].source, topPreds[j].source, topPreds[k].source]).size < 3) continue;
+          const mask3 = combineMasks([topPreds[i], topPreds[j], topPreds[k]]);
+          const r3 = effectForMask(mask3, y);
+          if (r3.n_in >= 100 && r3.n_out >= 100) groupRows.push({preds:[topPreds[i], topPreds[j], topPreds[k]], ...r3});
+        }
+      }
+    }
+    groups[dep] = groupRows
+      .filter(r => Number.isFinite(r.effect))
+      .sort((a,b) => a.effect - b.effect);
+  }
+
+  console.error('Top simple effects by dependency');
+  for (const dep of depCols) {
+    const r = simple[dep][0], c = cont[dep][0], g = groups[dep][0], p = pairs[dep][0];
+    console.error(dep, 'simple', predicateText(r.pred), fmt(r.effect), pFmt(r.p), 'cont', c.col, fmt(c.effect), pFmt(c.p), 'group', g.preds.map(predicateText).join(' AND '), fmt(g.effect), pFmt(g.p), 'interaction', p ? `${predicateText(p.a)} x ${predicateText(p.b)} ${fmt(p.effect)} ${pFmt(p.p)}` : 'none');
+  }
+
+  let hid = 1;
+  const transcript = {
+    dataset_id: 'ds001_depmap',
+    model_id: 'gpt-5-codex',
+    harness_id: 'codex-cli@local-node-analysis',
+    max_iterations: 10,
+    iterations: []
+  };
+  const summaryLines = [];
+  summaryLines.push('CRISPR dependency map analysis for ds001_depmap');
+  summaryLines.push(`Analyzed ${n} cell lines, ${featureCols.length} cell-line features, and ${depCols.length} dependency outcomes. More negative dependency scores indicate stronger dependency after knockout.`);
+  summaryLines.push('');
+
+  function addIter(index, hypotheses, analyses) {
+    transcript.iterations.push({index, proposed_hypotheses:hypotheses, analyses});
+  }
+  function newHyp(text, kind='novel') { return {id:`h${hid++}`, text, kind}; }
+
+  // Iteration 1: broad main-effect scan.
+  const h1s = [];
+  const a1s = [];
+  for (const dep of depCols.slice(0,5)) {
+    const r = simple[dep][0];
+    const h = newHyp(`Cell lines with ${predicateText(r.pred)} have ${describeDirection(r.effect, dep)} than cell lines without that predicate.`);
+    h1s.push(h);
+    a1s.push(analysisRecord(h.id, `Welch-style comparison of mean ${dep} for ${predicateText(r.pred)} versus all other cell lines.`, r, `Mean ${dep} was ${fmt(r.mean_in)} in-predicate versus ${fmt(r.mean_out)} outside (n=${r.n_in} vs ${r.n_out}).`));
+  }
+  addIter(1, h1s, a1s);
+  summaryLines.push('Iteration 1 screened single-predicate main effects for BRAF, EGFR, ERBB2, KRAS, and RIT1. The largest simple effects were all highly significant by large-sample mean comparisons.');
+
+  // Iteration 2: remaining main effects and continuous covariates.
+  const h2s = [];
+  const a2s = [];
+  for (const dep of depCols.slice(5)) {
+    const r = simple[dep][0];
+    const c = cont[dep][0];
+    const h = newHyp(`Cell lines with ${predicateText(r.pred)} have ${describeDirection(r.effect, dep)} than cell lines without that predicate.`);
+    const hc = newHyp(`A one-standard-deviation increase in ${c.col} is associated with ${describeDirection(c.effect, dep)}.`);
+    h2s.push(h, hc);
+    a2s.push(analysisRecord(h.id, `Welch-style comparison of mean ${dep} for ${predicateText(r.pred)} versus all other cell lines.`, r, `Mean ${dep} was ${fmt(r.mean_in)} in-predicate versus ${fmt(r.mean_out)} outside (n=${r.n_in} vs ${r.n_out}).`));
+    a2s.push(analysisRecord(hc.id, `Univariate linear regression of ${dep} on standardized ${c.col}.`, c, `Per-SD effect for ${c.col} on ${dep}.`));
+  }
+  addIter(2, h2s, a2s);
+  summaryLines.push('Iteration 2 extended the single-feature scan to KIF18A, TMED10, DHX9, POLR2A, and RPL11 and paired those with continuous-feature regressions.');
+
+  // Iterations 3-7: refined subgroup tests for pairs of outcomes.
+  const outcomePairs = [
+    ['dependency_BRAF','dependency_EGFR'],
+    ['dependency_ERBB2','dependency_KRAS'],
+    ['dependency_RIT1','dependency_KIF18A'],
+    ['dependency_TMED10','dependency_DHX9'],
+    ['dependency_POLR2A','dependency_RPL11']
+  ];
+  for (let idx=0; idx<outcomePairs.length; idx++) {
+    const hyps = [], ans = [];
+    for (const dep of outcomePairs[idx]) {
+      const g = groups[dep][0];
+      const predText = g.preds.map(predicateText).join(' and ');
+      const h = newHyp(`Cell lines satisfying ${predText} have more negative ${dep} scores than all other cell lines.`, 'refined');
+      hyps.push(h);
+      ans.push(analysisRecord(h.id, `Subgroup mean comparison for ${dep}: (${predText}) versus complement.`, g, `Subgroup mean ${dep} was ${fmt(g.mean_in)} versus ${fmt(g.mean_out)} outside (n=${g.n_in} vs ${g.n_out}).`));
+    }
+    addIter(3+idx, hyps, ans);
+    summaryLines.push(`Iteration ${3+idx} refined subgroup hypotheses for ${outcomePairs[idx].join(' and ')} using the strongest rule-based subgroup from the current screen.`);
+  }
+
+  // Iteration 8: explicit interaction tests for strongest modifiers per outcome.
+  const h8s=[], a8s=[];
+  for (const dep of depCols.slice(0,5)) {
+    const r = pairs[dep][0];
+    const interactionDirection = r.effect < 0 ? 'more negative than expected from the two main effects alone' : 'less negative than expected from the two main effects alone';
+    const h = newHyp(`The joint pattern ${predicateText(r.a)} and ${predicateText(r.b)} makes ${dep} ${interactionDirection}.`, 'refined');
+    h8s.push(h);
+    const extra = `Four-cell interaction means for ${dep}: neither=${fmt(r.cells[0].mean)}, ${predicateText(r.b)} only=${fmt(r.cells[1].mean)}, ${predicateText(r.a)} only=${fmt(r.cells[2].mean)}, both=${fmt(r.cells[3].mean)}.`;
+    a8s.push(analysisRecord(h.id, `Two-predicate interaction contrast for ${dep}: (${predicateText(r.a)} x ${predicateText(r.b)}).`, r, extra));
+  }
+  addIter(8, h8s, a8s);
+  summaryLines.push('Iteration 8 tested explicit two-feature interaction contrasts for the first five dependency outcomes.');
+
+  // Iteration 9: systematic dependency-heterogeneity search for every outcome.
+  const h9s=[], a9s=[];
+  for (const dep of depCols) {
+    const r = pairs[dep][0];
+    const interactionDirection = r.effect < 0 ? 'more negative than expected under additivity' : 'less negative than expected under additivity';
+    const h = newHyp(`A systematic feature-by-feature interaction screen identifies ${predicateText(r.a)} and ${predicateText(r.b)} as the strongest heterogeneity pair for ${dep}, making ${dep} ${interactionDirection}.`, 'refined');
+    h9s.push(h);
+    a9s.push(analysisRecord(h.id, `Systematic pairwise interaction screen over top single-feature predicates for ${dep}.`, r, `Strongest interaction was ${predicateText(r.a)} by ${predicateText(r.b)}.`));
+  }
+  addIter(9, h9s, a9s);
+  summaryLines.push('Iteration 9 performed the required systematic dependency-heterogeneity search for each dependency outcome, using pairwise interaction contrasts among the strongest feature predicates for that outcome.');
+
+  // Iteration 10: final best-supported subgroup hypothesis for each outcome.
+  const h10s=[], a10s=[];
+  for (const dep of depCols) {
+    const g = groups[dep][0];
+    const predText = g.preds.map(predicateText).join(' and ');
+    const h = newHyp(`Final best-supported subgroup for ${dep}: cell lines satisfying ${predText} have more negative ${dep} scores than all other cell lines.`, 'refined');
+    h10s.push(h);
+    a10s.push(analysisRecord(h.id, `Final subgroup test for ${dep}: (${predText}) versus complement.`, g, `Subgroup mean ${dep} was ${fmt(g.mean_in)} versus ${fmt(g.mean_out)} outside (n=${g.n_in} vs ${g.n_out}).`));
+  }
+  addIter(10, h10s, a10s);
+  summaryLines.push('Iteration 10 recorded the final best-supported dependency subgroup for each outcome.');
+  summaryLines.push('');
+
+  summaryLines.push('Key results by dependency outcome:');
+  for (const dep of depCols) {
+    const r = simple[dep][0], c = cont[dep][0], g = groups[dep][0], inter = pairs[dep][0];
+    summaryLines.push(`- ${dep}: strongest simple predicate was ${predicateText(r.pred)} (mean ${fmt(r.mean_in)} vs ${fmt(r.mean_out)}, effect ${fmt(r.effect)}, p=${pFmt(r.p)}). Strongest continuous association was ${c.col} (per-SD effect ${fmt(c.effect)}, p=${pFmt(c.p)}). Best subgroup was ${g.preds.map(predicateText).join(' AND ')} (mean ${fmt(g.mean_in)} vs ${fmt(g.mean_out)}, effect ${fmt(g.effect)}, p=${pFmt(g.p)}). Strongest interaction was ${predicateText(inter.a)} x ${predicateText(inter.b)} (difference-in-differences ${fmt(inter.effect)}, p=${pFmt(inter.p)}).`);
+  }
+  summaryLines.push('');
+  summaryLines.push('Overall conclusions: several dependency outcomes show very strong, statistically significant subgroup concentration rather than only broad main effects. The strongest rule-based subgroups are listed above; negative effects indicate stronger dependency in the subgroup. KIF18A behaves differently from the oncogene-like dependencies because its strongest simple signal is weaker and the best continuous association is modest, whereas BRAF, EGFR, ERBB2, KRAS, RIT1, TMED10, DHX9, POLR2A, and RPL11 each have sharply significant subgroup or interaction structure in this synthetic DepMap-style cohort.');
+
+  fs.writeFileSync('transcript.json', JSON.stringify(transcript, null, 2) + '\n');
+  fs.writeFileSync('analysis_summary.txt', summaryLines.join('\n') + '\n');
+}

diff --git a/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js b/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js
new file mode 100644
index 0000000000000000000000000000000000000000..27a2e8ef84619630cd13e54a3fd6a0a4ddf3ed6f
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js
@@ -0,0 +1,817 @@
+const fs = require('fs');
+
+const WRITE_OUTPUTS = process.argv.includes('--write');
+if (WRITE_OUTPUTS) console.log = function(){};
+const buf = fs.readFileSync('dataset.parquet');
+function readU32LE(pos) { return buf.readUInt32LE(pos); }
+const magic1 = buf.subarray(0, 4).toString('ascii');
+const magic2 = buf.subarray(buf.length - 4).toString('ascii');
+const footerLen = readU32LE(buf.length - 8);
+const footerStart = buf.length - 8 - footerLen;
+console.log({ len: buf.length, magic1, magic2, footerLen, footerStart });
+
+const TC = { STOP:0, TRUE:1, FALSE:2, BYTE:3, I16:4, I32:5, I64:6, DOUBLE:7, BINARY:8, LIST:9, SET:10, MAP:11, STRUCT:12 };
+const PTYPE = ['BOOLEAN','INT32','INT64','INT96','FLOAT','DOUBLE','BYTE_ARRAY','FIXED_LEN_BYTE_ARRAY'];
+const ENCODING = {
+  0: 'PLAIN',
+  1: 'PLAIN_DICTIONARY',
+  2: 'PLAIN_DICTIONARY',
+  3: 'RLE',
+  4: 'BIT_PACKED',
+  5: 'DELTA_BINARY_PACKED',
+  6: 'DELTA_LENGTH_BYTE_ARRAY',
+  7: 'DELTA_BYTE_ARRAY',
+  8: 'RLE_DICTIONARY',
+  9: 'BYTE_STREAM_SPLIT'
+};
+const PAGE_TYPE = {0:'DATA_PAGE',1:'INDEX_PAGE',2:'DICTIONARY_PAGE',3:'DATA_PAGE_V2'};
+
+class Reader {
+  constructor(b, pos=0, end=b.length) { this.b=b; this.pos=pos; this.end=end; this.stack=[0]; }
+  byte(){ return this.b[this.pos++]; }
+  varintBig(){
+    let shift=0n, out=0n;
+    while(true){
+      const x=this.byte();
+      out |= BigInt(x & 0x7f) << shift;
+      if((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
+  varint(){ return Number(this.varintBig()); }
+  zigzag(n){ return (n >>> 1) ^ -(n & 1); }
+  zigzagBig(n){ return (n >> 1n) ^ (-(n & 1n)); }
+  i16(){ return this.zigzag(this.varint()); }
+  i32(){ return this.zigzag(this.varint()); }
+  i64(){ return this.zigzagBig(this.varintBig()); }
+  double(){ const v=this.b.readDoubleLE(this.pos); this.pos+=8; return v; }
+  binary(){ const n=this.varint(); const s=this.b.subarray(this.pos,this.pos+n); this.pos+=n; return s; }
+  fieldHeader(){
+    const h=this.byte();
+    const type=h & 0x0f;
+    if(type===TC.STOP) return {type, id:null};
+    const delta=h >> 4;
+    let id;
+    if(delta) id=this.stack[this.stack.length-1]+delta; else id=this.i16();
+    this.stack[this.stack.length-1]=id;
+    return {type,id};
+  }
+  listHeader(){
+    const h=this.byte();
+    let size=h>>4, type=h & 0x0f;
+    if(size===15) size=this.varint();
+    return {size,type};
+  }
+  readType(type){
+    switch(type){
+      case TC.TRUE: return true;
+      case TC.FALSE: return false;
+      case TC.BYTE: return (this.byte()<<24)>>24;
+      case TC.I16: return this.i16();
+      case TC.I32: return this.i32();
+      case TC.I64: return this.i64();
+      case TC.DOUBLE: return this.double();
+      case TC.BINARY: return this.binary().toString('utf8');
+      case TC.STRUCT: return this.readAnyStruct();
+      case TC.LIST: {
+        const {size,type:et}=this.listHeader();
+        const a=[];
+        for(let i=0;i<size;i++) a.push(this.readType(et));
+        return a;
+      }
+      case TC.SET: {
+        const {size,type:et}=this.listHeader();
+        const a=[];
+        for(let i=0;i<size;i++) a.push(this.readType(et));
+        return a;
+      }
+      case TC.MAP: {
+        const n=this.varint();
+        if(n===0) return [];
+        const ktvt=this.byte();
+        const kt=(ktvt>>4)&0x0f, vt=ktvt&0x0f;
+        const a=[];
+        for(let i=0;i<n;i++) a.push([this.readType(kt), this.readType(vt)]);
+        return a;
+      }
+      default: throw new Error('unknown compact type '+type+' at '+this.pos);
+    }
+  }
+  readAnyStruct(){
+    const out={};
+    this.stack.push(0);
+    while(true){
+      const {type,id}=this.fieldHeader();
+      if(type===TC.STOP) break;
+      out[id]=this.readType(type);
+    }
+    this.stack.pop();
+    return out;
+  }
+}
+
+function parseFileMeta(r){
+  const fm={schema:[], row_groups:[]};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
