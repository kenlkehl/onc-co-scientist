+  readAnyStruct(){
+    const out={};
+    this.stack.push(0);
+    while(true){
+      const {type,id}=this.fieldHeader();
+      if(type===TC.STOP) break;
+      out[id]=this.readType(type);
+    }
+    this.stack.pop();
+    return out;
+  }
+}
+
+function parseFileMeta(r){
+  const fm={schema:[], row_groups:[]};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) fm.version=r.readType(type);
+    else if(id===2) {
+      const lh=r.listHeader();
+      for(let i=0;i<lh.size;i++) fm.schema.push(parseSchemaElement(r));
+    } else if(id===3) fm.num_rows=Number(r.readType(type));
+    else if(id===4) {
+      const lh=r.listHeader();
+      for(let i=0;i<lh.size;i++) fm.row_groups.push(parseRowGroup(r));
+    } else if(id===6) fm.created_by=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return fm;
+}
+function parseSchemaElement(r){
+  const se={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) se.type=r.readType(type);
+    else if(id===2) se.type_length=r.readType(type);
+    else if(id===3) se.repetition_type=r.readType(type);
+    else if(id===4) se.name=r.readType(type);
+    else if(id===5) se.num_children=r.readType(type);
+    else if(id===6) se.converted_type=r.readType(type);
+    else if(id===7) se.scale=r.readType(type);
+    else if(id===8) se.precision=r.readType(type);
+    else if(id===9) se.field_id=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return se;
+}
+function parseRowGroup(r){
+  const rg={columns:[]};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1){
+      const lh=r.listHeader();
+      for(let i=0;i<lh.size;i++) rg.columns.push(parseColumnChunk(r));
+    } else if(id===2) rg.total_byte_size=Number(r.readType(type));
+    else if(id===3) rg.num_rows=Number(r.readType(type));
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return rg;
+}
+function parseColumnChunk(r){
+  const cc={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) cc.file_path=r.readType(type);
+    else if(id===2) cc.file_offset=Number(r.readType(type));
+    else if(id===3) cc.meta_data=parseColumnMetaData(r);
+    else if(id===4) cc.offset_index_offset=Number(r.readType(type));
+    else if(id===5) cc.offset_index_length=r.readType(type);
+    else if(id===6) cc.column_index_offset=Number(r.readType(type));
+    else if(id===7) cc.column_index_length=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return cc;
+}
+function parseColumnMetaData(r){
+  const md={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) md.type=r.readType(type);
+    else if(id===2) { const lh=r.listHeader(); md.encodings=[]; for(let i=0;i<lh.size;i++) md.encodings.push(r.readType(lh.type)); }
+    else if(id===3) { const lh=r.listHeader(); md.path_in_schema=[]; for(let i=0;i<lh.size;i++) md.path_in_schema.push(r.readType(lh.type)); }
+    else if(id===4) md.codec=r.readType(type);
+    else if(id===5) md.num_values=Number(r.readType(type));
+    else if(id===6) md.total_uncompressed_size=Number(r.readType(type));
+    else if(id===7) md.total_compressed_size=Number(r.readType(type));
+    else if(id===9) md.data_page_offset=Number(r.readType(type));
+    else if(id===10) md.index_page_offset=Number(r.readType(type));
+    else if(id===11) md.dictionary_page_offset=Number(r.readType(type));
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return md;
+}
+
+function parsePageHeaderAt(pos) {
+  const r = new Reader(buf, pos);
+  const ph = {};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) ph.type=r.readType(type);
+    else if(id===2) ph.uncompressed_page_size=r.readType(type);
+    else if(id===3) ph.compressed_page_size=r.readType(type);
+    else if(id===4) ph.crc=r.readType(type);
+    else if(id===5) ph.data_page_header=parseDataPageHeader(r);
+    else if(id===7) ph.dictionary_page_header=parseDictionaryPageHeader(r);
+    else if(id===8) ph.data_page_header_v2=parseDataPageHeaderV2(r);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  ph.header_size = r.pos - pos;
+  return ph;
+}
+function parseDataPageHeader(r){
+  const d={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) d.num_values=r.readType(type);
+    else if(id===2) d.encoding=r.readType(type);
+    else if(id===3) d.definition_level_encoding=r.readType(type);
+    else if(id===4) d.repetition_level_encoding=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return d;
+}
+function parseDataPageHeaderV2(r){
+  const d={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) d.num_values=r.readType(type);
+    else if(id===2) d.num_nulls=r.readType(type);
+    else if(id===3) d.num_rows=r.readType(type);
+    else if(id===4) d.encoding=r.readType(type);
+    else if(id===5) d.definition_levels_byte_length=r.readType(type);
+    else if(id===6) d.repetition_levels_byte_length=r.readType(type);
+    else if(id===7) d.is_compressed=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return d;
+}
+function parseDictionaryPageHeader(r){
+  const d={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) d.num_values=r.readType(type);
+    else if(id===2) d.encoding=r.readType(type);
+    else if(id===3) d.is_sorted=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return d;
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let resultLen = 0, shift = 0;
+  while (true) {
+    const b = input[pos++];
+    resultLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(resultLen);
+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let len;
+      if (lenCode < 60) {
+        len = lenCode + 1;
+      } else {
+        const bytes = lenCode - 59;
+        len = 1;
+        let v = 0;
+        for (let i=0; i<bytes; i++) v |= input[pos++] << (8*i);
+        len = v + 1;
+      }
+      input.copy(out, outPos, pos, pos + len);
+      pos += len;
+      outPos += len;
+    } else {
+      let len, offset;
+      if (type === 1) {
+        len = 4 + ((tag >> 2) & 0x7);
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = 1 + (tag >> 2);
+        offset = input[pos] | (input[pos+1] << 8);
+        pos += 2;
+      } else {
+        len = 1 + (tag >> 2);
+        offset = input[pos] | (input[pos+1] << 8) | (input[pos+2] << 16) | (input[pos+3] << 24);
+        pos += 4;
+      }
+      for (let i=0; i<len; i++) {
+        out[outPos] = out[outPos - offset];
+        outPos++;
+      }
+    }
+  }
+  if (outPos !== resultLen) throw new Error(`snappy length mismatch ${outPos} != ${resultLen}`);
+  return out;
+}
+
+function decodePlainValues(b, type, count) {
+  let pos = 0;
+  const out = new Array(count);
+  for (let i=0; i<count; i++) {
+    if (type === 5) { out[i] = b.readDoubleLE(pos); pos += 8; }
+    else if (type === 4) { out[i] = b.readFloatLE(pos); pos += 4; }
+    else if (type === 2) { out[i] = Number(b.readBigInt64LE(pos)); pos += 8; }
+    else if (type === 1) { out[i] = b.readInt32LE(pos); pos += 4; }
+    else if (type === 6) { const n=b.readUInt32LE(pos); pos += 4; out[i] = b.subarray(pos,pos+n).toString('utf8'); pos += n; }
+    else throw new Error('plain type not supported '+type);
+  }
+  return out;
+}
+
+function readUnsignedVarintFrom(b, st) {
+  let shift=0, out=0;
+  while(true) {
+    const x=b[st.pos++];
+    out |= (x & 0x7f) << shift;
+    if((x & 0x80) === 0) break;
+    shift += 7;
+  }
+  return out;
+}
+function readBitsLE(b, bitPos, width) {
+  let v=0;
+  for (let j=0; j<width; j++) {
+    const p = bitPos + j;
+    const bit = (b[p >> 3] >> (p & 7)) & 1;
+    v |= bit << j;
+  }
+  return v;
+}
+function decodeHybridRleBitpacked(b, pos, bitWidth, expectedCount, byteLength=null) {
+  const st = {pos};
+  const end = byteLength == null ? b.length : pos + byteLength;
+  const out = [];
+  const bytesForVal = Math.ceil(bitWidth / 8);
+  while (st.pos < end && out.length < expectedCount) {
+    const header = readUnsignedVarintFrom(b, st);
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      let v = 0;
+      for (let i=0; i<bytesForVal; i++) v |= b[st.pos++] << (8*i);
+      for (let i=0; i<runLen && out.length<expectedCount; i++) out.push(v);
+    } else {
+      const groups = header >> 1;
+      const nvals = groups * 8;
+      const nbytes = groups * bitWidth;
+      let bitPos = st.pos * 8;
+      for (let i=0; i<nvals && out.length<expectedCount; i++) out.push(readBitsLE(b, bitPos + i*bitWidth, bitWidth));
+      st.pos += nbytes;
+    }
+  }
+  if (byteLength != null) st.pos = pos + byteLength;
+  return {values: out, pos: st.pos};
+}
+
+function bitWidthFor(n) {
+  let w=0;
+  while ((1 << w) <= n) w++;
+  return Math.max(w, 0);
+}
+
+function decodeColumn(cc, schemaElement) {
+  const md = cc.meta_data;
+  let pos = md.dictionary_page_offset ?? md.data_page_offset;
+  let dictionary = null;
+  const values = [];
+  while (values.length < md.num_values) {
+    const ph = parsePageHeaderAt(pos);
+    pos += ph.header_size;
+    const compressed = buf.subarray(pos, pos + ph.compressed_page_size);
+    pos += ph.compressed_page_size;
+    let page = compressed;
+    if (md.codec === 1) page = snappyUncompress(compressed);
+    else if (md.codec !== 0) throw new Error('unsupported codec '+md.codec);
+    if (page.length !== ph.uncompressed_page_size && PAGE_TYPE[ph.type] !== 'DATA_PAGE_V2') {
+      throw new Error(`${md.path_in_schema[0]} page length ${page.length} != ${ph.uncompressed_page_size}`);
+    }
+    if (ph.type === 2) {
+      const dh = ph.dictionary_page_header;
+      if (dh.encoding !== 0) throw new Error('unsupported dict encoding '+dh.encoding);
+      dictionary = decodePlainValues(page, md.type, dh.num_values);
+    } else if (ph.type === 0) {
+      const dh = ph.data_page_header;
+      let p = 0;
+      const n = dh.num_values;
+      const maxDef = schemaElement.repetition_type === 1 ? 1 : 0;
+      let nonNull = n;
+      if (maxDef > 0) {
+        const levLen = page.readUInt32LE(p); p += 4;
+        const lev = decodeHybridRleBitpacked(page, p, bitWidthFor(maxDef), n, levLen);
+        p = lev.pos;
+        nonNull = lev.values.filter(v => v === maxDef).length;
+      }
+      let pageVals;
+      if (dh.encoding === 8 || dh.encoding === 2) {
+        const bw = page[p++];
+        const dec = decodeHybridRleBitpacked(page, p, bw, nonNull, null);
+        pageVals = dec.values.map(i => dictionary[i]);
+      } else if (dh.encoding === 0) {
+        pageVals = decodePlainValues(page.subarray(p), md.type, nonNull);
+      } else {
+        throw new Error('unsupported data encoding '+dh.encoding+' for '+md.path_in_schema[0]);
+      }
+      values.push(...pageVals);
+    } else {
+      throw new Error('unsupported page type '+ph.type);
+    }
+  }
+  if (values.length !== md.num_values) throw new Error(`${md.path_in_schema[0]} got ${values.length}`);
+  return values;
+}
+
+const r = new Reader(buf.subarray(footerStart, footerStart + footerLen));
+const meta = parseFileMeta(r);
+console.log('meta', {version: meta.version, num_rows: meta.num_rows, created_by: meta.created_by, schema_len: meta.schema.length, row_groups: meta.row_groups.length});
+console.log('schema');
+for (const s of meta.schema) console.log(s);
+for (let rg=0; rg<meta.row_groups.length; rg++) {
+  console.log('row_group', rg, {num_rows: meta.row_groups[rg].num_rows, cols: meta.row_groups[rg].columns.length});
+  for (const c of meta.row_groups[rg].columns) console.log(c.meta_data);
+}
+
+console.log('page samples');
+for (const c of meta.row_groups[0].columns.slice(0, 8).concat(meta.row_groups[0].columns.slice(-10))) {
+  let pos = c.meta_data.dictionary_page_offset ?? c.meta_data.data_page_offset;
+  const ph1 = parsePageHeaderAt(pos);
+  const next = pos + ph1.header_size + ph1.compressed_page_size;
+  const ph2 = parsePageHeaderAt(next);
+  console.log(c.meta_data.path_in_schema[0], {
+    type: PTYPE[c.meta_data.type],
+    codec: c.meta_data.codec,
+    first: PAGE_TYPE[ph1.type],
+    firstHeader: ph1,
+    second: PAGE_TYPE[ph2.type],
+    secondHeader: ph2
+  });
+}
+
+console.log('decode samples');
+const rg0 = meta.row_groups[0];
+for (let i=1; i<meta.schema.length; i++) {
+  const name = meta.schema[i].name;
+  const vals = decodeColumn(rg0.columns[i-1], meta.schema[i]);
+  const sample = vals.slice(0, 8);
+  const uniq = new Map();
+  for (const v of vals) {
+    const k = String(v);
+    uniq.set(k, (uniq.get(k)||0)+1);
+    if (uniq.size > 20) break;
+  }
+  console.log(name, sample, 'uniq_seen', Array.from(uniq.entries()).slice(0, 12));
+  if (i > 12 && name.startsWith('dependency_')) break;
+}

diff --git a/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js b/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js
new file mode 100644
index 0000000000000000000000000000000000000000..8b9235c142df9fbed3dd88fa6d2ebdef6e247f66
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js
@@ -0,0 +1,484 @@
+const fs = require('fs');
+
+const buf = fs.readFileSync('dataset.parquet');
+function readU32LE(pos) { return buf.readUInt32LE(pos); }
+const magic1 = buf.subarray(0, 4).toString('ascii');
+const magic2 = buf.subarray(buf.length - 4).toString('ascii');
+const footerLen = readU32LE(buf.length - 8);
+const footerStart = buf.length - 8 - footerLen;
+console.log({ len: buf.length, magic1, magic2, footerLen, footerStart });
+
+const TC = { STOP:0, TRUE:1, FALSE:2, BYTE:3, I16:4, I32:5, I64:6, DOUBLE:7, BINARY:8, LIST:9, SET:10, MAP:11, STRUCT:12 };
+const PTYPE = ['BOOLEAN','INT32','INT64','INT96','FLOAT','DOUBLE','BYTE_ARRAY','FIXED_LEN_BYTE_ARRAY'];
+const ENCODING = {
+  0: 'PLAIN',
+  1: 'PLAIN_DICTIONARY',
+  2: 'PLAIN_DICTIONARY',
+  3: 'RLE',
+  4: 'BIT_PACKED',
+  5: 'DELTA_BINARY_PACKED',
+  6: 'DELTA_LENGTH_BYTE_ARRAY',
+  7: 'DELTA_BYTE_ARRAY',
+  8: 'RLE_DICTIONARY',
+  9: 'BYTE_STREAM_SPLIT'
+};
+const PAGE_TYPE = {0:'DATA_PAGE',1:'INDEX_PAGE',2:'DICTIONARY_PAGE',3:'DATA_PAGE_V2'};
+
+class Reader {
+  constructor(b, pos=0, end=b.length) { this.b=b; this.pos=pos; this.end=end; this.stack=[0]; }
+  byte(){ return this.b[this.pos++]; }
+  varintBig(){
+    let shift=0n, out=0n;
+    while(true){
+      const x=this.byte();
+      out |= BigInt(x & 0x7f) << shift;
+      if((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
+  varint(){ return Number(this.varintBig()); }
+  zigzag(n){ return (n >>> 1) ^ -(n & 1); }
+  zigzagBig(n){ return (n >> 1n) ^ (-(n & 1n)); }
+  i16(){ return this.zigzag(this.varint()); }
+  i32(){ return this.zigzag(this.varint()); }
+  i64(){ return this.zigzagBig(this.varintBig()); }
+  double(){ const v=this.b.readDoubleLE(this.pos); this.pos+=8; return v; }
+  binary(){ const n=this.varint(); const s=this.b.subarray(this.pos,this.pos+n); this.pos+=n; return s; }
+  fieldHeader(){
+    const h=this.byte();
+    const type=h & 0x0f;
+    if(type===TC.STOP) return {type, id:null};
+    const delta=h >> 4;
+    let id;
+    if(delta) id=this.stack[this.stack.length-1]+delta; else id=this.i16();
+    this.stack[this.stack.length-1]=id;
+    return {type,id};
+  }
+  listHeader(){
+    const h=this.byte();
+    let size=h>>4, type=h & 0x0f;
+    if(size===15) size=this.varint();
+    return {size,type};
+  }
+  readType(type){
+    switch(type){
+      case TC.TRUE: return true;
+      case TC.FALSE: return false;
+      case TC.BYTE: return (this.byte()<<24)>>24;
+      case TC.I16: return this.i16();
+      case TC.I32: return this.i32();
+      case TC.I64: return this.i64();
+      case TC.DOUBLE: return this.double();
+      case TC.BINARY: return this.binary().toString('utf8');
+      case TC.STRUCT: return this.readAnyStruct();
+      case TC.LIST: {
+        const {size,type:et}=this.listHeader();
+        const a=[];
+        for(let i=0;i<size;i++) a.push(this.readType(et));
+        return a;
+      }
+      case TC.SET: {
+        const {size,type:et}=this.listHeader();
+        const a=[];
+        for(let i=0;i<size;i++) a.push(this.readType(et));
+        return a;
+      }
+      case TC.MAP: {
+        const n=this.varint();
+        if(n===0) return [];
+        const ktvt=this.byte();
+        const kt=(ktvt>>4)&0x0f, vt=ktvt&0x0f;
+        const a=[];
+        for(let i=0;i<n;i++) a.push([this.readType(kt), this.readType(vt)]);
+        return a;
+      }
+      default: throw new Error('unknown compact type '+type+' at '+this.pos);
+    }
+  }
+  readAnyStruct(){
+    const out={};
+    this.stack.push(0);
+    while(true){
+      const {type,id}=this.fieldHeader();
+      if(type===TC.STOP) break;
+      out[id]=this.readType(type);
+    }
+    this.stack.pop();
+    return out;
+  }
+}
+
+function parseFileMeta(r){
+  const fm={schema:[], row_groups:[]};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) fm.version=r.readType(type);
+    else if(id===2) {
+      const lh=r.listHeader();
+      for(let i=0;i<lh.size;i++) fm.schema.push(parseSchemaElement(r));
+    } else if(id===3) fm.num_rows=Number(r.readType(type));
+    else if(id===4) {
+      const lh=r.listHeader();
+      for(let i=0;i<lh.size;i++) fm.row_groups.push(parseRowGroup(r));
+    } else if(id===6) fm.created_by=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return fm;
+}
+function parseSchemaElement(r){
+  const se={};
+  r.stack.push(0);
+  while(true){
+    const {type,id}=r.fieldHeader();
+    if(type===TC.STOP) break;
+    if(id===1) se.type=r.readType(type);
+    else if(id===2) se.type_length=r.readType(type);
+    else if(id===3) se.repetition_type=r.readType(type);
+    else if(id===4) se.name=r.readType(type);
+    else if(id===5) se.num_children=r.readType(type);
+    else if(id===6) se.converted_type=r.readType(type);
+    else if(id===7) se.scale=r.readType(type);
+    else if(id===8) se.precision=r.readType(type);
+    else if(id===9) se.field_id=r.readType(type);
+    else r.readType(type);
+  }
+  r.stack.pop();
+  return se;
+}
+function parseRowGroup(r){
+  const rg={columns:[]};
