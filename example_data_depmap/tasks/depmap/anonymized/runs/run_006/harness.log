+function slopeTest(x, y) {
+  const n = x.length;
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0;
+  let sxy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    const r = y[i] - intercept - slope * x[i];
+    rss += r * r;
+  }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  const z = slope / se;
+  return { slope, intercept, z, p: twoSidedFromZ(z) };
