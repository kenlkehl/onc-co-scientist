+const fs = require("fs");
+const path = require("path");
+
+const PARQUET_TYPE = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  INT96: 3,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+  FIXED_LEN_BYTE_ARRAY: 7,
+};
+
+class CompactReader {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.offset = offset;
+    this.end = end;
+  }
+
+  byte() {
+    return this.buf[this.offset++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let value = 0n;
+    while (true) {
+      const b = this.byte();
+      value |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return value;
+      shift += 7n;
+    }
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return this.zigzag(this.varint());
+  }
+
+  string() {
+    const len = Number(this.varint());
+    const out = this.buf.toString("utf8", this.offset, this.offset + len);
+    this.offset += len;
+    return out;
+  }
+
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return [type, size];
+  }
+
+  mapHeader() {
+    const size = Number(this.varint());
+    if (size === 0) return [0, 0, 0];
+    const h = this.byte();
+    return [h >> 4, h & 0x0f, size];
+  }
+
+  value(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.byte();
+      case 4:
+      case 5:
+        return this.i32();
+      case 6:
+        return this.i64();
+      case 7: {
+        const out = this.buf.readDoubleLE(this.offset);
+        this.offset += 8;
+        return out;
+      }
+      case 8:
+        return this.string();
+      case 9:
+      case 10: {
+        const [elementType, size] = this.listHeader();
+        const out = [];
+        for (let i = 0; i < size; i++) out.push(this.value(elementType));
+        return out;
+      }
+      case 11: {
+        const [keyType, valueType, size] = this.mapHeader();
+        const out = [];
+        for (let i = 0; i < size; i++) out.push([this.value(keyType), this.value(valueType)]);
+        return out;
+      }
+      case 12:
+        return this.struct();
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.offset}`);
+    }
+  }
+
+  struct() {
+    const out = {};
+    let lastFieldId = 0;
+    while (true) {
+      const header = this.byte();
+      const type = header & 0x0f;
+      if (type === 0) break;
+      const modifier = header >> 4;
+      const fieldId = modifier === 0 ? this.i32() : lastFieldId + modifier;
+      lastFieldId = fieldId;
+      out[fieldId] = this.value(type);
+    }
+    return out;
+  }
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[pos++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
+        const bytes = literalLen - 59;
+        literalLen = 1;
+        let extra = 0;
+        for (let i = 0; i < bytes; i++) extra |= input[pos++] << (8 * i);
+        literalLen += extra;
+      }
+      input.copy(out, outPos, pos, pos + literalLen);
+      pos += literalLen;
+      outPos += literalLen;
+    } else {
+      let copyLen;
+      let offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < copyLen; i++) out[outPos + i] = out[outPos - offset + i];
+      outPos += copyLen;
+    }
+  }
+  if (outPos !== len) throw new Error(`Snappy length mismatch ${outPos} != ${len}`);
+  return out;
+}
+
+function readUnsignedVarint(buf, offset) {
+  let value = 0;
+  let shift = 0;
+  let pos = offset;
+  while (true) {
+    const b = buf[pos++];
+    value |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) return [value, pos];
+    shift += 7;
+  }
+}
+
+function readHybrid(buf, offset, count, bitWidth) {
+  const values = [];
+  let pos = offset;
+  const byteWidth = Math.ceil(bitWidth / 8);
+  while (values.length < count) {
+    let header;
+    [header, pos] = readUnsignedVarint(buf, pos);
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < byteWidth; i++) value |= buf[pos + i] << (8 * i);
+      pos += byteWidth;
+      for (let i = 0; i < runLength && values.length < count; i++) values.push(value);
+    } else {
+      const groups = header >> 1;
+      const totalValues = groups * 8;
+      let bitPos = 0;
+      for (let i = 0; i < totalValues && values.length < count; i++) {
+        let value = 0;
+        for (let bit = 0; bit < bitWidth; bit++) {
+          const absolute = pos * 8 + bitPos;
+          const bitValue = (buf[Math.floor(absolute / 8)] >> (absolute % 8)) & 1;
+          value |= bitValue << bit;
+          bitPos++;
+        }
+        values.push(value);
+      }
+      pos += Math.ceil((totalValues * bitWidth) / 8);
+    }
+  }
