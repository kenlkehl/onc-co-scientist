+  const v0 = ss0 / Math.max(1, n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = se > 0 ? (m1 - m0) / se : 0;
+  return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, z, p: twoSidedFromZ(z) };
+}
+
+function slopeTest(x, y) {
+  const n = x.length;
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0;
+  let sxy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    const r = y[i] - intercept - slope * x[i];
+    rss += r * r;
+  }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  const z = slope / se;
+  return { slope, intercept, z, p: twoSidedFromZ(z) };
+}
+
+function olsCoefficients(columns, y) {
+  const n = y.length;
+  const p = columns.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const va = columns[a][i];
+      xty[a] += va * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += va * columns[b][i];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += beta[j] * columns[j][i];
+    const r = y[i] - pred;
+    rss += r * r;
+  }
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, row[i] * sigma2)));
+  return { beta, se, rss };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => [...row, ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))]);
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(m[r][col]) > Math.abs(m[pivot][col])) pivot = r;
+    if (Math.abs(m[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    [m[col], m[pivot]] = [m[pivot], m[col]];
+    const div = m[col][col];
+    for (let c = 0; c < 2 * n; c++) m[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = m[r][col];
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= factor * m[col][c];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function uniqueCounts(values) {
+  const counts = new Map();
+  for (const v of values) counts.set(v, (counts.get(v) || 0) + 1);
+  return counts;
+}
+
+function predicateText(pred) {
+  if (pred.kind === "eq") return `\`${pred.feature}\` = ${JSON.stringify(pred.value)}`;
+  return `\`${pred.feature}\` in its top quartile (>= ${pred.threshold.toFixed(3)})`;
+}
+
+function makeMask(pred, data, n) {
+  const arr = data[pred.feature];
+  const mask = new Array(n);
+  if (pred.kind === "eq") {
+    for (let i = 0; i < n; i++) mask[i] = arr[i] === pred.value;
+  } else {
+    for (let i = 0; i < n; i++) mask[i] = arr[i] >= pred.threshold;
+  }
+  return mask;
+}
+
+function andMask(maskA, maskB) {
+  const out = new Array(maskA.length);
+  for (let i = 0; i < maskA.length; i++) out[i] = maskA[i] && maskB[i];
+  return out;
+}
+
+function notMask(maskA) {
+  const out = new Array(maskA.length);
+  for (let i = 0; i < maskA.length; i++) out[i] = !maskA[i];
+  return out;
+}
+
+function interactionContrast(y, maskA, maskB) {
+  let n00 = 0, n10 = 0, n01 = 0, n11 = 0;
+  let s00 = 0, s10 = 0, s01 = 0, s11 = 0;
+  let q00 = 0, q10 = 0, q01 = 0, q11 = 0;
+  for (let i = 0; i < y.length; i++) {
+    const yi = y[i];
+    const yi2 = yi * yi;
+    if (maskA[i] && maskB[i]) { n11++; s11 += yi; q11 += yi2; }
+    else if (maskA[i]) { n10++; s10 += yi; q10 += yi2; }
+    else if (maskB[i]) { n01++; s01 += yi; q01 += yi2; }
+    else { n00++; s00 += yi; q00 += yi2; }
+  }
+  if (Math.min(n00, n10, n01, n11) < 50) return null;
+  const m00 = s00 / n00, m10 = s10 / n10, m01 = s01 / n01, m11 = s11 / n11;
+  const v00 = Math.max(0, (q00 - n00 * m00 * m00) / Math.max(1, n00 - 1));
+  const v10 = Math.max(0, (q10 - n10 * m10 * m10) / Math.max(1, n10 - 1));
+  const v01 = Math.max(0, (q01 - n01 * m01 * m01) / Math.max(1, n01 - 1));
+  const v11 = Math.max(0, (q11 - n11 * m11 * m11) / Math.max(1, n11 - 1));
+  const effect = m11 - m10 - m01 + m00;
+  const se = Math.sqrt(v11 / n11 + v10 / n10 + v01 / n01 + v00 / n00);
+  const z = se > 0 ? effect / se : 0;
+  return { n00, n10, n01, n11, m00, m10, m01, m11, effect, beta: effect, se, z, p: twoSidedFromZ(z) };
+}
+
+function fnum(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) < 1e-300 && x !== 0) return "0";
+  if (Math.abs(x) < 0.001 || Math.abs(x) >= 10000) return x.toExponential(3);
+  return x.toFixed(digits);
+}
