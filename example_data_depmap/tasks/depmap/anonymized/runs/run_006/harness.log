  const hOutcomeSpecific = `h${hCounter++}`;
  iter9.proposed_hypotheses.push({
    id: hOutcomeSpecific,
    text: `The complete subgroup \`feature_011\` = "skin", \`feature_006\` = "BRAF", and \`feature_021\` != "suppressor_1" is specific for \`dependency_KIF18A\` and does not induce comparably negative shifts in \`dependency_BRAF\`, \`dependency_EGFR\`, \`dependency_ERBB2\`, \`dependency_KRAS\`, \`dependency_RIT1\`, \`dependency_TMED10\`, \`dependency_DHX9\`, \`dependency_POLR2A\`, or \`dependency_RPL11\`.`,
    kind: "refined",
  });
  const nonKifEffects = [];
  for (const outcome of outcomes.filter((o) => o !== "dependency_KIF18A")) {
    const r = diffTest(data[outcome], completeMask);
    nonKifEffects.push({ outcome, effect: r.effect, p: r.p });
  }
