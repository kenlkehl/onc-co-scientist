+  summaryLines.push("Iteration 6: three-feature subgroup search");
+  summaryLines.push("A three-feature check over the strongest KIF18A modifiers recovered feature_011=\"colorectal\", feature_035=1, and feature_020=0 as the strongest interpretable rule.");
+  summaryLines.push("");
+
+  const iter7 = { index: 7, proposed_hypotheses: [], analyses: [] };
