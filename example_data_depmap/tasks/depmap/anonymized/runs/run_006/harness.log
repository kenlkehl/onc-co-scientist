+function addAnalysis(iteration, hypothesisIds, resultSummary, pValue, effectEstimate, significant, code = null, extra = {}) {
+  const rec = {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: resultSummary,
+    p_value: Number.isFinite(pValue) ? pValue : null,
+    effect_estimate: Number.isFinite(effectEstimate) ? effectEstimate : null,
+    significant,
+    ...extra,
+  };
+  iteration.analyses.push(rec);
+  return rec;
