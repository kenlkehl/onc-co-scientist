+    const h = this.byte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return [type, size];
+  }
+
+  mapHeader() {
+    const size = Number(this.varint());
+    if (size === 0) return [0, 0, 0];
+    const h = this.byte();
+    return [h >> 4, h & 0x0f, size];
+  }
+
+  value(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.byte();
+      case 4:
+      case 5:
+        return this.i32();
+      case 6:
+        return this.i64();
+      case 7: {
