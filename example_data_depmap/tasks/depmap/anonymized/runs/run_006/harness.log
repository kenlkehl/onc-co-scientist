+        for (let bit = 0; bit < bitWidth; bit++) {
+          const absolute = pos * 8 + bitPos;
+          const bitValue = (buf[Math.floor(absolute / 8)] >> (absolute % 8)) & 1;
+          value |= bitValue << bit;
+          bitPos++;
+        }
+        values.push(value);
+      }
+      pos += Math.ceil((totalValues * bitWidth) / 8);
+    }
+  }
+  return { values, offset: pos };
+}
+
+function decodePlain(buf, offset, type, count) {
+  const values = [];
+  let pos = offset;
+  if (type === PARQUET_TYPE.DOUBLE) {
+    for (let i = 0; i < count; i++) {
+      values.push(buf.readDoubleLE(pos));
+      pos += 8;
+    }
