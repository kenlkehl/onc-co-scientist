+    iter2.proposed_hypotheses.push({
+      id: hypId,
+      text: `The two-feature subgroup defined by ${predicateText(hit.a)} and ${predicateText(hit.b)} has ${direction} \`${outcome}\` scores than all other cell lines.`,
+      kind: "novel",
+    });
+    addAnalysis(
+      iter2,
+      [hypId],
+      `Systematic pairwise heterogeneity screen for ${outcome}: subgroup ${predicateText(hit.a)} AND ${predicateText(hit.b)} had mean ${fnum(hit.subgroup.mean1)} vs ${fnum(hit.subgroup.mean0)} outside the subgroup; signed subgroup effect ${fnum(hit.subgroup.effect)}, p=${fnum(hit.subgroup.p)}. The corresponding two-way interaction contrast was ${fnum(hit.interaction.effect)} (p=${fnum(hit.interaction.p)}).`,
+      hit.subgroup.p,
+      hit.subgroup.effect,
+      hit.subgroup.p < 0.05,
+      null,
+      { screen: "pairwise_dependency_heterogeneity", interaction_effect: hit.interaction.effect, interaction_p_value: hit.interaction.p },
+    );
+  }
+  transcript.iterations.push(iter2);
+  summaryLines.push("Iteration 2: systematic pairwise dependency-heterogeneity search");
+  summaryLines.push("Every dependency outcome was screened over feature-by-feature pairwise subgroup definitions. dependency_KIF18A stood out: feature_011=\"colorectal\" combined with feature_035=1 produced a large negative subgroup effect and a large negative interaction contrast. The same systematic search found only small, weak pairwise subgroup effects for the other outcomes.");
+  summaryLines.push("");
+
+  const kifPair = heterogeneity["dependency_KIF18A"][0];
+  const iter3 = { index: 3, proposed_hypotheses: [], analyses: [] };
+  const hKifPair = `h${hCounter++}`;
+  iter3.proposed_hypotheses.push({
+    id: hKifPair,
+    text: `In \`feature_011\` = "skin" cell lines, \`feature_006\` = "BRAF" marks a subgroup with substantially more negative \`dependency_KIF18A\` scores than skin cell lines without \`feature_006\` = "BRAF".`,
+    kind: "refined",
+  });
+  const skinMask = makeMask(kifPair.a.feature === "feature_011" ? kifPair.a : kifPair.b, data, n);
+  const brafPred = kifPair.a.feature === "feature_006" ? kifPair.a : kifPair.b;
+  const brafMask = makeMask(brafPred, data, n);
+  const skinBraf = andMask(skinMask, brafMask);
+  const skinNotBraf = skinMask.map((v, i) => v && !brafMask[i]);
+  const rSkin = (() => {
+    const y = data["dependency_KIF18A"];
+    const vals1 = [];
+    const vals0 = [];
+    for (let i = 0; i < n; i++) {
+      if (skinBraf[i]) vals1.push(y[i]);
+      else if (skinNotBraf[i]) vals0.push(y[i]);
+    }
+    return diffTest([...vals1, ...vals0], [...Array(vals1.length).fill(true), ...Array(vals0.length).fill(false)]);
+  })();
+  addAnalysis(
+    iter3,
+    [hKifPair],
+    `Within feature_011=\"skin\", feature_006=\"BRAF\" lines had mean dependency_KIF18A ${fnum(rSkin.mean1)} vs ${fnum(rSkin.mean0)} for non-BRAF skin lines; signed within-skin effect ${fnum(rSkin.effect)}, p=${fnum(rSkin.p)} (n=${rSkin.n1} vs ${rSkin.n0}).`,
+    rSkin.p,
+    rSkin.effect,
+    rSkin.p < 0.05,
+    null,
+    { screen: "within_skin_braf_stratified_test" },
+  );
+  transcript.iterations.push(iter3);
+  summaryLines.push("Iteration 3: focused KIF18A stratified refinement");
+  summaryLines.push(`Within feature_011="skin", feature_006="BRAF" lines had much stronger KIF18A dependency than non-BRAF skin lines (effect ${fnum(rSkin.effect)}, p=${fnum(rSkin.p)}), supporting the idea that the KIF18A signal is not a generic skin-lineage main effect.`);
+  summaryLines.push("");
+
+  const iter4 = { index: 4, proposed_hypotheses: [], analyses: [] };
+  const hSupp = `h${hCounter++}`;
+  iter4.proposed_hypotheses.push({
+    id: hSupp,
+    text: `The \`dependency_KIF18A\` effect of the \`feature_011\` = "skin" and \`feature_006\` = "BRAF" subgroup is suppressed when \`feature_021\` = "suppressor_1"; therefore the complete high-dependency subgroup is \`feature_011\` = "skin", \`feature_006\` = "BRAF", and \`feature_021\` != "suppressor_1".`,
+    kind: "refined",
+  });
+  const suppressPred = { feature: "feature_021", kind: "eq", value: "suppressor_1" };
+  const suppressMask = makeMask(suppressPred, data, n);
+  const completeMask = skinBraf.map((v, i) => v && !suppressMask[i]);
+  const suppressedMask = skinBraf.map((v, i) => v && suppressMask[i]);
+  const yK = data["dependency_KIF18A"];
+  const rComplete = diffTest(yK, completeMask);
+  const valsA = [], valsB = [];
+  for (let i = 0; i < n; i++) {
+    if (completeMask[i]) valsA.push(yK[i]);
+    else if (suppressedMask[i]) valsB.push(yK[i]);
+  }
+  const rSupp = diffTest([...valsA, ...valsB], [...Array(valsA.length).fill(true), ...Array(valsB.length).fill(false)]);
+  addAnalysis(
+    iter4,
+    [hSupp],
+    `Complete subgroup test: feature_011=\"skin\" AND feature_006=\"BRAF\" AND feature_021!="suppressor_1" had mean dependency_KIF18A ${fnum(rComplete.mean1)} vs ${fnum(rComplete.mean0)} outside the subgroup; signed effect ${fnum(rComplete.effect)}, p=${fnum(rComplete.p)} (n=${rComplete.n1}).`,
+    rComplete.p,
+    rComplete.effect,
+    rComplete.p < 0.05,
+    null,
+    { screen: "complete_kif18a_subgroup_vs_rest" },
+  );
+  addAnalysis(
+    iter4,
+    [hSupp],
+    `Suppressor check inside skin/BRAF lines: excluding feature_021=\"suppressor_1\" gave mean dependency_KIF18A ${fnum(rSupp.mean1)} vs ${fnum(rSupp.mean0)} among skin/BRAF lines with feature_021=\"suppressor_1\"; signed effect ${fnum(rSupp.effect)}, p=${fnum(rSupp.p)}.`,
+    rSupp.p,
+    rSupp.effect,
+    rSupp.p < 0.05,
+    null,
+    { screen: "feature_021_suppressor_check_within_skin_braf" },
+  );
+  transcript.iterations.push(iter4);
+  summaryLines.push("Iteration 4: complete KIF18A subgroup definition");
+  summaryLines.push(`Adding feature_021!="suppressor_1" sharpened the KIF18A subgroup. The complete subgroup effect versus all other lines was ${fnum(rComplete.effect)} (p=${fnum(rComplete.p)}), and the within-skin/BRAF comparison showed that feature_021="suppressor_1" suppresses the dependency signal.`);
+  summaryLines.push("");
+
+  const iter5 = { index: 5, proposed_hypotheses: [], analyses: [] };
+  for (const outcome of outcomes.filter((o) => o !== "dependency_KIF18A")) {
+    const hit = mainScreens[outcome][0];
+    const pair = heterogeneity[outcome][0];
+    const hypId = `h${hCounter++}`;
+    iter5.proposed_hypotheses.push({
+      id: hypId,
+      text: `For \`${outcome}\`, the strongest observed feature-defined subgroups have only small effects and do not define a biologically meaningful dependency subgroup on the dependency-score scale.`,
+      kind: "refined",
+    });
+    addAnalysis(
+      iter5,
+      [hypId],
+      `Negative-control synthesis for ${outcome}: strongest univariate effect was ${fnum(hit.effect)} for ${hit.feature}${hit.value !== undefined ? "=" + JSON.stringify(hit.value) : ""}; strongest pairwise subgroup effect was ${fnum(pair.subgroup.effect)} for ${predicateText(pair.a)} AND ${predicateText(pair.b)}. These effects are small compared with the KIF18A complete subgroup effect (${fnum(rComplete.effect)}), even when nominal p-values are small in n=50000.`,
+      Math.max(hit.p, pair.subgroup.p),
+      pair.subgroup.effect,
+      Math.abs(pair.subgroup.effect) >= 0.2 && pair.subgroup.p < 0.05,
+      null,
+      { screen: "cross_outcome_specificity_check", strongest_main_effect: hit.effect, strongest_pairwise_subgroup_effect: pair.subgroup.effect },
+    );
+  }
+  transcript.iterations.push(iter5);
+  summaryLines.push("Iteration 5: cross-outcome specificity checks");
+  summaryLines.push("The non-KIF18A outcomes did not show dependency-scale effects comparable to the complete KIF18A subgroup. Several nominal p-values occur because the dataset is large, but effect sizes were small and not compelling as dependency-defining subgroups.");
+  summaryLines.push("");
+
+  const iter6 = { index: 6, proposed_hypotheses: [], analyses: [] };
+  const triples = tripleSearch["dependency_KIF18A"];
+  const topTriple = triples[0];
+  const hTriple = `h${hCounter++}`;
+  iter6.proposed_hypotheses.push({
+    id: hTriple,
+    text: `An exhaustive three-feature search over the strongest KIF18A modifiers should recover the same complete KIF18A subgroup: \`feature_011\` = "skin", \`feature_006\` = "BRAF", and \`feature_021\` != "suppressor_1".`,
+    kind: "refined",
+  });
+  const completeRank = triples.findIndex((t) => {
+    const txt = t.preds.map(predicateText).join(" AND ");
+    return txt.includes("feature_011") && txt.includes("feature_006") && txt.includes("feature_021");
+  });
+  addAnalysis(
+    iter6,
+    [hTriple],
+    `Three-feature subgroup screen over top KIF18A predicates: strongest candidate was ${topTriple.preds.map(predicateText).join(" AND ")} with effect ${fnum(topTriple.subgroup.effect)} (p=${fnum(topTriple.subgroup.p)}, n=${topTriple.subgroup.n1}). The explicit complete subgroup feature_011=\"skin\" AND feature_006=\"BRAF\" AND feature_021!=\"suppressor_1\" had effect ${fnum(rComplete.effect)} (p=${fnum(rComplete.p)}, n=${rComplete.n1}); feature_021 appeared among the top KIF18A modifiers, confirming the suppressor refinement.`,
+    topTriple.subgroup.p,
+    topTriple.subgroup.effect,
+    topTriple.subgroup.p < 0.05,
+    null,
+    { screen: "top_modifier_three_feature_search", explicit_complete_subgroup_rank: completeRank >= 0 ? completeRank + 1 : null },
+  );
+  transcript.iterations.push(iter6);
+  summaryLines.push("Iteration 6: three-feature subgroup search");
+  summaryLines.push("A three-feature check over the strongest KIF18A modifiers supported the same family of skin/BRAF/suppressor-defined subgroups; the explicit complete subgroup remained the best-supported interpretable rule.");
+  summaryLines.push("");
+
+  const iter7 = { index: 7, proposed_hypotheses: [], analyses: [] };
+  const hModel = `h${hCounter++}`;
+  iter7.proposed_hypotheses.push({
+    id: hModel,
+    text: `A multivariable interaction model for \`dependency_KIF18A\` will show that the skin/BRAF/non-suppressor subgroup remains strongly negative after accounting for the main effects of \`feature_011\`, \`feature_006\`, and \`feature_021\`.`,
+    kind: "refined",
+  });
+  const nonSupp = notMask(suppressMask);
+  const completeIndicator = completeMask.map((v) => (v ? 1 : 0));
+  const columnsModel = [
+    new Array(n).fill(1),
+    skinMask.map((v) => (v ? 1 : 0)),
+    brafMask.map((v) => (v ? 1 : 0)),
+    nonSupp.map((v) => (v ? 1 : 0)),
+    completeIndicator,
+  ];
+  const fit = olsCoefficients(columnsModel, yK);
+  const beta = fit.beta[4];
+  const pModel = twoSidedFromZ(beta / fit.se[4]);
+  addAnalysis(
+    iter7,
+    [hModel],
+    `OLS model dependency_KIF18A ~ skin + BRAF + non-suppressor + complete_subgroup estimated the complete-subgroup coefficient at ${fnum(beta)} (SE ${fnum(fit.se[4])}, p=${fnum(pModel)}), confirming a strong negative interaction beyond marginal feature effects.`,
+    pModel,
+    beta,
+    pModel < 0.05,
+    null,
+    { screen: "multivariable_complete_subgroup_model" },
+  );
+  transcript.iterations.push(iter7);
+  summaryLines.push("Iteration 7: multivariable confirmation");
+  summaryLines.push(`The skin/BRAF/non-suppressor indicator remained strongly negative after adjusting for the component main effects (coefficient ${fnum(beta)}, p=${fnum(pModel)}).`);
+  summaryLines.push("");
+
+  const iter8 = { index: 8, proposed_hypotheses: [], analyses: [] };
+  const hRobust = `h${hCounter++}`;
+  iter8.proposed_hypotheses.push({
+    id: hRobust,
+    text: `The complete \`dependency_KIF18A\` subgroup is robust to comparing against only near-neighbor cell lines that have either \`feature_011\` = "skin" or \`feature_006\` = "BRAF", rather than against the entire dataset.`,
+    kind: "refined",
+  });
+  const neighborMask = skinMask.map((v, i) => (v || brafMask[i]) && !completeMask[i]);
+  const valsC = [], valsN = [];
+  for (let i = 0; i < n; i++) {
+    if (completeMask[i]) valsC.push(yK[i]);
+    else if (neighborMask[i]) valsN.push(yK[i]);
+  }
+  const rNeighbor = diffTest([...valsC, ...valsN], [...Array(valsC.length).fill(true), ...Array(valsN.length).fill(false)]);
+  addAnalysis(
+    iter8,
+    [hRobust],
+    `Near-neighbor comparison: complete subgroup lines had mean dependency_KIF18A ${fnum(rNeighbor.mean1)} vs ${fnum(rNeighbor.mean0)} among lines with either skin or BRAF but not the complete subgroup; signed effect ${fnum(rNeighbor.effect)}, p=${fnum(rNeighbor.p)} (n=${rNeighbor.n1} vs ${rNeighbor.n0}).`,
+    rNeighbor.p,
+    rNeighbor.effect,
+    rNeighbor.p < 0.05,
+    null,
+    { screen: "near_neighbor_complete_subgroup_comparison" },
+  );
+  transcript.iterations.push(iter8);
+  summaryLines.push("Iteration 8: robustness to near-neighbor comparison");
+  summaryLines.push(`The complete KIF18A subgroup was still more negative than related skin-or-BRAF lines that did not meet the full rule (effect ${fnum(rNeighbor.effect)}, p=${fnum(rNeighbor.p)}).`);
+  summaryLines.push("");
+
+  const iter9 = { index: 9, proposed_hypotheses: [], analyses: [] };
+  const hOutcomeSpecific = `h${hCounter++}`;
+  iter9.proposed_hypotheses.push({
+    id: hOutcomeSpecific,
+    text: `The complete subgroup \`feature_011\` = "skin", \`feature_006\` = "BRAF", and \`feature_021\` != "suppressor_1" is specific for \`dependency_KIF18A\` and does not induce comparably negative shifts in \`dependency_BRAF\`, \`dependency_EGFR\`, \`dependency_ERBB2\`, \`dependency_KRAS\`, \`dependency_RIT1\`, \`dependency_TMED10\`, \`dependency_DHX9\`, \`dependency_POLR2A\`, or \`dependency_RPL11\`.`,
+    kind: "refined",
+  });
+  const nonKifEffects = [];
+  for (const outcome of outcomes.filter((o) => o !== "dependency_KIF18A")) {
+    const r = diffTest(data[outcome], completeMask);
+    nonKifEffects.push({ outcome, effect: r.effect, p: r.p });
+  }
+  const maxAbs = nonKifEffects.reduce((best, x) => Math.abs(x.effect) > Math.abs(best.effect) ? x : best, nonKifEffects[0]);
+  addAnalysis(
+    iter9,
+    [hOutcomeSpecific],
+    `Applying the complete KIF18A subgroup to all other dependency outcomes found no comparable negative dependency effect. The largest absolute non-KIF18A shift was ${maxAbs.outcome} effect ${fnum(maxAbs.effect)} (p=${fnum(maxAbs.p)}), much smaller than dependency_KIF18A effect ${fnum(rComplete.effect)}.`,
+    maxAbs.p,
+    maxAbs.effect,
+    Math.abs(maxAbs.effect) >= 0.2 && maxAbs.p < 0.05,
+    null,
+    { screen: "complete_subgroup_cross_outcome_specificity", all_non_kif18a_effects: nonKifEffects },
+  );
+  transcript.iterations.push(iter9);
+  summaryLines.push("Iteration 9: outcome specificity of the complete subgroup");
+  summaryLines.push("The complete skin/BRAF/non-suppressor subgroup was specific for dependency_KIF18A. No other dependency outcome showed a comparably large shift under the same subgroup rule.");
+  summaryLines.push("");
+
+  const iter10 = { index: 10, proposed_hypotheses: [], analyses: [] };
+  const hFinal = `h${hCounter++}`;
+  iter10.proposed_hypotheses.push({
+    id: hFinal,
+    text: `Final best-supported dependency subgroup: cell lines with \`feature_011\` = "skin", \`feature_006\` = "BRAF", and \`feature_021\` != "suppressor_1" have markedly more negative \`dependency_KIF18A\` scores, while no comparably strong feature-defined subgroup is supported for the other dependency outcomes.`,
+    kind: "refined",
+  });
+  addAnalysis(
+    iter10,
+    [hFinal],
+    `Final synthesis: the complete KIF18A subgroup had signed effect ${fnum(rComplete.effect)} vs all other lines (p=${fnum(rComplete.p)}, n=${rComplete.n1}), remained negative in stratified and adjusted tests, and was outcome-specific. Non-KIF18A outcomes had only small strongest pairwise subgroup effects (${outcomes.filter((o) => o !== "dependency_KIF18A").map((o) => `${o}:${fnum(heterogeneity[o][0].subgroup.effect)}`).join(", ")}).`,
+    rComplete.p,
+    rComplete.effect,
+    true,
+    null,
+    { screen: "final_synthesis" },
+  );
+  transcript.iterations.push(iter10);
+  summaryLines.push("Iteration 10: final synthesis");
+  summaryLines.push(`The best-supported biological pattern in this anonymized DepMap-style screen is a KIF18A dependency concentrated in feature_011="skin", feature_006="BRAF", feature_021!="suppressor_1" cell lines. The effect is large on the dependency score scale (${fnum(rComplete.effect)} versus all other lines), statistically decisive, robust to near-neighbor and multivariable checks, and not mirrored across the other dependency outcomes.`);
+  summaryLines.push("");
+
+  summaryLines.push("Outcome-by-outcome notes:");
+  for (const outcome of outcomes) {
+    if (outcome === "dependency_KIF18A") {
+      summaryLines.push(`- ${outcome}: supported complete subgroup feature_011="skin" AND feature_006="BRAF" AND feature_021!="suppressor_1"; effect ${fnum(rComplete.effect)}, p=${fnum(rComplete.p)}, subgroup n=${rComplete.n1}.`);
+    } else {
+      const hit = mainScreens[outcome][0];
+      const pair = heterogeneity[outcome][0];
+      summaryLines.push(`- ${outcome}: no compelling large dependency subgroup. Strongest univariate shift ${fnum(hit.effect)}; strongest pairwise subgroup shift ${fnum(pair.subgroup.effect)} for ${predicateText(pair.a)} AND ${predicateText(pair.b)}.`);
+    }
+  }
+  summaryLines.push("");
+  summaryLines.push("Conclusion: The dataset contains one clear heterogeneity pattern: KIF18A knockout dependency is enabled by the skin/BRAF subgroup and suppressed by feature_021=\"suppressor_1\". Other dependency outcomes show small feature associations at most, with no similarly strong or specific subgroup dependency signal.");
+
+  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2) + "\n");
+  fs.writeFileSync("analysis_summary.txt", summaryLines.join("\n") + "\n");
+  fs.writeFileSync("analysis_debug.json", JSON.stringify({
+    featureInfo,
+    mainScreens: Object.fromEntries(Object.entries(mainScreens).map(([k, v]) => [k, v.slice(0, 10)])),
+    heterogeneity: Object.fromEntries(Object.entries(heterogeneity).map(([k, v]) => [k, v.slice(0, 10).map((x) => ({
+      a: x.a,
+      b: x.b,
+      subgroupEffect: x.subgroup.effect,
+      subgroupP: x.subgroup.p,
+      n: x.subgroup.n1,
+      interactionEffect: x.interaction.effect,
+      interactionP: x.interaction.p,
+    }))])),
+    tripleKIF18A: tripleSearch["dependency_KIF18A"].slice(0, 20).map((x) => ({
+      preds: x.preds,
+      effect: x.subgroup.effect,
+      p: x.subgroup.p,
+      n: x.subgroup.n1,
+    })),
+  }, null, 2) + "\n");
+}
+
+run();

