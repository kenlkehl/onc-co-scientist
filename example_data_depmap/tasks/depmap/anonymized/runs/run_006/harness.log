      `Negative-control synthesis for ${outcome}: strongest univariate effect was ${fnum(hit.effect)} for ${hit.feature}${hit.value !== undefined ? "=" + JSON.stringify(hit.value) : ""}; strongest pairwise subgroup effect was ${fnum(pair.subgroup.effect)} for ${predicateText(pair.a)} AND ${predicateText(pair.b)}. These effects are small compared with the KIF18A complete subgroup effect (${fnum(rComplete.effect)}), even when nominal p-values are small in n=50000.`,
      Math.max(hit.p, pair.subgroup.p),
      pair.subgroup.effect,
      Math.abs(pair.subgroup.effect) >= 0.2 && pair.subgroup.p < 0.05,
      null,
      { screen: "cross_outcome_specificity_check", strongest_main_effect: hit.effect, strongest_pairwise_subgroup_effect: pair.subgroup.effect },
    );
  }
  transcript.iterations.push(iter5);
  summaryLines.push("Iteration 5: cross-outcome specificity checks");
  summaryLines.push("The non-KIF18A outcomes did not show dependency-scale effects comparable to the complete KIF18A subgroup. Several nominal p-values occur because the dataset is large, but effect sizes were small and not compelling as dependency-defining subgroups.");
  summaryLines.push("");

  const iter6 = { index: 6, proposed_hypotheses: [], analyses: [] };
  const triples = tripleSearch["dependency_KIF18A"];
  const topTriple = triples[0];
  const hTriple = `h${hCounter++}`;
  iter6.proposed_hypotheses.push({
    id: hTriple,
    text: `An exhaustive three-feature search over the strongest KIF18A modifiers should recover the same complete KIF18A subgroup: \`feature_011\` = "skin", \`feature_006\` = "BRAF", and \`feature_021\` != "suppressor_1".`,
    kind: "refined",
  });
  const completeRank = triples.findIndex((t) => {
    const txt = t.preds.map(predicateText).join(" AND ");
    return txt.includes("feature_011") && txt.includes("feature_006") && txt.includes("feature_021");
  });
  addAnalysis(
    iter6,
    [hTriple],
    `Three-feature subgroup screen over top KIF18A predicates: strongest candidate was ${topTriple.preds.map(predicateText).join(" AND ")} with effect ${fnum(topTriple.subgroup.effect)} (p=${fnum(topTriple.subgroup.p)}, n=${topTriple.subgroup.n1}). The explicit complete subgroup feature_011=\"skin\" AND feature_006=\"BRAF\" AND feature_021!=\"suppressor_1\" had effect ${fnum(rComplete.effect)} (p=${fnum(rComplete.p)}, n=${rComplete.n1}); feature_021 appeared among the top KIF18A modifiers, confirming the suppressor refinement.`,
    topTriple.subgroup.p,
    topTriple.subgroup.effect,
    topTriple.subgroup.p < 0.05,
    null,
    { screen: "top_modifier_three_feature_search", explicit_complete_subgroup_rank: completeRank >= 0 ? completeRank + 1 : null },
  );
  transcript.iterations.push(iter6);
  summaryLines.push("Iteration 6: three-feature subgroup search");
  summaryLines.push("A three-feature check over the strongest KIF18A modifiers supported the same family of skin/BRAF/suppressor-defined subgroups; the explicit complete subgroup remained the best-supported interpretable rule.");
  summaryLines.push("");

  const iter7 = { index: 7, proposed_hypotheses: [], analyses: [] };
  const hModel = `h${hCounter++}`;
  iter7.proposed_hypotheses.push({
    id: hModel,
    text: `A multivariable interaction model for \`dependency_KIF18A\` will show that the skin/BRAF/non-suppressor subgroup remains strongly negative after accounting for the main effects of \`feature_011\`, \`feature_006\`, and \`feature_021\`.`,
    kind: "refined",
  });
  const nonSupp = notMask(suppressMask);
  const completeIndicator = completeMask.map((v) => (v ? 1 : 0));
  const columnsModel = [
    new Array(n).fill(1),
    skinMask.map((v) => (v ? 1 : 0)),
    brafMask.map((v) => (v ? 1 : 0)),
    nonSupp.map((v) => (v ? 1 : 0)),
    completeIndicator,
  ];
  const fit = olsCoefficients(columnsModel, yK);
  const beta = fit.beta[4];
  const pModel = twoSidedFromZ(beta / fit.se[4]);
  addAnalysis(
    iter7,
    [hModel],
    `OLS model dependency_KIF18A ~ skin + BRAF + non-suppressor + complete_subgroup estimated the complete-subgroup coefficient at ${fnum(beta)} (SE ${fnum(fit.se[4])}, p=${fnum(pModel)}), confirming a strong negative interaction beyond marginal feature effects.`,
    pModel,
    beta,
    pModel < 0.05,
    null,
    { screen: "multivariable_complete_subgroup_model" },
  );
  transcript.iterations.push(iter7);
  summaryLines.push("Iteration 7: multivariable confirmation");
  summaryLines.push(`The skin/BRAF/non-suppressor indicator remained strongly negative after adjusting for the component main effects (coefficient ${fnum(beta)}, p=${fnum(pModel)}).`);
  summaryLines.push("");

  const iter8 = { index: 8, proposed_hypotheses: [], analyses: [] };
  const hRobust = `h${hCounter++}`;
  iter8.proposed_hypotheses.push({
    id: hRobust,
    text: `The complete \`dependency_KIF18A\` subgroup is robust to comparing against only near-neighbor cell lines that have either \`feature_011\` = "skin" or \`feature_006\` = "BRAF", rather than against the entire dataset.`,
    kind: "refined",
  });
  const neighborMask = skinMask.map((v, i) => (v || brafMask[i]) && !completeMask[i]);
  const valsC = [], valsN = [];
  for (let i = 0; i < n; i++) {
    if (completeMask[i]) valsC.push(yK[i]);
    else if (neighborMask[i]) valsN.push(yK[i]);
  }
  const rNeighbor = diffTest([...valsC, ...valsN], [...Array(valsC.length).fill(true), ...Array(valsN.length).fill(false)]);
  addAnalysis(
    iter8,
    [hRobust],
    `Near-neighbor comparison: complete subgroup lines had mean dependency_KIF18A ${fnum(rNeighbor.mean1)} vs ${fnum(rNeighbor.mean0)} among lines with either skin or BRAF but not the complete subgroup; signed effect ${fnum(rNeighbor.effect)}, p=${fnum(rNeighbor.p)} (n=${rNeighbor.n1} vs ${rNeighbor.n0}).`,
    rNeighbor.p,
    rNeighbor.effect,
    rNeighbor.p < 0.05,
    null,
    { screen: "near_neighbor_complete_subgroup_comparison" },
  );
  transcript.iterations.push(iter8);
  summaryLines.push("Iteration 8: robustness to near-neighbor comparison");
  summaryLines.push(`The complete KIF18A subgroup was still more negative than related skin-or-BRAF lines that did not meet the full rule (effect ${fnum(rNeighbor.effect)}, p=${fnum(rNeighbor.p)}).`);
  summaryLines.push("");

