+++ b/example_data_depmap/tasks/depmap/anonymized/analysis_work.js
@@ -0,0 +1,1053 @@
+const fs = require("fs");
+const path = require("path");
+
+const PARQUET_TYPE = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  INT96: 3,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+  FIXED_LEN_BYTE_ARRAY: 7,
+};
+
+class CompactReader {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.offset = offset;
+    this.end = end;
+  }
+
+  byte() {
+    return this.buf[this.offset++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let value = 0n;
+    while (true) {
+      const b = this.byte();
+      value |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return value;
+      shift += 7n;
+    }
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return this.zigzag(this.varint());
+  }
+
+  string() {
+    const len = Number(this.varint());
+    const out = this.buf.toString("utf8", this.offset, this.offset + len);
+    this.offset += len;
+    return out;
+  }
+
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return [type, size];
+  }
+
+  mapHeader() {
+    const size = Number(this.varint());
+    if (size === 0) return [0, 0, 0];
+    const h = this.byte();
+    return [h >> 4, h & 0x0f, size];
+  }
+
+  value(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.byte();
+      case 4:
+      case 5:
+        return this.i32();
+      case 6:
+        return this.i64();
+      case 7: {
+        const out = this.buf.readDoubleLE(this.offset);
+        this.offset += 8;
+        return out;
+      }
+      case 8:
