+  const fit = olsCoefficients(columnsModel, yK);
+  const beta = fit.beta[4];
+  const pModel = twoSidedFromZ(beta / fit.se[4]);
+  addAnalysis(
+    iter7,
+    [hModel],
+    `OLS model dependency_KIF18A ~ colorectal + feature_035_1 + feature_020_0 + complete_subgroup estimated the complete-subgroup coefficient at ${fnum(beta)} (SE ${fnum(fit.se[4])}, p=${fnum(pModel)}), confirming a strong negative interaction beyond marginal feature effects.`,
+    pModel,
+    beta,
+    pModel < 0.05,
+    null,
+    { screen: "multivariable_complete_subgroup_model" },
+  );
+  transcript.iterations.push(iter7);
+  summaryLines.push("Iteration 7: multivariable confirmation");
+  summaryLines.push(`The colorectal/feature_035=1/feature_020=0 indicator remained strongly negative after adjusting for the component main effects (coefficient ${fnum(beta)}, p=${fnum(pModel)}).`);
+  summaryLines.push("");
+
+  const iter8 = { index: 8, proposed_hypotheses: [], analyses: [] };
+  const hRobust = `h${hCounter++}`;
+  iter8.proposed_hypotheses.push({
+    id: hRobust,
+    text: `The complete \`dependency_KIF18A\` subgroup is robust to comparing against near-neighbor cell lines that satisfy two of the three predicates \`feature_011\` = "colorectal", \`feature_035\` = 1, and \`feature_020\` = 0, rather than against the entire dataset.`,
+    kind: "refined",
+  });
+  const neighborMask = colorectalMask.map((v, i) => (
+    ((v && markerMask[i]) || (v && enableMask[i]) || (markerMask[i] && enableMask[i])) && !completeMask[i]
+  ));
+  const valsC = [], valsN = [];
+  for (let i = 0; i < n; i++) {
+    if (completeMask[i]) valsC.push(yK[i]);
+    else if (neighborMask[i]) valsN.push(yK[i]);
+  }
+  const rNeighbor = diffTest([...valsC, ...valsN], [...Array(valsC.length).fill(true), ...Array(valsN.length).fill(false)]);
+  addAnalysis(
+    iter8,
+    [hRobust],
+    `Near-neighbor comparison: complete subgroup lines had mean dependency_KIF18A ${fnum(rNeighbor.mean1)} vs ${fnum(rNeighbor.mean0)} among lines satisfying two of the three predicates but not the complete subgroup; signed effect ${fnum(rNeighbor.effect)}, p=${fnum(rNeighbor.p)} (n=${rNeighbor.n1} vs ${rNeighbor.n0}).`,
+    rNeighbor.p,
+    rNeighbor.effect,
+    rNeighbor.p < 0.05,
+    null,
+    { screen: "near_neighbor_complete_subgroup_comparison" },
+  );
+  transcript.iterations.push(iter8);
+  summaryLines.push("Iteration 8: robustness to near-neighbor comparison");
+  summaryLines.push(`The complete KIF18A subgroup was still more negative than related two-predicate lines that did not meet the full rule (effect ${fnum(rNeighbor.effect)}, p=${fnum(rNeighbor.p)}).`);
+  summaryLines.push("");
+
+  const iter9 = { index: 9, proposed_hypotheses: [], analyses: [] };
+  const hOutcomeSpecific = `h${hCounter++}`;
+  iter9.proposed_hypotheses.push({
+    id: hOutcomeSpecific,
+    text: `The complete subgroup \`feature_011\` = "colorectal", \`feature_035\` = 1, and \`feature_020\` = 0 is specific for \`dependency_KIF18A\` and does not induce comparably negative shifts in \`dependency_BRAF\`, \`dependency_EGFR\`, \`dependency_ERBB2\`, \`dependency_KRAS\`, \`dependency_RIT1\`, \`dependency_TMED10\`, \`dependency_DHX9\`, \`dependency_POLR2A\`, or \`dependency_RPL11\`.`,
+    kind: "refined",
+  });
+  const nonKifEffects = [];
+  for (const outcome of outcomes.filter((o) => o !== "dependency_KIF18A")) {
