+  varint() {
+    let shift = 0n;
+    let value = 0n;
+    while (true) {
+      const b = this.byte();
+      value |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return value;
+      shift += 7n;
