+    if (mask[i]) {
+      n1++;
+      s1 += y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) {
+      const d = y[i] - m1;
+      ss1 += d * d;
+    } else {
+      const d = y[i] - m0;
+      ss0 += d * d;
+    }
+  }
+  const v1 = ss1 / Math.max(1, n1 - 1);
+  const v0 = ss0 / Math.max(1, n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
