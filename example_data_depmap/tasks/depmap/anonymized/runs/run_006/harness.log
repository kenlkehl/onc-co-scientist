  addAnalysis(
    iter9,
    [hOutcomeSpecific],
    `Applying the complete KIF18A subgroup to all other dependency outcomes found no comparable negative dependency effect. The largest absolute non-KIF18A shift was ${maxAbs.outcome} effect ${fnum(maxAbs.effect)} (p=${fnum(maxAbs.p)}), much smaller than dependency_KIF18A effect ${fnum(rComplete.effect)}.`,
    maxAbs.p,
    maxAbs.effect,
    Math.abs(maxAbs.effect) >= 0.2 && maxAbs.p < 0.05,
    null,
    { screen: "complete_subgroup_cross_outcome_specificity", all_non_kif18a_effects: nonKifEffects },
  );
  transcript.iterations.push(iter9);
  summaryLines.push("Iteration 9: outcome specificity of the complete subgroup");
  summaryLines.push("The complete skin/BRAF/non-suppressor subgroup was specific for dependency_KIF18A. No other dependency outcome showed a comparably large shift under the same subgroup rule.");
  summaryLines.push("");

  const iter10 = { index: 10, proposed_hypotheses: [], analyses: [] };
  const hFinal = `h${hCounter++}`;
  iter10.proposed_hypotheses.push({
    id: hFinal,
    text: `Final best-supported dependency subgroup: cell lines with \`feature_011\` = "skin", \`feature_006\` = "BRAF", and \`feature_021\` != "suppressor_1" have markedly more negative \`dependency_KIF18A\` scores, while no comparably strong feature-defined subgroup is supported for the other dependency outcomes.`,
    kind: "refined",
  });
  addAnalysis(
    iter10,
    [hFinal],
    `Final synthesis: the complete KIF18A subgroup had signed effect ${fnum(rComplete.effect)} vs all other lines (p=${fnum(rComplete.p)}, n=${rComplete.n1}), remained negative in stratified and adjusted tests, and was outcome-specific. Non-KIF18A outcomes had only small strongest pairwise subgroup effects (${outcomes.filter((o) => o !== "dependency_KIF18A").map((o) => `${o}:${fnum(heterogeneity[o][0].subgroup.effect)}`).join(", ")}).`,
    rComplete.p,
    rComplete.effect,
    true,
    null,
    { screen: "final_synthesis" },
  );
  transcript.iterations.push(iter10);
  summaryLines.push("Iteration 10: final synthesis");
  summaryLines.push(`The best-supported biological pattern in this anonymized DepMap-style screen is a KIF18A dependency concentrated in feature_011="skin", feature_006="BRAF", feature_021!="suppressor_1" cell lines. The effect is large on the dependency score scale (${fnum(rComplete.effect)} versus all other lines), statistically decisive, robust to near-neighbor and multivariable checks, and not mirrored across the other dependency outcomes.`);
  summaryLines.push("");

  summaryLines.push("Outcome-by-outcome notes:");
  for (const outcome of outcomes) {
    if (outcome === "dependency_KIF18A") {
      summaryLines.push(`- ${outcome}: supported complete subgroup feature_011="skin" AND feature_006="BRAF" AND feature_021!="suppressor_1"; effect ${fnum(rComplete.effect)}, p=${fnum(rComplete.p)}, subgroup n=${rComplete.n1}.`);
    } else {
      const hit = mainScreens[outcome][0];
      const pair = heterogeneity[outcome][0];
      summaryLines.push(`- ${outcome}: no compelling large dependency subgroup. Strongest univariate shift ${fnum(hit.effect)}; strongest pairwise subgroup shift ${fnum(pair.subgroup.effect)} for ${predicateText(pair.a)} AND ${predicateText(pair.b)}.`);
    }
  }
  summaryLines.push("");
  summaryLines.push("Conclusion: The dataset contains one clear heterogeneity pattern: KIF18A knockout dependency is enabled by the skin/BRAF subgroup and suppressed by feature_021=\"suppressor_1\". Other dependency outcomes show small feature associations at most, with no similarly strong or specific subgroup dependency signal.");

  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2) + "\n");
  fs.writeFileSync("analysis_summary.txt", summaryLines.join("\n") + "\n");
  fs.writeFileSync("analysis_debug.json", JSON.stringify({
    featureInfo,
    mainScreens: Object.fromEntries(Object.entries(mainScreens).map(([k, v]) => [k, v.slice(0, 10)])),
    heterogeneity: Object.fromEntries(Object.entries(heterogeneity).map(([k, v]) => [k, v.slice(0, 10).map((x) => ({
      a: x.a,
      b: x.b,
      subgroupEffect: x.subgroup.effect,
      subgroupP: x.subgroup.p,
      n: x.subgroup.n1,
      interactionEffect: x.interaction.effect,

