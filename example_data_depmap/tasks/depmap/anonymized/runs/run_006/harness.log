diff --git a/example_data_depmap/tasks/depmap/anonymized/analysis_work.js b/example_data_depmap/tasks/depmap/anonymized/analysis_work.js
new file mode 100644
index 0000000000000000000000000000000000000000..d03bdaaf78e6996e68ac4011057f8994789827e2
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/analysis_work.js
@@ -0,0 +1,1041 @@
+const fs = require("fs");
+const path = require("path");
+
+const PARQUET_TYPE = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  INT96: 3,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+  FIXED_LEN_BYTE_ARRAY: 7,
+};
+
+class CompactReader {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.offset = offset;
+    this.end = end;
+  }
+
+  byte() {
+    return this.buf[this.offset++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let value = 0n;
+    while (true) {
+      const b = this.byte();
+      value |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return value;
+      shift += 7n;
+    }
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
