+    id: hKifPair,
+    text: `In \`feature_011\` = "skin" cell lines, \`feature_006\` = "BRAF" marks a subgroup with substantially more negative \`dependency_KIF18A\` scores than skin cell lines without \`feature_006\` = "BRAF".`,
+    kind: "refined",
+  });
+  const skinMask = makeMask(kifPair.a.feature === "feature_011" ? kifPair.a : kifPair.b, data, n);
+  const brafPred = kifPair.a.feature === "feature_006" ? kifPair.a : kifPair.b;
+  const brafMask = makeMask(brafPred, data, n);
+  const skinBraf = andMask(skinMask, brafMask);
+  const skinNotBraf = skinMask.map((v, i) => v && !brafMask[i]);
+  const rSkin = (() => {
+    const y = data["dependency_KIF18A"];
+    const vals1 = [];
+    const vals0 = [];
+    for (let i = 0; i < n; i++) {
+      if (skinBraf[i]) vals1.push(y[i]);
