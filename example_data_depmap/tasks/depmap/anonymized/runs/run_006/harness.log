+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += beta[j] * columns[j][i];
+    const r = y[i] - pred;
+    rss += r * r;
+  }
