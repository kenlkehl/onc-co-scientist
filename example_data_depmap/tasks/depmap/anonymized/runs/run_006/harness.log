+  const markerMask = makeMask(markerPred, data, n);
+  const enableMask = makeMask(enablePred, data, n);
+  const suppressMask = makeMask(suppressPred, data, n);
+  const colorectalMarkerMask = andMask(colorectalMask, markerMask);
+  const yK = data["dependency_KIF18A"];
+
+  const iter3 = { index: 3, proposed_hypotheses: [], analyses: [] };
