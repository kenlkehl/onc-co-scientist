+  const n = Number(rowGroup[3]);
+  const columns = rowGroup[1];
+  const names = schema.slice(1).map((s) => s[4]);
+  const types = schema.slice(1).map((s) => s[1]);
+  const data = {};
+  for (let i = 0; i < columns.length; i++) {
+    data[names[i]] = readColumn(fileBuf, columns[i], types[i]);
+  }
