+  mapHeader() {
+    const size = Number(this.varint());
+    if (size === 0) return [0, 0, 0];
+    const h = this.byte();
+    return [h >> 4, h & 0x0f, size];
+  }
+
+  value(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.byte();
+      case 4:
+      case 5:
+        return this.i32();
+      case 6:
+        return this.i64();
+      case 7: {
+        const out = this.buf.readDoubleLE(this.offset);
+        this.offset += 8;
+        return out;
+      }
+      case 8:
+        return this.string();
+      case 9:
+      case 10: {
+        const [elementType, size] = this.listHeader();
+        const out = [];
+        for (let i = 0; i < size; i++) out.push(this.value(elementType));
+        return out;
+      }
+      case 11: {
