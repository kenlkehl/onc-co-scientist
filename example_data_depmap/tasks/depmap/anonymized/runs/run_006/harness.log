+      }
+    }
+    hits.sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+    mainScreens[outcome] = hits;
+  }
+
+  const heterogeneity = {};
+  for (const outcome of outcomes) {
+    const y = data[outcome];
+    const predMasks = predicates.map((pred) => ({ pred, mask: makeMask(pred, data, n) }));
+    const interactions = [];
+    for (let i = 0; i < predMasks.length; i++) {
+      for (let j = i + 1; j < predMasks.length; j++) {
+        const a = predMasks[i];
+        const b = predMasks[j];
+        if (a.pred.feature === b.pred.feature) continue;
+        const ix = interactionContrast(y, a.mask, b.mask);
+        if (!ix) continue;
+        const both = andMask(a.mask, b.mask);
+        const subgroup = diffTest(y, both);
+        interactions.push({ outcome, a: a.pred, b: b.pred, interaction: ix, subgroup });
+      }
+    }
+    interactions.sort((x, y2) => Math.abs(y2.interaction.effect) - Math.abs(x.interaction.effect));
+    heterogeneity[outcome] = interactions;
+  }
+
+  const tripleSearch = {};
+  for (const outcome of outcomes) {
+    const y = data[outcome];
+    const topPreds = [];
+    const seen = new Set();
+    for (const item of mainScreens[outcome]) {
+      const pred = item.type === "level_vs_rest"
+        ? predicates.find((p) => p.feature === item.feature && p.kind === "eq" && p.value === item.value)
+        : null;
+      if (pred && !seen.has(`${pred.feature}:${pred.value}`)) {
+        topPreds.push({ pred, mask: makeMask(pred, data, n), main: item });
+        seen.add(`${pred.feature}:${pred.value}`);
+      }
+      if (topPreds.length >= 16) break;
+    }
+    for (const item of heterogeneity[outcome].slice(0, 12)) {
+      for (const pred of [item.a, item.b]) {
+        const key = `${pred.feature}:${pred.kind}:${pred.value ?? pred.threshold}`;
+        if (!seen.has(key)) {
+          topPreds.push({ pred, mask: makeMask(pred, data, n), main: null });
+          seen.add(key);
+        }
+      }
+    }
+    const triples = [];
+    for (let i = 0; i < topPreds.length; i++) {
+      for (let j = i + 1; j < topPreds.length; j++) {
+        for (let k = j + 1; k < topPreds.length; k++) {
+          const features3 = new Set([topPreds[i].pred.feature, topPreds[j].pred.feature, topPreds[k].pred.feature]);
+          if (features3.size < 3) continue;
+          const both = andMask(andMask(topPreds[i].mask, topPreds[j].mask), topPreds[k].mask);
+          const r = diffTest(y, both);
+          if (r.n1 >= 100 && r.n0 >= 100) triples.push({ preds: [topPreds[i].pred, topPreds[j].pred, topPreds[k].pred], subgroup: r });
+        }
+      }
+    }
+    triples.sort((a, b) => Math.abs(b.subgroup.effect) - Math.abs(a.subgroup.effect));
+    tripleSearch[outcome] = triples;
