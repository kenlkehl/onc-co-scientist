+function interactionContrast(y, maskA, maskB) {
+  let n00 = 0, n10 = 0, n01 = 0, n11 = 0;
+  let s00 = 0, s10 = 0, s01 = 0, s11 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (maskA[i] && maskB[i]) { n11++; s11 += y[i]; }
+    else if (maskA[i]) { n10++; s10 += y[i]; }
+    else if (maskB[i]) { n01++; s01 += y[i]; }
+    else { n00++; s00 += y[i]; }
+  }
