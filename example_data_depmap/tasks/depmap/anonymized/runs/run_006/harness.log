+        values.push(value);
+      }
+      pos += Math.ceil((totalValues * bitWidth) / 8);
+    }
+  }
+  return { values, offset: pos };
+}
+
+function decodePlain(buf, offset, type, count) {
+  const values = [];
+  let pos = offset;
+  if (type === PARQUET_TYPE.DOUBLE) {
+    for (let i = 0; i < count; i++) {
+      values.push(buf.readDoubleLE(pos));
+      pos += 8;
+    }
