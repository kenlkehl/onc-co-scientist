+    if (mask[i]) {
+      n1++;
+      s1 += y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) {
+      const d = y[i] - m1;
+      ss1 += d * d;
+    } else {
+      const d = y[i] - m0;
+      ss0 += d * d;
+    }
+  }
