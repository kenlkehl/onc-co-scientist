+    `Within feature_011=\"skin\", feature_006=\"BRAF\" lines had mean dependency_KIF18A ${fnum(rSkin.mean1)} vs ${fnum(rSkin.mean0)} for non-BRAF skin lines; signed within-skin effect ${fnum(rSkin.effect)}, p=${fnum(rSkin.p)} (n=${rSkin.n1} vs ${rSkin.n0}).`,
+    rSkin.p,
+    rSkin.effect,
+    rSkin.p < 0.05,
+    null,
+    { screen: "within_skin_braf_stratified_test" },
+  );
+  transcript.iterations.push(iter3);
+  summaryLines.push("Iteration 3: focused KIF18A stratified refinement");
+  summaryLines.push(`Within feature_011="skin", feature_006="BRAF" lines had much stronger KIF18A dependency than non-BRAF skin lines (effect ${fnum(rSkin.effect)}, p=${fnum(rSkin.p)}), supporting the idea that the KIF18A signal is not a generic skin-lineage main effect.`);
+  summaryLines.push("");
+
+  const iter4 = { index: 4, proposed_hypotheses: [], analyses: [] };
+  const hSupp = `h${hCounter++}`;
+  iter4.proposed_hypotheses.push({
+    id: hSupp,
+    text: `The \`dependency_KIF18A\` effect of the \`feature_011\` = "skin" and \`feature_006\` = "BRAF" subgroup is suppressed when \`feature_021\` = "suppressor_1"; therefore the complete high-dependency subgroup is \`feature_011\` = "skin", \`feature_006\` = "BRAF", and \`feature_021\` != "suppressor_1".`,
+    kind: "refined",
+  });
+  const suppressPred = { feature: "feature_021", kind: "eq", value: "suppressor_1" };
+  const suppressMask = makeMask(suppressPred, data, n);
+  const completeMask = skinBraf.map((v, i) => v && !suppressMask[i]);
+  const suppressedMask = skinBraf.map((v, i) => v && suppressMask[i]);
+  const yK = data["dependency_KIF18A"];
+  const rComplete = diffTest(yK, completeMask);
+  const valsA = [], valsB = [];
+  for (let i = 0; i < n; i++) {
