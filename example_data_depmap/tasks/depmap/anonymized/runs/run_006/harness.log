+  return { slope, intercept, z, p: twoSidedFromZ(z) };
+}
+
+function olsCoefficients(columns, y) {
+  const n = y.length;
+  const p = columns.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const va = columns[a][i];
+      xty[a] += va * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += va * columns[b][i];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += beta[j] * columns[j][i];
+    const r = y[i] - pred;
+    rss += r * r;
+  }
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, row[i] * sigma2)));
+  return { beta, se, rss };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => [...row, ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))]);
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(m[r][col]) > Math.abs(m[pivot][col])) pivot = r;
+    if (Math.abs(m[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    [m[col], m[pivot]] = [m[pivot], m[col]];
+    const div = m[col][col];
+    for (let c = 0; c < 2 * n; c++) m[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = m[r][col];
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= factor * m[col][c];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function uniqueCounts(values) {
+  const counts = new Map();
+  for (const v of values) counts.set(v, (counts.get(v) || 0) + 1);
+  return counts;
+}
+
+function predicateText(pred) {
+  if (pred.kind === "eq") return `\`${pred.feature}\` = ${JSON.stringify(pred.value)}`;
+  return `\`${pred.feature}\` in its top quartile (>= ${pred.threshold.toFixed(3)})`;
