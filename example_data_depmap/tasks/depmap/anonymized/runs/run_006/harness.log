+        iter1,
+        [hypId],
+        `Univariate level-vs-rest screen: ${hit.feature}=${JSON.stringify(hit.value)} had mean ${outcome} ${fnum(hit.mean1)} vs ${fnum(hit.mean0)} in all other lines; signed difference ${fnum(hit.effect)} with p=${fnum(hit.p)} (normal approximation to Welch test; n=${hit.n1} vs ${hit.n0}).`,
+        hit.p,
+        hit.effect,
+        hit.p < 0.05,
+        null,
+        { feature: hit.feature, level: hit.value, screen: "main_effect_level_vs_rest" },
+      );
+    } else {
+      iter1.proposed_hypotheses.push({
+        id: hypId,
+        text: `Higher values of \`${hit.feature}\` are associated with ${direction} \`${outcome}\` scores.`,
+        kind: "novel",
+      });
+      addAnalysis(
+        iter1,
+        [hypId],
