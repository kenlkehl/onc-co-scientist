+    iter4,
+    [hSupp],
+    `Complete subgroup test: feature_011=\"skin\" AND feature_006=\"BRAF\" AND feature_021!="suppressor_1" had mean dependency_KIF18A ${fnum(rComplete.mean1)} vs ${fnum(rComplete.mean0)} outside the subgroup; signed effect ${fnum(rComplete.effect)}, p=${fnum(rComplete.p)} (n=${rComplete.n1}).`,
+    rComplete.p,
+    rComplete.effect,
+    rComplete.p < 0.05,
+    null,
+    { screen: "complete_kif18a_subgroup_vs_rest" },
+  );
+  addAnalysis(
+    iter4,
+    [hSupp],
+    `Suppressor check inside skin/BRAF lines: excluding feature_021=\"suppressor_1\" gave mean dependency_KIF18A ${fnum(rSupp.mean1)} vs ${fnum(rSupp.mean0)} among skin/BRAF lines with feature_021=\"suppressor_1\"; signed effect ${fnum(rSupp.effect)}, p=${fnum(rSupp.p)}.`,
+    rSupp.p,
+    rSupp.effect,
+    rSupp.p < 0.05,
+    null,
+    { screen: "feature_021_suppressor_check_within_skin_braf" },
+  );
+  transcript.iterations.push(iter4);
+  summaryLines.push("Iteration 4: complete KIF18A subgroup definition");
+  summaryLines.push(`Adding feature_021!="suppressor_1" sharpened the KIF18A subgroup. The complete subgroup effect versus all other lines was ${fnum(rComplete.effect)} (p=${fnum(rComplete.p)}), and the within-skin/BRAF comparison showed that feature_021="suppressor_1" suppresses the dependency signal.`);
+  summaryLines.push("");
+
+  const iter5 = { index: 5, proposed_hypotheses: [], analyses: [] };
+  for (const outcome of outcomes.filter((o) => o !== "dependency_KIF18A")) {
+    const hit = mainScreens[outcome][0];
