+      pos += 4;
+    }
+  } else if (type === PARQUET_TYPE.BYTE_ARRAY) {
+    for (let i = 0; i < count; i++) {
+      const len = buf.readInt32LE(pos);
+      pos += 4;
+      values.push(buf.toString("utf8", pos, pos + len));
+      pos += len;
+    }
+  } else {
+    throw new Error(`Unsupported plain type ${type}`);
+  }
+  return { values, offset: pos };
+}
+
+function parseMetadata(fileBuf) {
+  const footerLen = fileBuf.readUInt32LE(fileBuf.length - 8);
+  const footerStart = fileBuf.length - 8 - footerLen;
+  return new CompactReader(fileBuf, footerStart, fileBuf.length - 8).struct();
+}
+
+function readPageHeader(fileBuf, offset) {
+  const reader = new CompactReader(fileBuf, offset);
+  const header = reader.struct();
+  return { header, bodyOffset: reader.offset };
+}
+
+function readColumn(fileBuf, columnMeta, parquetType) {
+  const meta = columnMeta[3];
+  const totalValues = Number(meta[5]);
+  const codec = meta[4];
+  const dict = [];
+  let pos = meta[11] !== undefined ? Number(meta[11]) : Number(meta[9]);
+  const values = [];
+
+  while (values.length < totalValues) {
+    const { header, bodyOffset } = readPageHeader(fileBuf, pos);
+    const compressedSize = Number(header[3]);
+    const compressed = fileBuf.subarray(bodyOffset, bodyOffset + compressedSize);
+    let page = compressed;
+    if (codec === 1) page = snappyUncompress(compressed);
+    else if (codec !== 0) throw new Error(`Unsupported compression codec ${codec}`);
