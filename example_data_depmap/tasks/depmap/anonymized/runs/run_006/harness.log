+    Math.abs(maxAbs.effect) >= 0.2 && maxAbs.p < 0.05,
+    null,
+    { screen: "complete_subgroup_cross_outcome_specificity", all_non_kif18a_effects: nonKifEffects },
+  );
+  transcript.iterations.push(iter9);
+  summaryLines.push("Iteration 9: outcome specificity of the complete subgroup");
+  summaryLines.push("The complete colorectal/feature_035=1/feature_020=0 subgroup was specific for dependency_KIF18A. No other dependency outcome showed a comparably large shift under the same subgroup rule.");
+  summaryLines.push("");
+
+  const iter10 = { index: 10, proposed_hypotheses: [], analyses: [] };
+  const hFinal = `h${hCounter++}`;
+  iter10.proposed_hypotheses.push({
+    id: hFinal,
+    text: `Final best-supported dependency subgroup: cell lines with \`feature_011\` = "colorectal", \`feature_035\` = 1, and \`feature_020\` = 0 have markedly more negative \`dependency_KIF18A\` scores, while no comparably strong feature-defined subgroup is supported for the other dependency outcomes.`,
+    kind: "refined",
+  });
+  addAnalysis(
+    iter10,
+    [hFinal],
+    `Final synthesis: the complete KIF18A subgroup had signed effect ${fnum(rComplete.effect)} vs all other lines (p=${fnum(rComplete.p)}, n=${rComplete.n1}), remained negative in stratified and adjusted tests, and was outcome-specific. Non-KIF18A outcomes had only small strongest pairwise subgroup effects (${outcomes.filter((o) => o !== "dependency_KIF18A").map((o) => `${o}:${fnum(heterogeneity[o][0].subgroup.effect)}`).join(", ")}).`,
+    rComplete.p,
+    rComplete.effect,
+    true,
+    null,
+    { screen: "final_synthesis" },
+  );
+  transcript.iterations.push(iter10);
+  summaryLines.push("Iteration 10: final synthesis");
+  summaryLines.push(`The best-supported biological pattern in this anonymized DepMap-style screen is a KIF18A dependency concentrated in feature_011="colorectal", feature_035=1, feature_020=0 cell lines. The effect is large on the dependency score scale (${fnum(rComplete.effect)} versus all other lines), statistically decisive, robust to near-neighbor and multivariable checks, and not mirrored across the other dependency outcomes.`);
+  summaryLines.push("");
+
+  summaryLines.push("Outcome-by-outcome notes:");
+  for (const outcome of outcomes) {
+    if (outcome === "dependency_KIF18A") {
+      summaryLines.push(`- ${outcome}: supported complete subgroup feature_011="colorectal" AND feature_035=1 AND feature_020=0; effect ${fnum(rComplete.effect)}, p=${fnum(rComplete.p)}, subgroup n=${rComplete.n1}.`);
+    } else {
+      const hit = mainScreens[outcome][0];
+      const pair = heterogeneity[outcome][0];
+      summaryLines.push(`- ${outcome}: no compelling large dependency subgroup. Strongest univariate shift ${fnum(hit.effect)}; strongest pairwise subgroup shift ${fnum(pair.subgroup.effect)} for ${predicateText(pair.a)} AND ${predicateText(pair.b)}.`);
+    }
+  }
+  summaryLines.push("");
+  summaryLines.push("Conclusion: The dataset contains one clear heterogeneity pattern: KIF18A knockout dependency is enabled in colorectal lines with feature_035=1 and feature_020=0, while feature_020=1 suppresses that dependency within the colorectal/feature_035=1 background. Other dependency outcomes show small feature associations at most, with no similarly strong or specific subgroup dependency signal.");
+
+  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2) + "\n");
+  fs.writeFileSync("analysis_summary.txt", summaryLines.join("\n") + "\n");
+  fs.writeFileSync("analysis_debug.json", JSON.stringify({
+    featureInfo,
+    mainScreens: Object.fromEntries(Object.entries(mainScreens).map(([k, v]) => [k, v.slice(0, 10)])),
+    heterogeneity: Object.fromEntries(Object.entries(heterogeneity).map(([k, v]) => [k, v.slice(0, 10).map((x) => ({
+      a: x.a,
+      b: x.b,
+      subgroupEffect: x.subgroup.effect,
+      subgroupP: x.subgroup.p,
+      n: x.subgroup.n1,
+      interactionEffect: x.interaction.effect,
+      interactionP: x.interaction.p,
+    }))])),
+    tripleKIF18A: tripleSearch["dependency_KIF18A"].slice(0, 20).map((x) => ({
+      preds: x.preds,
+      effect: x.subgroup.effect,
+      p: x.subgroup.p,
+      n: x.subgroup.n1,
+    })),
+  }, null, 2) + "\n");
+}
+
+run();

diff --git a/example_data_depmap/tasks/depmap/anonymized/analysis_work.js b/example_data_depmap/tasks/depmap/anonymized/analysis_work.js
new file mode 100644
index 0000000000000000000000000000000000000000..1b51a96b71090d7f397323221e033b70f1a1e82f
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/analysis_work.js
@@ -0,0 +1,1052 @@
+const fs = require("fs");
+const path = require("path");
+
+const PARQUET_TYPE = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  INT96: 3,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+  FIXED_LEN_BYTE_ARRAY: 7,
+};
+
+class CompactReader {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.offset = offset;
+    this.end = end;
+  }
+
+  byte() {
+    return this.buf[this.offset++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let value = 0n;
+    while (true) {
+      const b = this.byte();
+      value |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return value;
+      shift += 7n;
+    }
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return this.zigzag(this.varint());
+  }
+
+  string() {
+    const len = Number(this.varint());
+    const out = this.buf.toString("utf8", this.offset, this.offset + len);
+    this.offset += len;
+    return out;
+  }
+
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return [type, size];
+  }
+
+  mapHeader() {
+    const size = Number(this.varint());
+    if (size === 0) return [0, 0, 0];
+    const h = this.byte();
+    return [h >> 4, h & 0x0f, size];
+  }
+
+  value(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.byte();
+      case 4:
+      case 5:
+        return this.i32();
+      case 6:
+        return this.i64();
+      case 7: {
+        const out = this.buf.readDoubleLE(this.offset);
+        this.offset += 8;
+        return out;
+      }
+      case 8:
+        return this.string();
+      case 9:
+      case 10: {
+        const [elementType, size] = this.listHeader();
+        const out = [];
+        for (let i = 0; i < size; i++) out.push(this.value(elementType));
+        return out;
+      }
+      case 11: {
