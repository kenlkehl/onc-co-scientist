+      const numDict = Number(dictHeader[1]);
+      const decoded = decodePlain(page, 0, parquetType, numDict);
+      dict.splice(0, dict.length, ...decoded.values);
+    } else if (header[1] === 0) {
+      const dataHeader = header[5];
+      const numValues = Number(dataHeader[1]);
+      const encoding = Number(dataHeader[2]);
+      let pageOffset = 0;
+      const levels = readHybrid(page, pageOffset, numValues, 1);
+      pageOffset = levels.offset;
+      const defined = levels.values.reduce((acc, v) => acc + (v === 1 ? 1 : 0), 0);
+      let decodedValues;
+      if (encoding === 8 || encoding === 2) {
+        const bitWidth = page[pageOffset++];
+        const indices = readHybrid(page, pageOffset, defined, bitWidth);
+        pageOffset = indices.offset;
+        decodedValues = indices.values.map((idx) => dict[idx]);
+      } else if (encoding === 0) {
+        const decoded = decodePlain(page, pageOffset, parquetType, defined);
+        decodedValues = decoded.values;
+        pageOffset = decoded.offset;
+      } else {
+        throw new Error(`Unsupported data encoding ${encoding}`);
+      }
