+
+function uniqueCounts(values) {
+  const counts = new Map();
+  for (const v of values) counts.set(v, (counts.get(v) || 0) + 1);
+  return counts;
+}
+
+function predicateText(pred) {
+  if (pred.kind === "eq") return `\`${pred.feature}\` = ${JSON.stringify(pred.value)}`;
+  return `\`${pred.feature}\` in its top quartile (>= ${pred.threshold.toFixed(3)})`;
