+    text: `Among \`feature_011\` = "colorectal" cell lines, \`feature_035\` = 1 marks a subgroup with substantially more negative \`dependency_KIF18A\` scores than colorectal cell lines with \`feature_035\` = 0.`,
+    kind: "refined",
+  });
+  const colorectalNotMarkerMask = colorectalMask.map((v, i) => v && !markerMask[i]);
+  const valsPairA = [], valsPairB = [];
+  for (let i = 0; i < n; i++) {
+    if (colorectalMarkerMask[i]) valsPairA.push(yK[i]);
+    else if (colorectalNotMarkerMask[i]) valsPairB.push(yK[i]);
+  }
+  const rColMarker = diffTest([...valsPairA, ...valsPairB], [...Array(valsPairA.length).fill(true), ...Array(valsPairB.length).fill(false)]);
+  addAnalysis(
+    iter3,
+    [hKifPair],
+    `Within feature_011=\"colorectal\", feature_035=1 lines had mean dependency_KIF18A ${fnum(rColMarker.mean1)} vs ${fnum(rColMarker.mean0)} for feature_035=0 colorectal lines; signed within-colorectal effect ${fnum(rColMarker.effect)}, p=${fnum(rColMarker.p)} (n=${rColMarker.n1} vs ${rColMarker.n0}).`,
+    rColMarker.p,
+    rColMarker.effect,
+    rColMarker.p < 0.05,
+    null,
+    { screen: "within_colorectal_feature035_stratified_test" },
+  );
+  transcript.iterations.push(iter3);
+  summaryLines.push("Iteration 3: focused KIF18A stratified refinement");
+  summaryLines.push(`Within feature_011="colorectal", feature_035=1 lines had much stronger KIF18A dependency than feature_035=0 colorectal lines (effect ${fnum(rColMarker.effect)}, p=${fnum(rColMarker.p)}), supporting an interaction rather than a simple lineage-only effect.`);
+  summaryLines.push("");
+
+  const iter4 = { index: 4, proposed_hypotheses: [], analyses: [] };
+  const hSupp = `h${hCounter++}`;
+  iter4.proposed_hypotheses.push({
+    id: hSupp,
+    text: `The \`dependency_KIF18A\` effect of the \`feature_011\` = "colorectal" and \`feature_035\` = 1 subgroup is enabled when \`feature_020\` = 0 and suppressed when \`feature_020\` = 1; therefore the complete high-dependency subgroup is \`feature_011\` = "colorectal", \`feature_035\` = 1, and \`feature_020\` = 0.`,
+    kind: "refined",
+  });
+  const completeMask = colorectalMarkerMask.map((v, i) => v && enableMask[i]);
+  const suppressedMask = colorectalMarkerMask.map((v, i) => v && suppressMask[i]);
+  const rComplete = diffTest(yK, completeMask);
+  const valsA = [], valsB = [];
+  for (let i = 0; i < n; i++) {
+    if (completeMask[i]) valsA.push(yK[i]);
+    else if (suppressedMask[i]) valsB.push(yK[i]);
+  }
+  const rSupp = diffTest([...valsA, ...valsB], [...Array(valsA.length).fill(true), ...Array(valsB.length).fill(false)]);
+  addAnalysis(
+    iter4,
+    [hSupp],
