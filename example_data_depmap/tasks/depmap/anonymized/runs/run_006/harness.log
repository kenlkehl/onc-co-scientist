+  struct() {
+    const out = {};
+    let lastFieldId = 0;
+    while (true) {
+      const header = this.byte();
+      const type = header & 0x0f;
+      if (type === 0) break;
+      const modifier = header >> 4;
+      const fieldId = modifier === 0 ? this.i32() : lastFieldId + modifier;
+      lastFieldId = fieldId;
+      out[fieldId] = this.value(type);
+    }
+    return out;
+  }
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[pos++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
