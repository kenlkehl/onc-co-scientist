+    kind: "refined",
+  });
+  const completeIndicator = completeMask.map((v) => (v ? 1 : 0));
+  const columnsModel = [
+    new Array(n).fill(1),
+    colorectalMask.map((v) => (v ? 1 : 0)),
+    markerMask.map((v) => (v ? 1 : 0)),
+    enableMask.map((v) => (v ? 1 : 0)),
