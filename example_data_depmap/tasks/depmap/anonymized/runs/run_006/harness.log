+function snappyUncompress(input) {
+  let pos = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[pos++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
