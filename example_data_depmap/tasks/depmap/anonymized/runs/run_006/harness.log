+    tripleKIF18A: tripleSearch["dependency_KIF18A"].slice(0, 20).map((x) => ({
+      preds: x.preds,
+      effect: x.subgroup.effect,
+      p: x.subgroup.p,
+      n: x.subgroup.n1,
+    })),
+  }, null, 2) + "\n");
+
+  const transcript = {
+    dataset_id: "ds001_depmap",
+    model_id: "gpt-5-codex",
+    harness_id: "codex-cli@local-node-parquet-analysis",
+    max_iterations: 10,
+    iterations: [],
+  };
+  const summaryLines = [];
+  summaryLines.push("CRISPR dependency map analysis for ds001_depmap");
+  summaryLines.push(`Rows: ${n}; features: ${features.length}; dependency outcomes: ${outcomes.length}. More negative dependency scores indicate stronger dependency.`);
+  summaryLines.push("");
+
+  const iter1 = { index: 1, proposed_hypotheses: [], analyses: [] };
+  let hCounter = 1;
+  for (const outcome of outcomes) {
+    const hit = mainScreens[outcome][0];
+    const direction = hit.effect < 0 ? "more negative" : "less negative";
+    const hypId = `h${hCounter++}`;
+    if (hit.type === "level_vs_rest") {
