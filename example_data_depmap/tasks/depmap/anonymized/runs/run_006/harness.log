+    [hSupp],
+    `Suppressor check inside colorectal/feature_035=1 lines: feature_020=0 lines had mean dependency_KIF18A ${fnum(rSupp.mean1)} vs ${fnum(rSupp.mean0)} among colorectal/feature_035=1 lines with feature_020=1; signed effect ${fnum(rSupp.effect)}, p=${fnum(rSupp.p)}.`,
+    rSupp.p,
+    rSupp.effect,
+    rSupp.p < 0.05,
+    null,
