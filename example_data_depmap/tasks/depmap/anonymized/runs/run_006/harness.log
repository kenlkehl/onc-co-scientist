+function readUnsignedVarint(buf, offset) {
+  let value = 0;
+  let shift = 0;
+  let pos = offset;
+  while (true) {
+    const b = buf[pos++];
+    value |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) return [value, pos];
+    shift += 7;
+  }
+}
