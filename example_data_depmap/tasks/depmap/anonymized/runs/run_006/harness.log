+  const featureInfo = {};
+  const predicates = [];
+  for (const feature of features) {
+    const counts = uniqueCounts(data[feature]);
+    const values = Array.from(counts.keys());
+    const numeric = typeof values[0] === "number";
+    featureInfo[feature] = { numeric, unique: values.length, counts: Object.fromEntries(counts) };
+    if (values.length <= 12) {
+      for (const [value, count] of counts.entries()) {
+        if (count >= 250 && n - count >= 250) predicates.push({ feature, kind: "eq", value, count });
+      }
+    } else if (numeric) {
+      const sorted = [...data[feature]].sort((a, b) => a - b);
+      const threshold = sorted[Math.floor(0.75 * (n - 1))];
+      const count = data[feature].reduce((acc, v) => acc + (v >= threshold ? 1 : 0), 0);
+      if (count >= 250 && n - count >= 250) predicates.push({ feature, kind: "high", threshold, count });
+    }
+  }
+
+  const mainScreens = {};
+  for (const outcome of outcomes) {
+    const y = data[outcome];
+    const hits = [];
+    for (const feature of features) {
+      const info = featureInfo[feature];
+      if (info.numeric && info.unique > 12) {
+        const r = slopeTest(data[feature], y);
+        hits.push({ outcome, feature, type: "slope", effect: r.slope, p: r.p, z: r.z });
+      } else {
+        const counts = uniqueCounts(data[feature]);
+        for (const [value, count] of counts.entries()) {
+          if (count < 250 || n - count < 250) continue;
+          const mask = data[feature].map((v) => v === value);
+          const r = diffTest(y, mask);
+          hits.push({ outcome, feature, value, type: "level_vs_rest", effect: r.effect, p: r.p, z: r.z, n1: r.n1, mean1: r.mean1, mean0: r.mean0 });
