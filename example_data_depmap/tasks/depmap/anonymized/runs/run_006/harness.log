+        hit.effect,
+        hit.p < 0.05,
+        null,
+        { feature: hit.feature, screen: "main_effect_slope" },
+      );
+    }
+  }
+  transcript.iterations.push(iter1);
+  summaryLines.push("Iteration 1: broad main-effect screen");
+  summaryLines.push("The largest univariate signals for most dependency outcomes were modest. The strongest overall single-feature signal was for dependency_KIF18A in feature_011=\"skin\" lines, which showed more negative scores than other lines.");
