+function interactionContrast(y, maskA, maskB) {
+  let n00 = 0, n10 = 0, n01 = 0, n11 = 0;
+  let s00 = 0, s10 = 0, s01 = 0, s11 = 0;
+  let q00 = 0, q10 = 0, q01 = 0, q11 = 0;
+  for (let i = 0; i < y.length; i++) {
+    const yi = y[i];
+    const yi2 = yi * yi;
+    if (maskA[i] && maskB[i]) { n11++; s11 += yi; q11 += yi2; }
+    else if (maskA[i]) { n10++; s10 += yi; q10 += yi2; }
+    else if (maskB[i]) { n01++; s01 += yi; q01 += yi2; }
+    else { n00++; s00 += yi; q00 += yi2; }
+  }
+  if (Math.min(n00, n10, n01, n11) < 50) return null;
+  const m00 = s00 / n00, m10 = s10 / n10, m01 = s01 / n01, m11 = s11 / n11;
+  const v00 = Math.max(0, (q00 - n00 * m00 * m00) / Math.max(1, n00 - 1));
+  const v10 = Math.max(0, (q10 - n10 * m10 * m10) / Math.max(1, n10 - 1));
+  const v01 = Math.max(0, (q01 - n01 * m01 * m01) / Math.max(1, n01 - 1));
+  const v11 = Math.max(0, (q11 - n11 * m11 * m11) / Math.max(1, n11 - 1));
+  const effect = m11 - m10 - m01 + m00;
+  const se = Math.sqrt(v11 / n11 + v10 / n10 + v01 / n01 + v00 / n00);
+  const z = se > 0 ? effect / se : 0;
+  return { n00, n10, n01, n11, m00, m10, m01, m11, effect, beta: effect, se, z, p: twoSidedFromZ(z) };
