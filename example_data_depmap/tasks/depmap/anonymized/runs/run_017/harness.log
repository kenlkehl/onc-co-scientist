+const fs = require('fs');
+
+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+    this.fieldStack = [0];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readUVarInt() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = BigInt(this.readByte());
+      result |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readZigZag() {
+    const n = this.readUVarInt();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
+    const len = Number(this.readUVarInt());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readString() {
+    return this.readBinary().toString('utf8');
+  }
+  readFieldHeader() {
+    const b = this.readByte();
+    if (b === 0) return null;
+    const type = b & 0x0f;
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) {
+      id = this.readZigZag();
+    } else {
+      id = this.fieldStack[this.fieldStack.length - 1] + delta;
+    }
+    this.fieldStack[this.fieldStack.length - 1] = id;
+    return { id, type };
+  }
+  beginStruct() {
+    this.fieldStack.push(0);
+  }
+  endStruct() {
+    this.fieldStack.pop();
+  }
+  readListHeader() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    let size = b >> 4;
+    if (size === 15) size = Number(this.readUVarInt());
+    return { size, type };
+  }
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.readZigZag();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8:
+        this.readBinary();
+        return;
+      case 9: {
+        const { size, type: elemType } = this.readListHeader();
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
+      case 10: {
+        const { size, type: elemType } = this.readListHeader();
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
+      case 11: {
+        const b = this.readByte();
+        if (b === 0) return;
+        const keyType = b & 0x0f;
+        const valType = b >> 4;
+        const size = Number(this.readUVarInt());
+        for (let i = 0; i < size; i++) {
+          this.skip(keyType);
+          this.skip(valType);
+        }
+        return;
+      }
+      case 12:
+        this.beginStruct();
+        while (true) {
+          const h = this.readFieldHeader();
+          if (!h) break;
+          this.skip(h.type);
+        }
+        this.endStruct();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+    }
+  }
+}
+
+function readI32ish(r, type) {
+  if (![4, 5, 6].includes(type)) throw new Error(`expected int type, got ${type}`);
+  return r.readZigZag();
+}
+
+function parseSchemaElement(r) {
+  const out = {};
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) out.type = readI32ish(r, h.type);
+    else if (h.id === 2) out.type_length = readI32ish(r, h.type);
+    else if (h.id === 3) out.repetition_type = readI32ish(r, h.type);
+    else if (h.id === 4) out.name = r.readString();
+    else if (h.id === 5) out.num_children = readI32ish(r, h.type);
+    else if (h.id === 6) out.converted_type = readI32ish(r, h.type);
+    else if (h.id === 7) out.scale = readI32ish(r, h.type);
+    else if (h.id === 8) out.precision = readI32ish(r, h.type);
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  return out;
+}
+
+function parseColumnMetaData(r) {
+  const out = {};
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) out.type = readI32ish(r, h.type);
+    else if (h.id === 2) {
+      const lh = r.readListHeader();
+      out.encodings = [];
+      for (let i = 0; i < lh.size; i++) out.encodings.push(readI32ish(r, lh.type));
+    } else if (h.id === 3) {
+      const lh = r.readListHeader();
+      out.path_in_schema = [];
+      for (let i = 0; i < lh.size; i++) out.path_in_schema.push(r.readString());
+    } else if (h.id === 4) out.codec = readI32ish(r, h.type);
+    else if (h.id === 5) out.num_values = readI32ish(r, h.type);
+    else if (h.id === 6) out.total_uncompressed_size = readI32ish(r, h.type);
+    else if (h.id === 7) out.total_compressed_size = readI32ish(r, h.type);
+    else if (h.id === 9) out.data_page_offset = readI32ish(r, h.type);
+    else if (h.id === 10) out.index_page_offset = readI32ish(r, h.type);
+    else if (h.id === 11) out.dictionary_page_offset = readI32ish(r, h.type);
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  return out;
+}
+
+function parseColumnChunk(r) {
+  const out = {};
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) out.file_path = r.readString();
+    else if (h.id === 2) out.file_offset = readI32ish(r, h.type);
+    else if (h.id === 3) out.meta_data = parseColumnMetaData(r);
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  return out;
+}
+
+function parseRowGroup(r) {
+  const out = {};
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) {
+      const lh = r.readListHeader();
+      out.columns = [];
+      for (let i = 0; i < lh.size; i++) out.columns.push(parseColumnChunk(r));
+    } else if (h.id === 2) out.total_byte_size = readI32ish(r, h.type);
+    else if (h.id === 3) out.num_rows = readI32ish(r, h.type);
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  return out;
+}
+
+function parseFileMeta(buf) {
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const footerStart = buf.length - 8 - footerLen;
+  const r = new CompactReader(buf, footerStart);
+  const out = { footerLen, footerStart };
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) out.version = readI32ish(r, h.type);
+    else if (h.id === 2) {
+      const lh = r.readListHeader();
+      out.schema = [];
+      for (let i = 0; i < lh.size; i++) out.schema.push(parseSchemaElement(r));
+    } else if (h.id === 3) out.num_rows = readI32ish(r, h.type);
+    else if (h.id === 4) {
+      const lh = r.readListHeader();
+      out.row_groups = [];
+      for (let i = 0; i < lh.size; i++) out.row_groups.push(parseRowGroup(r));
+    } else if (h.id === 6) out.created_by = r.readString();
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  out.metaEnd = r.pos;
+  return out;
+}
+
+function parsePageHeader(buf, offset) {
+  const r = new CompactReader(buf, offset);
+  const out = {};
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) out.type = readI32ish(r, h.type);
+    else if (h.id === 2) out.uncompressed_page_size = readI32ish(r, h.type);
+    else if (h.id === 3) out.compressed_page_size = readI32ish(r, h.type);
+    else if (h.id === 5) out.data_page_header = parseDataPageHeader(r);
+    else if (h.id === 7) out.dictionary_page_header = parseDictionaryPageHeader(r);
+    else if (h.id === 8) out.data_page_header_v2 = parseDataPageHeaderV2(r);
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  out.headerSize = r.pos - offset;
+  return out;
+}
+
+function parseDataPageHeader(r) {
+  const out = {};
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) out.num_values = readI32ish(r, h.type);
+    else if (h.id === 2) out.encoding = readI32ish(r, h.type);
+    else if (h.id === 3) out.definition_level_encoding = readI32ish(r, h.type);
+    else if (h.id === 4) out.repetition_level_encoding = readI32ish(r, h.type);
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  return out;
+}
+
+function parseDictionaryPageHeader(r) {
+  const out = {};
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) out.num_values = readI32ish(r, h.type);
+    else if (h.id === 2) out.encoding = readI32ish(r, h.type);
+    else if (h.id === 3) out.is_sorted = h.type === 1 ? true : (h.type === 2 ? false : !!readI32ish(r, h.type));
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  return out;
+}
+
+function parseDataPageHeaderV2(r) {
+  const out = {};
+  r.beginStruct();
+  while (true) {
+    const h = r.readFieldHeader();
+    if (!h) break;
+    if (h.id === 1) out.num_values = readI32ish(r, h.type);
+    else if (h.id === 2) out.num_nulls = readI32ish(r, h.type);
+    else if (h.id === 3) out.num_rows = readI32ish(r, h.type);
+    else if (h.id === 4) out.encoding = readI32ish(r, h.type);
+    else if (h.id === 5) out.definition_levels_byte_length = readI32ish(r, h.type);
+    else if (h.id === 6) out.repetition_levels_byte_length = readI32ish(r, h.type);
+    else if (h.id === 7) out.is_compressed = h.type === 1 ? true : (h.type === 2 ? false : !!readI32ish(r, h.type));
+    else r.skip(h.type);
+  }
+  r.endStruct();
+  return out;
+}
+
+const buf = fs.readFileSync('dataset.parquet');
+const meta = parseFileMeta(buf);
+
+function snappyUncompress(src) {
+  let p = 0;
+  let shift = 0;
+  let expected = 0;
+  while (true) {
+    const b = src[p++];
+    expected |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(expected);
+  let o = 0;
+  while (p < src.length) {
+    const tag = src[p++];
+    const kind = tag & 3;
+    if (kind === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const n = len - 59;
+        len = 0;
+        for (let i = 0; i < n; i++) len |= src[p++] << (8 * i);
+        len += 1;
+      }
+      src.copy(out, o, p, p + len);
+      p += len;
+      o += len;
+    } else if (kind === 1) {
+      const len = ((tag >> 2) & 0x7) + 4;
+      const offset = ((tag & 0xe0) << 3) | src[p++];
+      for (let i = 0; i < len; i++) {
+        out[o] = out[o - offset];
+        o++;
+      }
+    } else if (kind === 2) {
+      const len = (tag >> 2) + 1;
+      const offset = src[p] | (src[p + 1] << 8);
+      p += 2;
+      for (let i = 0; i < len; i++) {
+        out[o] = out[o - offset];
+        o++;
+      }
+    } else {
+      const len = (tag >> 2) + 1;
+      const offset = src[p] | (src[p + 1] << 8) | (src[p + 2] << 16) | (src[p + 3] << 24);
+      p += 4;
+      for (let i = 0; i < len; i++) {
+        out[o] = out[o - offset];
+        o++;
+      }
+    }
+  }
+  if (o !== expected) throw new Error(`snappy length mismatch ${o} != ${expected}`);
+  return out;
+}
+
+function pagePayload(buf, offset) {
+  const header = parsePageHeader(buf, offset);
+  const start = offset + header.headerSize;
+  const raw = buf.subarray(start, start + header.compressed_page_size);
+  const payload = snappyUncompress(raw);
+  return { header, payload, next: start + header.compressed_page_size };
+}
+
+if (require.main === module) {
+  console.log(JSON.stringify({
+    rows: meta.num_rows,
+    footerStart: meta.footerStart,
+    created_by: meta.created_by,
+    schema: meta.schema.map(s => ({ name: s.name, type: s.type, repetition_type: s.repetition_type, num_children: s.num_children })),
+    row_groups: meta.row_groups.map(rg => ({
+      num_rows: rg.num_rows,
+      columns: rg.columns.map(c => {
+        const first = parsePageHeader(buf, c.meta_data.dictionary_page_offset ?? c.meta_data.data_page_offset);
+        const data = parsePageHeader(buf, c.meta_data.data_page_offset);
+        return {
+          path: c.meta_data.path_in_schema,
+          type: c.meta_data.type,
+          codec: c.meta_data.codec,
+          encodings: c.meta_data.encodings,
+          num_values: c.meta_data.num_values,
+          total_compressed_size: c.meta_data.total_compressed_size,
+          data_page_offset: c.meta_data.data_page_offset,
+          dictionary_page_offset: c.meta_data.dictionary_page_offset,
+          first_page: first,
+          data_page: data
+        };
+      })
+    }))
+  }, null, 2));
+}
+
+module.exports = {
+  CompactReader,
+  parseFileMeta,
+  parsePageHeader,
+  snappyUncompress,
+  pagePayload,
+};

diff --git a/example_data_depmap/tasks/depmap/anonymized/analyze_depmap.js b/example_data_depmap/tasks/depmap/anonymized/analyze_depmap.js
new file mode 100644
index 0000000000000000000000000000000000000000..8e336e0999d2d8819f7465117ed7c3ea320f3ae3
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/analyze_depmap.js
@@ -0,0 +1,335 @@
+const fs = require('fs');
+const {
+  parseFileMeta,
+  pagePayload,
+} = require('./inspect_parquet.js');
+
+const PARQUET = fs.readFileSync('dataset.parquet');
+const META = parseFileMeta(PARQUET);
+const ROW_GROUP = META.row_groups[0];
+const SCHEMA_BY_NAME = new Map(META.schema.slice(1).map(s => [s.name, s]));
+
+function plainDecode(buf, type, count) {
+  const out = new Array(count);
+  let p = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === 6) {
+      const len = buf.readInt32LE(p);
+      p += 4;
+      out[i] = buf.subarray(p, p + len).toString('utf8');
+      p += len;
+    } else if (type === 5) {
+      out[i] = buf.readDoubleLE(p);
+      p += 8;
+    } else if (type === 2) {
+      out[i] = Number(buf.readBigInt64LE(p));
+      p += 8;
+    } else {
+      throw new Error(`Unsupported plain type ${type}`);
+    }
+  }
+  return out;
+}
+
+function readUVar(buf, pos) {
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = buf[pos++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) return { value: result, pos };
+    shift += 7;
+  }
+}
+
+function readPackedValue(buf, bitOffset, bitWidth) {
+  let v = 0;
+  for (let b = 0; b < bitWidth; b++) {
+    const absolute = bitOffset + b;
+    const bit = (buf[absolute >> 3] >> (absolute & 7)) & 1;
+    v |= bit << b;
+  }
+  return v;
+}
+
+function decodeHybrid(buf, pos, bitWidth, count) {
+  const out = [];
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (out.length < count) {
+    const h = readUVar(buf, pos);
+    const header = h.value;
+    pos = h.pos;
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < valueBytes; i++) value |= buf[pos++] << (8 * i);
+      const n = Math.min(runLength, count - out.length);
+      for (let i = 0; i < n; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const values = groups * 8;
+      const byteLength = Math.ceil(values * bitWidth / 8);
+      const start = pos;
+      const n = Math.min(values, count - out.length);
+      for (let i = 0; i < n; i++) out.push(readPackedValue(buf.subarray(start, start + byteLength), i * bitWidth, bitWidth));
+      pos += byteLength;
+    }
+  }
+  return { values: out, pos };
+}
+
+function decodeColumn(columnChunk) {
+  const md = columnChunk.meta_data;
+  const name = md.path_in_schema[0];
+  const schema = SCHEMA_BY_NAME.get(name);
+  let dictionary = null;
+  if (md.dictionary_page_offset !== undefined) {
+    const dictPage = pagePayload(PARQUET, md.dictionary_page_offset);
+    dictionary = plainDecode(
+      dictPage.payload,
+      md.type,
+      dictPage.header.dictionary_page_header.num_values,
+    );
+  }
+  const values = [];
+  let off = md.data_page_offset;
+  while (values.length < md.num_values) {
+    const page = pagePayload(PARQUET, off);
+    off = page.next;
+    if (page.header.type !== 0) continue;
+    const h = page.header.data_page_header;
+    let p = 0;
+    if (schema.repetition_type === 1) {
+      const defLen = page.payload.readUInt32LE(p);
+      p += 4 + defLen;
+    }
+    let pageValues;
+    if (h.encoding === 8 || h.encoding === 2) {
+      const bitWidth = page.payload[p++];
+      const decoded = decodeHybrid(page.payload, p, bitWidth, h.num_values);
+      pageValues = decoded.values.map(idx => dictionary[idx]);
+    } else if (h.encoding === 0) {
+      pageValues = plainDecode(page.payload.subarray(p), md.type, h.num_values);
+    } else {
+      throw new Error(`Unsupported data encoding ${h.encoding} for ${name}`);
+    }
+    values.push(...pageValues);
+  }
+  return values.slice(0, md.num_values);
+}
+
+function loadData() {
+  const data = {};
+  for (const col of ROW_GROUP.columns) {
+    const name = col.meta_data.path_in_schema[0];
+    if (name === 'cell_line_id') continue;
+    try {
+      data[name] = decodeColumn(col);
+    } catch (err) {
+      err.message = `${name}: ${err.message}`;
+      throw err;
+    }
+  }
+  return data;
+}
+
+function mean(values, mask = null, desired = true) {
+  let s = 0, n = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (!mask || mask[i] === desired) {
+      s += values[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(values, m, mask = null, desired = true) {
+  let ss = 0, n = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (!mask || mask[i] === desired) {
+      const d = values[i] - m;
+      ss += d * d;
+      n++;
+    }
+  }
+  return ss / Math.max(1, n - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
+  return sign * y;
+}
+
+function normalPFromZ(z) {
+  const az = Math.abs(z);
+  if (!Number.isFinite(az)) return 0;
+  if (az > 37) return 1e-300;
+  const phi = 0.5 * (1 + erf(az / Math.SQRT2));
+  return Math.max(1e-300, 2 * (1 - phi));
+}
+
+function diffTest(y, mask) {
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (mask[i]) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - s1 * s1 / n1) / Math.max(1, n1 - 1);
+  const v0 = (ss0 - s0 * s0 / n0) / Math.max(1, n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, z, p: normalPFromZ(z) };
+}
+
+function slopeTest(x, y) {
+  const n = x.length;
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    sxy += dx * dy;
+    syy += dy * dy;
+  }
+  const slope = sxy / sxx;
+  const sse = syy - slope * sxy;
+  const se = Math.sqrt((sse / Math.max(1, n - 2)) / sxx);
+  const z = slope / se;
+  const sd = Math.sqrt(sxx / (n - 1));
+  return { slope, perSdEffect: slope * sd, z, p: normalPFromZ(z) };
+}
+
+function uniqueValues(arr) {
+  return Array.from(new Set(arr));
+}
+
+function quantile(sorted, q) {
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos), hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] * (hi - pos) + sorted[hi] * (pos - lo);
+}
+
+function makePredicates(data, features) {
+  const preds = [];
+  for (const f of features) {
+    const x = data[f];
+    const vals = uniqueValues(x);
+    if (typeof vals[0] === 'string') {
+      for (const v of vals) {
+        const mask = x.map(a => a === v);
+        const n = mask.reduce((a, b) => a + (b ? 1 : 0), 0);
+        if (n >= 200 && n <= x.length - 200) preds.push({ text: `${f} == ${JSON.stringify(v)}`, feature: f, kind: 'categorical', mask, n });
+      }
+    } else if (vals.length <= 5 && vals.every(v => Number.isInteger(v))) {
+      for (const v of vals.sort((a, b) => a - b)) {
+        const mask = x.map(a => a === v);
+        const n = mask.reduce((a, b) => a + (b ? 1 : 0), 0);
+        if (n >= 200 && n <= x.length - 200) preds.push({ text: `${f} == ${v}`, feature: f, kind: 'binary', mask, n });
+      }
+    } else {
+      const sorted = [...x].sort((a, b) => a - b);
+      const q25 = quantile(sorted, 0.25);
+      const q75 = quantile(sorted, 0.75);
+      for (const [label, fn] of [[`<= ${q25.toFixed(4)}`, a => a <= q25], [`>= ${q75.toFixed(4)}`, a => a >= q75]]) {
+        const mask = x.map(fn);
+        const n = mask.reduce((a, b) => a + (b ? 1 : 0), 0);
+        preds.push({ text: `${f} ${label}`, feature: f, kind: 'continuous_bin', mask, n });
+      }
+    }
+  }
+  return preds;
+}
+
+function andMask(a, b) {
+  const out = new Array(a.length);
+  let n = 0;
+  for (let i = 0; i < a.length; i++) {
+    const v = a[i] && b[i];
+    out[i] = v;
+    if (v) n++;
+  }
+  return { mask: out, n };
+}
+
+function summarizeFeature(data, f) {
+  const x = data[f];
+  const vals = uniqueValues(x);
+  if (typeof vals[0] === 'string' || vals.length <= 12) {
+    const counts = new Map();
+    for (const v of x) counts.set(v, (counts.get(v) || 0) + 1);
+    return Array.from(counts.entries()).sort((a, b) => b[1] - a[1]).map(([v, n]) => `${v}:${n}`).join(', ');
+  }
+  const sorted = [...x].sort((a, b) => a - b);
+  return `mean=${mean(x).toFixed(4)}, q25=${quantile(sorted, 0.25).toFixed(4)}, q50=${quantile(sorted, 0.5).toFixed(4)}, q75=${quantile(sorted, 0.75).toFixed(4)}`;
+}
+
+function main() {
+  const data = loadData();
+  const features = Object.keys(data).filter(c => c.startsWith('feature_'));
+  const outcomes = Object.keys(data).filter(c => c.startsWith('dependency_'));
+  console.log('loaded', META.num_rows, 'rows', features.length, 'features', outcomes.length, 'outcomes');
+  for (const f of features) console.log('FEATURE', f, summarizeFeature(data, f));
+  for (const yname of outcomes) {
+    const y = data[yname];
+    const sorted = [...y].sort((a, b) => a - b);
+    console.log('OUTCOME', yname, `mean=${mean(y).toFixed(4)} q05=${quantile(sorted, 0.05).toFixed(4)} q50=${quantile(sorted, 0.5).toFixed(4)} q95=${quantile(sorted, 0.95).toFixed(4)}`);
+  }
+  const preds = makePredicates(data, features);
+  for (const yname of outcomes) {
+    const y = data[yname];
+    const tests = [];
+    for (const p of preds) tests.push({ pred: p.text, feature: p.feature, ...diffTest(y, p.mask) });
+    for (const f of features) {
+      const vals = uniqueValues(data[f]);
+      if (typeof vals[0] === 'number' && vals.length > 5) {
+        const st = slopeTest(data[f], y);
+        tests.push({ pred: `${f} continuous`, feature: f, effect: st.perSdEffect, p: st.p, z: st.z, n1: data[f].length, mean1: null, mean0: null });
+      }
+    }
+    tests.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    console.log('\\nTOP MAIN', yname);
+    for (const t of tests.slice(0, 12)) {
+      console.log(JSON.stringify({ pred: t.pred, n: t.n1, effect: +t.effect.toFixed(6), z: +t.z.toFixed(3), p: t.p, mean_in: t.mean1 === null ? null : +t.mean1.toFixed(5), mean_out: t.mean0 === null ? null : +t.mean0.toFixed(5) }));
+    }
+    const predScores = preds.map((p, idx) => ({ idx, p, ...diffTest(y, p.mask) }))
+      .filter(t => t.n1 >= 300 && t.n0 >= 300)
+      .sort((a, b) => Math.abs(b.z) - Math.abs(a.z))
+      .slice(0, 40);
+    const pairs = [];
+    for (let i = 0; i < predScores.length; i++) {
+      for (let j = i + 1; j < predScores.length; j++) {
+        const a = predScores[i].p, b = predScores[j].p;
+        if (a.feature === b.feature) continue;
+        const { mask, n } = andMask(a.mask, b.mask);
+        if (n < 200 || n > y.length - 200) continue;
+        const st = diffTest(y, mask);
+        pairs.push({ pred: `${a.text} AND ${b.text}`, n, ...st });
+      }
+    }
+    pairs.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    console.log('TOP PAIRS', yname);
+    for (const t of pairs.slice(0, 10)) {
+      console.log(JSON.stringify({ pred: t.pred, n: t.n, effect: +t.effect.toFixed(6), z: +t.z.toFixed(3), p: t.p, mean_in: +t.mean1.toFixed(5), mean_out: +t.mean0.toFixed(5) }));
+    }
+  }
+}
+
+if (require.main === module) main();
+
+module.exports = { loadData, diffTest, slopeTest, mean, variance, quantile, uniqueValues, makePredicates, andMask, normalPFromZ };
