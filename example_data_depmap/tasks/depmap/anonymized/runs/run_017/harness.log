+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = BigInt(this.readByte());
+      result |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
