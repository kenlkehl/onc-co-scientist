+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+    this.fieldStack = [0];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readUVarInt() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = BigInt(this.readByte());
+      result |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readZigZag() {
+    const n = this.readUVarInt();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
