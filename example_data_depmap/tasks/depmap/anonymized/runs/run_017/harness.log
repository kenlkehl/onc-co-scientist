+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.readZigZag();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8:
+        this.readBinary();
+        return;
+      case 9: {
+        const { size, type: elemType } = this.readListHeader();
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
+      case 10: {
+        const { size, type: elemType } = this.readListHeader();
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
+      case 11: {
+        const b = this.readByte();
+        if (b === 0) return;
+        const keyType = b & 0x0f;
+        const valType = b >> 4;
+        const size = Number(this.readUVarInt());
