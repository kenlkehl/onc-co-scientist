+const fs = require('fs');
+
+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+    this.fieldStack = [0];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readUVarInt() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
