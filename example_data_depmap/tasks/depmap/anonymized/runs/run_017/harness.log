+  }
+  r.endStruct();
+  return out;
+}
+
+const buf = fs.readFileSync('dataset.parquet');
+const meta = parseFileMeta(buf);
+
+function snappyUncompress(src) {
+  let p = 0;
+  let shift = 0;
+  let expected = 0;
+  while (true) {
+    const b = src[p++];
+    expected |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(expected);
+  let o = 0;
+  while (p < src.length) {
+    const tag = src[p++];
+    const kind = tag & 3;
+    if (kind === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const n = len - 59;
+        len = 0;
+        for (let i = 0; i < n; i++) len |= src[p++] << (8 * i);
+        len += 1;
+      }
+      src.copy(out, o, p, p + len);
