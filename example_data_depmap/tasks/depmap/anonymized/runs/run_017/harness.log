+  let o = 0;
+  while (p < src.length) {
+    const tag = src[p++];
+    const kind = tag & 3;
+    if (kind === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const n = len - 59;
+        len = 0;
+        for (let i = 0; i < n; i++) len |= src[p++] << (8 * i);
+        len += 1;
+      }
