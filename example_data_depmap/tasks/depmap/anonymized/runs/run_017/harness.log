import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
print('features', len(features), 'outcomes', len(outcomes))
print('\\nFeature unique counts and means:')
for c in features:
    vals=df[c].unique()
    print(c, 'nunique', df[c].nunique(), 'mean', float(df[c].mean()), 'min', df[c].min(), 'max', df[c].max())
print('\\nOutcome summary:')
print(df[outcomes].describe().T.to_string())
