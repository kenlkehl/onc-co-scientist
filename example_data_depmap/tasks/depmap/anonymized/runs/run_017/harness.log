+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    sxy += dx * dy;
+    syy += dy * dy;
+  }
+  const slope = sxy / sxx;
+  const sse = syy - slope * sxy;
+  const se = Math.sqrt((sse / Math.max(1, n - 2)) / sxx);
+  const z = slope / se;
+  const sd = Math.sqrt(sxx / (n - 1));
