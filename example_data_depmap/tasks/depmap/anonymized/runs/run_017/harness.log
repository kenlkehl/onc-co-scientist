+      p += len;
+      o += len;
+    } else if (kind === 1) {
+      const len = ((tag >> 2) & 0x7) + 4;
+      const offset = ((tag & 0xe0) << 3) | src[p++];
+      for (let i = 0; i < len; i++) {
+        out[o] = out[o - offset];
+        o++;
+      }
+    } else if (kind === 2) {
+      const len = (tag >> 2) + 1;
+      const offset = src[p] | (src[p + 1] << 8);
+      p += 2;
+      for (let i = 0; i < len; i++) {
+        out[o] = out[o - offset];
+        o++;
+      }
+    } else {
+      const len = (tag >> 2) + 1;
+      const offset = src[p] | (src[p + 1] << 8) | (src[p + 2] << 16) | (src[p + 3] << 24);
+      p += 4;
+      for (let i = 0; i < len; i++) {
