--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/inspect_parquet.js
@@ -0,0 +1,410 @@
+const fs = require('fs');
+
+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+    this.fieldStack = [0];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readUVarInt() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = BigInt(this.readByte());
+      result |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readZigZag() {
+    const n = this.readUVarInt();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
+    const len = Number(this.readUVarInt());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readString() {
+    return this.readBinary().toString('utf8');
+  }
+  readFieldHeader() {
+    const b = this.readByte();
+    if (b === 0) return null;
+    const type = b & 0x0f;
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) {
+      id = this.readZigZag();
+    } else {
+      id = this.fieldStack[this.fieldStack.length - 1] + delta;
+    }
+    this.fieldStack[this.fieldStack.length - 1] = id;
+    return { id, type };
+  }
+  beginStruct() {
+    this.fieldStack.push(0);
+  }
+  endStruct() {
+    this.fieldStack.pop();
+  }
+  readListHeader() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    let size = b >> 4;
+    if (size === 15) size = Number(this.readUVarInt());
+    return { size, type };
