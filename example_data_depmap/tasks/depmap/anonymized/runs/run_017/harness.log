+          dictionary_page_offset: c.meta_data.dictionary_page_offset,
+          first_page: first,
+          data_page: data
+        };
+      })
+    }))
+  }, null, 2));
+}
+
+module.exports = {
+  CompactReader,
+  parseFileMeta,
+  parsePageHeader,
+  snappyUncompress,
+  pagePayload,
+};

