const fs=require('fs'); const file=fs.readFileSync('dataset.parquet');
class R{constructor(b,off=0){this.b=b;this.p=off;}u8(){return this.b[this.p++];}varint(){let s=0,n=0n;while(true){const byte=this.u8();n|=BigInt(byte&127)<<BigInt(s);if("'!(byte&128))break;s+=7;}return n;}zig(){const n=this.varint();return Number((n>>1n)''^(-(n&1n)));}zigBig(){const n=this.varint();return(n>>1n)''^(-(n&1n));}bin(){const l=Number(this.varint());const v=this.b.subarray(this.p,this.p+l);this.p+=l;return v;}dbl(){const v=this.b.readDoubleLE(this.p);this.p+=8;return v;}}
function readStruct(r,cb){let last=0;while(true){const h=r.u8();const t=h&15;if(t===0)break;const d=h>>4;const fid=d===0?r.zig():last+d;last=fid;cb(fid,t,r);}}
function readList(r,cb){const h=r.u8();let size=h>>4,et=h&15;if(size===15)size=Number(r.varint());const a=[];for(let i=0;i<size;i++)a.push(cb(r,et,i));return a;}
function val(r,t){if(t===1)return true;if(t===2)return false;if(t===3)return r.u8();if(t===4||t===5)return r.zig();if(t===6)return Number(r.zigBig());if(t===7)return r.dbl();if(t===8)return r.bin().toString('"'utf8');throw Error('val '+t)}
function skip(r,t){if(t===1||t===2)return;if(t===3){r.u8();return;}if(t===4||t===5){r.zig();return;}if(t===6){r.zigBig();return;}if(t===7){r.dbl();return;}if(t===8){r.bin();return;}if(t===9||t===10){readList(r,(r,et)=>skip(r,et));return;}if(t===11){const h=r.u8();let size=h>>4,kt=h&15,vt=r.u8();if(size===15)size=Number(r.varint());for(let i=0;i<size;i++){skip(r,kt);skip(r,vt);}return;}if(t===12){readStruct(r,(fid,t,r)=>skip(r,t));return;}throw Error('skip '+t)}
