+
+function mean(values, mask = null) {
+  let sum = 0;
+  let n = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (mask && !mask[i]) continue;
+    sum += values[i];
+    n += 1;
+  }
+  return sum / n;
+}
+
+function sampleVariance(values, mask = null, knownMean = null) {
+  const m = knownMean ?? mean(values, mask);
+  let ss = 0;
+  let n = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (mask && !mask[i]) continue;
+    const d = values[i] - m;
+    ss += d * d;
+    n += 1;
+  }
+  return ss / Math.max(1, n - 1);
+}
+
+function splitStats(values, mask) {
+  let n1 = 0;
+  let n0 = 0;
+  let sum1 = 0;
+  let sum0 = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (mask[i]) {
+      n1 += 1;
+      sum1 += values[i];
+    } else {
+      n0 += 1;
+      sum0 += values[i];
+    }
+  }
+  const mean1 = sum1 / n1;
+  const mean0 = sum0 / n0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (mask[i]) {
+      const d = values[i] - mean1;
+      ss1 += d * d;
+    } else {
+      const d = values[i] - mean0;
+      ss0 += d * d;
+    }
+  }
+  const v1 = ss1 / Math.max(1, n1 - 1);
+  const v0 = ss0 / Math.max(1, n0 - 1);
+  const effect = mean1 - mean0;
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = effect / se;
+  const p = twoSidedNormalP(z);
+  return { n1, n0, mean1, mean0, effect, se, z, p };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y =
+    1 -
+    (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) *
+      t *
+      Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedNormalP(z) {
+  const az = Math.abs(z);
+  if (!Number.isFinite(az)) return 0;
+  if (az > 37) return 0;
+  return Math.max(0, 2 * (1 - normalCdf(az)));
+}
+
+function pearson(x, y, mask = null) {
+  let n = 0;
+  let sx = 0;
+  let sy = 0;
+  for (let i = 0; i < x.length; i++) {
+    if (mask && !mask[i]) continue;
+    sx += x[i];
+    sy += y[i];
+    n += 1;
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0;
+  let syy = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    if (mask && !mask[i]) continue;
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    syy += dy * dy;
+    sxy += dx * dy;
+  }
+  const r = sxy / Math.sqrt(sxx * syy);
+  const slope = sxy / sxx;
+  const z = r * Math.sqrt(Math.max(1, n - 3));
+  return { n, r, slope, p: twoSidedNormalP(z), meanX: mx, meanY: my };
+}
+
+function ols(y, predictors) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...predictors.map((pred) => pred[i])];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, i) => s + v * xty[i], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < predictors.length; j++) pred += beta[j + 1] * predictors[j][i];
+    const resid = y[i] - pred;
+    rss += resid * resid;
+  }
+  const sigma2 = rss / Math.max(1, n - p);
+  const se = beta.map((_, i) => Math.sqrt(Math.max(0, sigma2 * inv[i][i])));
+  const z = beta.map((b, i) => b / se[i]);
+  const pValues = z.map(twoSidedNormalP);
+  return { beta, se, z, pValues, rss, df: n - p };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => [
+    ...row.map((v) => Number(v)),
+    ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0)),
+  ]);
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    }
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error("Singular matrix in OLS");
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const scale = aug[col][col];
+    for (let c = 0; c < 2 * n; c++) aug[col][c] /= scale;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = aug[r][col];
+      for (let c = 0; c < 2 * n; c++) aug[r][c] -= factor * aug[col][c];
