+function snappyDecompress(input) {
+  let i = 0;
+  function readVarint() {
+    let result = 0;
+    let shift = 0;
+    while (true) {
+      const b = input[i++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return result;
+      shift += 7;
+    }
+  }
+
+  const outputLength = readVarint();
+  const output = Buffer.alloc(outputLength);
+  let o = 0;
+  while (i < input.length) {
+    const tag = input[i++];
+    const kind = tag & 3;
+    if (kind === 0) {
+      let length = tag >> 2;
+      if (length < 60) {
+        length += 1;
+      } else {
+        const bytes = length - 59;
+        length = 0;
+        for (let k = 0; k < bytes; k++) length |= input[i++] << (8 * k);
+        length += 1;
+      }
+      input.copy(output, o, i, i + length);
+      i += length;
+      o += length;
+    } else {
+      let length;
+      let offset;
+      if (kind === 1) {
+        length = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[i++];
+      } else if (kind === 2) {
+        length = (tag >> 2) + 1;
+        offset = input[i] | (input[i + 1] << 8);
+        i += 2;
+      } else {
+        length = (tag >> 2) + 1;
+        offset =
+          (input[i] |
+            (input[i + 1] << 8) |
+            (input[i + 2] << 16) |
+            (input[i + 3] << 24)) >>>
+          0;
+        i += 4;
+      }
+      for (let k = 0; k < length; k++) output[o + k] = output[o - offset + k];
+      o += length;
+    }
+  }
+  if (o !== outputLength) {
+    throw new Error(`Snappy length mismatch: decoded ${o}, expected ${outputLength}`);
+  }
+  return output;
+}
+
+class CompactProtocol {
+  constructor(buffer, offset = 0) {
+    this.b = buffer;
+    this.i = offset;
+    this.fieldStack = [0];
+  }
+
+  readByte() {
+    return this.b[this.i++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const value = this.readByte();
+      result |= BigInt(value & 0x7f) << shift;
+      if ((value & 0x80) === 0) return result;
+      shift += 7n;
+    }
+  }
+
+  zigZag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  readI32() {
+    return this.zigZag(this.readVarint());
+  }
+
+  readI64() {
+    return this.zigZag(this.readVarint());
+  }
+
+  readDouble() {
+    const value = this.b.readDoubleLE(this.i);
+    this.i += 8;
+    return value;
+  }
+
+  readBinary() {
+    const length = Number(this.readVarint());
+    const out = this.b.subarray(this.i, this.i + length);
+    this.i += length;
+    return out;
+  }
