+        out.push(value >>> 0);
+      }
+      offset += Math.ceil((valueCount * bitWidthValue) / 8);
+    }
+  }
+  return { values: out, offset };
+}
+
+function readColumn(buffer, column, schemaElement) {
+  const meta = column.meta_data;
+  const chunkEnd = (meta.dictionary_page_offset ?? meta.data_page_offset) + meta.total_compressed_size;
+  let position = meta.dictionary_page_offset ?? meta.data_page_offset;
+  let dictionary = null;
+  const values = [];
+  while (position < chunkEnd) {
+    const header = readPageHeader(buffer, position);
+    const bodyStart = header.header_end;
+    const bodyEnd = bodyStart + header.compressed_page_size;
+    const page = decompressPage(meta.codec, buffer.subarray(bodyStart, bodyEnd));
+    position = bodyEnd;
+
+    if (header.type === 2) {
+      dictionary = decodePlainDictionary(meta.type, page, header.dictionary_page_header.num_values);
+      continue;
+    }
+
+    if (header.type !== 0) throw new Error(`Unsupported page type ${header.type} in ${meta.path[0]}`);
+    if (!dictionary) throw new Error(`Missing dictionary for ${meta.path[0]}`);
+
+    const n = header.data_page_header.num_values;
+    let offset = 0;
+    const maxDefinitionLevel = schemaElement.repetition_type === 0 ? 0 : 1;
+    if (maxDefinitionLevel > 0) {
+      const definitionWidth = bitWidth(maxDefinitionLevel);
+      const decoded = decodeRleBitpacked(page, offset, definitionWidth, n, true);
+      offset = decoded.offset;
+    }
+    const idWidth = page[offset++];
+    const decodedIds = decodeRleBitpacked(page, offset, idWidth, n, false).values;
+    for (const id of decodedIds) values.push(dictionary[id]);
+  }
+  if (values.length !== meta.num_values) {
+    throw new Error(`Column ${meta.path[0]} decoded ${values.length}, expected ${meta.num_values}`);
+  }
+  return values;
+}
+
+function readParquet(path) {
+  const buffer = fs.readFileSync(path);
+  const metadata = readMetadata(buffer);
+  if (metadata.row_groups.length !== 1) throw new Error("Only one row group is supported by this task reader");
+  const schemaByName = new Map(metadata.schema.slice(1).map((s) => [s.name, s]));
+  const columns = {};
+  for (const column of metadata.row_groups[0].columns) {
+    const name = column.meta_data.path[0];
+    columns[name] = readColumn(buffer, column, schemaByName.get(name));
+  }
+  return { metadata, columns };
+}
+
+function mean(values, mask = null) {
+  let sum = 0;
+  let n = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (mask && !mask[i]) continue;
+    sum += values[i];
+    n += 1;
+  }
+  return sum / n;
+}
+
+function sampleVariance(values, mask = null, knownMean = null) {
+  const m = knownMean ?? mean(values, mask);
+  let ss = 0;
+  let n = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (mask && !mask[i]) continue;
+    const d = values[i] - m;
+    ss += d * d;
+    n += 1;
+  }
+  return ss / Math.max(1, n - 1);
+}
+
+function splitStats(values, mask) {
+  let n1 = 0;
+  let n0 = 0;
+  let sum1 = 0;
+  let sum0 = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (mask[i]) {
+      n1 += 1;
+      sum1 += values[i];
+    } else {
+      n0 += 1;
+      sum0 += values[i];
+    }
+  }
+  const mean1 = sum1 / n1;
+  const mean0 = sum0 / n0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < values.length; i++) {
+    if (mask[i]) {
+      const d = values[i] - mean1;
+      ss1 += d * d;
+    } else {
+      const d = values[i] - mean0;
+      ss0 += d * d;
+    }
+  }
+  const v1 = ss1 / Math.max(1, n1 - 1);
+  const v0 = ss0 / Math.max(1, n0 - 1);
+  const effect = mean1 - mean0;
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = effect / se;
+  const p = twoSidedNormalP(z);
+  return { n1, n0, mean1, mean0, effect, se, z, p };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y =
+    1 -
+    (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) *
+      t *
+      Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedNormalP(z) {
+  const az = Math.abs(z);
+  if (!Number.isFinite(az)) return 0;
+  if (az > 37) return 0;
+  return Math.max(0, 2 * (1 - normalCdf(az)));
+}
+
+function pearson(x, y, mask = null) {
+  let n = 0;
+  let sx = 0;
+  let sy = 0;
+  for (let i = 0; i < x.length; i++) {
+    if (mask && !mask[i]) continue;
+    sx += x[i];
+    sy += y[i];
+    n += 1;
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0;
+  let syy = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    if (mask && !mask[i]) continue;
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    syy += dy * dy;
+    sxy += dx * dy;
+  }
+  const r = sxy / Math.sqrt(sxx * syy);
+  const slope = sxy / sxx;
+  const z = r * Math.sqrt(Math.max(1, n - 3));
+  return { n, r, slope, p: twoSidedNormalP(z), meanX: mx, meanY: my };
+}
+
+function ols(y, predictors) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...predictors.map((pred) => pred[i])];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, i) => s + v * xty[i], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < predictors.length; j++) pred += beta[j + 1] * predictors[j][i];
+    const resid = y[i] - pred;
+    rss += resid * resid;
+  }
+  const sigma2 = rss / Math.max(1, n - p);
+  const se = beta.map((_, i) => Math.sqrt(Math.max(0, sigma2 * inv[i][i])));
+  const z = beta.map((b, i) => b / se[i]);
+  const pValues = z.map(twoSidedNormalP);
+  return { beta, se, z, pValues, rss, df: n - p };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => [
+    ...row.map((v) => Number(v)),
+    ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0)),
+  ]);
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    }
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error("Singular matrix in OLS");
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const scale = aug[col][col];
+    for (let c = 0; c < 2 * n; c++) aug[col][c] /= scale;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = aug[r][col];
+      for (let c = 0; c < 2 * n; c++) aug[r][c] -= factor * aug[col][c];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function quantile(values, q) {
+  const sorted = [...values].sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] + (sorted[hi] - sorted[lo]) * (pos - lo);
+}
+
+function unique(values) {
+  return [...new Set(values)];
+}
+
+function maskFromPredicate(columns, predicate) {
+  const v = columns[predicate.column];
+  if (predicate.kind === "eq") return v.map((x) => x === predicate.value);
+  if (predicate.kind === "neq") return v.map((x) => x !== predicate.value);
+  if (predicate.kind === "ge") return v.map((x) => x >= predicate.value);
+  if (predicate.kind === "le") return v.map((x) => x <= predicate.value);
+  throw new Error(`Unknown predicate kind ${predicate.kind}`);
+}
+
+function andMasks(a, b) {
+  return a.map((v, i) => v && b[i]);
+}
+
+function predLabel(predicate) {
+  if (predicate.kind === "eq") return `${predicate.column} == ${JSON.stringify(predicate.value)}`;
+  if (predicate.kind === "neq") return `${predicate.column} != ${JSON.stringify(predicate.value)}`;
+  if (predicate.kind === "ge") return `${predicate.column} >= ${round(predicate.value, 4)}`;
+  if (predicate.kind === "le") return `${predicate.column} <= ${round(predicate.value, 4)}`;
+  return `${predicate.column} ${predicate.kind} ${predicate.value}`;
+}
+
+function round(x, digits = 6) {
+  if (!Number.isFinite(x)) return x;
+  return Number(x.toFixed(digits));
+}
+
+function formatP(p) {
+  if (p === 0) return "p<1e-300";
+  if (p < 1e-4) return `p=${p.toExponential(2)}`;
+  return `p=${p.toPrecision(3)}`;
+}
+
+function buildPredicates(columns) {
+  const categorical = ["lineage", "lineage_subtype", "culture_type", "screen_batch"];
+  const binary = [
+    "kras_mutation",
+    "braf_v600e",
+    "egfr_amplification",
+    "erbb2_amplification",
+    "pik3ca_mutation",
+    "apc_mutation",
+    "smad4_loss",
+    "nf1_loss",
+    "rb1_loss",
+    "myc_amplification",
+    "cdkn2a_loss",
+    "pten_loss",
+    "stk11_loss",
+    "brca2_loss",
+    "msi_high",
+  ];
+  const continuous = [
+    "media_serum_pct",
+    "cas9_activity_score",
+    "growth_rate_doublings_per_day",
+    "ploidy",
+    "aneuploidy_score",
+    "mutation_burden",
+    "wnt_activity_score",
+    "emt_score",
+    "stemness_score",
+    "ifn_gamma_signature",
+    "hypoxia_score",
+    "copy_number_8q24",
+    "copy_number_9p21",
+    "rnaseq_MYC_log2_tpm",
+    "rnaseq_AXL_log2_tpm",
+    "rnaseq_SLFN11_log2_tpm",
+    "rnaseq_ASCL2_log2_tpm",
+  ];
+
+  const predicates = [];
+  for (const col of categorical) {
+    for (const value of unique(columns[col])) predicates.push({ column: col, kind: "eq", value });
+  }
+  for (const col of binary) predicates.push({ column: col, kind: "eq", value: 1 });
+  for (const col of continuous) {
+    predicates.push({ column: col, kind: "ge", value: quantile(columns[col], 0.75), tail: "high" });
+    predicates.push({ column: col, kind: "le", value: quantile(columns[col], 0.25), tail: "low" });
+  }
+  return predicates;
+}
+
+function screenPredicates(columns, outcome, predicates) {
+  const y = columns[outcome];
+  const results = [];
+  for (const predicate of predicates) {
+    const mask = maskFromPredicate(columns, predicate);
+    const n = mask.reduce((s, v) => s + (v ? 1 : 0), 0);
+    if (n < 100 || n > y.length - 100) continue;
+    const stats = splitStats(y, mask);
+    results.push({ outcome, predicates: [predicate], ...stats });
+  }
+  results.sort((a, b) => a.effect - b.effect);
+  return results;
+}
+
+function screenPairs(columns, outcome, predicates) {
+  const y = columns[outcome];
+  const masks = predicates.map((p) => maskFromPredicate(columns, p));
+  const results = [];
+  for (let i = 0; i < predicates.length; i++) {
+    for (let j = i + 1; j < predicates.length; j++) {
+      if (predicates[i].column === predicates[j].column) continue;
+      const mask = andMasks(masks[i], masks[j]);
+      const n = mask.reduce((s, v) => s + (v ? 1 : 0), 0);
+      if (n < 100 || n > y.length - 100) continue;
+      const stats = splitStats(y, mask);
+      results.push({ outcome, predicates: [predicates[i], predicates[j]], ...stats });
+    }
+  }
+  results.sort((a, b) => a.effect - b.effect);
+  return results;
+}
+
+function topCorrelations(columns, outcome, features) {
+  const y = columns[outcome];
+  return features
+    .map((feature) => ({ outcome, feature, ...pearson(columns[feature], y) }))
+    .sort((a, b) => Math.abs(b.r) - Math.abs(a.r));
+}
+
+function analyze() {
+  const { metadata, columns } = readParquet(DATASET);
+  const outcomes = Object.keys(columns).filter((c) => c.startsWith("dependency_"));
+  const continuous = [
+    "media_serum_pct",
+    "cas9_activity_score",
+    "growth_rate_doublings_per_day",
+    "ploidy",
+    "aneuploidy_score",
+    "mutation_burden",
+    "wnt_activity_score",
+    "emt_score",
+    "stemness_score",
+    "ifn_gamma_signature",
+    "hypoxia_score",
+    "copy_number_8q24",
+    "copy_number_9p21",
+    "rnaseq_MYC_log2_tpm",
+    "rnaseq_AXL_log2_tpm",
+    "rnaseq_SLFN11_log2_tpm",
+    "rnaseq_ASCL2_log2_tpm",
+  ];
+  const binary = [
+    "kras_mutation",
+    "braf_v600e",
+    "egfr_amplification",
+    "erbb2_amplification",
+    "pik3ca_mutation",
+    "apc_mutation",
+    "smad4_loss",
+    "nf1_loss",
+    "rb1_loss",
+    "myc_amplification",
+    "cdkn2a_loss",
+    "pten_loss",
+    "stk11_loss",
+    "brca2_loss",
+    "msi_high",
+  ];
+  const predicates = buildPredicates(columns);
+
+  console.log(`decoded rows=${metadata.num_rows}, columns=${Object.keys(columns).length}`);
+  console.log("outcome summaries");
+  for (const outcome of outcomes) {
+    const y = columns[outcome];
+    console.log(
+      outcome,
+      `mean=${round(mean(y), 4)}`,
+      `sd=${round(Math.sqrt(sampleVariance(y)), 4)}`,
+      `min=${round(Math.min(...y), 4)}`,
+      `max=${round(Math.max(...y), 4)}`
+    );
+  }
+
+  console.log("\ncanonical oncogene tests");
+  const canonical = [
+    ["dependency_BRAF", "braf_v600e"],
+    ["dependency_EGFR", "egfr_amplification"],
+    ["dependency_ERBB2", "erbb2_amplification"],
+    ["dependency_KRAS", "kras_mutation"],
+  ];
+  for (const [outcome, feature] of canonical) {
+    const stats = splitStats(columns[outcome], columns[feature].map((v) => v === 1));
+    console.log(outcome, feature, JSON.stringify({
+      n1: stats.n1,
+      mean1: round(stats.mean1, 4),
+      mean0: round(stats.mean0, 4),
+      effect: round(stats.effect, 4),
+      z: round(stats.z, 2),
+      p: stats.p
+    }));
+  }
+
+  console.log("\nmain binary screens strongest negative");
+  for (const outcome of outcomes) {
+    const results = binary
+      .map((feature) => ({ feature, ...splitStats(columns[outcome], columns[feature].map((v) => v === 1)) }))
+      .sort((a, b) => a.effect - b.effect)
+      .slice(0, 5);
+    console.log(outcome, results.map((r) => `${r.feature}:effect=${round(r.effect,4)},n=${r.n1},means=${round(r.mean1,4)}/${round(r.mean0,4)},${formatP(r.p)}`).join(" | "));
+  }
+
+  console.log("\ncontinuous correlations strongest");
+  for (const outcome of outcomes) {
+    const results = topCorrelations(columns, outcome, continuous).slice(0, 6);
+    console.log(outcome, results.map((r) => `${r.feature}:r=${round(r.r,3)},slope=${round(r.slope,4)},${formatP(r.p)}`).join(" | "));
+  }
+
+  console.log("\nsingle-predicate dependency heterogeneity search");
+  const singles = {};
+  for (const outcome of outcomes) {
+    singles[outcome] = screenPredicates(columns, outcome, predicates).slice(0, 8);
+    console.log(outcome);
+    for (const r of singles[outcome]) {
+      console.log("  ", r.predicates.map(predLabel).join(" AND "), `n=${r.n1}`, `mean=${round(r.mean1,4)} vs ${round(r.mean0,4)}`, `effect=${round(r.effect,4)}`, formatP(r.p));
+    }
+  }
+
+  console.log("\npair-predicate dependency heterogeneity search");
+  const pairs = {};
+  for (const outcome of outcomes) {
+    pairs[outcome] = screenPairs(columns, outcome, predicates).slice(0, 10);
+    console.log(outcome);
+    for (const r of pairs[outcome]) {
+      console.log("  ", r.predicates.map(predLabel).join(" AND "), `n=${r.n1}`, `mean=${round(r.mean1,4)} vs ${round(r.mean0,4)}`, `effect=${round(r.effect,4)}`, formatP(r.p));
+    }
+  }
+
+  function subgroupStats(outcome, predList) {
+    let mask = Array(columns[outcome].length).fill(true);
+    for (const p of predList) mask = andMasks(mask, maskFromPredicate(columns, p));
+    return splitStats(columns[outcome], mask);
+  }
+
+  const checks = {
+    braf_in_braf_mut: subgroupStats("dependency_BRAF", [{ column: "braf_v600e", kind: "eq", value: 1 }]),
+    egfr_in_egfr_amp: subgroupStats("dependency_EGFR", [{ column: "egfr_amplification", kind: "eq", value: 1 }]),
+    erbb2_in_erbb2_amp: subgroupStats("dependency_ERBB2", [{ column: "erbb2_amplification", kind: "eq", value: 1 }]),
+    kras_in_kras_mut: subgroupStats("dependency_KRAS", [{ column: "kras_mutation", kind: "eq", value: 1 }]),
+    rit1_nf1_loss: subgroupStats("dependency_RIT1", [{ column: "nf1_loss", kind: "eq", value: 1 }]),
+    kif18a_aneuploid_high: subgroupStats("dependency_KIF18A", [{ column: "aneuploidy_score", kind: "ge", value: quantile(columns.aneuploidy_score, 0.75) }]),
+    tmed10_colorectal: subgroupStats("dependency_TMED10", [{ column: "lineage", kind: "eq", value: "colorectal" }]),
+    dhx9_slfn11_high: subgroupStats("dependency_DHX9", [{ column: "rnaseq_SLFN11_log2_tpm", kind: "ge", value: quantile(columns.rnaseq_SLFN11_log2_tpm, 0.75) }]),
+    polr2a_cn9p21_low: subgroupStats("dependency_POLR2A", [{ column: "copy_number_9p21", kind: "le", value: quantile(columns.copy_number_9p21, 0.25) }]),
+    rpl11_myc_amp: subgroupStats("dependency_RPL11", [{ column: "myc_amplification", kind: "eq", value: 1 }]),
+  };
+  console.log("\nselected checks json");
+  console.log(JSON.stringify(Object.fromEntries(Object.entries(checks).map(([k, v]) => [k, {
+    n1: v.n1,
+    n0: v.n0,
+    mean1: round(v.mean1, 6),
+    mean0: round(v.mean0, 6),
+    effect: round(v.effect, 6),
+    z: round(v.z, 4),
+    p: v.p
+  }])), null, 2));
+
+  return { columns, outcomes, predicates, singles, pairs };
+}
+
+analyze();
diff --git a/example_data_depmap/tasks/depmap/named/analysis_summary.txt b/example_data_depmap/tasks/depmap/named/analysis_summary.txt
new file mode 100644
index 0000000000000000000000000000000000000000..76b924f3f4cdf43ee10159485a224477bab5f840
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/named/analysis_summary.txt
@@ -0,0 +1,17 @@
+Dataset ds001_depmap contained 50000 cancer cell-line records with 10 CRISPR dependency outcomes. More negative dependency scores indicate stronger dependency after knockout. I decoded the local Parquet bundle and ran Welch-style two-group comparisons, continuous-feature correlation screens, and a systematic dependency-heterogeneity search over lineage, lineage_subtype, culture_type, screen_batch, all binary molecular features, top and bottom quartiles of continuous features, and eligible pairwise subgroup intersections with at least 100 cell lines.
+
+Canonical driver dependencies were strongly supported. BRAF-mutant lines (`braf_v600e == 1`) had much more negative `dependency_BRAF` scores than BRAF-wild-type lines (-0.8047 vs -0.2495; effect -0.5552; p<1e-300). EGFR-amplified lines had more negative `dependency_EGFR` (-0.6010 vs -0.2524; effect -0.3486; p<1e-300). ERBB2-amplified lines had more negative `dependency_ERBB2` (-0.6856 vs -0.2535; effect -0.4321; p<1e-300). KRAS-mutant lines had more negative `dependency_KRAS` (-0.5594 vs -0.2520; effect -0.3075; p<1e-300). Lineage analyses were directionally consistent: skin lines were enriched for BRAF dependency, pancreatic and colorectal lines for KRAS dependency, and breast/HER2-enriched or luminal contexts for ERBB2 dependency.
+
+`dependency_RIT1` showed a clear NF1-loss association. Lines with `nf1_loss == 1` had mean `dependency_RIT1` -0.3527 versus -0.2572 in other lines (effect -0.0955; p<1e-300). A refined brain/NF1-loss subgroup was stronger (`lineage == "brain"` and `nf1_loss == 1`: -0.4047 vs -0.2650; effect -0.1397; p=1.22e-13), but the broad NF1-loss effect was the main reproducible signal.
+
+The strongest non-canonical dependency pattern was for `dependency_KIF18A`. Colorectal lines were much more dependent than other lines (-0.7204 vs -0.2524; effect -0.4680; p<1e-300), APC-mutant lines were also more dependent (-0.5447 vs -0.2526; effect -0.2921; p<1e-300), and high-WNT lines (`wnt_activity_score >= 0.819`) were more dependent (-0.4694 vs -0.2526; effect -0.2168; p<1e-300). The best complete subgroup was `lineage == "colorectal"` plus `apc_mutation == 1`, with mean `dependency_KIF18A` -0.9425 versus -0.2527 in all other lines (effect -0.6899; p<1e-300). The related subgroup `lineage == "colorectal"` plus high `wnt_activity_score` was nearly as strong (-0.9288 vs -0.2527; effect -0.6761; p<1e-300). High aneuploidy alone was refuted as an explanation: top-quartile `aneuploidy_score` had almost no effect (-0.3078 vs -0.3065; effect -0.0013; p=0.775).
+
+For `dependency_TMED10`, the evidence was weaker and mostly tied to screen/proliferation covariates. High `growth_rate_doublings_per_day` was associated with slightly more negative scores (-0.2816 vs -0.2447; effect -0.0369; p<1e-300). A colorectal hypothesis was not supported (-0.2576 vs -0.2535; effect -0.0040; p=0.412). A small luminal/STK11-loss subgroup was nominally significant but small and less robust (-0.3078 vs -0.2537; effect -0.0541; p=0.0169).
+
+`dependency_DHX9` was modestly associated with MYC/proliferation rather than SLFN11. High `rnaseq_MYC_log2_tpm` had a negative effect (-0.3551 vs -0.3265; effect -0.0286; p=2e-15), and the high-growth/high-MYC subgroup was stronger (-0.3892 vs -0.3297; effect -0.0595; p<1e-300). Top-quartile `rnaseq_SLFN11_log2_tpm` was refuted (effect +0.0007; p=0.848).
+
+`dependency_POLR2A` was most strongly related to proliferation. High-growth lines had substantially more negative `dependency_POLR2A` scores (-0.4972 vs -0.3928; effect -0.1043; p<1e-300). Adding low `copy_number_9p21` to high growth still defined a negative subgroup (-0.5098 vs -0.4131; effect -0.0967; p<1e-300), but low `copy_number_9p21` alone was not supported (effect -0.0009; p=0.811).
+
+`dependency_RPL11` was linked to MYC/8q24 biology. `myc_amplification == 1` lines had more negative `dependency_RPL11` scores (-0.3614 vs -0.2523; effect -0.1091; p<1e-300), and top-quartile `copy_number_8q24` was similarly strong (-0.3440 vs -0.2452; effect -0.0988; p<1e-300). The strongest refined subgroup combined MYC amplification with high growth rate (-0.3936 vs -0.2632; effect -0.1303; p<1e-300).
+
+Overall, the dataset contains expected oncogene-addiction signals for BRAF, EGFR, ERBB2, KRAS, and RIT1/NF1, plus a pronounced colorectal/APC/WNT-specific KIF18A dependency. TMED10, DHX9, and POLR2A were dominated by smaller growth-rate or MYC/proliferation-associated shifts rather than clean lineage-specific molecular dependencies.
