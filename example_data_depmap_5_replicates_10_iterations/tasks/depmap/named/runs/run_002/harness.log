+const fs = require("fs");
+
+const DATASET = "dataset.parquet";
+
+const Type = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
