+}
+
+function decompressPage(codec, body) {
+  if (codec === 0) return body;
+  if (codec === 1) return snappyDecompress(body);
+  throw new Error(`Unsupported Parquet codec ${codec}`);
+}
+
+function decodePlainDictionary(type, body, count) {
+  const out = new Array(count);
+  let offset = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === Type.BYTE_ARRAY) {
+      const length = body.readInt32LE(offset);
+      offset += 4;
+      out[i] = body.subarray(offset, offset + length).toString("utf8");
+      offset += length;
+    } else if (type === Type.DOUBLE) {
+      out[i] = body.readDoubleLE(offset);
+      offset += 8;
+    } else if (type === Type.INT64) {
+      out[i] = Number(body.readBigInt64LE(offset));
+      offset += 8;
+    } else {
+      throw new Error(`Unsupported dictionary physical type ${type}`);
+    }
+  }
