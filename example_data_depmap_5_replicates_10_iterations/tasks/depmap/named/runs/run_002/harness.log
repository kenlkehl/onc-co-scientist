+  readFieldBegin() {
+    const header = this.readByte();
+    if (header === 0) return { stop: true };
+    const type = header & 0x0f;
+    const delta = header >> 4;
+    let fid;
+    if (delta === 0) fid = this.readI32();
+    else fid = this.fieldStack[this.fieldStack.length - 1] + delta;
+    this.fieldStack[this.fieldStack.length - 1] = fid;
+    return { fid, type };
+  }
+
+  readListBegin() {
+    const header = this.readByte();
+    const elementType = header & 0x0f;
+    let size = header >> 4;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elementType };
+  }
