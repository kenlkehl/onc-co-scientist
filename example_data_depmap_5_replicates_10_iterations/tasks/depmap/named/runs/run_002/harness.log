+  const my = sy / n;
+  let sxx = 0;
+  let syy = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    if (mask && !mask[i]) continue;
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    syy += dy * dy;
+    sxy += dx * dy;
+  }
+  const r = sxy / Math.sqrt(sxx * syy);
+  const slope = sxy / sxx;
+  const z = r * Math.sqrt(Math.max(1, n - 3));
