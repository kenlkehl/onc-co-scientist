const fs=require('fs');
const buf=fs.readFileSync('dataset.parquet');
let footerLen=buf.readInt32LE(buf.length-8); let footerStart=buf.length-8-footerLen; let b=buf.subarray(footerStart, buf.length-8);
class Compact {
  constructor(buf){this.b=buf; this.i=0; this.stack=[0];}
  readByte(){return this.b[this.i++];}
  readVarint(){let shift=0, res=0n; while(true){let x=this.readByte(); res |= BigInt(x&0x7f)<<BigInt(shift); if((x&0x80)===0) break; shift+=7;} return res;}
  zig(n){return Number((n>>1n) "'^ (-(n&1n)));}
  readI32(){return this.zig(this.readVarint());}
  readI64(){let n=this.readVarint(); return Number((n>>1n) ''^ (-(n&1n)));}
  readDouble(){let v=this.b.readDoubleLE(this.i); this.i+=8; return v;}
  readBinary(){let len=Number(this.readVarint()); let s=this.b.subarray(this.i,this.i+len); this.i+=len; return s;}
  readString(){return this.readBinary().toString('"'utf8');}
  readFieldBegin(){let x=this.readByte(); if(x===0) return {stop:true}; let type=x&0x0f, delta=x>>4; let fid; if(delta===0){fid=this.readI32();} else {fid=this.stack[this.stack.length-1]+delta;} this.stack[this.stack.length-1]=fid; return {fid,type};}
  readListBegin(){let x=this.readByte(); let et=x&0x0f, size=x>>4; if(size===15) size=Number(this.readVarint()); return {size, et};}
  enter(){this.stack.push(0);} leave(){this.stack.pop();}
  skip(type){switch(type){case 0: return; case 1: case 2: return; case 3: this.i++; return; case 4: case 5: this.readI32(); return; case 6: this.readI64(); return; case 7: this.i+=8; return; case 8: this.readBinary(); return; case 9: case 10: {let {size,et}=this.readListBegin(); for(let k=0;k<size;k++) this.skip(et); return;} case 11: {let x=this.readByte(); if(x===0) return; let kt=x&0x0f, vt=x>>4; let size=Number(this.readVarint()); for(let k=0;k<size;k++){this.skip(kt); this.skip(vt);} return;} case 12: {this.enter(); while(true){let f=this.readFieldBegin(); if(f.stop) break; this.skip(f.type);} this.leave(); return;} default: throw new Error('skip type '+type+' at '+this.i);}}
}
function readSchemaElement(p){let o={}; p.enter(); while(true){let f=p.readFieldBegin(); if(f.stop) break; switch(f.fid){case 1:o.type=p.readI32();break;case 2:o.type_length=p.readI32();break;case 3:o.repetition_type=p.readI32();break;case 4:o.name=p.readString();break;case 5:o.num_children=p.readI32();break;default:p.skip(f.type);} } p.leave(); return o;}
