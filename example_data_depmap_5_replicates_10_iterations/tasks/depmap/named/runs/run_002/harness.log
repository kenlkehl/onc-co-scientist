+    "media_serum_pct",
+    "cas9_activity_score",
+    "growth_rate_doublings_per_day",
+    "ploidy",
+    "aneuploidy_score",
+    "mutation_burden",
+    "wnt_activity_score",
+    "emt_score",
+    "stemness_score",
+    "ifn_gamma_signature",
+    "hypoxia_score",
+    "copy_number_8q24",
+    "copy_number_9p21",
+    "rnaseq_MYC_log2_tpm",
