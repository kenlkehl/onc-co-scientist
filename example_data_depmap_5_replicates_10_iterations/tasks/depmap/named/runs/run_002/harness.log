+    "erbb2_amplification",
+    "pik3ca_mutation",
+    "apc_mutation",
+    "smad4_loss",
+    "nf1_loss",
+    "rb1_loss",
+    "myc_amplification",
+    "cdkn2a_loss",
+    "pten_loss",
+    "stk11_loss",
+    "brca2_loss",
+    "msi_high",
