+}
+
+function bitWidth(maxValue) {
+  let width = 0;
+  while (maxValue > 0) {
+    width += 1;
+    maxValue >>= 1;
+  }
+  return width;
+}
+
+function readUnsignedLE(buffer, offset, byteWidth) {
+  let value = 0;
+  for (let i = 0; i < byteWidth; i++) value |= buffer[offset + i] << (8 * i);
+  return value >>> 0;
+}
+
+function decodeRleBitpacked(buffer, offset, bitWidthValue, targetCount, hasLengthPrefix) {
+  let end = buffer.length;
+  if (hasLengthPrefix) {
+    const length = buffer.readInt32LE(offset);
+    offset += 4;
+    end = offset + length;
+  }
+  const out = [];
+  const byteWidth = Math.ceil(bitWidthValue / 8);
+  while (offset < end && out.length < targetCount) {
+    let shift = 0;
+    let header = 0;
