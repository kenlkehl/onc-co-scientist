@@ -0,0 +1,455 @@
+{
+  "dataset_id": "ds001_depmap",
+  "model_id": "gpt-5-codex",
+  "harness_id": "codex-direct-depmap-analysis@2026-05-04",
+  "max_iterations": 10,
+  "iterations": [
+    {
+      "index": 1,
+      "proposed_hypotheses": [
+        {
+          "id": "h1",
+          "text": "Cell lines with `braf_v600e == 1` have more negative `dependency_BRAF` scores than cell lines with `braf_v600e == 0`.",
+          "kind": "novel"
+        },
+        {
+          "id": "h2",
+          "text": "Cell lines with `egfr_amplification == 1` have more negative `dependency_EGFR` scores than cell lines with `egfr_amplification == 0`.",
+          "kind": "novel"
+        },
+        {
+          "id": "h3",
+          "text": "The apparent BRAF dependency is enriched in `lineage == \"skin\"` cell lines, which should have more negative `dependency_BRAF` scores than other lineages.",
+          "kind": "refined"
+        }
+      ],
+      "analyses": [
+        {
+          "hypothesis_ids": ["h1"],
+          "method": "Welch two-sample comparison of dependency_BRAF by braf_v600e status.",
+          "result_summary": "`braf_v600e == 1` lines had mean `dependency_BRAF` -0.8047 versus -0.2495 in non-mutant lines (n=5574 vs 44426), a difference of -0.5552.",
+          "p_value": 1e-300,
+          "effect_estimate": -0.555195,
+          "significant": true
+        },
+        {
+          "hypothesis_ids": ["h2"],
+          "method": "Welch two-sample comparison of dependency_EGFR by egfr_amplification status.",
+          "result_summary": "`egfr_amplification == 1` lines had mean `dependency_EGFR` -0.6010 versus -0.2524 in non-amplified lines (n=3880 vs 46120), a difference of -0.3486.",
+          "p_value": 1e-300,
+          "effect_estimate": -0.348638,
+          "significant": true
