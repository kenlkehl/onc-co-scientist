+          "kind": "refined"
+        }
+      ],
+      "analyses": [
+        {
+          "hypothesis_ids": ["h7"],
+          "method": "Welch two-sample comparison of dependency_RIT1 by nf1_loss status.",
+          "result_summary": "`nf1_loss == 1` lines had mean `dependency_RIT1` -0.3527 versus -0.2572 in other lines (n=4560 vs 45440), a difference of -0.0955.",
+          "p_value": 1e-300,
+          "effect_estimate": -0.09552,
+          "significant": true
+        },
+        {
+          "hypothesis_ids": ["h8"],
+          "method": "Pair-predicate heterogeneity screen.",
+          "result_summary": "`lineage == \"brain\"` and `nf1_loss == 1` lines had mean `dependency_RIT1` -0.4047 versus -0.2650 in all other lines (n=329), a difference of -0.1397.",
+          "p_value": 1.22e-13,
+          "effect_estimate": -0.1397,
+          "significant": true
+        }
+      ]
+    },
+    {
+      "index": 4,
+      "proposed_hypotheses": [
+        {
+          "id": "h9",
+          "text": "Cell lines with `lineage == \"colorectal\"` have more negative `dependency_KIF18A` scores than non-colorectal cell lines.",
