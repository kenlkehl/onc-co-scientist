+        return;
+      case 4:
+      case 5:
+        this.readI32();
+        return;
+      case 6:
+        this.readI64();
+        return;
+      case 7:
+        this.i += 8;
+        return;
+      case 8:
+        this.readBinary();
+        return;
+      case 9:
+      case 10: {
+        const list = this.readListBegin();
+        for (let i = 0; i < list.size; i++) this.skip(list.elementType);
+        return;
+      }
+      case 11: {
+        const header = this.readByte();
+        if (header === 0) return;
+        const keyType = header & 0x0f;
+        const valueType = header >> 4;
+        const size = Number(this.readVarint());
+        for (let i = 0; i < size; i++) {
+          this.skip(keyType);
+          this.skip(valueType);
+        }
+        return;
+      }
+      case 12:
+        this.enterStruct();
+        while (true) {
+          const field = this.readFieldBegin();
+          if (field.stop) break;
+          this.skip(field.type);
+        }
+        this.leaveStruct();
+        return;
+      default:
+        throw new Error(`Unknown compact type ${type} at ${this.i}`);
+    }
+  }
+}
+
+function readSchemaElement(p) {
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1:
+        out.type = p.readI32();
+        break;
+      case 2:
+        out.type_length = p.readI32();
+        break;
+      case 3:
+        out.repetition_type = p.readI32();
+        break;
+      case 4:
+        out.name = p.readString();
+        break;
+      case 5:
+        out.num_children = p.readI32();
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  return out;
+}
+
+function readStatistics(p) {
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1:
+        out.max = p.readBinary();
+        break;
+      case 2:
+        out.min = p.readBinary();
+        break;
+      case 3:
+        out.null_count = p.readI64();
+        break;
+      case 4:
+        out.distinct_count = p.readI64();
+        break;
+      case 5:
+        out.max_value = p.readBinary();
+        break;
+      case 6:
+        out.min_value = p.readBinary();
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  return out;
+}
+
+function readColumnMetaData(p) {
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1:
+        out.type = p.readI32();
+        break;
+      case 2: {
+        const list = p.readListBegin();
+        out.encodings = [];
+        for (let i = 0; i < list.size; i++) out.encodings.push(p.readI32());
+        break;
+      }
+      case 3: {
+        const list = p.readListBegin();
+        out.path = [];
+        for (let i = 0; i < list.size; i++) out.path.push(p.readString());
+        break;
+      }
+      case 4:
+        out.codec = p.readI32();
+        break;
+      case 5:
+        out.num_values = p.readI64();
+        break;
+      case 6:
+        out.total_uncompressed_size = p.readI64();
+        break;
+      case 7:
+        out.total_compressed_size = p.readI64();
+        break;
+      case 9:
+        out.data_page_offset = p.readI64();
+        break;
+      case 10:
+        out.index_page_offset = p.readI64();
+        break;
+      case 11:
+        out.dictionary_page_offset = p.readI64();
+        break;
+      case 12:
+        out.statistics = readStatistics(p);
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  return out;
+}
+
+function readColumnChunk(p) {
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1:
+        out.file_path = p.readString();
+        break;
+      case 2:
+        out.file_offset = p.readI64();
+        break;
+      case 3:
+        out.meta_data = readColumnMetaData(p);
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  return out;
+}
+
+function readRowGroup(p) {
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1: {
+        const list = p.readListBegin();
+        out.columns = [];
+        for (let i = 0; i < list.size; i++) out.columns.push(readColumnChunk(p));
+        break;
+      }
+      case 2:
+        out.total_byte_size = p.readI64();
+        break;
+      case 3:
+        out.num_rows = p.readI64();
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  return out;
+}
+
+function readMetadata(buffer) {
+  if (buffer.subarray(0, 4).toString("ascii") !== "PAR1") throw new Error("Not a Parquet file");
+  const footerLength = buffer.readInt32LE(buffer.length - 8);
+  const footerStart = buffer.length - 8 - footerLength;
+  const p = new CompactProtocol(buffer.subarray(footerStart, buffer.length - 8));
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1:
+        out.version = p.readI32();
+        break;
+      case 2: {
+        const list = p.readListBegin();
+        out.schema = [];
+        for (let i = 0; i < list.size; i++) out.schema.push(readSchemaElement(p));
+        break;
+      }
+      case 3:
+        out.num_rows = p.readI64();
+        break;
+      case 4: {
+        const list = p.readListBegin();
+        out.row_groups = [];
+        for (let i = 0; i < list.size; i++) out.row_groups.push(readRowGroup(p));
+        break;
+      }
+      case 6:
+        out.created_by = p.readString();
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  return out;
+}
+
+function readDictionaryPageHeader(p) {
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1:
+        out.num_values = p.readI32();
+        break;
+      case 2:
+        out.encoding = p.readI32();
+        break;
+      case 3:
+        out.is_sorted = field.type === 1;
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  return out;
+}
+
+function readDataPageHeader(p) {
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1:
+        out.num_values = p.readI32();
+        break;
+      case 2:
+        out.encoding = p.readI32();
+        break;
+      case 3:
+        out.definition_level_encoding = p.readI32();
+        break;
+      case 4:
+        out.repetition_level_encoding = p.readI32();
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  return out;
+}
+
+function readPageHeader(buffer, offset) {
+  const p = new CompactProtocol(buffer, offset);
+  const out = {};
+  p.enterStruct();
+  while (true) {
+    const field = p.readFieldBegin();
+    if (field.stop) break;
+    switch (field.fid) {
+      case 1:
+        out.type = p.readI32();
+        break;
+      case 2:
+        out.uncompressed_page_size = p.readI32();
+        break;
+      case 3:
+        out.compressed_page_size = p.readI32();
+        break;
+      case 5:
+        out.data_page_header = readDataPageHeader(p);
+        break;
+      case 7:
+        out.dictionary_page_header = readDictionaryPageHeader(p);
+        break;
+      default:
+        p.skip(field.type);
+    }
+  }
+  p.leaveStruct();
+  out.header_end = p.i;
