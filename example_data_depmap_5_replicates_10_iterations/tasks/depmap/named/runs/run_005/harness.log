function testMask(y,mask,count){const ys=data[y], total=yStats[y];let s1=0,ss1=0;for(let i=0;i<N;i++)if(mask[i]){const v=ys[i];s1+=v;ss1+=v*v;}const n1=count,n0=N-count,s0=total.sum-s1,ss0=total.ss-ss1,m1=s1/n1,m0=s0/n0;const v1=(ss1-s1*s1/n1)/(n1-1),v0=(ss0-s0*s0/n0)/(n0-1);const eff=m1-m0,se=Math.sqrt(v1/n1+v0/n0);const z=eff/se;return{effect:eff,p:normp(z),z,mean_true:m1,mean_false:m0,n_true:n1,n_false:n0};}
