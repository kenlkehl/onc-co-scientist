for(const yname of outcomes){const y=data[yname];const singles=[];for(const pr of preds){const st=diffStat(pr.mask,y);if(st)singles.push({...st,label:pr.label,parts:[pr],base:pr.base});}singles.sort((a,b)=>a.diff-b.diff);const topBase=singles.filter(x=>x.n>=500).slice(0,40);const combos=[];for(let i=0;i<topBase.length;i++)for(let j=i+1;j<topBase.length;j++){if(!compatible(topBase[i].parts[0],topBase[j].parts[0]))continue;const parts=[topBase[i].parts[0],topBase[j].parts[0]];const st=diffStat(combineMasks(parts),y);if(st&&st.n>=250)combos.push({...st,label:parts.map(p=>p.label).join('"' & '),parts});}combos.sort((a,b)=>a.diff-b.diff);const triples=[];for(const cmb of combos.slice(0,20)){for(const s of topBase.slice(0,30)){const pr=s.parts[0];if(cmb.parts.some(p=>p.base===pr.base))continue;const parts=[...cmb.parts,pr];const st=diffStat(combineMasks(parts),y);if(st&&st.n>=150)triples.push({...st,label:parts.map(p=>p.label).join(' & '),parts});}}triples.sort((a,b)=>a.diff-b.diff);report[yname]={single:singles.slice(0,8).map(compact),pair:combos.slice(0,8).map(compact),triple:triples.slice(0,8).map(compact)};}
console.log(JSON.stringify(report,null,2));
