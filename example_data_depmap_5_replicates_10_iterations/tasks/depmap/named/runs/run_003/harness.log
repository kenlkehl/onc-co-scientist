function makeParser(buffer,start=0){let p=start; function rv(){let s=0n,r=0n;while(true){const by=buffer[p++];r|=BigInt(by&127)<<s;if((by&128)===0)break;s+=7n;}return r;} function zz(n){return(n>>1n)"'^(-(n&1n));} function ri(){return Number(zz(rv()));} function bin(){const l=Number(rv());const s=buffer.slice(p,p+l);p+=l;return s;} function list(){const h=buffer[p++];let n=h>>4,t=h&15;if(n===15)n=Number(rv());let a=[];for(let i=0;i<n;i++)a.push(val(t));return a;} function map(){const n=Number(rv());if(n===0)return[];const h=buffer[p++],kt=h>>4,vt=h&15;let a=[];for(let i=0;i<n;i++)a.push([val(kt),val(vt)]);return a;} function str(){let last=0,o={};while(true){const h=buffer[p++],t=h&15;if(t===0)break;const d=h>>4;const fid=d?last+d:ri();last=fid;if(t===1)o[fid]=true;else if(t===2)o[fid]=false;else o[fid]=val(t);}return o;} function val(t){switch(t){case 1:return true;case 2:return false;case 3:return buffer[p++];case 4:case 5:return ri();case 6:return ri();case 7:{const v=buffer.readDoubleLE(p);p+=8;return v;}case 8:return bin();case 9:case 10:return list();case 11:return map();case 12:return str();case 13:{const v=buffer.readFloatLE(p);p+=4;return v;}default:throw Error('"'bad type '+t+' at '+p)}} return{struct:str,pos:()=>p};}
function snappyDecode(input){let ip=0; function readVarint(){let res=0,shift=0;while(true){const c=input[ip++];res|=(c&0x7f)<<shift;if((c&0x80)===0)break;shift+=7;}return res;} const outLen=readVarint(); const out=Buffer.alloc(outLen); let op=0; while(ip<input.length){const token=input[ip++];const tag=token&3;if(tag===0){let len=token>>2;if(len<60)len+=1;else{const bytes=len-59;len=0;for(let i=0;i<bytes;i++)len|=input[ip++]<<(8*i);len+=1;}input.copy(out,op,ip,ip+len);ip+=len;op+=len;}else{let len,off;if(tag===1){len=((token>>2)&7)+4;off=((token&0xe0)<<3)|input[ip++];}else if(tag===2){len=(token>>2)+1;off=input[ip]|(input[ip+1]<<8);ip+=2;}else{len=(token>>2)+1;off=(input[ip]|(input[ip+1]<<8)|(input[ip+2]<<16)|(input[ip+3]<<24))>>>0;ip+=4;}for(let i=0;i<len;i++)out[op+i]=out[op-off+i];op+=len;}}return out;}
