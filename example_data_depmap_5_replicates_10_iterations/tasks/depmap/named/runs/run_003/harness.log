// reuse compact parser over arbitrary buffer
function makeParser(buf, start=0){ let p=start; function readVarint(){let shift=0n,result=0n; while(true){const byte=buf[p++]; result|=BigInt(byte&0x7f)<<shift; if((byte&0x80)===0) break; shift+=7n;} return result;} function zigzag(n){return (n>>1n)"'^(-(n&1n));} function readI(){return Number(zigzag(readVarint()));} function bin(){const len=Number(readVarint()); const s=buf.slice(p,p+len); p+=len; return s.toString('"'utf8');} function dbl(){const v=buf.readDoubleLE(p); p+=8; return v;} function flt(){const v=buf.readFloatLE(p); p+=4; return v;} function list(){const h=buf[p++]; let size=h>>4; const et=h&15; if(size===15) size=Number(readVarint()); const arr=[]; for(let i=0;i<size;i++)arr.push(val(et)); return arr;} function map(){const size=Number(readVarint()); if(size===0)return []; const h=buf[p++]; const kt=h>>4,vt=h&15; const arr=[]; for(let i=0;i<size;i++)arr.push([val(kt),val(vt)]); return arr;} function struct(){let last=0; const o={}; while(true){const h=buf[p++]; const t=h&15; if(t===0)break; const d=h>>4; const fid=d?last+d:readI(); last=fid; if(t===1)o[fid]=true; else if(t===2)o[fid]=false; else o[fid]=val(t);} return o;} function val(t){switch(t){case 1:return true;case 2:return false;case 3:return buf[p++];case 4:case 5:return readI();case 6:return readI();case 7:return dbl();case 8:return bin();case 9:case 10:return list();case 11:return map();case 12:return struct();case 13:return flt();default:throw new Error('bad '+t+' at '+p);}} return {struct, pos:()=>p};}
