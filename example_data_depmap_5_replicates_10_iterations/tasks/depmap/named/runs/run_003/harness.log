function decodeHybrid(data,pos,bitWidth,count){const out=new Int32Array(count);let oi=0;const ref={pos};const bytesPer=Math.ceil(bitWidth/8);const mask=(1<<bitWidth)-1;while(oi<count){const header=readUleb(data,ref);if((header&1)===0){const run=header>>1;let v=0;for(let i=0;i<bytesPer;i++)v|=data[ref.pos++]<<(8*i);const lim=Math.min(count,oi+run);out.fill(v,oi,lim);oi=lim;}else{const groups=header>>1;const vals=groups*8;const start=ref.pos;let bit=0;const lim=Math.min(count-oi,vals);for(let j=0;j<lim;j++){const bi=start+(bit>>3);const sh=bit&7;const word=(data[bi]|(data[bi+1]<<8)|(data[bi+2]<<16)|(data[bi+3]<<24))>>>0;out[oi++]=(word>>>sh)&mask;bit+=bitWidth;}ref.pos=start+Math.ceil(vals*bitWidth/8);}}return out;}
