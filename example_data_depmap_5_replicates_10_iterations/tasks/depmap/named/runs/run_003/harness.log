function pFromZ(z){z=Math.abs(z);if(z>37)return 1e-300;return Math.max(1e-300,erfc(z/Math.SQRT2));}
function diffStat(mask,y){let n1=0,n0=0,s1=0,s0=0,ss1=0,ss0=0;for(let i=0;i<N;i++){const v=y[i];if(mask[i]){n1++;s1+=v;ss1+=v*v;}else{n0++;s0+=v;ss0+=v*v;}}if(n1<30||n0<30)return null;const m1=s1/n1,m0=s0/n0;const v1=(ss1-s1*s1/n1)/(n1-1),v0=(ss0-s0*s0/n0)/(n0-1);const z=(m1-m0)/Math.sqrt(v1/n1+v0/n0);return {n:n1,mean:m1,out:m0,diff:m1-m0,p:pFromZ(z),z};}
function quantile(arr,q){const a=Array.from(arr).sort((x,y)=>x-y);const pos=(a.length-1)*q;const lo=Math.floor(pos),hi=Math.ceil(pos);return lo===hi?a[lo]:a[lo]*(hi-pos)+a[hi]*(pos-lo);}
const preds=[];for(const c of binary){const arr=data[c];let m1=new Uint8Array(N),m0=new Uint8Array(N);for(let i=0;i<N;i++){if(arr[i]===1)m1[i]=1;else m0[i]=1;}preds.push({label:"'`${c}=1`,mask:m1,base:c});preds.push({label:`${c}=0`,mask:m0,base:c});}
