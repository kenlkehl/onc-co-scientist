function parsePageHeader(r){let x={},last=0,start=r.o;while(true){const f=r.field(last);if(!f)break;last=f.id;switch(f.id){case 1:x.type=r.vi();break;case 2:x.uncompressed_page_size=r.vi();break;case 3:x.compressed_page_size=r.vi();break;case 5:x.data_page_header=parseDPH(r);break;case 7:x.dictionary_page_header=parseDictH(r);break;case 8:x.data_page_header_v2=parseDPH2(r);break;default:r.skip(f.type);}}x.header_size=r.o-start;return x;}
