class R{constructor(buf,off=0,end=buf.length){this.b=buf;this.o=off;this.end=end;}u8(){return this.b[this.o++];}varBig(){let s=0n,r=0n;while(true){const x=this.u8();r|=BigInt(x&0x7f)<<s;if((x&0x80)===0)break;s+=7n;}return r;}vi(){return Number(zig(this.varBig()));}vu(){return Number(this.varBig());}bin(){const n=this.vu();const s=this.b.subarray(this.o,this.o+n);this.o+=n;return s;}str(){return this.bin().toString('"'utf8');}field(last){const h=this.u8();if(h===0)return null;const type=h&15,d=h>>4;const id=d?last+d:this.vi();return{id,type};}listHeader(){const h=this.u8();let n=h>>4,et=h&15;if(n===15)n=this.vu();return{n,et};}skip(type){switch(type){case 1:case 2:return;case 3:this.u8();return;case 4:case 5:case 6:this.vi();return;case 7:this.o+=8;return;case 13:this.o+=4;return;case 8:this.bin();return;case 9:case 10:{const{n,et}=this.listHeader();for(let i=0;i<n;i++)this.skip(et);return;}case 11:{const n=this.vu();if(n===0)return;const kt=this.u8(),vt=this.u8();for(let i=0;i<n;i++){this.skip(kt);this.skip(vt);}return;}case 12:{let last=0;while(true){const f=this.field(last);if("'!f)return;last=f.id;this.skip(f.type);}}default:throw new Error('"'skip '+type);}}}
function parseStats(r){let x={},last=0;while(true){const f=r.field(last);if("'!f)break;last=f.id;r.skip(f.type);}return x;}
function parseDPH(r){let x={},last=0;while(true){const f=r.field(last);if(!f)break;last=f.id;switch(f.id){case 1:x.num_values=r.vi();break;case 2:x.encoding=r.vi();break;case 3:x.definition_level_encoding=r.vi();break;case 4:x.repetition_level_encoding=r.vi();break;default:r.skip(f.type);}}return x;}
function parseDPH2(r){let x={},last=0;while(true){const f=r.field(last);if(!f)break;last=f.id;switch(f.id){case 1:x.num_values=r.vi();break;case 2:x.num_nulls=r.vi();break;case 3:x.num_rows=r.vi();break;case 4:x.encoding=r.vi();break;case 5:x.definition_levels_byte_length=r.vi();break;case 6:x.repetition_levels_byte_length=r.vi();break;case 7:x.is_compressed=(f.type===1);break;default:r.skip(f.type);}}return x;}
