+    const vals = data[f];
+    const uniq = [...new Set(vals)];
+    if (typeof vals[0] === "string") {
+      for (const level of uniq.sort()) {
+        const idx = [];
+        for (let i = 0; i < n; i++) if (vals[i] === level) idx.push(i);
+        if (idx.length >= 100 && idx.length <= n - 100) {
+          predicates.push({
+            feature: f,
+            label: `${f} == ${level}`,
+            text: `\`${f}\` == '${level}'`,
+            idx,
+          });
+        }
+      }
+    } else if (uniq.length <= 10) {
+      for (const level of uniq.sort((a, b) => a - b)) {
+        const idx = [];
+        for (let i = 0; i < n; i++) if (vals[i] === level) idx.push(i);
+        if (idx.length >= 100 && idx.length <= n - 100) {
+          predicates.push({
+            feature: f,
+            label: `${f} == ${level}`,
+            text: `\`${f}\` == ${level}`,
+            idx,
+          });
+        }
+      }
+      if (uniq.length === 2 && uniq.includes(1)) {
+        const idx = [];
+        for (let i = 0; i < n; i++) if (vals[i] === 1) idx.push(i);
+        predicates.push({
+          feature: f,
+          label: `${f} == 1`,
+          text: `\`${f}\` == 1`,
+          idx,
+          duplicateOk: true,
+        });
+      }
+    } else {
+      const sorted = [...vals].sort((a, b) => a - b);
+      const q25 = sorted[Math.floor(0.25 * (n - 1))];
+      const q75 = sorted[Math.floor(0.75 * (n - 1))];
+      for (const [op, thr, side] of [
+        ["<=", q25, "low"],
+        [">=", q75, "high"],
+      ]) {
+        const idx = [];
+        for (let i = 0; i < n; i++) {
+          if (op === "<=" ? vals[i] <= thr : vals[i] >= thr) idx.push(i);
+        }
+        if (idx.length >= 100 && idx.length <= n - 100) {
+          predicates.push({
+            feature: f,
+            label: `${f} ${op} ${thr}`,
+            text: `\`${f}\` ${op} ${thr} (${side} quartile)`,
+            idx,
+          });
+        }
+      }
+    }
+  }
+  const seen = new Set();
+  return predicates.filter((p) => {
+    const key = p.feature + "|" + p.label;
+    if (seen.has(key) && !p.duplicateOk) return false;
+    seen.add(key);
+    return true;
+  });
+}
+
+function intersectSorted(a, b) {
+  const out = [];
+  let i = 0;
+  let j = 0;
+  while (i < a.length && j < b.length) {
+    if (a[i] === b[j]) {
+      out.push(a[i]);
+      i++;
+      j++;
+    } else if (a[i] < b[j]) {
+      i++;
+    } else {
+      j++;
+    }
+  }
+  return out;
+}
+
+function momentsForIdx(y, idx) {
+  let sum = 0;
+  let sumSq = 0;
+  for (const i of idx) {
+    const v = y[i];
+    sum += v;
+    sumSq += v * v;
+  }
+  return { n: idx.length, sum, sumSq };
+}
+
+function subgroupTest(y, total, idx) {
+  const m = momentsForIdx(y, idx);
+  if (m.n < 30 || m.n > total.n - 30) return null;
+  return welchFromMoments(
+    m.n,
+    m.sum,
+    m.sumSq,
+    total.n - m.n,
+    total.sum - m.sum,
+    total.sumSq - m.sumSq,
+  );
+}
+
+function matrixSolve(A, b) {
+  const n = A.length;
+  const M = A.map((row, i) => row.slice().concat([b[i]]));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error("singular matrix");
+    [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let c = i; c <= n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      for (let c = i; c <= n; c++) M[r][c] -= f * M[i][c];
+    }
+  }
+  return M.map((row) => row[n]);
+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const inv = [];
+  for (let i = 0; i < n; i++) {
+    const e = Array(n).fill(0);
+    e[i] = 1;
+    inv.push(matrixSolve(A, e));
+  }
+  const out = Array.from({ length: n }, () => Array(n).fill(0));
+  for (let i = 0; i < n; i++) for (let j = 0; j < n; j++) out[j][i] = inv[i][j];
+  return out;
+}
+
+function ols(y, columns) {
+  const n = y.length;
+  const p = columns.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let ySumSq = 0;
+  for (let i = 0; i < n; i++) {
+    ySumSq += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      const xa = columns[a][i];
+      xty[a] += xa * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += xa * columns[b][i];
+    }
+  }
+  const beta = matrixSolve(xtx, xty);
+  let sse = ySumSq;
+  for (let j = 0; j < p; j++) sse -= beta[j] * xty[j];
+  const sigma2 = Math.max(sse / (n - p), 1e-12);
+  const inv = invertMatrix(xtx);
+  const se = beta.map((_, j) => Math.sqrt(sigma2 * inv[j][j]));
+  return { beta, se };
+}
+
+function zscore(values) {
+  const m = mean(values);
+  const s = Math.sqrt(variance(values));
+  return values.map((v) => (v - m) / s);
+}
+
+function indicator(values, target) {
+  return values.map((v) => (v === target ? 1 : 0));
+}
+
+function main() {
+  const { data, columns, n } = loadData();
+  const features = columns.filter((c) => c.startsWith("feature_"));
+  const outcomes = columns.filter((c) => c.startsWith("dependency_"));
+  const outcomeStats = Object.fromEntries(outcomes.map((y) => [y, columnStats(data[y])]));
+  const predicates = buildPredicates(data, features, n);
+
+  const univariate = {};
+  for (const yName of outcomes) {
+    const y = data[yName];
+    const total = outcomeStats[yName];
+    const rows = [];
+    for (const f of features) {
+      const x = data[f];
+      const uniq = [...new Set(x)];
+      if (typeof x[0] === "number" && uniq.length > 10) {
+        const r = pearson(x, y);
+        rows.push({
+          feature: f,
+          kind: "continuous_slope",
+          predicate: `per 1-unit increase in ${f}`,
+          effect: r.slope,
+          p: r.p,
+          z: r.z,
+          r: r.r,
+        });
+      } else {
+        for (const pred of predicates.filter((p) => p.feature === f)) {
+          const test = subgroupTest(y, total, pred.idx);
+          if (test) {
+            rows.push({
+              feature: f,
+              kind: "group_vs_rest",
+              predicate: pred.label,
+              effect: test.effect,
+              p: test.p,
+              z: test.z,
+              n1: test.n1,
+              m1: test.m1,
+              m0: test.m0,
+            });
+          }
+        }
+      }
+    }
+    rows.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    univariate[yName] = rows.slice(0, 12);
+  }
+
+  const subgroup = {};
+  for (const yName of outcomes) {
+    const y = data[yName];
+    const total = outcomeStats[yName];
+    const candidates = [];
+    for (let i = 0; i < predicates.length; i++) {
+      for (let j = i + 1; j < predicates.length; j++) {
+        if (predicates[i].feature === predicates[j].feature) continue;
+        const idx = intersectSorted(predicates[i].idx, predicates[j].idx);
+        if (idx.length < 100 || idx.length > n - 100) continue;
+        const test = subgroupTest(y, total, idx);
+        if (!test) continue;
+        candidates.push({
+          preds: [predicates[i], predicates[j]],
+          label: `${predicates[i].label} AND ${predicates[j].label}`,
+          text: `${predicates[i].text} and ${predicates[j].text}`,
+          idx,
+          ...test,
+        });
+      }
+    }
+    candidates.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    const seedPairs = candidates.slice(0, 75);
+    const triples = [];
+    for (const seed of seedPairs) {
+      const used = new Set(seed.preds.map((p) => p.feature));
+      for (const p of predicates) {
+        if (used.has(p.feature)) continue;
+        const idx = intersectSorted(seed.idx, p.idx);
+        if (idx.length < 100 || idx.length > n - 100) continue;
+        const test = subgroupTest(y, total, idx);
+        if (!test) continue;
+        triples.push({
+          preds: [...seed.preds, p],
+          label: `${seed.label} AND ${p.label}`,
+          text: `${seed.text} and ${p.text}`,
+          idx,
+          ...test,
+        });
+      }
+    }
+    const all = candidates.concat(triples);
+    all.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    const mostNegative = all.filter((c) => c.effect < 0).slice(0, 10);
+    const mostPositive = all.filter((c) => c.effect > 0).slice(0, 5);
+    subgroup[yName] = {
+      strongest: all.slice(0, 20),
+      strongestPairs: candidates.slice(0, 20),
+      mostNegative,
+      mostPositive,
+    };
+  }
+
+  function findPred(label) {
+    const p = predicates.find((x) => x.label === label);
+    if (!p) throw new Error("missing predicate: " + label);
+    return p;
+  }
+
+  function comboResult(yName, labels) {
+    let idx = findPred(labels[0]).idx;
+    for (const label of labels.slice(1)) idx = intersectSorted(idx, findPred(label).idx);
+    const test = subgroupTest(data[yName], outcomeStats[yName], idx);
+    return {
+      labels,
+      text: labels.join(" AND "),
+      ...test,
+    };
+  }
+
+  const manual = {
+    dependency_KIF18A: [
+      comboResult("dependency_KIF18A", ["feature_011 == colorectal"]),
+      comboResult("dependency_KIF18A", ["feature_035 == 1"]),
+      comboResult("dependency_KIF18A", ["feature_028 >= 0.819"]),
+      comboResult("dependency_KIF18A", ["feature_011 == colorectal", "feature_035 == 1"]),
+      comboResult("dependency_KIF18A", ["feature_011 == colorectal", "feature_028 >= 0.819"]),
+      comboResult("dependency_KIF18A", ["feature_035 == 1", "feature_028 >= 0.819"]),
+      comboResult("dependency_KIF18A", [
+        "feature_011 == colorectal",
+        "feature_035 == 1",
+        "feature_028 >= 0.819",
+      ]),
+    ],
+    dependency_RPL11: [
+      comboResult("dependency_RPL11", ["feature_018 == 1"]),
+      comboResult("dependency_RPL11", ["feature_003 >= 0.428"]),
+      comboResult("dependency_RPL11", ["feature_018 == 1", "feature_003 >= 0.428"]),
+    ],
+  };
+
+  const summaries = {
+    rows: n,
+    features,
+    outcomes,
+    featureLevels: {},
+    outcomeSummary: {},
+    univariate,
+    subgroup: Object.fromEntries(
+      outcomes.map((y) => [
+        y,
+        {
+          strongest: subgroup[y].strongest.map(stripIdx),
+          strongestPairs: subgroup[y].strongestPairs.map(stripIdx),
+          mostNegative: subgroup[y].mostNegative.map(stripIdx),
+          mostPositive: subgroup[y].mostPositive.map(stripIdx),
+        },
+      ]),
+    ),
+    manual,
+    interactions: Object.fromEntries(
+      outcomes.map((y) => [
+        y,
+        subgroup[y].strongestPairs.map((r) => ({
+          terms: r.preds.map((p) => p.label),
+          effect: r.effect,
+          p: r.p,
+          z: r.z,
+          n1: r.n1,
+          m1: r.m1,
+          m0: r.m0,
+        })),
+      ]),
+    ),
+  };
+  for (const f of features) {
+    const vals = data[f];
+    const uniq = [...new Set(vals)];
+    summaries.featureLevels[f] = {
+      unique: uniq.length,
+      examples: uniq.slice(0, 12),
+      mean: typeof vals[0] === "number" ? mean(vals) : null,
+      sd: typeof vals[0] === "number" ? Math.sqrt(variance(vals)) : null,
+    };
+  }
+  for (const y of outcomes) {
+    const vals = data[y];
+    summaries.outcomeSummary[y] = {
+      mean: mean(vals),
+      sd: Math.sqrt(variance(vals)),
+      min: Math.min(...vals),
+      max: Math.max(...vals),
+    };
+  }
+  fs.writeFileSync("analysis_results.json", JSON.stringify(summaries, null, 2));
+
+  console.log("Top univariate signals");
+  for (const y of outcomes) {
+    const top = univariate[y][0];
+    console.log(
+      y,
+      top.predicate,
+      "effect",
+      top.effect.toFixed(4),
+      "z",
+      top.z.toFixed(1),
+      "p",
+      top.p.toExponential(2),
+    );
+  }
+  console.log("\\nTop negative subgroups");
+  for (const y of outcomes) {
+    const top = subgroup[y].mostNegative[0];
+    console.log(
+      y,
+      top.label,
+      "n",
+      top.n1,
+      "mean",
+      top.m1.toFixed(4),
+      "rest",
+      top.m0.toFixed(4),
+      "effect",
+      top.effect.toFixed(4),
+      "z",
+      top.z.toFixed(1),
+      "p",
+      top.p.toExponential(2),
+    );
+  }
+  console.log("\\nTop interactions");
+  for (const y of outcomes) {
+    const top = subgroup[y].strongestPairs[0];
+    console.log(
+      y,
+      top.preds.map((p) => p.label).join(" x "),
+      "pair subgroup",
+      top.effect.toFixed(4),
+      "z",
+      top.z.toFixed(1),
+      "p",
+      top.p.toExponential(2),
+    );
+  }
+}
+
+function stripIdx(row) {
+  const out = { ...row };
+  delete out.idx;
+  if (out.preds) {
+    out.preds = out.preds.map((p) => ({
+      feature: p.feature,
+      label: p.label,
+      text: p.text,
+    }));
+  }
+  return out;
+}
+
+main();
diff --git a/example_data_depmap/tasks/depmap/anonymized/analysis_summary.txt b/example_data_depmap/tasks/depmap/anonymized/analysis_summary.txt
new file mode 100644
index 0000000000000000000000000000000000000000..1af510b535667c3e88d206e4183687b80fda911c
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/analysis_summary.txt
@@ -0,0 +1,13 @@
+I analyzed the 50,000-row CRISPR dependency map using only the local task bundle. More negative dependency scores were treated as stronger dependency. Tests were Welch two-sample comparisons for subgroup hypotheses and univariate slopes for continuous features; p-values are two-sided normal approximations, with extremely small values capped at 1e-300. I also ran a systematic dependency-heterogeneity search over single predicates, all two-feature predicate pairs, and top three-feature subgroup refinements for each dependency outcome.
+
+The clearest main-effect dependencies were straightforward. `dependency_BRAF` was much more negative in `feature_009` == 1 lines (-0.805 vs -0.250; effect -0.555; p <= 1e-300). `dependency_EGFR` was more negative in `feature_022` == 1 lines (-0.601 vs -0.252; effect -0.349; p <= 1e-300). `dependency_ERBB2` tracked `feature_024` == 1 (-0.686 vs -0.253; effect -0.432; p <= 1e-300), and `dependency_KRAS` tracked `feature_014` == 1 (-0.559 vs -0.252; effect -0.308; p <= 1e-300). The pairwise heterogeneity search found subgroups such as each driver-positive group with `feature_021` == 0, but these did not materially improve the effect beyond the driver feature itself.
+
+`dependency_RIT1` showed a weaker but significant signal: `feature_027` == 1 lines averaged -0.353 versus -0.257 in other lines (effect -0.096; p=2.03e-70). The best pair subgroup, `feature_027` == 1 with `feature_022` == 0, had a similar effect (-0.098; p=2.82e-69), so I interpret the RIT1 result mainly as a `feature_027` association with only modest heterogeneity.
+
+Several outcomes shared a continuous `feature_016` pattern. Higher `feature_016` predicted more negative `dependency_POLR2A` most strongly (slope -0.3048 per unit; p <= 1e-300), with weaker but significant slopes for `dependency_TMED10` (-0.1012; p=1.11e-38) and `dependency_DHX9` (-0.1086; p=2.73e-44). The heterogeneity screen refined these into high-`feature_016` subgroups: `feature_016` >= 0.964 and `feature_027` == 0 for POLR2A (effect -0.105; p=3.34e-175), `feature_016` >= 0.964 and `feature_024` == 0 for TMED10 (effect -0.038; p=4.71e-24), and `feature_016` >= 0.964 and `feature_009` == 0 for DHX9 (effect -0.038; p=3.39e-24). These refinements were statistically significant but smaller than the kinase-like driver effects.
+
+`dependency_RPL11` was associated with both high `feature_003` and `feature_018` == 1. The continuous slope for `feature_003` was -0.1015 per unit (p=8.39e-263), while `feature_018` == 1 lines averaged -0.361 versus -0.252 in other lines (effect -0.109; p=7.04e-144). The combined subgroup `feature_018` == 1 and `feature_003` >= 0.428 averaged -0.365 versus -0.252 in other lines (effect -0.112; p=3.53e-148), so the combined subgroup was supported but not dramatically stronger than the two component signals.
+
+The most biologically distinctive multivariable pattern was for `dependency_KIF18A`. Single-feature tests showed stronger dependency in `feature_011` == 'colorectal' lines (effect -0.468), `feature_035` == 1 lines (effect -0.292), and high-`feature_028` lines (effect -0.217), all with p <= 1e-300. Pair refinements were stronger: colorectal plus `feature_035` == 1 had effect -0.690, and colorectal plus high `feature_028` had effect -0.676. The strongest complete subgroup was `feature_011` == 'colorectal', `feature_035` == 1, and `feature_028` >= 0.819: n=3133, mean `dependency_KIF18A` -1.112 versus -0.253 in all other lines, effect -0.859, p <= 1e-300. This supports a genuine dependency-heterogeneity hypothesis rather than a simple main effect alone.
+
+Overall, the supported hypotheses are strong driver-like binary-feature dependencies for BRAF, EGFR, ERBB2, and KRAS; a weaker RIT1 association with `feature_027`; a broad `feature_016` axis affecting POLR2A/TMED10/DHX9; a modest RPL11 subgroup involving `feature_018` and `feature_003`; and a sharply defined KIF18A subgroup requiring colorectal status, `feature_035` == 1, and high `feature_028`. The main refutation from the heterogeneity search is that most non-KIF18A outcomes did not require complex subgroup definitions beyond their primary driver or continuous feature axis.
