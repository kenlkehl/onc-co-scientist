+const fs = require("fs");
+
+const file = fs.readFileSync("dataset.parquet");
+
+function makeCompact(buf, start = 0, end = buf.length) {
+  let p = start;
+  function readByte() {
+    if (p >= end) throw new Error("EOF at " + p);
+    return buf[p++];
+  }
+  function readVarint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const byte = readByte();
+      result |= BigInt(byte & 0x7f) << shift;
