+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset =
+          input[ip] |
+          (input[ip + 1] << 8) |
+          (input[ip + 2] << 16) |
+          (input[ip + 3] << 24);
