+
+function snappyUncompress(input) {
+  let ip = 0;
+  function readVarint() {
+    let shift = 0;
+    let result = 0;
+    while (true) {
+      const b = input[ip++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const outLen = readVarint();
+  const out = Buffer.allocUnsafe(outLen);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const n = len - 59;
+        len = 0;
+        for (let i = 0; i < n; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else {
