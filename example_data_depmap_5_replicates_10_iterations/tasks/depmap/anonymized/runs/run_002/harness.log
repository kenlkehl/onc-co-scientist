+    for (let i = 0; i < size; i++) arr.push(readValue(et));
+    return arr;
+  }
+  function readStruct() {
+    const obj = {};
+    let last = 0;
+    while (true) {
+      const h = readByte();
+      const type = h & 0xf;
+      if (type === 0) break;
+      const mod = h >> 4;
