+
+function stripIdx(row) {
+  const out = { ...row };
+  delete out.idx;
+  if (out.preds) {
+    out.preds = out.preds.map((p) => ({
+      feature: p.feature,
+      label: p.label,
+      text: p.text,
+    }));
+  }
+  return out;
