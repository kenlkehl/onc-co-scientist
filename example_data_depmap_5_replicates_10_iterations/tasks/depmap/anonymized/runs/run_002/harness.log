+    }
+  }
+  if (op !== outLen) throw new Error("snappy len mismatch " + op + " != " + outLen);
+  return out;
+}
+
+function readHybrid(buf, p, count, width, lengthPrefixed = false) {
+  if (width === 0) return { values: Array(count).fill(0), pos: p };
+  let end = buf.length;
+  if (lengthPrefixed) {
+    const len = buf.readUInt32LE(p);
+    p += 4;
+    end = p + len;
+  }
+  const vals = [];
+  function readUVar() {
+    let shift = 0;
+    let res = 0;
+    while (true) {
+      const b = buf[p++];
+      res |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return res;
+  }
+  while (vals.length < count && p < end) {
+    const header = readUVar();
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      let v = 0;
+      const bytes = Math.ceil(width / 8);
+      for (let i = 0; i < bytes; i++) v |= buf[p++] << (8 * i);
+      for (let i = 0; i < runLen && vals.length < count; i++) vals.push(v);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bitBuf = 0;
+      let bits = 0;
+      for (let i = 0; i < total && vals.length < count; i++) {
+        while (bits < width) {
+          bitBuf |= buf[p++] << bits;
+          bits += 8;
+        }
+        const mask = (1 << width) - 1;
+        vals.push(bitBuf & mask);
+        bitBuf >>= width;
+        bits -= width;
+      }
+    }
+  }
+  if (lengthPrefixed) p = end;
+  return { values: vals, pos: p };
+}
+
+function decodePlain(buf, type, n) {
+  let p = 0;
+  const vals = [];
+  for (let i = 0; i < n; i++) {
+    if (type === 5) {
+      vals.push(buf.readDoubleLE(p));
+      p += 8;
+    } else if (type === 2) {
+      vals.push(Number(buf.readBigInt64LE(p)));
+      p += 8;
+    } else if (type === 6) {
+      const len = buf.readInt32LE(p);
+      p += 4;
+      vals.push(buf.subarray(p, p + len).toString());
+      p += len;
+    } else {
+      throw new Error("plain type unsupported " + type);
+    }
+  }
+  return vals;
+}
+
+function readPageHeader(pos) {
+  const c = makeCompact(file, pos, file.length);
+  const h = c.readStruct();
+  return { header: h, pos: c.pos() };
+}
+
+function readColumn(colMeta) {
+  const type = colMeta[1];
+  const codec = colMeta[4];
+  const numValues = colMeta[5];
+  const dataOffset = colMeta[9];
+  const dictOffset = colMeta[11];
+  let pos = dictOffset ?? dataOffset;
+  let dictionary = null;
+  const values = [];
+  while (values.length < numValues) {
+    const hp = readPageHeader(pos);
+    const h = hp.header;
+    pos = hp.pos;
+    const compSize = h[3];
+    const uncompSize = h[2];
+    const pageType = h[1];
+    let payload = file.subarray(pos, pos + compSize);
+    pos += compSize;
+    if (codec === 1) payload = snappyUncompress(payload);
+    else if (codec !== 0) throw new Error("unsupported codec " + codec);
+    if (payload.length !== uncompSize) {
+      throw new Error("uncomp mismatch " + payload.length + " " + uncompSize);
+    }
+    if (pageType === 2) {
+      const dh = h[7];
+      dictionary = decodePlain(payload, type, dh[1]);
+    } else if (pageType === 0) {
+      const dph = h[5];
+      const n = dph[1];
+      let p = 0;
+      const def = readHybrid(payload, p, n, 1, true);
+      p = def.pos;
+      const nonNull = def.values.filter((v) => v === 1).length;
+      if (dph[2] === 8 || dph[2] === 2) {
+        const width = payload[p++];
+        const ids = readHybrid(payload, p, nonNull, width, false).values;
+        for (const id of ids) values.push(dictionary[id]);
+      } else if (dph[2] === 0) {
+        values.push(...decodePlain(payload.subarray(p), type, nonNull));
+      } else {
+        throw new Error("unsupported data encoding " + dph[2]);
+      }
+    } else {
+      throw new Error("unsupported page type " + pageType);
+    }
+  }
+  return values;
+}
+
+function loadData() {
+  const meta = parseMeta();
+  const schema = meta[2].slice(1).map((s) => ({ name: s[4].toString(), type: s[1] }));
+  const cols = meta[4][0][1];
+  const data = {};
+  for (let i = 0; i < schema.length; i++) {
+    const name = schema[i].name;
+    data[name] = readColumn(cols[i][3]);
+    if (data[name].length !== meta[3]) throw new Error("length mismatch " + name);
+  }
+  return { data, columns: schema.map((s) => s.name), n: meta[3] };
+}
+
+function mean(values) {
+  return values.reduce((a, b) => a + b, 0) / values.length;
+}
+
+function variance(values) {
+  const m = mean(values);
+  return values.reduce((a, b) => a + (b - m) * (b - m), 0) / (values.length - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y =
+    1 -
+    (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t * Math.exp(-x * x));
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedPFromZ(z) {
+  z = Math.abs(z);
+  if (!Number.isFinite(z)) return 0;
+  if (z < 8) return Math.max(2 * (1 - normalCdf(z)), 1e-300);
+  const sf =
+    (Math.exp(-0.5 * z * z) / (z * Math.sqrt(2 * Math.PI))) *
+    (1 - 1 / (z * z) + 3 / (z ** 4));
+  return Math.max(2 * sf, 1e-300);
+}
+
+function welchFromMoments(n1, sum1, sumSq1, n0, sum0, sumSq0) {
+  const m1 = sum1 / n1;
+  const m0 = sum0 / n0;
+  const v1 = Math.max((sumSq1 - (sum1 * sum1) / n1) / (n1 - 1), 1e-12);
+  const v0 = Math.max((sumSq0 - (sum0 * sum0) / n0) / (n0 - 1), 1e-12);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: twoSidedPFromZ(z), z, m1, m0, n1, n0 };
+}
+
+function columnStats(values) {
+  const n = values.length;
+  let sum = 0;
+  let sumSq = 0;
+  for (const v of values) {
+    sum += v;
+    sumSq += v * v;
+  }
+  return { n, sum, sumSq, mean: sum / n };
+}
+
+function rank(values) {
+  const sorted = values.map((v, i) => [v, i]).sort((a, b) => a[0] - b[0]);
+  const out = Array(values.length);
+  let i = 0;
+  while (i < sorted.length) {
+    let j = i + 1;
+    while (j < sorted.length && sorted[j][0] === sorted[i][0]) j++;
+    const r = (i + j + 1) / 2;
+    for (let k = i; k < j; k++) out[sorted[k][1]] = r;
+    i = j;
+  }
+  return out;
+}
+
+function pearson(x, y) {
+  const n = x.length;
+  let sx = 0;
+  let sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0;
+  let syy = 0;
+  let sxy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    syy += dy * dy;
+    sxy += dx * dy;
+  }
+  const r = sxy / Math.sqrt(sxx * syy);
+  const slope = sxy / sxx;
+  const se = Math.sqrt(Math.max((syy - slope * sxy) / (n - 2), 1e-12) / sxx);
+  const z = slope / se;
+  return { r, slope, p: twoSidedPFromZ(z), z };
+}
+
+function buildPredicates(data, features, n) {
+  const predicates = [];
+  for (const f of features) {
+    const vals = data[f];
+    const uniq = [...new Set(vals)];
+    if (typeof vals[0] === "string") {
+      for (const level of uniq.sort()) {
+        const idx = [];
+        for (let i = 0; i < n; i++) if (vals[i] === level) idx.push(i);
+        if (idx.length >= 100 && idx.length <= n - 100) {
+          predicates.push({
+            feature: f,
+            label: `${f} == ${level}`,
+            text: `\`${f}\` == '${level}'`,
+            idx,
+          });
+        }
+      }
+    } else if (uniq.length <= 10) {
+      for (const level of uniq.sort((a, b) => a - b)) {
+        const idx = [];
+        for (let i = 0; i < n; i++) if (vals[i] === level) idx.push(i);
+        if (idx.length >= 100 && idx.length <= n - 100) {
+          predicates.push({
+            feature: f,
+            label: `${f} == ${level}`,
+            text: `\`${f}\` == ${level}`,
+            idx,
+          });
+        }
+      }
+      if (uniq.length === 2 && uniq.includes(1)) {
+        const idx = [];
+        for (let i = 0; i < n; i++) if (vals[i] === 1) idx.push(i);
+        predicates.push({
+          feature: f,
+          label: `${f} == 1`,
+          text: `\`${f}\` == 1`,
+          idx,
+          duplicateOk: true,
+        });
+      }
+    } else {
+      const sorted = [...vals].sort((a, b) => a - b);
+      const q25 = sorted[Math.floor(0.25 * (n - 1))];
+      const q75 = sorted[Math.floor(0.75 * (n - 1))];
+      for (const [op, thr, side] of [
+        ["<=", q25, "low"],
+        [">=", q75, "high"],
+      ]) {
+        const idx = [];
+        for (let i = 0; i < n; i++) {
+          if (op === "<=" ? vals[i] <= thr : vals[i] >= thr) idx.push(i);
+        }
+        if (idx.length >= 100 && idx.length <= n - 100) {
+          predicates.push({
+            feature: f,
+            label: `${f} ${op} ${thr}`,
+            text: `\`${f}\` ${op} ${thr} (${side} quartile)`,
+            idx,
+          });
+        }
+      }
+    }
+  }
+  const seen = new Set();
+  return predicates.filter((p) => {
+    const key = p.feature + "|" + p.label;
+    if (seen.has(key) && !p.duplicateOk) return false;
+    seen.add(key);
+    return true;
+  });
+}
+
+function intersectSorted(a, b) {
+  const out = [];
+  let i = 0;
+  let j = 0;
+  while (i < a.length && j < b.length) {
+    if (a[i] === b[j]) {
+      out.push(a[i]);
+      i++;
+      j++;
+    } else if (a[i] < b[j]) {
+      i++;
+    } else {
+      j++;
+    }
+  }
+  return out;
+}
+
+function momentsForIdx(y, idx) {
+  let sum = 0;
+  let sumSq = 0;
+  for (const i of idx) {
+    const v = y[i];
+    sum += v;
+    sumSq += v * v;
+  }
+  return { n: idx.length, sum, sumSq };
+}
+
+function subgroupTest(y, total, idx) {
+  const m = momentsForIdx(y, idx);
+  if (m.n < 30 || m.n > total.n - 30) return null;
+  return welchFromMoments(
+    m.n,
+    m.sum,
+    m.sumSq,
+    total.n - m.n,
+    total.sum - m.sum,
+    total.sumSq - m.sumSq,
+  );
+}
+
+function matrixSolve(A, b) {
+  const n = A.length;
+  const M = A.map((row, i) => row.slice().concat([b[i]]));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error("singular matrix");
+    [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let c = i; c <= n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      for (let c = i; c <= n; c++) M[r][c] -= f * M[i][c];
+    }
+  }
+  return M.map((row) => row[n]);
+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const inv = [];
+  for (let i = 0; i < n; i++) {
+    const e = Array(n).fill(0);
+    e[i] = 1;
+    inv.push(matrixSolve(A, e));
+  }
+  const out = Array.from({ length: n }, () => Array(n).fill(0));
+  for (let i = 0; i < n; i++) for (let j = 0; j < n; j++) out[j][i] = inv[i][j];
+  return out;
+}
+
+function ols(y, columns) {
+  const n = y.length;
+  const p = columns.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let ySumSq = 0;
+  for (let i = 0; i < n; i++) {
+    ySumSq += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      const xa = columns[a][i];
+      xty[a] += xa * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += xa * columns[b][i];
+    }
+  }
+  const beta = matrixSolve(xtx, xty);
+  let sse = ySumSq;
+  for (let j = 0; j < p; j++) sse -= beta[j] * xty[j];
+  const sigma2 = Math.max(sse / (n - p), 1e-12);
+  const inv = invertMatrix(xtx);
+  const se = beta.map((_, j) => Math.sqrt(sigma2 * inv[j][j]));
+  return { beta, se };
+}
+
+function zscore(values) {
+  const m = mean(values);
+  const s = Math.sqrt(variance(values));
+  return values.map((v) => (v - m) / s);
+}
+
+function indicator(values, target) {
+  return values.map((v) => (v === target ? 1 : 0));
+}
+
+function main() {
+  const { data, columns, n } = loadData();
+  const features = columns.filter((c) => c.startsWith("feature_"));
+  const outcomes = columns.filter((c) => c.startsWith("dependency_"));
+  const outcomeStats = Object.fromEntries(outcomes.map((y) => [y, columnStats(data[y])]));
+  const predicates = buildPredicates(data, features, n);
+
+  const univariate = {};
+  for (const yName of outcomes) {
+    const y = data[yName];
+    const total = outcomeStats[yName];
+    const rows = [];
+    for (const f of features) {
+      const x = data[f];
+      const uniq = [...new Set(x)];
+      if (typeof x[0] === "number" && uniq.length > 10) {
+        const r = pearson(x, y);
+        rows.push({
+          feature: f,
+          kind: "continuous_slope",
+          predicate: `per 1-unit increase in ${f}`,
+          effect: r.slope,
+          p: r.p,
+          z: r.z,
+          r: r.r,
+        });
+      } else {
+        for (const pred of predicates.filter((p) => p.feature === f)) {
+          const test = subgroupTest(y, total, pred.idx);
+          if (test) {
+            rows.push({
+              feature: f,
+              kind: "group_vs_rest",
+              predicate: pred.label,
+              effect: test.effect,
+              p: test.p,
+              z: test.z,
+              n1: test.n1,
+              m1: test.m1,
+              m0: test.m0,
+            });
+          }
+        }
+      }
+    }
+    rows.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    univariate[yName] = rows.slice(0, 12);
+  }
+
+  const subgroup = {};
+  for (const yName of outcomes) {
+    const y = data[yName];
+    const total = outcomeStats[yName];
+    const candidates = [];
+    for (let i = 0; i < predicates.length; i++) {
+      for (let j = i + 1; j < predicates.length; j++) {
+        if (predicates[i].feature === predicates[j].feature) continue;
+        const idx = intersectSorted(predicates[i].idx, predicates[j].idx);
+        if (idx.length < 100 || idx.length > n - 100) continue;
+        const test = subgroupTest(y, total, idx);
+        if (!test) continue;
+        candidates.push({
+          preds: [predicates[i], predicates[j]],
+          label: `${predicates[i].label} AND ${predicates[j].label}`,
+          text: `${predicates[i].text} and ${predicates[j].text}`,
+          idx,
+          ...test,
+        });
+      }
+    }
+    candidates.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    const seedPairs = candidates.slice(0, 75);
+    const triples = [];
+    for (const seed of seedPairs) {
+      const used = new Set(seed.preds.map((p) => p.feature));
+      for (const p of predicates) {
+        if (used.has(p.feature)) continue;
+        const idx = intersectSorted(seed.idx, p.idx);
+        if (idx.length < 100 || idx.length > n - 100) continue;
+        const test = subgroupTest(y, total, idx);
+        if (!test) continue;
+        triples.push({
+          preds: [...seed.preds, p],
+          label: `${seed.label} AND ${p.label}`,
+          text: `${seed.text} and ${p.text}`,
+          idx,
+          ...test,
+        });
+      }
+    }
+    const all = candidates.concat(triples);
+    all.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    const mostNegative = all.filter((c) => c.effect < 0).slice(0, 10);
+    const mostPositive = all.filter((c) => c.effect > 0).slice(0, 5);
+    subgroup[yName] = {
+      strongest: all.slice(0, 20),
+      strongestPairs: candidates.slice(0, 20),
+      mostNegative,
+      mostPositive,
+    };
+  }
+
+  function findPred(label) {
+    const p = predicates.find((x) => x.label === label);
+    if (!p) throw new Error("missing predicate: " + label);
+    return p;
+  }
+
+  function comboResult(yName, labels) {
+    let idx = findPred(labels[0]).idx;
+    for (const label of labels.slice(1)) idx = intersectSorted(idx, findPred(label).idx);
+    const test = subgroupTest(data[yName], outcomeStats[yName], idx);
+    return {
+      labels,
+      text: labels.join(" AND "),
+      ...test,
+    };
+  }
+
+  const manual = {
+    dependency_KIF18A: [
+      comboResult("dependency_KIF18A", ["feature_011 == colorectal"]),
+      comboResult("dependency_KIF18A", ["feature_035 == 1"]),
+      comboResult("dependency_KIF18A", ["feature_028 >= 0.819"]),
+      comboResult("dependency_KIF18A", ["feature_011 == colorectal", "feature_035 == 1"]),
+      comboResult("dependency_KIF18A", ["feature_011 == colorectal", "feature_028 >= 0.819"]),
+      comboResult("dependency_KIF18A", ["feature_035 == 1", "feature_028 >= 0.819"]),
+      comboResult("dependency_KIF18A", [
+        "feature_011 == colorectal",
+        "feature_035 == 1",
+        "feature_028 >= 0.819",
+      ]),
+    ],
+    dependency_RPL11: [
+      comboResult("dependency_RPL11", ["feature_018 == 1"]),
+      comboResult("dependency_RPL11", ["feature_003 >= 0.428"]),
+      comboResult("dependency_RPL11", ["feature_018 == 1", "feature_003 >= 0.428"]),
+    ],
+  };
+
+  const summaries = {
+    rows: n,
+    features,
+    outcomes,
+    featureLevels: {},
+    outcomeSummary: {},
+    univariate,
+    subgroup: Object.fromEntries(
+      outcomes.map((y) => [
+        y,
+        {
+          strongest: subgroup[y].strongest.map(stripIdx),
+          strongestPairs: subgroup[y].strongestPairs.map(stripIdx),
+          mostNegative: subgroup[y].mostNegative.map(stripIdx),
+          mostPositive: subgroup[y].mostPositive.map(stripIdx),
+        },
+      ]),
+    ),
+    manual,
+    interactions: Object.fromEntries(
+      outcomes.map((y) => [
+        y,
+        subgroup[y].strongestPairs.map((r) => ({
+          terms: r.preds.map((p) => p.label),
+          effect: r.effect,
+          p: r.p,
+          z: r.z,
+          n1: r.n1,
+          m1: r.m1,
+          m0: r.m0,
+        })),
+      ]),
+    ),
+  };
+  for (const f of features) {
+    const vals = data[f];
+    const uniq = [...new Set(vals)];
+    summaries.featureLevels[f] = {
+      unique: uniq.length,
+      examples: uniq.slice(0, 12),
+      mean: typeof vals[0] === "number" ? mean(vals) : null,
+      sd: typeof vals[0] === "number" ? Math.sqrt(variance(vals)) : null,
+    };
+  }
+  for (const y of outcomes) {
+    const vals = data[y];
+    summaries.outcomeSummary[y] = {
+      mean: mean(vals),
+      sd: Math.sqrt(variance(vals)),
+      min: Math.min(...vals),
+      max: Math.max(...vals),
+    };
+  }
+  fs.writeFileSync("analysis_results.json", JSON.stringify(summaries, null, 2));
+
+  console.log("Top univariate signals");
+  for (const y of outcomes) {
+    const top = univariate[y][0];
+    console.log(
+      y,
+      top.predicate,
+      "effect",
+      top.effect.toFixed(4),
+      "z",
+      top.z.toFixed(1),
+      "p",
+      top.p.toExponential(2),
+    );
+  }
+  console.log("\\nTop negative subgroups");
+  for (const y of outcomes) {
+    const top = subgroup[y].mostNegative[0];
+    console.log(
+      y,
+      top.label,
+      "n",
+      top.n1,
+      "mean",
