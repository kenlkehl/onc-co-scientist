"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
print('\\nfeatures', len(features), features)
print('outcomes', len(outcomes), outcomes)
print('\\nfeature unique counts and means/top values')
for c in features:
    s=df[c]
    nun=s.nunique()
    if nun<=10:
        vc=s.value_counts(normalize=True).sort_index()
        print(c, 'nunique', nun, 'dtype', s.dtype, 'mean', float(s.mean()) if pd.api.types.is_numeric_dtype(s) else 'NA', 'dist', {str(k): round(float(v),4) for k,v in vc.items()})
    else:
        print(c, 'nunique', nun, 'dtype', s.dtype, 'mean', float(s.mean()), 'std', float(s.std()), 'min', float(s.min()), 'max', float(s.max()))
print('\\noutcome summaries')
print(df[outcomes].describe().T.to_string())
print('\\noutcome correlations')
print(df[outcomes].corr().round(3).to_string())
