const fs = require('fs');
const file = fs.readFileSync('dataset.parquet');

function makeCompact(buf, start=0, end=buf.length) {
  let p=start;
  function readByte(){ if(p>=end) throw new Error('EOF at '+p); return buf[p++]; }
  function readVarint(){ let shift=0n, result=0n; while(true){ const byte=readByte(); result |= BigInt(byte & 0x7f) << shift; if((byte & 0x80)===0) break; shift += 7n; } return result; }
  function zigzag(n){ return Number((n >> 1n) "'^ (-(n & 1n))); }
  function readI(){ return zigzag(readVarint()); }
  function readDouble(){ const v=buf.readDoubleLE(p); p+=8; return v; }
  function readBinary(){ const len=Number(readVarint()); const s=buf.subarray(p,p+len); p+=len; return s; }
  function readValue(type){
    switch(type){
      case 1: return true; case 2: return false; case 3: case 4: case 5: return readI(); case 6: return readI(); case 7: return readDouble(); case 8: return readBinary(); case 9: case 10: return readList(); case 12: return readStruct(); default: throw new Error('"'bad compact type '+type+' at '+p);
    }
  }
  function readList(){ const h=readByte(); let size=h>>4; const et=h&0xf; if(size===15) size=Number(readVarint()); const arr=[]; for(let i=0;i<size;i++) arr.push(readValue(et)); return arr; }
  function readStruct(){ const obj={}; let last=0; while(true){ const h=readByte(); const type=h&0xf; if(type===0) break; const mod=h>>4; let fid; if(mod===0) fid=readI(); else fid=last+mod; last=fid; obj[fid]=readValue(type); } return obj; }
  return { readStruct, pos:()=>p };
}
function parseMeta() {
  const metaLen=file.readUInt32LE(file.length-8); const start=file.length-8-metaLen;
  const c=makeCompact(file, start, file.length-8); const meta=c.readStruct();
  return meta;
}
function snappyUncompress(input) {
  let ip=0;
  function readVarint(){ let shift=0, result=0; while(true){ const b=input[ip++]; result |= (b & 0x7f) << shift; if((b&0x80)===0) break; shift += 7; } return result; }
  const outLen=readVarint(); const out=Buffer.allocUnsafe(outLen); let op=0;
  while(ip < input.length) {
    const tag=input[ip++]; const type=tag & 3;
    if(type===0) {
      let len=tag >> 2;
