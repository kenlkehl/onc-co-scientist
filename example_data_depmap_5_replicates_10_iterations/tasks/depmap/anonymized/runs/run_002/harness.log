+  "iterations": [
+    {
+      "index": 1,
+      "proposed_hypotheses": [
+        {
+          "id": "h1",
+          "text": "Cell lines with `feature_009` == 1 have more negative `dependency_BRAF` scores than cell lines with `feature_009` == 0.",
+          "kind": "novel"
+        },
+        {
+          "id": "h2",
+          "text": "Cell lines with `feature_022` == 1 have more negative `dependency_EGFR` scores than cell lines with `feature_022` == 0.",
+          "kind": "novel"
+        }
+      ],
+      "analyses": [
+        {
+          "hypothesis_ids": ["h1"],
+          "code": "Welch two-sample test of dependency_BRAF for feature_009 == 1 versus all other cell lines; effect is subgroup mean minus complement mean.",
+          "result_summary": "`dependency_BRAF` averaged -0.805 in `feature_009` == 1 lines (n=5574) versus -0.250 in other lines; the subgroup was much more BRAF-dependent.",
+          "p_value": 1e-300,
+          "effect_estimate": -0.5552,
+          "significant": true
+        },
+        {
+          "hypothesis_ids": ["h2"],
+          "code": "Welch two-sample test of dependency_EGFR for feature_022 == 1 versus all other cell lines; effect is subgroup mean minus complement mean.",
+          "result_summary": "`dependency_EGFR` averaged -0.601 in `feature_022` == 1 lines (n=3880) versus -0.252 in other lines.",
+          "p_value": 1e-300,
+          "effect_estimate": -0.3486,
+          "significant": true
+        }
+      ]
+    },
+    {
+      "index": 2,
+      "proposed_hypotheses": [
+        {
+          "id": "h3",
+          "text": "Cell lines with `feature_024` == 1 have more negative `dependency_ERBB2` scores than cell lines with `feature_024` == 0.",
+          "kind": "novel"
+        },
+        {
+          "id": "h4",
+          "text": "Cell lines with `feature_014` == 1 have more negative `dependency_KRAS` scores than cell lines with `feature_014` == 0.",
+          "kind": "novel"
+        }
+      ],
+      "analyses": [
+        {
+          "hypothesis_ids": ["h3"],
+          "code": "Welch two-sample test of dependency_ERBB2 for feature_024 == 1 versus all other cell lines.",
+          "result_summary": "`dependency_ERBB2` averaged -0.686 in `feature_024` == 1 lines (n=4890) versus -0.253 in other lines.",
+          "p_value": 1e-300,
+          "effect_estimate": -0.4321,
+          "significant": true
+        },
+        {
+          "hypothesis_ids": ["h4"],
+          "code": "Welch two-sample test of dependency_KRAS for feature_014 == 1 versus all other cell lines.",
+          "result_summary": "`dependency_KRAS` averaged -0.559 in `feature_014` == 1 lines (n=11842) versus -0.252 in other lines.",
+          "p_value": 1e-300,
+          "effect_estimate": -0.3075,
+          "significant": true
+        }
+      ]
+    },
+    {
+      "index": 3,
+      "proposed_hypotheses": [
+        {
+          "id": "h5",
+          "text": "Cell lines with `feature_027` == 1 have more negative `dependency_RIT1` scores than cell lines with `feature_027` == 0.",
+          "kind": "novel"
+        },
+        {
+          "id": "h6",
+          "text": "Increasing `feature_016` is associated with more negative `dependency_RIT1` scores.",
+          "kind": "novel"
+        }
+      ],
+      "analyses": [
+        {
+          "hypothesis_ids": ["h5"],
