+  const interactions = {};
+  const numericFeatureCols = {};
+  const baseFeatureCols = [];
+  for (const f of features) {
+    const vals = data[f];
+    const uniq = [...new Set(vals)];
+    if (typeof vals[0] === "number" && uniq.length > 10) {
+      numericFeatureCols[f] = zscore(vals);
+      baseFeatureCols.push({ feature: f, label: `${f} (z)`, values: numericFeatureCols[f] });
+    } else {
+      for (const pred of predicates.filter((p) => p.feature === f)) {
+        const arr = Array(n).fill(0);
+        for (const i of pred.idx) arr[i] = 1;
+        baseFeatureCols.push({ feature: f, label: pred.label, values: arr });
+      }
+    }
+  }
+  for (const yName of outcomes) {
+    const y = data[yName];
+    const rows = [];
+    for (let i = 0; i < baseFeatureCols.length; i++) {
+      for (let j = i + 1; j < baseFeatureCols.length; j++) {
+        const a = baseFeatureCols[i];
+        const b = baseFeatureCols[j];
+        if (a.feature === b.feature) continue;
+        const intCol = a.values.map((v, k) => v * b.values[k]);
+        try {
+          const fit = ols(y, [Array(n).fill(1), a.values, b.values, intCol]);
+          const beta = fit.beta[3];
+          const se = fit.se[3];
+          const z = beta / se;
+          rows.push({
+            terms: [a.label, b.label],
+            effect: beta,
+            p: twoSidedPFromZ(z),
+            z,
+          });
+        } catch (_) {
+          // Skip aliased terms.
+        }
+      }
+    }
+    rows.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    interactions[yName] = rows.slice(0, 20);
+  }
+
+  const summaries = {
+    rows: n,
+    features,
+    outcomes,
+    featureLevels: {},
+    outcomeSummary: {},
+    univariate,
+    subgroup,
+    interactions,
+  };
+  for (const f of features) {
+    const vals = data[f];
+    const uniq = [...new Set(vals)];
+    summaries.featureLevels[f] = {
+      unique: uniq.length,
+      examples: uniq.slice(0, 12),
+      mean: typeof vals[0] === "number" ? mean(vals) : null,
+      sd: typeof vals[0] === "number" ? Math.sqrt(variance(vals)) : null,
+    };
+  }
+  for (const y of outcomes) {
+    const vals = data[y];
+    summaries.outcomeSummary[y] = {
+      mean: mean(vals),
+      sd: Math.sqrt(variance(vals)),
+      min: Math.min(...vals),
+      max: Math.max(...vals),
+    };
+  }
+  fs.writeFileSync("analysis_results.json", JSON.stringify(summaries, null, 2));
+
+  console.log("Top univariate signals");
+  for (const y of outcomes) {
+    const top = univariate[y][0];
+    console.log(
+      y,
+      top.predicate,
+      "effect",
+      top.effect.toFixed(4),
+      "z",
+      top.z.toFixed(1),
+      "p",
+      top.p.toExponential(2),
+    );
+  }
+  console.log("\\nTop negative subgroups");
+  for (const y of outcomes) {
+    const top = subgroup[y].mostNegative[0];
+    console.log(
+      y,
+      top.label,
+      "n",
+      top.n1,
+      "mean",
+      top.m1.toFixed(4),
+      "rest",
+      top.m0.toFixed(4),
+      "effect",
+      top.effect.toFixed(4),
+      "z",
+      top.z.toFixed(1),
+      "p",
+      top.p.toExponential(2),
+    );
+  }
+  console.log("\\nTop interactions");
+  for (const y of outcomes) {
+    const top = interactions[y][0];
+    console.log(
+      y,
+      top.terms.join(" x "),
+      "interaction",
+      top.effect.toFixed(4),
+      "z",
+      top.z.toFixed(1),
+      "p",
+      top.p.toExponential(2),
+    );
+  }
+}
+
+main();

