+              kind: "group_vs_rest",
+              predicate: pred.label,
+              effect: test.effect,
+              p: test.p,
+              z: test.z,
+              n1: test.n1,
+              m1: test.m1,
+              m0: test.m0,
+            });
+          }
+        }
+      }
+    }
