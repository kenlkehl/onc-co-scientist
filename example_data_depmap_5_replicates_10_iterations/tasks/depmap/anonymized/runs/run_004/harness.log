codex
The local Parquet pages are Snappy-compressed and dictionary-encoded, so I implemented a small in-memory reader in Node for this bundle. The first screen found strong dependency signals for several gene outcomes and a notably stronger KIF18A subgroup; I’m refining the subgroup search with quantile predicates instead of exact continuous values.
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs=require('fs');const b=fs.readFileSync('dataset.parquet');
// Minimal Parquet reader for this local bundle (Thrift compact metadata + Snappy + dictionary data pages).
class P{constructor(buf,off=0){this.b=buf;this.i=off;this.last=0;}byte(){return this.b[this.i++];}varint(){let sh=0,n=0n;while(true){let c=this.byte();if(c===undefined)throw Error('eof');n|=BigInt(c&127)<<BigInt(sh);if("'!(c&128))break;sh+=7;}return n;}zig(n){return Number((n>>1n)''^(-(n&1n)));}vi(){return this.zig(this.varint());}vu(){return Number(this.varint());}str(){let l=this.vu(),s=this.b.slice(this.i,this.i+l).toString('"'utf8');this.i+=l;return s;}field(){let h=this.byte(),t=h&15,d=(h>>4)&15;if(t===0)return null;let id=d===0?this.vi():this.last+d;this.last=id;return{id,type:t};}skip(t){switch(t){case 1:case 2:return;case 3:this.byte();return;case 4:case 5:case 6:this.vi();return;case 7:this.i+=8;return;case 8:this.str();return;case 9:case 10:{let h=this.byte(),sz=(h>>4)&15,et=h&15;if(sz===15)sz=this.vu();for(let j=0;j<sz;j++)this.skip(et);return;}case 11:{let sz=this.vu();if("'!sz)return;let h=this.byte(),kt=(h>>4)&15,vt=h&15;for(let j=0;j<sz;j++){this.skip(kt);this.skip(vt)}return;}case 12:this.readStruct(null);return;default:throw Error('"'skip '+t+' at '+this.i)}}readStruct(fn){let prev=this.last;this.last=0;while(true){let f=this.field();if("'!f)break;if(fn)fn(f,this);else this.skip(f.type)}this.last=prev;}}
function readList(p,fn){let h=p.byte(),sz=(h>>4)&15,et=h&15;if(sz===15)sz=p.vu();let a=[];for(let i=0;i<sz;i++)a.push(fn(p,et));return a}function schemaEl(p){let o={};p.readStruct((f,p)=>{if(f.id===1)o.type=p.vi();else if(f.id===4)o.name=p.str();else if(f.id===5)o.children=p.vi();else p.skip(f.type)});return o}function colMeta(p){let o={};p.readStruct((f,p)=>{switch(f.id){case 1:o.type=p.vi();break;case 3:o.path=readList(p,p=>p.str());break;case 4:o.codec=p.vi();break;case 5:o.num_values=p.vi();break;case 9:o.data=p.vi();break;case 11:o.dict=p.vi();break;default:p.skip(f.type)}});return o}function colChunk(p){let o={};p.readStruct((f,p)=>{if(f.id===3)o.meta=colMeta(p);else p.skip(f.type)});return o}function rowGroup(p){let o={};p.readStruct((f,p)=>{if(f.id===1)o.cols=readList(p,p=>colChunk(p));else if(f.id===3)o.rows=p.vi();else p.skip(f.type)});return o}function dataHeader(p){let o={};p.readStruct((f,p)=>{if(f.id===1)o.num_values=p.vi();else if(f.id===2)o.encoding=p.vi();else if(f.id===3)o.def=p.vi();else if(f.id===4)o.rep=p.vi();else p.skip(f.type)});return o}function dictHeader(p){let o={};p.readStruct((f,p)=>{if(f.id===1)o.num_values=p.vi();else if(f.id===2)o.encoding=p.vi();else if(f.id===3)o.sorted=(f.type===1);else p.skip(f.type)});return o}function pageHeader(off){let p=new P(b,off),o={};p.readStruct((f,p)=>{if(f.id===1)o.type=p.vi();else if(f.id===2)o.un=p.vi();else if(f.id===3)o.comp=p.vi();else if(f.id===5)o.dh=dataHeader(p);else if(f.id===7)o.dict=dictHeader(p);else p.skip(f.type)});o.body=p.i;o.next=p.i+o.comp;return o}function snappy(src){let i=0;function rv(){let sh=0,n=0;while(true){let c=src[i++];n|=(c&127)<<sh;if(!(c&128))break;sh+=7}return n}let len=rv(),out=Buffer.alloc(len),o=0;while(i<src.length){let tag=src[i++],type=tag&3;if(type===0){let l=tag>>2;if(l<60)l++;else{let n=l-59;l=0;for(let j=0;j<n;j++)l|=src[i++]<<(8*j);l++}src.copy(out,o,i,i+l);i+=l;o+=l}else{let l,off;if(type===1){l=((tag>>2)&7)+4;off=((tag&224)<<3)|src[i++]}else if(type===2){l=(tag>>2)+1;off=src[i]|(src[i+1]<<8);i+=2}else{l=(tag>>2)+1;off=(src[i]|(src[i+1]<<8)|(src[i+2]<<16)|(src[i+3]<<24))>>>0;i+=4}for(let j=0;j<l;j++){out[o]=out[o-off];o++}}}return out}function plain(buf,type,n){let a=[],off=0;for(let i=0;i<n;i++){if(type===5){a.push(buf.readDoubleLE(off));off+=8}else if(type===2){a.push(Number(buf.readBigInt64LE(off)));off+=8}else if(type===6){let l=buf.readInt32LE(off);off+=4;a.push(buf.slice(off,off+l).toString('"'utf8'));off+=l}else throw Error('type '+type)}return a}function hybrid(buf,off,bw,n){let vals=[];function vi(){let sh=0,x=0;while(true){let c=buf[off++];x|=(c&127)<<sh;if("'!(c&128))break;sh+=7}return x}while(vals.length<n){let h=vi();if((h&1)===0){let cnt=h>>1,bytes=Math.ceil(bw/8),v=0;for(let j=0;j<bytes;j++)v|=buf[off++]<<(8*j);for(let j=0;j<cnt&&vals.length<n;j++)vals.push(v)}else{let groups=h>>1,total=groups*8,bytes=groups*bw,bit=0;for(let k=0;k<total&&vals.length<n;k++){let v=0;for(let bb=0;bb<bw;bb++){v|=((buf[off+(bit>>3)]>>(bit&7))&1)<<bb;bit++}vals.push(v)}off+=bytes}}return vals}function dataPage(buf,h,dict,type){let pos=0,defLen=buf.readUInt32LE(pos);pos+=4+defLen;if(h.dh.encoding===8){let bw=buf[pos++];return hybrid(buf,pos,bw,h.dh.num_values).map(i=>dict[i])}if(h.dh.encoding===0)return plain(buf.slice(pos),type,h.dh.num_values);throw Error('"'encoding '+h.dh.encoding)}function load(){let fl=b.readUInt32LE(b.length-8),foot=b.slice(b.length-8-fl,b.length-8),p=new P(foot),m={};p.readStruct((f,p)=>{if(f.id===2)m.schema=readList(p,p=>schemaEl(p));else if(f.id===3)m.num_rows=p.vi();else if(f.id===4)m.rgs=readList(p,p=>rowGroup(p));else p.skip(f.type)});let cols=m.schema.slice(1),rg=m.rgs[0],data={};for(let ci=0;ci<cols.length;ci++){let se=cols[ci],cm=rg.cols[ci].meta,dict=[];if(cm.dict"'!==undefined){let h=pageHeader(cm.dict);dict=plain(snappy(b.slice(h.body,h.body+h.comp)),se.type,h.dict.num_values)}let vals=[],off=cm.data;while(vals.length<cm.num_values){let h=pageHeader(off);vals=vals.concat(dataPage(snappy(b.slice(h.body,h.body+h.comp)),h,dict,se.type));off=h.next}data[se.name]=vals}return data}
const data=load(),N=data.cell_line_id.length,features=Object.keys(data).filter(c=>c.startsWith('"'feature_')),outcomes=Object.keys(data).filter(c=>c.startsWith('dependency_'));
function uniq(vals){let m=new Map();for(let v of vals)m.set(v,(m.get(v)||0)+1);return [...m.entries()]}function quant(vals,q){let a=[...vals].sort((a,b)=>a-b);return a[Math.floor(q*(a.length-1))]}function makeMask(vals,fn){let m=new Uint8Array(vals.length),n=0;for(let i=0;i<vals.length;i++)if(fn(vals[i])){m[i]=1;n++}m.n=n;return m}let predicates=[];for(let c of features){let vals=data[c],u=uniq(vals);let isNum=typeof vals[0]==='number';if("'!isNum||u.length<=10){for(let [v,n] of u){if(n>=100&&n<=N-100)predicates.push({name:`${c}=${v}`,col:c,mask:makeMask(vals,x=>x===v)})}}else{for(let [label,q,op] of [['"'<=p10',0.10,'le'],['<=p25',0.25,'le'],['>=p75',0.75,'ge'],['>=p90',0.90,'ge']]){let cut=quant(vals,q);let mask=makeMask(vals,x=>op==='le'?x<=cut:x>=cut);if(mask.n>=100&&mask.n<=N-100)predicates.push({name:"'`${c}${label}(${cut})`,col:c,mask})}}}
let totals={};for(let y of outcomes){let s=0,ss=0;for(let v of data[y]){s+=v;ss+=v*v}totals[y]={s,ss}}
function pnorm(z){z=Math.abs(z);if(z>38)return 0;let t=1/(1+0.3275911*z/Math.SQRT2),x=z/Math.SQRT2;let erf=1-(((((1.061405429*t-1.453152027)*t+1.421413741)*t-0.284496736)*t+0.254829592)*t)*Math.exp(-x*x);return Math.max(0,2*(1-(.5*(1+erf))))}function stat(y,mask){let vals=data[y],n=0,s=0,ss=0;for(let i=0;i<N;i++)if(mask[i]){n++;let v=vals[i];s+=v;ss+=v*v}let n0=N-n,s0=totals[y].s-s,ss0=totals[y].ss-ss,m=s/n,m0=s0/n0,v=(ss-s*s/n)/(n-1),v0=(ss0-s0*s0/n0)/(n0-1),t=(m-m0)/Math.sqrt(v/n+v0/n0);return{n,mean:m,compMean:m0,effect:m-m0,t,p:pnorm(t)}}function intersect(masks){let m=new Uint8Array(N);for(let i=0;i<N;i++){let ok=1;for(let mm of masks)if(!mm[i]){ok=0;break}if(ok)m[i]=1}return m}
console.log('"'N',N,'predicates',predicates.length);let all={};for(let y of outcomes){let singles=predicates.map((p,i)=>({type:'single',pred:p.name,idx:[i],...stat(y,p.mask)})).filter(r=>r.n>=100&&r.n<=N-100).sort((a,b)=>a.effect-b.effect);let topIdx=singles.slice(0,45).map(r=>r.idx[0]);let pairs=[];for(let a=0;a<topIdx.length;a++)for(let c=a+1;c<topIdx.length;c++){let p1=predicates[topIdx[a]],p2=predicates[topIdx[c]];if(p1.col===p2.col)continue;let m=intersect([p1.mask,p2.mask]);let n=0;for(let v of m)n+=v;if(n<150||n>N-150)continue;let r=stat(y,m);pairs.push({type:'pair',pred:"'`${p1.name} & ${p2.name}`,idx:[topIdx[a],topIdx[c]],...r})}pairs.sort((a,b)=>a.effect-b.effect);let triples=[];for(let base of pairs.slice(0,20)){for(let pi of topIdx){if(base.idx.includes(pi))continue;let cols=base.idx.map(i=>predicates[i].col);if(cols.includes(predicates[pi].col))continue;let m=intersect([...base.idx.map(i=>predicates[i].mask),predicates[pi].mask]);let n=0;for(let v of m)n+=v;if(n<150||n>N-150)continue;let r=stat(y,m);triples.push({type:'"'triple',pred:"'`${base.pred} & ${predicates[pi].name}`,idx:[...base.idx,pi],...r})}}triples.sort((a,b)=>a.effect-b.effect);all[y]={singles:singles.slice(0,8),pairs:pairs.slice(0,8),triples:triples.slice(0,8)};console.log('"'\\n###',y);for(let label of ['singles','pairs','triples']){console.log(label);for(let r of all[y][label])console.log(r.pred,'n='+r.n,'mean='+r.mean.toFixed(4),'comp='+r.compMean.toFixed(4),'eff='+r.effect.toFixed(4),'p='+r.p.toExponential(2))}}
// Focused KIF18A subgroup breakdown
function maskBy(name){let p=predicates.find(p=>p.name===name);if("'!p)throw Error('"'missing '+name);return p.mask}function namedStat(y,names){let m=intersect(names.map(maskBy));return {names,...stat(y,m)}}console.log('\\nKIF18A focused');for(let names of [ ['feature_011=colorectal'], ['feature_035=1'], ['feature_020=0'], ['feature_020=1'], ['feature_011=colorectal','feature_035=1'], ['feature_011=colorectal','feature_035=1','feature_020=0'], ['feature_011=colorectal','feature_035=1','feature_020=1'], ['feature_011=colorectal','feature_035=0'], ['feature_011=colorectal','feature_035=0','feature_020=0']]){let r=namedStat('dependency_KIF18A',names);console.log(names.join(' & '),'n='+r.n,'mean='+r.mean.toFixed(4),'comp='+r.compMean.toFixed(4),'eff='+r.effect.toFixed(4),'p='+r.p.toExponential(2))}
