import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print(df.shape)
print(df.dtypes.to_string())
print('\\nOutcome summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.25,.5,.75,.95,.99]).to_string())
print('\\nColumns')
print('\\n'.join(df.columns))
print('\\nBinary prevalence candidates')
for c in df.columns:
    if c == 'pfs_months':
        continue
    vals = df[c].drop_duplicates()
    if len(vals) <= 2 and set(vals.tolist()).issubset({0,1,False,True}):
        print(f'{c}: mean={df[c].mean():.4f}, n1={int(df[c].sum())}')
print('\\nNumeric summaries')
for c in df.columns:
    if c == 'pfs_months':
        continue
    if not (df[c].drop_duplicates().size <= 2 and set(df[c].drop_duplicates().tolist()).issubset({0,1,False,True})):
        s=df[c]
        print(f'{c}: mean={s.mean():.3f}, sd={s.std():.3f}, min={s.min():.3f}, q25={s.quantile(.25):.3f}, med={s.median():.3f}, q75={s.quantile(.75):.3f}, max={s.max():.3f}')
