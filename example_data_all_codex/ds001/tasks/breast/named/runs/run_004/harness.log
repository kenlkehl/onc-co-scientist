+const fs = require('fs');
+
+const file = fs.readFileSync('dataset.parquet');
+
+class TCompact {
+  constructor(buf, off = 0) {
+    this.b = buf;
+    this.o = off;
+  }
+
+  readByte() {
+    return this.b[this.o++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = this.readByte();
+      out |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
