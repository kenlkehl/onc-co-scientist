+function analysis(hypothesisIds, result, effect, p, significant = p < 0.05, code = null) {
+  return {
+    hypothesis_ids: Array.isArray(hypothesisIds) ? hypothesisIds : [hypothesisIds],
+    code,
+    result_summary: result,
