+function olsContrast(model, weights) {
+  let beta = 0;
+  for (const [name, weight] of Object.entries(weights)) beta += weight * model.byName[name].beta;
+  let variance = 0;
+  for (const [nameA, weightA] of Object.entries(weights)) {
+    const i = model.byName[nameA].index;
+    for (const [nameB, weightB] of Object.entries(weights)) {
+      const j = model.byName[nameB].index;
+      variance += weightA * weightB * model.cov[i][j];
+    }
+  }
+  const se = Math.sqrt(Math.max(0, variance));
+  const z = beta / se;
+  return { beta, se, z, p: pFromZ(z) };
