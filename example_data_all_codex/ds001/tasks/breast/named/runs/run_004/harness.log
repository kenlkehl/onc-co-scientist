+function topUnivariate() {
+  const rows = [];
+  for (const col of allCols) {
+    const vals = data[col];
+    const unique = new Set(Array.from(vals.slice(0, Math.min(vals.length, 5000))));
+    if (unique.size <= 10) {
+      const d = binaryDiff(col);
+      rows.push({ col, effect: d.diff, p: d.p, desc: `mean ${fmt(d.m1)} vs ${fmt(d.m0)}` });
+    } else {
+      const mx = mean(vals);
+      const my = mean(y);
+      let sxy = 0, sxx = 0;
+      for (let i = 0; i < y.length; i++) {
+        const dx = vals[i] - mx;
+        sxy += dx * (y[i] - my);
+        sxx += dx * dx;
+      }
+      const beta = sxy / sxx;
+      rows.push({ col, effect: beta, p: null, desc: `slope ${fmt(beta, 4)} per unit` });
+    }
+  }
+  return rows.sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect)).slice(0, 20);
+}
