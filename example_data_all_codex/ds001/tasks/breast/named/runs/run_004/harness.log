new file mode 100644
index 0000000000000000000000000000000000000000..8c31fdb4096dc5cb2dd3dd15aaa4069953719434
--- /dev/null
+++ b/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/breast/named/analysis_runner.js
@@ -0,0 +1,1027 @@
+const fs = require('fs');
+
+const file = fs.readFileSync('dataset.parquet');
+
+class TCompact {
+  constructor(buf, off = 0) {
+    this.b = buf;
+    this.o = off;
+  }
+
+  readByte() {
+    return this.b[this.o++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = this.readByte();
+      out |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readI32() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const value = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return value;
+  }
