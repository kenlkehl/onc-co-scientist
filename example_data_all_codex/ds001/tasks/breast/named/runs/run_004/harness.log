+const burdenCols = [
+  'stage_iv',
+  'liver_mets',
+  'bone_mets',
+  'has_brain_mets',
+  'pleural_effusion',
+  'contralateral_lung_mets',
+  'tumor_size_cm',
+  'albumin_g_dl',
+  'ldh_u_l',
+  'weight_loss_pct_6mo',
+  'crp_mg_l',
+  'nlr',
+  'ecog_ps',
+];
+const adjustmentCols = [
+  'age_years',
+  'sex_female',
+  'ecog_ps',
+  'stage_iv',
+  'has_brain_mets',
+  'liver_mets',
+  'bone_mets',
+  'node_positive',
+  'er_positive',
+  'pr_positive',
+  'her2_positive',
+  'her2_low',
+  'brca1_mutation',
