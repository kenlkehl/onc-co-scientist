+const file = fs.readFileSync('dataset.parquet');
+
+class TCompact {
+  constructor(buf, off = 0) {
+    this.b = buf;
+    this.o = off;
+  }
+
+  readByte() {
+    return this.b[this.o++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = this.readByte();
+      out |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readI32() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const value = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return value;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const value = this.b.slice(this.o, this.o + len);
+    this.o += len;
+    return value;
+  }
+
+  readList() {
+    const h = this.readByte();
+    let size = h >> 4;
+    const elemType = h & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const values = [];
+    for (let i = 0; i < size; i++) values.push(this.readValue(elemType));
+    return values;
+  }
+
+  readValue(t) {
+    switch (t) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.readByte();
+      case 4:
+        return Number(this.zigzag(this.readVarint()));
+      case 5:
+        return this.readI32();
+      case 6:
+        return this.readI64();
+      case 7:
+        return this.readDouble();
+      case 8:
+        return this.readBinary();
+      case 9:
+        return this.readList();
+      case 12:
+        return this.readStruct();
+      default:
+        throw new Error(`Unsupported compact type ${t} at ${this.o}`);
+    }
+  }
+
+  readStruct() {
+    const obj = {};
+    let lastId = 0;
+    while (true) {
+      const h = this.readByte();
+      const type = h & 0x0f;
+      if (type === 0) break;
+      const delta = h >> 4;
+      let id;
+      if (delta === 0) {
+        id = Number(this.zigzag(this.readVarint()));
+      } else {
+        id = lastId + delta;
+      }
+      lastId = id;
+      obj[id] = this.readValue(type);
+    }
+    return obj;
+  }
