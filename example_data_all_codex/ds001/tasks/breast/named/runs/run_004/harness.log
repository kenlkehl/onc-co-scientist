+function solveLinear(A, b) {
+  const n = b.length;
+  const M = A.map((row, i) => row.slice().concat([b[i]]));
+  for (let k = 0; k < n; k++) {
+    let pivot = k;
+    for (let i = k + 1; i < n; i++) {
+      if (Math.abs(M[i][k]) > Math.abs(M[pivot][k])) pivot = i;
+    }
+    if (Math.abs(M[pivot][k]) < 1e-12) throw new Error('Singular matrix');
