+  const builders = includeIntercept ? [{ name: 'Intercept', fn: () => 1 }, ...terms] : terms;
+  const p = builders.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = builders.map((t) => t.fn(i));
+    const yi = y[i];
+    yty += yi * yi;
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * yi;
+      for (let b = 0; b <= a; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  }
+  const beta = solveLinear(xtx, xty);
+  let sse = yty;
+  for (let a = 0; a < p; a++) sse -= beta[a] * xty[a];
