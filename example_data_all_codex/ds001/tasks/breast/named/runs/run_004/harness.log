+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = this.readByte();
+      out |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
