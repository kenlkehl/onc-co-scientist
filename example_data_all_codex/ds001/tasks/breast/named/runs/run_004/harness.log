+function readUVar(buf, posObj) {
+  let shift = 0;
+  let out = 0;
+  while (true) {
+    const x = buf[posObj.pos++];
+    out |= (x & 0x7f) << shift;
+    if ((x & 0x80) === 0) break;
+    shift += 7;
+  }
+  return out;
