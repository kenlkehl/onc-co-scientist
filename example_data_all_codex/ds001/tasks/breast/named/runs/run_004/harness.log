+const fs = require('fs');
+
+const file = fs.readFileSync('dataset.parquet');
+
+class TCompact {
+  constructor(buf, off = 0) {
+    this.b = buf;
+    this.o = off;
+  }
+
+  readByte() {
+    return this.b[this.o++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = this.readByte();
+      out |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readI32() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const value = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return value;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const value = this.b.slice(this.o, this.o + len);
+    this.o += len;
+    return value;
+  }
+
+  readList() {
+    const h = this.readByte();
+    let size = h >> 4;
+    const elemType = h & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const values = [];
+    for (let i = 0; i < size; i++) values.push(this.readValue(elemType));
+    return values;
+  }
