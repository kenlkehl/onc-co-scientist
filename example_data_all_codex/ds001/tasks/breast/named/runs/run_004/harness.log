+const fs = require('fs');
+
+const file = fs.readFileSync('dataset.parquet');
+
+class TCompact {
+  constructor(buf, off = 0) {
+    this.b = buf;
+    this.o = off;
+  }
+
+  readByte() {
+    return this.b[this.o++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = this.readByte();
+      out |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readI32() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const value = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return value;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const value = this.b.slice(this.o, this.o + len);
+    this.o += len;
+    return value;
+  }
+
+  readList() {
+    const h = this.readByte();
+    let size = h >> 4;
+    const elemType = h & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const values = [];
+    for (let i = 0; i < size; i++) values.push(this.readValue(elemType));
+    return values;
+  }
+
+  readValue(t) {
+    switch (t) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.readByte();
+      case 4:
+        return Number(this.zigzag(this.readVarint()));
+      case 5:
+        return this.readI32();
+      case 6:
+        return this.readI64();
+      case 7:
+        return this.readDouble();
+      case 8:
+        return this.readBinary();
+      case 9:
+        return this.readList();
+      case 12:
+        return this.readStruct();
+      default:
+        throw new Error(`Unsupported compact type ${t} at ${this.o}`);
+    }
+  }
+
+  readStruct() {
+    const obj = {};
+    let lastId = 0;
+    while (true) {
+      const h = this.readByte();
+      const type = h & 0x0f;
+      if (type === 0) break;
+      const delta = h >> 4;
+      let id;
+      if (delta === 0) {
+        id = Number(this.zigzag(this.readVarint()));
+      } else {
+        id = lastId + delta;
+      }
+      lastId = id;
+      obj[id] = this.readValue(type);
+    }
+    return obj;
+  }
+}
+
+function parseMeta() {
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const start = file.length - 8 - footerLen;
+  return new TCompact(file.slice(start, file.length - 8)).readStruct();
+}
+
+function snappyUncompress(input, expectedLen) {
+  let pos = 0;
+  let shift = 0;
+  let declaredLen = 0;
+  while (true) {
+    const x = input[pos++];
+    declaredLen |= (x & 0x7f) << shift;
+    if ((x & 0x80) === 0) break;
+    shift += 7;
+  }
+  const outLen = expectedLen ?? declaredLen;
+  const out = Buffer.allocUnsafe(outLen);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 1;
+        for (let i = 0; i < bytes; i++) len += input[pos++] << (8 * i);
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset =
+          input[pos] |
+          (input[pos + 1] << 8) |
+          (input[pos + 2] << 16) |
+          (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch ${op} vs ${outLen}`);
+  return out;
+}
+
+function readUVar(buf, posObj) {
+  let shift = 0;
+  let out = 0;
+  while (true) {
+    const x = buf[posObj.pos++];
+    out |= (x & 0x7f) << shift;
+    if ((x & 0x80) === 0) break;
+    shift += 7;
+  }
+  return out;
+}
+
+function decodeHybrid(buf, n, bitWidth) {
+  const values = new Int32Array(n);
+  const posObj = { pos: 0 };
+  let out = 0;
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (out < n && posObj.pos < buf.length) {
+    const header = readUVar(buf, posObj);
+    if ((header & 1) === 0) {
+      const count = header >> 1;
+      let value = 0;
+      for (let b = 0; b < valueBytes; b++) value |= buf[posObj.pos++] << (8 * b);
+      const end = Math.min(n, out + count);
+      while (out < end) values[out++] = value;
+    } else {
+      const groups = header >> 1;
+      const runStart = posObj.pos;
+      let bitBuffer = 0;
+      let bitCount = 0;
+      const modulus = 2 ** bitWidth;
