+  readDouble() {
+    const value = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return value;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const value = this.b.slice(this.o, this.o + len);
+    this.o += len;
+    return value;
+  }
