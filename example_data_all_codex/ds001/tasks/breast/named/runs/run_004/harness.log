+const fs = require('fs');
+
+const file = fs.readFileSync('dataset.parquet');
+
+class TCompact {
+  constructor(buf, off = 0) {
+    this.b = buf;
+    this.o = off;
+  }
+
+  readByte() {
+    return this.b[this.o++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const x = this.readByte();
+      out |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return out;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readI32() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const value = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return value;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const value = this.b.slice(this.o, this.o + len);
+    this.o += len;
+    return value;
+  }
+
+  readList() {
+    const h = this.readByte();
+    let size = h >> 4;
+    const elemType = h & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const values = [];
+    for (let i = 0; i < size; i++) values.push(this.readValue(elemType));
+    return values;
+  }
+
+  readValue(t) {
+    switch (t) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.readByte();
+      case 4:
+        return Number(this.zigzag(this.readVarint()));
+      case 5:
+        return this.readI32();
+      case 6:
+        return this.readI64();
+      case 7:
+        return this.readDouble();
+      case 8:
+        return this.readBinary();
+      case 9:
+        return this.readList();
+      case 12:
+        return this.readStruct();
+      default:
+        throw new Error(`Unsupported compact type ${t} at ${this.o}`);
+    }
+  }
+
+  readStruct() {
+    const obj = {};
+    let lastId = 0;
+    while (true) {
+      const h = this.readByte();
+      const type = h & 0x0f;
+      if (type === 0) break;
+      const delta = h >> 4;
+      let id;
+      if (delta === 0) {
+        id = Number(this.zigzag(this.readVarint()));
+      } else {
+        id = lastId + delta;
+      }
+      lastId = id;
+      obj[id] = this.readValue(type);
+    }
+    return obj;
+  }
+}
+
+function parseMeta() {
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const start = file.length - 8 - footerLen;
+  return new TCompact(file.slice(start, file.length - 8)).readStruct();
+}
+
+function snappyUncompress(input, expectedLen) {
+  let pos = 0;
+  let shift = 0;
+  let declaredLen = 0;
+  while (true) {
+    const x = input[pos++];
+    declaredLen |= (x & 0x7f) << shift;
+    if ((x & 0x80) === 0) break;
+    shift += 7;
+  }
+  const outLen = expectedLen ?? declaredLen;
+  const out = Buffer.allocUnsafe(outLen);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 1;
+        for (let i = 0; i < bytes; i++) len += input[pos++] << (8 * i);
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset =
+          input[pos] |
+          (input[pos + 1] << 8) |
+          (input[pos + 2] << 16) |
+          (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch ${op} vs ${outLen}`);
+  return out;
+}
+
+function readUVar(buf, posObj) {
+  let shift = 0;
+  let out = 0;
+  while (true) {
+    const x = buf[posObj.pos++];
+    out |= (x & 0x7f) << shift;
+    if ((x & 0x80) === 0) break;
+    shift += 7;
+  }
+  return out;
+}
+
+function decodeHybrid(buf, n, bitWidth) {
+  const values = new Int32Array(n);
+  const posObj = { pos: 0 };
+  let out = 0;
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (out < n && posObj.pos < buf.length) {
+    const header = readUVar(buf, posObj);
+    if ((header & 1) === 0) {
+      const count = header >> 1;
+      let value = 0;
+      for (let b = 0; b < valueBytes; b++) value |= buf[posObj.pos++] << (8 * b);
+      const end = Math.min(n, out + count);
+      while (out < end) values[out++] = value;
+    } else {
+      const groups = header >> 1;
+      const runStart = posObj.pos;
+      let bitBuffer = 0;
+      let bitCount = 0;
+      const modulus = 2 ** bitWidth;
+      for (let g = 0; g < groups * 8 && out < n; g++) {
+        while (bitCount < bitWidth) {
+          bitBuffer += buf[posObj.pos++] * (2 ** bitCount);
+          bitCount += 8;
+        }
+        values[out++] = bitBuffer % modulus;
+        bitBuffer = Math.floor(bitBuffer / modulus);
+        bitCount -= bitWidth;
+      }
+      const bytesForRun = Math.ceil((groups * 8 * bitWidth) / 8);
+      posObj.pos = runStart + bytesForRun;
+    }
+  }
+  if (out !== n) throw new Error(`Hybrid decode count mismatch ${out} vs ${n}`);
+  return values;
+}
+
+function plainValue(buf, pos, physicalType) {
+  if (physicalType === 5) return buf.readDoubleLE(pos);
+  if (physicalType === 2) return Number(buf.readBigInt64LE(pos));
+  if (physicalType === 1) return buf.readInt32LE(pos);
+  throw new Error(`Unsupported physical type ${physicalType}`);
+}
+
+function readColumn(colChunk) {
+  const md = colChunk[3];
+  const physicalType = md[1];
+  const name = md[3].map((x) => x.toString()).join('.');
+  const totalCompressed = Number(md[7]);
+  const start = Number(md[11] ?? md[9]);
+  const end = start + totalCompressed;
+  let pos = start;
+  let dict = null;
+  const out = new Float64Array(Number(md[5]));
+  let outPos = 0;
+  while (pos < end) {
+    const reader = new TCompact(file, pos);
+    const header = reader.readStruct();
+    const bodyStart = reader.o;
+    const compressedSize = Number(header[3]);
+    const uncompressedSize = Number(header[2]);
+    const compressed = file.slice(bodyStart, bodyStart + compressedSize);
+    const body = md[4] === 1 ? snappyUncompress(compressed, uncompressedSize) : compressed;
+    pos = bodyStart + compressedSize;
+
+    if (header[1] === 2) {
+      const dictHeader = header[7];
+      const n = Number(dictHeader[1]);
+      dict = new Float64Array(n);
+      const width = physicalType === 5 || physicalType === 2 ? 8 : 4;
+      for (let i = 0; i < n; i++) dict[i] = plainValue(body, i * width, physicalType);
+    } else if (header[1] === 0) {
+      const dataHeader = header[5];
+      const n = Number(dataHeader[1]);
+      const encoding = dataHeader[2];
+      let valueBody = body;
+      if (dataHeader[4] === 3 && body.length >= 4) {
+        const defLen = body.readUInt32LE(0);
+        valueBody = body.slice(4 + defLen);
+      }
+      if (encoding === 8) {
+        const bitWidth = valueBody[0];
+        let indexes;
+        try {
+          indexes = decodeHybrid(valueBody.slice(1), n, bitWidth);
+        } catch (err) {
+          throw new Error(`${name} page decode failed: bitWidth=${bitWidth}, bodyLen=${body.length}, valueBodyLen=${valueBody.length}, n=${n}, firstBytes=${Array.from(body.slice(0, 16)).join(',')}; ${err.message}`);
+        }
+        if (!dict) throw new Error(`Missing dictionary for ${name}`);
+        for (let i = 0; i < n; i++) out[outPos++] = dict[indexes[i]];
+      } else if (encoding === 0) {
+        const width = physicalType === 5 || physicalType === 2 ? 8 : 4;
+        for (let i = 0; i < n; i++) out[outPos++] = plainValue(valueBody, i * width, physicalType);
+      } else {
+        throw new Error(`Unsupported data encoding ${encoding} for ${name}`);
+      }
+    } else if (header[1] === 3) {
+      throw new Error(`Data page v2 not implemented for ${name}`);
+    }
+  }
+  if (outPos !== out.length) throw new Error(`Column ${name} count mismatch ${outPos} vs ${out.length}`);
+  return out;
+}
+
+function mean(arr, mask = null, value = 1) {
+  let s = 0;
+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) {
+      if (mask[i] === value) {
+        s += arr[i];
+        n++;
+      }
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) s += arr[i];
+    n = arr.length;
+  }
+  return s / n;
+}
+
+function variance(arr, m = null) {
+  const mu = m ?? mean(arr);
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - mu;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function normalCdf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x) / Math.SQRT2;
+  const t = 1 / (1 + 0.3275911 * x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const erf = sign * (1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x));
+  return 0.5 * (1 + erf);
+}
+
+function pFromZ(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  if (!Number.isFinite(p)) return 0;
+  return Math.max(0, Math.min(1, p));
+}
