+    const reader = new TCompact(file, pos);
+    const header = reader.readStruct();
+    const bodyStart = reader.o;
+    const compressedSize = Number(header[3]);
+    const uncompressedSize = Number(header[2]);
+    const compressed = file.slice(bodyStart, bodyStart + compressedSize);
