+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const inv = [];
+  for (let j = 0; j < n; j++) {
+    const e = Array(n).fill(0);
+    e[j] = 1;
+    inv.push(solveLinear(A, e));
+  }
+  const out = Array.from({ length: n }, () => Array(n).fill(0));
+  for (let j = 0; j < n; j++) {
+    for (let i = 0; i < n; i++) out[i][j] = inv[j][i];
+  }
+  return out;
+}
+
+function ols(y, terms, includeIntercept = true) {
+  const n = y.length;
+  const builders = includeIntercept ? [{ name: 'Intercept', fn: () => 1 }, ...terms] : terms;
+  const p = builders.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = builders.map((t) => t.fn(i));
+    const yi = y[i];
+    yty += yi * yi;
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * yi;
+      for (let b = 0; b <= a; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  }
+  const beta = solveLinear(xtx, xty);
+  let sse = yty;
+  for (let a = 0; a < p; a++) sse -= beta[a] * xty[a];
+  const df = n - p;
+  const sigma2 = sse / df;
+  const inv = invertMatrix(xtx);
+  const cov = inv.map((row) => row.map((x) => x * sigma2));
