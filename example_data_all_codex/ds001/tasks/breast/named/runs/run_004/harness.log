+  for (let a = 0; a < p; a++) {
+    const se = Math.sqrt(Math.max(0, cov[a][a]));
+    const z = beta[a] / se;
+    byName[builders[a].name] = {
+      beta: beta[a],
+      se,
+      z,
+      p: pFromZ(z),
+      index: a,
+    };
+  }
+  return { byName, beta, sse, sigma2, df, n, p, cov, names: builders.map((x) => x.name) };
+}
+
+function olsContrast(model, weights) {
+  let beta = 0;
+  for (const [name, weight] of Object.entries(weights)) beta += weight * model.byName[name].beta;
+  let variance = 0;
+  for (const [nameA, weightA] of Object.entries(weights)) {
+    const i = model.byName[nameA].index;
+    for (const [nameB, weightB] of Object.entries(weights)) {
+      const j = model.byName[nameB].index;
+      variance += weightA * weightB * model.cov[i][j];
+    }
+  }
+  const se = Math.sqrt(Math.max(0, variance));
+  const z = beta / se;
+  return { beta, se, z, p: pFromZ(z) };
+}
+
+function fmt(x, digits = 3) {
+  return Number.isFinite(x) ? Number(x.toFixed(digits)) : x;
+}
+
+function pFmt(p) {
+  if (p === 0 || p < 1e-300) return '<1e-300';
+  if (p < 1e-4) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function quantile(arr, q) {
+  const x = Array.from(arr).sort((a, b) => a - b);
+  const pos = (x.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return x[lo];
+  return x[lo] + (x[hi] - x[lo]) * (pos - lo);
+}
+
+const meta = parseMeta();
+const rowGroup = meta[4][0];
+const chunks = rowGroup[1];
+const schema = meta[2].slice(1).map((x) => x[4].toString());
+const data = {};
+for (let i = 1; i < schema.length; i++) {
+  data[schema[i]] = readColumn(chunks[i]);
+}
+
+const y = data.pfs_months;
+const allCols = Object.keys(data).filter((x) => x !== 'pfs_months');
+const treatmentCols = allCols.filter((x) => x.startsWith('treatment_'));
+const biomarkerCols = [
+  'er_positive',
+  'pr_positive',
+  'her2_positive',
+  'her2_low',
+  'brca1_mutation',
+  'brca2_mutation',
+  'pik3ca_mutation',
+  'ki67_pct',
+  'her2_amplification',
+];
+const burdenCols = [
+  'stage_iv',
+  'liver_mets',
+  'bone_mets',
+  'has_brain_mets',
+  'pleural_effusion',
+  'contralateral_lung_mets',
+  'tumor_size_cm',
+  'albumin_g_dl',
+  'ldh_u_l',
+  'weight_loss_pct_6mo',
+  'crp_mg_l',
+  'nlr',
+  'ecog_ps',
+];
+const adjustmentCols = [
+  'age_years',
+  'sex_female',
+  'ecog_ps',
+  'stage_iv',
+  'has_brain_mets',
+  'liver_mets',
+  'bone_mets',
+  'node_positive',
+  'er_positive',
+  'pr_positive',
+  'her2_positive',
+  'her2_low',
+  'brca1_mutation',
+  'brca2_mutation',
+  'pik3ca_mutation',
+  'ki67_pct',
+  'tumor_size_cm',
+  'albumin_g_dl',
+  'ldh_u_l',
+  'weight_loss_pct_6mo',
+  'crp_mg_l',
+  'nlr',
+];
+const baseTerms = adjustmentCols.concat(treatmentCols).map((name) => ({ name, fn: (i) => data[name][i] }));
+const adjustedMain = ols(y, baseTerms);
+
+function coeff(model, name) {
+  return model.byName[name];
+}
+
+function binaryDiff(col, maskFn = null) {
+  const x = data[col];
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (maskFn && !maskFn(i)) continue;
+    if (x[i] === 1) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, m1, m0, diff: m1 - m0, se, p: pFromZ(z) };
+}
+
+function subgroupTreatment(treatment, subgroup) {
+  const t = data[treatment];
+  const g = data[subgroup];
+  const rows = [];
+  for (const level of [0, 1]) {
+    let n1 = 0, n0 = 0, s1 = 0, s0 = 0;
+    for (let i = 0; i < y.length; i++) {
+      if (g[i] !== level) continue;
+      if (t[i] === 1) {
+        n1++;
+        s1 += y[i];
+      } else {
+        n0++;
+        s0 += y[i];
+      }
+    }
+    rows.push({ level, n_treated: n1, n_untreated: n0, mean_treated: s1 / n1, mean_untreated: s0 / n0, diff: s1 / n1 - s0 / n0 });
+  }
+  const terms = adjustmentCols
+    .concat(treatmentCols.filter((x) => x !== treatment))
+    .filter((name, idx, arr) => name !== subgroup && arr.indexOf(name) === idx)
+    .map((name) => ({ name, fn: (i) => data[name][i] }));
+  terms.push({ name: treatment, fn: (i) => data[treatment][i] });
+  terms.push({ name: subgroup, fn: (i) => data[subgroup][i] });
+  terms.push({ name: `${treatment}:${subgroup}`, fn: (i) => data[treatment][i] * data[subgroup][i] });
+  const model = ols(y, terms);
+  return { rows, interaction: coeff(model, `${treatment}:${subgroup}`), treatmentMain: coeff(model, treatment) };
+}
+
+function continuousInteraction(treatment, marker) {
+  const vals = data[marker];
+  const mu = mean(vals);
+  const sd = Math.sqrt(variance(vals, mu));
+  const terms = adjustmentCols.concat(treatmentCols.filter((x) => x !== treatment && x !== marker)).map((name) => {
+    if (name === marker) return { name: `${marker}_z`, fn: (i) => (data[marker][i] - mu) / sd };
+    return { name, fn: (i) => data[name][i] };
+  });
+  if (!adjustmentCols.includes(marker)) terms.push({ name: `${marker}_z`, fn: (i) => (data[marker][i] - mu) / sd });
+  terms.push({ name: treatment, fn: (i) => data[treatment][i] });
+  terms.push({ name: `${treatment}:${marker}_z`, fn: (i) => data[treatment][i] * ((data[marker][i] - mu) / sd) });
+  const model = ols(y, terms);
+  return { mean: mu, sd, interaction: coeff(model, `${treatment}:${marker}_z`), treatment: coeff(model, treatment) };
+}
+
+function binaryInteraction(colA, colB, extraAdjust = []) {
+  const excluded = new Set([colA, colB]);
+  const covars = adjustmentCols.concat(treatmentCols).concat(extraAdjust).filter((x, idx, arr) => !excluded.has(x) && arr.indexOf(x) === idx);
+  const terms = covars.map((name) => ({ name, fn: (i) => data[name][i] }));
+  terms.push({ name: colA, fn: (i) => data[colA][i] });
+  terms.push({ name: colB, fn: (i) => data[colB][i] });
+  terms.push({ name: `${colA}:${colB}`, fn: (i) => data[colA][i] * data[colB][i] });
+  const model = ols(y, terms);
+  return { interaction: coeff(model, `${colA}:${colB}`), model };
+}
+
+function simpleContinuous(col) {
+  const vals = data[col];
+  const mu = mean(vals);
+  const sd = Math.sqrt(variance(vals, mu));
+  const terms = adjustmentCols.concat(treatmentCols).filter((x) => x !== col).map((name) => ({ name, fn: (i) => data[name][i] }));
+  terms.push({ name: `${col}_z`, fn: (i) => (vals[i] - mu) / sd });
+  const model = ols(y, terms);
+  return { mean: mu, sd, coef: coeff(model, `${col}_z`) };
+}
+
+function topUnivariate() {
+  const rows = [];
+  for (const col of allCols) {
+    const vals = data[col];
+    const unique = new Set(Array.from(vals.slice(0, Math.min(vals.length, 5000))));
+    if (unique.size <= 10) {
+      const d = binaryDiff(col);
+      rows.push({ col, effect: d.diff, p: d.p, desc: `mean ${fmt(d.m1)} vs ${fmt(d.m0)}` });
+    } else {
+      const mx = mean(vals);
+      const my = mean(y);
+      let sxy = 0, sxx = 0;
+      for (let i = 0; i < y.length; i++) {
+        const dx = vals[i] - mx;
+        sxy += dx * (y[i] - my);
+        sxx += dx * dx;
+      }
+      const beta = sxy / sxx;
+      rows.push({ col, effect: beta, p: null, desc: `slope ${fmt(beta, 4)} per unit` });
+    }
+  }
+  return rows.sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect)).slice(0, 20);
+}
+
+const pfsMean = mean(y);
+const pfsSd = Math.sqrt(variance(y, pfsMean));
+const pfsQ = [0, 0.25, 0.5, 0.75, 0.95].map((q) => quantile(y, q));
+
+const selected = {};
+for (const col of [...treatmentCols, ...biomarkerCols, ...burdenCols]) {
+  if (data[col]) selected[col] = {
+    prevalence_or_mean: fmt(mean(data[col]), 4),
+    unadjusted: data[col] && new Set(Array.from(data[col].slice(0, 5000))).size <= 10 ? binaryDiff(col) : null,
+    adjusted: adjustedMain.byName[col] ?? null,
+  };
+}
+
+const interactions = {
+  trastuzumab_her2_positive: subgroupTreatment('treatment_trastuzumab', 'her2_positive'),
+  trastuzumab_her2_amplification: subgroupTreatment('treatment_trastuzumab', 'her2_amplification'),
+  trastuzumab_her2_low: subgroupTreatment('treatment_trastuzumab', 'her2_low'),
+  palbociclib_er_positive: subgroupTreatment('treatment_palbociclib', 'er_positive'),
+  palbociclib_pr_positive: subgroupTreatment('treatment_palbociclib', 'pr_positive'),
+  tamoxifen_er_positive: subgroupTreatment('treatment_tamoxifen', 'er_positive'),
+  olaparib_brca1: subgroupTreatment('treatment_olaparib', 'brca1_mutation'),
+  olaparib_brca2: subgroupTreatment('treatment_olaparib', 'brca2_mutation'),
+  pembrolizumab_autoimmune: subgroupTreatment('treatment_pembrolizumab', 'autoimmune_disease'),
+  pembrolizumab_nlr: continuousInteraction('treatment_pembrolizumab', 'nlr'),
+  sacituzumab_stage_iv: subgroupTreatment('treatment_sacituzumab_govitecan', 'stage_iv'),
+  sacituzumab_liver_mets: subgroupTreatment('treatment_sacituzumab_govitecan', 'liver_mets'),
+  stage_liver: binaryInteraction('stage_iv', 'liver_mets'),
+  brain_pleural: binaryInteraction('has_brain_mets', 'pleural_effusion'),
