+          indexes = decodeHybrid(valueBody.slice(1), n, bitWidth);
+        } catch (err) {
+          throw new Error(`${name} page decode failed: bitWidth=${bitWidth}, bodyLen=${body.length}, valueBodyLen=${valueBody.length}, n=${n}, firstBytes=${Array.from(body.slice(0, 16)).join(',')}; ${err.message}`);
