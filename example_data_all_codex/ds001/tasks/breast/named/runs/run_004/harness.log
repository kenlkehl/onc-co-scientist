+  const out = Buffer.allocUnsafe(outLen);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 1;
+        for (let i = 0; i < bytes; i++) len += input[pos++] << (8 * i);
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
