+}
+
+function plainValue(buf, pos, physicalType) {
+  if (physicalType === 5) return buf.readDoubleLE(pos);
+  if (physicalType === 2) return Number(buf.readBigInt64LE(pos));
+  if (physicalType === 1) return buf.readInt32LE(pos);
+  throw new Error(`Unsupported physical type ${physicalType}`);
+}
+
+function readColumn(colChunk) {
+  const md = colChunk[3];
+  const physicalType = md[1];
+  const name = md[3].map((x) => x.toString()).join('.');
+  const totalCompressed = Number(md[7]);
+  const start = Number(md[11] ?? md[9]);
+  const end = start + totalCompressed;
+  let pos = start;
+  let dict = null;
+  const out = new Float64Array(Number(md[5]));
+  let outPos = 0;
+  while (pos < end) {
+    const reader = new TCompact(file, pos);
+    const header = reader.readStruct();
+    const bodyStart = reader.o;
+    const compressedSize = Number(header[3]);
+    const uncompressedSize = Number(header[2]);
+    const compressed = file.slice(bodyStart, bodyStart + compressedSize);
+    const body = md[4] === 1 ? snappyUncompress(compressed, uncompressedSize) : compressed;
+    pos = bodyStart + compressedSize;
+
+    if (header[1] === 2) {
+      const dictHeader = header[7];
+      const n = Number(dictHeader[1]);
+      dict = new Float64Array(n);
+      const width = physicalType === 5 || physicalType === 2 ? 8 : 4;
+      for (let i = 0; i < n; i++) dict[i] = plainValue(body, i * width, physicalType);
+    } else if (header[1] === 0) {
+      const dataHeader = header[5];
+      const n = Number(dataHeader[1]);
+      const encoding = dataHeader[2];
+      if (encoding === 8) {
+        const bitWidth = body[0];
+        const indexes = decodeHybrid(body.slice(1), n, bitWidth);
+        if (!dict) throw new Error(`Missing dictionary for ${name}`);
+        for (let i = 0; i < n; i++) out[outPos++] = dict[indexes[i]];
+      } else if (encoding === 0) {
+        const width = physicalType === 5 || physicalType === 2 ? 8 : 4;
+        for (let i = 0; i < n; i++) out[outPos++] = plainValue(body, i * width, physicalType);
+      } else {
+        throw new Error(`Unsupported data encoding ${encoding} for ${name}`);
+      }
+    } else if (header[1] === 3) {
+      throw new Error(`Data page v2 not implemented for ${name}`);
+    }
+  }
+  if (outPos !== out.length) throw new Error(`Column ${name} count mismatch ${outPos} vs ${out.length}`);
+  return out;
+}
+
+function mean(arr, mask = null, value = 1) {
+  let s = 0;
+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) {
+      if (mask[i] === value) {
+        s += arr[i];
+        n++;
+      }
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) s += arr[i];
+    n = arr.length;
+  }
+  return s / n;
+}
+
+function variance(arr, m = null) {
+  const mu = m ?? mean(arr);
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - mu;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function normalCdf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x) / Math.SQRT2;
+  const t = 1 / (1 + 0.3275911 * x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const erf = sign * (1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x));
+  return 0.5 * (1 + erf);
+}
+
+function pFromZ(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  if (!Number.isFinite(p)) return 0;
+  return Math.max(0, Math.min(1, p));
