+  let n = 0;
+  if (mask) {
+    for (let i = 0; i < arr.length; i++) {
+      if (mask[i] === value) {
+        s += arr[i];
+        n++;
+      }
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) s += arr[i];
+    n = arr.length;
+  }
+  return s / n;
+}
+
+function variance(arr, m = null) {
+  const mu = m ?? mean(arr);
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - mu;
+    s += d * d;
