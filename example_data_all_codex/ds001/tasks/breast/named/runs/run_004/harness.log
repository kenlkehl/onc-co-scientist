+function continuousInteraction(treatment, marker) {
+  const vals = data[marker];
+  const mu = mean(vals);
+  const sd = Math.sqrt(variance(vals, mu));
+  const terms = adjustmentCols.concat(treatmentCols.filter((x) => x !== treatment && x !== marker)).map((name) => {
+    if (name === marker) return { name: `${marker}_z`, fn: (i) => (data[marker][i] - mu) / sd };
+    return { name, fn: (i) => data[name][i] };
+  });
+  if (!adjustmentCols.includes(marker)) terms.push({ name: `${marker}_z`, fn: (i) => (data[marker][i] - mu) / sd });
+  terms.push({ name: treatment, fn: (i) => data[treatment][i] });
+  terms.push({ name: `${treatment}:${marker}_z`, fn: (i) => data[treatment][i] * ((data[marker][i] - mu) / sd) });
+  const model = ols(y, terms);
+  return { mean: mu, sd, interaction: coeff(model, `${treatment}:${marker}_z`), treatment: coeff(model, treatment) };
