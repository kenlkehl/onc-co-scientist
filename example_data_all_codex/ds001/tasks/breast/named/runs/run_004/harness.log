+
+function readUVar(buf, posObj) {
+  let shift = 0;
+  let out = 0;
+  while (true) {
+    const x = buf[posObj.pos++];
+    out |= (x & 0x7f) << shift;
+    if ((x & 0x80) === 0) break;
+    shift += 7;
+  }
+  return out;
+}
+
+function decodeHybrid(buf, n, bitWidth) {
+  const values = new Int32Array(n);
+  const posObj = { pos: 0 };
+  let out = 0;
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (out < n && posObj.pos < buf.length) {
+    const header = readUVar(buf, posObj);
+    if ((header & 1) === 0) {
+      const count = header >> 1;
+      let value = 0;
+      for (let b = 0; b < valueBytes; b++) value |= buf[posObj.pos++] << (8 * b);
+      const end = Math.min(n, out + count);
+      while (out < end) values[out++] = value;
+    } else {
+      const groups = header >> 1;
+      const runStart = posObj.pos;
+      let bitBuffer = 0;
+      let bitCount = 0;
+      const modulus = 2 ** bitWidth;
+      for (let g = 0; g < groups * 8 && out < n; g++) {
+        while (bitCount < bitWidth) {
+          bitBuffer += buf[posObj.pos++] * (2 ** bitCount);
+          bitCount += 8;
+        }
+        values[out++] = bitBuffer % modulus;
+        bitBuffer = Math.floor(bitBuffer / modulus);
+        bitCount -= bitWidth;
+      }
+      const bytesForRun = Math.ceil((groups * 8 * bitWidth) / 8);
+      posObj.pos = runStart + bytesForRun;
+    }
+  }
