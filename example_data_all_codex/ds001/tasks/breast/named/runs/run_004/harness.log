+function snappyUncompress(input, expectedLen) {
+  let pos = 0;
+  let shift = 0;
+  let declaredLen = 0;
+  while (true) {
+    const x = input[pos++];
+    declaredLen |= (x & 0x7f) << shift;
+    if ((x & 0x80) === 0) break;
+    shift += 7;
+  }
