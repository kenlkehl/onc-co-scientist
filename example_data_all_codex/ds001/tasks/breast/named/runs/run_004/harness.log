+    const h = this.readByte();
+    let size = h >> 4;
+    const elemType = h & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const values = [];
+    for (let i = 0; i < size; i++) values.push(this.readValue(elemType));
+    return values;
+  }
+
+  readValue(t) {
+    switch (t) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.readByte();
+      case 4:
+        return Number(this.zigzag(this.readVarint()));
+      case 5:
+        return this.readI32();
+      case 6:
+        return this.readI64();
+      case 7:
+        return this.readDouble();
+      case 8:
+        return this.readBinary();
+      case 9:
