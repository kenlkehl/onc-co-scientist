+const rowGroup = meta[4][0];
+const chunks = rowGroup[1];
+const schema = meta[2].slice(1).map((x) => x[4].toString());
+const data = {};
+for (let i = 1; i < schema.length; i++) {
+  data[schema[i]] = readColumn(chunks[i]);
+}
+
+const y = data.pfs_months;
+const allCols = Object.keys(data).filter((x) => x !== 'pfs_months');
+const treatmentCols = allCols.filter((x) => x.startsWith('treatment_'));
+const biomarkerCols = [
+  'er_positive',
+  'pr_positive',
+  'her2_positive',
+  'her2_low',
