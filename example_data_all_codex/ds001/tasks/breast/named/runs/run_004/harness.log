+function quantile(arr, q) {
+  const x = Array.from(arr).sort((a, b) => a - b);
+  const pos = (x.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return x[lo];
+  return x[lo] + (x[hi] - x[lo]) * (pos - lo);
+}
+
+const meta = parseMeta();
