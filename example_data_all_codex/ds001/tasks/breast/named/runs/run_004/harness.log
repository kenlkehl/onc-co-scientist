+
+function binaryInteraction(colA, colB, extraAdjust = []) {
+  const excluded = new Set([colA, colB]);
+  const covars = adjustmentCols.concat(treatmentCols).concat(extraAdjust).filter((x, idx, arr) => !excluded.has(x) && arr.indexOf(x) === idx);
+  const terms = covars.map((name) => ({ name, fn: (i) => data[name][i] }));
+  terms.push({ name: colA, fn: (i) => data[colA][i] });
+  terms.push({ name: colB, fn: (i) => data[colB][i] });
+  terms.push({ name: `${colA}:${colB}`, fn: (i) => data[colA][i] * data[colB][i] });
+  const model = ols(y, terms);
+  return { interaction: coeff(model, `${colA}:${colB}`), model };
+}
+
+function simpleContinuous(col) {
+  const vals = data[col];
+  const mu = mean(vals);
+  const sd = Math.sqrt(variance(vals, mu));
+  const terms = adjustmentCols.concat(treatmentCols).filter((x) => x !== col).map((name) => ({ name, fn: (i) => data[name][i] }));
+  terms.push({ name: `${col}_z`, fn: (i) => (vals[i] - mu) / sd });
