+        for (let i = 0; i < n; i++) out[outPos++] = plainValue(body, i * width, physicalType);
+      } else {
+        throw new Error(`Unsupported data encoding ${encoding} for ${name}`);
+      }
+    } else if (header[1] === 3) {
