+function decodeHybrid(buf, n, bitWidth) {
+  const values = new Int32Array(n);
+  const posObj = { pos: 0 };
+  let out = 0;
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (out < n && posObj.pos < buf.length) {
+    const header = readUVar(buf, posObj);
+    if ((header & 1) === 0) {
+      const count = header >> 1;
+      let value = 0;
+      for (let b = 0; b < valueBytes; b++) value |= buf[posObj.pos++] << (8 * b);
+      const end = Math.min(n, out + count);
+      while (out < end) values[out++] = value;
+    } else {
+      const groups = header >> 1;
+      let bitBuffer = 0;
+      let bitCount = 0;
+      for (let g = 0; g < groups * 8 && out < n; g++) {
+        while (bitCount < bitWidth) {
+          bitBuffer |= buf[posObj.pos++] << bitCount;
+          bitCount += 8;
+        }
+        values[out++] = bitBuffer & ((1 << bitWidth) - 1);
+        bitBuffer >>= bitWidth;
+        bitCount -= bitWidth;
