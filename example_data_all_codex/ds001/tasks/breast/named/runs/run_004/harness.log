+  'pleural_effusion',
+  'contralateral_lung_mets',
+  'tumor_size_cm',
+  'albumin_g_dl',
+  'ldh_u_l',
+  'weight_loss_pct_6mo',
+  'crp_mg_l',
+  'nlr',
+  'ecog_ps',
+];
+const adjustmentCols = [
+  'age_years',
+  'sex_female',
+  'ecog_ps',
