+      const mx = mean(vals);
+      const my = mean(y);
+      let sxy = 0, sxx = 0;
+      for (let i = 0; i < y.length; i++) {
+        const dx = vals[i] - mx;
+        sxy += dx * (y[i] - my);
+        sxx += dx * dx;
+      }
+      const beta = sxy / sxx;
+      rows.push({ col, effect: beta, p: null, desc: `slope ${fmt(beta, 4)} per unit` });
+    }
