+      const h = this.readByte();
+      const type = h & 0x0f;
+      if (type === 0) break;
+      const delta = h >> 4;
+      let id;
+      if (delta === 0) {
+        id = Number(this.zigzag(this.readVarint()));
+      } else {
+        id = lastId + delta;
+      }
+      lastId = id;
+      obj[id] = this.readValue(type);
+    }
+    return obj;
+  }
