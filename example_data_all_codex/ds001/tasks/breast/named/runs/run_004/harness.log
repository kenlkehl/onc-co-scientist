+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = builders.map((t) => t.fn(i));
+    const yi = y[i];
+    yty += yi * yi;
+    for (let a = 0; a < p; a++) {
