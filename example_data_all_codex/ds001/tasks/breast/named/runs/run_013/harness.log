+function diffTest(columns, feature, outcome = "pfs_months") {
+  const x = columns[feature];
+  const y = columns[outcome];
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) (x[i] ? a : b).push(y[i]);
+  const mean1 = mean(a);
+  const mean0 = mean(b);
+  const v1 = variance(a, mean1);
+  const v0 = variance(b, mean0);
+  const se = Math.sqrt(v1 / a.length + v0 / b.length);
+  const t = (mean1 - mean0) / se;
+  return { feature, n1: a.length, n0: b.length, mean1, mean0, effect: mean1 - mean0, t, p: normalPFromT(t) };
+}
+
+function corrTest(columns, feature, outcome = "pfs_months") {
+  const x = columns[feature];
+  const y = columns[outcome];
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0;
+  let syy = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    syy += dy * dy;
+    sxy += dx * dy;
+  }
+  const r = sxy / Math.sqrt(sxx * syy);
+  const t = r * Math.sqrt((x.length - 2) / (1 - r * r));
+  const sx = Math.sqrt(sxx / (x.length - 1));
+  const sy = Math.sqrt(syy / (x.length - 1));
