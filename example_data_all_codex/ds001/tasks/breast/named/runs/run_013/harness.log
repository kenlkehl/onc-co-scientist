"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from scipy import stats

path='dataset.parquet'
df=pd.read_parquet(path)
print(df.shape)
print(df.dtypes.to_string())
print('\\nPFS summary')
print(df['pfs_months'].describe())
print('\\nFirst rows')
print(df.head().to_string())

binary=[]
cont=[]
for c in df.columns:
    if c=='pfs_months': continue
    vals=df[c].dropna().unique()
    if len(vals)<=2 and set(vals).issubset({0,1,False,True}): binary.append(c)
    else: cont.append(c)
print('\\nbinary', len(binary), binary)
print('cont', len(cont), cont)
print('\\nTreatment prevalences')
for c in [x for x in df.columns if x.startswith('treatment_')]:
    print(c, int(df[c].sum()), df[c].mean())
print('\\nBiomarker prevalences')
for c in ['er_positive','pr_positive','her2_positive','her2_low','brca1_mutation','brca2_mutation','pik3ca_mutation','her2_amplification','met_exon14_skipping','ret_fusion','ros1_fusion']:
    if c in df: print(c, int(df[c].sum()), df[c].mean())

print('\\nTop binary mean differences')
rows=[]
for c in binary:
    y1=df.loc[df[c]==1,'pfs_months']; y0=df.loc[df[c]==0,'pfs_months']
    if len(y1)>1 and len(y0)>1:
        t,p=stats.ttest_ind(y1,y0,equal_var=False)
        rows.append((c,y1.mean()-y0.mean(),p,y1.mean(),y0.mean(),len(y1)))
for r in sorted(rows, key=lambda x: abs(x[1]), reverse=True)[:30]:
    print(r)

print('\\nTop continuous correlations')
rows=[]
for c in cont:
    if c=='pfs_months': continue
    r,p=stats.pearsonr(df[c], df['pfs_months'])
    rows.append((c,r,p,df[c].mean(),df[c].std()))
for r in sorted(rows, key=lambda x: abs(x[1]), reverse=True)[:30]:
    print(r)
