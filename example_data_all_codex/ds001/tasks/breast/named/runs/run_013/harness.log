+function decodeRleBitpacked(buffer, bitWidth, count, offset = 0, length = buffer.length - offset) {
+  const end = offset + length;
+  const values = [];
+  let pos = offset;
+  function readVarint() {
+    let shift = 0;
+    let value = 0;
+    while (true) {
+      const b = buffer[pos++];
+      value += (b & 0x7f) * 2 ** shift;
+      if ((b & 0x80) === 0) return value;
+      shift += 7;
+    }
+  }
+  while (values.length < count && pos < end) {
+    const header = readVarint();
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      const bytesForValue = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < bytesForValue; i++) value |= buffer[pos++] << (8 * i);
+      for (let i = 0; i < runLength && values.length < count; i++) values.push(value);
