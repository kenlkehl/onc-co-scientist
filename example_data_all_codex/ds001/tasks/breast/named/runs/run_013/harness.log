+function ols(y, terms) {
+  const n = y.length;
+  const names = ["Intercept", ...terms.map((t) => t.name)];
+  const X = Array.from({ length: n }, (_, i) => [1, ...terms.map((t) => t.values[i])]);
+  const { xtx, xty } = transposeMultiply(X, y);
+  const inv = invert(xtx);
+  const beta = matVec(inv, xty);
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < beta.length; j++) pred += X[i][j] * beta[j];
+    rss += (y[i] - pred) ** 2;
+  }
+  const sigma2 = rss / (n - beta.length);
+  const rows = names.map((name, i) => {
+    const se = Math.sqrt(sigma2 * inv[i][i]);
+    const t = beta[i] / se;
+    return { name, beta: beta[i], se, t, p: normalPFromT(t) };
+  });
+  return { names, beta, rows, rss, sigma2, df: n - beta.length };
+}
+
+function term(columns, name, transform = (x) => x) {
+  return { name, values: columns[name].map(transform) };
+}
+
+function centeredTerm(columns, name) {
+  const m = mean(columns[name]);
+  return { name, values: columns[name].map((x) => x - m), center: m };
+}
+
+function interaction(name, a, b) {
+  return { name, values: a.values.map((x, i) => x * b.values[i]) };
+}
+
+function subsetDiff(columns, feature, subgroupFeature, subgroupValue, outcome = "pfs_months") {
+  const x = columns[feature];
+  const g = columns[subgroupFeature];
+  const y = columns[outcome];
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) {
+    if (g[i] === subgroupValue) (x[i] ? a : b).push(y[i]);
+  }
+  const mean1 = mean(a);
+  const mean0 = mean(b);
+  const v1 = variance(a, mean1);
+  const v0 = variance(b, mean0);
+  const se = Math.sqrt(v1 / a.length + v0 / b.length);
+  const t = (mean1 - mean0) / se;
+  return { feature, subgroupFeature, subgroupValue, n1: a.length, n0: b.length, mean1, mean0, effect: mean1 - mean0, t, p: normalPFromT(t) };
+}
+
+function fmtP(p) {
+  if (p < 1e-250) return "<1e-250";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toPrecision(3);
+}
+
+function round(x, digits = 4) {
+  return Number(x.toFixed(digits));
+}
+
+function bh(rows) {
+  const sorted = rows.map((r, i) => ({ ...r, originalIndex: i })).sort((a, b) => a.p - b.p);
+  let minQ = 1;
+  for (let i = sorted.length - 1; i >= 0; i--) {
+    minQ = Math.min(minQ, (sorted[i].p * sorted.length) / (i + 1));
+    sorted[i].q = Math.min(1, minQ);
+  }
+  return sorted.sort((a, b) => a.originalIndex - b.originalIndex);
+}
