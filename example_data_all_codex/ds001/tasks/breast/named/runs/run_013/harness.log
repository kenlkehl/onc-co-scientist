+  const values = [];
+  let offset = dataPageOffset;
+  while (values.length < totalValues) {
+    const { value: pageHeader, bytesRead } = compactStruct(fileBuffer, offset);
+    const bodyStart = offset + bytesRead;
+    const compressedSize = pageHeader[3];
+    let body = fileBuffer.subarray(bodyStart, bodyStart + compressedSize);
+    if (codec === 1) body = snappyDecompress(body);
+    const pageType = pageHeader[1];
+    if (pageType !== 0) throw new Error(`Unsupported page type ${pageType}`);
+    const dataHeader = pageHeader[5];
+    const numValues = dataHeader[1];
+    const encoding = dataHeader[2];
