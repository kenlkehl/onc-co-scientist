+function readColumn(fileBuffer, columnChunk) {
+  const metadata = columnChunk[3];
+  const type = metadata[1];
+  const codec = metadata[4];
+  const totalValues = metadata[5];
+  const dataPageOffset = metadata[9];
+  const dictionaryPageOffset = metadata[11];
+  let dictionary = null;
