+  const values = [];
+  let offset = dataPageOffset;
+  while (values.length < totalValues) {
+    const { value: pageHeader, bytesRead } = compactStruct(fileBuffer, offset);
+    const bodyStart = offset + bytesRead;
+    const compressedSize = pageHeader[3];
+    let body = fileBuffer.subarray(bodyStart, bodyStart + compressedSize);
+    if (codec === 1) body = snappyDecompress(body);
+    const pageType = pageHeader[1];
+    if (pageType !== 0) throw new Error(`Unsupported page type ${pageType}`);
+    const dataHeader = pageHeader[5];
+    const numValues = dataHeader[1];
+    const encoding = dataHeader[2];
+
+    let pos = 0;
+    const defLen = body.readUInt32LE(pos);
+    pos += 4;
+    const defLevels = decodeRleBitpacked(body, 1, numValues, pos, defLen).values;
+    pos += defLen;
+    const present = defLevels.reduce((a, x) => a + (x ? 1 : 0), 0);
+
+    let pageValues;
+    if (encoding === 8) {
+      if (!dictionary) throw new Error("Dictionary encoding without dictionary page");
+      const bitWidth = body[pos++];
+      const decoded = decodeRleBitpacked(body, bitWidth, present, pos);
+      pageValues = decoded.values.map((idx) => dictionary[idx]);
+    } else if (encoding === 0) {
+      pageValues = readPlainValues(type, body.subarray(pos), present);
+    } else {
+      throw new Error(`Unsupported data encoding ${encoding}`);
+    }
+
+    let valuePos = 0;
+    for (const level of defLevels) values.push(level ? pageValues[valuePos++] : null);
+    offset = bodyStart + compressedSize;
+  }
+  return values;
+}
+
+function loadDataset(path) {
+  const fileBuffer = fs.readFileSync(path);
+  const metadata = readParquetMetadata(fileBuffer);
+  const schema = metadata[2].slice(1).map((s) => ({ name: utf8(s[4]), type: s[1] }));
+  const rowGroup = metadata[4][0];
+  const columns = {};
+  for (let i = 0; i < schema.length; i++) {
+    const name = schema[i].name;
+    columns[name] = readColumn(fileBuffer, rowGroup[1][i]);
+  }
+  return { metadata, schema, columns, n: metadata[3] };
+}
+
+function mean(arr) {
+  return arr.reduce((a, b) => a + b, 0) / arr.length;
+}
+
+function variance(arr, mu = mean(arr)) {
+  let s = 0;
+  for (const x of arr) s += (x - mu) ** 2;
+  return s / (arr.length - 1);
+}
+
+function sd(arr) {
+  return Math.sqrt(variance(arr));
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function normalPFromT(t) {
+  const z = Math.abs(t);
+  if (z > 37) return 1e-300;
+  const p = 2 * (1 - normalCdf(z));
+  return Math.max(p, 1e-300);
+}
+
+function diffTest(columns, feature, outcome = "pfs_months") {
+  const x = columns[feature];
+  const y = columns[outcome];
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) (x[i] ? a : b).push(y[i]);
+  const mean1 = mean(a);
+  const mean0 = mean(b);
+  const v1 = variance(a, mean1);
+  const v0 = variance(b, mean0);
+  const se = Math.sqrt(v1 / a.length + v0 / b.length);
+  const t = (mean1 - mean0) / se;
+  return { feature, n1: a.length, n0: b.length, mean1, mean0, effect: mean1 - mean0, t, p: normalPFromT(t) };
+}
+
+function corrTest(columns, feature, outcome = "pfs_months") {
+  const x = columns[feature];
+  const y = columns[outcome];
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0;
+  let syy = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    syy += dy * dy;
+    sxy += dx * dy;
+  }
+  const r = sxy / Math.sqrt(sxx * syy);
+  const t = r * Math.sqrt((x.length - 2) / (1 - r * r));
+  const sx = Math.sqrt(sxx / (x.length - 1));
+  const sy = Math.sqrt(syy / (x.length - 1));
+  const slope = r * sy / sx;
+  return { feature, r, slope, t, p: normalPFromT(t) };
