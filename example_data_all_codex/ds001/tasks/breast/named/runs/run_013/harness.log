+function loadDataset(path) {
+  const fileBuffer = fs.readFileSync(path);
+  const metadata = readParquetMetadata(fileBuffer);
+  const schema = metadata[2].slice(1).map((s) => ({ name: utf8(s[4]), type: s[1] }));
+  const rowGroup = metadata[4][0];
+  const columns = {};
+  for (let i = 0; i < schema.length; i++) {
+    const name = schema[i].name;
+    columns[name] = readColumn(fileBuffer, rowGroup[1][i]);
+  }
+  return { metadata, schema, columns, n: metadata[3] };
+}
+
+function mean(arr) {
+  return arr.reduce((a, b) => a + b, 0) / arr.length;
+}
+
+function variance(arr, mu = mean(arr)) {
+  let s = 0;
+  for (const x of arr) s += (x - mu) ** 2;
+  return s / (arr.length - 1);
+}
+
+function sd(arr) {
+  return Math.sqrt(variance(arr));
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function normalPFromT(t) {
+  const z = Math.abs(t);
+  if (z > 37) return 1e-300;
+  const p = 2 * (1 - normalCdf(z));
+  return Math.max(p, 1e-300);
+}
+
+function diffTest(columns, feature, outcome = "pfs_months") {
+  const x = columns[feature];
+  const y = columns[outcome];
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) (x[i] ? a : b).push(y[i]);
+  const mean1 = mean(a);
+  const mean0 = mean(b);
+  const v1 = variance(a, mean1);
+  const v0 = variance(b, mean0);
+  const se = Math.sqrt(v1 / a.length + v0 / b.length);
+  const t = (mean1 - mean0) / se;
+  return { feature, n1: a.length, n0: b.length, mean1, mean0, effect: mean1 - mean0, t, p: normalPFromT(t) };
+}
+
+function corrTest(columns, feature, outcome = "pfs_months") {
+  const x = columns[feature];
+  const y = columns[outcome];
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0;
+  let syy = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxx += dx * dx;
+    syy += dy * dy;
+    sxy += dx * dy;
+  }
+  const r = sxy / Math.sqrt(sxx * syy);
+  const t = r * Math.sqrt((x.length - 2) / (1 - r * r));
+  const sx = Math.sqrt(sxx / (x.length - 1));
+  const sy = Math.sqrt(syy / (x.length - 1));
+  const slope = r * sy / sx;
+  return { feature, r, slope, t, p: normalPFromT(t) };
+}
+
+function transposeMultiply(X, y) {
+  const p = X[0].length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < X.length; i++) {
+    for (let j = 0; j < p; j++) {
+      xty[j] += X[i][j] * y[i];
+      for (let k = j; k < p; k++) xtx[j][k] += X[i][j] * X[i][k];
+    }
+  }
+  for (let j = 0; j < p; j++) for (let k = 0; k < j; k++) xtx[j][k] = xtx[k][j];
+  return { xtx, xty };
+}
+
+function invert(matrix) {
+  const n = matrix.length;
+  const a = matrix.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(a[r][col]) > Math.abs(a[pivot][col])) pivot = r;
+    if (Math.abs(a[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    [a[col], a[pivot]] = [a[pivot], a[col]];
+    const div = a[col][col];
+    for (let c = 0; c < 2 * n; c++) a[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = a[r][col];
+      for (let c = 0; c < 2 * n; c++) a[r][c] -= factor * a[col][c];
+    }
+  }
+  return a.map((row) => row.slice(n));
+}
+
+function matVec(matrix, vector) {
+  return matrix.map((row) => row.reduce((s, v, i) => s + v * vector[i], 0));
+}
+
+function ols(y, terms) {
+  const n = y.length;
+  const names = ["Intercept", ...terms.map((t) => t.name)];
+  const X = Array.from({ length: n }, (_, i) => [1, ...terms.map((t) => t.values[i])]);
+  const { xtx, xty } = transposeMultiply(X, y);
+  const inv = invert(xtx);
+  const beta = matVec(inv, xty);
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < beta.length; j++) pred += X[i][j] * beta[j];
+    rss += (y[i] - pred) ** 2;
+  }
+  const sigma2 = rss / (n - beta.length);
+  const rows = names.map((name, i) => {
+    const se = Math.sqrt(sigma2 * inv[i][i]);
+    const t = beta[i] / se;
+    return { name, beta: beta[i], se, t, p: normalPFromT(t) };
+  });
+  return { names, beta, rows, rss, sigma2, df: n - beta.length };
+}
+
+function term(columns, name, transform = (x) => x) {
+  return { name, values: columns[name].map(transform) };
+}
+
+function centeredTerm(columns, name) {
+  const m = mean(columns[name]);
+  return { name, values: columns[name].map((x) => x - m), center: m };
+}
+
+function interaction(name, a, b) {
+  return { name, values: a.values.map((x, i) => x * b.values[i]) };
+}
+
+function subsetDiff(columns, feature, subgroupFeature, subgroupValue, outcome = "pfs_months") {
+  const x = columns[feature];
+  const g = columns[subgroupFeature];
+  const y = columns[outcome];
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) {
+    if (g[i] === subgroupValue) (x[i] ? a : b).push(y[i]);
+  }
+  const mean1 = mean(a);
+  const mean0 = mean(b);
+  const v1 = variance(a, mean1);
+  const v0 = variance(b, mean0);
+  const se = Math.sqrt(v1 / a.length + v0 / b.length);
+  const t = (mean1 - mean0) / se;
+  return { feature, subgroupFeature, subgroupValue, n1: a.length, n0: b.length, mean1, mean0, effect: mean1 - mean0, t, p: normalPFromT(t) };
+}
+
+function fmtP(p) {
+  if (p < 1e-250) return "<1e-250";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toPrecision(3);
+}
+
+function round(x, digits = 4) {
+  return Number(x.toFixed(digits));
+}
+
+function bh(rows) {
+  const sorted = rows.map((r, i) => ({ ...r, originalIndex: i })).sort((a, b) => a.p - b.p);
+  let minQ = 1;
+  for (let i = sorted.length - 1; i >= 0; i--) {
+    minQ = Math.min(minQ, (sorted[i].p * sorted.length) / (i + 1));
+    sorted[i].q = Math.min(1, minQ);
+  }
+  return sorted.sort((a, b) => a.originalIndex - b.originalIndex);
+}
+
+function summarizeExploration(columns, schema) {
+  const y = columns.pfs_months;
+  const ignore = new Set(["patient_id", "pfs_months"]);
+  const binary = [];
+  const continuous = [];
+  for (const { name } of schema) {
+    if (ignore.has(name)) continue;
+    const vals = columns[name];
+    const unique = Array.from(new Set(vals));
+    if (unique.length === 2 && unique.includes(0) && unique.includes(1)) binary.push(name);
+    else continuous.push(name);
+  }
+  const binaryResults = binary.map((name) => diffTest(columns, name));
+  const continuousResults = continuous.map((name) => corrTest(columns, name));
+  console.log("n", y.length);
+  console.log("pfs", { mean: mean(y), sd: sd(y), min: Math.min(...y), max: Math.max(...y) });
+  console.log("binary", binary.length, binary);
+  console.log("continuous", continuous.length, continuous);
+  console.log("top binary effects");
+  for (const r of binaryResults.slice().sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect)).slice(0, 30)) {
+    console.log(r.feature, "effect", r.effect.toFixed(4), "mean1", r.mean1.toFixed(3), "mean0", r.mean0.toFixed(3), "n1", r.n1, "p", fmtP(r.p));
+  }
+  console.log("top continuous correlations");
+  for (const r of continuousResults.slice().sort((a, b) => Math.abs(b.r) - Math.abs(a.r)).slice(0, 30)) {
+    console.log(r.feature, "slope", r.slope.toFixed(4), "r", r.r.toFixed(4), "p", fmtP(r.p));
+  }
+}
+
+function generateOutputs() {
