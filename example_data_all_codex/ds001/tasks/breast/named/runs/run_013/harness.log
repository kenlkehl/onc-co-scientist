+    let body = fileBuffer.subarray(bodyStart, bodyStart + pageHeader[3]);
+    if (codec === 1) body = snappyDecompress(body);
+    const dictionaryHeader = pageHeader[7];
+    dictionary = readPlainValues(type, body, dictionaryHeader[1]);
+  }
