  zigzag(n){ return (n >> 1n) ''^ (-(n & 1n)); }
  readI32(){ return Number(this.zigzag(this.readVarint())); }
  readI64(){ return this.zigzag(this.readVarint()); }
  readDouble(){ const v=this.b.readDoubleLE(this.i); this.i+=8; return v; }
  readBinary(){ const len=Number(this.readVarint()); const s=this.b.subarray(this.i,this.i+len); this.i+=len; return s.toString('"'utf8'); }
