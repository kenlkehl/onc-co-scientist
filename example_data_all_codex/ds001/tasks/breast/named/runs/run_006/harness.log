function makeAnalysis(h){let c,extra={};if(h.type==='main'){c=main.coef[h.term];extra.code='Adjusted OLS: pfs_months ~ clinical, biomarker, metastatic-site, laboratory, and treatment covariates; coefficient extracted for '+h.term+'.';extra.result_summary="'`Adjusted coefficient for ${h.label}: ${fmt(c.beta)} months (SE ${c.se.toFixed(3)}, p=${pf(c.p_value)}); result was ${sig(c)}.`;extra.model='"'adjusted ordinary least squares'}else{const ic=inter(h.a,h.b,h.remove||[]);c=ic.coef;extra.code="'`Adjusted OLS: pfs_months ~ covariates + ${h.a} + ${h.b} + ${ic.name}; coefficient extracted for interaction term.`;extra.result_summary=`Adjusted interaction coefficient for ${ic.name}: ${fmt(c.beta)} months (SE ${c.se.toFixed(3)}, p=${pf(c.p_value)}); result was ${sig(c)}.`;extra.model='"'adjusted ordinary least squares with interaction term';if(ic.subgroup)extra.crude_subgroup_means=ic.subgroup}if("'!Number.isFinite(c.beta)||!Number.isFinite(c.p_value))throw Error('"'bad result '+h.id);return Object.assign({hypothesis_ids:[h.id],p_value:c.p_value,effect_estimate:c.beta,significant:c.significant,standard_error:c.se,z_statistic:c.z},extra)}
