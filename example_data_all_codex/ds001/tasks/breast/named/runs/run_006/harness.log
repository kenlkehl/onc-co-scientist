function ols(yName,features){const y=df[yName],cols=features.map(f=>Array.isArray(f)?f[1]:df[f]);for(let j=0;j<cols.length;j++)if("'!cols[j])throw Error('"'missing feature '+features[j]);const p=cols.length+1,xtx=Array.from({length:p},()=>Array(p).fill(0)),xty=Array(p).fill(0);let ysum=0;for(let i=0;i<N;i++){const x=[1];for(const col of cols)x.push(col[i]);const yi=y[i];ysum+=yi;for(let j=0;j<p;j++){if("'!Number.isFinite(x[j]))throw Error('"'bad x '+j);xty[j]+=x[j]*yi;for(let k=0;k<=j;k++)xtx[j][k]+=x[j]*x[k]}}for(let j=0;j<p;j++)for(let k=0;k<j;k++)xtx[k][j]=xtx[j][k];const xtxi=invert(xtx),beta=xtxi.map(row=>row.reduce((s,v,j)=>s+v*xty[j],0));let sse=0,tss=0,ybar=ysum/N;for(let i=0;i<N;i++){let pred=beta[0];for(let j=0;j<cols.length;j++)pred+=beta[j+1]*cols[j][i];const e=y[i]-pred;sse+=e*e;const dy=y[i]-ybar;tss+=dy*dy}const sig2=sse/(N-p),labels=['(Intercept)',...features.map(f=>Array.isArray(f)?f[0]:f)],coef={};for(let j=0;j<p;j++){const se=Math.sqrt(Math.max(0,sig2*xtxi[j][j])),z=beta[j]/se,pv=pValue(z);if("'!Number.isFinite(beta[j])||!Number.isFinite(se))throw Error('"'non-finite coef '+labels[j]);coef[labels[j]]={beta:beta[j],se,z,p_value:pv,significant:pv<0.05}}return{coef,r2:1-sse/tss,sigma:Math.sqrt(sig2),df:N-p}}
