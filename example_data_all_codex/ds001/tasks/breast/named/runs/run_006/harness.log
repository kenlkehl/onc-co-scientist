const summary=[];summary.push(`Dataset ds001_breast contained 50,000 breast oncology records with no missing values. The outcome '"\\"'`pfs_months'"\\"'` ranged from ${yMin.toFixed(2)} to ${yMax.toFixed(2)} months with mean ${yMean.toFixed(2)} months. I used adjusted ordinary least squares models for '"\\"'`pfs_months'"\\"'`; coefficient tests use large-sample normal approximations. The common adjustment set included age, sex, ECOG performance status, stage, receptor and mutation features, tumor burden and metastatic sites, inflammatory/nutritional laboratory markers, and treatment indicators. Interaction models added both main effects and the specified product term.`);
summary.push('"'The prognostic pass showed strong independent structure. '+[line('h1','Older age per 10 years'),line('h2','Higher ECOG performance status'),line('h3','Stage IV disease'),line('h4','Brain metastases'),line('h5','Weight loss per 5 percentage points'),line('h6','Albumin per 1 g/dL'),line('h7','Ki-67 per 10 percentage points'),line('h8','PIK3CA mutation'),line('h9','ER positivity'),line('h10','HER2 positivity'),line('h11','LDH per 100 U/L')].join(' '));
summary.push('These results support longer PFS with older age, ER positivity, and higher albumin, and shorter PFS with worse ECOG status, stage IV disease, brain metastases, higher weight loss, higher Ki-67, PIK3CA mutation, HER2 positivity, and higher LDH. The largest adjusted non-treatment effects were age, ECOG, stage IV status, and brain metastases.');
summary.push('Treatment analyses were dominated by palbociclib. '+[line('h12','Palbociclib main effect'),line('h13','Palbociclib by ER-positive interaction'),line('h14','Palbociclib by PR-positive interaction'),line('h15','Palbociclib by PIK3CA mutation interaction'),line('h16','Palbociclib by above-median Ki-67 interaction'),line('h17','Palbociclib by HER2-positive interaction'),line('h18','Palbociclib by triple-negative interaction'),line('h19','Palbociclib by HER2-low interaction')].join(' '));
summary.push('The palbociclib pattern is internally consistent: the average adjusted association was strongly positive, but the benefit was concentrated in hormone-receptor-positive disease and reduced in PIK3CA-mutated, high-proliferation, HER2-positive, or triple-negative subgroups. HER2-low status showed a smaller positive interaction.');
summary.push('The remaining treatment-biomarker probes were mixed. '+[line('h20','Sacituzumab govitecan by triple-negative interaction'),line('h21','Sacituzumab govitecan by brain metastases interaction'),line('h22','Pembrolizumab by above-median Ki-67 interaction'),line('h23','Trastuzumab by HER2-positive interaction'),line('h24','Olaparib by any BRCA1/BRCA2 mutation interaction'),line('h25a','Tamoxifen by ER-positive interaction')].join(' '));
