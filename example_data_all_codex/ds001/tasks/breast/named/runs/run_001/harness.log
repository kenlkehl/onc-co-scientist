+  function readVar() {
+    let shift = 0;
+    let res = 0;
+    while (true) {
+      const b = src[ip++];
+      res |= (b & 127) << shift;
+      if ((b & 128) === 0) break;
+      shift += 7;
+    }
+    return res;
+  }
+  const outLen = readVar();
+  const out = Buffer.allocUnsafe(outLen);
+  let op = 0;
+  while (ip < src.length) {
+    const tag = src[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) len += 1;
+      else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= src[ip++] << (8 * i);
+        len += 1;
+      }
+      src.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else if (type === 1) {
+      const len = ((tag >> 2) & 7) + 4;
+      const offset = ((tag & 0xe0) << 3) | src[ip++];
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    } else if (type === 2) {
+      const len = (tag >> 2) + 1;
+      const offset = src[ip] | (src[ip + 1] << 8);
+      ip += 2;
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    } else {
+      const len = (tag >> 2) + 1;
+      const offset = (src[ip] | (src[ip + 1] << 8) | (src[ip + 2] << 16) | (src[ip + 3] << 24)) >>> 0;
+      ip += 4;
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    }
