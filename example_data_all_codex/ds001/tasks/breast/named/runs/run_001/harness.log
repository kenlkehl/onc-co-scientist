+      analyses: [rec("h18", ex.special.palboBestMain.model, `Within the ER-positive/HER2-negative/PIK3CA-wildtype subgroup (n=${ex.special.palboBestMain.n}), palbociclib was associated with +2.920 PFS months (SE 0.020; p<1e-14).`, subsetCode, { subgroup_n: ex.special.palboBestMain.n })],
+    },
