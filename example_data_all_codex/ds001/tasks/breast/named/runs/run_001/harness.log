+      proposed_hypotheses: [hyp("h17", "The positive association of `treatment_palbociclib` with `pfs_months` is larger when `her2_low` equals 1 than when `her2_low` equals 0.", "refined")],
+      analyses: [rec("h17", byInteraction["treatment_palbociclib:her2_low"], "The palbociclib-by-HER2-low interaction was positive: +0.382 months (SE 0.022; p<1e-14).", interactionCode)],
+    },
