+    let fit = beta[0];
+    for (let j = 0; j < terms.length; j++) fit += beta[j + 1] * terms[j].values[i];
+    const e = y[i] - fit;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const inv = inverse(XtX);
+  const out = {};
+  for (let j = 0; j < terms.length; j++) {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[j + 1][j + 1]));
+    const z = beta[j + 1] / se;
+    out[terms[j].name] = { beta: beta[j + 1], se, z, p: pFromZ(z) };
