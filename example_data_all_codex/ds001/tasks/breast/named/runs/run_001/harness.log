+      analyses: [rec("h19", ex.special.palboPik3caInErHer2Neg.model, `Within the ER-positive/HER2-negative subgroup (n=${ex.special.palboPik3caInErHer2Neg.n}), the palbociclib-by-PIK3CA interaction was -2.918 months (SE 0.029; p<1e-14).`, "Adjusted OLS restricted to er_positive=1 and her2_positive=0 with treatment_palbociclib, pik3ca_mutation, and their interaction.", { subgroup_n: ex.special.palboPik3caInErHer2Neg.n })],
+    },
+    {
