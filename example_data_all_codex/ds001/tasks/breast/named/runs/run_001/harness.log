+      else if (fid === 5) o.num_values = this.readVal(t);
+      else if (fid === 6) o.total_uncompressed_size = this.readVal(t);
+      else if (fid === 7) o.total_compressed_size = this.readVal(t);
+      else if (fid === 9) o.data_page_offset = this.readVal(t);
+      else if (fid === 11) o.dictionary_page_offset = this.readVal(t);
