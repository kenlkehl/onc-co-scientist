+}
+
+function complementProduct(data, vars) {
+  const n = data.pfs_months.length;
+  const out = new Array(n);
+  for (let i = 0; i < n; i++) {
+    let v = 1;
+    for (const name of vars) v *= 1 - data[name][i];
+    out[i] = v;
+  }
+  return out;
+}
+
+function diffMeans(data, groupName, yName = "pfs_months") {
+  const x = data[groupName];
+  const y = data[yName];
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i]) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1, m0 = s0 / n0;
+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
