+class CompactReader {
+  constructor(buf, off = 0) {
+    this.buf = buf;
+    this.p = off;
+  }
+  readByte() {
+    return this.buf[this.p++];
+  }
+  readVarint() {
+    let shift = 0n;
+    let res = 0n;
