+function runExploration() {
+  const data = loadData();
+  const y = data.pfs_months;
+  const names = Object.keys(data).filter((k) => k !== "pfs_months");
+  const binary = names.filter((k) => data[k].every((v) => v === 0 || v === 1));
+  const continuous = names.filter((k) => !binary.includes(k));
+  const isVarying = (name) => variance(data[name]) > 1e-12;
+  const treatment = binary.filter((k) => k.startsWith("treatment_") && isVarying(k));
+  const coreNames = [
+    "age_years", "sex_female", "ecog_ps", "stage_iv", "has_brain_mets",
+    "node_positive", "er_positive", "pr_positive", "her2_positive",
+    "brca1_mutation", "brca2_mutation", "pik3ca_mutation", "ki67_pct",
+    "tumor_size_cm", "albumin_g_dl", "ldh_u_l", "weight_loss_pct_6mo",
+    "crp_mg_l", "nlr", "liver_mets", "bone_mets", "pleural_effusion",
+  ];
+  const coreTerms = [];
+  for (const name of coreNames) {
+    if (!isVarying(name)) continue;
+    const vals = continuous.includes(name) ? zscore(data[name]) : data[name];
+    coreTerms.push({ name, values: vals });
+  }
+  const mainNames = [
+    ...coreNames,
+    ...treatment,
+    "treatment_tamoxifen", "treatment_palbociclib", "treatment_trastuzumab",
+    "treatment_olaparib", "treatment_sacituzumab_govitecan", "treatment_pembrolizumab",
+    "postmenopausal", "her2_low", "her2_amplification", "adrenal_mets",
+    "pericardial_effusion", "contralateral_lung_mets", "autoimmune_disease",
+    "chronic_kidney_disease", "heart_failure", "prior_malignancy",
+    "interstitial_lung_disease_history", "hemoglobin_g_dl", "alkaline_phosphatase_u_l",
+    "ast_u_l", "alt_u_l", "total_bilirubin_mg_dl", "creatinine_mg_dl",
+    "sodium_meq_l", "calcium_mg_dl", "glucose_mg_dl", "platelets_k_ul",
+    "wbc_k_ul", "anc_k_ul", "alc_k_ul", "cea_ng_ml", "bmi", "spo2_pct",
+  ].filter((v, i, a) => names.includes(v) && isVarying(v) && a.indexOf(v) === i);
+  const allMainTerms = [];
+  for (const name of mainNames) {
+    allMainTerms.push({ name, values: continuous.includes(name) ? zscore(data[name]) : data[name] });
+  }
+  const mainModel = ols(y, allMainTerms);
+  const mainRank = mainNames.map((name) => ({ name, ...mainModel[name] })).sort((a, b) => Math.abs(b.beta / b.se) - Math.abs(a.beta / a.se));
+
+  const interactionCandidates = [
+    "er_positive", "pr_positive", "her2_positive", "her2_low", "her2_amplification",
+    "brca1_mutation", "brca2_mutation", "pik3ca_mutation", "stage_iv", "has_brain_mets",
+    "liver_mets", "bone_mets", "pleural_effusion", "autoimmune_disease",
+    "postmenopausal", "node_positive",
+  ];
+  const interactions = [];
+  for (const trt of treatment) {
+    for (const mod of interactionCandidates) {
+      if (trt === mod) continue;
+      const intName = `${trt}:${mod}`;
+      const terms = coreTerms.filter((t) => t.name !== trt && t.name !== mod).slice();
+      terms.push({ name: trt, values: data[trt] });
+      terms.push({ name: mod, values: data[mod] });
+      terms.push({ name: intName, values: prod(data[trt], data[mod]) });
+      try {
