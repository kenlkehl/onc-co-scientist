+class CompactReader {
+  constructor(buf, off = 0) {
+    this.buf = buf;
+    this.p = off;
+  }
+  readByte() {
+    return this.buf[this.p++];
+  }
+  readVarint() {
+    let shift = 0n;
+    let res = 0n;
+    while (true) {
+      const b = this.readByte();
+      res |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zig(n) {
+    return (n >> 1n) ^ -(n & 1n);
+  }
+  readI32() {
+    return Number(this.zig(this.readVarint()));
+  }
+  readI64() {
+    return Number(this.zig(this.readVarint()));
+  }
+  readBin() {
+    const len = Number(this.readVarint());
+    const b = this.buf.subarray(this.p, this.p + len);
+    this.p += len;
+    return b;
+  }
+  readVal(type) {
+    if (type === 4 || type === 5) return this.readI32();
+    if (type === 6) return this.readI64();
+    if (type === 7) {
+      const v = this.buf.readDoubleLE(this.p);
+      this.p += 8;
+      return v;
+    }
+    if (type === 8) return this.readBin().toString();
+    throw new Error(`Unsupported compact value type ${type} at ${this.p}`);
+  }
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.p++;
+        return;
+      case 4:
+      case 5:
+        this.readI32();
+        return;
+      case 6:
+        this.readI64();
+        return;
+      case 7:
+        this.p += 8;
+        return;
+      case 13:
+        this.p += 4;
+        return;
+      case 8:
+        this.readBin();
+        return;
+      case 9:
+      case 10: {
+        const h = this.readByte();
+        let n = h >> 4;
+        const et = h & 15;
+        if (n === 15) n = Number(this.readVarint());
+        for (let i = 0; i < n; i++) this.skip(et);
+        return;
+      }
+      case 11: {
+        const n = Number(this.readVarint());
+        if (n === 0) return;
+        const types = this.readByte();
+        const kt = types >> 4;
+        const vt = types & 15;
+        for (let i = 0; i < n; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12:
