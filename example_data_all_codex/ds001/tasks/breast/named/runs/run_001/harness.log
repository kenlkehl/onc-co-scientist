+  const palboBest = data.er_positive.map((v, i) => (v === 1 && data.her2_positive[i] === 0 && data.pik3ca_mutation[i] === 0) ? 1 : 0);
+  data.er_positive_her2_negative_pik3ca_wildtype = palboBest;
