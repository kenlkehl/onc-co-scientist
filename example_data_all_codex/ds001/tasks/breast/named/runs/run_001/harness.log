+    for (let j = k; j <= n; j++) M[k][j] /= pv;
+    for (let i = 0; i < n; i++) {
+      if (i === k) continue;
+      const f = M[i][k];
+      if (f === 0) continue;
+      for (let j = k; j <= n; j++) M[i][j] -= f * M[k][j];
