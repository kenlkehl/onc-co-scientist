+  for (const k of Object.keys(acc)) acc[k].mean = acc[k].s / acc[k].n;
+  return {
+    subgroup1Effect: acc.g1t1.mean - acc.g1t0.mean,
+    subgroup0Effect: acc.g0t1.mean - acc.g0t0.mean,
+    cells: acc,
+  };
+}
+
+function runExploration() {
+  const data = loadData();
+  const y = data.pfs_months;
+  const names = Object.keys(data).filter((k) => k !== "pfs_months");
+  const binary = names.filter((k) => data[k].every((v) => v === 0 || v === 1));
+  const continuous = names.filter((k) => !binary.includes(k));
+  const isVarying = (name) => variance(data[name]) > 1e-12;
+  const treatment = binary.filter((k) => k.startsWith("treatment_") && isVarying(k));
+  const coreNames = [
+    "age_years", "sex_female", "ecog_ps", "stage_iv", "has_brain_mets",
+    "node_positive", "er_positive", "pr_positive", "her2_positive",
+    "brca1_mutation", "brca2_mutation", "pik3ca_mutation", "ki67_pct",
+    "tumor_size_cm", "albumin_g_dl", "ldh_u_l", "weight_loss_pct_6mo",
+    "crp_mg_l", "nlr", "liver_mets", "bone_mets", "pleural_effusion",
+  ];
+  const coreTerms = [];
+  for (const name of coreNames) {
+    if (!isVarying(name)) continue;
+    const vals = continuous.includes(name) ? zscore(data[name]) : data[name];
+    coreTerms.push({ name, values: vals });
+  }
+  const mainNames = [
+    ...coreNames,
+    ...treatment,
+    "treatment_tamoxifen", "treatment_palbociclib", "treatment_trastuzumab",
+    "treatment_olaparib", "treatment_sacituzumab_govitecan", "treatment_pembrolizumab",
+    "postmenopausal", "her2_low", "her2_amplification", "adrenal_mets",
+    "pericardial_effusion", "contralateral_lung_mets", "autoimmune_disease",
+    "chronic_kidney_disease", "heart_failure", "prior_malignancy",
+    "interstitial_lung_disease_history", "hemoglobin_g_dl", "alkaline_phosphatase_u_l",
+    "ast_u_l", "alt_u_l", "total_bilirubin_mg_dl", "creatinine_mg_dl",
+    "sodium_meq_l", "calcium_mg_dl", "glucose_mg_dl", "platelets_k_ul",
+    "wbc_k_ul", "anc_k_ul", "alc_k_ul", "cea_ng_ml", "bmi", "spo2_pct",
+  ].filter((v, i, a) => names.includes(v) && isVarying(v) && a.indexOf(v) === i);
+  const allMainTerms = [];
+  for (const name of mainNames) {
+    allMainTerms.push({ name, values: continuous.includes(name) ? zscore(data[name]) : data[name] });
+  }
+  const mainModel = ols(y, allMainTerms);
+  const mainRank = mainNames.map((name) => ({ name, ...mainModel[name] })).sort((a, b) => Math.abs(b.beta / b.se) - Math.abs(a.beta / a.se));
+
+  const interactionCandidates = [
+    "er_positive", "pr_positive", "her2_positive", "her2_low", "her2_amplification",
+    "brca1_mutation", "brca2_mutation", "pik3ca_mutation", "stage_iv", "has_brain_mets",
+    "liver_mets", "bone_mets", "pleural_effusion", "autoimmune_disease",
+    "postmenopausal", "node_positive",
+  ];
+  const interactions = [];
+  for (const trt of treatment) {
+    for (const mod of interactionCandidates) {
+      if (trt === mod) continue;
+      const intName = `${trt}:${mod}`;
+      const terms = coreTerms.filter((t) => t.name !== trt && t.name !== mod).slice();
+      terms.push({ name: trt, values: data[trt] });
+      terms.push({ name: mod, values: data[mod] });
+      terms.push({ name: intName, values: prod(data[trt], data[mod]) });
+      try {
+        const model = ols(y, terms);
+        const sgd = subgroupDiff(data, trt, mod);
+        interactions.push({ trt, mod, name: intName, ...model[intName], subgroup: sgd });
+      } catch (e) {
+        interactions.push({ trt, mod, error: e.message });
+      }
+    }
+  }
+  interactions.sort((a, b) => Math.abs((b.beta || 0) / (b.se || 1)) - Math.abs((a.beta || 0) / (a.se || 1)));
+
+  const tripleNegative = complementProduct(data, ["er_positive", "pr_positive", "her2_positive"]);
+  data.triple_negative = tripleNegative;
+  const tnTerms = coreTerms.concat([
+    { name: "treatment_pembrolizumab", values: data.treatment_pembrolizumab },
+    { name: "triple_negative", values: tripleNegative },
+    { name: "treatment_pembrolizumab:triple_negative", values: prod(data.treatment_pembrolizumab, tripleNegative) },
+  ]);
+  const tnPembro = ols(y, tnTerms);
+  const sgPembroTn = subgroupDiff(data, "treatment_pembrolizumab", "triple_negative");
+
+  const brcaAny = data.brca1_mutation.map((v, i) => (v || data.brca2_mutation[i]) ? 1 : 0);
+  data.brca_any = brcaAny;
+  const brcaTerms = coreTerms.concat([
+    { name: "treatment_olaparib", values: data.treatment_olaparib },
+    { name: "brca_any", values: brcaAny },
+    { name: "treatment_olaparib:brca_any", values: prod(data.treatment_olaparib, brcaAny) },
+  ]);
+  const olapBrca = ols(y, brcaTerms);
+  const sgOlapBrca = subgroupDiff(data, "treatment_olaparib", "brca_any");
+
+  const her2Either = data.her2_positive.map((v, i) => (v || data.her2_amplification[i]) ? 1 : 0);
+  data.her2_positive_or_amplified = her2Either;
+  const her2Terms = coreTerms.concat([
+    { name: "treatment_trastuzumab", values: data.treatment_trastuzumab },
+    { name: "her2_positive_or_amplified", values: her2Either },
+    { name: "treatment_trastuzumab:her2_positive_or_amplified", values: prod(data.treatment_trastuzumab, her2Either) },
+  ]);
+  const trastHer2 = ols(y, her2Terms);
+  const sgTrastHer2 = subgroupDiff(data, "treatment_trastuzumab", "her2_positive_or_amplified");
+
+  const exploratory = {
+    n: y.length,
+    pfs: { mean: mean(y), sd: sd(y), min: Math.min(...y), max: Math.max(...y) },
+    binaryPrevalence: Object.fromEntries(binary.map((b) => [b, mean(data[b])])),
+    continuousSummary: Object.fromEntries(continuous.map((c) => [c, { mean: mean(data[c]), sd: sd(data[c]) }])),
+    unadjustedBinaryDiffs: Object.fromEntries(binary.map((b) => [b, diffMeans(data, b)])),
+    mainRank: mainRank.slice(0, 40),
+    treatmentMain: Object.fromEntries(treatment.map((t) => [t, mainModel[t]])),
+    selectedMain: Object.fromEntries(["stage_iv", "has_brain_mets", "er_positive", "pik3ca_mutation", "albumin_g_dl", "ldh_u_l", "crp_mg_l", "weight_loss_pct_6mo", "nlr", "ki67_pct", "tumor_size_cm"].map((v) => [v, mainModel[v]])),
+    interactions: interactions.slice(0, 80),
+    special: {
+      pembroTn: { model: tnPembro["treatment_pembrolizumab:triple_negative"], subgroup: sgPembroTn },
+      olapBrca: { model: olapBrca["treatment_olaparib:brca_any"], subgroup: sgOlapBrca },
+      trastHer2: { model: trastHer2["treatment_trastuzumab:her2_positive_or_amplified"], subgroup: sgTrastHer2 },
+    },
+  };
+  fs.writeFileSync("exploration_tmp.json", JSON.stringify(exploratory, null, 2));
+  console.log(JSON.stringify({
+    n: exploratory.n,
+    pfs: exploratory.pfs,
+    topMain: exploratory.mainRank.slice(0, 15),
+    topInteractions: exploratory.interactions.slice(0, 20),
+    special: exploratory.special,
+  }, null, 2));
+}
+
+runExploration();

