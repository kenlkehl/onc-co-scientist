+    if (fid === 1) o.type = this.readVal(t);
+    else if (fid === 2) o.uncompressed_page_size = this.readVal(t);
+    else if (fid === 3) o.compressed_page_size = this.readVal(t);
+    else if (fid === 5) o.data_page_header = dataHeader.call(this);
+    else if (fid === 7) o.dictionary_page_header = dictHeader.call(this);
+    else this.skip(t);
+  });
+  h.header_size = r.p - off;
+  return h;
+}
