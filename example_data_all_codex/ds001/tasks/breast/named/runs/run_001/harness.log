+
+function mean(a) {
+  let s = 0;
+  for (const v of a) s += v;
+  return s / a.length;
+}
+
+function variance(a) {
+  const m = mean(a);
+  let s = 0;
+  for (const v of a) {
+    const d = v - m;
+    s += d * d;
+  }
+  return s / (a.length - 1);
