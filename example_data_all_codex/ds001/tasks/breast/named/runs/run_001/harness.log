+}
+
+function variance(a) {
+  const m = mean(a);
+  let s = 0;
+  for (const v of a) {
+    const d = v - m;
+    s += d * d;
+  }
+  return s / (a.length - 1);
+}
+
+function sd(a) {
+  return Math.sqrt(variance(a));
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
