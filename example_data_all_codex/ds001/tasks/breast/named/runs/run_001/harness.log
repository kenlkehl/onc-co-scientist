+function readHybrid(buf, pos, bw, count) {
+  const vals = [];
+  let p = pos;
+  while (vals.length < count) {
+    const tmp = readUVar(buf, p);
+    const header = tmp[0];
+    p = tmp[1];
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const bytes = Math.ceil(bw / 8);
+      let val = 0;
+      for (let i = 0; i < bytes; i++) val |= buf[p++] << (8 * i);
+      for (let i = 0; i < run && vals.length < count; i++) vals.push(val);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bits = 0;
+      let bitbuf = 0;
+      for (let i = 0; i < total; i++) {
