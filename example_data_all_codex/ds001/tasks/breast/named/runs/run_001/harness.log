+const fs = require("fs");
+
+const file = fs.readFileSync("dataset.parquet");
+
+class CompactReader {
+  constructor(buf, off = 0) {
+    this.buf = buf;
+    this.p = off;
+  }
+  readByte() {
+    return this.buf[this.p++];
+  }
+  readVarint() {
+    let shift = 0n;
+    let res = 0n;
+    while (true) {
+      const b = this.readByte();
+      res |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zig(n) {
+    return (n >> 1n) ^ -(n & 1n);
+  }
+  readI32() {
+    return Number(this.zig(this.readVarint()));
+  }
+  readI64() {
+    return Number(this.zig(this.readVarint()));
+  }
+  readBin() {
+    const len = Number(this.readVarint());
+    const b = this.buf.subarray(this.p, this.p + len);
+    this.p += len;
+    return b;
+  }
+  readVal(type) {
+    if (type === 4 || type === 5) return this.readI32();
+    if (type === 6) return this.readI64();
+    if (type === 7) {
+      const v = this.buf.readDoubleLE(this.p);
+      this.p += 8;
+      return v;
+    }
+    if (type === 8) return this.readBin().toString();
+    throw new Error(`Unsupported compact value type ${type} at ${this.p}`);
+  }
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.p++;
+        return;
+      case 4:
+      case 5:
+        this.readI32();
+        return;
+      case 6:
+        this.readI64();
+        return;
+      case 7:
+        this.p += 8;
+        return;
+      case 13:
+        this.p += 4;
+        return;
+      case 8:
+        this.readBin();
+        return;
+      case 9:
+      case 10: {
+        const h = this.readByte();
+        let n = h >> 4;
+        const et = h & 15;
+        if (n === 15) n = Number(this.readVarint());
+        for (let i = 0; i < n; i++) this.skip(et);
+        return;
+      }
+      case 11: {
+        const n = Number(this.readVarint());
+        if (n === 0) return;
+        const types = this.readByte();
+        const kt = types >> 4;
+        const vt = types & 15;
+        for (let i = 0; i < n; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12:
+        this.struct((fid, t) => this.skip(t));
+        return;
+      default:
+        throw new Error(`Unsupported compact skip type ${type} at ${this.p}`);
+    }
+  }
+  list(readElem) {
+    const h = this.readByte();
+    let n = h >> 4;
+    const et = h & 15;
+    if (n === 15) n = Number(this.readVarint());
+    const a = [];
+    for (let i = 0; i < n; i++) a.push(readElem.call(this, et));
+    return a;
+  }
+  struct(fn) {
+    const out = {};
+    let last = 0;
+    while (true) {
+      const b = this.readByte();
+      const type = b & 15;
+      if (type === 0) break;
+      const delta = b >> 4;
+      const fid = delta === 0 ? this.readI32() : last + delta;
+      last = fid;
+      fn.call(this, fid, type, out);
+    }
+    return out;
+  }
+}
+
+function parseMeta() {
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const start = file.length - 8 - footerLen;
+  const r = new CompactReader(file.subarray(start, file.length - 8));
+  function schema() {
+    return this.struct(function (fid, t, o) {
+      if (fid === 1) o.type = this.readVal(t);
+      else if (fid === 2) o.type_length = this.readVal(t);
+      else if (fid === 3) o.repetition_type = this.readVal(t);
+      else if (fid === 4) o.name = this.readVal(t);
+      else if (fid === 5) o.num_children = this.readVal(t);
+      else this.skip(t);
+    });
+  }
+  function colmeta() {
+    return this.struct(function (fid, t, o) {
+      if (fid === 1) o.type = this.readVal(t);
+      else if (fid === 2) o.encodings = this.list(function (et) { return this.readVal(et); });
+      else if (fid === 3) o.path_in_schema = this.list(function (et) { return this.readVal(et); });
+      else if (fid === 4) o.codec = this.readVal(t);
+      else if (fid === 5) o.num_values = this.readVal(t);
+      else if (fid === 6) o.total_uncompressed_size = this.readVal(t);
+      else if (fid === 7) o.total_compressed_size = this.readVal(t);
+      else if (fid === 9) o.data_page_offset = this.readVal(t);
+      else if (fid === 11) o.dictionary_page_offset = this.readVal(t);
+      else this.skip(t);
+    });
+  }
+  function colchunk() {
+    return this.struct(function (fid, t, o) {
+      if (fid === 2) o.file_offset = this.readVal(t);
+      else if (fid === 3) o.meta_data = colmeta.call(this);
+      else this.skip(t);
+    });
+  }
+  function rowgroup() {
+    return this.struct(function (fid, t, o) {
+      if (fid === 1) o.columns = this.list(function () { return colchunk.call(this); });
+      else if (fid === 3) o.num_rows = this.readVal(t);
+      else this.skip(t);
+    });
+  }
+  return r.struct(function (fid, t, o) {
+    if (fid === 1) o.version = this.readVal(t);
+    else if (fid === 2) o.schema = this.list(function () { return schema.call(this); });
+    else if (fid === 3) o.num_rows = this.readVal(t);
+    else if (fid === 4) o.row_groups = this.list(function () { return rowgroup.call(this); });
+    else if (fid === 6) o.created_by = this.readVal(t);
+    else this.skip(t);
+  });
+}
+
+function pageHeaderAt(off) {
+  const r = new CompactReader(file, off);
+  function dataHeader() {
+    return this.struct(function (fid, t, o) {
+      if (fid === 1) o.num_values = this.readVal(t);
+      else if (fid === 2) o.encoding = this.readVal(t);
+      else if (fid === 3) o.definition_level_encoding = this.readVal(t);
+      else if (fid === 4) o.repetition_level_encoding = this.readVal(t);
+      else this.skip(t);
+    });
+  }
