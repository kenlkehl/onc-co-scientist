"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -NoProfile -Command "@'
const fs = require('fs');
const buf = fs.readFileSync('dataset.parquet');
function readUInt32LE(off){return buf.readUInt32LE(off)}
console.log('size', buf.length, 'magic start', buf.subarray(0,4).toString(), 'magic end', buf.subarray(buf.length-4).toString());
const footerLen = readUInt32LE(buf.length-8);
console.log('footerLen', footerLen, 'footerStart', buf.length-8-footerLen);
const meta = buf.subarray(buf.length-8-footerLen, buf.length-8);
let p=0;
function readByte(){ return meta[p++]; }
function readVarint(){ let shift=0n, res=0n; while(true){ const b=readByte(); res |= BigInt(b & 0x7f) << shift; if((b & 0x80)===0) break; shift += 7n; } return res; }
function zigzag(n){ return (n >> 1n) "'^ (-(n & 1n)); }
function readI32(){ return Number(zigzag(readVarint())); }
function readI64(){ return zigzag(readVarint()); }
function readBinary(){ const len=Number(readVarint()); const s=meta.subarray(p,p+len); p+=len; return s; }
function skipVal(type){
  switch(type){
    case 1: case 2: return true;
    case 3: p++; return;
    case 4: readI32(); return;
    case 5: readI32(); return;
    case 6: readI64(); return;
