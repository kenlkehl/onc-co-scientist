+  let p = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === 5) {
+      vals.push(buf.readDoubleLE(p));
+      p += 8;
+    } else if (type === 2) {
+      vals.push(Number(buf.readBigInt64LE(p)));
+      p += 8;
+    } else if (type === 1) {
+      vals.push(buf.readInt32LE(p));
+      p += 4;
+    } else if (type === 6) {
+      const len = buf.readUInt32LE(p);
+      p += 4;
+      vals.push(buf.subarray(p, p + len).toString());
+      p += len;
+    } else {
+      throw new Error(`Unsupported plain type ${type}`);
+    }
+  }
+  return vals;
+}
+
+function readUVar(buf, pos) {
+  let shift = 0;
+  let res = 0;
+  let p = pos;
+  while (true) {
+    const b = buf[p++];
+    res |= (b & 127) << shift;
+    if ((b & 128) === 0) break;
+    shift += 7;
+  }
+  return [res, p];
+}
+
+function readHybrid(buf, pos, bw, count) {
+  const vals = [];
+  let p = pos;
+  while (vals.length < count) {
+    const tmp = readUVar(buf, p);
+    const header = tmp[0];
+    p = tmp[1];
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const bytes = Math.ceil(bw / 8);
+      let val = 0;
+      for (let i = 0; i < bytes; i++) val |= buf[p++] << (8 * i);
+      for (let i = 0; i < run && vals.length < count; i++) vals.push(val);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bits = 0;
+      let bitbuf = 0;
+      for (let i = 0; i < total; i++) {
