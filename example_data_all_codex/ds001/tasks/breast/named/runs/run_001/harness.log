+const fs = require("fs");
+
+const file = fs.readFileSync("dataset.parquet");
+
+class CompactReader {
+  constructor(buf, off = 0) {
+    this.buf = buf;
+    this.p = off;
+  }
+  readByte() {
+    return this.buf[this.p++];
+  }
+  readVarint() {
+    let shift = 0n;
+    let res = 0n;
+    while (true) {
+      const b = this.readByte();
+      res |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zig(n) {
+    return (n >> 1n) ^ -(n & 1n);
+  }
+  readI32() {
+    return Number(this.zig(this.readVarint()));
+  }
+  readI64() {
+    return Number(this.zig(this.readVarint()));
+  }
+  readBin() {
+    const len = Number(this.readVarint());
+    const b = this.buf.subarray(this.p, this.p + len);
+    this.p += len;
+    return b;
