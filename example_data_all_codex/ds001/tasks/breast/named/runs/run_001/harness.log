+      proposed_hypotheses: [hyp("h4", "A 1-SD increase in `age_years` is associated with higher adjusted `pfs_months`.")],
+      analyses: [rec("h4", main("age_years"), "Older age showed a strong positive cohort association: +1.749 PFS months per 1-SD higher `age_years` (SE 0.005; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 5,
+      proposed_hypotheses: [hyp("h5", "A 1-SD increase in `weight_loss_pct_6mo` is associated with lower adjusted `pfs_months`.")],
+      analyses: [rec("h5", main("weight_loss_pct_6mo"), "Higher recent weight loss was associated with 0.296 fewer PFS months per SD (SE 0.005; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 6,
+      proposed_hypotheses: [hyp("h6", "A 1-SD increase in `albumin_g_dl` is associated with higher adjusted `pfs_months`.")],
+      analyses: [rec("h6", main("albumin_g_dl"), "Higher albumin was associated with 0.238 more PFS months per SD (SE 0.005; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 7,
+      proposed_hypotheses: [hyp("h7", "A 1-SD increase in `ki67_pct` is associated with lower adjusted `pfs_months`.")],
+      analyses: [rec("h7", main("ki67_pct"), "Higher `ki67_pct` was associated with 0.230 fewer PFS months per SD (SE 0.005; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 8,
+      proposed_hypotheses: [hyp("h8", "Patients with `pik3ca_mutation` equal to 1 have lower adjusted mean `pfs_months` than patients without `pik3ca_mutation`.")],
+      analyses: [rec("h8", main("pik3ca_mutation"), "`pik3ca_mutation=1` was associated with 0.582 fewer PFS months (SE 0.011; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 9,
+      proposed_hypotheses: [hyp("h9", "Patients with `er_positive` equal to 1 have higher adjusted mean `pfs_months` than patients with `er_positive` equal to 0.")],
+      analyses: [rec("h9", main("er_positive"), "`er_positive=1` was associated with 0.532 more PFS months (SE 0.015; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 10,
+      proposed_hypotheses: [hyp("h10", "Patients with `her2_positive` equal to 1 have lower adjusted mean `pfs_months` than patients with `her2_positive` equal to 0.")],
+      analyses: [rec("h10", main("her2_positive"), "`her2_positive=1` was associated with 0.471 fewer PFS months (SE 0.014; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 11,
+      proposed_hypotheses: [hyp("h11", "A 1-SD increase in `ldh_u_l` is associated with lower adjusted `pfs_months`.")],
+      analyses: [rec("h11", main("ldh_u_l"), "Higher `ldh_u_l` was associated with a small but significant 0.042-month lower PFS per SD (SE 0.005; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 12,
+      proposed_hypotheses: [hyp("h12", "Patients with `treatment_palbociclib` equal to 1 have higher adjusted mean `pfs_months` than patients without `treatment_palbociclib`.")],
+      analyses: [rec("h12", ex.treatmentMain.treatment_palbociclib, "`treatment_palbociclib=1` had the only large adjusted treatment main effect: +1.101 PFS months (SE 0.011; p<1e-14).", adjustedMainCode)],
+    },
+    {
+      index: 13,
+      proposed_hypotheses: [hyp("h13", "The positive association of `treatment_palbociclib` with `pfs_months` is larger when `er_positive` equals 1 than when `er_positive` equals 0.", "refined")],
+      analyses: [rec("h13", byInteraction["treatment_palbociclib:er_positive"], "The palbociclib-by-ER interaction was strongly positive: +1.559 months (SE 0.022; p<1e-14).", interactionCode)],
+    },
+    {
+      index: 14,
+      proposed_hypotheses: [hyp("h14", "The positive association of `treatment_palbociclib` with `pfs_months` is smaller when `her2_positive` equals 1 than when `her2_positive` equals 0.", "refined")],
+      analyses: [rec("h14", byInteraction["treatment_palbociclib:her2_positive"], "The palbociclib-by-HER2-positive interaction was strongly negative: -1.337 months (SE 0.027; p<1e-14).", interactionCode)],
+    },
+    {
+      index: 15,
+      proposed_hypotheses: [hyp("h15", "The positive association of `treatment_palbociclib` with `pfs_months` is smaller when `pik3ca_mutation` equals 1 than when `pik3ca_mutation` equals 0.", "refined")],
+      analyses: [rec("h15", byInteraction["treatment_palbociclib:pik3ca_mutation"], "The palbociclib-by-PIK3CA interaction was strongly negative: -1.665 months (SE 0.021; p<1e-14).", interactionCode)],
+    },
+    {
