function normP(t){const x=Math.abs(t); if(x>37) return 0; const a1=0.319381530,a2=-0.356563782,a3=1.781477937,a4=-1.821255978,a5=1.330274429; const k=1/(1+0.2316419*x); const phi=Math.exp(-0.5*x*x)/Math.sqrt(2*Math.PI); const cdf=1-phi*(a1*k+a2*k*k+a3*k**3+a4*k**4+a5*k**5); return Math.max(0, Math.min(1, 2*(1-cdf)));}
function twoGroup(x){let n0=0,n1=0,s0=0,s1=0,ss0=0,ss1=0; for(let i=0;i<n;i++){if(x[i]){n1++;s1+=y[i];ss1+=y[i]*y[i];} else {n0++;s0+=y[i];ss0+=y[i]*y[i];}} const m0=s0/n0,m1=s1/n1,v0=(ss0-s0*s0/n0)/(n0-1),v1=(ss1-s1*s1/n1)/(n1-1); const se=Math.sqrt(v0/n0+v1/n1); const t=(m1-m0)/se; return {n0,n1,m0,m1,diff:m1-m0,t,p:normP(t)};}
function slope(x){let sx=0,sy=0; for(let i=0;i<n;i++){sx+=x[i];sy+=y[i];} const mx=sx/n,my=sy/n; let sxx=0,sxy=0; for(let i=0;i<n;i++){const dx=x[i]-mx; sxx+=dx*dx; sxy+=dx*(y[i]-my);} const b=sxy/sxx, a=my-b*mx; let rss=0; for(let i=0;i<n;i++){const e=y[i]-(a+b*x[i]); rss+=e*e;} const se=Math.sqrt((rss/(n-2))/sxx); const t=b/se; return {slope:b,t,p:normP(t),meanX:mx};}
function invert(A){const p=A.length; const M=A.map((row,i)=>{const r=row.slice(); for(let j=0;j<p;j++) r.push(i===j?1:0); return r;}); for(let col=0; col<p; col++){let piv=col; for(let r=col+1;r<p;r++) if(Math.abs(M[r][col])>Math.abs(M[piv][col])) piv=r; if(Math.abs(M[piv][col])<1e-12) throw Error('"'singular '+col); if(piv"'!==col){const tmp=M[col];M[col]=M[piv];M[piv]=tmp;} const div=M[col][col]; for(let j=0;j<2*p;j++) M[col][j]/=div; for(let r=0;r<p;r++){if(r===col) continue; const f=M[r][col]; if(f!==0) for(let j=0;j<2*p;j++) M[r][j]-=f*M[col][j];}} return M.map(r=>r.slice(p));}
function ols(preds, mask=null){const idx=[]; for(let i=0;i<n;i++) if(!mask||mask[i]) idx.push(i); const m=idx.length, p=preds.length+1; const XtX=Array.from({length:p},()=>Array(p).fill(0)); const Xty=Array(p).fill(0); for(const ii of idx){const xv=[1]; for(const pr of preds) xv.push(pr.data[ii]); const yi=y[ii]; for(let a=0;a<p;a++){Xty[a]+=xv[a]*yi; for(let c=0;c<p;c++) XtX[a][c]+=xv[a]*xv[c];}} const inv=invert(XtX); const beta=Array(p).fill(0); for(let i=0;i<p;i++) for(let j=0;j<p;j++) beta[i]+=inv[i][j]*Xty[j]; let rss=0; for(const ii of idx){let fit=beta[0]; for(let j=0;j<preds.length;j++) fit+=beta[j+1]*preds[j].data[ii]; const e=y[ii]-fit; rss+=e*e;} const sigma2=rss/(m-p); const se=Array(p); const t=Array(p); const pv=Array(p); for(let j=0;j<p;j++){se[j]=Math.sqrt(Math.max(0,sigma2*inv[j][j])); t[j]=beta[j]/se[j]; pv[j]=normP(t[j]);} return {n:m,beta,se,t,p:pv,names:['"'Intercept',...preds.map(p=>p.name)]};}
