const meta = readMeta();
const schema = meta[2].slice(1).map((se, i) => ({ i, name: se[4] }));
const data = {};
for (const s of schema) if (s.name !== '"'patient_id') data[s.name] = readColumn(s.i, meta);
const n = data.pfs_months.length, y = data.pfs_months;

data.brca_any_mutation = data.brca1_mutation.map((v, i) => (v || data.brca2_mutation[i]) ? 1 : 0);

function normalCdf(x) { const sign = x < 0 ? -1 : 1; x = Math.abs(x) / Math.SQRT2; const t = 1 / (1 + 0.3275911 * x); const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429; const erf = 1 - (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x); return 0.5 * (1 + sign * erf); }
function pFromZ(z) { return Math.max(1e-300, 2 * (1 - normalCdf(Math.abs(z)))); }
function invert(A) { const m = A.length; const aug = A.map((row, i) => { const r = row.slice(); for (let j = 0; j < m; j++) r.push(i === j ? 1 : 0); return r; }); for (let c = 0; c < m; c++) { let piv = c; for (let r = c + 1; r < m; r++) if (Math.abs(aug[r][c]) > Math.abs(aug[piv][c])) piv = r; if (Math.abs(aug[piv][c]) < 1e-10) throw new Error('singular matrix at column ' + c); [aug[c], aug[piv]] = [aug[piv], aug[c]]; const pv = aug[c][c]; for (let j = 0; j < 2 * m; j++) aug[c][j] /= pv; for (let r = 0; r < m; r++) { if (r === c) continue; const f = aug[r][c]; if (f "'!== 0) for (let j = 0; j < 2 * m; j++) aug[r][j] -= f * aug[c][j]; } } return aug.map(row => row.slice(m)); }
function ols(terms, idx = null) {
  idx = idx || Array.from({ length: n }, (_, i) => i);
  const m = idx.length, p = terms.length + 1;
  const xtx = Array.from({ length: p }, () => Array(p).fill(0)); const xty = Array(p).fill(0);
  for (const i of idx) { const x = [1]; for (const t of terms) x.push(t.values[i]); const yi = y[i]; for (let a = 0; a < p; a++) { xty[a] += x[a] * yi; for (let b = 0; b < p; b++) xtx[a][b] += x[a] * x[b]; } }
  const inv = invert(xtx); const beta = Array(p).fill(0); for (let a = 0; a < p; a++) for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
  let rss = 0; for (const i of idx) { let pred = beta[0]; for (let j = 0; j < terms.length; j++) pred += beta[j + 1] * terms[j].values[i]; const e = y[i] - pred; rss += e * e; }
  const sigma2 = rss / (m - p), out = {};
  for (let j = 0; j < terms.length; j++) { const se = Math.sqrt(Math.max(0, sigma2 * inv[j + 1][j + 1])); const z = beta[j + 1] / se; out[terms[j].name] = { coef: beta[j + 1], se, z, p: pFromZ(z), n: m }; }
  return out;
}
function uniq(a) { return [...new Set(a)]; }
function V(name) { return data[name]; }
function term(name, values = null) { return { name, values: values || V(name) }; }
function prod(a, b, name = `${a}:${b}`) { const A = V(a), B = V(b), out = new Array(n); for (let i = 0; i < n; i++) out[i] = A[i] * B[i]; return term(name, out); }
function prodNamed(a, arr, name) { const A = V(a), out = new Array(n); for (let i = 0; i < n; i++) out[i] = A[i] * arr[i]; return term(name, out); }
function centered(name) { const arr = V(name); const mean = arr.reduce((s, x) => s + x, 0) / arr.length; return { mean, values: arr.map(x => x - mean) }; }
function idxWhere(pred) { const out = []; for (let i = 0; i < n; i++) if (pred(i)) out.push(i); return out; }

const base = ['"'age_years','sex_female','postmenopausal','stage_iv','ecog_ps','has_brain_mets','node_positive','liver_mets','bone_mets','adrenal_mets','pleural_effusion','pericardial_effusion','contralateral_lung_mets','tumor_size_cm','ki67_pct','albumin_g_dl','ldh_u_l','weight_loss_pct_6mo','crp_mg_l','nlr'];
const biomarkers = ['er_positive','pr_positive','her2_positive','her2_low','brca1_mutation','brca2_mutation','pik3ca_mutation','her2_amplification'];
const treatments = ['treatment_tamoxifen','treatment_palbociclib','treatment_trastuzumab','treatment_olaparib','treatment_sacituzumab_govitecan','treatment_pembrolizumab'];
const mainNames = uniq([...base, ...biomarkers, ...treatments]);
const mainFit = ols(mainNames.map(name => term(name)));
function interactionFit(a, b, opts = {}) {
  let names = uniq([...mainNames]);
  if (opts.drop) names = names.filter(x => "'!opts.drop.includes(x));
  const terms = names.map(name => term(name));
  let bTerm;
  if (opts.bValues) { terms.push(term(b, opts.bValues)); bTerm = { name: b, values: opts.bValues }; }
  if (!names.includes(a) && !terms.some(t => t.name === a)) terms.push(term(a));
  if (!names.includes(b) && !terms.some(t => t.name === b)) terms.push(bTerm || term(b));
  let inter;
  if (opts.bValues) inter = prodNamed(a, opts.bValues, `${a}:${b}`); else inter = prod(a, b);
  return ols([...terms, inter])[inter.name];
