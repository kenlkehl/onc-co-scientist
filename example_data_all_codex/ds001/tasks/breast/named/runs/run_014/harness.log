  ['h6', 'Higher "'`weight_loss_pct_6mo` is associated with lower `pfs_months` after multivariable adjustment.'"', 'novel', mainFit.weight_loss_pct_6mo, "'`Adjusted OLS coefficient for weight_loss_pct_6mo was ${fmt(mainFit.weight_loss_pct_6mo.coef)} months per percentage point (SE ${fmt(mainFit.weight_loss_pct_6mo.se)}, ${pf(mainFit.weight_loss_pct_6mo.p)}), supporting lower PFS with more weight loss.`, '"'pfs_months ~ weight_loss_pct_6mo + adjusted covariates'],
  ['h7', 'Higher "'`ki67_pct` is associated with lower `pfs_months` in an adjusted main-effects model.'"', 'novel', mainFit.ki67_pct, "'`In the adjusted main-effects model, ki67_pct coefficient was ${fmt(mainFit.ki67_pct.coef)} months per percentage point (SE ${fmt(mainFit.ki67_pct.se)}, ${pf(mainFit.ki67_pct.p)}), supporting an apparent adverse association before interaction refinement.`, '"'pfs_months ~ ki67_pct + adjusted covariates'],
  ['h8', 'Patients with "'`er_positive` have higher `pfs_months` than ER-negative patients in an adjusted main-effects model.'"', 'novel', mainFit.er_positive, "'`In the adjusted main-effects model, er_positive coefficient was ${fmt(mainFit.er_positive.coef)} months (SE ${fmt(mainFit.er_positive.se)}, ${pf(mainFit.er_positive.p)}), supporting an apparent positive association before interaction refinement.`, '"'pfs_months ~ er_positive + adjusted covariates'],
  ['h9', 'Patients with "'`pik3ca_mutation` have lower `pfs_months` than PIK3CA-wildtype patients in an adjusted main-effects model.'"', 'novel', mainFit.pik3ca_mutation, "'`In the adjusted main-effects model, pik3ca_mutation coefficient was ${fmt(mainFit.pik3ca_mutation.coef)} months (SE ${fmt(mainFit.pik3ca_mutation.se)}, ${pf(mainFit.pik3ca_mutation.p)}), supporting an apparent adverse association before interaction refinement.`, '"'pfs_months ~ pik3ca_mutation + adjusted covariates'],
  ['h10', 'Patients with "'`her2_positive` have lower `pfs_months` than HER2-negative patients after multivariable adjustment.'"', 'novel', mainFit.her2_positive, "'`Adjusted OLS coefficient for her2_positive was ${fmt(mainFit.her2_positive.coef)} months (SE ${fmt(mainFit.her2_positive.se)}, ${pf(mainFit.her2_positive.p)}), supporting lower PFS in HER2-positive patients.`, '"'pfs_months ~ her2_positive + adjusted covariates'],
  ['h11', 'Patients receiving "'`treatment_palbociclib` have higher `pfs_months` than patients not receiving palbociclib in an adjusted main-effects model.'"', 'novel', mainFit.treatment_palbociclib, "'`Adjusted main-effects coefficient for treatment_palbociclib was ${fmt(mainFit.treatment_palbociclib.coef)} months (SE ${fmt(mainFit.treatment_palbociclib.se)}, ${pf(mainFit.treatment_palbociclib.p)}), supporting higher PFS overall.`, '"'pfs_months ~ treatment_palbociclib + adjusted covariates'],
