function readPage(offset) { const tr = new TReader(file, offset); const h = tr.struct(); const start = tr.pos; const raw = file.subarray(start, start + h[3]); const data = h[3] "'!== h[2] ? snappy(raw) : raw; return { h, next: start + h[3], data }; }
function hybridDecode(buf, pos, bitWidth, count, limitBytes = null) {
