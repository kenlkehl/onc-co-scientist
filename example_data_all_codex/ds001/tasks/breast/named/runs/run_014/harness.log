const H = [
  ['"'h1', 'Higher "'`age_years` is associated with higher `pfs_months` after adjustment for disease severity, biomarkers, labs, metastatic sites, and treatments.'"', 'novel', mainFit.age_years, "'`Adjusted OLS coefficient for age_years was ${fmt(mainFit.age_years.coef)} months per year (SE ${fmt(mainFit.age_years.se)}, ${pf(mainFit.age_years.p)}), supporting higher PFS with older age.`, '"'pfs_months ~ age_years + adjusted covariates'],
  ['h2', 'Patients with "'`stage_iv` have lower `pfs_months` than patients without `stage_iv` after multivariable adjustment.'"', 'novel', mainFit.stage_iv, "'`Adjusted OLS coefficient for stage_iv was ${fmt(mainFit.stage_iv.coef)} months (SE ${fmt(mainFit.stage_iv.se)}, ${pf(mainFit.stage_iv.p)}), supporting lower PFS in stage IV disease.`, '"'pfs_months ~ stage_iv + adjusted covariates'],
  ['h3', 'Each one-point increase in "'`ecog_ps` is associated with lower `pfs_months` after multivariable adjustment.'"', 'novel', mainFit.ecog_ps, "'`Adjusted OLS coefficient for ecog_ps was ${fmt(mainFit.ecog_ps.coef)} months per point (SE ${fmt(mainFit.ecog_ps.se)}, ${pf(mainFit.ecog_ps.p)}), supporting worse PFS with poorer performance status.`, '"'pfs_months ~ ecog_ps + adjusted covariates'],
