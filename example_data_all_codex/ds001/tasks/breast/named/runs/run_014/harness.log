const ki = centered('"'ki67_pct');
const jointPalbo = ols([...mainNames.map(name => term(name)), prod('treatment_palbociclib','er_positive','palbo_er_positive'), prod('treatment_palbociclib','pik3ca_mutation','palbo_pik3ca_mutation'), prodNamed('treatment_palbociclib', ki.values, 'palbo_ki67_centered')]);
const palboStage = interactionFit('treatment_palbociclib', 'stage_iv');
const tamoxifenEr = interactionFit('treatment_tamoxifen', 'er_positive');
const trastuzumabHer2 = interactionFit('treatment_trastuzumab', 'her2_positive');
const olaparibBrca = interactionFit('treatment_olaparib', 'brca_any_mutation', { bValues: data.brca_any_mutation, drop: ['brca1_mutation','brca2_mutation'] });
const pembAuto = interactionFit('treatment_pembrolizumab', 'autoimmune_disease');
const saciHer2Low = interactionFit('treatment_sacituzumab_govitecan', 'her2_low');

const sub = {
  palboErNeg: treatmentInSubgroup('treatment_palbociclib', idxWhere(i => V('er_positive')[i] === 0), ['er_positive']),
  palboErPosPikWt: treatmentInSubgroup('treatment_palbociclib', idxWhere(i => V('er_positive')[i] === 1 && V('pik3ca_mutation')[i] === 0), ['er_positive','pik3ca_mutation']),
  palboErPosPikMut: treatmentInSubgroup('treatment_palbociclib', idxWhere(i => V('er_positive')[i] === 1 && V('pik3ca_mutation')[i] === 1), ['er_positive','pik3ca_mutation']),
  palboBest: treatmentInSubgroup('treatment_palbociclib', idxWhere(i => V('er_positive')[i] === 1 && V('pik3ca_mutation')[i] === 0 && V('ki67_pct')[i] <= 25), ['er_positive','pik3ca_mutation']),
  palboHighKi: treatmentInSubgroup('treatment_palbociclib', idxWhere(i => V('er_positive')[i] === 1 && V('pik3ca_mutation')[i] === 0 && V('ki67_pct')[i] > 25), ['er_positive','pik3ca_mutation'])
};
const counts = {
  palboErNeg: idxWhere(i => V('er_positive')[i] === 0).length,
  palboErPosPikWt: idxWhere(i => V('er_positive')[i] === 1 && V('pik3ca_mutation')[i] === 0).length,
  palboErPosPikMut: idxWhere(i => V('er_positive')[i] === 1 && V('pik3ca_mutation')[i] === 1).length,
  palboBest: idxWhere(i => V('er_positive')[i] === 1 && V('pik3ca_mutation')[i] === 0 && V('ki67_pct')[i] <= 25).length,
  palboHighKi: idxWhere(i => V('er_positive')[i] === 1 && V('pik3ca_mutation')[i] === 0 && V('ki67_pct')[i] > 25).length
};

function num(x, d = 6) { return Number(x.toFixed(d)); }
function fmt(x, d = 3) { return Number(x).toFixed(d); }
