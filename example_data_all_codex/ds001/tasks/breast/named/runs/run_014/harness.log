"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from scipy import stats

pd.set_option('display.width', 200)
pd.set_option('display.max_columns', 120)
df = pd.read_parquet('dataset.parquet')
print('shape', df.shape)
print('columns', list(df.columns))
print('\\ndtypes')
print(df.dtypes.value_counts())
print('\\noutcome summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]))
print('\\nfirst row')
print(df.head(1).T)

# binary/non-binary detect
for c in df.columns:
    if c == 'pfs_months': continue
    vals = df[c].dropna().unique()
    if len(vals) <= 4:
        print(c, sorted(vals)[:10], 'mean', df[c].mean())
print('\\ncontinuous summaries')
cont = [c for c in df.columns if c"'!='"'pfs_months' and df[c].nunique()>4]
print(df[cont].describe().T[['mean','std','min','25%','50%','75%','max']].round(3))

# univariate effect for binary vars (mean diff 1-0) + t p
rows=[]
for c in df.columns:
    if c == 'pfs_months': continue
    if df[c].nunique()==2:
        y1=df.loc[df[c]==1,'pfs_months']
        y0=df.loc[df[c]==0,'pfs_months']
        t,p=stats.ttest_ind(y1,y0,equal_var=False)
        rows.append((c, len(y1), y1.mean()-y0.mean(), p, y1.mean(), y0.mean()))
print('\\nTop binary mean differences:')
for row in sorted(rows, key=lambda x: abs(x[2]), reverse=True)[:40]:
    print(row[0], 'n1', row[1], 'diff', round(row[2],3), 'p', f'{row[3]:.2e}', 'mean1', round(row[4],2), 'mean0', round(row[5],2))

# correlations for continuous vars
cor=[]
for c in cont:
    r,p=stats.pearsonr(df[c], df['pfs_months'])
    slope = np.cov(df[c], df['pfs_months'], ddof=1)[0,1] / np.var(df[c], ddof=1)
    cor.append((c,r,p,slope))
print('\\nTop continuous correlations:')
for row in sorted(cor, key=lambda x: abs(x[1]), reverse=True):
    print(row[0], 'r', round(row[1],3), 'slope/mo per unit', round(row[3],4), 'p', f'{row[2]:.2e}')
