const mainNames=features;console.log('\\nRunning full main-effects OLS');const main=ols(y,mainNames.map(k=>df[k]),mainNames);const terms=main.terms.slice(1).sort((a,b)=>Math.abs(b.t)-Math.abs(a.t));for(const r of terms.slice(0,45))console.log(r.name,'coef',r.coef.toFixed(4),'se',r.se.toFixed(4),'t',r.t.toFixed(1),'p',fmtp(r.p));
const treatments=['treatment_tamoxifen','treatment_palbociclib','treatment_trastuzumab','treatment_olaparib','treatment_sacituzumab_govitecan','treatment_pembrolizumab'];console.log('\\nTreatment unadjusted and adjusted main effects');for(const t of treatments){const u=diffBinary(y,df[t]);const adj=main.terms.find(r=>r.name===t);console.log(t,'unadj',u.effect.toFixed(4),'p',fmtp(u.p),'adj',adj.coef.toFixed(4),'p',fmtp(adj.p),'n1',u.n1);}
const biomBin=features.filter(k=>summaries[k].binary && "'!treatments.includes(k));const intRows=[];for(const t of treatments){for(const b of biomBin){const z=makeInteraction(df[t],df[b]);try{const fit=ols(y,[df[t],df[b],z],[t,b,`${t}:${b}`]);const term=fit.terms[3];intRows.push({t,b,coef:term.coef,se:term.se,tstat:term.t,p:term.p});}catch(e){}}
}
intRows.sort((a,b)=>Math.abs(b.tstat)-Math.abs(a.tstat));console.log('"'\\nTop treatment x binary biomarker interactions (unadjusted 4-term models)');for(const r of intRows.slice(0,60))console.log("'`${r.t} x ${r.b}`,'"'coef',r.coef.toFixed(4),'t',r.tstat.toFixed(1),'p',fmtp(r.p));
