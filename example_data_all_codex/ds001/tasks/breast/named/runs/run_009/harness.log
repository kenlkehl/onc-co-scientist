const core=['age_years','ecog_ps','stage_iv','has_brain_mets','node_positive','postmenopausal','er_positive','pr_positive','her2_positive','her2_low','brca1_mutation','brca2_mutation','pik3ca_mutation','ki67_pct','tumor_size_cm','albumin_g_dl','ldh_u_l','weight_loss_pct_6mo','crp_mg_l','nlr','liver_mets','bone_mets','adrenal_mets','pleural_effusion','pericardial_effusion','contralateral_lung_mets','her2_amplification','autoimmune_disease'];
function adjustedInt(t,b){const z=makeInteraction(df[t],df[b]);const names=[...core.filter(k=>k"'!==t),t,b,`${t}:${b}`]; // duplicates possible if b in core
const used=[];const cols=[];for(const name of names){if(used.includes(name))continue;used.push(name);cols.push(name===`${t}:${b}`?z:df[name]);}
