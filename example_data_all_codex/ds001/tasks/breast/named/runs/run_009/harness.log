function subgroupTreat(tt,g){const n=y.length;function stat(gval,tval){let c=0,s=0;for(let i=0;i<n;i++){if(g[i]===gval && df[tt][i]===tval){c++;s+=y[i];}}return{c,m:s/c};}const a=stat(1,1),b=stat(1,0),c=stat(0,1),d=stat(0,0);return{group1:a.m-b.m,n11:a.c,n10:b.c,group0:c.m-d.m,n01:c.c,n00:d.c,diff:(a.m-b.m)-(c.m-d.m)};}console.log('\\nSelected subgroup treatment effects');for(const [tt,bb,g] of [['treatment_trastuzumab','her2_positive',df.her2_positive],['treatment_olaparib','brca_any',brcaAny],['treatment_sacituzumab_govitecan','triple_negative',tn],['treatment_pembrolizumab','high_crp',highCrp],['treatment_tamoxifen','hr_positive',hrpos],['treatment_palbociclib','hr_positive',hrpos]])console.log(tt,bb,subgroupTreat(tt,g));
