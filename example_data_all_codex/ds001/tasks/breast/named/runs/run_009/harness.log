const mainNames=features;console.log('\\nRunning full main-effects OLS');const main=ols(y,mainNames.map(k=>df[k]),mainNames);const terms=main.terms.slice(1).sort((a,b)=>Math.abs(b.t)-Math.abs(a.t));for(const r of terms.slice(0,45))console.log(r.name,'coef',r.coef.toFixed(4),'se',r.se.toFixed(4),'t',r.t.toFixed(1),'p',fmtp(r.p));
