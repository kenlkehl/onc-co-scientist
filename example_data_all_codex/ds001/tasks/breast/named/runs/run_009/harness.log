const core=['age_years','ecog_ps','stage_iv','has_brain_mets','node_positive','postmenopausal','er_positive','pr_positive','her2_positive','her2_low','brca1_mutation','brca2_mutation','pik3ca_mutation','ki67_pct','tumor_size_cm','albumin_g_dl','ldh_u_l','weight_loss_pct_6mo','crp_mg_l','nlr','liver_mets','bone_mets','adrenal_mets','pleural_effusion','pericardial_effusion','contralateral_lung_mets','her2_amplification','autoimmune_disease'];
function adjustedInt(tt,bb){const z=makeInteraction(df[tt],df[bb]);const names=[...core,tt,bb,"'`${tt}:${bb}`];const used=[];const cols=[];for(const name of names){if(used.includes(name))continue;used.push(name);cols.push(name===`${tt}:${bb}`?z:df[name]);}const fit=ols(y,cols,used);return fit.terms.find(r=>r.name===`${tt}:${bb}`);}const selected=[['"'treatment_tamoxifen','er_positive'],['treatment_tamoxifen','pr_positive'],['treatment_palbociclib','er_positive'],['treatment_palbociclib','pr_positive'],['treatment_palbociclib','pik3ca_mutation'],['treatment_trastuzumab','her2_positive'],['treatment_trastuzumab','her2_amplification'],['treatment_trastuzumab','her2_low'],['treatment_olaparib','brca1_mutation'],['treatment_olaparib','brca2_mutation'],['treatment_sacituzumab_govitecan','er_positive'],['treatment_sacituzumab_govitecan','pr_positive'],['treatment_sacituzumab_govitecan','her2_positive'],['treatment_pembrolizumab','autoimmune_disease'],['treatment_pembrolizumab','er_positive'],['treatment_pembrolizumab','pr_positive'],['treatment_pembrolizumab','her2_positive'],['treatment_pembrolizumab','liver_mets'],['treatment_pembrolizumab','has_brain_mets']];console.log('\\nAdjusted selected interactions');for(const [tt,bb] of selected){const r=adjustedInt(tt,bb);console.log("'`${tt} x ${bb}`,'"'coef',r.coef.toFixed(4),'se',r.se.toFixed(4),'t',r.t.toFixed(1),'p',fmtp(r.p));}
