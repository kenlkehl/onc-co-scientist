function loadDataset(){const buf=fs.readFileSync('"'dataset.parquet');const flen=buf.readUInt32LE(buf.length-8);const m=meta(new R(buf,buf.length-8-flen));const rg0=m.row_groups[0];const columns={};const info={};for(const chunk of rg0.columns){const md=chunk.meta_data;const name=md.path[0];if(name==='patient_id') continue;if("'!(md.type===2||md.type===5)) continue;let off=md.dictionary_page_offset||md.data_page_offset;let dict=null;let out=new Float64Array(md.num_values);let outPos=0;while(outPos<md.num_values){const ph=pageHeaderAt(buf,off);const bodyComp=buf.slice(ph.bodyOff,ph.bodyOff+ph.compressed);const body=md.codec===1?snappyUncompress(bodyComp):bodyComp;if(ph.type===2){dict=readPlainDict(body,md.type,ph.dict_page.num_values);off=ph.bodyOff+ph.compressed;continue;}if(ph.type!==0) throw Error('"'Unexpected page type '+ph.type+' '+name);let pos=0;if(ph.data_page){ // skip definition levels, all present
