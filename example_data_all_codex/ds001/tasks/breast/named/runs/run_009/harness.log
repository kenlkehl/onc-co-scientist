const biomBin=features.filter(k=>summaries[k].binary && "'!treatments.includes(k));const intRows=[];for(const tt of treatments){for(const bb of biomBin){const z=makeInteraction(df[tt],df[bb]);try{const fit=ols(y,[df[tt],df[bb],z],[tt,bb,`${tt}:${bb}`]);const term=fit.terms[3];intRows.push({tt,bb,coef:term.coef,se:term.se,tstat:term.t,p:term.p});}catch(e){}}}
