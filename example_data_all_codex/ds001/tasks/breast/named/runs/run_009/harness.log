const {columns:df,n}=loadDataset();const y=df.pfs_months;console.log('loaded', n, Object.keys(df).length, 'cols');console.log('pfs', summarizeCol(y));const summaries={};for(const [k,v] of Object.entries(df)) summaries[k]=summarizeCol(v);console.log('\\nCounts/means key');for(const k of ['er_positive','pr_positive','her2_positive','her2_low','brca1_mutation','brca2_mutation','pik3ca_mutation','stage_iv','liver_mets','bone_mets','treatment_tamoxifen','treatment_palbociclib','treatment_trastuzumab','treatment_olaparib','treatment_sacituzumab_govitecan','treatment_pembrolizumab']) console.log(k,summaries[k]);
