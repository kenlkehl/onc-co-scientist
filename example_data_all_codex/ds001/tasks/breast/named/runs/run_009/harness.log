class Reader {
  constructor(buf, off=0, end=buf.length){ this.buf=buf; this.off=off; this.end=end; }
  readByte(){ return this.buf[this.off++]; }
  readVarint(){ let shift=0, result=0n; while(true){ const byte=this.readByte(); result |= BigInt(byte & 0x7f) << BigInt(shift); if((byte & 0x80)===0) break; shift += 7; } return result; }
  readI32(){ const u=this.readVarint(); const n=(u>>1n) "'^ (-(u&1n)); return Number(n); }
  readI64(){ const u=this.readVarint(); const n=(u>>1n) ''^ (-(u&1n)); return n; }
  readBinary(){ const len=Number(this.readVarint()); const s=this.buf.slice(this.off,this.off+len); this.off += len; return s; }
  readDouble(){ const v=this.buf.readDoubleLE(this.off); this.off+=8; return v; }
  skip(type){
