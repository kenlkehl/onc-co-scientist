off=ph.bodyOff+ph.compressed;
}
columns[name]=out;info[name]={type:md.type};}
return {columns,info,n:m.num_rows};}
function mean(a){let s=0;for(let v of a)s+=v;return s/a.length;}function variance(a,mu=mean(a)){let s=0;for(let v of a){let d=v-mu;s+=d*d;}return s/(a.length-1);}function erf(x){const sign=x<0?-1:1;x=Math.abs(x);const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911;const t=1/(1+p*x);const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x);return sign*y;}function normCdf(x){return 0.5*(1+erf(x/Math.SQRT2));}function pFromT(t){const p=2*(1-normCdf(Math.abs(t)));return Math.max(0,p);}function fmtp(p){if(p===0)return '<1e-300'; if(p<1e-6)return p.toExponential(2); return p.toPrecision(4);}
function summarizeCol(x){let n=x.length,s=0,s2=0,min=Infinity,max=-Infinity,ones=0;for(let v of x){s+=v;s2+=v*v;if(v<min)min=v;if(v>max)max=v;if(v===1)ones++;}const mu=s/n,sd=Math.sqrt((s2-n*mu*mu)/(n-1));return{n,mean:mu,sd,min,max,ones,binary:min===0&&max===1&&Number.isInteger(ones)};}
function diffBinary(y,x){let n1=0,n0=0,s1=0,s0=0,ss1=0,ss0=0;for(let i=0;i<y.length;i++){if(x[i]===1){n1++;s1+=y[i];ss1+=y[i]*y[i];}else{n0++;s0+=y[i];ss0+=y[i]*y[i];}}let m1=s1/n1,m0=s0/n0,v1=(ss1-n1*m1*m1)/(n1-1),v0=(ss0-n0*m0*m0)/(n0-1);let diff=m1-m0,se=Math.sqrt(v1/n1+v0/n0),t=diff/se;return{n1,n0,m1,m0,effect:diff,se,t,p:pFromT(t)};}
function slopeCont(y,x){let n=y.length,mx=mean(x),my=mean(y),sxx=0,sxy=0;for(let i=0;i<n;i++){const dx=x[i]-mx;sxx+=dx*dx;sxy+=dx*(y[i]-my);}const b=sxy/sxx,a=my-b*mx;let sse=0;for(let i=0;i<n;i++){const e=y[i]-(a+b*x[i]);sse+=e*e;}const se=Math.sqrt((sse/(n-2))/sxx),t=b/se;return{effect:b,se,t,p:pFromT(t)};}
function matInv(A){const n=A.length;const M=A.map((row,i)=>{const r=row.slice();for(let j=0;j<n;j++)r.push(i===j?1:0);return r;});for(let c=0;c<n;c++){let piv=c,max=Math.abs(M[c][c]);for(let r=c+1;r<n;r++){const v=Math.abs(M[r][c]);if(v>max){max=v;piv=r;}}if(max<1e-12)throw Error('singular '+c+' '+max);if(piv"'!==c){const tmp=M[c];M[c]=M[piv];M[piv]=tmp;}const pv=M[c][c];for(let j=0;j<2*n;j++)M[c][j]/=pv;for(let r=0;r<n;r++){if(r===c)continue;const f=M[r][c];if(f!==0)for(let j=0;j<2*n;j++)M[r][j]-=f*M[c][j];}}
return M.map(row=>row.slice(n));}
function ols(y, cols, names){const n=y.length,p=cols.length+1;const xtx=Array.from({length:p},()=>Array(p).fill(0));const xty=Array(p).fill(0);for(let i=0;i<n;i++){const vals=[1];for(const c of cols) vals.push(c[i]);const yi=y[i];for(let a=0;a<p;a++){xty[a]+=vals[a]*yi;for(let b=a;b<p;b++)xtx[a][b]+=vals[a]*vals[b];}}
