import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome describe')
print(df['pfs_months'].describe().to_string())
print('missing total', int(df.isna().sum().sum()))
# basic binary prevalence and treatment mean pfs
binary_cols = [c for c in df.columns if c "'!= '"'pfs_months' and sorted(df[c].dropna().unique().tolist()) in ([0,1],[0.0,1.0])]
print('binary count', len(binary_cols))
print('binary prevalence top/bottom')
prev = df[binary_cols].mean().sort_values()
print(pd.concat([prev.head(15), prev.tail(15)]).to_string())
print('treatment stats')
for c in [x for x in df.columns if x.startswith('treatment_')]:
    m1 = df.loc[df[c]==1,'pfs_months'].mean(); m0 = df.loc[df[c]==0,'pfs_months'].mean(); n=int(df[c].sum())
    print(c, 'n', n, 'mean_on', round(m1,3), 'mean_off', round(m0,3), 'diff', round(m1-m0,3))
