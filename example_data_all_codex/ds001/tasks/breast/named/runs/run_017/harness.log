+    'age_years',
+    'ecog_ps',
+    'stage_iv',
+    'has_brain_mets',
+    'node_positive',
+    'ki67_pct',
+    'tumor_size_cm',
+    'albumin_g_dl',
+    'ldh_u_l',
+    'weight_loss_pct_6mo',
+    'crp_mg_l',
+    'nlr',
+    'liver_mets',
+    'bone_mets',
+  ];
+
+  let res;
+  res = binaryDiff(data, 'er_positive');
+  addIter(1, [
+    { id: 'h1', text: 'Patients with `er_positive` equal to 1 have higher mean `pfs_months` than patients with `er_positive` equal to 0.', kind: 'novel' },
+  ], [
+    analysis(['h1'], res.effect, res.p, `Mean pfs_months was ${round(res.mean1, 3)} for er_positive=1 versus ${round(res.mean0, 3)} for er_positive=0, a signed difference of ${round(res.effect, 3)} months (Welch t-test p=${pFmt(res.p)}).`),
+  ]);
+
+  res = binaryDiff(data, 'her2_positive');
+  addIter(2, [
+    { id: 'h2', text: 'Patients with `her2_positive` equal to 1 have lower mean `pfs_months` than patients with `her2_positive` equal to 0.', kind: 'novel' },
+  ], [
+    analysis(['h2'], res.effect, res.p, `Mean pfs_months was ${round(res.mean1, 3)} for her2_positive=1 versus ${round(res.mean0, 3)} for her2_positive=0, a signed difference of ${round(res.effect, 3)} months (Welch t-test p=${pFmt(res.p)}).`),
+  ]);
+
+  const iv = binaryDiff(data, 'stage_iv');
+  const brain = binaryDiff(data, 'has_brain_mets');
+  const liver = binaryDiff(data, 'liver_mets');
+  addIter(3, [
+    { id: 'h3', text: 'Patients with `stage_iv` equal to 1 have lower mean `pfs_months` than patients with `stage_iv` equal to 0.', kind: 'novel' },
+    { id: 'h4', text: 'Patients with `has_brain_mets` equal to 1 have lower mean `pfs_months` than patients with `has_brain_mets` equal to 0.', kind: 'novel' },
+    { id: 'h5', text: 'Patients with `liver_mets` equal to 1 have lower mean `pfs_months` than patients with `liver_mets` equal to 0.', kind: 'novel' },
+  ], [
+    analysis(['h3'], iv.effect, iv.p, `Mean pfs_months was ${round(iv.mean1, 3)} for stage_iv=1 versus ${round(iv.mean0, 3)} for stage_iv=0, difference ${round(iv.effect, 3)} months (p=${pFmt(iv.p)}).`),
+    analysis(['h4'], brain.effect, brain.p, `Mean pfs_months was ${round(brain.mean1, 3)} for has_brain_mets=1 versus ${round(brain.mean0, 3)} for has_brain_mets=0, difference ${round(brain.effect, 3)} months (p=${pFmt(brain.p)}).`),
+    analysis(['h5'], liver.effect, liver.p, `Mean pfs_months was ${round(liver.mean1, 3)} for liver_mets=1 versus ${round(liver.mean0, 3)} for liver_mets=0, difference ${round(liver.effect, 3)} months (p=${pFmt(liver.p)}).`),
