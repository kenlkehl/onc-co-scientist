+function readBitPacked(buf, pos, bitWidthValue, count) {
+  const vals = [];
+  let bitOffset = 0;
+  for (let i = 0; i < count; i++) {
+    let v = 0;
+    for (let b = 0; b < bitWidthValue; b++) {
+      const byte = buf[pos + ((bitOffset + b) >> 3)];
+      const bit = (byte >> ((bitOffset + b) & 7)) & 1;
+      v |= bit << b;
+    }
+    vals.push(v);
+    bitOffset += bitWidthValue;
+  }
+  return { vals, pos: pos + Math.ceil(bitOffset / 8) };
