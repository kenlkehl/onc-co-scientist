+const parquetPath = 'dataset.parquet';
+const transcriptPath = 'transcript.json';
+const summaryPath = 'analysis_summary.txt';
+
+function readVarint(buf, pos) {
+  let shift = 0;
+  let result = 0n;
+  let i = pos;
+  while (true) {
+    const b = buf[i++];
+    result |= BigInt(b & 0x7f) << BigInt(shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: result, pos: i };
