+
+function readColumn(buf, chunk, schemaElem) {
+  const meta = chunk.meta_data;
+  let pos = meta.dictionary_page_offset ?? meta.data_page_offset;
+  const end = pos + meta.total_compressed_size;
+  const values = [];
+  let dictionary = null;
+  while (pos < end && values.length < meta.num_values) {
+    const header = readPageHeader(buf, pos);
+    pos += header.header_size;
+    let page = buf.slice(pos, pos + header.compressed_page_size);
+    pos += header.compressed_page_size;
+    if (meta.codec === 1) page = snappyDecompress(page);
+    else if (meta.codec !== 0) throw new Error(`Unsupported codec ${meta.codec}`);
