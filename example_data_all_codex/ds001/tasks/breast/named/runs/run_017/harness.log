@@ -0,0 +1,1313 @@
+const fs = require('fs');
+
+const parquetPath = 'dataset.parquet';
+const transcriptPath = 'transcript.json';
+const summaryPath = 'analysis_summary.txt';
+
+function readVarint(buf, pos) {
+  let shift = 0;
+  let result = 0n;
+  let i = pos;
+  while (true) {
+    const b = buf[i++];
+    result |= BigInt(b & 0x7f) << BigInt(shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: result, pos: i };
+}
+
+function zigzag(n) {
+  return (n >> 1n) ^ (-(n & 1n));
+}
+
+function toNumber(n) {
+  const v = Number(n);
+  if (!Number.isSafeInteger(v)) return v;
+  return v;
+}
+
+class CompactReader {
+  constructor(buf, pos = 0, end = buf.length) {
+    this.buf = buf;
+    this.pos = pos;
+    this.end = end;
+    this.lastField = [0];
+  }
+
+  readByte() {
+    return this.buf[this.pos++];
+  }
+
+  readVarint() {
+    const out = readVarint(this.buf, this.pos);
+    this.pos = out.pos;
+    return out.value;
+  }
+
+  readZigzag() {
+    return zigzag(this.readVarint());
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const start = this.pos;
+    this.pos += len;
+    return this.buf.slice(start, start + len);
+  }
+
+  readString() {
+    return this.readBinary().toString('utf8');
+  }
+
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+
+  readFieldHeader() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) {
+      id = Number(this.readZigzag());
+    } else {
+      id = this.lastField[this.lastField.length - 1] + delta;
+    }
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+
+  pushStruct() {
+    this.lastField.push(0);
+  }
+
+  popStruct() {
+    this.lastField.pop();
+  }
+
+  readListHeader() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elemType };
+  }
+
+  skip(type) {
+    switch (type) {
+      case 0:
+        return;
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.readZigzag();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case 9:
+      case 10: {
+        const { size, elemType } = this.readListHeader();
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
+      case 11: {
+        const size = Number(this.readVarint());
+        if (size === 0) return;
+        const kt = this.readByte();
+        const keyType = kt >> 4;
+        const valType = kt & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(keyType);
+          this.skip(valType);
+        }
+        return;
+      }
+      case 12:
+        this.pushStruct();
+        while (true) {
+          const h = this.readFieldHeader();
+          if (h.type === 0) break;
+          this.skip(h.type);
+        }
+        this.popStruct();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+    }
+  }
+
+  readValue(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.readByte();
+      case 4:
+      case 5:
+      case 6:
+        return toNumber(this.readZigzag());
+      case 7:
+        return this.readDouble();
+      case 8:
+        return this.readString();
+      case 9: {
+        const { size, elemType } = this.readListHeader();
+        const arr = [];
+        for (let i = 0; i < size; i++) arr.push(this.readValue(elemType));
+        return arr;
+      }
+      case 12:
+        return this.readGenericStruct();
+      default:
+        throw new Error(`Unsupported value type ${type}`);
+    }
+  }
+
+  readGenericStruct() {
+    const obj = {};
+    this.pushStruct();
+    while (true) {
+      const h = this.readFieldHeader();
+      if (h.type === 0) break;
+      obj[h.id] = this.readValue(h.type);
+    }
+    this.popStruct();
+    return obj;
+  }
+}
+
+function readStructWith(reader, fields) {
+  const obj = {};
+  reader.pushStruct();
+  while (true) {
+    const h = reader.readFieldHeader();
+    if (h.type === 0) break;
+    const fn = fields[h.id];
+    if (fn) obj[fn.name] = fn.read(reader, h.type);
+    else reader.skip(h.type);
+  }
+  reader.popStruct();
+  return obj;
+}
+
+function readI(reader) {
+  return toNumber(reader.readZigzag());
+}
+
+function readString(reader) {
+  return reader.readString();
+}
+
+function readList(reader, elemReader) {
+  const { size, elemType } = reader.readListHeader();
+  const arr = [];
+  for (let i = 0; i < size; i++) arr.push(elemReader(reader, elemType));
+  return arr;
+}
+
+function readSchemaElement(reader) {
+  return readStructWith(reader, {
+    1: { name: 'type', read: readI },
+    2: { name: 'type_length', read: readI },
+    3: { name: 'repetition_type', read: readI },
+    4: { name: 'name', read: readString },
+    5: { name: 'num_children', read: readI },
+    6: { name: 'converted_type', read: readI },
+    7: { name: 'scale', read: readI },
+    8: { name: 'precision', read: readI },
+    9: { name: 'field_id', read: readI },
+    10: { name: 'logical_type', read: (r, t) => r.readValue(t) },
+  });
+}
+
+function readColumnMetaData(reader) {
+  return readStructWith(reader, {
+    1: { name: 'type', read: readI },
+    2: { name: 'encodings', read: (r) => readList(r, readI) },
+    3: { name: 'path_in_schema', read: (r) => readList(r, readString) },
+    4: { name: 'codec', read: readI },
+    5: { name: 'num_values', read: readI },
+    6: { name: 'total_uncompressed_size', read: readI },
+    7: { name: 'total_compressed_size', read: readI },
+    9: { name: 'data_page_offset', read: readI },
+    10: { name: 'index_page_offset', read: readI },
+    11: { name: 'dictionary_page_offset', read: readI },
+    12: { name: 'statistics', read: (r, t) => r.readValue(t) },
+    13: { name: 'encoding_stats', read: (r, t) => r.readValue(t) },
+  });
+}
+
+function readColumnChunk(reader) {
+  return readStructWith(reader, {
+    1: { name: 'file_path', read: readString },
+    2: { name: 'file_offset', read: readI },
+    3: { name: 'meta_data', read: () => readColumnMetaData(reader) },
+    4: { name: 'offset_index_offset', read: readI },
+    5: { name: 'offset_index_length', read: readI },
+    6: { name: 'column_index_offset', read: readI },
+    7: { name: 'column_index_length', read: readI },
+  });
+}
+
+function readRowGroup(reader) {
+  return readStructWith(reader, {
+    1: { name: 'columns', read: (r) => readList(r, () => readColumnChunk(r)) },
+    2: { name: 'total_byte_size', read: readI },
+    3: { name: 'num_rows', read: readI },
+    5: { name: 'file_offset', read: readI },
+    6: { name: 'total_compressed_size', read: readI },
+  });
+}
+
+function readFileMetaData(footer) {
+  const reader = new CompactReader(footer);
+  return readStructWith(reader, {
+    1: { name: 'version', read: readI },
+    2: { name: 'schema', read: (r) => readList(r, () => readSchemaElement(r)) },
+    3: { name: 'num_rows', read: readI },
+    4: { name: 'row_groups', read: (r) => readList(r, () => readRowGroup(r)) },
+    5: { name: 'key_value_metadata', read: (r, t) => r.readValue(t) },
