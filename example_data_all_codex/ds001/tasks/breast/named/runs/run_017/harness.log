+function readVarint(buf, pos) {
+  let shift = 0;
+  let result = 0n;
+  let i = pos;
+  while (true) {
+    const b = buf[i++];
+    result |= BigInt(b & 0x7f) << BigInt(shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: result, pos: i };
+}
+
+function zigzag(n) {
+  return (n >> 1n) ^ (-(n & 1n));
+}
+
+function toNumber(n) {
+  const v = Number(n);
+  if (!Number.isSafeInteger(v)) return v;
+  return v;
+}
+
+class CompactReader {
+  constructor(buf, pos = 0, end = buf.length) {
+    this.buf = buf;
+    this.pos = pos;
+    this.end = end;
+    this.lastField = [0];
+  }
+
+  readByte() {
+    return this.buf[this.pos++];
+  }
+
+  readVarint() {
+    const out = readVarint(this.buf, this.pos);
+    this.pos = out.pos;
+    return out.value;
+  }
+
+  readZigzag() {
+    return zigzag(this.readVarint());
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const start = this.pos;
+    this.pos += len;
+    return this.buf.slice(start, start + len);
+  }
+
+  readString() {
+    return this.readBinary().toString('utf8');
+  }
+
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+
+  readFieldHeader() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) {
+      id = Number(this.readZigzag());
+    } else {
+      id = this.lastField[this.lastField.length - 1] + delta;
+    }
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+
+  pushStruct() {
+    this.lastField.push(0);
+  }
+
+  popStruct() {
+    this.lastField.pop();
+  }
+
+  readListHeader() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elemType };
+  }
