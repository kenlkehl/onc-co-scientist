+function binaryDiff(data, feature, yName = 'pfs_months', mask = null) {
+  const x = col(data, feature);
+  const y = col(data, yName);
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) {
+    if (mask && !mask[i]) continue;
+    if (x[i] === 1) a.push(y[i]);
+    else b.push(y[i]);
+  }
+  const ma = mean(a), mb = mean(b);
+  const va = variance(a, ma), vb = variance(b, mb);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const t = (ma - mb) / se;
+  const df = (va / a.length + vb / b.length) ** 2 / ((va / a.length) ** 2 / (a.length - 1) + (vb / b.length) ** 2 / (b.length - 1));
