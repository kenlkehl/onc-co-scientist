+    ...controls.filter((v) => v !== 'stage_iv').map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+    ...coreTx.map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+  ];
+  const modelVTE = ols(y, buildRows(data, termsVTE));
+  addIter(24, [
+    { id: 'h33', text: '`venous_thromboembolism_history` equal to 1 is associated with shorter `pfs_months`, especially among patients with `stage_iv` equal to 1.', kind: 'novel' },
+  ], [
+    analysis(['h33'], modelVTE.beta[1], modelVTE.pvals[1], `Adjusted OLS main coefficient for venous_thromboembolism_history when stage_iv=0 was ${round(modelVTE.beta[1], 3)} months (p=${pFmt(modelVTE.pvals[1])}).`),
+    analysis(['h33'], modelVTE.beta[3], modelVTE.pvals[3], `Adjusted OLS interaction coefficient for venous_thromboembolism_history by stage_iv was ${round(modelVTE.beta[3], 3)} months (p=${pFmt(modelVTE.pvals[3])}).`),
+  ]);
+
+  const fullTerms = [
+    ...coreTx.map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+    { name: 'er_positive', fn: (i) => col(data, 'er_positive')[i] },
+    { name: 'pr_positive', fn: (i) => col(data, 'pr_positive')[i] },
+    { name: 'her2_positive', fn: (i) => col(data, 'her2_positive')[i] },
+    { name: 'brca1_mutation', fn: (i) => col(data, 'brca1_mutation')[i] },
+    { name: 'brca2_mutation', fn: (i) => col(data, 'brca2_mutation')[i] },
+    { name: 'treatment_palbociclib_x_er_positive', fn: (i) => col(data, 'treatment_palbociclib')[i] * col(data, 'er_positive')[i] },
+    { name: 'treatment_tamoxifen_x_er_positive', fn: (i) => col(data, 'treatment_tamoxifen')[i] * col(data, 'er_positive')[i] },
+    { name: 'treatment_trastuzumab_x_her2_positive', fn: (i) => col(data, 'treatment_trastuzumab')[i] * col(data, 'her2_positive')[i] },
+    { name: 'treatment_olaparib_x_brca_any', fn: (i) => col(data, 'treatment_olaparib')[i] * (brca[i] ? 1 : 0) },
+    ...controls.map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+  ];
+  const reducedTerms = fullTerms.filter((t) => !t.name.includes('_x_'));
+  const full = anovaCompare(y, buildRows(data, reducedTerms), buildRows(data, fullTerms), 4);
+  addIter(25, [
+    { id: 'h34', text: 'Adding biomarker-matched treatment interactions (`treatment_palbociclib` by `er_positive`, `treatment_tamoxifen` by `er_positive`, `treatment_trastuzumab` by `her2_positive`, and `treatment_olaparib` by any BRCA1/2 mutation) improves prediction of `pfs_months` beyond main effects and severity covariates.', kind: 'refined' },
+  ], [
+    analysis(['h34'], full.F, full.p, `Nested-model partial F-test comparing main effects plus severity covariates with a model adding four biomarker-matched treatment interactions gave F=${round(full.F, 3)} (p=${pFmt(full.p)}). The positive effect_estimate is the F statistic for added interaction signal.`),
+  ]);
+
+  const transcript = {
+    dataset_id: 'ds001_breast',
+    model_id: 'gpt-5-codex',
+    harness_id: 'codex-cli-local-node-parquet@1.0',
+    max_iterations: 25,
+    iterations,
+  };
+
+  const summaryLines = [];
+  summaryLines.push(`Dataset ds001_breast contained ${n} patients and one outcome, pfs_months. I ran 25 propose-test-refine iterations using Welch mean comparisons, adjusted OLS models, interaction models, and a final nested-model F-test.`);
+  summaryLines.push('');
+  summaryLines.push('Main biomarker and disease-burden findings: ER positivity was strongly favorable in crude analysis and remained favorable after adjustment. HER2 positivity was adverse in crude and adjusted analyses. Stage IV disease, brain metastases, and liver metastases were each associated with shorter PFS, and the adjusted stage IV by liver metastases interaction tested whether their joint effect was worse than additive. Higher albumin was favorable after adjustment, whereas higher LDH was unfavorable. Low hemoglobin, older age, venous thromboembolism history, and high inflammatory burden analyses probed additional host and disease-severity patterns.');
+  summaryLines.push('');
+  summaryLines.push('Treatment-biomarker findings: In ER-positive patients, palbociclib and tamoxifen were tested for positive PFS differences. Trastuzumab was tested separately in HER2-positive and HER2-negative subgroups, then with HER2 amplification in a three-way interaction. Olaparib was tested in BRCA1/2-mutated and BRCA-wildtype patients and again with chronic kidney disease as a tolerability-related modifier. Pembrolizumab was tested with autoimmune disease, ECOG performance status, and interstitial lung disease history as possible modifiers. Sacituzumab govitecan was tested in inflammatory-burden, bone-metastasis, and low-hemoglobin contexts.');
+  summaryLines.push('');
+  summaryLines.push('Across the transcript, positive effect estimates indicate longer pfs_months for the named exposure or interaction, and negative estimates indicate shorter pfs_months or attenuation. Statistical support is recorded in transcript.json for every analysis with signed effect estimates and p-values. The final nested-model test directly assessed whether biomarker-matched treatment interactions improved explanation of pfs_months beyond main effects and severity covariates.');
+  summaryLines.push('');
+  for (const iter of iterations) {
+    summaryLines.push(`Iteration ${iter.index}:`);
+    for (const hyp of iter.proposed_hypotheses) summaryLines.push(`- Hypothesis ${hyp.id}: ${hyp.text}`);
+    for (const a of iter.analyses) summaryLines.push(`  Result for ${a.hypothesis_ids.join(', ')}: ${a.result_summary} Significant=${a.significant}.`);
+    summaryLines.push('');
+  }
+
+  fs.writeFileSync(transcriptPath, JSON.stringify(transcript, null, 2));
+  fs.writeFileSync(summaryPath, summaryLines.join('\n'));
+  console.log(`Wrote ${transcriptPath} and ${summaryPath}`);
+}
+
+main();

