+    { id: 'h6', text: 'After adjustment for treatments and clinical severity variables, `er_positive` remains positively associated with `pfs_months`.', kind: 'refined' },
+    { id: 'h7', text: 'After adjustment for treatments and clinical severity variables, `her2_positive` remains negatively associated with `pfs_months`.', kind: 'refined' },
