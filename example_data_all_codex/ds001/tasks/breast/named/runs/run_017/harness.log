+
+function readColumn(buf, chunk, schemaElem) {
+  const meta = chunk.meta_data;
+  let pos = meta.dictionary_page_offset ?? meta.data_page_offset;
+  const end = pos + meta.total_compressed_size;
+  const values = [];
+  let dictionary = null;
+  while (pos < end && values.length < meta.num_values) {
+    const header = readPageHeader(buf, pos);
+    pos += header.header_size;
+    let page = buf.slice(pos, pos + header.compressed_page_size);
+    pos += header.compressed_page_size;
+    if (meta.codec === 1) page = snappyDecompress(page);
+    else if (meta.codec !== 0) throw new Error(`Unsupported codec ${meta.codec}`);
+
+    if (header.type === 2) {
+      const dh = header.dictionary_page_header;
+      dictionary = readPlain(page, meta.type, dh.num_values);
+    } else if (header.type === 0) {
+      const dh = header.data_page_header;
+      const count = dh.num_values;
+      let p = 0;
+      const rep = decodeHybridLevels(page.slice(p), 0, count);
+      if (rep.length && bitWidth(0) > 0) p += 4;
+      const def = decodeHybridLevels(page.slice(p), 0, count);
+      if (def.length && bitWidth(0) > 0) p += 4;
+      const data = page.slice(p);
+      let decoded;
+      if (dh.encoding === 0) decoded = readPlain(data, meta.type, count);
+      else if (dh.encoding === 8 || dh.encoding === 2) decoded = decodeDictionaryData(data, dictionary, count);
+      else throw new Error(`Unsupported data page encoding ${dh.encoding} for ${meta.path_in_schema.join('.')}`);
+      values.push(...decoded);
+    } else if (header.type === 3) {
+      const dh = header.data_page_header_v2;
+      const p = dh.repetition_levels_byte_length + dh.definition_levels_byte_length;
+      const data = page.slice(p);
+      let decoded;
+      if (dh.encoding === 0) decoded = readPlain(data, meta.type, dh.num_values);
+      else if (dh.encoding === 8 || dh.encoding === 2) decoded = decodeDictionaryData(data, dictionary, dh.num_values);
+      else throw new Error(`Unsupported data page v2 encoding ${dh.encoding}`);
+      values.push(...decoded);
+    }
+  }
+  return values.slice(0, meta.num_values);
+}
+
+function loadParquet() {
+  const buf = fs.readFileSync(parquetPath);
+  if (buf.slice(0, 4).toString() !== 'PAR1' || buf.slice(buf.length - 4).toString() !== 'PAR1') {
+    throw new Error('Not a parquet file');
+  }
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const footer = buf.slice(buf.length - 8 - footerLen, buf.length - 8);
+  const meta = readFileMetaData(footer);
+  const rowGroup = meta.row_groups[0];
+  const data = {};
+  const schemaByName = new Map();
+  for (const s of meta.schema.slice(1)) schemaByName.set(s.name, s);
+  for (const chunk of rowGroup.columns) {
+    const name = chunk.meta_data.path_in_schema[0];
+    data[name] = readColumn(buf, chunk, schemaByName.get(name));
+  }
+  return { meta, data };
+}
+
+function loadFooterOnly() {
+  const buf = fs.readFileSync(parquetPath);
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const footer = buf.slice(buf.length - 8 - footerLen, buf.length - 8);
+  return readFileMetaData(footer);
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function variance(arr, m = mean(arr)) {
+  let s = 0;
+  for (const v of arr) {
+    const d = v - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function normalP(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  return Math.max(0, Math.min(1, p));
+}
+
+function logGamma(z) {
+  const coeff = [
+    676.5203681218851,
+    -1259.1392167224028,
+    771.32342877765313,
+    -176.61502916214059,
+    12.507343278686905,
+    -0.13857109526572012,
+    9.9843695780195716e-6,
+    1.5056327351493116e-7,
+  ];
+  if (z < 0.5) return Math.log(Math.PI) - Math.log(Math.sin(Math.PI * z)) - logGamma(1 - z);
+  z -= 1;
+  let x = 0.99999999999980993;
+  for (let i = 0; i < coeff.length; i++) x += coeff[i] / (z + i + 1);
+  const t = z + coeff.length - 0.5;
+  return 0.5 * Math.log(2 * Math.PI) + (z + 0.5) * Math.log(t) - t + Math.log(x);
+}
+
+function betacf(a, b, x) {
+  const maxIter = 200;
+  const eps = 3e-14;
+  const fpmin = 1e-300;
+  let qab = a + b;
+  let qap = a + 1;
+  let qam = a - 1;
+  let c = 1;
+  let d = 1 - qab * x / qap;
+  if (Math.abs(d) < fpmin) d = fpmin;
+  d = 1 / d;
+  let h = d;
+  for (let m = 1; m <= maxIter; m++) {
+    const m2 = 2 * m;
+    let aa = m * (b - m) * x / ((qam + m2) * (a + m2));
+    d = 1 + aa * d;
+    if (Math.abs(d) < fpmin) d = fpmin;
+    c = 1 + aa / c;
+    if (Math.abs(c) < fpmin) c = fpmin;
+    d = 1 / d;
+    h *= d * c;
+    aa = -(a + m) * (qab + m) * x / ((a + m2) * (qap + m2));
+    d = 1 + aa * d;
+    if (Math.abs(d) < fpmin) d = fpmin;
+    c = 1 + aa / c;
+    if (Math.abs(c) < fpmin) c = fpmin;
+    d = 1 / d;
+    const del = d * c;
+    h *= del;
+    if (Math.abs(del - 1) < eps) break;
+  }
+  return h;
+}
+
+function ibeta(x, a, b) {
+  if (x <= 0) return 0;
+  if (x >= 1) return 1;
+  const bt = Math.exp(logGamma(a + b) - logGamma(a) - logGamma(b) + a * Math.log(x) + b * Math.log(1 - x));
+  if (x < (a + 1) / (a + b + 2)) return bt * betacf(a, b, x) / a;
+  return 1 - bt * betacf(b, a, 1 - x) / b;
+}
+
+function tP(t, df) {
+  const x = df / (df + t * t);
+  return ibeta(x, df / 2, 0.5);
+}
+
+function fP(f, df1, df2) {
+  const x = (df1 * f) / (df1 * f + df2);
+  return 1 - ibeta(x, df1 / 2, df2 / 2);
+}
+
+function chiSquareP(x, k) {
+  if (k === 1) {
+    const z = Math.sqrt(x);
+    return normalP(z);
+  }
+  return gammaQ(k / 2, x / 2);
+}
+
+function gammaP(a, x) {
+  if (x <= 0) return 0;
+  if (x < a + 1) {
+    let ap = a;
+    let sum = 1 / a;
+    let del = sum;
+    for (let n = 1; n <= 200; n++) {
+      ap += 1;
+      del *= x / ap;
+      sum += del;
+      if (Math.abs(del) < Math.abs(sum) * 3e-14) break;
+    }
+    return sum * Math.exp(-x + a * Math.log(x) - logGamma(a));
+  }
+  return 1 - gammaQ(a, x);
+}
+
+function gammaQ(a, x) {
+  if (x <= 0) return 1;
+  if (x < a + 1) return 1 - gammaP(a, x);
+  let b = x + 1 - a;
+  let c = 1 / 1e-300;
+  let d = 1 / b;
+  let h = d;
+  for (let i = 1; i <= 200; i++) {
+    const an = -i * (i - a);
+    b += 2;
+    d = an * d + b;
+    if (Math.abs(d) < 1e-300) d = 1e-300;
+    c = b + an / c;
+    if (Math.abs(c) < 1e-300) c = 1e-300;
+    d = 1 / d;
+    const del = d * c;
+    h *= del;
+    if (Math.abs(del - 1) < 3e-14) break;
+  }
+  return Math.exp(-x + a * Math.log(x) - logGamma(a)) * h;
+}
+
+function transpose(X) {
+  const n = X.length;
+  const p = X[0].length;
+  const out = Array.from({ length: p }, () => new Array(n));
+  for (let i = 0; i < n; i++) for (let j = 0; j < p; j++) out[j][i] = X[i][j];
+  return out;
+}
+
+function matMul(A, B) {
+  const n = A.length;
+  const m = B[0].length;
+  const k = B.length;
+  const out = Array.from({ length: n }, () => new Array(m).fill(0));
+  for (let i = 0; i < n; i++) {
+    for (let t = 0; t < k; t++) {
+      const a = A[i][t];
+      if (a === 0) continue;
+      for (let j = 0; j < m; j++) out[i][j] += a * B[t][j];
+    }
+  }
+  return out;
+}
+
+function matVec(A, v) {
+  return A.map((row) => row.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function invert(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let j = 0; j < 2 * n; j++) M[i][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = M[r][i];
+      for (let j = 0; j < 2 * n; j++) M[r][j] -= factor * M[i][j];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function ols(y, X) {
+  const Xt = transpose(X);
+  const XtX = matMul(Xt, X);
+  const XtXInv = invert(XtX);
+  const Xty = Xt.map((row) => row.reduce((s, x, i) => s + x * y[i], 0));
+  const beta = matVec(XtXInv, Xty);
+  const fitted = matVec(X, beta);
+  let rss = 0;
+  for (let i = 0; i < y.length; i++) {
+    const e = y[i] - fitted[i];
+    rss += e * e;
+  }
+  const df = y.length - X[0].length;
+  const sigma2 = rss / df;
+  const se = XtXInv.map((row, i) => Math.sqrt(Math.max(0, row[i] * sigma2)));
+  const tvals = beta.map((b, i) => b / se[i]);
+  const pvals = tvals.map((t) => tP(t, df));
+  return { beta, se, tvals, pvals, rss, df, sigma2, XtXInv };
+}
+
+function anovaCompare(y, XReduced, XFull, addedDf) {
+  const r = ols(y, XReduced);
+  const f = ols(y, XFull);
+  const F = ((r.rss - f.rss) / addedDf) / (f.rss / f.df);
+  return { F, p: fP(F, addedDf, f.df), full: f, reduced: r };
+}
+
+function col(data, name) {
+  return data[name];
+}
+
+function zscore(values) {
+  const m = mean(values);
+  const sd = Math.sqrt(variance(values, m));
+  return values.map((v) => (v - m) / sd);
+}
+
+function quantile(values, q) {
+  const arr = [...values].sort((a, b) => a - b);
+  const pos = (arr.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return arr[lo];
+  return arr[lo] * (hi - pos) + arr[hi] * (pos - lo);
+}
+
+function binaryDiff(data, feature, yName = 'pfs_months', mask = null) {
+  const x = col(data, feature);
+  const y = col(data, yName);
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) {
+    if (mask && !mask[i]) continue;
+    if (x[i] === 1) a.push(y[i]);
+    else b.push(y[i]);
+  }
+  const ma = mean(a), mb = mean(b);
+  const va = variance(a, ma), vb = variance(b, mb);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const t = (ma - mb) / se;
+  const df = (va / a.length + vb / b.length) ** 2 / ((va / a.length) ** 2 / (a.length - 1) + (vb / b.length) ** 2 / (b.length - 1));
