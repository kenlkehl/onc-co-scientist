+    if (mask && !mask[i]) continue;
+    if (x[i] === 1) a.push(y[i]);
+    else b.push(y[i]);
+  }
+  const ma = mean(a), mb = mean(b);
+  const va = variance(a, ma), vb = variance(b, mb);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const t = (ma - mb) / se;
+  const df = (va / a.length + vb / b.length) ** 2 / ((va / a.length) ** 2 / (a.length - 1) + (vb / b.length) ** 2 / (b.length - 1));
+  return { effect: ma - mb, p: tP(t, df), n1: a.length, n0: b.length, mean1: ma, mean0: mb };
+}
+
+function subgroupTreatment(data, treatment, subgroup, subgroupValue = 1) {
+  const s = col(data, subgroup);
+  const mask = s.map((v) => v === subgroupValue);
+  return binaryDiff(data, treatment, 'pfs_months', mask);
+}
+
+function buildRows(data, terms) {
+  const n = col(data, 'pfs_months').length;
+  const X = Array.from({ length: n }, () => [1]);
+  for (const term of terms) {
+    for (let i = 0; i < n; i++) X[i].push(term.fn(i));
+  }
+  return X;
+}
+
+function controlledModel(data, variables) {
+  const n = col(data, 'pfs_months').length;
+  const y = col(data, 'pfs_months');
+  const X = Array.from({ length: n }, (_, i) => [1, ...variables.map((v) => col(data, v)[i])]);
+  return ols(y, X);
+}
+
+function round(x, digits = 4) {
+  if (!Number.isFinite(x)) return x;
+  return Number(x.toFixed(digits));
+}
+
+function pFmt(p) {
+  if (p === 0) return '<1e-16';
+  if (p < 1e-16) return '<1e-16';
+  if (p < 0.0001) return p.toExponential(2);
+  return p.toPrecision(3);
+}
+
+function analysis(hypothesis_ids, effect, p, result_summary, code = null) {
+  return {
+    hypothesis_ids,
+    code,
+    result_summary,
+    p_value: p,
+    effect_estimate: effect,
+    significant: p < 0.05,
+  };
+}
