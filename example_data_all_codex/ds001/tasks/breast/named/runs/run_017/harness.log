+}
+
+function readColumnMetaData(reader) {
+  return readStructWith(reader, {
+    1: { name: 'type', read: readI },
+    2: { name: 'encodings', read: (r) => readList(r, readI) },
+    3: { name: 'path_in_schema', read: (r) => readList(r, readString) },
+    4: { name: 'codec', read: readI },
+    5: { name: 'num_values', read: readI },
+    6: { name: 'total_uncompressed_size', read: readI },
+    7: { name: 'total_compressed_size', read: readI },
+    9: { name: 'data_page_offset', read: readI },
+    10: { name: 'index_page_offset', read: readI },
+    11: { name: 'dictionary_page_offset', read: readI },
+    12: { name: 'statistics', read: (r, t) => r.readValue(t) },
+    13: { name: 'encoding_stats', read: (r, t) => r.readValue(t) },
+  });
+}
+
+function readColumnChunk(reader) {
