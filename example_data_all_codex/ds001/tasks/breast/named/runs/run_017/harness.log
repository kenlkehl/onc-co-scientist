+    1: { name: 'file_path', read: readString },
+    2: { name: 'file_offset', read: readI },
+    3: { name: 'meta_data', read: () => readColumnMetaData(reader) },
+    4: { name: 'offset_index_offset', read: readI },
+    5: { name: 'offset_index_length', read: readI },
+    6: { name: 'column_index_offset', read: readI },
+    7: { name: 'column_index_length', read: readI },
+  });
+}
+
+function readRowGroup(reader) {
+  return readStructWith(reader, {
+    1: { name: 'columns', read: (r) => readList(r, () => readColumnChunk(r)) },
+    2: { name: 'total_byte_size', read: readI },
+    3: { name: 'num_rows', read: readI },
+    5: { name: 'file_offset', read: readI },
+    6: { name: 'total_compressed_size', read: readI },
+  });
+}
+
+function readFileMetaData(footer) {
+  const reader = new CompactReader(footer);
+  return readStructWith(reader, {
+    1: { name: 'version', read: readI },
+    2: { name: 'schema', read: (r) => readList(r, () => readSchemaElement(r)) },
+    3: { name: 'num_rows', read: readI },
+    4: { name: 'row_groups', read: (r) => readList(r, () => readRowGroup(r)) },
+    5: { name: 'key_value_metadata', read: (r, t) => r.readValue(t) },
+    6: { name: 'created_by', read: readString },
+  });
+}
+
+function readPageHeader(buf, pos) {
+  const reader = new CompactReader(buf, pos);
+  const header = readStructWith(reader, {
+    1: { name: 'type', read: readI },
+    2: { name: 'uncompressed_page_size', read: readI },
+    3: { name: 'compressed_page_size', read: readI },
+    4: { name: 'crc', read: readI },
+    5: { name: 'data_page_header', read: () => readStructWith(reader, {
+      1: { name: 'num_values', read: readI },
+      2: { name: 'encoding', read: readI },
+      3: { name: 'definition_level_encoding', read: readI },
+      4: { name: 'repetition_level_encoding', read: readI },
+      5: { name: 'statistics', read: (r, t) => r.readValue(t) },
+    }) },
+    7: { name: 'dictionary_page_header', read: () => readStructWith(reader, {
+      1: { name: 'num_values', read: readI },
+      2: { name: 'encoding', read: readI },
+      3: { name: 'is_sorted', read: (r, t) => r.readValue(t) },
+    }) },
+    8: { name: 'data_page_header_v2', read: () => readStructWith(reader, {
+      1: { name: 'num_values', read: readI },
+      2: { name: 'num_nulls', read: readI },
+      3: { name: 'num_rows', read: readI },
+      4: { name: 'encoding', read: readI },
+      5: { name: 'definition_levels_byte_length', read: readI },
+      6: { name: 'repetition_levels_byte_length', read: readI },
+      7: { name: 'is_compressed', read: (r, t) => r.readValue(t) },
+      8: { name: 'statistics', read: (r, t) => r.readValue(t) },
+    }) },
+  });
+  header.header_size = reader.pos - pos;
+  return header;
+}
+
+function snappyDecompress(input) {
+  let pos = 0;
+  const lenInfo = readVarint(input, pos);
+  const outLen = Number(lenInfo.value);
+  pos = lenInfo.pos;
+  const out = Buffer.allocUnsafe(outLen);
+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let len;
+      if (lenCode < 60) {
+        len = lenCode + 1;
+      } else {
+        const bytes = lenCode - 59;
+        len = 1;
+        let raw = 0;
+        for (let i = 0; i < bytes; i++) raw |= input[pos++] << (8 * i);
+        len = raw + 1;
+      }
+      input.copy(out, outPos, pos, pos + len);
+      pos += len;
+      outPos += len;
+    } else {
+      let len, offset;
+      if (type === 1) {
+        len = 4 + ((tag >> 2) & 0x7);
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = 1 + (tag >> 2);
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = 1 + (tag >> 2);
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) out[outPos + i] = out[outPos - offset + i];
+      outPos += len;
+    }
+  }
+  if (outPos !== outLen) throw new Error(`Snappy length mismatch: expected ${outLen}, got ${outPos}`);
+  return out;
+}
+
+function bitWidth(maxValue) {
+  let w = 0;
+  while ((1 << w) <= maxValue && w < 31) w++;
+  return w;
+}
+
+function readPlain(buf, type, count) {
+  const out = new Array(count);
+  let pos = 0;
+  if (type === 0) {
+    let bit = 0;
+    for (let i = 0; i < count; i++) {
+      out[i] = (buf[bit >> 3] >> (bit & 7)) & 1;
+      bit++;
+    }
+  } else if (type === 1) {
+    for (let i = 0; i < count; i++) {
+      out[i] = buf.readInt32LE(pos);
+      pos += 4;
+    }
+  } else if (type === 2) {
+    for (let i = 0; i < count; i++) {
+      out[i] = Number(buf.readBigInt64LE(pos));
+      pos += 8;
+    }
+  } else if (type === 4) {
+    for (let i = 0; i < count; i++) {
+      out[i] = buf.readFloatLE(pos);
+      pos += 4;
+    }
+  } else if (type === 5) {
+    for (let i = 0; i < count; i++) {
