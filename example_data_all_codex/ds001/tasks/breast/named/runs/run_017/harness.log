+function decodeRleBitpacked(buf, bitWidthValue, expected, hasLengthPrefix) {
+  let pos = 0;
+  const end = hasLengthPrefix ? (() => {
+    const len = buf.readInt32LE(0);
+    pos = 4;
+    return pos + len;
+  })() : buf.length;
+  const out = [];
+  while (pos < end && out.length < expected) {
+    const h = readVarint(buf, pos);
+    const header = Number(h.value);
+    pos = h.pos;
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      let value = 0;
+      const bytes = Math.ceil(bitWidthValue / 8);
+      for (let i = 0; i < bytes; i++) value |= buf[pos++] << (8 * i);
+      for (let i = 0; i < runLen && out.length < expected; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const valueCount = groups * 8;
+      const decoded = readBitPacked(buf, pos, bitWidthValue, valueCount);
+      pos = decoded.pos;
+      for (const v of decoded.vals) {
+        if (out.length < expected) out.push(v);
+      }
+    }
+  }
+  return out;
+}
+
+function decodeHybridLevels(buf, maxLevel, count) {
+  if (maxLevel === 0) return new Array(count).fill(0);
+  return decodeRleBitpacked(buf, bitWidth(maxLevel), count, true);
