+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.readZigzag();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case 9:
