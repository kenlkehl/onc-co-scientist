+    { name: 'interaction', fn: (i) => col(data, 'treatment_tamoxifen')[i] * col(data, 'postmenopausal')[i] },
+    { name: 'er_positive', fn: (i) => col(data, 'er_positive')[i] },
+    { name: 'pr_positive', fn: (i) => col(data, 'pr_positive')[i] },
+    ...controls.map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+  ];
+  const modelMenopause = ols(y, buildRows(data, termsMenopause));
+  addIter(18, [
+    { id: 'h27', text: 'The association between `treatment_tamoxifen` and `pfs_months` is smaller in patients with `postmenopausal` equal to 1 than in patients with `postmenopausal` equal to 0 after accounting for hormone receptor status and severity.', kind: 'novel' },
+  ], [
+    analysis(['h27'], modelMenopause.beta[3], modelMenopause.pvals[3], `Adjusted OLS interaction coefficient for treatment_tamoxifen by postmenopausal, controlling for er_positive, pr_positive, and severity covariates, was ${round(modelMenopause.beta[3], 3)} months (p=${pFmt(modelMenopause.pvals[3])}).`),
+  ]);
+
+  const termsPik = [
+    { name: 'pik3ca_mutation', fn: (i) => col(data, 'pik3ca_mutation')[i] },
+    { name: 'treatment_palbociclib', fn: (i) => col(data, 'treatment_palbociclib')[i] },
+    { name: 'interaction', fn: (i) => col(data, 'pik3ca_mutation')[i] * col(data, 'treatment_palbociclib')[i] },
+    { name: 'er_positive', fn: (i) => col(data, 'er_positive')[i] },
+    ...controls.map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+  ];
+  const modelPik = ols(y, buildRows(data, termsPik));
+  addIter(19, [
+    { id: 'h28', text: '`pik3ca_mutation` equal to 1 is associated with shorter `pfs_months`, and this negative association is partly offset among patients with `treatment_palbociclib` equal to 1.', kind: 'novel' },
+  ], [
+    analysis(['h28'], modelPik.beta[1], modelPik.pvals[1], `Adjusted OLS main coefficient for pik3ca_mutation when treatment_palbociclib=0 was ${round(modelPik.beta[1], 3)} months (p=${pFmt(modelPik.pvals[1])}).`),
+    analysis(['h28'], modelPik.beta[3], modelPik.pvals[3], `Adjusted OLS interaction coefficient for pik3ca_mutation by treatment_palbociclib was ${round(modelPik.beta[3], 3)} months (p=${pFmt(modelPik.pvals[3])}); positive values indicate offset of the mutation-associated decrement among treated patients.`),
+  ]);
+
+  const severe = col(data, 'stage_iv').map((v, i) => (v === 1 && col(data, 'liver_mets')[i] === 1 ? 1 : 0));
+  data.stage_iv_liver_mets = severe;
+  const termsSevere = [
+    { name: 'stage_iv', fn: (i) => col(data, 'stage_iv')[i] },
+    { name: 'liver_mets', fn: (i) => col(data, 'liver_mets')[i] },
+    { name: 'interaction', fn: (i) => col(data, 'stage_iv')[i] * col(data, 'liver_mets')[i] },
+    ...coreTx.map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+    ...controls.filter((v) => !['stage_iv', 'liver_mets'].includes(v)).map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+  ];
+  const modelSevere = ols(y, buildRows(data, termsSevere));
+  addIter(20, [
+    { id: 'h29', text: 'The negative association of `stage_iv` with `pfs_months` is more severe when `liver_mets` equals 1, yielding a negative `stage_iv` by `liver_mets` interaction after adjustment.', kind: 'refined' },
+  ], [
+    analysis(['h29'], modelSevere.beta[3], modelSevere.pvals[3], `Adjusted OLS interaction coefficient for stage_iv by liver_mets was ${round(modelSevere.beta[3], 3)} months (p=${pFmt(modelSevere.pvals[3])}).`),
+  ]);
+
+  const termsToxicity = [
+    { name: 'treatment_pembrolizumab', fn: (i) => col(data, 'treatment_pembrolizumab')[i] },
+    { name: 'interstitial_lung_disease_history', fn: (i) => col(data, 'interstitial_lung_disease_history')[i] },
+    { name: 'interaction', fn: (i) => col(data, 'treatment_pembrolizumab')[i] * col(data, 'interstitial_lung_disease_history')[i] },
+    ...controls.map((v) => ({ name: v, fn: (i, vv = v) => col(data, vv)[i] })),
+  ];
+  const modelToxicity = ols(y, buildRows(data, termsToxicity));
+  addIter(21, [
+    { id: 'h30', text: 'The positive association of `treatment_pembrolizumab` with `pfs_months` is attenuated among patients with `interstitial_lung_disease_history` equal to 1.', kind: 'novel' },
+  ], [
+    analysis(['h30'], modelToxicity.beta[3], modelToxicity.pvals[3], `Adjusted OLS interaction coefficient for treatment_pembrolizumab by interstitial_lung_disease_history was ${round(modelToxicity.beta[3], 3)} months (p=${pFmt(modelToxicity.pvals[3])}).`),
+  ]);
+
+  const anemia = col(data, 'hemoglobin_g_dl').map((v) => v < quantile(col(data, 'hemoglobin_g_dl'), 0.25));
+  data.low_hemoglobin = anemia.map((v) => (v ? 1 : 0));
+  const termsAnemia = [
+    { name: 'low_hemoglobin', fn: (i) => col(data, 'low_hemoglobin')[i] },
+    { name: 'treatment_sacituzumab_govitecan', fn: (i) => col(data, 'treatment_sacituzumab_govitecan')[i] },
