+function matMul(A, B) {
+  const n = A.length;
+  const m = B[0].length;
+  const k = B.length;
+  const out = Array.from({ length: n }, () => new Array(m).fill(0));
+  for (let i = 0; i < n; i++) {
+    for (let t = 0; t < k; t++) {
+      const a = A[i][t];
+      if (a === 0) continue;
+      for (let j = 0; j < m; j++) out[i][j] += a * B[t][j];
+    }
+  }
