+          if (h.type === 0) break;
+          this.skip(h.type);
+        }
+        this.popStruct();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+    }
+  }
+
+  readValue(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.readByte();
+      case 4:
+      case 5:
+      case 6:
+        return toNumber(this.readZigzag());
+      case 7:
+        return this.readDouble();
+      case 8:
+        return this.readString();
+      case 9: {
