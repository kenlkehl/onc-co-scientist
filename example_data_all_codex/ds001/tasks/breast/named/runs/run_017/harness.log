+function snappyDecompress(input) {
+  let pos = 0;
+  const lenInfo = readVarint(input, pos);
+  const outLen = Number(lenInfo.value);
+  pos = lenInfo.pos;
+  const out = Buffer.allocUnsafe(outLen);
+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let len;
+      if (lenCode < 60) {
+        len = lenCode + 1;
+      } else {
+        const bytes = lenCode - 59;
+        len = 1;
+        let raw = 0;
+        for (let i = 0; i < bytes; i++) raw |= input[pos++] << (8 * i);
+        len = raw + 1;
+      }
+      input.copy(out, outPos, pos, pos + len);
+      pos += len;
+      outPos += len;
+    } else {
+      let len, offset;
+      if (type === 1) {
+        len = 4 + ((tag >> 2) & 0x7);
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = 1 + (tag >> 2);
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = 1 + (tag >> 2);
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
