+    switch (type) {
+      case 0:
+        return;
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.readZigzag();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case 9:
+      case 10: {
+        const { size, elemType } = this.readListHeader();
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
+      case 11: {
+        const size = Number(this.readVarint());
+        if (size === 0) return;
+        const kt = this.readByte();
+        const keyType = kt >> 4;
+        const valType = kt & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(keyType);
+          this.skip(valType);
+        }
+        return;
+      }
+      case 12:
+        this.pushStruct();
+        while (true) {
