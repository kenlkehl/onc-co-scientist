+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let len;
+      if (lenCode < 60) {
+        len = lenCode + 1;
+      } else {
+        const bytes = lenCode - 59;
+        len = 1;
+        let raw = 0;
+        for (let i = 0; i < bytes; i++) raw |= input[pos++] << (8 * i);
+        len = raw + 1;
+      }
+      input.copy(out, outPos, pos, pos + len);
+      pos += len;
+      outPos += len;
+    } else {
