+      } else {
+        const bytes = lenCode - 59;
+        len = 1;
+        let raw = 0;
+        for (let i = 0; i < bytes; i++) raw |= input[pos++] << (8 * i);
+        len = raw + 1;
+      }
+      input.copy(out, outPos, pos, pos + len);
+      pos += len;
+      outPos += len;
+    } else {
+      let len, offset;
+      if (type === 1) {
+        len = 4 + ((tag >> 2) & 0x7);
+        offset = ((tag & 0xe0) << 3) | input[pos++];
