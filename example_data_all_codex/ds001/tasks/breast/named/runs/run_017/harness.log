+    1: { name: 'columns', read: (r) => readList(r, () => readColumnChunk(r)) },
+    2: { name: 'total_byte_size', read: readI },
+    3: { name: 'num_rows', read: readI },
+    5: { name: 'file_offset', read: readI },
+    6: { name: 'total_compressed_size', read: readI },
+  });
+}
+
+function readFileMetaData(footer) {
+  const reader = new CompactReader(footer);
+  return readStructWith(reader, {
+    1: { name: 'version', read: readI },
+    2: { name: 'schema', read: (r) => readList(r, () => readSchemaElement(r)) },
+    3: { name: 'num_rows', read: readI },
+    4: { name: 'row_groups', read: (r) => readList(r, () => readRowGroup(r)) },
+    5: { name: 'key_value_metadata', read: (r, t) => r.readValue(t) },
+    6: { name: 'created_by', read: readString },
+  });
