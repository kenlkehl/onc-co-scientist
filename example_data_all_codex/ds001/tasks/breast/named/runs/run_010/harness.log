+  double() { const v = this.b.readDoubleLE(this.p); this.p += 8; return v; }
+  binary() { const n = Number(this.varint()); const out = this.b.subarray(this.p, this.p + n); this.p += n; return out; }
+  listHeader() { const h = this.byte(); let size = h >> 4; const type = h & 15; if (size === 15) size = Number(this.varint()); return { size, type }; }
+  fieldHeader() {
+    const h = this.byte();
+    const type = h & 15;
+    if (type === CT.STOP) return { type, id: 0 };
+    const delta = h >> 4;
