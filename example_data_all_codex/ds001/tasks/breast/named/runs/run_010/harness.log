+class CompactReader {
+  constructor(b) {
+    this.b = b;
+    this.p = 0;
+    this.stack = [0];
+  }
+  byte() { return this.b[this.p++]; }
+  varint() {
+    let shift = 0n, result = 0n;
+    while (true) {
+      const x = BigInt(this.byte());
+      result |= (x & 0x7fn) << shift;
+      if ((x & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  zigzag() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  int() { return this.zigzag(); }
+  i64() {
+    const n = this.varint();
+    const z = (n >> 1n) ^ (-(n & 1n));
+    const num = Number(z);
+    return Number.isSafeInteger(num) ? num : z.toString();
+  }
+  double() {
+    const v = this.b.readDoubleLE(this.p);
+    this.p += 8;
+    return v;
+  }
+  binary() {
+    const len = Number(this.varint());
+    const out = this.b.subarray(this.p, this.p + len);
+    this.p += len;
+    return out;
+  }
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+  fieldHeader() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === T.STOP) return { type, id: 0 };
+    const delta = h >> 4;
+    let id;
+    if (delta === 0) id = this.int();
