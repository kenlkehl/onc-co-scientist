--- /dev/null
+++ b/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/breast/named/parquet_inspect.js
@@ -0,0 +1,154 @@
+const fs = require('fs');
+
+const path = 'dataset.parquet';
+const buf = fs.readFileSync(path);
+function readU32LE(off) { return buf.readUInt32LE(off); }
+if (buf.subarray(0, 4).toString() !== 'PAR1' || buf.subarray(buf.length - 4).toString() !== 'PAR1') {
+  throw new Error('Not a parquet file');
+}
+const footerLen = readU32LE(buf.length - 8);
+const footerStart = buf.length - 8 - footerLen;
+const footer = buf.subarray(footerStart, footerStart + footerLen);
+
+const T = {
+  STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6, DOUBLE: 7,
+  BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12
+};
+
+class CompactReader {
+  constructor(b) {
+    this.b = b;
+    this.p = 0;
+    this.stack = [0];
+  }
+  byte() { return this.b[this.p++]; }
+  varint() {
+    let shift = 0n, result = 0n;
+    while (true) {
+      const x = BigInt(this.byte());
+      result |= (x & 0x7fn) << shift;
+      if ((x & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  zigzag() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  int() { return this.zigzag(); }
+  i64() {
+    const n = this.varint();
+    const z = (n >> 1n) ^ (-(n & 1n));
+    const num = Number(z);
+    return Number.isSafeInteger(num) ? num : z.toString();
+  }
+  double() {
+    const v = this.b.readDoubleLE(this.p);
+    this.p += 8;
+    return v;
+  }
+  binary() {
+    const len = Number(this.varint());
+    const out = this.b.subarray(this.p, this.p + len);
+    this.p += len;
+    return out;
+  }
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+  fieldHeader() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === T.STOP) return { type, id: 0 };
+    const delta = h >> 4;
+    let id;
+    if (delta === 0) id = this.int();
+    else id = this.stack[this.stack.length - 1] + delta;
+    this.stack[this.stack.length - 1] = id;
+    return { type, id };
+  }
+  readValue(type, structName = '') {
+    switch (type) {
+      case T.TRUE: return true;
+      case T.FALSE: return false;
+      case T.BYTE: return this.byte();
+      case T.I16:
+      case T.I32: return this.int();
+      case T.I64: return this.i64();
+      case T.DOUBLE: return this.double();
+      case T.BINARY: return this.binary();
+      case T.LIST: {
+        const { size, type: elemType } = this.listHeader();
+        const arr = [];
+        for (let i = 0; i < size; i++) arr.push(this.readValue(elemType));
+        return arr;
+      }
+      case T.STRUCT: return this.readStruct(structName);
+      default: throw new Error(`Unsupported compact type ${type} at ${this.p}`);
+    }
+  }
+  readStruct(structName = '') {
+    const obj = {};
+    this.stack.push(0);
+    while (true) {
+      const { type, id } = this.fieldHeader();
+      if (type === T.STOP) break;
+      obj[id] = this.readValue(type);
+    }
+    this.stack.pop();
+    return obj;
+  }
+}
+
+function utf8(v) { return Buffer.isBuffer(v) ? v.toString('utf8') : v; }
+function pathOf(chunk) {
+  const md = chunk[3] || {};
+  return (md[3] || []).map(utf8).join('.');
+}
+
+const r = new CompactReader(footer);
+const meta = r.readStruct('FileMetaData');
+console.log(JSON.stringify({
+  fileBytes: buf.length,
+  footerLen,
+  version: meta[1],
+  numRows: meta[3],
+  createdBy: utf8(meta[6]),
+  schemaCount: (meta[2] || []).length,
+  rowGroups: (meta[4] || []).length,
+  schema: (meta[2] || []).map(s => ({
+    name: utf8(s[4]),
+    type: s[1],
+    typeLength: s[2],
+    repetition: s[3],
+    numChildren: s[5],
+    convertedType: s[6],
+    logicalType: s[10] ? Object.keys(s[10]) : undefined
+  })),
+  rowGroupSummary: (meta[4] || []).map((rg, i) => ({
+    i,
+    numRows: rg[3],
+    columns: (rg[1] || []).length,
+    totalByteSize: rg[2],
+    firstColumns: (rg[1] || []).slice(0, 8).map(c => {
+      const md = c[3] || {};
+      return {
+        path: pathOf(c),
+        type: md[1],
+        encodings: md[2],
+        codec: md[4],
+        numValues: md[5],
+        uncomp: md[6],
+        comp: md[7],
+        dataPageOffset: md[9],
+        dictPageOffset: md[11],
+        statsFields: md[12] ? Object.keys(md[12]) : []
+      };
+    })
+  }))
+}, null, 2));

codex
The parquet is a single row group written by Arrow, using Snappy-compressed dictionary pages for the columns. I’m extending the local reader to decode those pages so we can run the actual statistics.
