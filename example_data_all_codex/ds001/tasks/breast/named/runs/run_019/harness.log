+function transposeMultiplyDesign(columns, y = null) {
+  const p = columns.length;
+  const n = columns[0].length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = y ? Array(p).fill(0) : null;
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = columns[a][i];
+      if (y) xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += xa * columns[b][i];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  }
+  return { xtx, xty };
