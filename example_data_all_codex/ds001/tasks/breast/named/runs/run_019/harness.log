+function addInteractionResult(baseFit, a, b) {
+  const y = baseFit.y;
+  const n = y.length;
+  const z = new Array(y.length);
+  for (let i = 0; i < y.length; i++) z[i] = a.values[i] * b.values[i];
+  const xtz = new Array(baseFit.columns.length).fill(0);
+  for (let i = 0; i < n; i++) {
+    const zi = z[i];
+    for (let j = 0; j < baseFit.columns.length; j++) xtz[j] += baseFit.columns[j][i] * zi;
+  }
+  const gamma = matVec(baseFit.inv, xtz);
+  let rssZ = 0;
+  let rzy = 0;
+  for (let i = 0; i < n; i++) {
+    let fittedZ = 0;
+    for (let j = 0; j < baseFit.columns.length; j++) fittedZ += baseFit.columns[j][i] * gamma[j];
+    const rz = z[i] - fittedZ;
+    rssZ += rz * rz;
+    rzy += rz * baseFit.residuals[i];
+  }
+  const beta = rzy / rssZ;
+  const sse = baseFit.sse - (rzy * rzy) / rssZ;
+  const df = n - baseFit.columns.length - 1;
+  const sigma2 = sse / df;
+  const se = Math.sqrt(Math.max(0, sigma2 / rssZ));
