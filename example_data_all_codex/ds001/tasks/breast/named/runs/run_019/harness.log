+      throw new Error(`Unknown compact type ${type} at byte ${reader.pos}`);
+  }
+}
+
+function readThriftStruct(reader) {
+  const obj = {};
+  let lastFieldId = 0;
+  while (true) {
+    const header = reader.byte();
+    const type = header & 0x0f;
+    if (type === CompactType.STOP) break;
+    const modifier = header >> 4;
+    const fieldId = modifier === 0 ? reader.i32() : lastFieldId + modifier;
+    lastFieldId = fieldId;
+    obj[fieldId] = readThriftValue(reader, type);
+  }
+  return obj;
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  function readVarint() {
+    let result = 0;
+    let shift = 0;
+    while (true) {
+      const b = input[ip++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const outLen = readVarint();
+  const out = Buffer.alloc(outLen);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const n = len - 59;
+        len = 0;
+        for (let i = 0; i < n; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = 4 + ((tag >> 2) & 7);
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        len = 1 + (tag >> 2);
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        len = 1 + (tag >> 2);
+        offset = (input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24)) >>> 0;
+        ip += 4;
+      }
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch: decoded ${op}, expected ${outLen}`);
+  return out;
+}
+
+function readHybridRleBitpack(buf, offset, bitWidth, count) {
+  const values = new Array(count);
+  let pos = offset;
+  let out = 0;
+  function readUnsignedVarint() {
+    let shift = 0;
+    let result = 0;
+    while (true) {
+      const b = buf[pos++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const byteWidth = Math.ceil(bitWidth / 8);
+  while (out < count) {
+    const header = readUnsignedVarint();
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < byteWidth; i++) value |= buf[pos++] << (8 * i);
+      for (let i = 0; i < runLength && out < count; i++) values[out++] = value;
+    } else {
+      const groups = header >> 1;
+      const nVals = groups * 8;
+      let bitPos = 0;
+      const totalBits = nVals * bitWidth;
+      const start = pos;
+      const mask = bitWidth === 32 ? 0xffffffff : (1 << bitWidth) - 1;
+      for (let i = 0; i < nVals && out < count; i++) {
+        const byteIndex = start + (bitPos >> 3);
+        const shift = bitPos & 7;
+        let word = buf[byteIndex] | (buf[byteIndex + 1] << 8) | (buf[byteIndex + 2] << 16) | (buf[byteIndex + 3] << 24);
+        values[out++] = (word >>> shift) & mask;
+        bitPos += bitWidth;
+      }
+      pos += Math.ceil(totalBits / 8);
+    }
+  }
+  return { values, pos };
+}
+
+function bitWidthFor(n) {
+  if (n <= 1) return 1;
+  return Math.ceil(Math.log2(n));
+}
+
+function readPlainDictionary(payload, physicalType, numValues) {
+  const out = new Array(numValues);
+  let pos = 0;
+  for (let i = 0; i < numValues; i++) {
+    if (physicalType === 5) {
+      out[i] = payload.readDoubleLE(pos);
+      pos += 8;
+    } else if (physicalType === 2) {
+      out[i] = Number(payload.readBigInt64LE(pos));
+      pos += 8;
+    } else if (physicalType === 6) {
+      const len = payload.readInt32LE(pos);
+      pos += 4 + len;
+      out[i] = null;
+    } else {
+      throw new Error(`Unsupported plain dictionary physical type ${physicalType}`);
+    }
+  }
+  return out;
+}
+
+function parseParquet() {
+  const file = fs.readFileSync(parquetPath);
+  if (file.slice(0, 4).toString("utf8") !== "PAR1" || file.slice(-4).toString("utf8") !== "PAR1") {
+    throw new Error("Not a Parquet file");
+  }
+  const footerLen = file.readInt32LE(file.length - 8);
+  const footer = file.slice(file.length - 8 - footerLen, file.length - 8);
+  const metadata = readThriftStruct(new CompactReader(footer));
+  const schema = metadata[2];
+  const rowGroup = metadata[4][0];
+  const columns = rowGroup[1];
+  const data = {};
+  const colMeta = [];
+
+  for (let ci = 0; ci < columns.length; ci++) {
+    const md = columns[ci][3];
+    const name = md[3][0];
+    const physicalType = md[1];
+    if (name === "patient_id") continue;
+    const numValues = md[5];
+    let dictionary = null;
+    if (md[11] != null) {
+      const headerReader = new CompactReader(file, md[11]);
+      const pageHeader = readThriftStruct(headerReader);
+      const payload = snappyUncompress(file.slice(headerReader.pos, headerReader.pos + pageHeader[3]));
+      dictionary = readPlainDictionary(payload, physicalType, pageHeader[7][1]);
+    }
+    const values = new Array(numValues);
+    let out = 0;
+    let offset = md[9];
+    while (out < numValues) {
+      const headerReader = new CompactReader(file, offset);
+      const pageHeader = readThriftStruct(headerReader);
+      const payloadStart = headerReader.pos;
+      const payload = snappyUncompress(file.slice(payloadStart, payloadStart + pageHeader[3]));
+      offset = payloadStart + pageHeader[3];
+      if (pageHeader[1] !== 0) continue;
+      const dataHeader = pageHeader[5];
+      const pageNumValues = dataHeader[1];
+      const encoding = dataHeader[2];
+      let pos = 0;
+      if (dataHeader[3] === 3) {
+        const defLen = payload.readInt32LE(pos);
+        pos += 4 + defLen;
+      }
+      if (encoding === 8) {
+        const width = payload[pos++];
+        const decoded = readHybridRleBitpack(payload, pos, width, pageNumValues).values;
+        for (let i = 0; i < pageNumValues; i++) values[out++] = dictionary[decoded[i]];
+      } else if (encoding === 0) {
+        const direct = readPlainDictionary(payload.slice(pos), physicalType, pageNumValues);
+        for (const value of direct) values[out++] = value;
+      } else {
+        throw new Error(`Unsupported page encoding ${encoding} in ${name}`);
+      }
+    }
+    data[name] = values;
+    colMeta.push({ name, physicalType, dictionaryValues: dictionary ? dictionary.length : null });
+  }
+  return { data, metadata, schema, colMeta };
+}
+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask == null || mask[i]) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, mask = null) {
+  const m = mean(arr, mask);
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask == null || mask[i]) {
+      const d = arr[i] - m;
+      s += d * d;
+      n++;
+    }
+  }
+  return s / (n - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function normalP(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  return Math.max(0, Math.min(1, p));
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    let maxAbs = Math.abs(aug[col][col]);
+    for (let r = col + 1; r < n; r++) {
+      const v = Math.abs(aug[r][col]);
+      if (v > maxAbs) {
+        maxAbs = v;
+        pivot = r;
+      }
+    }
+    if (maxAbs < 1e-10) throw new Error(`Singular matrix at column ${col}`);
+    if (pivot !== col) {
+      const tmp = aug[col];
+      aug[col] = aug[pivot];
+      aug[pivot] = tmp;
+    }
+    const pv = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= pv;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function transposeMultiplyDesign(columns, y = null) {
+  const p = columns.length;
+  const n = columns[0].length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = y ? Array(p).fill(0) : null;
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = columns[a][i];
+      if (y) xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += xa * columns[b][i];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  }
+  return { xtx, xty };
+}
+
+function matVec(m, v) {
+  return m.map((row) => row.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function fitOls(y, predictors) {
+  const n = y.length;
+  const names = ["intercept", ...predictors.map((p) => p.name)];
+  const columns = [Array(n).fill(1), ...predictors.map((p) => p.values)];
+  const { xtx, xty } = transposeMultiplyDesign(columns, y);
+  const inv = invertMatrix(xtx);
+  const beta = matVec(inv, xty);
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < columns.length; j++) pred += beta[j] * columns[j][i];
+    const r = y[i] - pred;
+    sse += r * r;
+  }
+  const df = n - columns.length;
+  const sigma2 = sse / df;
+  const rows = names.map((name, i) => {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    const z = beta[i] / se;
+    return { name, beta: beta[i], se, z, p: normalP(z) };
+  });
+  return { rows, sigma2, df, sse, names, columns, inv, beta, y };
+}
+
+function addInteractionResult(y, basePredictors, a, b) {
+  const z = new Array(y.length);
+  for (let i = 0; i < y.length; i++) z[i] = a.values[i] * b.values[i];
+  const fit = fitOls(y, [...basePredictors, { name: `${a.name}:${b.name}`, values: z }]);
+  return fit.rows[fit.rows.length - 1];
+}
+
+function groupDiff(y, x) {
+  const mask1 = x.map((v) => v === 1);
+  const mask0 = x.map((v) => v === 0);
+  const n1 = mask1.reduce((s, v) => s + (v ? 1 : 0), 0);
+  const n0 = mask0.length - n1;
+  const m1 = mean(y, mask1);
+  const m0 = mean(y, mask0);
+  const v1 = variance(y, mask1);
+  const v0 = variance(y, mask0);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, m1, m0, diff: m1 - m0, p: normalP(z) };
+}
+
+function subgroupTreatmentDiff(y, treatment, subgroup) {
+  const diffs = {};
+  for (const s of [0, 1]) {
+    const idx = subgroup.values.map((v) => v === s);
+    let n1 = 0;
+    let n0 = 0;
+    let sum1 = 0;
+    let sum0 = 0;
+    for (let i = 0; i < y.length; i++) {
+      if (!idx[i]) continue;
+      if (treatment.values[i] === 1) {
+        n1++;
+        sum1 += y[i];
+      } else {
+        n0++;
+        sum0 += y[i];
+      }
+    }
+    diffs[s] = { n_treated: n1, n_untreated: n0, mean_treated: sum1 / n1, mean_untreated: sum0 / n0, diff: sum1 / n1 - sum0 / n0 };
+  }
+  return diffs;
+}
+
+function quantile(arr, q) {
+  const sorted = arr.slice().sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] * (hi - pos) + sorted[hi] * (pos - lo);
+}
+
+function main() {
+  const { data, colMeta } = parseParquet();
+  const y = data.pfs_months;
+  const names = Object.keys(data).filter((name) => name !== "pfs_months");
+  const binaryNames = names.filter((name) => new Set(data[name]).size <= 6 && data[name].every((v) => Number.isInteger(v)));
+  const continuousNames = names.filter((name) => !binaryNames.includes(name));
+  const predictors = names.map((name) => ({ name, values: data[name] }));
+  const adjusted = fitOls(y, predictors);
+  const adjustedRows = Object.fromEntries(adjusted.rows.map((row) => [row.name, row]));
+
+  const univariate = binaryNames.map((name) => ({ name, ...groupDiff(y, data[name]) })).sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff));
+  const topAdjusted = adjusted.rows
+    .filter((row) => row.name !== "intercept")
+    .slice()
+    .sort((a, b) => Math.abs(b.beta / b.se) - Math.abs(a.beta / a.se));
+
+  const derived = {};
+  derived.brca_any_mutation = data.brca1_mutation.map((v, i) => (v || data.brca2_mutation[i] ? 1 : 0));
+  derived.triple_negative = data.er_positive.map((v, i) => (v === 0 && data.pr_positive[i] === 0 && data.her2_positive[i] === 0 ? 1 : 0));
+  derived.hormone_receptor_positive = data.er_positive.map((v, i) => (v || data.pr_positive[i] ? 1 : 0));
+  derived.high_nlr = data.nlr.map((v) => (v >= quantile(data.nlr, 0.75) ? 1 : 0));
+  derived.high_crp = data.crp_mg_l.map((v) => (v >= quantile(data.crp_mg_l, 0.75) ? 1 : 0));
+  derived.low_albumin = data.albumin_g_dl.map((v) => (v <= quantile(data.albumin_g_dl, 0.25) ? 1 : 0));
+  derived.high_ki67 = data.ki67_pct.map((v) => (v >= quantile(data.ki67_pct, 0.75) ? 1 : 0));
+
+  const treatmentNames = names.filter((name) => name.startsWith("treatment_"));
+  const modifierNames = [
+    "er_positive",
+    "pr_positive",
+    "her2_positive",
+    "her2_low",
+    "her2_amplification",
+    "brca1_mutation",
+    "brca2_mutation",
+    "pik3ca_mutation",
+    "stage_iv",
+    "liver_mets",
+    "bone_mets",
+    "has_brain_mets",
+    "autoimmune_disease",
+    "postmenopausal",
+    "node_positive",
+    "brca_any_mutation",
+    "triple_negative",
+    "hormone_receptor_positive",
+    "high_nlr",
+    "high_crp",
+    "low_albumin",
+    "high_ki67",
+  ];
+  const basePredictors = predictors;
+  const interactions = [];
+  for (const tName of treatmentNames) {
+    for (const mName of modifierNames) {
+      const t = { name: tName, values: data[tName] };
+      const values = data[mName] || derived[mName];
+      if (!values) continue;
+      const m = { name: mName, values };
+      const row = addInteractionResult(y, basePredictors, t, m);
+      interactions.push({ treatment: tName, modifier: mName, ...row });
+    }
+  }
+  interactions.sort((a, b) => Math.abs(b.beta / b.se) - Math.abs(a.beta / a.se));
+
+  const keySubgroups = [
+    ["treatment_tamoxifen", "er_positive"],
+    ["treatment_palbociclib", "er_positive"],
+    ["treatment_trastuzumab", "her2_positive"],
+    ["treatment_trastuzumab", "her2_amplification"],
+    ["treatment_olaparib", "brca1_mutation"],
+    ["treatment_olaparib", "brca2_mutation"],
+    ["treatment_sacituzumab_govitecan", "triple_negative"],
+    ["treatment_pembrolizumab", "triple_negative"],
+    ["treatment_pembrolizumab", "autoimmune_disease"],
+    ["treatment_palbociclib", "pik3ca_mutation"],
+  ];
+  const subgroupDiffs = {};
+  for (const [t, s] of keySubgroups) {
+    subgroupDiffs[`${t}|${s}`] = subgroupTreatmentDiff(y, { name: t, values: data[t] }, { name: s, values: data[s] || derived[s] });
+  }
+
+  const summary = {
+    n: y.length,
+    pfs: {
+      mean: mean(y),
+      sd: Math.sqrt(variance(y)),
+      q05: quantile(y, 0.05),
+      q25: quantile(y, 0.25),
+      q50: quantile(y, 0.5),
+      q75: quantile(y, 0.75),
+      q95: quantile(y, 0.95),
+    },
+    colMeta,
+    binaryPrevalence: Object.fromEntries(binaryNames.map((name) => [name, mean(data[name])])),
+    continuous: Object.fromEntries(continuousNames.map((name) => [name, { mean: mean(data[name]), sd: Math.sqrt(variance(data[name])), q25: quantile(data[name], 0.25), q75: quantile(data[name], 0.75) }])),
+    univariate: univariate.slice(0, 30),
+    adjustedTop: topAdjusted.slice(0, 50),
+    adjustedSelected: Object.fromEntries([
+      ...treatmentNames,
+      "age_years",
+      "ecog_ps",
+      "stage_iv",
+      "has_brain_mets",
+      "liver_mets",
+      "bone_mets",
+      "albumin_g_dl",
+      "ldh_u_l",
+      "weight_loss_pct_6mo",
+      "crp_mg_l",
+      "nlr",
+      "hemoglobin_g_dl",
+      "alkaline_phosphatase_u_l",
+      "tumor_size_cm",
+      "ki67_pct",
+      "er_positive",
+      "pr_positive",
+      "her2_positive",
+      "her2_low",
+      "brca1_mutation",
+      "brca2_mutation",
+      "pik3ca_mutation",
+    ].map((name) => [name, adjustedRows[name]])),
+    interactions: interactions.slice(0, 80),
+    interactionSelected: Object.fromEntries(interactions.map((r) => [`${r.treatment}|${r.modifier}`, r])),
+    subgroupDiffs,
+  };
+
+  fs.writeFileSync("exploration_results.json", JSON.stringify(summary, null, 2));
+  console.log(JSON.stringify({
+    n: summary.n,
+    pfs: summary.pfs,
+    univariateTop10: summary.univariate.slice(0, 10),
+    adjustedTop20: summary.adjustedTop.slice(0, 20),
+    interactionsTop20: summary.interactions.slice(0, 20),
+  }, null, 2));
+}
+
+main();

