+  const xtz = new Array(baseFit.columns.length).fill(0);
+  let zty = 0;
+  let ztz = 0;
+  for (let i = 0; i < n; i++) {
+    const zi = z[i];
+    zty += zi * baseFit.residuals[i];
+    ztz += zi * zi;
+    for (let j = 0; j < baseFit.columns.length; j++) xtz[j] += baseFit.columns[j][i] * zi;
