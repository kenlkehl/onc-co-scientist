+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ -(n & 1n);
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  binary() {
+    const len = Number(this.varint());
+    const value = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return value;
+  }
