+      aug[col] = aug[pivot];
+      aug[pivot] = tmp;
+    }
+    const pv = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= pv;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
