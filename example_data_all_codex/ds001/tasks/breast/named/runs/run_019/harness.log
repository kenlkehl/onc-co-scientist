+    let n0 = 0;
+    let sum1 = 0;
+    let sum0 = 0;
+    for (let i = 0; i < y.length; i++) {
+      if (!idx[i]) continue;
+      if (treatment.values[i] === 1) {
+        n1++;
+        sum1 += y[i];
+      } else {
+        n0++;
+        sum0 += y[i];
+      }
+    }
