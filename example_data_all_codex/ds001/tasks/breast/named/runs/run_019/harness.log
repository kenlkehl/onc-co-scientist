+  const summary = {
+    n: y.length,
+    pfs: {
+      mean: mean(y),
+      sd: Math.sqrt(variance(y)),
+      q05: quantile(y, 0.05),
+      q25: quantile(y, 0.25),
+      q50: quantile(y, 0.5),
