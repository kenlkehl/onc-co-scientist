+const fs = require("fs");
+
+const parquetPath = "dataset.parquet";
+
+const CompactType = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ -(n & 1n);
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  binary() {
+    const len = Number(this.varint());
+    const value = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return value;
+  }
+
+  double() {
+    const value = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return value;
+  }
+}
+
+function readThriftValue(reader, type) {
+  switch (type) {
+    case CompactType.TRUE:
+      return true;
+    case CompactType.FALSE:
+      return false;
+    case CompactType.BYTE:
+      return reader.byte();
+    case CompactType.I16:
+    case CompactType.I32:
+      return reader.i32();
+    case CompactType.I64:
+      return reader.i64();
+    case CompactType.DOUBLE:
+      return reader.double();
+    case CompactType.BINARY:
+      return reader.binary().toString("utf8");
+    case CompactType.STRUCT:
+      return readThriftStruct(reader);
+    case CompactType.LIST:
+    case CompactType.SET: {
+      const header = reader.byte();
+      let size = header >> 4;
+      const elemType = header & 0x0f;
+      if (size === 15) size = Number(reader.varint());
+      const out = [];
+      for (let i = 0; i < size; i++) out.push(readThriftValue(reader, elemType));
+      return out;
+    }
+    case CompactType.MAP: {
+      const size = Number(reader.varint());
+      if (size === 0) return [];
+      const header = reader.byte();
+      const keyType = header >> 4;
+      const valType = header & 0x0f;
+      const out = [];
+      for (let i = 0; i < size; i++) {
+        out.push([readThriftValue(reader, keyType), readThriftValue(reader, valType)]);
+      }
+      return out;
+    }
+    default:
+      throw new Error(`Unknown compact type ${type} at byte ${reader.pos}`);
+  }
+}
+
+function readThriftStruct(reader) {
+  const obj = {};
+  let lastFieldId = 0;
+  while (true) {
+    const header = reader.byte();
+    const type = header & 0x0f;
+    if (type === CompactType.STOP) break;
+    const modifier = header >> 4;
+    const fieldId = modifier === 0 ? reader.i32() : lastFieldId + modifier;
+    lastFieldId = fieldId;
+    obj[fieldId] = readThriftValue(reader, type);
+  }
+  return obj;
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  function readVarint() {
+    let result = 0;
+    let shift = 0;
+    while (true) {
+      const b = input[ip++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const outLen = readVarint();
+  const out = Buffer.alloc(outLen);
+  let op = 0;
