+}
+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask == null || mask[i]) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, mask = null) {
+  const m = mean(arr, mask);
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask == null || mask[i]) {
+      const d = arr[i] - m;
+      s += d * d;
+      n++;
+    }
+  }
+  return s / (n - 1);
