+  const modifierNames = [
+    "er_positive",
+    "pr_positive",
+    "her2_positive",
+    "her2_low",
+    "her2_amplification",
+    "brca1_mutation",
+    "brca2_mutation",
+    "pik3ca_mutation",
+    "stage_iv",
+    "liver_mets",
+    "bone_mets",
+    "has_brain_mets",
+    "autoimmune_disease",
+    "postmenopausal",
+    "node_positive",
+    "brca_any_mutation",
+    "triple_negative",
+    "hormone_receptor_positive",
+    "high_nlr",
+    "high_crp",
+    "low_albumin",
+    "high_ki67",
+  ];
+  const basePredictors = predictors;
+  const interactions = [];
+  for (const tName of treatmentNames) {
+    for (const mName of modifierNames) {
+      const t = { name: tName, values: data[tName] };
+      const values = data[mName] || derived[mName];
+      if (!values) continue;
+      const m = { name: mName, values };
+      const row = addInteractionResult(y, basePredictors, t, m);
+      interactions.push({ treatment: tName, modifier: mName, ...row });
+    }
+  }
+  interactions.sort((a, b) => Math.abs(b.beta / b.se) - Math.abs(a.beta / a.se));
+
+  const keySubgroups = [
+    ["treatment_tamoxifen", "er_positive"],
+    ["treatment_palbociclib", "er_positive"],
+    ["treatment_trastuzumab", "her2_positive"],
+    ["treatment_trastuzumab", "her2_amplification"],
+    ["treatment_olaparib", "brca1_mutation"],
+    ["treatment_olaparib", "brca2_mutation"],
+    ["treatment_sacituzumab_govitecan", "triple_negative"],
+    ["treatment_pembrolizumab", "triple_negative"],
+    ["treatment_pembrolizumab", "autoimmune_disease"],
+    ["treatment_palbociclib", "pik3ca_mutation"],
+  ];
+  const subgroupDiffs = {};
+  for (const [t, s] of keySubgroups) {
+    subgroupDiffs[`${t}|${s}`] = subgroupTreatmentDiff(y, { name: t, values: data[t] }, { name: s, values: data[s] || derived[s] });
+  }
+
+  const summary = {
+    n: y.length,
+    pfs: {
+      mean: mean(y),
+      sd: Math.sqrt(variance(y)),
+      q05: quantile(y, 0.05),
+      q25: quantile(y, 0.25),
+      q50: quantile(y, 0.5),
+      q75: quantile(y, 0.75),
+      q95: quantile(y, 0.95),
+    },
+    colMeta,
+    binaryPrevalence: Object.fromEntries(binaryNames.map((name) => [name, mean(data[name])])),
+    continuous: Object.fromEntries(continuousNames.map((name) => [name, { mean: mean(data[name]), sd: Math.sqrt(variance(data[name])), q25: quantile(data[name], 0.25), q75: quantile(data[name], 0.75) }])),
+    univariate: univariate.slice(0, 30),
+    adjustedTop: topAdjusted.slice(0, 50),
+    adjustedSelected: Object.fromEntries([
+      ...treatmentNames,
+      "age_years",
+      "ecog_ps",
+      "stage_iv",
+      "has_brain_mets",
+      "liver_mets",
+      "bone_mets",
+      "albumin_g_dl",
+      "ldh_u_l",
+      "weight_loss_pct_6mo",
+      "crp_mg_l",
+      "nlr",
+      "hemoglobin_g_dl",
+      "alkaline_phosphatase_u_l",
+      "tumor_size_cm",
+      "ki67_pct",
+      "er_positive",
+      "pr_positive",
+      "her2_positive",
+      "her2_low",
+      "brca1_mutation",
+      "brca2_mutation",
+      "pik3ca_mutation",
+    ].map((name) => [name, adjustedRows[name]])),
+    interactions: interactions.slice(0, 80),
+    interactionSelected: Object.fromEntries(interactions.map((r) => [`${r.treatment}|${r.modifier}`, r])),
+    subgroupDiffs,
+  };
+
+  fs.writeFileSync("exploration_results.json", JSON.stringify(summary, null, 2));
+  console.log(JSON.stringify({
+    n: summary.n,
+    pfs: summary.pfs,
+    univariateTop10: summary.univariate.slice(0, 10),
+    adjustedTop20: summary.adjustedTop.slice(0, 20),
+    interactionsTop20: summary.interactions.slice(0, 20),
+  }, null, 2));
+}
+
+main();

codex
The decoder itself is viable, but the first pass spent too much time refitting full regressions for every interaction. I’m narrowing the script so it fits the main model once and then runs the targeted interaction models more efficiently.
