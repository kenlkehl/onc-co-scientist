+    "her2_amplification",
+  ];
+  const predictors = coreNames.map((name) => ({ name, values: data[name] }));
+  if (process.argv[2] === "parse-only") {
+    console.log(JSON.stringify({ n: y.length, names: names.length, binaryNames: binaryNames.length, pfsMean: mean(y), pfsSd: Math.sqrt(variance(y)) }, null, 2));
+    return;
+  }
+  console.error("Fitting core adjusted model");
+  const adjusted = fitOls(y, predictors);
+  console.error("Fitted core adjusted model");
+  const adjustedRows = Object.fromEntries(adjusted.rows.map((row) => [row.name, row]));
+
+  console.error("Computing univariate summaries");
+  const univariate = binaryNames.map((name) => ({ name, ...groupDiff(y, data[name]) })).sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff));
