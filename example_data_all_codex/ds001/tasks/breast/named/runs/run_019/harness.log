+  const xty = y ? Array(p).fill(0) : null;
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = columns[a][i];
+      if (y) xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += xa * columns[b][i];
+    }
+  }
+  for (let a = 0; a < p; a++) {
