+
+function main() {
+  const { data, colMeta } = parseParquet();
+  const y = data.pfs_months;
+  const names = Object.keys(data).filter((name) => name !== "pfs_months");
+  const binaryNames = names.filter((name) => new Set(data[name]).size <= 6 && data[name].every((v) => Number.isInteger(v)));
+  const continuousNames = names.filter((name) => !binaryNames.includes(name));
+  const predictors = names.map((name) => ({ name, values: data[name] }));
+  const adjusted = fitOls(y, predictors);
+  const adjustedRows = Object.fromEntries(adjusted.rows.map((row) => [row.name, row]));
