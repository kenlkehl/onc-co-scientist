+  let out = 0;
+  function readUnsignedVarint() {
+    let shift = 0;
+    let result = 0;
+    while (true) {
+      const b = buf[pos++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const byteWidth = Math.ceil(bitWidth / 8);
