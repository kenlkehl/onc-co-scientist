+  derived.high_ki67 = data.ki67_pct.map((v) => (v >= quantile(data.ki67_pct, 0.75) ? 1 : 0));
+
+  const treatmentNames = names.filter((name) => name.startsWith("treatment_"));
+  const modifierNames = [
+    "er_positive",
+    "pr_positive",
+    "her2_positive",
+    "her2_low",
+    "her2_amplification",
+    "brca1_mutation",
+    "brca2_mutation",
+    "pik3ca_mutation",
+    "stage_iv",
+    "liver_mets",
+    "bone_mets",
+    "has_brain_mets",
+    "autoimmune_disease",
+    "postmenopausal",
+    "node_positive",
+    "brca_any_mutation",
+    "triple_negative",
+    "hormone_receptor_positive",
+    "high_nlr",
+    "high_crp",
+    "low_albumin",
+    "high_ki67",
+  ];
+  const interactions = [];
+  for (const tName of treatmentNames) {
+    for (const mName of modifierNames) {
