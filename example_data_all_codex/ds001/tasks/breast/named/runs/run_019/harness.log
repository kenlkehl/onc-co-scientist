+    data[name] = values;
+    colMeta.push({ name, physicalType, dictionaryValues: dictionary ? dictionary.length : null });
+  }
+  return { data, metadata, schema, colMeta };
+}
+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask == null || mask[i]) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, mask = null) {
+  const m = mean(arr, mask);
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask == null || mask[i]) {
+      const d = arr[i] - m;
+      s += d * d;
+      n++;
+    }
+  }
+  return s / (n - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function normalP(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  return Math.max(0, Math.min(1, p));
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    let maxAbs = Math.abs(aug[col][col]);
+    for (let r = col + 1; r < n; r++) {
+      const v = Math.abs(aug[r][col]);
+      if (v > maxAbs) {
+        maxAbs = v;
+        pivot = r;
+      }
+    }
+    if (maxAbs < 1e-10) throw new Error(`Singular matrix at column ${col}`);
+    if (pivot !== col) {
+      const tmp = aug[col];
+      aug[col] = aug[pivot];
+      aug[pivot] = tmp;
+    }
+    const pv = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= pv;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function transposeMultiplyDesign(columns, y = null) {
+  const p = columns.length;
+  const n = columns[0].length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = y ? Array(p).fill(0) : null;
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = columns[a][i];
+      if (y) xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += xa * columns[b][i];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  }
+  return { xtx, xty };
+}
+
+function matVec(m, v) {
+  return m.map((row) => row.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function fitOls(y, predictors) {
+  const n = y.length;
+  const names = ["intercept", ...predictors.map((p) => p.name)];
+  const columns = [Array(n).fill(1), ...predictors.map((p) => p.values)];
+  const { xtx, xty } = transposeMultiplyDesign(columns, y);
+  const inv = invertMatrix(xtx);
+  const beta = matVec(inv, xty);
+  let sse = 0;
+  const residuals = new Array(n);
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < columns.length; j++) pred += beta[j] * columns[j][i];
+    const r = y[i] - pred;
+    residuals[i] = r;
+    sse += r * r;
+  }
+  const df = n - columns.length;
+  const sigma2 = sse / df;
+  const rows = names.map((name, i) => {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    const z = beta[i] / se;
+    return { name, beta: beta[i], se, z, p: normalP(z) };
+  });
+  return { rows, sigma2, df, sse, names, columns, inv, beta, y, residuals };
+}
+
+function addInteractionResult(baseFit, a, b) {
+  const y = baseFit.y;
+  const n = y.length;
+  const z = new Array(y.length);
+  for (let i = 0; i < y.length; i++) z[i] = a.values[i] * b.values[i];
+  const xtz = new Array(baseFit.columns.length).fill(0);
+  let zty = 0;
+  let ztz = 0;
+  for (let i = 0; i < n; i++) {
+    const zi = z[i];
+    zty += zi * baseFit.residuals[i];
+    ztz += zi * zi;
+    for (let j = 0; j < baseFit.columns.length; j++) xtz[j] += baseFit.columns[j][i] * zi;
+  }
+  const gamma = matVec(baseFit.inv, xtz);
+  let projection = 0;
+  for (let j = 0; j < xtz.length; j++) projection += xtz[j] * gamma[j];
+  const rssZ = ztz - projection;
+  const beta = zty / rssZ;
+  const sse = baseFit.sse - (zty * zty) / rssZ;
+  const df = n - baseFit.columns.length - 1;
+  const sigma2 = sse / df;
+  const se = Math.sqrt(Math.max(0, sigma2 / rssZ));
+  const zscore = beta / se;
+  return { name: `${a.name}:${b.name}`, beta, se, z: zscore, p: normalP(zscore) };
+}
+
+function groupDiff(y, x) {
+  const mask1 = x.map((v) => v === 1);
+  const mask0 = x.map((v) => v === 0);
+  const n1 = mask1.reduce((s, v) => s + (v ? 1 : 0), 0);
+  const n0 = mask0.length - n1;
+  const m1 = mean(y, mask1);
+  const m0 = mean(y, mask0);
+  const v1 = variance(y, mask1);
+  const v0 = variance(y, mask0);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, m1, m0, diff: m1 - m0, p: normalP(z) };
+}
+
+function subgroupTreatmentDiff(y, treatment, subgroup) {
+  const diffs = {};
+  for (const s of [0, 1]) {
+    const idx = subgroup.values.map((v) => v === s);
+    let n1 = 0;
+    let n0 = 0;
+    let sum1 = 0;
+    let sum0 = 0;
+    for (let i = 0; i < y.length; i++) {
+      if (!idx[i]) continue;
+      if (treatment.values[i] === 1) {
+        n1++;
+        sum1 += y[i];
+      } else {
+        n0++;
+        sum0 += y[i];
+      }
+    }
+    diffs[s] = { n_treated: n1, n_untreated: n0, mean_treated: sum1 / n1, mean_untreated: sum0 / n0, diff: sum1 / n1 - sum0 / n0 };
+  }
+  return diffs;
+}
+
+function quantile(arr, q) {
+  const sorted = arr.slice().sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] * (hi - pos) + sorted[hi] * (pos - lo);
+}
+
+function main() {
+  console.error("Parsing parquet");
+  const { data, colMeta } = parseParquet();
+  console.error("Parsed parquet");
+  const y = data.pfs_months;
+  const names = Object.keys(data).filter((name) => name !== "pfs_months");
+  const binaryNames = names.filter((name) => new Set(data[name]).size <= 6 && data[name].every((v) => Number.isInteger(v)));
+  const continuousNames = names.filter((name) => !binaryNames.includes(name));
+  const coreNames = [
+    "age_years",
+    "sex_female",
+    "ecog_ps",
+    "stage_iv",
+    "has_brain_mets",
+    "node_positive",
+    "postmenopausal",
+    "er_positive",
+    "pr_positive",
+    "her2_positive",
+    "her2_low",
+    "brca1_mutation",
+    "brca2_mutation",
+    "pik3ca_mutation",
+    "ki67_pct",
+    "tumor_size_cm",
+    "albumin_g_dl",
