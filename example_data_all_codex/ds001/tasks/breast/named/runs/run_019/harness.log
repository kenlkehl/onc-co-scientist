+      throw new Error(`Unknown compact type ${type} at byte ${reader.pos}`);
+  }
+}
+
+function readThriftStruct(reader) {
+  const obj = {};
+  let lastFieldId = 0;
+  while (true) {
+    const header = reader.byte();
+    const type = header & 0x0f;
+    if (type === CompactType.STOP) break;
+    const modifier = header >> 4;
+    const fieldId = modifier === 0 ? reader.i32() : lastFieldId + modifier;
+    lastFieldId = fieldId;
+    obj[fieldId] = readThriftValue(reader, type);
+  }
+  return obj;
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  function readVarint() {
+    let result = 0;
+    let shift = 0;
+    while (true) {
+      const b = input[ip++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const outLen = readVarint();
+  const out = Buffer.alloc(outLen);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const n = len - 59;
+        len = 0;
+        for (let i = 0; i < n; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = 4 + ((tag >> 2) & 7);
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        len = 1 + (tag >> 2);
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        len = 1 + (tag >> 2);
+        offset = (input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24)) >>> 0;
+        ip += 4;
+      }
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch: decoded ${op}, expected ${outLen}`);
+  return out;
+}
+
+function readHybridRleBitpack(buf, offset, bitWidth, count) {
+  const values = new Array(count);
+  let pos = offset;
+  let out = 0;
+  function readUnsignedVarint() {
+    let shift = 0;
+    let result = 0;
+    while (true) {
+      const b = buf[pos++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const byteWidth = Math.ceil(bitWidth / 8);
+  while (out < count) {
+    const header = readUnsignedVarint();
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < byteWidth; i++) value |= buf[pos++] << (8 * i);
+      for (let i = 0; i < runLength && out < count; i++) values[out++] = value;
+    } else {
+      const groups = header >> 1;
+      const nVals = groups * 8;
+      let bitPos = 0;
+      const totalBits = nVals * bitWidth;
+      const start = pos;
+      const mask = bitWidth === 32 ? 0xffffffff : (1 << bitWidth) - 1;
+      for (let i = 0; i < nVals && out < count; i++) {
+        const byteIndex = start + (bitPos >> 3);
+        const shift = bitPos & 7;
+        let word = buf[byteIndex] | (buf[byteIndex + 1] << 8) | (buf[byteIndex + 2] << 16) | (buf[byteIndex + 3] << 24);
+        values[out++] = (word >>> shift) & mask;
+        bitPos += bitWidth;
+      }
+      pos += Math.ceil(totalBits / 8);
+    }
+  }
+  return { values, pos };
+}
+
+function bitWidthFor(n) {
+  if (n <= 1) return 1;
+  return Math.ceil(Math.log2(n));
+}
+
+function readPlainDictionary(payload, physicalType, numValues) {
+  const out = new Array(numValues);
+  let pos = 0;
+  for (let i = 0; i < numValues; i++) {
+    if (physicalType === 5) {
+      out[i] = payload.readDoubleLE(pos);
+      pos += 8;
+    } else if (physicalType === 2) {
+      out[i] = Number(payload.readBigInt64LE(pos));
+      pos += 8;
+    } else if (physicalType === 6) {
+      const len = payload.readInt32LE(pos);
+      pos += 4 + len;
+      out[i] = null;
+    } else {
+      throw new Error(`Unsupported plain dictionary physical type ${physicalType}`);
+    }
+  }
+  return out;
+}
+
+function parseParquet() {
+  const file = fs.readFileSync(parquetPath);
+  if (file.slice(0, 4).toString("utf8") !== "PAR1" || file.slice(-4).toString("utf8") !== "PAR1") {
+    throw new Error("Not a Parquet file");
+  }
+  const footerLen = file.readInt32LE(file.length - 8);
+  const footer = file.slice(file.length - 8 - footerLen, file.length - 8);
+  const metadata = readThriftStruct(new CompactReader(footer));
+  const schema = metadata[2];
+  const rowGroup = metadata[4][0];
+  const columns = rowGroup[1];
+  const data = {};
+  const colMeta = [];
+
+  for (let ci = 0; ci < columns.length; ci++) {
+    const md = columns[ci][3];
+    const name = md[3][0];
+    const physicalType = md[1];
+    if (name === "patient_id") continue;
+    const numValues = md[5];
+    let dictionary = null;
+    if (md[11] != null) {
+      const headerReader = new CompactReader(file, md[11]);
+      const pageHeader = readThriftStruct(headerReader);
+      const payload = snappyUncompress(file.slice(headerReader.pos, headerReader.pos + pageHeader[3]));
+      dictionary = readPlainDictionary(payload, physicalType, pageHeader[7][1]);
+    }
+    const values = new Array(numValues);
+    let out = 0;
+    let offset = md[9];
+    while (out < numValues) {
+      const headerReader = new CompactReader(file, offset);
+      const pageHeader = readThriftStruct(headerReader);
+      const payloadStart = headerReader.pos;
+      const payload = snappyUncompress(file.slice(payloadStart, payloadStart + pageHeader[3]));
+      offset = payloadStart + pageHeader[3];
+      if (pageHeader[1] !== 0) continue;
+      const dataHeader = pageHeader[5];
+      const pageNumValues = dataHeader[1];
+      const encoding = dataHeader[2];
+      let pos = 0;
+      if (dataHeader[3] === 3) {
+        const defLen = payload.readInt32LE(pos);
+        pos += 4 + defLen;
+      }
+      if (encoding === 8) {
+        const width = payload[pos++];
+        const decoded = readHybridRleBitpack(payload, pos, width, pageNumValues).values;
+        for (let i = 0; i < pageNumValues; i++) values[out++] = dictionary[decoded[i]];
+      } else if (encoding === 0) {
+        const direct = readPlainDictionary(payload.slice(pos), physicalType, pageNumValues);
+        for (const value of direct) values[out++] = value;
+      } else {
+        throw new Error(`Unsupported page encoding ${encoding} in ${name}`);
+      }
+    }
+    data[name] = values;
+    colMeta.push({ name, physicalType, dictionaryValues: dictionary ? dictionary.length : null });
+  }
+  return { data, metadata, schema, colMeta };
+}
+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask == null || mask[i]) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, mask = null) {
+  const m = mean(arr, mask);
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask == null || mask[i]) {
+      const d = arr[i] - m;
+      s += d * d;
+      n++;
+    }
+  }
+  return s / (n - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function normalP(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  return Math.max(0, Math.min(1, p));
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    let maxAbs = Math.abs(aug[col][col]);
+    for (let r = col + 1; r < n; r++) {
+      const v = Math.abs(aug[r][col]);
+      if (v > maxAbs) {
+        maxAbs = v;
+        pivot = r;
+      }
+    }
+    if (maxAbs < 1e-10) throw new Error(`Singular matrix at column ${col}`);
+    if (pivot !== col) {
+      const tmp = aug[col];
+      aug[col] = aug[pivot];
+      aug[pivot] = tmp;
+    }
+    const pv = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= pv;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) aug[r][j] -= f * aug[col][j];
