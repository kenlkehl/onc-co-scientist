+}
+
+function bitWidth(maxValue) {
+  if (maxValue <= 0) return 0;
+  return Math.ceil(Math.log2(maxValue + 1));
+}
+
+function readUnsignedVar(buffer, state) {
+  let shift = 0;
+  let n = 0;
+  while (true) {
+    const byte = buffer[state.pos++];
+    n += (byte & 0x7f) * Math.pow(2, shift);
+    if ((byte & 0x80) === 0) break;
+    shift += 7;
+  }
+  return n;
+}
+
+function decodeHybrid(buffer, start, width, count) {
+  const out = [];
+  const state = { pos: start };
+  const valueBytes = Math.ceil(width / 8);
+  while (out.length < count && state.pos < buffer.length) {
+    const header = readUnsignedVar(buffer, state);
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < valueBytes; i++) value |= buffer[state.pos++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const values = groups * 8;
+      let bitPos = 0;
+      for (let i = 0; i < values && out.length < count; i++) {
+        let value = 0;
+        for (let bit = 0; bit < width; bit++) {
+          const absolute = state.pos * 8 + bitPos;
+          const byte = buffer[absolute >> 3];
+          const bitValue = (byte >> (absolute & 7)) & 1;
+          value |= bitValue << bit;
+          bitPos++;
+        }
+        out.push(value);
+      }
+      state.pos += Math.ceil((values * width) / 8);
+    }
+  }
+  return { values: out, pos: state.pos };
+}
+
+function decodePlainDictionary(buffer, primitiveType, numValues) {
+  const out = new Array(numValues);
+  let pos = 0;
+  for (let i = 0; i < numValues; i++) {
+    if (primitiveType === 5) {
+      out[i] = buffer.readDoubleLE(pos);
+      pos += 8;
+    } else if (primitiveType === 2) {
+      out[i] = Number(buffer.readBigInt64LE(pos));
+      pos += 8;
+    } else if (primitiveType === 1) {
+      out[i] = buffer.readInt32LE(pos);
+      pos += 4;
+    } else if (primitiveType === 6) {
+      const len = buffer.readInt32LE(pos);
+      pos += 4;
+      out[i] = buffer.slice(pos, pos + len).toString("utf8");
+      pos += len;
+    } else {
+      throw new Error(`Unsupported primitive type ${primitiveType}`);
+    }
+  }
+  return out;
+}
+
+function readColumn(columnChunk, primitiveType, numRows, optional) {
+  const meta = columnChunk[3];
+  const codec = meta[4];
+  const start = meta[11] || meta[9];
+  const end = start + meta[7];
+  let offset = start;
+  let dictionary = null;
+  const out = new Float64Array(numRows);
+  let outPos = 0;
+  while (offset < end) {
+    const header = readPageHeader(offset);
+    const pageStart = header.headerEnd;
+    const pageEnd = pageStart + header[3];
+    let body = data.slice(pageStart, pageEnd);
+    if (codec === 1) body = snappyUncompress(body);
+    else if (codec !== 0) throw new Error(`Unsupported compression codec ${codec}`);
