+    1: () => r.readI32(),
+    2: () => r.readList(() => schemaElement()),
+    3: () => r.readI64(),
+    4: () => r.readList(() => rowGroup()),
+    5: () => r.readList(() => keyValue()),
+    6: () => r.readBinary(),
