+function snappyUncompress(input) {
+  let ip = 0;
+  function readLength() {
+    let result = 0;
+    let shift = 0;
+    while (true) {
+      const byte = input[ip++];
+      result |= (byte & 0x7f) << shift;
+      if (byte < 128) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const length = readLength();
+  const output = Buffer.allocUnsafe(length);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(output, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else if (type === 1) {
+      const len = ((tag >> 2) & 7) + 4;
+      const offset = ((tag & 0xe0) << 3) | input[ip++];
+      for (let i = 0; i < len; i++) output[op + i] = output[op - offset + i];
+      op += len;
+    } else if (type === 2) {
+      const len = (tag >> 2) + 1;
+      const offset = input[ip] | (input[ip + 1] << 8);
+      ip += 2;
+      for (let i = 0; i < len; i++) output[op + i] = output[op - offset + i];
+      op += len;
+    } else {
+      const len = (tag >> 2) + 1;
+      const offset =
+        input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24);
+      ip += 4;
+      for (let i = 0; i < len; i++) output[op + i] = output[op - offset + i];
+      op += len;
+    }
+  }
