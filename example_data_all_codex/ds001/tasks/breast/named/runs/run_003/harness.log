+}
+
+function mean(arr, idx = null) {
+  let s = 0;
+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n += 1;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n += 1;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr) {
+  const m = mean(arr);
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
