+addIter(
+  6,
+  [
+    hyp("h11", "Patients with `bone_mets` have lower `pfs_months` than patients without `bone_mets`, after adjustment."),
+    hyp("h12", "Patients with `node_positive` disease have lower `pfs_months` than patients without node-positive disease, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h11"], codeText("bone_mets"), mainScan, "bone_mets"),
+    recordAnalysis(["h12"], codeText("node_positive"), mainScan, "node_positive"),
+  ]
+);
+
+addIter(
+  7,
+  [
+    hyp("h13", "Each 1 g/dL higher `albumin_g_dl` is associated with higher `pfs_months`, after adjustment."),
+    hyp("h14", "Each 100 U/L higher `ldh_u_l` is associated with lower `pfs_months`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h13"], codeText("albumin_g_dl"), mainScan, "albumin_g_dl"),
+    recordAnalysis(["h14"], codeText("ldh_u_l_per_100"), mainScan, "ldh_per100"),
+  ]
