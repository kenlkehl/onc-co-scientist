+  ],
+  [
+    recordAnalysis(["h1"], codeText("treatment_tamoxifen"), mainScan, "treatment_tamoxifen"),
+    recordAnalysis(["h2"], codeText("treatment_palbociclib"), mainScan, "treatment_palbociclib"),
+  ]
+);
+addIter(
