+  ["treatment_trastuzumab", "her2_positive"],
+  ["treatment_trastuzumab", "her2_amplification"],
+  ["treatment_olaparib", "brca_any"],
+  ["treatment_olaparib", "brca1_mutation"],
+  ["treatment_olaparib", "brca2_mutation"],
+  ["treatment_sacituzumab_govitecan", "triple_negative"],
+  ["treatment_sacituzumab_govitecan", "visceral_mets"],
+  ["treatment_pembrolizumab", "triple_negative"],
+  ["treatment_pembrolizumab", "high_crp"],
+  ["treatment_pembrolizumab", "autoimmune_disease"],
+  ["stage_iv", "liver_mets"],
+  ["stage_iv", "bone_mets"],
+  ["low_albumin", "weight_loss_per5"],
