+function makeCompactReader(buffer, start) {
+  let pos = start;
+  function readVarUInt() {
+    let shift = 0;
+    let n = 0;
+    while (true) {
+      const byte = buffer[pos++];
+      n += (byte & 0x7f) * Math.pow(2, shift);
+      if ((byte & 0x80) === 0) break;
+      shift += 7;
+    }
+    return n;
+  }
+  function zigZag(n) {
+    return (n >>> 1) ^ -(n & 1);
+  }
+  function readI32() {
+    return zigZag(readVarUInt());
+  }
+  function readI64() {
+    return zigZag(readVarUInt());
+  }
+  function readBinaryBuffer() {
+    const len = readVarUInt();
+    const out = buffer.slice(pos, pos + len);
+    pos += len;
+    return out;
+  }
+  function readBinary() {
+    return readBinaryBuffer().toString("utf8");
+  }
+  function readBool(type) {
+    if (type === 1) return true;
+    if (type === 2) return false;
+    throw new Error(`Unexpected bool type ${type}`);
+  }
+  function skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        pos += 1;
+        return;
+      case 4:
+      case 5:
+        readI32();
+        return;
+      case 6:
+        readI64();
+        return;
+      case 7:
+        pos += 8;
+        return;
+      case 8: {
+        const len = readVarUInt();
+        pos += len;
+        return;
+      }
+      case 9:
+      case 10: {
+        let header = buffer[pos++];
+        let size = header >> 4;
+        const elemType = header & 0x0f;
+        if (size === 15) size = readVarUInt();
+        for (let i = 0; i < size; i++) skip(elemType);
+        return;
+      }
+      case 11: {
+        const size = readVarUInt();
+        if (size === 0) return;
+        const header = buffer[pos++];
+        const keyType = (header >> 4) & 0x0f;
+        const valType = header & 0x0f;
+        for (let i = 0; i < size; i++) {
+          skip(keyType);
+          skip(valType);
+        }
+        return;
+      }
+      case 12:
+        readStruct({});
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${pos}`);
+    }
+  }
+  function readStruct(handlers) {
+    const out = {};
+    let lastField = 0;
+    while (true) {
+      const header = buffer[pos++];
+      const type = header & 0x0f;
+      if (type === 0) break;
+      const delta = header >> 4;
+      const fieldId = delta ? lastField + delta : readI32();
+      lastField = fieldId;
+      if (handlers[fieldId]) out[fieldId] = handlers[fieldId](type);
+      else skip(type);
+    }
+    return out;
+  }
+  function readList(reader) {
+    let header = buffer[pos++];
+    let size = header >> 4;
+    const elemType = header & 0x0f;
+    if (size === 15) size = readVarUInt();
