+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const term of terms) row.push(term.values[i]);
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = j; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+    yty += y[i] * y[i];
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = 0; k < j; k++) xtx[j][k] = xtx[k][j];
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, i) => s + v * xty[i], 0));
