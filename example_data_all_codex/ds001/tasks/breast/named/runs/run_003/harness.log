+);
+const menoTam = subgroupTxEffect("treatment_tamoxifen", "postmenopausal");
+addIter(
+  11,
+  [
+    hyp("h20", "The positive association between `treatment_tamoxifen` and `pfs_months` is larger in `postmenopausal` patients than in premenopausal patients."),
+  ],
+  [recordAnalysis(["h20"], codeText("treatment_tamoxifen, postmenopausal, and their interaction"), menoTam, "treatment_tamoxifen:postmenopausal")]
+);
+const erPalbo = subgroupTxEffect("treatment_palbociclib", "er_positive");
+addIter(
+  12,
+  [
+    hyp("h21", "The positive association between `treatment_palbociclib` and `pfs_months` is larger in `er_positive` patients than in `er_positive` = 0 patients."),
+  ],
+  [recordAnalysis(["h21"], codeText("treatment_palbociclib, er_positive, and their interaction"), erPalbo, "treatment_palbociclib:er_positive")]
+);
+const pikPalbo = subgroupTxEffect("treatment_palbociclib", "pik3ca_mutation");
+addIter(
+  13,
+  [
+    hyp("h22", "The positive association between `treatment_palbociclib` and `pfs_months` is smaller in patients with `pik3ca_mutation` than in patients without `pik3ca_mutation`."),
+  ],
+  [recordAnalysis(["h22"], codeText("treatment_palbociclib, pik3ca_mutation, and their interaction"), pikPalbo, "treatment_palbociclib:pik3ca_mutation")]
+);
+const her2Tras = subgroupTxEffect("treatment_trastuzumab", "her2_positive");
+addIter(
+  14,
+  [
+    hyp("h23", "The positive association between `treatment_trastuzumab` and `pfs_months` is larger in `her2_positive` patients than in `her2_positive` = 0 patients."),
+  ],
+  [recordAnalysis(["h23"], codeText("treatment_trastuzumab, her2_positive, and their interaction"), her2Tras, "treatment_trastuzumab:her2_positive")]
+);
+const her2AmpTras = subgroupTxEffect("treatment_trastuzumab", "her2_amplification");
+addIter(
+  15,
+  [
+    hyp("h24", "The positive association between `treatment_trastuzumab` and `pfs_months` is larger in patients with `her2_amplification` than in patients without `her2_amplification`."),
+  ],
+  [recordAnalysis(["h24"], codeText("treatment_trastuzumab, her2_amplification, and their interaction"), her2AmpTras, "treatment_trastuzumab:her2_amplification")]
+);
+const brcaOla = subgroupTxEffect("treatment_olaparib", "brca_any");
+addIter(
+  16,
+  [
+    hyp("h25", "The positive association between `treatment_olaparib` and `pfs_months` is larger in patients with either `brca1_mutation` or `brca2_mutation` than in patients without either mutation."),
+  ],
+  [recordAnalysis(["h25"], codeText("treatment_olaparib, brca_any, and their interaction"), brcaOla, "treatment_olaparib:brca_any")]
+);
+const brca1Ola = subgroupTxEffect("treatment_olaparib", "brca1_mutation");
+const brca2Ola = subgroupTxEffect("treatment_olaparib", "brca2_mutation");
+addIter(
+  17,
+  [
+    hyp("h26", "The positive association between `treatment_olaparib` and `pfs_months` is larger in patients with `brca1_mutation` than in patients without `brca1_mutation`."),
+    hyp("h27", "The positive association between `treatment_olaparib` and `pfs_months` is larger in patients with `brca2_mutation` than in patients without `brca2_mutation`."),
+  ],
+  [
+    recordAnalysis(["h26"], codeText("treatment_olaparib, brca1_mutation, and their interaction"), brca1Ola, "treatment_olaparib:brca1_mutation"),
+    recordAnalysis(["h27"], codeText("treatment_olaparib, brca2_mutation, and their interaction"), brca2Ola, "treatment_olaparib:brca2_mutation"),
+  ]
+);
+const tnbcSac = subgroupTxEffect("treatment_sacituzumab_govitecan", "triple_negative");
+addIter(
+  18,
+  [
+    hyp("h28", "The positive association between `treatment_sacituzumab_govitecan` and `pfs_months` is larger in triple-negative patients (`er_positive` = 0, `pr_positive` = 0, `her2_positive` = 0) than in other patients."),
+  ],
+  [recordAnalysis(["h28"], codeText("treatment_sacituzumab_govitecan, triple_negative, and their interaction"), tnbcSac, "treatment_sacituzumab_govitecan:triple_negative")]
+);
+const viscSac = subgroupTxEffect("treatment_sacituzumab_govitecan", "visceral_mets");
+addIter(
+  19,
+  [
+    hyp("h29", "The positive association between `treatment_sacituzumab_govitecan` and `pfs_months` is larger in patients with visceral metastases (`liver_mets`, `adrenal_mets`, `contralateral_lung_mets`, or `pleural_effusion`) than in patients without visceral metastases."),
+  ],
+  [recordAnalysis(["h29"], codeText("treatment_sacituzumab_govitecan, visceral_mets, and their interaction"), viscSac, "treatment_sacituzumab_govitecan:visceral_mets")]
+);
+const tnbcPembro = subgroupTxEffect("treatment_pembrolizumab", "triple_negative");
+addIter(
+  20,
+  [
+    hyp("h30", "The positive association between `treatment_pembrolizumab` and `pfs_months` is larger in triple-negative patients (`er_positive` = 0, `pr_positive` = 0, `her2_positive` = 0) than in other patients."),
+  ],
+  [recordAnalysis(["h30"], codeText("treatment_pembrolizumab, triple_negative, and their interaction"), tnbcPembro, "treatment_pembrolizumab:triple_negative")]
+);
+const crpPembro = subgroupTxEffect("treatment_pembrolizumab", "high_crp");
+addIter(
+  21,
+  [
+    hyp("h31", "The positive association between `treatment_pembrolizumab` and `pfs_months` is smaller in patients with `crp_mg_l` >= 10 than in patients with lower `crp_mg_l`."),
+  ],
+  [recordAnalysis(["h31"], codeText("treatment_pembrolizumab, high_crp, and their interaction"), crpPembro, "treatment_pembrolizumab:high_crp")]
+);
+const autoPembro = subgroupTxEffect("treatment_pembrolizumab", "autoimmune_disease");
+addIter(
+  22,
+  [
+    hyp("h32", "The positive association between `treatment_pembrolizumab` and `pfs_months` is smaller in patients with `autoimmune_disease` than in patients without `autoimmune_disease`."),
+  ],
+  [recordAnalysis(["h32"], codeText("treatment_pembrolizumab, autoimmune_disease, and their interaction"), autoPembro, "treatment_pembrolizumab:autoimmune_disease")]
+);
+const stageLiver = modelWith([interaction("stage_iv:liver_mets", cols.stage_iv, cols.liver_mets)]);
+addIter(
+  23,
+  [
+    hyp("h33", "The negative association between `stage_iv` and `pfs_months` is more pronounced in patients with `liver_mets` than in patients without `liver_mets`."),
