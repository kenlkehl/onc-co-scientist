+
+function readPageHeader(offset) {
+  const r = makeCompactReader(data, offset);
+  function statistics() {
+    return r.readStruct({
+      1: () => r.readBinaryBuffer(),
+      2: () => r.readBinaryBuffer(),
+      3: () => r.readI64(),
+      4: () => r.readI64(),
+      5: () => r.readBinaryBuffer(),
+      6: () => r.readBinaryBuffer(),
+    });
+  }
+  function dataPageHeader() {
+    return r.readStruct({
+      1: () => r.readI32(),
+      2: () => r.readI32(),
+      3: () => r.readI32(),
+      4: () => r.readI32(),
+      5: () => statistics(),
+    });
+  }
+  function dictionaryPageHeader() {
+    return r.readStruct({
+      1: () => r.readI32(),
+      2: () => r.readI32(),
+      3: (type) => r.readBool(type),
+    });
+  }
+  function dataPageHeaderV2() {
+    return r.readStruct({
+      1: () => r.readI32(),
+      2: () => r.readI32(),
+      3: () => r.readI32(),
+      4: () => r.readI32(),
+      5: () => r.readI32(),
+      6: () => r.readI32(),
+      7: (type) => r.readBool(type),
+      8: () => statistics(),
+    });
+  }
+  const header = r.readStruct({
+    1: () => r.readI32(),
+    2: () => r.readI32(),
+    3: () => r.readI32(),
+    4: () => r.readI32(),
+    5: () => dataPageHeader(),
+    7: () => dictionaryPageHeader(),
+    8: () => dataPageHeaderV2(),
+  });
