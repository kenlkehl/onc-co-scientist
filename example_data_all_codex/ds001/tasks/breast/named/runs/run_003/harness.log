+);
+addIter(
+  2,
+  [
+    hyp("h3", "Patients receiving `treatment_trastuzumab` have higher mean `pfs_months` than patients not receiving `treatment_trastuzumab`, after adjustment."),
+    hyp("h4", "Patients receiving `treatment_olaparib` have higher mean `pfs_months` than patients not receiving `treatment_olaparib`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h3"], codeText("treatment_trastuzumab"), mainScan, "treatment_trastuzumab"),
+    recordAnalysis(["h4"], codeText("treatment_olaparib"), mainScan, "treatment_olaparib"),
