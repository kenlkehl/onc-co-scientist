+  "liver_mets",
+  "bone_mets",
+  "node_positive",
+  "tumor_size_cm",
+  "ki67_per10",
+  "albumin_g_dl",
+  "ldh_per100",
+  "weight_loss_per5",
+  "crp_per10",
+  "nlr",
