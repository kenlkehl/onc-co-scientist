+
+function mean(arr, idx = null) {
+  let s = 0;
+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n += 1;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n += 1;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr) {
+  const m = mean(arr);
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function sd(arr) {
+  return Math.sqrt(variance(arr));
+}
+
+function normalP(z) {
+  const x = Math.abs(z) / Math.SQRT2;
+  const t = 1 / (1 + 0.3275911 * x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const erf = 1 - (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x);
+  const p = 1 - erf;
+  if (!Number.isFinite(p) || p <= 0) return 1e-300;
+  return Math.max(1e-300, p);
+}
+
+function invertMatrix(matrix) {
+  const n = matrix.length;
+  const a = matrix.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let row = col + 1; row < n; row++) {
+      if (Math.abs(a[row][col]) > Math.abs(a[pivot][col])) pivot = row;
+    }
+    if (Math.abs(a[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) {
+      const tmp = a[pivot];
+      a[pivot] = a[col];
+      a[col] = tmp;
+    }
+    const div = a[col][col];
+    for (let j = 0; j < 2 * n; j++) a[col][j] /= div;
+    for (let row = 0; row < n; row++) {
+      if (row === col) continue;
+      const factor = a[row][col];
+      if (factor === 0) continue;
+      for (let j = 0; j < 2 * n; j++) a[row][j] -= factor * a[col][j];
+    }
+  }
+  return a.map((row) => row.slice(n));
+}
+
+function ols(y, terms) {
+  const n = y.length;
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const term of terms) row.push(term.values[i]);
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = j; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+    yty += y[i] * y[i];
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = 0; k < j; k++) xtx[j][k] = xtx[k][j];
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, i) => s + v * xty[i], 0));
+  const betaXty = beta.reduce((s, v, i) => s + v * xty[i], 0);
+  const sse = Math.max(0, yty - betaXty);
+  const sigma2 = sse / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const named = {};
+  for (let i = 1; i < p; i++) {
+    const z = beta[i] / se[i];
+    named[terms[i - 1].name] = {
+      beta: beta[i],
+      se: se[i],
+      z,
+      p: normalP(z),
+    };
+  }
+  return { beta, se, sse, sigma2, terms: named };
+}
+
+function term(name, values) {
+  return { name, values };
+}
+
+function interaction(name, a, b) {
+  const n = a.length;
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = a[i] * b[i];
+  return term(name, out);
+}
+
+function transform(name, values, fn) {
+  const n = values.length;
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = fn(values[i], i);
+  return term(name, out);
+}
+
+function binaryFrom(name, n, fn) {
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = fn(i) ? 1 : 0;
+  return term(name, out);
+}
+
+function groupDifferenceP(y, group) {
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) {
+    if (group[i]) a.push(y[i]);
+    else b.push(y[i]);
+  }
+  const ma = mean(a);
+  const mb = mean(b);
+  const va = variance(a);
+  const vb = variance(b);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  return { n1: a.length, n0: b.length, mean1: ma, mean0: mb, effect: ma - mb, p: normalP((ma - mb) / se) };
+}
+
+function addScaledTerms(cols) {
+  cols.age_decade = transform("age_years_per_10", cols.age_years, (v) => v / 10).values;
+  cols.ki67_per10 = transform("ki67_pct_per_10", cols.ki67_pct, (v) => v / 10).values;
+  cols.ldh_per100 = transform("ldh_u_l_per_100", cols.ldh_u_l, (v) => v / 100).values;
+  cols.weight_loss_per5 = transform("weight_loss_pct_6mo_per_5", cols.weight_loss_pct_6mo, (v) => v / 5).values;
+  cols.crp_per10 = transform("crp_mg_l_per_10", cols.crp_mg_l, (v) => v / 10).values;
+  cols.tumor_size_per_cm = cols.tumor_size_cm;
+}
+
+function termFromCols(cols, name) {
+  return term(name, cols[name]);
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 100) return x.toFixed(1);
+  if (Math.abs(x) >= 10) return x.toFixed(2);
+  if (Math.abs(x) >= 1) return x.toFixed(2);
+  return x.toFixed(digits);
+}
+
+function pFmt(p) {
+  if (p < 1e-50) return "<1e-50";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function recordAnalysis(hypothesisIds, code, result, termName) {
+  const t = result.terms[termName];
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: `${termName}: adjusted coefficient ${fmt(t.beta)} months (SE ${fmt(t.se)}, p=${pFmt(t.p)}).`,
+    p_value: t.p,
+    effect_estimate: t.beta,
+    significant: t.p < 0.05,
+  };
+}
+
+function recordDiff(hypothesisIds, code, label, result) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: `${label}: mean pfs_months ${fmt(result.mean1)} in group=1 vs ${fmt(result.mean0)} in group=0; difference ${fmt(result.effect)} months (p=${pFmt(result.p)}).`,
+    p_value: result.p,
+    effect_estimate: result.effect,
+    significant: result.p < 0.05,
+  };
+}
+
+const meta = readMetadata();
+const schema = meta[2];
+const rowGroup = meta[4][0];
+const chunks = rowGroup[1];
+const n = meta[3];
+const cols = {};
+for (let i = 1; i < schema.length; i++) {
+  const name = schema[i][4];
+  if (name === "patient_id") continue;
+  const primitiveType = schema[i][1];
+  const optional = schema[i][3] === 1;
+  cols[name] = readColumn(chunks[i - 1], primitiveType, n, optional);
+}
+addScaledTerms(cols);
+cols.brca_any = binaryFrom("brca_any", n, (i) => cols.brca1_mutation[i] === 1 || cols.brca2_mutation[i] === 1).values;
+cols.triple_negative = binaryFrom(
+  "triple_negative",
+  n,
+  (i) => cols.er_positive[i] === 0 && cols.pr_positive[i] === 0 && cols.her2_positive[i] === 0
+).values;
+cols.visceral_mets = binaryFrom(
+  "visceral_mets",
+  n,
+  (i) =>
+    cols.liver_mets[i] === 1 ||
+    cols.adrenal_mets[i] === 1 ||
+    cols.contralateral_lung_mets[i] === 1 ||
+    cols.pleural_effusion[i] === 1
+).values;
+cols.low_albumin = binaryFrom("low_albumin", n, (i) => cols.albumin_g_dl[i] < 3.5).values;
+cols.high_crp = binaryFrom("high_crp", n, (i) => cols.crp_mg_l[i] >= 10).values;
+cols.ecog_2 = binaryFrom("ecog_2", n, (i) => cols.ecog_ps[i] >= 2).values;
+cols.high_ki67 = binaryFrom("high_ki67", n, (i) => cols.ki67_pct[i] >= 30).values;
+cols.her2_target_positive = binaryFrom(
+  "her2_target_positive",
+  n,
+  (i) => cols.her2_positive[i] === 1 || cols.her2_amplification[i] === 1
+).values;
+
+const y = cols.pfs_months;
+const treatmentNames = [
+  "treatment_tamoxifen",
+  "treatment_palbociclib",
+  "treatment_trastuzumab",
+  "treatment_olaparib",
+  "treatment_sacituzumab_govitecan",
+  "treatment_pembrolizumab",
+];
+const coreAdjust = [
+  "age_decade",
+  "sex_female",
+  "ecog_ps",
+  "stage_iv",
+  "has_brain_mets",
+  "liver_mets",
+  "bone_mets",
+  "node_positive",
+  "tumor_size_cm",
+  "ki67_per10",
+  "albumin_g_dl",
+  "ldh_per100",
+  "weight_loss_per5",
+  "crp_per10",
+  "nlr",
+  "er_positive",
+  "pr_positive",
+  "her2_positive",
+  "her2_low",
+  "brca1_mutation",
+  "brca2_mutation",
+  "pik3ca_mutation",
+  "postmenopausal",
+  ...treatmentNames,
+];
+function modelWith(extraTerms) {
+  const names = [...coreAdjust];
+  const terms = names.map((name) => termFromCols(cols, name)).concat(extraTerms || []);
+  return ols(y, terms);
+}
+
+const outputs = [];
+outputs.push(`Rows decoded: ${n}`);
+outputs.push(`Mean pfs_months: ${fmt(mean(y))}; SD: ${fmt(sd(y))}`);
+for (const tx of treatmentNames) {
+  const d = groupDifferenceP(y, cols[tx]);
+  outputs.push(`${tx}: n=${d.n1}; unadjusted diff=${fmt(d.effect)} p=${pFmt(d.p)}`);
+}
+
+// Exploratory scans used to choose and refine the 25 recorded iterations.
