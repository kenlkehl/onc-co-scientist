+      } else if (encoding === 0) {
+        const plain = decodePlainDictionary(body.slice(bodyPos), primitiveType, numValues);
+        for (const value of plain) out[outPos++] = value;
+      } else {
+        throw new Error(`Unsupported data encoding ${encoding}`);
+      }
+    } else {
+      throw new Error(`Unsupported page type ${header[1]}`);
+    }
+    offset = pageEnd;
+  }
