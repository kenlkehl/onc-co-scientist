+  ],
+  [
+    recordAnalysis(["h11"], codeText("bone_mets"), mainScan, "bone_mets"),
+    recordAnalysis(["h12"], codeText("node_positive"), mainScan, "node_positive"),
+  ]
+);
+
+addIter(
+  7,
+  [
+    hyp("h13", "Each 1 g/dL higher `albumin_g_dl` is associated with higher `pfs_months`, after adjustment."),
+    hyp("h14", "Each 100 U/L higher `ldh_u_l` is associated with lower `pfs_months`, after adjustment."),
