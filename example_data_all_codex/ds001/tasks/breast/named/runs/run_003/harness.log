+
+const y = cols.pfs_months;
+const treatmentNames = [
+  "treatment_tamoxifen",
+  "treatment_palbociclib",
+  "treatment_trastuzumab",
+  "treatment_olaparib",
+  "treatment_sacituzumab_govitecan",
+  "treatment_pembrolizumab",
+];
+const coreAdjust = [
+  "age_decade",
+  "sex_female",
+  "ecog_ps",
+  "stage_iv",
+  "has_brain_mets",
+  "liver_mets",
+  "bone_mets",
+  "node_positive",
+  "tumor_size_cm",
+  "ki67_per10",
+  "albumin_g_dl",
+  "ldh_per100",
+  "weight_loss_per5",
+  "crp_per10",
+  "nlr",
+  "er_positive",
+  "pr_positive",
+  "her2_positive",
+  "her2_low",
