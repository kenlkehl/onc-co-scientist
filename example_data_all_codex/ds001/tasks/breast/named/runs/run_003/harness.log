+  8,
+  [
+    hyp("h15", "Each 5 percentage-point higher `weight_loss_pct_6mo` is associated with lower `pfs_months`, after adjustment."),
+    hyp("h16", "Each 10 mg/L higher `crp_mg_l` is associated with lower `pfs_months`, after adjustment."),
