+      2: () => r.readI32(),
+      3: () => r.readI32(),
+      4: () => r.readBinary(),
+      5: () => r.readI32(),
+      6: () => r.readI32(),
+      7: () => r.readI32(),
+      8: () => r.readI32(),
+      9: () => r.readI32(),
