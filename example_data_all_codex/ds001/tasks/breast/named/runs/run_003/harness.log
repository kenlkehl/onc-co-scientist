+cols.high_crp = binaryFrom("high_crp", n, (i) => cols.crp_mg_l[i] >= 10).values;
+cols.ecog_2 = binaryFrom("ecog_2", n, (i) => cols.ecog_ps[i] >= 2).values;
+cols.high_ki67 = binaryFrom("high_ki67", n, (i) => cols.ki67_pct[i] >= 30).values;
+cols.her2_target_positive = binaryFrom(
+  "her2_target_positive",
+  n,
+  (i) => cols.her2_positive[i] === 1 || cols.her2_amplification[i] === 1
+).values;
+
+const y = cols.pfs_months;
+const treatmentNames = [
+  "treatment_tamoxifen",
+  "treatment_palbociclib",
+  "treatment_trastuzumab",
+  "treatment_olaparib",
+  "treatment_sacituzumab_govitecan",
+  "treatment_pembrolizumab",
+];
+const coreAdjust = [
+  "age_decade",
+  "sex_female",
+  "ecog_ps",
+  "stage_iv",
+  "has_brain_mets",
+  "liver_mets",
+  "bone_mets",
+  "node_positive",
+  "tumor_size_cm",
+  "ki67_per10",
+  "albumin_g_dl",
+  "ldh_per100",
+  "weight_loss_per5",
+  "crp_per10",
+  "nlr",
+  "er_positive",
+  "pr_positive",
+  "her2_positive",
+  "her2_low",
+  "brca1_mutation",
+  "brca2_mutation",
+  "pik3ca_mutation",
+  "postmenopausal",
+  ...treatmentNames,
+];
+function modelWith(extraTerms) {
+  const names = [...coreAdjust];
+  const terms = names.map((name) => termFromCols(cols, name)).concat(extraTerms || []);
+  return ols(y, terms);
+}
+
+const outputs = [];
+outputs.push(`Rows decoded: ${n}`);
+outputs.push(`Mean pfs_months: ${fmt(mean(y))}; SD: ${fmt(sd(y))}`);
+for (const tx of treatmentNames) {
+  const d = groupDifferenceP(y, cols[tx]);
+  outputs.push(`${tx}: n=${d.n1}; unadjusted diff=${fmt(d.effect)} p=${pFmt(d.p)}`);
+}
+
+// Exploratory scans used to choose and refine the 25 recorded iterations.
+const mainScan = modelWith([]);
+outputs.push("Core adjusted main effects:");
+for (const name of coreAdjust) {
+  const t = mainScan.terms[name];
+  outputs.push(`${name}\t${t.beta}\t${t.se}\t${t.p}`);
+}
+const scanPairs = [
+  ["treatment_tamoxifen", "er_positive"],
+  ["treatment_tamoxifen", "postmenopausal"],
+  ["treatment_palbociclib", "er_positive"],
+  ["treatment_palbociclib", "pik3ca_mutation"],
+  ["treatment_trastuzumab", "her2_positive"],
+  ["treatment_trastuzumab", "her2_amplification"],
+  ["treatment_olaparib", "brca_any"],
+  ["treatment_olaparib", "brca1_mutation"],
+  ["treatment_olaparib", "brca2_mutation"],
+  ["treatment_sacituzumab_govitecan", "triple_negative"],
+  ["treatment_sacituzumab_govitecan", "visceral_mets"],
+  ["treatment_pembrolizumab", "triple_negative"],
+  ["treatment_pembrolizumab", "high_crp"],
+  ["treatment_pembrolizumab", "autoimmune_disease"],
+  ["stage_iv", "liver_mets"],
+  ["stage_iv", "bone_mets"],
+  ["low_albumin", "weight_loss_per5"],
+  ["ecog_2", "weight_loss_per5"],
+  ["high_ki67", "er_positive"],
+  ["her2_low", "treatment_sacituzumab_govitecan"],
+];
+outputs.push("Interaction scan:");
+const interactionResults = {};
+for (const [a, b] of scanPairs) {
+  const iname = `${a}:${b}`;
+  const result = modelWith(extraMainTerms([b]).concat([interaction(iname, cols[a], cols[b])]));
+  interactionResults[iname] = result;
+  const t = result.terms[iname];
+  outputs.push(`${iname}\t${t.beta}\t${t.se}\t${t.p}`);
+}
+
+function subgroupTxEffect(tx, subgroup) {
+  const txArr = cols[tx];
+  const sg = cols[subgroup];
+  const iname = `${tx}:${subgroup}`;
+  return modelWith(extraMainTerms([subgroup]).concat([interaction(iname, txArr, sg)]));
+}
+
+function extraMainTerms(names) {
+  const representedByCore = new Set(["brca_any"]);
+  return names
+    .filter((name) => !coreAdjust.includes(name) && !representedByCore.has(name))
+    .map((name) => termFromCols(cols, name));
+}
+
+const iterations = [];
+function hyp(id, text, kind = "novel") {
+  return { id, text, kind };
+}
+function addIter(index, hypotheses, analyses) {
+  iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+}
+function codeText(desc) {
+  return `Adjusted OLS of pfs_months on ${desc}, with covariates: age_years_per_10, sex_female, ecog_ps, stage_iv, has_brain_mets, liver_mets, bone_mets, node_positive, tumor_size_cm, ki67_pct_per_10, albumin_g_dl, ldh_u_l_per_100, weight_loss_pct_6mo_per_5, crp_mg_l_per_10, nlr, er_positive, pr_positive, her2_positive, her2_low, brca1_mutation, brca2_mutation, pik3ca_mutation, postmenopausal, and all six treatment indicators.`;
+}
+
+addIter(
+  1,
+  [
+    hyp("h1", "Patients receiving `treatment_tamoxifen` have higher mean `pfs_months` than patients not receiving `treatment_tamoxifen`, after adjustment for disease burden, biomarkers, labs, and other treatments."),
+    hyp("h2", "Patients receiving `treatment_palbociclib` have higher mean `pfs_months` than patients not receiving `treatment_palbociclib`, after adjustment for disease burden, biomarkers, labs, and other treatments."),
+  ],
+  [
+    recordAnalysis(["h1"], codeText("treatment_tamoxifen"), mainScan, "treatment_tamoxifen"),
+    recordAnalysis(["h2"], codeText("treatment_palbociclib"), mainScan, "treatment_palbociclib"),
+  ]
+);
+addIter(
+  2,
+  [
+    hyp("h3", "Patients receiving `treatment_trastuzumab` have higher mean `pfs_months` than patients not receiving `treatment_trastuzumab`, after adjustment."),
+    hyp("h4", "Patients receiving `treatment_olaparib` have higher mean `pfs_months` than patients not receiving `treatment_olaparib`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h3"], codeText("treatment_trastuzumab"), mainScan, "treatment_trastuzumab"),
+    recordAnalysis(["h4"], codeText("treatment_olaparib"), mainScan, "treatment_olaparib"),
+  ]
+);
+addIter(
+  3,
+  [
+    hyp("h5", "Patients receiving `treatment_sacituzumab_govitecan` have higher mean `pfs_months` than patients not receiving `treatment_sacituzumab_govitecan`, after adjustment."),
+    hyp("h6", "Patients receiving `treatment_pembrolizumab` have higher mean `pfs_months` than patients not receiving `treatment_pembrolizumab`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h5"], codeText("treatment_sacituzumab_govitecan"), mainScan, "treatment_sacituzumab_govitecan"),
+    recordAnalysis(["h6"], codeText("treatment_pembrolizumab"), mainScan, "treatment_pembrolizumab"),
+  ]
+);
+
+addIter(
+  4,
+  [
+    hyp("h7", "Higher `ecog_ps` is associated with lower `pfs_months`; each 1-point increase in `ecog_ps` decreases progression-free survival after adjustment."),
+    hyp("h8", "Having `stage_iv` disease is associated with lower `pfs_months` than non-stage-IV disease after adjustment."),
+  ],
+  [
+    recordAnalysis(["h7"], codeText("ecog_ps"), mainScan, "ecog_ps"),
+    recordAnalysis(["h8"], codeText("stage_iv"), mainScan, "stage_iv"),
+  ]
+);
+addIter(
+  5,
+  [
+    hyp("h9", "Patients with `has_brain_mets` have lower `pfs_months` than patients without `has_brain_mets`, after adjustment."),
+    hyp("h10", "Patients with `liver_mets` have lower `pfs_months` than patients without `liver_mets`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h9"], codeText("has_brain_mets"), mainScan, "has_brain_mets"),
+    recordAnalysis(["h10"], codeText("liver_mets"), mainScan, "liver_mets"),
+  ]
