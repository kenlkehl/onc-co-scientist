+
+const iterations = [];
+function hyp(id, text, kind = "novel") {
+  return { id, text, kind };
+}
+function addIter(index, hypotheses, analyses) {
+  iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+}
+function codeText(desc) {
+  return `Adjusted OLS of pfs_months on ${desc}, with covariates: age_years_per_10, sex_female, ecog_ps, stage_iv, has_brain_mets, liver_mets, bone_mets, node_positive, tumor_size_cm, ki67_pct_per_10, albumin_g_dl, ldh_u_l_per_100, weight_loss_pct_6mo_per_5, crp_mg_l_per_10, nlr, er_positive, pr_positive, her2_positive, her2_low, brca1_mutation, brca2_mutation, pik3ca_mutation, postmenopausal, and all six treatment indicators.`;
