const footerLen=b.readUInt32LE(b.length-8); console.log('footerLen',footerLen,'footerStart',b.length-8-footerLen);
let pos=b.length-8-footerLen;
function readVar(){let shift=0,n=0; while(true){let by=b[pos++]; n += (by & 0x7f)*Math.pow(2,shift); if((by&0x80)===0) break; shift+=7;} return n;}
function zig(n){return (n>>>1) "'^ -(n&1)}
function readI32(){return zig(readVar())}
function readI64(){return zig(readVar())}
function readBinary(){let len=readVar(); let s=b.slice(pos,pos+len); pos+=len; return s.toString('"'utf8');}
function skip(type){switch(type){case 1:case 2:return; case 3:pos++;return; case 4:case 5:readI32();return; case 6:readI64();return; case 7:pos+=8;return; case 8: {let len=readVar();pos+=len;return;} case 9:case 10:{let h=b[pos++]; let size=h>>4, et=h&0xf; if(size===15) size=readVar(); for(let i=0;i<size;i++) skip(et); return;} case 11:{let size=readVar(); if(size===0)return; let h=b[pos++]; let kt=(h>>4)&0xf, vt=h&0xf; for(let i=0;i<size;i++){skip(kt);skip(vt);} return;} case 12:{let last=0; while(true){let h=b[pos++]; let t=h&0xf; if(t===0) break; let d=h>>4; let fid=d?last+d:readI32(); last=fid; skip(t);} return;} default: throw new Error('skip type '+type+' pos '+pos);}}
function readStruct(handlers){let out={}; let last=0; while(true){let h=b[pos++]; let type=h&0xf; if(type===0) break; let d=h>>4; let fid=d?last+d:readI32(); last=fid; if(handlers && handlers[fid]) out[fid]=handlers[fid](type); else skip(type); } return out;}
function readList(elemReader){let h=b[pos++]; let size=h>>4, et=h&0xf; if(size===15) size=readVar(); let arr=[]; for(let i=0;i<size;i++) arr.push(elemReader(et)); return arr;}
function readSchemaElement(){return readStruct({1:t=>readI32(),2:t=>readI32(),3:t=>readI32(),4:t=>readBinary(),5:t=>readI32(),6:t=>readI32(),7:t=>readI32(),8:t=>readI32(),9:t=>readI32()});}
function readKeyValue(){return readStruct({1:t=>readBinary(),2:t=>readBinary()});}
function readStatistics(){return readStruct({1:t=>readBinary(),2:t=>readBinary(),3:t=>readI64(),4:t=>readI64(),5:t=>readBinary(),6:t=>readBinary()});}
function readColumnMeta(){return readStruct({1:t=>readI32(),2:t=>readList(et=>readI32()),3:t=>readList(et=>readBinary()),4:t=>readI32(),5:t=>readI64(),6:t=>readI64(),7:t=>readI64(),8:t=>readList(et=>readKeyValue()),9:t=>readI64(),10:t=>readI64(),11:t=>readI64(),12:t=>readStatistics()});}
function readColumnChunk(){return readStruct({1:t=>readBinary(),2:t=>readI64(),3:t=>readColumnMeta(),4:t=>readI64(),5:t=>readI32(),6:t=>readI64(),7:t=>readI32()});}
function readRowGroup(){return readStruct({1:t=>readList(et=>readColumnChunk()),2:t=>readI64(),3:t=>readI64(),5:t=>readI64(),6:t=>readI64()});}
