+addIter(
+  3,
+  [
+    hyp("h5", "Patients receiving `treatment_sacituzumab_govitecan` have higher mean `pfs_months` than patients not receiving `treatment_sacituzumab_govitecan`, after adjustment."),
+    hyp("h6", "Patients receiving `treatment_pembrolizumab` have higher mean `pfs_months` than patients not receiving `treatment_pembrolizumab`, after adjustment."),
