+}
+
+addIter(
+  1,
+  [
+    hyp("h1", "Patients receiving `treatment_tamoxifen` have higher mean `pfs_months` than patients not receiving `treatment_tamoxifen`, after adjustment for disease burden, biomarkers, labs, and other treatments."),
