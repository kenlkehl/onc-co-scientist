+      2: () => r.readList(() => r.readI32()),
+      3: () => r.readList(() => r.readBinary()),
+      4: () => r.readI32(),
+      5: () => r.readI64(),
+      6: () => r.readI64(),
+      7: () => r.readI64(),
+      8: () => r.readList(() => keyValue()),
+      9: () => r.readI64(),
+      10: () => r.readI64(),
+      11: () => r.readI64(),
