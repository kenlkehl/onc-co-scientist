+    effect_estimate: result.effect,
+    significant: result.p < 0.05,
+  };
+}
+
+const meta = readMetadata();
+const schema = meta[2];
+const rowGroup = meta[4][0];
+const chunks = rowGroup[1];
+const n = meta[3];
+const cols = {};
+for (let i = 1; i < schema.length; i++) {
+  const name = schema[i][4];
+  if (name === "patient_id") continue;
+  const primitiveType = schema[i][1];
+  const optional = schema[i][3] === 1;
