+
+function mean(arr, idx = null) {
+  let s = 0;
+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n += 1;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n += 1;
+    }
+  }
+  return s / n;
+}
