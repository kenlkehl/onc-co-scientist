+  };
+}
+
+function recordDiff(hypothesisIds, code, label, result) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: `${label}: mean pfs_months ${fmt(result.mean1)} in group=1 vs ${fmt(result.mean0)} in group=0; difference ${fmt(result.effect)} months (p=${pFmt(result.p)}).`,
