+      const len = (tag >> 2) + 1;
+      const offset = input[ip] | (input[ip + 1] << 8);
+      ip += 2;
+      for (let i = 0; i < len; i++) output[op + i] = output[op - offset + i];
+      op += len;
+    } else {
+      const len = (tag >> 2) + 1;
+      const offset =
