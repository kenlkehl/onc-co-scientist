+      state.pos += Math.ceil((values * width) / 8);
+    }
+  }
+  return { values: out, pos: state.pos };
+}
+
+function decodePlainDictionary(buffer, primitiveType, numValues) {
+  const out = new Array(numValues);
+  let pos = 0;
+  for (let i = 0; i < numValues; i++) {
+    if (primitiveType === 5) {
+      out[i] = buffer.readDoubleLE(pos);
+      pos += 8;
+    } else if (primitiveType === 2) {
+      out[i] = Number(buffer.readBigInt64LE(pos));
+      pos += 8;
+    } else if (primitiveType === 1) {
+      out[i] = buffer.readInt32LE(pos);
+      pos += 4;
+    } else if (primitiveType === 6) {
+      const len = buffer.readInt32LE(pos);
+      pos += 4;
+      out[i] = buffer.slice(pos, pos + len).toString("utf8");
+      pos += len;
+    } else {
+      throw new Error(`Unsupported primitive type ${primitiveType}`);
+    }
+  }
+  return out;
+}
+
+function readColumn(columnChunk, primitiveType, numRows, optional) {
+  const meta = columnChunk[3];
+  const codec = meta[4];
+  const start = meta[11] || meta[9];
+  const end = start + meta[7];
+  let offset = start;
+  let dictionary = null;
+  const out = new Float64Array(numRows);
+  let outPos = 0;
+  while (offset < end) {
+    const header = readPageHeader(offset);
+    const pageStart = header.headerEnd;
+    const pageEnd = pageStart + header[3];
+    let body = data.slice(pageStart, pageEnd);
+    if (codec === 1) body = snappyUncompress(body);
+    else if (codec !== 0) throw new Error(`Unsupported compression codec ${codec}`);
+
+    if (header[1] === 2) {
+      const dictHeader = header[7];
+      dictionary = decodePlainDictionary(body, primitiveType, dictHeader[1]);
+    } else if (header[1] === 0) {
+      const dataHeader = header[5];
+      const numValues = dataHeader[1];
+      let bodyPos = 0;
+      if (optional) {
+        const levelLen = body.readUInt32LE(bodyPos);
+        bodyPos += 4 + levelLen;
+      }
+      const encoding = dataHeader[2];
+      if (encoding === 8) {
+        if (!dictionary) throw new Error("Dictionary page missing before dictionary data");
+        const width = body[bodyPos++];
+        const decoded = decodeHybrid(body, bodyPos, width, numValues);
+        for (const index of decoded.values) out[outPos++] = dictionary[index];
+      } else if (encoding === 0) {
+        const plain = decodePlainDictionary(body.slice(bodyPos), primitiveType, numValues);
+        for (const value of plain) out[outPos++] = value;
+      } else {
+        throw new Error(`Unsupported data encoding ${encoding}`);
+      }
+    } else {
+      throw new Error(`Unsupported page type ${header[1]}`);
+    }
+    offset = pageEnd;
+  }
+  if (outPos !== numRows) throw new Error(`Decoded ${outPos}, expected ${numRows}`);
+  return out;
+}
+
+function mean(arr, idx = null) {
+  let s = 0;
+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n += 1;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n += 1;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr) {
+  const m = mean(arr);
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function sd(arr) {
+  return Math.sqrt(variance(arr));
+}
+
+function normalP(z) {
+  const x = Math.abs(z) / Math.SQRT2;
+  const t = 1 / (1 + 0.3275911 * x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const erf = 1 - (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x);
+  const p = 1 - erf;
+  if (!Number.isFinite(p) || p <= 0) return 1e-300;
+  return Math.max(1e-300, p);
+}
+
+function invertMatrix(matrix) {
+  const n = matrix.length;
+  const a = matrix.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let row = col + 1; row < n; row++) {
+      if (Math.abs(a[row][col]) > Math.abs(a[pivot][col])) pivot = row;
+    }
+    if (Math.abs(a[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) {
+      const tmp = a[pivot];
+      a[pivot] = a[col];
+      a[col] = tmp;
+    }
+    const div = a[col][col];
+    for (let j = 0; j < 2 * n; j++) a[col][j] /= div;
+    for (let row = 0; row < n; row++) {
+      if (row === col) continue;
+      const factor = a[row][col];
+      if (factor === 0) continue;
+      for (let j = 0; j < 2 * n; j++) a[row][j] -= factor * a[col][j];
+    }
+  }
+  return a.map((row) => row.slice(n));
+}
+
+function ols(y, terms) {
+  const n = y.length;
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const term of terms) row.push(term.values[i]);
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = j; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+    yty += y[i] * y[i];
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = 0; k < j; k++) xtx[j][k] = xtx[k][j];
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, i) => s + v * xty[i], 0));
+  const betaXty = beta.reduce((s, v, i) => s + v * xty[i], 0);
+  const sse = Math.max(0, yty - betaXty);
+  const sigma2 = sse / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const named = {};
+  for (let i = 1; i < p; i++) {
+    const z = beta[i] / se[i];
+    named[terms[i - 1].name] = {
+      beta: beta[i],
+      se: se[i],
+      z,
+      p: normalP(z),
+    };
+  }
+  return { beta, se, sse, sigma2, terms: named };
+}
+
+function term(name, values) {
+  return { name, values };
+}
+
+function interaction(name, a, b) {
+  const n = a.length;
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = a[i] * b[i];
+  return term(name, out);
+}
+
+function transform(name, values, fn) {
+  const n = values.length;
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = fn(values[i], i);
+  return term(name, out);
+}
+
+function binaryFrom(name, n, fn) {
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = fn(i) ? 1 : 0;
+  return term(name, out);
+}
+
+function groupDifferenceP(y, group) {
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) {
+    if (group[i]) a.push(y[i]);
+    else b.push(y[i]);
+  }
+  const ma = mean(a);
+  const mb = mean(b);
+  const va = variance(a);
+  const vb = variance(b);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  return { n1: a.length, n0: b.length, mean1: ma, mean0: mb, effect: ma - mb, p: normalP((ma - mb) / se) };
+}
+
+function addScaledTerms(cols) {
+  cols.age_decade = transform("age_years_per_10", cols.age_years, (v) => v / 10).values;
+  cols.ki67_per10 = transform("ki67_pct_per_10", cols.ki67_pct, (v) => v / 10).values;
+  cols.ldh_per100 = transform("ldh_u_l_per_100", cols.ldh_u_l, (v) => v / 100).values;
+  cols.weight_loss_per5 = transform("weight_loss_pct_6mo_per_5", cols.weight_loss_pct_6mo, (v) => v / 5).values;
+  cols.crp_per10 = transform("crp_mg_l_per_10", cols.crp_mg_l, (v) => v / 10).values;
