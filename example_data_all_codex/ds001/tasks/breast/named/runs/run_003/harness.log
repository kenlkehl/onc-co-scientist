+
+// Exploratory scans used to choose and refine the 25 recorded iterations.
+const mainScan = modelWith([]);
+outputs.push("Core adjusted main effects:");
+for (const name of coreAdjust) {
+  const t = mainScan.terms[name];
+  outputs.push(`${name}\t${t.beta}\t${t.se}\t${t.p}`);
+}
+const scanPairs = [
+  ["treatment_tamoxifen", "er_positive"],
+  ["treatment_tamoxifen", "postmenopausal"],
+  ["treatment_palbociclib", "er_positive"],
+  ["treatment_palbociclib", "pik3ca_mutation"],
+  ["treatment_trastuzumab", "her2_positive"],
+  ["treatment_trastuzumab", "her2_amplification"],
+  ["treatment_olaparib", "brca_any"],
+  ["treatment_olaparib", "brca1_mutation"],
+  ["treatment_olaparib", "brca2_mutation"],
+  ["treatment_sacituzumab_govitecan", "triple_negative"],
+  ["treatment_sacituzumab_govitecan", "visceral_mets"],
+  ["treatment_pembrolizumab", "triple_negative"],
+  ["treatment_pembrolizumab", "high_crp"],
+  ["treatment_pembrolizumab", "autoimmune_disease"],
+  ["stage_iv", "liver_mets"],
+  ["stage_iv", "bone_mets"],
+  ["low_albumin", "weight_loss_per5"],
+  ["ecog_2", "weight_loss_per5"],
+  ["high_ki67", "er_positive"],
+  ["her2_low", "treatment_sacituzumab_govitecan"],
