+      const groups = header >> 1;
+      const values = groups * 8;
+      let bitPos = 0;
+      for (let i = 0; i < values && out.length < count; i++) {
+        let value = 0;
+        for (let bit = 0; bit < width; bit++) {
+          const absolute = state.pos * 8 + bitPos;
+          const byte = buffer[absolute >> 3];
+          const bitValue = (byte >> (absolute & 7)) & 1;
+          value |= bitValue << bit;
+          bitPos++;
+        }
+        out.push(value);
+      }
+      state.pos += Math.ceil((values * width) / 8);
+    }
+  }
+  return { values: out, pos: state.pos };
+}
+
+function decodePlainDictionary(buffer, primitiveType, numValues) {
+  const out = new Array(numValues);
+  let pos = 0;
+  for (let i = 0; i < numValues; i++) {
+    if (primitiveType === 5) {
+      out[i] = buffer.readDoubleLE(pos);
+      pos += 8;
+    } else if (primitiveType === 2) {
+      out[i] = Number(buffer.readBigInt64LE(pos));
+      pos += 8;
+    } else if (primitiveType === 1) {
+      out[i] = buffer.readInt32LE(pos);
+      pos += 4;
+    } else if (primitiveType === 6) {
+      const len = buffer.readInt32LE(pos);
+      pos += 4;
+      out[i] = buffer.slice(pos, pos + len).toString("utf8");
+      pos += len;
+    } else {
+      throw new Error(`Unsupported primitive type ${primitiveType}`);
+    }
+  }
+  return out;
+}
+
+function readColumn(columnChunk, primitiveType, numRows, optional) {
+  const meta = columnChunk[3];
+  const codec = meta[4];
+  const start = meta[11] || meta[9];
+  const end = start + meta[7];
+  let offset = start;
+  let dictionary = null;
+  const out = new Float64Array(numRows);
+  let outPos = 0;
+  while (offset < end) {
+    const header = readPageHeader(offset);
+    const pageStart = header.headerEnd;
+    const pageEnd = pageStart + header[3];
+    let body = data.slice(pageStart, pageEnd);
+    if (codec === 1) body = snappyUncompress(body);
+    else if (codec !== 0) throw new Error(`Unsupported compression codec ${codec}`);
+
+    if (header[1] === 2) {
+      const dictHeader = header[7];
+      dictionary = decodePlainDictionary(body, primitiveType, dictHeader[1]);
+    } else if (header[1] === 0) {
+      const dataHeader = header[5];
+      const numValues = dataHeader[1];
+      let bodyPos = 0;
+      if (optional) {
+        const levelLen = body.readUInt32LE(bodyPos);
+        bodyPos += 4 + levelLen;
+      }
+      const encoding = dataHeader[2];
+      if (encoding === 8) {
+        if (!dictionary) throw new Error("Dictionary page missing before dictionary data");
+        const width = body[bodyPos++];
+        const decoded = decodeHybrid(body, bodyPos, width, numValues);
+        for (const index of decoded.values) out[outPos++] = dictionary[index];
+      } else if (encoding === 0) {
+        const plain = decodePlainDictionary(body.slice(bodyPos), primitiveType, numValues);
+        for (const value of plain) out[outPos++] = value;
+      } else {
+        throw new Error(`Unsupported data encoding ${encoding}`);
+      }
+    } else {
+      throw new Error(`Unsupported page type ${header[1]}`);
+    }
+    offset = pageEnd;
+  }
+  if (outPos !== numRows) throw new Error(`Decoded ${outPos}, expected ${numRows}`);
+  return out;
+}
+
+function mean(arr, idx = null) {
+  let s = 0;
+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n += 1;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n += 1;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr) {
+  const m = mean(arr);
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function sd(arr) {
+  return Math.sqrt(variance(arr));
+}
+
+function normalP(z) {
+  const x = Math.abs(z) / Math.SQRT2;
+  const t = 1 / (1 + 0.3275911 * x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const erf = 1 - (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x);
+  const p = 1 - erf;
+  if (!Number.isFinite(p) || p <= 0) return 1e-300;
+  return Math.max(1e-300, p);
+}
+
+function invertMatrix(matrix) {
+  const n = matrix.length;
+  const a = matrix.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let row = col + 1; row < n; row++) {
+      if (Math.abs(a[row][col]) > Math.abs(a[pivot][col])) pivot = row;
+    }
+    if (Math.abs(a[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) {
+      const tmp = a[pivot];
+      a[pivot] = a[col];
+      a[col] = tmp;
+    }
+    const div = a[col][col];
+    for (let j = 0; j < 2 * n; j++) a[col][j] /= div;
+    for (let row = 0; row < n; row++) {
+      if (row === col) continue;
+      const factor = a[row][col];
+      if (factor === 0) continue;
+      for (let j = 0; j < 2 * n; j++) a[row][j] -= factor * a[col][j];
+    }
+  }
+  return a.map((row) => row.slice(n));
+}
+
+function ols(y, terms) {
+  const n = y.length;
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const term of terms) row.push(term.values[i]);
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = j; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+    yty += y[i] * y[i];
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = 0; k < j; k++) xtx[j][k] = xtx[k][j];
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, i) => s + v * xty[i], 0));
+  const betaXty = beta.reduce((s, v, i) => s + v * xty[i], 0);
+  const sse = Math.max(0, yty - betaXty);
+  const sigma2 = sse / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const named = {};
+  for (let i = 1; i < p; i++) {
+    const z = beta[i] / se[i];
+    named[terms[i - 1].name] = {
+      beta: beta[i],
+      se: se[i],
+      z,
+      p: normalP(z),
+    };
+  }
+  return { beta, se, sse, sigma2, terms: named };
+}
+
+function term(name, values) {
+  return { name, values };
+}
+
+function interaction(name, a, b) {
+  const n = a.length;
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = a[i] * b[i];
+  return term(name, out);
+}
+
+function transform(name, values, fn) {
+  const n = values.length;
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = fn(values[i], i);
+  return term(name, out);
+}
+
+function binaryFrom(name, n, fn) {
+  const out = new Float64Array(n);
+  for (let i = 0; i < n; i++) out[i] = fn(i) ? 1 : 0;
+  return term(name, out);
+}
+
+function groupDifferenceP(y, group) {
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) {
+    if (group[i]) a.push(y[i]);
+    else b.push(y[i]);
+  }
+  const ma = mean(a);
+  const mb = mean(b);
+  const va = variance(a);
+  const vb = variance(b);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  return { n1: a.length, n0: b.length, mean1: ma, mean0: mb, effect: ma - mb, p: normalP((ma - mb) / se) };
+}
+
+function addScaledTerms(cols) {
+  cols.age_decade = transform("age_years_per_10", cols.age_years, (v) => v / 10).values;
+  cols.ki67_per10 = transform("ki67_pct_per_10", cols.ki67_pct, (v) => v / 10).values;
+  cols.ldh_per100 = transform("ldh_u_l_per_100", cols.ldh_u_l, (v) => v / 100).values;
+  cols.weight_loss_per5 = transform("weight_loss_pct_6mo_per_5", cols.weight_loss_pct_6mo, (v) => v / 5).values;
+  cols.crp_per10 = transform("crp_mg_l_per_10", cols.crp_mg_l, (v) => v / 10).values;
+  cols.tumor_size_per_cm = cols.tumor_size_cm;
+}
+
+function termFromCols(cols, name) {
+  return term(name, cols[name]);
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 100) return x.toFixed(1);
+  if (Math.abs(x) >= 10) return x.toFixed(2);
+  if (Math.abs(x) >= 1) return x.toFixed(2);
+  return x.toFixed(digits);
+}
+
+function pFmt(p) {
+  if (p < 1e-50) return "<1e-50";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function recordAnalysis(hypothesisIds, code, result, termName) {
+  const t = result.terms[termName];
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: `${termName}: adjusted coefficient ${fmt(t.beta)} months (SE ${fmt(t.se)}, p=${pFmt(t.p)}).`,
+    p_value: t.p,
+    effect_estimate: t.beta,
+    significant: t.p < 0.05,
+  };
+}
+
+function recordDiff(hypothesisIds, code, label, result) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: `${label}: mean pfs_months ${fmt(result.mean1)} in group=1 vs ${fmt(result.mean0)} in group=0; difference ${fmt(result.effect)} months (p=${pFmt(result.p)}).`,
+    p_value: result.p,
+    effect_estimate: result.effect,
+    significant: result.p < 0.05,
+  };
+}
+
+const meta = readMetadata();
+const schema = meta[2];
+const rowGroup = meta[4][0];
+const chunks = rowGroup[1];
+const n = meta[3];
+const cols = {};
+for (let i = 1; i < schema.length; i++) {
+  const name = schema[i][4];
+  if (name === "patient_id") continue;
+  const primitiveType = schema[i][1];
+  const optional = schema[i][3] === 1;
+  cols[name] = readColumn(chunks[i - 1], primitiveType, n, optional);
+}
+addScaledTerms(cols);
+cols.brca_any = binaryFrom("brca_any", n, (i) => cols.brca1_mutation[i] === 1 || cols.brca2_mutation[i] === 1).values;
+cols.triple_negative = binaryFrom(
+  "triple_negative",
+  n,
+  (i) => cols.er_positive[i] === 0 && cols.pr_positive[i] === 0 && cols.her2_positive[i] === 0
+).values;
+cols.visceral_mets = binaryFrom(
+  "visceral_mets",
+  n,
+  (i) =>
+    cols.liver_mets[i] === 1 ||
+    cols.adrenal_mets[i] === 1 ||
+    cols.contralateral_lung_mets[i] === 1 ||
+    cols.pleural_effusion[i] === 1
+).values;
+cols.low_albumin = binaryFrom("low_albumin", n, (i) => cols.albumin_g_dl[i] < 3.5).values;
+cols.high_crp = binaryFrom("high_crp", n, (i) => cols.crp_mg_l[i] >= 10).values;
+cols.ecog_2 = binaryFrom("ecog_2", n, (i) => cols.ecog_ps[i] >= 2).values;
+cols.high_ki67 = binaryFrom("high_ki67", n, (i) => cols.ki67_pct[i] >= 30).values;
+cols.her2_target_positive = binaryFrom(
+  "her2_target_positive",
+  n,
+  (i) => cols.her2_positive[i] === 1 || cols.her2_amplification[i] === 1
+).values;
+
+const y = cols.pfs_months;
+const treatmentNames = [
+  "treatment_tamoxifen",
+  "treatment_palbociclib",
+  "treatment_trastuzumab",
+  "treatment_olaparib",
+  "treatment_sacituzumab_govitecan",
+  "treatment_pembrolizumab",
+];
+const coreAdjust = [
+  "age_decade",
+  "sex_female",
+  "ecog_ps",
+  "stage_iv",
+  "has_brain_mets",
+  "liver_mets",
+  "bone_mets",
+  "node_positive",
+  "tumor_size_cm",
+  "ki67_per10",
+  "albumin_g_dl",
+  "ldh_per100",
+  "weight_loss_per5",
+  "crp_per10",
+  "nlr",
+  "er_positive",
+  "pr_positive",
+  "her2_positive",
+  "her2_low",
+  "brca1_mutation",
+  "brca2_mutation",
+  "pik3ca_mutation",
+  "postmenopausal",
+  ...treatmentNames,
+];
+function modelWith(extraTerms) {
+  const names = [...coreAdjust];
+  const terms = names.map((name) => termFromCols(cols, name)).concat(extraTerms || []);
+  return ols(y, terms);
+}
+
+const outputs = [];
+outputs.push(`Rows decoded: ${n}`);
+outputs.push(`Mean pfs_months: ${fmt(mean(y))}; SD: ${fmt(sd(y))}`);
+for (const tx of treatmentNames) {
+  const d = groupDifferenceP(y, cols[tx]);
+  outputs.push(`${tx}: n=${d.n1}; unadjusted diff=${fmt(d.effect)} p=${pFmt(d.p)}`);
+}
+
+// Exploratory scans used to choose and refine the 25 recorded iterations.
+const mainScan = modelWith([]);
+outputs.push("Core adjusted main effects:");
+for (const name of coreAdjust) {
+  const t = mainScan.terms[name];
+  outputs.push(`${name}\t${t.beta}\t${t.se}\t${t.p}`);
+}
+const scanPairs = [
+  ["treatment_tamoxifen", "er_positive"],
+  ["treatment_tamoxifen", "postmenopausal"],
+  ["treatment_palbociclib", "er_positive"],
+  ["treatment_palbociclib", "pik3ca_mutation"],
+  ["treatment_trastuzumab", "her2_positive"],
+  ["treatment_trastuzumab", "her2_amplification"],
+  ["treatment_olaparib", "brca_any"],
+  ["treatment_olaparib", "brca1_mutation"],
+  ["treatment_olaparib", "brca2_mutation"],
+  ["treatment_sacituzumab_govitecan", "triple_negative"],
+  ["treatment_sacituzumab_govitecan", "visceral_mets"],
+  ["treatment_pembrolizumab", "triple_negative"],
+  ["treatment_pembrolizumab", "high_crp"],
+  ["treatment_pembrolizumab", "autoimmune_disease"],
+  ["stage_iv", "liver_mets"],
+  ["stage_iv", "bone_mets"],
+  ["low_albumin", "weight_loss_per5"],
+  ["ecog_2", "weight_loss_per5"],
+  ["high_ki67", "er_positive"],
+  ["her2_low", "treatment_sacituzumab_govitecan"],
+];
+outputs.push("Interaction scan:");
+const interactionResults = {};
+for (const [a, b] of scanPairs) {
+  const iname = `${a}:${b}`;
+  const result = modelWith([interaction(iname, cols[a], cols[b])]);
+  interactionResults[iname] = result;
+  const t = result.terms[iname];
+  outputs.push(`${iname}\t${t.beta}\t${t.se}\t${t.p}`);
+}
+
+function subgroupTxEffect(tx, subgroup) {
+  const txArr = cols[tx];
+  const sg = cols[subgroup];
+  const iname = `${tx}:${subgroup}`;
+  const result = modelWith([interaction(iname, txArr, sg)]);
+  return result;
+}
+
+const iterations = [];
+function hyp(id, text, kind = "novel") {
+  return { id, text, kind };
+}
+function addIter(index, hypotheses, analyses) {
+  iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+}
+function codeText(desc) {
+  return `Adjusted OLS of pfs_months on ${desc}, with covariates: age_years_per_10, sex_female, ecog_ps, stage_iv, has_brain_mets, liver_mets, bone_mets, node_positive, tumor_size_cm, ki67_pct_per_10, albumin_g_dl, ldh_u_l_per_100, weight_loss_pct_6mo_per_5, crp_mg_l_per_10, nlr, er_positive, pr_positive, her2_positive, her2_low, brca1_mutation, brca2_mutation, pik3ca_mutation, postmenopausal, and all six treatment indicators.`;
+}
+
+addIter(
+  1,
+  [
+    hyp("h1", "Patients receiving `treatment_tamoxifen` have higher mean `pfs_months` than patients not receiving `treatment_tamoxifen`, after adjustment for disease burden, biomarkers, labs, and other treatments."),
+    hyp("h2", "Patients receiving `treatment_palbociclib` have higher mean `pfs_months` than patients not receiving `treatment_palbociclib`, after adjustment for disease burden, biomarkers, labs, and other treatments."),
+  ],
+  [
+    recordAnalysis(["h1"], codeText("treatment_tamoxifen"), mainScan, "treatment_tamoxifen"),
+    recordAnalysis(["h2"], codeText("treatment_palbociclib"), mainScan, "treatment_palbociclib"),
+  ]
+);
+addIter(
+  2,
+  [
+    hyp("h3", "Patients receiving `treatment_trastuzumab` have higher mean `pfs_months` than patients not receiving `treatment_trastuzumab`, after adjustment."),
+    hyp("h4", "Patients receiving `treatment_olaparib` have higher mean `pfs_months` than patients not receiving `treatment_olaparib`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h3"], codeText("treatment_trastuzumab"), mainScan, "treatment_trastuzumab"),
+    recordAnalysis(["h4"], codeText("treatment_olaparib"), mainScan, "treatment_olaparib"),
+  ]
+);
+addIter(
+  3,
+  [
+    hyp("h5", "Patients receiving `treatment_sacituzumab_govitecan` have higher mean `pfs_months` than patients not receiving `treatment_sacituzumab_govitecan`, after adjustment."),
+    hyp("h6", "Patients receiving `treatment_pembrolizumab` have higher mean `pfs_months` than patients not receiving `treatment_pembrolizumab`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h5"], codeText("treatment_sacituzumab_govitecan"), mainScan, "treatment_sacituzumab_govitecan"),
+    recordAnalysis(["h6"], codeText("treatment_pembrolizumab"), mainScan, "treatment_pembrolizumab"),
+  ]
+);
+
+addIter(
+  4,
+  [
+    hyp("h7", "Higher `ecog_ps` is associated with lower `pfs_months`; each 1-point increase in `ecog_ps` decreases progression-free survival after adjustment."),
+    hyp("h8", "Having `stage_iv` disease is associated with lower `pfs_months` than non-stage-IV disease after adjustment."),
+  ],
+  [
+    recordAnalysis(["h7"], codeText("ecog_ps"), mainScan, "ecog_ps"),
+    recordAnalysis(["h8"], codeText("stage_iv"), mainScan, "stage_iv"),
+  ]
+);
+addIter(
+  5,
+  [
+    hyp("h9", "Patients with `has_brain_mets` have lower `pfs_months` than patients without `has_brain_mets`, after adjustment."),
+    hyp("h10", "Patients with `liver_mets` have lower `pfs_months` than patients without `liver_mets`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h9"], codeText("has_brain_mets"), mainScan, "has_brain_mets"),
+    recordAnalysis(["h10"], codeText("liver_mets"), mainScan, "liver_mets"),
+  ]
+);
+addIter(
+  6,
+  [
+    hyp("h11", "Patients with `bone_mets` have lower `pfs_months` than patients without `bone_mets`, after adjustment."),
+    hyp("h12", "Patients with `node_positive` disease have lower `pfs_months` than patients without node-positive disease, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h11"], codeText("bone_mets"), mainScan, "bone_mets"),
+    recordAnalysis(["h12"], codeText("node_positive"), mainScan, "node_positive"),
+  ]
+);
+
+addIter(
+  7,
+  [
+    hyp("h13", "Each 1 g/dL higher `albumin_g_dl` is associated with higher `pfs_months`, after adjustment."),
+    hyp("h14", "Each 100 U/L higher `ldh_u_l` is associated with lower `pfs_months`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h13"], codeText("albumin_g_dl"), mainScan, "albumin_g_dl"),
+    recordAnalysis(["h14"], codeText("ldh_u_l_per_100"), mainScan, "ldh_per100"),
+  ]
+);
+addIter(
+  8,
+  [
+    hyp("h15", "Each 5 percentage-point higher `weight_loss_pct_6mo` is associated with lower `pfs_months`, after adjustment."),
+    hyp("h16", "Each 10 mg/L higher `crp_mg_l` is associated with lower `pfs_months`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h15"], codeText("weight_loss_pct_6mo_per_5"), mainScan, "weight_loss_per5"),
+    recordAnalysis(["h16"], codeText("crp_mg_l_per_10"), mainScan, "crp_per10"),
+  ]
+);
+addIter(
+  9,
+  [
+    hyp("h17", "Each 1-unit higher `nlr` is associated with lower `pfs_months`, after adjustment."),
+    hyp("h18", "Each 10 percentage-point higher `ki67_pct` is associated with lower `pfs_months`, after adjustment."),
+  ],
+  [
+    recordAnalysis(["h17"], codeText("nlr"), mainScan, "nlr"),
+    recordAnalysis(["h18"], codeText("ki67_pct_per_10"), mainScan, "ki67_per10"),
+  ]
+);
+
+const erTam = subgroupTxEffect("treatment_tamoxifen", "er_positive");
+addIter(
+  10,
+  [
+    hyp("h19", "The positive association between `treatment_tamoxifen` and `pfs_months` is larger in `er_positive` patients than in `er_positive` = 0 patients."),
+  ],
+  [recordAnalysis(["h19"], codeText("treatment_tamoxifen, er_positive, and their interaction"), erTam, "treatment_tamoxifen:er_positive")]
+);
+const menoTam = subgroupTxEffect("treatment_tamoxifen", "postmenopausal");
+addIter(
+  11,
+  [
+    hyp("h20", "The positive association between `treatment_tamoxifen` and `pfs_months` is larger in `postmenopausal` patients than in premenopausal patients."),
+  ],
+  [recordAnalysis(["h20"], codeText("treatment_tamoxifen, postmenopausal, and their interaction"), menoTam, "treatment_tamoxifen:postmenopausal")]
