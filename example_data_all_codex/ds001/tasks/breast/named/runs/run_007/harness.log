function erf(x){const sign=x<0?-1:1;const ax=Math.abs(x);const t=1/(1+0.3275911*ax);const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429;const v=1-(((((a5*t+a4)*t+a3)*t+a2)*t+a1)*t)*Math.exp(-ax*ax);return sign*v}function pnorm2(z){const p=1-erf(Math.abs(z)/Math.SQRT2);return p===0?1e-300:p}
