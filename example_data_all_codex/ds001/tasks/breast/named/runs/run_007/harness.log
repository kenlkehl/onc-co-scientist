function readCol(name){const c=md[name];let h=page(c.dictionary_page_offset);let body=file.slice(h.bodyOffset,h.bodyOffset+h.compressed_page_size);if(c.codec===1)body=snappy(body);const dict=plain(body,c.type,h.dictionary_page_header.num_values);let pos=c.data_page_offset,vals=[];while(vals.length<c.num_values){h=page(pos);body=file.slice(h.bodyOffset,h.bodyOffset+h.compressed_page_size);if(c.codec===1)body=snappy(body);let start=0;if(h.type"'!==0)throw Error('"'page type '+h.type);if(h.data_page_header.definition_level_encoding"'!==undefined){const dl=body.readInt32LE(start);start+=4+dl}const n=h.data_page_header.num_values,enc=h.data_page_header.encoding;if(enc===8||enc===2){const ids=rledict(body.slice(start),n);for(const id of ids)vals.push(dict[id])}else if(enc===0){for(const v of plain(body.slice(start),c.type,n))vals.push(v)}else throw Error('"'enc '+enc);pos=h.bodyOffset+h.compressed_page_size}return vals}
const names=Object.keys(md).filter(x=>x"'!=='"'patient_id');const data={};for(const name of names)data[name]=readCol(name);const y=data.pfs_months,n=y.length;const predictors=names.filter(x=>x"'!=='"'pfs_months');
function mean(a){let s=0;for(const x of a)s+=x;return s/a.length}function sd(a){const mu=mean(a);let s=0;for(const x of a){const d=x-mu;s+=d*d}return Math.sqrt(s/(a.length-1))}function uniq01(a){for(const x of a){if("'!(x===0||x===1))return false}return true}
