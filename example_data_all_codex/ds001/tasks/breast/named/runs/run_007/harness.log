function ols(terms) { const p = terms.length + 1; const xtx = Array.from({ length: p }, () => Array(p).fill(0)); const xty = Array(p).fill(0); let yty = 0; for (let i = 0; i < n; i++) { const row = [1]; for (const t of terms) row.push(t.v[i]); const yi = y[i]; yty += yi * yi; for (let a = 0; a < p; a++) { xty[a] += row[a] * yi; for (let b = 0; b <= a; b++) xtx[a][b] += row[a] * row[b]; } } for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b]; const inv = invert(xtx); const beta = Array(p).fill(0); for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j]; let bxty = 0; for (let i = 0; i < p; i++) bxty += beta[i] * xty[i]; const sse = Math.max(0, yty - bxty), df = n - p, mse = sse / df; const out = []; for (let i = 1; i < p; i++) { const se = Math.sqrt(Math.max(0, mse * inv[i][i])); const z = beta[i] / se; out.push({ name: terms[i - 1].name, beta: beta[i], se, z, p: pnorm2(z) }); } return { terms: out, sse, df, mse, inv, beta, xty, termList: terms }; }
