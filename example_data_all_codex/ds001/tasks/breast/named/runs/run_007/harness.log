function rawTerm(name){return {name,v:data[name]}}
function interactionTest(t,s){const inter=arrMap(i=>data[t][i]*data[s][i]);const terms=baseTerms.concat([{name:t+'_x_'+s,v:inter}]);const res=ols(terms).terms.at(-1);return {t,s,beta:res.beta,p:res.p,z:res.z};}
