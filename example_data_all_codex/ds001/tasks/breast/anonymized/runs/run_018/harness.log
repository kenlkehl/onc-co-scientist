+  const did = m[3] - m[2] - m[1] + m[0];
+  let sse = 0;
+  for (let g = 0; g < 4; g++) sse += ss[g] - n[g] * m[g] * m[g];
+  const mse = sse / (y.length - 4);
+  const se = Math.sqrt(mse * (1 / n[0] + 1 / n[1] + 1 / n[2] + 1 / n[3]));
