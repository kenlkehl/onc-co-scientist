+
+function snappyUncompress(input) {
+  let p = 0, shift = 0, len = 0;
+  while (true) {
+    const b = input[p++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let o = 0;
+  while (p < input.length) {
+    const tag = input[p++];
+    const typ = tag & 3;
+    if (typ === 0) {
+      let l = tag >> 2;
+      if (l < 60) {
+        l += 1;
+      } else {
+        const n = l - 59;
+        l = 0;
+        for (let i = 0; i < n; i++) l |= input[p++] << (8 * i);
+        l += 1;
+      }
+      input.copy(out, o, p, p + l);
+      p += l; o += l;
+    } else {
+      let l, off;
+      if (typ === 1) {
+        l = ((tag >> 2) & 7) + 4;
+        off = ((tag & 0xe0) << 3) | input[p++];
+      } else if (typ === 2) {
+        l = (tag >> 2) + 1;
+        off = input[p] | (input[p + 1] << 8);
+        p += 2;
+      } else {
+        l = (tag >> 2) + 1;
+        off = input[p] | (input[p + 1] << 8) | (input[p + 2] << 16) | (input[p + 3] << 24);
+        p += 4;
+      }
+      for (let i = 0; i < l; i++) out[o + i] = out[o - off + i];
+      o += l;
+    }
+  }
+  if (o !== len) throw new Error(`snappy len mismatch ${o} != ${len}`);
+  return out;
+}
+
+for (const i of [1, 2, 79 - 1]) {
+  const cc = meta[4][0][1][i];
+  const md = cc[3];
+  console.log('page headers for col', i, md[3][0]);
+  for (const off of [md[11], md[9]]) {
+    const h = readPageHeaderAt(off);
+    console.log(' offset', off, JSON.stringify(h));
+    const start = off + h.__headerLen;
+    console.log(' first bytes', Array.from(buf.subarray(start, start + Math.min(40, h[3]))));
+    const raw = snappyUncompress(buf.subarray(start, start + h[3]));
+    console.log(' raw len', raw.length, 'raw first bytes', Array.from(raw.subarray(0, 60)));
+  }
+}

