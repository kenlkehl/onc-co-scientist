+  for (let i = 0; i < Math.min(10, rg[1].length); i++) {
+    const cc = rg[1][i];
+    const md = cc[3];
+    console.log(i, {
+      file_offset: cc[2],
+      type: md[1],
+      encodings: md[2],
+      path: md[3],
+      codec: md[4],
+      num_values: md[5],
+      uncompressed: md[6],
+      compressed: md[7],
+      data_page_offset: md[9],
+      dict_page_offset: md[11],
+      stats: md[12],
+      enc_stats: md[13],
+    });
+  }
+}
+
+function readPageHeaderAt(offset) {
+  const r = new CompactReader(buf.subarray(offset));
+  const h = r.readStruct();
+  h.__headerLen = r.p;
+  return h;
+}
+
+for (const i of [1, 2, 79 - 1]) {
+  const cc = meta[4][0][1][i];
+  const md = cc[3];
+  console.log('page headers for col', i, md[3][0]);
+  for (const off of [md[11], md[9]]) {
+    const h = readPageHeaderAt(off);
+    console.log(' offset', off, JSON.stringify(h));
+    const start = off + h.__headerLen;
+    console.log(' first bytes', Array.from(buf.subarray(start, start + Math.min(40, h[3]))));
+  }
+}

