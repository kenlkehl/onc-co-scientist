@@ -0,0 +1,122 @@
+const fs = require('fs');
+
+const buf = fs.readFileSync('dataset.parquet');
+const magicStart = buf.subarray(0, 4).toString('ascii');
+const magicEnd = buf.subarray(buf.length - 4).toString('ascii');
+const footerLen = buf.readUInt32LE(buf.length - 8);
+const footerStart = buf.length - 8 - footerLen;
+const footer = buf.subarray(footerStart, footerStart + footerLen);
+
+class CompactReader {
+  constructor(buffer) {
+    this.b = buffer;
+    this.p = 0;
+  }
+  readByte() { return this.b[this.p++]; }
+  readVarBig() {
+    let shift = 0n, out = 0n;
+    while (true) {
+      const x = BigInt(this.readByte());
+      out |= (x & 0x7fn) << shift;
+      if ((x & 0x80n) === 0n) return out;
+      shift += 7n;
+    }
+  }
+  readVar() { return Number(this.readVarBig()); }
+  zig(n) {
+    const bi = BigInt(n);
+    return Number((bi >> 1n) ^ (-(bi & 1n)));
+  }
+  readI16() { return this.zig(this.readVarBig()); }
+  readI32() { return this.zig(this.readVarBig()); }
+  readI64() { return this.zig(this.readVarBig()); }
+  readDouble() {
+    const v = this.b.readDoubleLE(this.p);
+    this.p += 8;
+    return v;
+  }
+  readBinary() {
+    const len = this.readVar();
+    const s = this.b.subarray(this.p, this.p + len);
+    this.p += len;
+    return s;
+  }
+  readValue(type) {
+    switch (type) {
+      case 1: return true;
+      case 2: return false;
+      case 3: return this.readByte();
+      case 4: return this.readI16();
+      case 5: return this.readI32();
+      case 6: return this.readI64();
+      case 7: return this.readDouble();
+      case 8: return this.readBinary().toString('utf8');
+      case 9: return this.readList();
+      case 10: return this.readList();
+      case 11: return this.readMap();
+      case 12: return this.readStruct();
+      default: throw new Error(`unsupported compact type ${type} at ${this.p}`);
+    }
+  }
+  readList() {
+    const h = this.readByte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = this.readVar();
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(this.readValue(type));
+    return arr;
+  }
+  readMap() {
+    const size = this.readVar();
+    if (size === 0) return [];
+    const types = this.readByte();
+    const kt = types >> 4, vt = types & 0x0f;
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push([this.readValue(kt), this.readValue(vt)]);
+    return arr;
+  }
+  readStruct() {
+    const out = {};
+    let fid = 0;
+    while (true) {
+      const h = this.readByte();
+      if (h === 0) break;
+      const type = h & 0x0f;
+      const delta = h >> 4;
+      fid = delta ? fid + delta : this.readI16();
+      out[fid] = this.readValue(type);
+    }
+    return out;
+  }
+}
+
+const reader = new CompactReader(footer);
+const meta = reader.readStruct();
+console.log({ magicStart, magicEnd, footerLen, footerStart, metaEnd: reader.p });
+console.log('file meta keys', Object.keys(meta));
+console.log('version', meta[1], 'num_rows', meta[3], 'created_by', meta[6]);
+console.log('schema count', meta[2].length);
+console.log(meta[2].map((s, i) => ({ i, name: s[4], type: s[1], repetition: s[3], converted: s[6], logical: s[10] })).slice(0, 90));
+console.log('row groups', meta[4].length);
+for (const [rgi, rg] of meta[4].entries()) {
+  console.log('rg', rgi, 'cols', rg[1].length, 'rows', rg[3], 'bytes', rg[2], 'comp', rg[6]);
+  for (let i = 0; i < Math.min(10, rg[1].length); i++) {
+    const cc = rg[1][i];
+    const md = cc[3];
+    console.log(i, {
+      file_offset: cc[2],
+      type: md[1],
+      encodings: md[2],
+      path: md[3],
+      codec: md[4],
+      num_values: md[5],
+      uncompressed: md[6],
+      compressed: md[7],
+      data_page_offset: md[9],
+      dict_page_offset: md[11],
+      stats: md[12],
+      enc_stats: md[13],
+    });
+  }
+}

