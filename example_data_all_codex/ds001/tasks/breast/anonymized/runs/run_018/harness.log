+
+function standardize(x) {
+  const m = mean(x);
+  const sd = Math.sqrt(variance(x, m));
+  const z = new Float64Array(x.length);
+  for (let i = 0; i < x.length; i++) z[i] = (x[i] - m) / sd;
+  return { z, mean: m, sd };
