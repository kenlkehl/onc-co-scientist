+    ySd,
+    binaryCount: binary.length,
+    nonbinaryCount: nonbinary.length,
+    topMain: topMain.map(r => ({ feature: r.feature, type: r.type, effect: r.effect, p: r.p, z: r.z })),
+    topBB: topBB.slice(0, 5).map(r => ({ a: r.a, b: r.b, effect: r.effect, p: r.p, z: r.z, n: r.n, means: r.means })),
+    topBC: topBC.slice(0, 5).map(r => ({ b: r.b, c: r.c, effect: r.effect, p: r.p, z: r.z })),
+    topCC: topCC.slice(0, 3).map(r => ({ a: r.a, b: r.b, effect: r.effect, p: r.p, z: r.z })),
+    nullMain: nullMain.map(r => ({ feature: r.feature, effect: r.effect, p: r.p, z: r.z })),
+    iterations: iterations.length,
+  }, null, 2));
+}
