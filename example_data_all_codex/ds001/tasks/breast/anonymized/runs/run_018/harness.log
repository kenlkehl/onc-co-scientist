+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error('singular matrix');
+    if (pivot !== i) [m[i], m[pivot]] = [m[pivot], m[i]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = m[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= f * m[i][c];
+    }
+  }
+  return m.map(row => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yy = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const pred of predictors) row.push(pred[i]);
+    yy += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  let bxty = 0;
+  for (let i = 0; i < p; i++) bxty += beta[i] * xty[i];
+  const sse = Math.max(0, yy - bxty);
+  const sigma2 = sse / Math.max(1, n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const t = beta.map((b, i) => b / se[i]);
+  const pvals = t.map(normalTwoSidedP);
+  return { beta, se, t, p: pvals, sse, sigma2, df: n - p };
