+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const se = Math.sqrt(v0 / n0 + v1 / n1);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: normalTwoSidedP(z), z, n0, n1, m0, m1 };
