+      makeAnalysis([h.id], `Within ${bestBB.b}=${sv}, ${bestBB.a}=1 vs 0 effect was ${fmt(sg.effect)} months (means ${fmt(sg.m1)} vs ${fmt(sg.m0)}, n1=${sg.n1}, n0=${sg.n0}); p=${sci(sg.p)}.`, sg.effect, sg.p),
