+  summaryLines.push(`A multivariable OLS model including the ${selectedMain.length} strongest univariable features (${selectedMain.join(', ')}) showed that the leading effects were not all interchangeable. Adjusted coefficients for the first four were ` + topMain.slice(0, 4).map(r => `${r.feature}: ${fmt(multiByFeature[r.feature].effect)} months (p=${sci(multiByFeature[r.feature].p)})`).join('; ') + '.');
+  summaryLines.push('');
+  summaryLines.push('Subgroup and interaction probing showed non-additive structure. The strongest binary-binary interactions were ' + topBB.slice(0, 5).map(r => `${r.a} x ${r.b}: ${fmt(r.effect)} months (p=${sci(r.p)})`).join('; ') + '. For the top interaction, the effect of ' + bestBB.a + ` differed sharply by ${bestBB.b}: ` + [0, 1].map(sv => { const sg = subgroupBinaryEffect(y, data[bestBB.a], data[bestBB.b], sv); return `${bestBB.b}=${sv}: ${fmt(sg.effect)} months (p=${sci(sg.p)})`; }).join('; ') + '.');
+  summaryLines.push('');
+  summaryLines.push('Binary-by-numeric interaction scans also found heterogeneity: ' + topBC.slice(0, 5).map(r => `${r.b} x ${r.c}: ${fmt(r.effect)} months per SD interaction (p=${sci(r.p)})`).join('; ') + '. Continuous-by-continuous product interactions were weaker but the largest were ' + topCC.slice(0, 3).map(r => `${r.a} x ${r.b}: ${fmt(r.effect)} months (p=${sci(r.p)})`).join('; ') + '.');
+  summaryLines.push('');
+  summaryLines.push('Null checks were included to avoid only reporting positive findings. Features with negligible univariable evidence included ' + nullMain.slice(0, 3).map(r => `${r.feature} (${fmt(r.effect)} months, p=${sci(r.p)})`).join(', ') + '. Overall, the cohort shows a mixture of strong main effects and meaningful subgroup heterogeneity among the opaque feature labels; because the labels are de-identified, the results should be interpreted as treatment/biomarker-like statistical patterns rather than named clinical mechanisms.');
+
+  fs.writeFileSync('transcript.json', JSON.stringify(transcript, null, 2));
+  fs.writeFileSync('analysis_summary.txt', summaryLines.join('\n'));
+
