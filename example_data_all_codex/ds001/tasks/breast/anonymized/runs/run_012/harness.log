+          break;
+        default:
+          reader.skip(f.type);
+      }
+    }
+    return out;
+  });
+}
+
+function parseFileMetaData(r) {
+  return r.readStruct((reader) => {
+    const out = {};
+    while (true) {
+      const f = reader.readFieldBegin();
+      if (f.type === 0) break;
+      switch (f.id) {
