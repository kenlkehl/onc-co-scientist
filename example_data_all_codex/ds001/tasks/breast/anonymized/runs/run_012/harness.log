+          break;
+        case 3:
+          out.definition_level_encoding = reader.readZigZag();
+          break;
+        case 4:
+          out.repetition_level_encoding = reader.readZigZag();
+          break;
+        default:
+          reader.skip(f.type);
+      }
+    }
+    return out;
+  });
+}
+
