+      analysisRecord(['h06'], `Adjusted OLS estimated ${adj('feature_037').beta.toFixed(3)} months of PFS per one-unit increase in feature_037.`, adj('feature_037').beta, adj('feature_037').p, 'Full multivariable OLS coefficient for feature_037.'));
+    addIteration(7, 'h07', '`feature_031` equal to 1 is associated with lower mean `pfs_months` than `feature_031` equal to 0.',
+      analysisRecord(['h07'], `Patients with feature_031=1 had mean PFS ${grp('feature_031').mean1.toFixed(3)} months vs ${grp('feature_031').mean0.toFixed(3)} months for feature_031=0; adjusted difference ${adj('feature_031').beta.toFixed(3)} months.`, adj('feature_031').beta, adj('feature_031').p, 'Welch mean comparison and full multivariable OLS coefficient for feature_031.'));
+    addIteration(8, 'h08', '`feature_069` equal to 1 is associated with higher mean `pfs_months` than `feature_069` equal to 0.',
