+        if (dh.encoding === 8) {
+          const bitWidth = body[p++];
+          const indices = readHybrid(body, p, bitWidth, defined);
+          for (const ix of indices.values) out.push(dictionary[ix]);
+        } else if (dh.encoding === 0) {
+          out.push(...readPlainValues(body.subarray(p), type, defined));
+        } else {
+          throw new Error(`Unsupported data encoding ${dh.encoding} for ${names[idx]}`);
+        }
