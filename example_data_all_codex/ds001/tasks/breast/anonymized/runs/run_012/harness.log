+    addIteration(5, 'h05', '`feature_015` equal to 1 is associated with lower mean `pfs_months` than `feature_015` equal to 0.',
+      analysisRecord(['h05'], `Patients with feature_015=1 had mean PFS ${grp('feature_015').mean1.toFixed(3)} months vs ${grp('feature_015').mean0.toFixed(3)} months for feature_015=0; adjusted difference ${adj('feature_015').beta.toFixed(3)} months.`, adj('feature_015').beta, adj('feature_015').p, 'Welch mean comparison and full multivariable OLS coefficient for feature_015.'));
