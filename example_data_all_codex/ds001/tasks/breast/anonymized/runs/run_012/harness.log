+        analyses: [analysis]
+      });
+    }
+
+    addIteration(1, 'h01', 'A one-unit increase in `feature_044` is associated with higher mean `pfs_months` in the full cohort.',
+      analysisRecord(['h01'], `Full multivariable OLS estimated +${adj('feature_044').beta.toFixed(3)} months of PFS per one-unit increase in feature_044 (univariable slope +${uni('feature_044').beta.toFixed(3)}).`, adj('feature_044').beta, adj('feature_044').p, 'Full multivariable OLS: pfs_months ~ all feature_*; coefficient for feature_044.'));
