+  readZigZag() {
+    const n = this.readVarint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  readZigZagBig() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 15;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = b >> 4;
+    const last = this.lastField[this.lastField.length - 1] || 0;
+    const id = delta === 0 ? this.readZigZag() : last + delta;
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
