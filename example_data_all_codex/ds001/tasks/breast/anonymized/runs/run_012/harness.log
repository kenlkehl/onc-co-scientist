+  const y = data.pfs_months;
+  const featureNames = names.filter((name) => name !== 'pfs_months');
+  const summaries = {};
+  const main = [];
+  const binaryNames = [];
+  const continuousNames = [];
+  for (const name of featureNames) {
+    const s = summarize(data[name]);
+    summaries[name] = s;
+    if (s.unique === 2 && s.min === 0 && s.max === 1) binaryNames.push(name);
+    else continuousNames.push(name);
+    const u = univariate(data[name], y);
+    const gd = s.unique === 2 ? groupDiff(data[name], y) : null;
+    main.push({ name, summary: s, univariate: u, group: gd });
+  }
+  main.sort((a, b) => Math.abs(b.univariate.z) - Math.abs(a.univariate.z));
+
+  const binaryPairs = [];
+  for (const name of binaryNames) {
+    const gd = groupDiff(data[name], y);
+    binaryPairs.push({ name, ...gd });
+  }
+  binaryPairs.sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff));
+
+  const adjustedPredictors = featureNames.map((name) => ({ name, values: data[name] }));
+  const adjusted = ols(adjustedPredictors, y);
+  const adjustedTerms = adjusted.terms.slice().sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const topMain = adjustedTerms.slice(0, 20).map((t) => t.name);
+  const interactions = [];
+  for (let i = 0; i < topMain.length; i++) {
+    for (let j = i + 1; j < topMain.length; j++) {
+      const a = topMain[i];
+      const b = topMain[j];
+      const interName = `${a}:${b}`;
+      const fit = ols([
+        { name: a, values: data[a] },
+        { name: b, values: data[b] },
+        makeInteraction(data[a], data[b], interName)
+      ], y);
+      const t = fit.terms[2];
+      interactions.push({ a, b, ...t });
+    }
+  }
+  interactions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const targeted = {};
+  function fitTerms(key, termSpecs) {
+    targeted[key] = ols(termSpecs.map((spec) => ({ name: spec.name, values: spec.values })), y).terms;
+  }
+
+  fitTerms('feature_040_feature_062_interaction', [
+    { name: 'feature_040', values: data.feature_040 },
+    { name: 'feature_062', values: data.feature_062 },
+    makeInteraction(data.feature_040, data.feature_062, 'feature_040:feature_062')
+  ]);
+  fitTerms('feature_027_feature_044_interaction', [
+    { name: 'feature_027', values: data.feature_027 },
+    { name: 'feature_044', values: data.feature_044 },
+    makeInteraction(data.feature_027, data.feature_044, 'feature_027:feature_044')
+  ]);
+  fitTerms('feature_039_feature_062_interaction', [
+    { name: 'feature_039', values: data.feature_039 },
+    { name: 'feature_062', values: data.feature_062 },
+    makeInteraction(data.feature_039, data.feature_062, 'feature_039:feature_062')
