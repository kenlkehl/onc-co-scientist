+  }
+  interactions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const targeted = {};
+  function fitTerms(key, termSpecs) {
+    targeted[key] = ols(termSpecs.map((spec) => ({ name: spec.name, values: spec.values })), y).terms;
+  }
+
+  fitTerms('feature_040_feature_062_interaction', [
+    { name: 'feature_040', values: data.feature_040 },
+    { name: 'feature_062', values: data.feature_062 },
