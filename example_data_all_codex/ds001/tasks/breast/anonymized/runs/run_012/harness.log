+  readStruct(fn) {
+    this.lastField.push(0);
+    const out = fn(this);
+    this.lastField.pop();
+    return out;
+  }
+
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 15;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elemType };
