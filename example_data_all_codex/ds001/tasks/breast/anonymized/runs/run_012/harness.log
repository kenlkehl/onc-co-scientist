+  while (values.length < count) {
+    let shift = 0;
+    let header = 0;
+    while (true) {
+      const b = buf[p++];
+      header |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    if ((header & 1) === 0) {
+      const run = header >>> 1;
+      let value = 0;
+      for (let i = 0; i < rleBytes; i++) value |= buf[p++] << (8 * i);
+      for (let j = 0; j < run && values.length < count; j++) values.push(value);
+    } else {
+      const groups = header >>> 1;
+      const run = groups * 8;
+      const blockBytes = Math.ceil((run * bitWidth) / 8);
+      const start = p;
+      let bitPos = 0;
+      for (let j = 0; j < run && values.length < count; j++) {
+        let value = 0;
+        for (let b = 0; b < bitWidth; b++) {
+          const absolute = bitPos + b;
+          const byte = buf[start + (absolute >> 3)];
+          const bit = (byte >> (absolute & 7)) & 1;
+          value |= bit << b;
+        }
+        values.push(value);
+        bitPos += bitWidth;
+      }
+      p = start + blockBytes;
+    }
+  }
+  return { values, pos: p };
+}
+
+function loadParquetColumns() {
+  const metaLen = fileBuf.readUInt32LE(fileBuf.length - 8);
+  const metaStart = fileBuf.length - 8 - metaLen;
+  const meta = parseFileMetaData(new TCompactReader(fileBuf, metaStart, fileBuf.length - 8));
+  const rg = meta.row_groups[0];
+  const names = meta.schema.slice(1).map((s) => s.name);
+  const data = {};
+  const schemaByColumn = meta.schema.slice(1);
+
+  function readColumn(idx) {
+    const md = rg.columns[idx].meta_data;
+    const type = md.type;
+    const start = md.dictionary_page_offset || md.data_page_offset;
+    const end = start + md.total_compressed_size;
+    let pos = start;
+    let dictionary = null;
+    const out = [];
+    while (pos < end && out.length < md.num_values) {
+      const header = parsePageHeader(fileBuf, pos);
+      const cstart = header.headerEnd;
+      const compressed = fileBuf.subarray(cstart, cstart + header.compressed_page_size);
+      const body = md.codec === 1 ? snappyUncompress(compressed) : Buffer.from(compressed);
+      if (header.type === 2) {
+        dictionary = readPlainValues(body, type, header.dictionary_page_header.num_values);
+      } else if (header.type === 0) {
+        const dh = header.data_page_header;
+        let p = 0;
+        let defined = dh.num_values;
+        if (schemaByColumn[idx].repetition_type === 1) {
+          const levelBytes = body.readInt32LE(p);
+          p += 4;
+          const levels = readHybrid(body, p, 1, dh.num_values);
+          let count = 0;
+          for (const v of levels.values) if (v === 1) count += 1;
+          defined = count;
+          p += levelBytes;
+        }
+
+        if (dh.encoding === 8) {
+          const bitWidth = body[p++];
+          const indices = readHybrid(body, p, bitWidth, defined);
+          for (const ix of indices.values) out.push(dictionary[ix]);
+        } else if (dh.encoding === 0) {
+          out.push(...readPlainValues(body.subarray(p), type, defined));
+        } else {
+          throw new Error(`Unsupported data encoding ${dh.encoding} for ${names[idx]}`);
+        }
+      }
+      pos = header.headerEnd + header.compressed_page_size;
+    }
+    if (out.length !== md.num_values) throw new Error(`Column ${names[idx]} decoded ${out.length}, expected ${md.num_values}`);
+    return out;
+  }
+
+  for (let idx = 1; idx < names.length; idx++) {
+    data[names[idx]] = readColumn(idx);
+  }
+  return { data, names: names.slice(1), n: meta.num_rows };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedPFromZ(z) {
+  const az = Math.abs(z);
+  if (!Number.isFinite(az)) return 1;
+  if (az < 8) return Math.max(1e-300, 2 * (1 - normalCdf(az)));
+  const logTail = -0.5 * az * az - Math.log(az) - 0.5 * Math.log(2 * Math.PI);
+  return Math.max(1e-300, 2 * Math.exp(logTail));
+}
+
+function summarize(arr) {
+  const n = arr.length;
+  let sum = 0;
+  let sumSq = 0;
+  let min = Infinity;
+  let max = -Infinity;
+  const uniq = new Set();
+  for (const v of arr) {
+    sum += v;
+    sumSq += v * v;
+    min = Math.min(min, v);
+    max = Math.max(max, v);
+    if (uniq.size <= 100000) uniq.add(v);
+  }
+  const mean = sum / n;
+  const variance = Math.max(0, (sumSq - n * mean * mean) / (n - 1));
+  return { n, mean, sd: Math.sqrt(variance), min, max, unique: uniq.size };
+}
+
+function univariate(x, y) {
+  const n = y.length;
+  let sx = 0, sy = 0, sxx = 0, syy = 0, sxy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+    sxx += x[i] * x[i];
+    syy += y[i] * y[i];
+    sxy += x[i] * y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  const Sxx = sxx - n * mx * mx;
+  const Syy = syy - n * my * my;
+  const Sxy = sxy - n * mx * my;
+  const beta = Sxy / Sxx;
+  const intercept = my - beta * mx;
+  const sse = Syy - beta * Sxy;
+  const sigma2 = sse / (n - 2);
+  const se = Math.sqrt(sigma2 / Sxx);
+  const z = beta / se;
+  return { beta, intercept, se, z, p: twoSidedPFromZ(z), r: Sxy / Math.sqrt(Sxx * Syy), r2: (Sxy * Sxy) / (Sxx * Syy) };
+}
+
+function groupDiff(x, y) {
+  const n = y.length;
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < n; i++) {
+    if (x[i] === 1) {
+      n1 += 1;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, mean1: m1, mean0: m0, diff: m1 - m0, se, z, p: twoSidedPFromZ(z) };
+}
+
+function inverse(matrix) {
+  const n = matrix.length;
+  const a = matrix.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(a[r][col]) > Math.abs(a[pivot][col])) pivot = r;
+    }
+    if (Math.abs(a[pivot][col]) < 1e-12) throw new Error(`Singular matrix at ${col}`);
+    if (pivot !== col) [a[pivot], a[col]] = [a[col], a[pivot]];
+    const scale = a[col][col];
+    for (let c = 0; c < 2 * n; c++) a[col][c] /= scale;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = a[r][col];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) a[r][c] -= factor * a[col][c];
+    }
+  }
+  return a.map((row) => row.slice(n));
+}
+
+function ols(predictors, y) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let syy = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const pred of predictors) row.push(pred.values[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+    syy += y[i] * y[i];
+  }
+  const inv = inverse(xtx);
+  const beta = Array(p).fill(0);
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
+  }
+  let sse = syy;
+  for (let a = 0; a < p; a++) sse -= beta[a] * xty[a];
+  const sigma2 = sse / (n - p);
+  const terms = predictors.map((pred, j) => {
+    const idx = j + 1;
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[idx][idx]));
+    const z = beta[idx] / se;
+    return { name: pred.name, beta: beta[idx], se, z, p: twoSidedPFromZ(z) };
+  });
+  return { beta, terms, sse, sigma2, df: n - p, inv, predictors, n, p };
+}
+
+function extraTermAgainstFull(fullFit, y, term) {
+  const p = fullFit.p;
+  const xz = Array(p).fill(0);
+  let zy = 0;
+  let zz = 0;
+  for (let i = 0; i < fullFit.n; i++) {
+    const z = term.values[i];
+    xz[0] += z;
+    for (let j = 0; j < fullFit.predictors.length; j++) {
+      xz[j + 1] += fullFit.predictors[j].values[i] * z;
+    }
+    zy += z * y[i];
+    zz += z * z;
+  }
+  const invXz = Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) invXz[i] += fullFit.inv[i][j] * xz[j];
+  }
+  let projection = 0;
+  let fittedCross = 0;
+  for (let i = 0; i < p; i++) {
+    projection += xz[i] * invXz[i];
+    fittedCross += xz[i] * fullFit.beta[i];
+  }
+  const denom = zz - projection;
+  const numerator = zy - fittedCross;
+  const beta = numerator / denom;
+  const sseAug = fullFit.sse - numerator * beta;
+  const sigma2 = sseAug / (fullFit.n - p - 1);
+  const se = Math.sqrt(Math.max(0, sigma2 / denom));
+  const z = beta / se;
+  return { name: term.name, beta, se, z, p: twoSidedPFromZ(z) };
+}
+
+function makeInteraction(a, b, name) {
+  const n = a.length;
+  const values = new Array(n);
+  for (let i = 0; i < n; i++) values[i] = a[i] * b[i];
+  return { name, values };
+}
