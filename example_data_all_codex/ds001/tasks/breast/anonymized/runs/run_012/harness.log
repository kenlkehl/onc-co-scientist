+const fs = require('fs');
+
+const fileBuf = fs.readFileSync('dataset.parquet');
+
+class TCompactReader {
+  constructor(buf, pos = 0, end = buf.length) {
+    this.buf = buf;
+    this.pos = pos;
+    this.end = end;
+    this.lastField = [];
+  }
+
+  readByte() {
+    if (this.pos >= this.end) throw new Error(`Unexpected EOF at ${this.pos}`);
+    return this.buf[this.pos++];
+  }
+
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+
+  readZigZag() {
+    const n = this.readVarint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  readZigZagBig() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 15;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = b >> 4;
+    const last = this.lastField[this.lastField.length - 1] || 0;
+    const id = delta === 0 ? this.readZigZag() : last + delta;
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+
+  readStruct(fn) {
+    this.lastField.push(0);
+    const out = fn(this);
+    this.lastField.pop();
+    return out;
+  }
+
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 15;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elemType };
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const start = this.pos;
+    this.pos += len;
+    return this.buf.subarray(start, start + len);
+  }
+
+  skip(type) {
+    switch (type) {
+      case 0:
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+        this.readZigZag();
+        return;
+      case 6:
+        this.readZigZagBig();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8:
+        this.readBinary();
+        return;
+      case 9:
+      case 10: {
+        const list = this.readListBegin();
+        for (let i = 0; i < list.size; i++) this.skip(list.elemType);
+        return;
+      }
+      case 11: {
+        const b = this.readByte();
+        const keyType = b >> 4;
+        const valType = b & 15;
+        const size = Number(this.readVarint());
+        for (let i = 0; i < size; i++) {
+          this.skip(keyType);
+          this.skip(valType);
+        }
+        return;
+      }
+      case 12:
+        this.lastField.push(0);
+        while (true) {
+          const f = this.readFieldBegin();
+          if (f.type === 0) break;
+          this.skip(f.type);
+        }
+        this.lastField.pop();
+        return;
+      default:
+        throw new Error(`Unsupported compact thrift type ${type} at ${this.pos}`);
+    }
+  }
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  function readVarint() {
+    let shift = 0;
+    let result = 0;
+    while (true) {
+      const b = input[ip++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result >>> 0;
+  }
+
+  const outLen = readVarint();
+  const out = Buffer.allocUnsafe(outLen);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = (input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24)) >>> 0;
+        ip += 4;
+      }
+      for (let i = 0; i < len; i++) {
+        out[op] = out[op - offset];
+        op += 1;
+      }
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch: ${op} != ${outLen}`);
+  return out;
+}
+
+function parseSchemaElement(r) {
+  return r.readStruct((reader) => {
+    const out = {};
+    while (true) {
+      const f = reader.readFieldBegin();
+      if (f.type === 0) break;
+      switch (f.id) {
+        case 1:
+          out.type = reader.readZigZag();
+          break;
+        case 3:
+          out.repetition_type = reader.readZigZag();
+          break;
+        case 4:
+          out.name = reader.readBinary().toString();
+          break;
+        case 5:
+          out.num_children = reader.readZigZag();
+          break;
+        default:
+          reader.skip(f.type);
+      }
+    }
+    return out;
+  });
+}
+
