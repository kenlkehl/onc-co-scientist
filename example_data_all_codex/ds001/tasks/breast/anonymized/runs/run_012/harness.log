+
+function summarize(arr) {
+  const n = arr.length;
+  let sum = 0;
+  let sumSq = 0;
+  let min = Infinity;
+  let max = -Infinity;
+  const uniq = new Set();
+  for (const v of arr) {
+    sum += v;
+    sumSq += v * v;
+    min = Math.min(min, v);
+    max = Math.max(max, v);
+    if (uniq.size <= 100000) uniq.add(v);
+  }
+  const mean = sum / n;
+  const variance = Math.max(0, (sumSq - n * mean * mean) / (n - 1));
+  return { n, mean, sd: Math.sqrt(variance), min, max, unique: uniq.size };
