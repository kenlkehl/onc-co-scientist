+function run() {
+  const { data, names, n } = loadParquetColumns();
+  const y = data.pfs_months;
+  const featureNames = names.filter((name) => name !== 'pfs_months');
+  const summaries = {};
+  const main = [];
+  const binaryNames = [];
+  const continuousNames = [];
+  for (const name of featureNames) {
+    const s = summarize(data[name]);
+    summaries[name] = s;
+    if (s.unique === 2 && s.min === 0 && s.max === 1) binaryNames.push(name);
+    else continuousNames.push(name);
+    const u = univariate(data[name], y);
+    const gd = s.unique === 2 ? groupDiff(data[name], y) : null;
+    main.push({ name, summary: s, univariate: u, group: gd });
+  }
+  main.sort((a, b) => Math.abs(b.univariate.z) - Math.abs(a.univariate.z));
+
+  const binaryPairs = [];
+  for (const name of binaryNames) {
+    const gd = groupDiff(data[name], y);
+    binaryPairs.push({ name, ...gd });
+  }
+  binaryPairs.sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff));
