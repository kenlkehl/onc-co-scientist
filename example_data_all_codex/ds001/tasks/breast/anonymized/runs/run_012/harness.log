+  return r.readStruct((reader) => {
+    const out = {};
+    while (true) {
+      const f = reader.readFieldBegin();
+      if (f.type === 0) break;
+      switch (f.id) {
+        case 1:
+          out.num_values = reader.readZigZag();
+          break;
+        case 2:
