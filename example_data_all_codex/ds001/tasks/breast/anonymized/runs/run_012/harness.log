+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+    sxx += x[i] * x[i];
+    syy += y[i] * y[i];
+    sxy += x[i] * y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  const Sxx = sxx - n * mx * mx;
+  const Syy = syy - n * my * my;
