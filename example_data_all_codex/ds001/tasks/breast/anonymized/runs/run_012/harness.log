+  fitTerms('feature_015_feature_044_interaction', [
+    { name: 'feature_015', values: data.feature_015 },
+    { name: 'feature_044', values: data.feature_044 },
+    makeInteraction(data.feature_015, data.feature_044, 'feature_015:feature_044')
+  ]);
+
+  const adjustedInteractionPairs = [
+    ['feature_046', 'feature_031'],
+    ['feature_046', 'feature_069'],
+    ['feature_046', 'feature_062'],
+    ['feature_046', 'feature_063'],
+    ['feature_031', 'feature_069'],
+    ['feature_031', 'feature_062'],
+    ['feature_062', 'feature_069'],
+    ['feature_031', 'feature_063'],
+    ['feature_069', 'feature_063'],
+    ['feature_062', 'feature_063'],
+    ['feature_044', 'feature_039'],
+    ['feature_044', 'feature_027'],
+    ['feature_044', 'feature_015'],
+    ['feature_027', 'feature_039'],
+    ['feature_040', 'feature_062'],
+    ['feature_039', 'feature_062']
+  ];
+  const adjustedInteractions = adjustedInteractionPairs.map(([a, b]) => ({
+    a,
+    b,
+    ...extraTermAgainstFull(adjusted, y, makeInteraction(data[a], data[b], `${a}:${b}`))
+  }));
+  adjustedInteractions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  function levelMeans(name) {
+    const counts = new Map();
+    const sums = new Map();
+    for (let i = 0; i < n; i++) {
+      const key = data[name][i];
+      counts.set(key, (counts.get(key) || 0) + 1);
+      sums.set(key, (sums.get(key) || 0) + y[i]);
+    }
+    return Array.from(counts.keys()).sort((a, b) => a - b).map((level) => ({
+      level,
+      n: counts.get(level),
+      mean: sums.get(level) / counts.get(level)
+    }));
+  }
+
+  const high44 = quantileThreshold(data.feature_044, 0.75);
+  const high62 = quantileThreshold(data.feature_062, 0.75);
+  const lowPfsCut = quantileThreshold(y, 0.25);
+  const groupStats = {};
+  function subgroupMean(key, predicate) {
+    let n1 = 0, s1 = 0, n0 = 0, s0 = 0;
+    for (let i = 0; i < n; i++) {
+      if (predicate(i)) {
+        n1 += 1;
+        s1 += y[i];
+      } else {
+        n0 += 1;
+        s0 += y[i];
+      }
+    }
+    groupStats[key] = { n1, mean1: s1 / n1, n0, mean0: s0 / n0, diff: s1 / n1 - s0 / n0 };
+  }
+  subgroupMean('feature_040_and_high_feature_062', (i) => data.feature_040[i] === 1 && data.feature_062[i] >= high62);
+  subgroupMean('feature_027_and_high_feature_044', (i) => data.feature_027[i] === 1 && data.feature_044[i] >= high44);
+  subgroupMean('feature_039_and_high_feature_062', (i) => data.feature_039[i] === 1 && data.feature_062[i] >= high62);
+  subgroupMean('feature_015_and_high_feature_044', (i) => data.feature_015[i] === 1 && data.feature_044[i] >= high44);
+
+  const slopes = {
+    feature_062_by_feature_040_1: subgroupContinuousSlope(data.feature_040, data.feature_062, y, 1),
+    feature_062_by_feature_040_0: subgroupContinuousSlope(data.feature_040, data.feature_062, y, 0),
+    feature_044_by_feature_027_1: subgroupContinuousSlope(data.feature_027, data.feature_044, y, 1),
+    feature_044_by_feature_027_0: subgroupContinuousSlope(data.feature_027, data.feature_044, y, 0),
+    feature_062_by_feature_039_1: subgroupContinuousSlope(data.feature_039, data.feature_062, y, 1),
+    feature_062_by_feature_039_0: subgroupContinuousSlope(data.feature_039, data.feature_062, y, 0)
+  };
+
+  const result = {
+    n,
+    outcome: summarize(y),
+    binaryNames,
+    continuousNames,
+    featureSummaries: summaries,
+    topUnivariate: main.slice(0, 25),
+    topBinaryDiffs: binaryPairs.slice(0, 25),
+    adjustedTop: adjustedTerms.slice(0, 30),
+    topInteractions: interactions.slice(0, 30),
+    adjustedInteractions,
+    targeted,
+    groupStats,
+    levelMeans: {
+      feature_027: levelMeans('feature_027')
