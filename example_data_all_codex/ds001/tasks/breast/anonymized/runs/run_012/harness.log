+      const run = groups * 8;
+      const blockBytes = Math.ceil((run * bitWidth) / 8);
+      const start = p;
+      let bitPos = 0;
+      for (let j = 0; j < run && values.length < count; j++) {
+        let value = 0;
+        for (let b = 0; b < bitWidth; b++) {
+          const absolute = bitPos + b;
+          const byte = buf[start + (absolute >> 3)];
+          const bit = (byte >> (absolute & 7)) & 1;
+          value |= bit << b;
+        }
+        values.push(value);
+        bitPos += bitWidth;
+      }
+      p = start + blockBytes;
+    }
+  }
+  return { values, pos: p };
+}
+
+function loadParquetColumns() {
+  const metaLen = fileBuf.readUInt32LE(fileBuf.length - 8);
+  const metaStart = fileBuf.length - 8 - metaLen;
+  const meta = parseFileMetaData(new TCompactReader(fileBuf, metaStart, fileBuf.length - 8));
+  const rg = meta.row_groups[0];
+  const names = meta.schema.slice(1).map((s) => s.name);
+  const data = {};
+  const schemaByColumn = meta.schema.slice(1);
+
+  function readColumn(idx) {
+    const md = rg.columns[idx].meta_data;
+    const type = md.type;
+    const start = md.dictionary_page_offset || md.data_page_offset;
+    const end = start + md.total_compressed_size;
+    let pos = start;
+    let dictionary = null;
+    const out = [];
+    while (pos < end && out.length < md.num_values) {
+      const header = parsePageHeader(fileBuf, pos);
+      const cstart = header.headerEnd;
+      const compressed = fileBuf.subarray(cstart, cstart + header.compressed_page_size);
+      const body = md.codec === 1 ? snappyUncompress(compressed) : Buffer.from(compressed);
+      if (header.type === 2) {
+        dictionary = readPlainValues(body, type, header.dictionary_page_header.num_values);
+      } else if (header.type === 0) {
+        const dh = header.data_page_header;
+        let p = 0;
+        let defined = dh.num_values;
+        if (schemaByColumn[idx].repetition_type === 1) {
+          const levelBytes = body.readInt32LE(p);
+          p += 4;
+          const levels = readHybrid(body, p, 1, dh.num_values);
+          let count = 0;
+          for (const v of levels.values) if (v === 1) count += 1;
+          defined = count;
+          p += levelBytes;
+        }
+
+        if (dh.encoding === 8) {
+          const bitWidth = body[p++];
+          const indices = readHybrid(body, p, bitWidth, defined);
+          for (const ix of indices.values) out.push(dictionary[ix]);
+        } else if (dh.encoding === 0) {
+          out.push(...readPlainValues(body.subarray(p), type, defined));
+        } else {
+          throw new Error(`Unsupported data encoding ${dh.encoding} for ${names[idx]}`);
+        }
+      }
+      pos = header.headerEnd + header.compressed_page_size;
+    }
+    if (out.length !== md.num_values) throw new Error(`Column ${names[idx]} decoded ${out.length}, expected ${md.num_values}`);
+    return out;
+  }
+
+  for (let idx = 1; idx < names.length; idx++) {
+    data[names[idx]] = readColumn(idx);
+  }
+  return { data, names: names.slice(1), n: meta.num_rows };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedPFromZ(z) {
+  const az = Math.abs(z);
+  if (!Number.isFinite(az)) return 1;
+  if (az < 8) return Math.max(1e-300, 2 * (1 - normalCdf(az)));
+  const logTail = -0.5 * az * az - Math.log(az) - 0.5 * Math.log(2 * Math.PI);
+  return Math.max(1e-300, 2 * Math.exp(logTail));
+}
+
+function summarize(arr) {
+  const n = arr.length;
+  let sum = 0;
+  let sumSq = 0;
+  let min = Infinity;
+  let max = -Infinity;
+  const uniq = new Set();
+  for (const v of arr) {
+    sum += v;
+    sumSq += v * v;
+    min = Math.min(min, v);
+    max = Math.max(max, v);
+    if (uniq.size <= 100000) uniq.add(v);
+  }
+  const mean = sum / n;
+  const variance = Math.max(0, (sumSq - n * mean * mean) / (n - 1));
+  return { n, mean, sd: Math.sqrt(variance), min, max, unique: uniq.size };
+}
+
+function univariate(x, y) {
+  const n = y.length;
+  let sx = 0, sy = 0, sxx = 0, syy = 0, sxy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+    sxx += x[i] * x[i];
+    syy += y[i] * y[i];
+    sxy += x[i] * y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  const Sxx = sxx - n * mx * mx;
+  const Syy = syy - n * my * my;
+  const Sxy = sxy - n * mx * my;
+  const beta = Sxy / Sxx;
+  const intercept = my - beta * mx;
+  const sse = Syy - beta * Sxy;
+  const sigma2 = sse / (n - 2);
+  const se = Math.sqrt(sigma2 / Sxx);
+  const z = beta / se;
+  return { beta, intercept, se, z, p: twoSidedPFromZ(z), r: Sxy / Math.sqrt(Sxx * Syy), r2: (Sxy * Sxy) / (Sxx * Syy) };
+}
+
+function groupDiff(x, y) {
+  const n = y.length;
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < n; i++) {
+    if (x[i] === 1) {
+      n1 += 1;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, mean1: m1, mean0: m0, diff: m1 - m0, se, z, p: twoSidedPFromZ(z) };
+}
+
+function inverse(matrix) {
+  const n = matrix.length;
+  const a = matrix.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(a[r][col]) > Math.abs(a[pivot][col])) pivot = r;
+    }
+    if (Math.abs(a[pivot][col]) < 1e-12) throw new Error(`Singular matrix at ${col}`);
+    if (pivot !== col) [a[pivot], a[col]] = [a[col], a[pivot]];
+    const scale = a[col][col];
+    for (let c = 0; c < 2 * n; c++) a[col][c] /= scale;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = a[r][col];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) a[r][c] -= factor * a[col][c];
+    }
+  }
+  return a.map((row) => row.slice(n));
+}
+
+function ols(predictors, y) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let syy = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const pred of predictors) row.push(pred.values[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+    syy += y[i] * y[i];
+  }
+  const inv = inverse(xtx);
+  const beta = Array(p).fill(0);
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
+  }
+  let sse = syy;
+  for (let a = 0; a < p; a++) sse -= beta[a] * xty[a];
+  const sigma2 = sse / (n - p);
+  const terms = predictors.map((pred, j) => {
+    const idx = j + 1;
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[idx][idx]));
+    const z = beta[idx] / se;
+    return { name: pred.name, beta: beta[idx], se, z, p: twoSidedPFromZ(z) };
+  });
+  return { beta, terms, sse, sigma2, df: n - p };
+}
+
+function makeInteraction(a, b, name) {
+  const n = a.length;
+  const values = new Array(n);
+  for (let i = 0; i < n; i++) values[i] = a[i] * b[i];
+  return { name, values };
+}
+
+function centerScale(arr) {
+  const s = summarize(arr);
+  return arr.map((v) => (v - s.mean) / s.sd);
+}
+
+function quantileThreshold(arr, q) {
+  const sorted = arr.slice().sort((a, b) => a - b);
+  return sorted[Math.min(sorted.length - 1, Math.max(0, Math.floor(q * (sorted.length - 1))))];
+}
+
+function subgroupContinuousSlope(binary, cont, y, level) {
+  const xs = [];
+  const ys = [];
+  for (let i = 0; i < y.length; i++) {
+    if (binary[i] === level) {
+      xs.push(cont[i]);
+      ys.push(y[i]);
+    }
+  }
+  return univariate(xs, ys);
+}
+
+function run() {
+  const { data, names, n } = loadParquetColumns();
+  const y = data.pfs_months;
+  const featureNames = names.filter((name) => name !== 'pfs_months');
+  const summaries = {};
+  const main = [];
+  const binaryNames = [];
+  const continuousNames = [];
+  for (const name of featureNames) {
+    const s = summarize(data[name]);
+    summaries[name] = s;
+    if (s.unique === 2 && s.min === 0 && s.max === 1) binaryNames.push(name);
+    else continuousNames.push(name);
+    const u = univariate(data[name], y);
+    const gd = s.unique === 2 ? groupDiff(data[name], y) : null;
+    main.push({ name, summary: s, univariate: u, group: gd });
+  }
+  main.sort((a, b) => Math.abs(b.univariate.z) - Math.abs(a.univariate.z));
+
+  const binaryPairs = [];
+  for (const name of binaryNames) {
+    const gd = groupDiff(data[name], y);
+    binaryPairs.push({ name, ...gd });
+  }
+  binaryPairs.sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff));
+
+  const adjustedPredictors = featureNames.map((name) => ({ name, values: data[name] }));
+  const adjusted = ols(adjustedPredictors, y);
+  const adjustedTerms = adjusted.terms.slice().sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const topMain = adjustedTerms.slice(0, 20).map((t) => t.name);
+  const interactions = [];
+  for (let i = 0; i < topMain.length; i++) {
+    for (let j = i + 1; j < topMain.length; j++) {
+      const a = topMain[i];
+      const b = topMain[j];
+      const interName = `${a}:${b}`;
+      const fit = ols([
+        { name: a, values: data[a] },
+        { name: b, values: data[b] },
+        makeInteraction(data[a], data[b], interName)
+      ], y);
+      const t = fit.terms[2];
+      interactions.push({ a, b, ...t });
+    }
+  }
+  interactions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const targeted = {};
+  function fitTerms(key, termSpecs) {
+    targeted[key] = ols(termSpecs.map((spec) => ({ name: spec.name, values: spec.values })), y).terms;
+  }
+
+  fitTerms('feature_040_feature_062_interaction', [
+    { name: 'feature_040', values: data.feature_040 },
+    { name: 'feature_062', values: data.feature_062 },
+    makeInteraction(data.feature_040, data.feature_062, 'feature_040:feature_062')
+  ]);
+  fitTerms('feature_027_feature_044_interaction', [
+    { name: 'feature_027', values: data.feature_027 },
+    { name: 'feature_044', values: data.feature_044 },
+    makeInteraction(data.feature_027, data.feature_044, 'feature_027:feature_044')
+  ]);
+  fitTerms('feature_039_feature_062_interaction', [
+    { name: 'feature_039', values: data.feature_039 },
+    { name: 'feature_062', values: data.feature_062 },
+    makeInteraction(data.feature_039, data.feature_062, 'feature_039:feature_062')
+  ]);
+  fitTerms('feature_015_feature_044_interaction', [
+    { name: 'feature_015', values: data.feature_015 },
+    { name: 'feature_044', values: data.feature_044 },
+    makeInteraction(data.feature_015, data.feature_044, 'feature_015:feature_044')
+  ]);
+
+  const high44 = quantileThreshold(data.feature_044, 0.75);
+  const high62 = quantileThreshold(data.feature_062, 0.75);
+  const lowPfsCut = quantileThreshold(y, 0.25);
+  const groupStats = {};
+  function subgroupMean(key, predicate) {
+    let n1 = 0, s1 = 0, n0 = 0, s0 = 0;
+    for (let i = 0; i < n; i++) {
+      if (predicate(i)) {
+        n1 += 1;
+        s1 += y[i];
+      } else {
+        n0 += 1;
+        s0 += y[i];
+      }
+    }
+    groupStats[key] = { n1, mean1: s1 / n1, n0, mean0: s0 / n0, diff: s1 / n1 - s0 / n0 };
+  }
+  subgroupMean('feature_040_and_high_feature_062', (i) => data.feature_040[i] === 1 && data.feature_062[i] >= high62);
+  subgroupMean('feature_027_and_high_feature_044', (i) => data.feature_027[i] === 1 && data.feature_044[i] >= high44);
+  subgroupMean('feature_039_and_high_feature_062', (i) => data.feature_039[i] === 1 && data.feature_062[i] >= high62);
+  subgroupMean('feature_015_and_high_feature_044', (i) => data.feature_015[i] === 1 && data.feature_044[i] >= high44);
+
+  const slopes = {
+    feature_062_by_feature_040_1: subgroupContinuousSlope(data.feature_040, data.feature_062, y, 1),
+    feature_062_by_feature_040_0: subgroupContinuousSlope(data.feature_040, data.feature_062, y, 0),
+    feature_044_by_feature_027_1: subgroupContinuousSlope(data.feature_027, data.feature_044, y, 1),
+    feature_044_by_feature_027_0: subgroupContinuousSlope(data.feature_027, data.feature_044, y, 0),
+    feature_062_by_feature_039_1: subgroupContinuousSlope(data.feature_039, data.feature_062, y, 1),
+    feature_062_by_feature_039_0: subgroupContinuousSlope(data.feature_039, data.feature_062, y, 0)
+  };
+
+  const result = {
+    n,
+    outcome: summarize(y),
+    binaryNames,
+    continuousNames,
+    featureSummaries: summaries,
+    topUnivariate: main.slice(0, 25),
+    topBinaryDiffs: binaryPairs.slice(0, 25),
+    adjustedTop: adjustedTerms.slice(0, 30),
+    topInteractions: interactions.slice(0, 30),
+    targeted,
+    groupStats,
+    thresholds: { high_feature_044_q75: high44, high_feature_062_q75: high62, low_pfs_q25: lowPfsCut },
+    slopes
+  };
+  console.log(JSON.stringify(result, null, 2));
+}
+
+run();

codex
The first pass found a compact set of strong main effects and candidate interaction terms. I’m tightening the interaction tests by adding each interaction on top of the full main-effect model, so the transcript does not rely on unadjusted interaction screens.
