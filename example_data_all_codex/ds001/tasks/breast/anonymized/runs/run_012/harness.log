+      topBinaryDiffs: result.topBinaryDiffs,
+      adjustedTop: result.adjustedTop,
+      adjustedSelected: ['feature_010', 'feature_025', 'feature_040'].map((name) => adjusted.terms.find((t) => t.name === name)),
+      adjustedInteractions: result.adjustedInteractions,
+      targeted: result.targeted,
+      groupStats: result.groupStats,
+      thresholds: result.thresholds,
+      levelMeans: result.levelMeans,
+      slopes: result.slopes
+    }, null, 2));
+  } else {
+    console.log(JSON.stringify(result, null, 2));
+  }
+}
