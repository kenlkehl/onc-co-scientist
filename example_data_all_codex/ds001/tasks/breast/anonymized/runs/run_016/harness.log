import pandas as pd
import json
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('missing total', int(df.isna().sum().sum()))
# summarize columns
summary=[]
for c in df.columns:
    s=df[c]
    vc=s.value_counts(dropna=False).head(10)
    summary.append({
        'col': c,
        'dtype': str(s.dtype),
        'nunique': int(s.nunique(dropna=False)),
        'mean': float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None,
        'std': float(s.std()) if pd.api.types.is_numeric_dtype(s) else None,
        'min': float(s.min()) if pd.api.types.is_numeric_dtype(s) else None,
        'max': float(s.max()) if pd.api.types.is_numeric_dtype(s) else None,
        'top': [(str(k), int(v)) for k,v in vc.items()]
    })
print(json.dumps(summary[:10], indent=2))
print('pfs describe')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
# binary counts all features
bin_cols=[]; cont_cols=[]
for c in df.columns:
    if c=='pfs_months': continue
    vals=set(df[c].unique().tolist())
    if vals.issubset({0,1,False,True}):
        bin_cols.append(c)
    else:
        cont_cols.append(c)
print('binary', len(bin_cols), bin_cols[:10])
print('nonbinary', len(cont_cols), cont_cols[:20])
# top binary prevalences
prev=df[bin_cols].mean().sort_values()
print('binary prev low')
print(prev.head(15).to_string())
print('binary prev high')
print(prev.tail(15).to_string())
if cont_cols:
    print('continuous summaries')
    print(df[cont_cols].describe(percentiles=[.01,.05,.25,.5,.75,.95,.99]).T.to_string())
