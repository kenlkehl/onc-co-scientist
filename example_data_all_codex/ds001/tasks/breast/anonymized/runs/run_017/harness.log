  listHeader(){ const h=this.byte(); let size=h>>4; const type=h&0x0f; if(size===15) size=Number(this.varint()); return {size,type}; }
  val(type){ switch(type){ case 1: return true; case 2: return false; case 3: return (this.byte()<<24)>>24; case 4: return this.i32(); case 5: return this.i32(); case 6: return this.i64(); case 7: return this.dbl(); case 8: return this.bin(); case 9: { const lh=this.listHeader(); const arr=[]; for(let i=0;i<lh.size;i++) arr.push(this.val(lh.type)); return arr; } case 12: return this.genericStruct(); default: throw new Error('unsupported type '+type+' at '+this.p); } }
