const fs = require('fs');
const b = fs.readFileSync('dataset.parquet');
function u32le(off){ return b.readUInt32LE(off); }
console.log('size', b.length, 'magic start', b.slice(0,4).toString(), 'magic end', b.slice(b.length-4).toString());
const footerLen = u32le(b.length-8);
const footerStart = b.length - 8 - footerLen;
console.log('footerLen', footerLen, 'footerStart', footerStart);
const buf = b.slice(footerStart, footerStart+footerLen);
class R {
  constructor(buf){this.b=buf; this.p=0; this.last=[];}
  byte(){return this.b[this.p++];}
  varint(){ let shift=0n, out=0n; while(true){ const x=this.byte(); out |= BigInt(x & 0x7f) << shift; if((x&0x80)===0) break; shift += 7n;} return out; }
  i32(){ const n=Number(this.varint()); return (n>>>1) "'^ -(n&1); }
  i64(){ const n=this.varint(); return (n >> 1n) ''^ (-(n & 1n)); }
  dbl(){ const v=this.b.readDoubleLE(this.p); this.p+=8; return v; }
  bin(){ const len=Number(this.varint()); const out=this.b.slice(this.p,this.p+len); this.p+=len; return out; }
  str(){ return this.bin().toString('"'utf8'); }
  fieldBegin(){ const h=this.byte(); const type=h&0x0f; if(type===0) return {type, id:0}; const mod=h>>4; let id; if(mod===0){ id=this.i32(); } else { id=this.last[this.last.length-1]+mod; } this.last[this.last.length-1]=id; return {type,id}; }
  struct(fn){ this.last.push(0); const res=fn(); this.last.pop(); return res; }
  listHeader(){ const h=this.byte(); let size=h>>4; const type=h&0x0f; if(size===15) size=Number(this.varint()); return {size,type}; }
  val(type){ switch(type){ case 1: return true; case 2: return false; case 3: return (this.byte()<<24)>>24; case 4: return this.i32(); case 5: return this.i32(); case 6: return Number(this.i64()); case 7: return this.dbl(); case 8: return this.bin(); case 9: { const lh=this.listHeader(); const arr=[]; for(let i=0;i<lh.size;i++) arr.push(this.val(lh.type)); return arr; } case 12: return this.genericStruct(); default: throw new Error('unsupported type '+type+' at '+this.p); } }
  skip(type){ this.val(type); }
  genericStruct(){ return this.struct(()=>{ const o={}; while(true){ const f=this.fieldBegin(); if(f.type===0) break; o[f.id]=this.val(f.type); } return o; }); }
}
const r = new R(buf);
