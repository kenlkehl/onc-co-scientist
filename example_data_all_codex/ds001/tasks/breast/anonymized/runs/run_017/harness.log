 function readColumnMetaData(r){ return r.struct(()=>{const o={}; while(true){ const f=r.fieldBegin(); if(f.type===0) break; if(f.id===1) o.type=r.i32(); else if(f.id===2){const lh=r.listHeader(); o.encodings=[]; for(let i=0;i<lh.size;i++) o.encodings.push(r.i32());} else if(f.id===3){const lh=r.listHeader(); o.path=[]; for(let i=0;i<lh.size;i++) o.path.push(r.str());} else if(f.id===4) o.codec=r.i32(); else if(f.id===5) o.num_values=r.i64(); else if(f.id===6) o.total_uncompressed_size=r.i64(); else if(f.id===7) o.total_compressed_size=r.i64(); else if(f.id===9) o.data_page_offset=r.i64(); else if(f.id===11) o.dictionary_page_offset=r.i64(); else if(f.id===12) o.statistics=readStatistics(r); else r.skip(f.type);} return o;}); }
 function readColumnChunk(r){ return r.struct(()=>{const o={}; while(true){ const f=r.fieldBegin(); if(f.type===0) break; if(f.id===2) o.file_offset=r.i64(); else if(f.id===3) o.meta_data=readColumnMetaData(r); else r.skip(f.type);} return o;}); }
