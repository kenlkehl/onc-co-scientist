 function readSchemaElement(r){ return r.struct(()=>{const o={}; while(true){ const f=r.fieldBegin(); if(f.type===0) break; if(f.id===1) o.type=r.i32(); else if(f.id===2) o.type_length=r.i32(); else if(f.id===3) o.repetition_type=r.i32(); else if(f.id===4) o.name=r.str(); else if(f.id===5) o.num_children=r.i32(); else r.skip(f.type);} return o;}); }
 return r.struct(()=>{const o={}; while(true){ const f=r.fieldBegin(); if(f.type===0) break; if(f.id===1) o.version=r.i32(); else if(f.id===2){ const lh=r.listHeader(); o.schema=[]; for(let i=0;i<lh.size;i++) o.schema.push(readSchemaElement(r)); } else if(f.id===3) o.num_rows=r.i64(); else if(f.id===4){ const lh=r.listHeader(); o.row_groups=[]; for(let i=0;i<lh.size;i++) o.row_groups.push(readRowGroup(r)); } else r.skip(f.type);} return o;});
