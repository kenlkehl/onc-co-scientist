+    return;
+  }
+  if (mode === "interactions") {
+    const features = Object.keys(data).filter(c => c !== "pfs_months");
+    const types = Object.fromEntries(summaries.map(r => [r.feature, r.binary ? "binary" : (r.unique <= 10 ? "categorical" : "continuous")]));
+    const topMain = summaries.slice(0, 12).map(r => r.feature);
+    const inters = [];
+    for (let i = 0; i < features.length; i++) {
+      for (let j = i + 1; j < features.length; j++) {
+        try {
+          const a = features[i], b = features[j];
+          const st = interactionStats(data[a], data[b], y);
+          inters.push({ a, b, typeA: types[a], typeB: types[b], effect: st.effect, se: st.se, z: st.z, p: st.p });
+        } catch (e) {}
+      }
+    }
+    inters.sort((a, b) => a.p - b.p);
+    const base = topMain.map(f => data[f]);
+    const adj = [];
+    for (let i = 0; i < topMain.length; i++) {
+      for (let j = i + 1; j < topMain.length; j++) {
+        const a = topMain[i], b = topMain[j];
