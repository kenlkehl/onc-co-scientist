+function ols(cols, y) {
+  const n = y.length;
+  const p = cols.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  const vals = Array(p);
+  for (let i = 0; i < n; i++) {
+    vals[0] = 1;
+    for (let j = 1; j < p; j++) vals[j] = cols[j - 1][i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += vals[a] * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += vals[a] * vals[b];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  const inv = invertMatrix(xtx);
+  const beta = inv.map(row => row.reduce((s, v, j) => s + v * xty[j], 0));
