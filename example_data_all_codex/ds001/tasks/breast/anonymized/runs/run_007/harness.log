+  for (const c of meta.row_groups[0].columns) {
+    const name = c.meta_data.path_in_schema[0];
+    if (name === "patient_id") continue;
+    data[name] = readColumn(c);
+  }
+  return data;
+}
+
+function mean(a) { let s = 0; for (const x of a) s += x; return s / a.length; }
+function sd(a, m = mean(a)) {
+  let s = 0;
+  for (const x of a) { const d = x - m; s += d * d; }
+  return Math.sqrt(s / (a.length - 1));
+}
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+function normCdf(x) { return 0.5 * (1 + erf(x / Math.SQRT2)); }
+function pFromZ(z) {
+  z = Math.abs(z);
+  if (z > 37) return 1e-300;
+  return Math.max(2 * (1 - normCdf(z)), 1e-300);
+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error("singular matrix");
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let j = 0; j < 2 * n; j++) M[i][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) M[r][j] -= f * M[i][j];
+    }
+  }
+  return M.map(row => row.slice(n));
+}
+
+function ols(cols, y) {
+  const n = y.length;
+  const p = cols.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  const vals = Array(p);
+  for (let i = 0; i < n; i++) {
+    vals[0] = 1;
+    for (let j = 1; j < p; j++) vals[j] = cols[j - 1][i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += vals[a] * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += vals[a] * vals[b];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  const inv = invertMatrix(xtx);
+  const beta = inv.map(row => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let fit = beta[0];
+    for (let j = 1; j < p; j++) fit += beta[j] * cols[j - 1][i];
+    const e = y[i] - fit;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, j) => Math.sqrt(Math.max(0, sigma2 * row[j])));
+  const z = beta.map((b, j) => b / se[j]);
+  const pvals = z.map(pFromZ);
+  return { beta, se, z, p: pvals, rss, df: n - p, sigma2 };
+}
+
+function uniqueSorted(a) {
+  return [...new Set(a)].sort((x, y) => x - y);
+}
+
+function binaryStats(x, y) {
+  let n0 = 0, n1 = 0, s0 = 0, s1 = 0, ss0 = 0, ss1 = 0;
+  for (let i = 0; i < x.length; i++) {
+    if (x[i] === 1) { n1++; s1 += y[i]; ss1 += y[i] * y[i]; }
+    else { n0++; s0 += y[i]; ss0 += y[i] * y[i]; }
+  }
+  const m0 = s0 / n0, m1 = s1 / n1;
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const se = Math.sqrt(v0 / n0 + v1 / n1);
+  const z = (m1 - m0) / se;
+  return { n0, n1, m0, m1, effect: m1 - m0, se, z, p: pFromZ(z) };
+}
+
+function slopeStats(x, y) {
+  const mx = mean(x), my = mean(y);
+  let cov = 0, vx = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    cov += dx * (y[i] - my);
+    vx += dx * dx;
+  }
+  const slope = cov / vx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < x.length; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (x.length - 2)) / vx);
+  const z = slope / se;
+  return { slope, intercept, se, z, p: pFromZ(z) };
+}
+
+function catStats(x, y) {
+  const vals = uniqueSorted(x);
+  const groups = vals.map(v => {
+    let n = 0, s = 0, ss = 0;
+    for (let i = 0; i < x.length; i++) if (x[i] === v) { n++; s += y[i]; ss += y[i] * y[i]; }
+    return { value: v, n, mean: s / n, variance: (ss - s * s / n) / (n - 1) };
+  });
+  return groups;
+}
+
+function interactionStats(x, z, y, baseCols = []) {
+  const mx = mean(x), mz = mean(z);
+  const inter = new Array(y.length);
+  for (let i = 0; i < y.length; i++) inter[i] = (x[i] - mx) * (z[i] - mz);
+  const fit = ols([...baseCols, x, z, inter], y);
+  const idx = fit.beta.length - 1;
+  return { effect: fit.beta[idx], se: fit.se[idx], z: fit.z[idx], p: fit.p[idx] };
+}
+
+function quartileGroups(x, y) {
+  const sorted = [...x].sort((a, b) => a - b);
+  const q = p => sorted[Math.floor((sorted.length - 1) * p)];
+  const cuts = [q(0.25), q(0.5), q(0.75)];
+  const groups = [0, 1, 2, 3].map(k => ({ k, n: 0, s: 0 }));
+  for (let i = 0; i < x.length; i++) {
+    const g = x[i] <= cuts[0] ? 0 : x[i] <= cuts[1] ? 1 : x[i] <= cuts[2] ? 2 : 3;
+    groups[g].n++;
+    groups[g].s += y[i];
+  }
+  return { cuts, groups: groups.map(g => ({ k: g.k, n: g.n, mean: g.s / g.n })) };
+}
+
+function summarize(data) {
+  const y = data.pfs_months;
+  const features = Object.keys(data).filter(c => c !== "pfs_months");
+  const out = [];
+  for (const f of features) {
+    const x = data[f];
+    const vals = uniqueSorted(x);
+    const s = vals.length === 2 && vals[0] === 0 && vals[1] === 1 ? binaryStats(x, y) : slopeStats(x, y);
+    out.push({
+      feature: f,
+      unique: vals.length,
+      min: vals[0],
+      max: vals[vals.length - 1],
+      mean: mean(x),
+      sd: sd(x),
+      effect: vals.length === 2 && vals[0] === 0 && vals[1] === 1 ? s.effect : s.slope,
+      p: s.p,
+      binary: vals.length === 2 && vals[0] === 0 && vals[1] === 1,
+      group: s.n0 !== undefined ? s : null
+    });
+  }
+  out.sort((a, b) => a.p - b.p);
+  return out;
+}
+
+function main() {
+  const mode = process.argv[2] || "summary";
+  const data = loadData();
+  const y = data.pfs_months;
+  const summaries = summarize(data);
+  if (mode === "summary") {
+    console.log(JSON.stringify({
+      n: y.length,
+      outcome: { mean: mean(y), sd: sd(y), min: Math.min(...y), max: Math.max(...y) },
+      top: summaries.slice(0, 30),
+      nonbinary: summaries.filter(r => !r.binary)
+    }, null, 2));
+    return;
+  }
+  if (mode === "interactions") {
+    const features = Object.keys(data).filter(c => c !== "pfs_months");
+    const types = Object.fromEntries(summaries.map(r => [r.feature, r.binary ? "binary" : (r.unique <= 10 ? "categorical" : "continuous")]));
+    const topMain = summaries.slice(0, 12).map(r => r.feature);
+    const inters = [];
+    for (let i = 0; i < features.length; i++) {
+      for (let j = i + 1; j < features.length; j++) {
+        try {
+          const a = features[i], b = features[j];
+          const st = interactionStats(data[a], data[b], y);
+          inters.push({ a, b, typeA: types[a], typeB: types[b], effect: st.effect, se: st.se, z: st.z, p: st.p });
+        } catch (e) {}
+      }
+    }
+    inters.sort((a, b) => a.p - b.p);
+    const base = topMain.map(f => data[f]);
+    const adj = [];
+    for (let i = 0; i < topMain.length; i++) {
+      for (let j = i + 1; j < topMain.length; j++) {
+        const a = topMain[i], b = topMain[j];
+        const baseWithout = topMain.filter(f => f !== a && f !== b).map(f => data[f]);
+        const st = interactionStats(data[a], data[b], y, baseWithout);
+        adj.push({ a, b, typeA: types[a], typeB: types[b], effect: st.effect, se: st.se, z: st.z, p: st.p });
+      }
+    }
+    adj.sort((a, b) => a.p - b.p);
+    const quads = [];
+    for (const r of summaries.filter(r => !r.binary)) {
+      const x = data[r.feature];
+      const mx = mean(x);
+      const x2 = x.map(v => (v - mx) * (v - mx));
+      const fit = ols([x, x2], y);
+      quads.push({ feature: r.feature, linear: fit.beta[1], quad: fit.beta[2], se: fit.se[2], p: fit.p[2] });
+    }
+    quads.sort((a, b) => a.p - b.p);
+    console.log(JSON.stringify({
+      topMain,
+      topInteractions: inters.slice(0, 40),
+      adjustedTopMainInteractions: adj.slice(0, 40),
+      topQuadratics: quads.slice(0, 20)
+    }, null, 2));
+    return;
+  }
+  if (mode === "details") {
+    const selected = [
+      "feature_044", "feature_027", "feature_039", "feature_015",
+      "feature_069", "feature_010", "feature_063", "feature_031",
+      "feature_062", "feature_004", "feature_037", "feature_046",
+      "feature_025", "feature_047", "feature_050", "feature_023"
+    ];
+    const fit = ols(selected.map(f => data[f]), y);
+    const adjusted = selected.map((f, i) => ({
+      feature: f,
+      effect: fit.beta[i + 1],
+      se: fit.se[i + 1],
+      z: fit.z[i + 1],
+      p: fit.p[i + 1]
+    }));
+    function twoBinary(a, b) {
+      const cells = {};
+      for (let av of [0, 1]) for (let bv of [0, 1]) cells[`${av}${bv}`] = { n: 0, sum: 0, ss: 0 };
+      for (let i = 0; i < y.length; i++) {
+        const key = `${data[a][i]}${data[b][i]}`;
+        cells[key].n++;
+        cells[key].sum += y[i];
+        cells[key].ss += y[i] * y[i];
+      }
+      for (const k of Object.keys(cells)) {
+        const c = cells[k];
+        c.mean = c.sum / c.n;
+      }
+      const st = interactionStats(data[a], data[b], y, selected.filter(f => f !== a && f !== b).map(f => data[f]));
+      return { a, b, cells, interaction: st };
+    }
+    function slopeByBinary(xf, bf) {
+      const rows = [];
+      for (const level of [0, 1]) {
+        const x = [], yy = [];
+        for (let i = 0; i < y.length; i++) if (data[bf][i] === level) { x.push(data[xf][i]); yy.push(y[i]); }
+        rows.push({ level, n: x.length, slope: slopeStats(x, yy) });
+      }
+      const st = interactionStats(data[xf], data[bf], y, selected.filter(f => f !== xf && f !== bf).map(f => data[f]));
+      return { x: xf, binary: bf, rows, interaction: st };
+    }
+    const cats027 = catStats(data.feature_027, y);
+    const quart044 = quartileGroups(data.feature_044, y);
+    const quart062 = quartileGroups(data.feature_062, y);
+    const quads = {};
+    for (const f of ["feature_044", "feature_062"]) {
+      const x = data[f], mx = mean(x), x2 = x.map(v => (v - mx) * (v - mx));
+      const qfit = ols([x, x2], y);
+      quads[f] = { linear: qfit.beta[1], quad: qfit.beta[2], quad_se: qfit.se[2], quad_p: qfit.p[2] };
+    }
+    const nullInteraction = interactionStats(data.feature_069, data.feature_010, y, selected.filter(f => f !== "feature_069" && f !== "feature_010").map(f => data[f]));
+    console.log(JSON.stringify({
+      adjusted,
+      feature_027_categories: cats027,
+      quartiles: { feature_044: quart044, feature_062: quart062 },
+      binary_interactions: [
+        twoBinary("feature_069", "feature_046"),
+        twoBinary("feature_010", "feature_046"),
+        twoBinary("feature_031", "feature_046"),
+        twoBinary("feature_063", "feature_046"),
+        twoBinary("feature_069", "feature_031"),
+        twoBinary("feature_069", "feature_063"),
+        twoBinary("feature_010", "feature_031"),
+        twoBinary("feature_010", "feature_063")
+      ],
+      slope_interactions: [
+        slopeByBinary("feature_062", "feature_046"),
+        slopeByBinary("feature_062", "feature_031"),
+        slopeByBinary("feature_044", "feature_039")
+      ],
+      ordinal_interactions: [
+        { a: "feature_044", b: "feature_027", interaction: interactionStats(data.feature_044, data.feature_027, y, selected.filter(f => f !== "feature_044" && f !== "feature_027").map(f => data[f])) },
+        { a: "feature_027", b: "feature_039", interaction: interactionStats(data.feature_027, data.feature_039, y, selected.filter(f => f !== "feature_027" && f !== "feature_039").map(f => data[f])) }
+      ],
+      quads,
+      null_interactions: [
+        { a: "feature_069", b: "feature_010", interaction: nullInteraction }
+      ],
+      summaries: summaries.slice(0, 30)
+    }, null, 2));
+    return;
+  }
+}
+
+main();

