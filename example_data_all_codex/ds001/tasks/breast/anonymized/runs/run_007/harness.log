+    for (let j = 1; j < p; j++) fit += beta[j] * cols[j - 1][i];
+    const e = y[i] - fit;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, j) => Math.sqrt(Math.max(0, sigma2 * row[j])));
+  const z = beta.map((b, j) => b / se[j]);
+  const pvals = z.map(pFromZ);
