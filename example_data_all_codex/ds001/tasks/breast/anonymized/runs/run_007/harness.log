@@ -0,0 +1,722 @@
+const fs = require("fs");
+
+const file = fs.readFileSync("dataset.parquet");
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.b = buf;
+    this.p = pos;
+    this.stack = [];
+    this.last = 0;
+  }
+  byte() { return this.b[this.p++]; }
+  varint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const x = this.byte();
+      result |= BigInt(x & 0x7f) << BigInt(shift);
+      if ((x & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  zigzag(n) { return Number((n >> 1n) ^ (-(n & 1n))); }
+  i32() { return this.zigzag(this.varint()); }
+  i64() { return this.zigzag(this.varint()); }
+  bin() {
+    const len = Number(this.varint());
+    const out = this.b.slice(this.p, this.p + len);
+    this.p += len;
+    return out;
+  }
+  str() { return this.bin().toString("utf8"); }
+  field() {
+    const x = this.byte();
+    const t = x & 15;
+    if (!t) return { t, id: 0 };
+    const delta = x >> 4;
+    const id = delta ? this.last + delta : this.i32();
+    this.last = id;
+    return { t, id };
+  }
+  push() { this.stack.push(this.last); this.last = 0; }
+  pop() { this.last = this.stack.pop(); }
+  list() {
+    const x = this.byte();
+    let size = x >> 4;
+    const et = x & 15;
+    if (size === 15) size = Number(this.varint());
+    return { size, et };
+  }
+  skip(t) {
+    if (t === 0 || t === 1 || t === 2) return;
+    if (t === 3) { this.byte(); return; }
+    if (t === 4 || t === 5) { this.i32(); return; }
+    if (t === 6) { this.i64(); return; }
+    if (t === 7) { this.p += 8; return; }
+    if (t === 8) { this.bin(); return; }
+    if (t === 9 || t === 10) {
+      const lh = this.list();
+      for (let i = 0; i < lh.size; i++) this.skip(lh.et);
+      return;
+    }
+    if (t === 11) {
+      const n = Number(this.varint());
+      if (n) {
+        const kt = this.byte();
+        const vt = this.byte();
+        for (let i = 0; i < n; i++) { this.skip(kt); this.skip(vt); }
+      }
+      return;
+    }
+    if (t === 12) {
+      this.push();
+      while (true) {
+        const h = this.field();
+        if (!h.t) break;
+        this.skip(h.t);
+      }
+      this.pop();
+      return;
+    }
+    throw new Error(`unknown compact type ${t} at ${this.p}`);
+  }
+}
+
+function readSchemaElement(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.type = r.i32();
+    else if (h.id === 2) o.type_length = r.i32();
+    else if (h.id === 3) o.repetition_type = r.i32();
+    else if (h.id === 4) o.name = r.str();
+    else if (h.id === 5) o.num_children = r.i32();
+    else if (h.id === 6) o.converted_type = r.i32();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readColumnMetaData(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.type = r.i32();
+    else if (h.id === 2) {
+      const lh = r.list();
+      o.encodings = [];
+      for (let i = 0; i < lh.size; i++) o.encodings.push(r.i32());
+    } else if (h.id === 3) {
+      const lh = r.list();
+      o.path_in_schema = [];
+      for (let i = 0; i < lh.size; i++) o.path_in_schema.push(r.str());
+    } else if (h.id === 4) o.codec = r.i32();
+    else if (h.id === 5) o.num_values = r.i64();
+    else if (h.id === 6) o.total_uncompressed_size = r.i64();
+    else if (h.id === 7) o.total_compressed_size = r.i64();
+    else if (h.id === 9) o.data_page_offset = r.i64();
+    else if (h.id === 11) o.dictionary_page_offset = r.i64();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readColumnChunk(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.file_path = r.str();
+    else if (h.id === 2) o.file_offset = r.i64();
+    else if (h.id === 3) o.meta_data = readColumnMetaData(r);
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readRowGroup(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) {
+      const lh = r.list();
+      o.columns = [];
+      for (let i = 0; i < lh.size; i++) o.columns.push(readColumnChunk(r));
+    } else if (h.id === 2) o.total_byte_size = r.i64();
+    else if (h.id === 3) o.num_rows = r.i64();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readFileMeta() {
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const start = file.length - 8 - footerLen;
+  const r = new CompactReader(file.slice(start, file.length - 8));
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.version = r.i32();
+    else if (h.id === 2) {
+      const lh = r.list();
+      o.schema = [];
+      for (let i = 0; i < lh.size; i++) o.schema.push(readSchemaElement(r));
+    } else if (h.id === 3) o.num_rows = r.i64();
+    else if (h.id === 4) {
+      const lh = r.list();
+      o.row_groups = [];
+      for (let i = 0; i < lh.size; i++) o.row_groups.push(readRowGroup(r));
+    } else if (h.id === 6) o.created_by = r.str();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readDataPageHeader(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.num_values = r.i32();
+    else if (h.id === 2) o.encoding = r.i32();
+    else if (h.id === 3) o.definition_level_encoding = r.i32();
+    else if (h.id === 4) o.repetition_level_encoding = r.i32();
+    else r.skip(h.t);
+  }
+  r.pop();
