+        } catch (e) {}
+      }
+    }
+    inters.sort((a, b) => a.p - b.p);
+    const base = topMain.map(f => data[f]);
+    const adj = [];
+    for (let i = 0; i < topMain.length; i++) {
+      for (let j = i + 1; j < topMain.length; j++) {
+        const a = topMain[i], b = topMain[j];
+        const baseWithout = topMain.filter(f => f !== a && f !== b).map(f => data[f]);
+        const st = interactionStats(data[a], data[b], y, baseWithout);
+        adj.push({ a, b, typeA: types[a], typeB: types[b], effect: st.effect, se: st.se, z: st.z, p: st.p });
+      }
+    }
+    adj.sort((a, b) => a.p - b.p);
+    const quads = [];
+    for (const r of summaries.filter(r => !r.binary)) {
+      const x = data[r.feature];
+      const mx = mean(x);
+      const x2 = x.map(v => (v - mx) * (v - mx));
+      const fit = ols([x, x2], y);
+      quads.push({ feature: r.feature, linear: fit.beta[1], quad: fit.beta[2], se: fit.se[2], p: fit.p[2] });
+    }
+    quads.sort((a, b) => a.p - b.p);
+    console.log(JSON.stringify({
+      topMain,
+      topInteractions: inters.slice(0, 40),
+      adjustedTopMainInteractions: adj.slice(0, 40),
