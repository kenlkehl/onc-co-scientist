+      const bytes = Math.ceil(bw / 8);
+      let v = 0;
+      for (let i = 0; i < bytes; i++) v |= buf[po.p++] << (8 * i);
+      for (let i = 0; i < run && vals.length < count; i++) vals.push(v);
