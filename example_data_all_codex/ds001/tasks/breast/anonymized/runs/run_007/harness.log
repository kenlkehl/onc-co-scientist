+function interactionStats(x, z, y, baseCols = []) {
+  const mx = mean(x), mz = mean(z);
+  const inter = new Array(y.length);
+  for (let i = 0; i < y.length; i++) inter[i] = (x[i] - mx) * (z[i] - mz);
+  const fit = ols([...baseCols, x, z, inter], y);
+  const idx = fit.beta.length - 1;
+  return { effect: fit.beta[idx], se: fit.se[idx], z: fit.z[idx], p: fit.p[idx] };
+}
+
+function quartileGroups(x, y) {
+  const sorted = [...x].sort((a, b) => a - b);
+  const q = p => sorted[Math.floor((sorted.length - 1) * p)];
+  const cuts = [q(0.25), q(0.5), q(0.75)];
+  const groups = [0, 1, 2, 3].map(k => ({ k, n: 0, s: 0 }));
+  for (let i = 0; i < x.length; i++) {
+    const g = x[i] <= cuts[0] ? 0 : x[i] <= cuts[1] ? 1 : x[i] <= cuts[2] ? 2 : 3;
+    groups[g].n++;
+    groups[g].s += y[i];
+  }
+  return { cuts, groups: groups.map(g => ({ k: g.k, n: g.n, mean: g.s / g.n })) };
