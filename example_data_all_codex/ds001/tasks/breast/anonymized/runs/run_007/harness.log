+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.b = buf;
+    this.p = pos;
+    this.stack = [];
+    this.last = 0;
+  }
+  byte() { return this.b[this.p++]; }
+  varint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const x = this.byte();
+      result |= BigInt(x & 0x7f) << BigInt(shift);
+      if ((x & 0x80) === 0) break;
+      shift += 7;
