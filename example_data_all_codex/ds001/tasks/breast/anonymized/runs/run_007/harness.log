+  }
+  out.sort((a, b) => a.p - b.p);
+  return out;
+}
+
+function main() {
+  const mode = process.argv[2] || "summary";
+  const data = loadData();
+  const y = data.pfs_months;
+  const summaries = summarize(data);
+  if (mode === "summary") {
+    console.log(JSON.stringify({
+      n: y.length,
+      outcome: { mean: mean(y), sd: sd(y), min: Math.min(...y), max: Math.max(...y) },
+      top: summaries.slice(0, 30),
+      nonbinary: summaries.filter(r => !r.binary)
