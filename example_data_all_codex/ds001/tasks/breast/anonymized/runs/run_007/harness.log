+const fs = require("fs");
+
+const file = fs.readFileSync("dataset.parquet");
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.b = buf;
+    this.p = pos;
+    this.stack = [];
+    this.last = 0;
+  }
+  byte() { return this.b[this.p++]; }
+  varint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const x = this.byte();
+      result |= BigInt(x & 0x7f) << BigInt(shift);
+      if ((x & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  zigzag(n) { return Number((n >> 1n) ^ (-(n & 1n))); }
+  i32() { return this.zigzag(this.varint()); }
+  i64() { return this.zigzag(this.varint()); }
+  bin() {
+    const len = Number(this.varint());
+    const out = this.b.slice(this.p, this.p + len);
+    this.p += len;
+    return out;
+  }
+  str() { return this.bin().toString("utf8"); }
+  field() {
+    const x = this.byte();
+    const t = x & 15;
+    if (!t) return { t, id: 0 };
+    const delta = x >> 4;
+    const id = delta ? this.last + delta : this.i32();
+    this.last = id;
+    return { t, id };
+  }
+  push() { this.stack.push(this.last); this.last = 0; }
+  pop() { this.last = this.stack.pop(); }
+  list() {
+    const x = this.byte();
+    let size = x >> 4;
+    const et = x & 15;
+    if (size === 15) size = Number(this.varint());
+    return { size, et };
+  }
+  skip(t) {
+    if (t === 0 || t === 1 || t === 2) return;
+    if (t === 3) { this.byte(); return; }
+    if (t === 4 || t === 5) { this.i32(); return; }
+    if (t === 6) { this.i64(); return; }
+    if (t === 7) { this.p += 8; return; }
+    if (t === 8) { this.bin(); return; }
+    if (t === 9 || t === 10) {
+      const lh = this.list();
+      for (let i = 0; i < lh.size; i++) this.skip(lh.et);
+      return;
+    }
+    if (t === 11) {
+      const n = Number(this.varint());
+      if (n) {
+        const kt = this.byte();
+        const vt = this.byte();
+        for (let i = 0; i < n; i++) { this.skip(kt); this.skip(vt); }
+      }
+      return;
+    }
+    if (t === 12) {
+      this.push();
+      while (true) {
+        const h = this.field();
+        if (!h.t) break;
+        this.skip(h.t);
+      }
+      this.pop();
+      return;
+    }
+    throw new Error(`unknown compact type ${t} at ${this.p}`);
+  }
+}
+
+function readSchemaElement(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.type = r.i32();
+    else if (h.id === 2) o.type_length = r.i32();
+    else if (h.id === 3) o.repetition_type = r.i32();
+    else if (h.id === 4) o.name = r.str();
+    else if (h.id === 5) o.num_children = r.i32();
+    else if (h.id === 6) o.converted_type = r.i32();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readColumnMetaData(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.type = r.i32();
+    else if (h.id === 2) {
+      const lh = r.list();
+      o.encodings = [];
+      for (let i = 0; i < lh.size; i++) o.encodings.push(r.i32());
+    } else if (h.id === 3) {
+      const lh = r.list();
+      o.path_in_schema = [];
+      for (let i = 0; i < lh.size; i++) o.path_in_schema.push(r.str());
+    } else if (h.id === 4) o.codec = r.i32();
+    else if (h.id === 5) o.num_values = r.i64();
+    else if (h.id === 6) o.total_uncompressed_size = r.i64();
+    else if (h.id === 7) o.total_compressed_size = r.i64();
+    else if (h.id === 9) o.data_page_offset = r.i64();
+    else if (h.id === 11) o.dictionary_page_offset = r.i64();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readColumnChunk(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.file_path = r.str();
+    else if (h.id === 2) o.file_offset = r.i64();
+    else if (h.id === 3) o.meta_data = readColumnMetaData(r);
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readRowGroup(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) {
+      const lh = r.list();
+      o.columns = [];
+      for (let i = 0; i < lh.size; i++) o.columns.push(readColumnChunk(r));
+    } else if (h.id === 2) o.total_byte_size = r.i64();
+    else if (h.id === 3) o.num_rows = r.i64();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readFileMeta() {
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const start = file.length - 8 - footerLen;
+  const r = new CompactReader(file.slice(start, file.length - 8));
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.version = r.i32();
+    else if (h.id === 2) {
+      const lh = r.list();
+      o.schema = [];
+      for (let i = 0; i < lh.size; i++) o.schema.push(readSchemaElement(r));
+    } else if (h.id === 3) o.num_rows = r.i64();
+    else if (h.id === 4) {
+      const lh = r.list();
+      o.row_groups = [];
+      for (let i = 0; i < lh.size; i++) o.row_groups.push(readRowGroup(r));
+    } else if (h.id === 6) o.created_by = r.str();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readDataPageHeader(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.num_values = r.i32();
+    else if (h.id === 2) o.encoding = r.i32();
+    else if (h.id === 3) o.definition_level_encoding = r.i32();
+    else if (h.id === 4) o.repetition_level_encoding = r.i32();
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readDictPageHeader(r) {
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.num_values = r.i32();
+    else if (h.id === 2) o.encoding = r.i32();
+    else if (h.id === 3) o.is_sorted = (h.t === 1);
+    else r.skip(h.t);
+  }
+  r.pop();
+  return o;
+}
+
+function readPageHeader(pos) {
+  const r = new CompactReader(file, pos);
+  const o = {};
+  r.push();
+  while (true) {
+    const h = r.field();
+    if (!h.t) break;
+    if (h.id === 1) o.type = r.i32();
+    else if (h.id === 2) o.uncompressed_page_size = r.i32();
+    else if (h.id === 3) o.compressed_page_size = r.i32();
+    else if (h.id === 5) o.data_page_header = readDataPageHeader(r);
+    else if (h.id === 7) o.dictionary_page_header = readDictPageHeader(r);
+    else r.skip(h.t);
+  }
+  r.pop();
+  o.header_size = r.p - pos;
+  o.data_start = r.p;
+  return o;
+}
+
+function snappyDecode(input, expected) {
+  let ip = 0;
+  let pre = 0;
+  let shift = 0;
+  while (true) {
+    const x = input[ip++];
+    pre |= (x & 127) << shift;
+    if (!(x & 128)) break;
+    shift += 7;
+  }
+  if (expected !== undefined && pre !== expected) {
+    throw new Error(`snappy length ${pre}, expected ${expected}`);
+  }
+  const out = Buffer.alloc(pre);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) len += 1;
+      else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else {
+      let len;
+      let off;
+      if (type === 1) {
+        len = ((tag >> 2) & 7) + 4;
+        off = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        off = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        off = (input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24)) >>> 0;
+        ip += 4;
+      }
+      for (let i = 0; i < len; i++) out[op + i] = out[op - off + i];
+      op += len;
+    }
+  }
+  if (op !== pre) throw new Error(`snappy decoded ${op}, expected ${pre}`);
+  return out;
+}
+
+function pageBytes(ph) {
+  const comp = file.slice(ph.data_start, ph.data_start + ph.compressed_page_size);
+  return snappyDecode(comp, ph.uncompressed_page_size);
+}
+
+function decodePlain(b, type, n) {
+  const out = [];
+  let p = 0;
+  if (type === 2) {
+    for (let i = 0; i < n; i++) { out.push(Number(b.readBigInt64LE(p))); p += 8; }
+  } else if (type === 5) {
+    for (let i = 0; i < n; i++) { out.push(b.readDoubleLE(p)); p += 8; }
+  } else if (type === 6) {
+    for (let i = 0; i < n; i++) {
+      const len = b.readInt32LE(p);
+      p += 4;
+      out.push(b.slice(p, p + len).toString("utf8"));
+      p += len;
+    }
+  } else {
+    throw new Error(`unsupported plain type ${type}`);
+  }
+  return out;
+}
+
+function readUVar(buf, posObj) {
+  let shift = 0;
+  let val = 0;
+  while (true) {
+    const x = buf[posObj.p++];
+    val |= (x & 127) << shift;
+    if (!(x & 128)) break;
+    shift += 7;
+  }
+  return val;
+}
+
+function unpackBits(buf, posObj, bw, count) {
+  const vals = [];
+  let bitPos = posObj.p * 8;
+  for (let i = 0; i < count; i++) {
+    let v = 0;
+    for (let b = 0; b < bw; b++) {
+      const byte = buf[bitPos >> 3];
+      const bit = (byte >> (bitPos & 7)) & 1;
+      v |= bit << b;
+      bitPos++;
+    }
+    vals.push(v);
+  }
+  posObj.p = Math.ceil(bitPos / 8);
+  return vals;
+}
