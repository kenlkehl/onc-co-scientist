+
+function summarize(data) {
+  const y = data.pfs_months;
+  const features = Object.keys(data).filter(c => c !== "pfs_months");
+  const out = [];
+  for (const f of features) {
+    const x = data[f];
+    const vals = uniqueSorted(x);
+    const s = vals.length === 2 && vals[0] === 0 && vals[1] === 1 ? binaryStats(x, y) : slopeStats(x, y);
+    out.push({
+      feature: f,
+      unique: vals.length,
+      min: vals[0],
+      max: vals[vals.length - 1],
+      mean: mean(x),
+      sd: sd(x),
+      effect: vals.length === 2 && vals[0] === 0 && vals[1] === 1 ? s.effect : s.slope,
+      p: s.p,
+      binary: vals.length === 2 && vals[0] === 0 && vals[1] === 1,
