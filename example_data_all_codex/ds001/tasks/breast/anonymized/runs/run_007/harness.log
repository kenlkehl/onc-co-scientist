+function decodeRleBitpacked(buf, pos, count, bw) {
+  const po = { p: pos };
+  const vals = [];
+  while (vals.length < count && po.p < buf.length) {
+    const header = readUVar(buf, po);
+    if ((header & 1) === 0) {
