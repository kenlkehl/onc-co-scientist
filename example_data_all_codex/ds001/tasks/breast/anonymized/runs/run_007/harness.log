+
+function binaryStats(x, y) {
+  let n0 = 0, n1 = 0, s0 = 0, s1 = 0, ss0 = 0, ss1 = 0;
+  for (let i = 0; i < x.length; i++) {
+    if (x[i] === 1) { n1++; s1 += y[i]; ss1 += y[i] * y[i]; }
+    else { n0++; s0 += y[i]; ss0 += y[i] * y[i]; }
+  }
+  const m0 = s0 / n0, m1 = s1 / n1;
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const se = Math.sqrt(v0 / n0 + v1 / n1);
+  const z = (m1 - m0) / se;
+  return { n0, n1, m0, m1, effect: m1 - m0, se, z, p: pFromZ(z) };
+}
+
+function slopeStats(x, y) {
+  const mx = mean(x), my = mean(y);
+  let cov = 0, vx = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    cov += dx * (y[i] - my);
+    vx += dx * dx;
+  }
+  const slope = cov / vx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < x.length; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (x.length - 2)) / vx);
+  const z = slope / se;
+  return { slope, intercept, se, z, p: pFromZ(z) };
