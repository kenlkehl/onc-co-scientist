+const fs = require("fs");
+const path = require("path");
+
+const DATASET_ID = "ds001_breast";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-local-parquet-js@2026-04-30";
+const MAX_ITERATIONS = 25;
+
+const parquetBuffer = fs.readFileSync(path.join(process.cwd(), "dataset.parquet"));
+
+class CompactReader {
+  constructor(buffer, offset = 0) {
+    this.buffer = buffer;
+    this.offset = offset;
+  }
+
+  byte() {
+    return this.buffer[this.offset++];
+  }
+
+  varintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const byte = this.byte();
+      result |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigZagBig(value) {
+    return (value >> 1n) ^ (-(value & 1n));
+  }
+
+  i32() {
+    return Number(this.zigZagBig(this.varintBig()));
+  }
+
+  i64() {
+    return Number(this.zigZagBig(this.varintBig()));
+  }
+
+  string() {
+    const length = Number(this.varintBig());
+    const value = this.buffer.toString("utf8", this.offset, this.offset + length);
+    this.offset += length;
+    return value;
+  }
+
+  listHeader() {
+    const header = this.byte();
