  zigzag(n){return (n >> 1n) "'^ (-(n & 1n));}
  i32(){return Number(this.zigzag(this.varint()));}
  i64(){return Number(this.zigzag(this.varint()));}
  bin(){const len=Number(this.varint()); const s=this.buf.subarray(this.pos,this.pos+len); this.pos += len; return s;}
