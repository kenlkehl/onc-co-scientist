+          let j = 0;
+          for (let i = 0; i < dph.num_values; i++) {
+            if (defLevels && defLevels[i] !== 1) values.push(null);
+            else values.push(dictionary[ids[j++]]);
+          }
+        } else if (dph.encoding === 0) {
+          const decoded = plainDecode(page.data.subarray(pos), parquetType, nonNull);
+          let j = 0;
+          for (let i = 0; i < dph.num_values; i++) {
+            if (defLevels && defLevels[i] !== 1) values.push(null);
+            else values.push(decoded[j++]);
+          }
+        } else {
+          throw new Error(`Unsupported data page encoding ${dph.encoding} for ${name}`);
+        }
+      } else if (page.header.type === 3) {
+        const h = page.header.data_page_header_v2;
+        let pos = h.repetition_levels_byte_length + h.definition_levels_byte_length;
+        const nonNull = h.num_values - h.num_nulls;
+        if (h.encoding === 8 || h.encoding === 2) {
+          const bitWidth = page.data[pos++];
+          const ids = decodeRleBitpacked(page.data, pos, bitWidth, nonNull).values;
+          for (const id of ids) values.push(dictionary[id]);
+        } else {
+          const decoded = plainDecode(page.data.subarray(pos), parquetType, nonNull);
+          for (const value of decoded) values.push(value);
+        }
+      } else {
+        throw new Error(`Unsupported page type ${page.header.type}`);
+      }
