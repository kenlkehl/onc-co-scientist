+  const f = Math.pow(10, digits);
+  return Math.round(x * f) / f;
+}
+
+function analysisRecord(hypothesisIds, resultSummary, effectEstimate, pValue, code) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: resultSummary,
+    p_value: pValue,
+    effect_estimate: effectEstimate,
+    significant: pValue < 0.05,
+  };
+}
+
+function main() {
+  const { meta, columns } = readParquet("dataset.parquet");
+  const y = columns.pfs_months.map(Number);
+  const allFeatures = Object.keys(columns).filter((c) => c !== "patient_id" && c !== "pfs_months");
+  const summaries = {};
+  for (const f of allFeatures) {
+    const arr = columns[f].map(Number);
+    const uc = uniqueCount(arr);
+    summaries[f] = {
+      unique: uc,
+      mean: mean(arr),
+      sd: Math.sqrt(variance(arr)),
+      min: Math.min(...arr),
+      max: Math.max(...arr),
+      isBinary: uc === 2 && Math.min(...arr) === 0 && Math.max(...arr) === 1,
+      values: arr,
+    };
+  }
+  const binary = allFeatures.filter((f) => summaries[f].isBinary);
+  const continuous = allFeatures.filter((f) => !summaries[f].isBinary);
+
+  const simple = [];
+  for (const f of allFeatures) {
+    const x = summaries[f].values;
+    const model = ols(y, [x]);
+    const effect = model.beta[1];
+    simple.push({ feature: f, effect, p: model.pValues[1], unique: summaries[f].unique, r: corr(x, y) });
+  }
+  simple.sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+  const byP = simple.slice().sort((a, b) => a.p - b.p);
+  const positive = simple.filter((d) => d.effect > 0).sort((a, b) => a.p - b.p);
+  const negative = simple.filter((d) => d.effect < 0).sort((a, b) => a.p - b.p);
+
+  const contZ = {};
+  for (const f of continuous) contZ[f] = standardize(summaries[f].values);
+  const binVals = {};
+  for (const f of binary) binVals[f] = summaries[f].values;
+
+  const keyFeatures = Array.from(new Set([
+    ...positive.slice(0, 8).map((d) => d.feature),
+    ...negative.slice(0, 8).map((d) => d.feature),
+    ...byP.slice(0, 12).map((d) => d.feature),
+  ]));
+  const multiXs = keyFeatures.map((f) => summaries[f].isBinary ? summaries[f].values : contZ[f]);
+  const multi = ols(y, multiXs);
+  const adjusted = {};
+  keyFeatures.forEach((f, i) => {
+    adjusted[f] = { effect: multi.beta[i + 1], p: multi.pValues[i + 1], se: multi.se[i + 1] };
+  });
+
+  const binaryMain = binary.map((f) => {
+    const md = meanDiff(y, summaries[f].values);
+    const model = ols(y, [summaries[f].values]);
+    return { feature: f, ...md, p: model.pValues[1] };
+  }).sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+
+  const contMain = continuous.map((f) => {
+    const model = ols(y, [contZ[f]]);
+    return { feature: f, effect: model.beta[1], p: model.pValues[1] };
+  }).sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+
+  const topBin = binaryMain[0].feature;
+  const secondBin = binaryMain.find((d) => d.feature !== topBin).feature;
+  const topContPos = contMain.filter((d) => d.effect > 0)[0].feature;
+  const topContNeg = contMain.filter((d) => d.effect < 0)[0].feature;
+  const strongestAdjusted = Object.entries(adjusted).sort((a, b) => a[1].p - b[1].p).map(([feature, stats]) => ({ feature, ...stats }));
+
+  const interactionPairs = [];
+  const interCandidates = Array.from(new Set([...keyFeatures, ...binaryMain.slice(0, 8).map((d) => d.feature), ...contMain.slice(0, 8).map((d) => d.feature)]));
+  for (let i = 0; i < interCandidates.length; i++) {
+    for (let j = i + 1; j < interCandidates.length; j++) {
+      const a = interCandidates[i];
+      const b = interCandidates[j];
+      const xa = summaries[a].isBinary ? summaries[a].values : contZ[a];
+      const xb = summaries[b].isBinary ? summaries[b].values : contZ[b];
+      const xab = xa.map((v, idx) => v * xb[idx]);
+      const mod = ols(y, [xa, xb, xab]);
+      interactionPairs.push({ a, b, effect: mod.beta[3], p: mod.pValues[3] });
+    }
+  }
+  interactionPairs.sort((a, b) => a.p - b.p);
+
+  function highLow(feature) {
+    const vals = summaries[feature].values;
+    const q75 = quantile(vals, 0.75);
+    const q25 = quantile(vals, 0.25);
+    return {
+      high: binaryVector(vals, (v) => v >= q75),
+      low: binaryVector(vals, (v) => v <= q25),
+      q75,
+      q25,
+    };
+  }
+
+  const hlPos = highLow(topContPos);
+  const hlNeg = highLow(topContNeg);
+  const hlPosMd = meanDiff(y, hlPos.high);
+  const hlNegMd = meanDiff(y, hlNeg.high);
+  const hlPosModel = ols(y, [hlPos.high]);
+  const hlNegModel = ols(y, [hlNeg.high]);
+
+  const subgroupTests = [];
+  for (const bf of binaryMain.slice(0, 10).map((d) => d.feature)) {
+    for (const cf of contMain.slice(0, 10).map((d) => d.feature)) {
+      const b = summaries[bf].values;
+      const z = contZ[cf];
+      const bz = b.map((v, i) => v * z[i]);
+      const mod = ols(y, [b, z, bz]);
+      subgroupTests.push({ binary: bf, continuous: cf, effect: mod.beta[3], p: mod.pValues[3] });
+    }
+  }
+  subgroupTests.sort((a, b) => a.p - b.p);
+
+  const thresholdTests = [];
+  for (const cf of contMain.slice(0, 12).map((d) => d.feature)) {
+    const vals = summaries[cf].values;
+    for (const q of [0.25, 0.5, 0.75]) {
+      const thr = quantile(vals, q);
+      const ind = binaryVector(vals, (v) => v >= thr);
+      const md = meanDiff(y, ind);
+      const mod = ols(y, [ind]);
+      thresholdTests.push({ feature: cf, q, threshold: thr, effect: md.effect, p: mod.pValues[1], nHigh: md.n1 });
+    }
+  }
+  thresholdTests.sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+
+  const selectedInteractions = interactionPairs.slice(0, 6);
+  const selectedSubgroups = subgroupTests.slice(0, 4);
+  const selectedThresholds = thresholdTests.slice(0, 6);
+
+  const iterations = [];
+  let hypCounter = 1;
+  function addIteration(hypTexts, analyses) {
+    const hyps = hypTexts.map((h) => ({
+      id: `h${hypCounter++}`,
+      text: h.text,
+      kind: h.kind || "novel",
+    }));
+    const remapped = analyses(hyps.map((h) => h.id));
+    iterations.push({
+      index: iterations.length + 1,
+      proposed_hypotheses: hyps,
+      analyses: remapped,
+    });
+  }
+
+  const topPositive = positive[0];
+  const topNegative = negative[0];
+  const secondPositive = positive.find((d) => d.feature !== topPositive.feature);
+  const secondNegative = negative.find((d) => d.feature !== topNegative.feature);
+
+  addIteration([
+    { text: `Patients with higher \`${topPositive.feature}\` have longer mean \`pfs_months\` than patients with lower \`${topPositive.feature}\`.` },
+    { text: `Patients with higher \`${topNegative.feature}\` have shorter mean \`pfs_months\` than patients with lower \`${topNegative.feature}\`.` },
+  ], ([h1, h2]) => [
+    analysisRecord([h1], `Simple linear regression estimated a +${round(topPositive.effect, 4)} month change in pfs_months per one-unit increase in ${topPositive.feature} (p=${formatP(topPositive.p)}).`, round(topPositive.effect, 6), topPositive.p, `OLS: pfs_months ~ ${topPositive.feature}`),
+    analysisRecord([h2], `Simple linear regression estimated a ${round(topNegative.effect, 4)} month change in pfs_months per one-unit increase in ${topNegative.feature} (p=${formatP(topNegative.p)}).`, round(topNegative.effect, 6), topNegative.p, `OLS: pfs_months ~ ${topNegative.feature}`),
+  ]);
+
+  addIteration([
+    { text: `Patients with \`${topBin}\` equal to 1 have longer mean \`pfs_months\` than patients with \`${topBin}\` equal to 0.` },
+    { text: `Patients with \`${secondBin}\` equal to 1 have a different mean \`pfs_months\` than patients with \`${secondBin}\` equal to 0.` },
+  ], ([h1, h2]) => {
+    const a = binaryMain.find((d) => d.feature === topBin);
+    const b = binaryMain.find((d) => d.feature === secondBin);
+    return [
+      analysisRecord([h1], `${topBin}=1 had mean pfs_months ${round(a.mean1, 3)} vs ${round(a.mean0, 3)} for ${topBin}=0; difference +${round(a.effect, 3)} months (p=${formatP(a.p)}).`, round(a.effect, 6), a.p, `Two-group OLS/t-test: pfs_months ~ ${topBin}`),
+      analysisRecord([h2], `${secondBin}=1 had mean pfs_months ${round(b.mean1, 3)} vs ${round(b.mean0, 3)} for ${secondBin}=0; difference ${round(b.effect, 3)} months (p=${formatP(b.p)}).`, round(b.effect, 6), b.p, `Two-group OLS/t-test: pfs_months ~ ${secondBin}`),
+    ];
+  });
+
+  addIteration([
+    { text: `A one-standard-deviation increase in \`${topContPos}\` is associated with longer \`pfs_months\`.` },
+    { text: `A one-standard-deviation increase in \`${topContNeg}\` is associated with shorter \`pfs_months\`.` },
+  ], ([h1, h2]) => {
+    const a = contMain.find((d) => d.feature === topContPos);
+    const b = contMain.find((d) => d.feature === topContNeg);
+    return [
+      analysisRecord([h1], `Standardized OLS estimated +${round(a.effect, 3)} months per SD increase in ${topContPos} (p=${formatP(a.p)}).`, round(a.effect, 6), a.p, `OLS: pfs_months ~ z(${topContPos})`),
+      analysisRecord([h2], `Standardized OLS estimated ${round(b.effect, 3)} months per SD increase in ${topContNeg} (p=${formatP(b.p)}).`, round(b.effect, 6), b.p, `OLS: pfs_months ~ z(${topContNeg})`),
+    ];
+  });
+
+  addIteration([
+    { text: `The positive association between \`${topPositive.feature}\` and \`pfs_months\` remains after adjustment for the strongest screened features.` },
+    { text: `The negative association between \`${topNegative.feature}\` and \`pfs_months\` remains after adjustment for the strongest screened features.` },
+  ], ([h1, h2]) => {
+    const a = adjusted[topPositive.feature];
+    const b = adjusted[topNegative.feature];
+    return [
+      analysisRecord([h1], `In a multivariable OLS model including ${keyFeatures.length} screened features, ${topPositive.feature} retained an adjusted effect of +${round(a.effect, 3)} months (p=${formatP(a.p)}).`, round(a.effect, 6), a.p, `OLS: pfs_months ~ ${keyFeatures.join(" + ")} (continuous features standardized)`),
+      analysisRecord([h2], `In the same multivariable model, ${topNegative.feature} retained an adjusted effect of ${round(b.effect, 3)} months (p=${formatP(b.p)}).`, round(b.effect, 6), b.p, `OLS: pfs_months ~ ${keyFeatures.join(" + ")} (continuous features standardized)`),
+    ];
+  });
+
+  addIteration([
+    { text: `Patients in the highest quartile of \`${topContPos}\` have longer mean \`pfs_months\` than the rest of the cohort.` },
+    { text: `Patients in the highest quartile of \`${topContNeg}\` have shorter mean \`pfs_months\` than the rest of the cohort.` },
+  ], ([h1, h2]) => [
+    analysisRecord([h1], `Highest-quartile ${topContPos} (>=${round(hlPos.q75, 3)}) had mean pfs_months ${round(hlPosMd.mean1, 3)} vs ${round(hlPosMd.mean0, 3)} otherwise; difference +${round(hlPosMd.effect, 3)} months (p=${formatP(hlPosModel.pValues[1])}).`, round(hlPosMd.effect, 6), hlPosModel.pValues[1], `OLS: pfs_months ~ I(${topContPos} >= Q75)`),
+    analysisRecord([h2], `Highest-quartile ${topContNeg} (>=${round(hlNeg.q75, 3)}) had mean pfs_months ${round(hlNegMd.mean1, 3)} vs ${round(hlNegMd.mean0, 3)} otherwise; difference ${round(hlNegMd.effect, 3)} months (p=${formatP(hlNegModel.pValues[1])}).`, round(hlNegMd.effect, 6), hlNegModel.pValues[1], `OLS: pfs_months ~ I(${topContNeg} >= Q75)`),
+  ]);
+
+  for (const item of strongestAdjusted.slice(0, 5)) {
+    const dir = item.effect >= 0 ? "longer" : "shorter";
+    addIteration([
+      { text: `After adjustment for other strong screened variables, higher \`${item.feature}\` is independently associated with ${dir} \`pfs_months\`.` , kind: "refined"},
+    ], ([h1]) => [
+      analysisRecord([h1], `Adjusted OLS coefficient for ${item.feature} was ${round(item.effect, 3)} months (SE ${round(item.se, 3)}, p=${formatP(item.p)}).`, round(item.effect, 6), item.p, `Adjusted OLS coefficient from pfs_months ~ ${keyFeatures.join(" + ")}`),
+    ]);
+  }
+
+  for (const inter of selectedInteractions) {
+    const direction = inter.effect >= 0 ? "positive" : "negative";
+    addIteration([
+      { text: `The association of \`${inter.a}\` with \`pfs_months\` is modified by \`${inter.b}\`, with a ${direction} interaction term.` },
+    ], ([h1]) => [
+      analysisRecord([h1], `Interaction model pfs_months ~ ${inter.a} + ${inter.b} + ${inter.a}:${inter.b} estimated an interaction effect of ${round(inter.effect, 3)} months (p=${formatP(inter.p)}).`, round(inter.effect, 6), inter.p, `OLS interaction: pfs_months ~ ${inter.a} + ${inter.b} + ${inter.a}:${inter.b}`),
+    ]);
+  }
+
+  for (const sg of selectedSubgroups) {
+    const direction = sg.effect >= 0 ? "stronger/more positive" : "weaker/more negative";
+    addIteration([
+      { text: `The standardized association between \`${sg.continuous}\` and \`pfs_months\` is ${direction} among patients with \`${sg.binary}\` equal to 1 than among patients with \`${sg.binary}\` equal to 0.` },
+    ], ([h1]) => [
+      analysisRecord([h1], `Binary-by-continuous interaction ${sg.binary}:z(${sg.continuous}) was ${round(sg.effect, 3)} months (p=${formatP(sg.p)}).`, round(sg.effect, 6), sg.p, `OLS: pfs_months ~ ${sg.binary} + z(${sg.continuous}) + ${sg.binary}:z(${sg.continuous})`),
+    ]);
+  }
+
+  for (const th of selectedThresholds) {
+    const direction = th.effect >= 0 ? "longer" : "shorter";
+    addIteration([
+      { text: `Patients with \`${th.feature}\` at or above its ${Math.round(th.q * 100)}th percentile have ${direction} mean \`pfs_months\` than patients below that threshold.` },
+    ], ([h1]) => [
+      analysisRecord([h1], `Threshold ${th.feature} >= ${round(th.threshold, 3)} (q=${th.q}) had a mean difference of ${round(th.effect, 3)} months (n=${th.nHigh}, p=${formatP(th.p)}).`, round(th.effect, 6), th.p, `OLS: pfs_months ~ I(${th.feature} >= ${round(th.threshold, 6)})`),
+    ]);
+  }
+
+  // Fill to the iteration cap with directed null/robustness probes from weaker screened effects.
+  const weak = simple.filter((d) => d.p > 0.05).sort((a, b) => Math.abs(a.effect) - Math.abs(b.effect));
+  let weakIdx = 0;
+  while (iterations.length < MAX_ITERATIONS) {
+    const w = weak[weakIdx++];
+    const dir = w.effect >= 0 ? "longer" : "shorter";
+    addIteration([
+      { text: `As a negative-control-style probe, higher \`${w.feature}\` is associated with ${dir} \`pfs_months\`.` },
+    ], ([h1]) => [
+      analysisRecord([h1], `Simple OLS for ${w.feature} estimated ${round(w.effect, 4)} months per unit (p=${formatP(w.p)}), providing no statistically significant support for this small effect.`, round(w.effect, 6), w.p, `OLS: pfs_months ~ ${w.feature}`),
+    ]);
+  }
+
+  const transcript = {
+    dataset_id: DATASET_ID,
+    model_id: MODEL_ID,
+    harness_id: HARNESS_ID,
+    max_iterations: MAX_ITERATIONS,
+    iterations,
+    dataset_shape: { rows: meta.num_rows, columns: Object.keys(columns).length },
+    analysis_notes: "P-values use large-sample normal approximations to OLS t-statistics; continuous features were standardized where explicitly stated. Patient_id was excluded from analyses.",
+  };
+
+  const summaryLines = [];
+  summaryLines.push(`Dataset ${DATASET_ID}: ${meta.num_rows} patients, ${allFeatures.length} anonymized features, outcome pfs_months.`);
+  summaryLines.push(`The analysis excluded patient_id, screened main effects for all features, then refined the largest findings with multivariable adjustment, quartile threshold tests, and interaction/subgroup models. P-values are large-sample OLS normal approximations.`);
+  summaryLines.push("");
+  summaryLines.push("Main-effect findings:");
+  summaryLines.push(`- The strongest positive simple association was ${topPositive.feature}: +${round(topPositive.effect, 3)} months per one-unit increase (p=${formatP(topPositive.p)}).`);
+  summaryLines.push(`- The strongest negative simple association was ${topNegative.feature}: ${round(topNegative.effect, 3)} months per one-unit increase (p=${formatP(topNegative.p)}).`);
+  summaryLines.push(`- Among binary features, ${topBin}=1 differed by ${round(binaryMain.find((d) => d.feature === topBin).effect, 3)} months versus ${topBin}=0 (p=${formatP(binaryMain.find((d) => d.feature === topBin).p)}).`);
+  summaryLines.push(`- Standardized continuous-feature contrasts supported ${topContPos} as favorable (+${round(contMain.find((d) => d.feature === topContPos).effect, 3)} months per SD, p=${formatP(contMain.find((d) => d.feature === topContPos).p)}) and ${topContNeg} as unfavorable (${round(contMain.find((d) => d.feature === topContNeg).effect, 3)} months per SD, p=${formatP(contMain.find((d) => d.feature === topContNeg).p)}).`);
+  summaryLines.push("");
+  summaryLines.push("Adjusted findings:");
+  for (const item of strongestAdjusted.slice(0, 8)) {
+    summaryLines.push(`- ${item.feature}: adjusted effect ${round(item.effect, 3)} months, p=${formatP(item.p)}.`);
+  }
+  summaryLines.push("");
+  summaryLines.push("Threshold findings:");
+  summaryLines.push(`- Highest-quartile ${topContPos} had +${round(hlPosMd.effect, 3)} months versus lower values (p=${formatP(hlPosModel.pValues[1])}).`);
+  summaryLines.push(`- Highest-quartile ${topContNeg} had ${round(hlNegMd.effect, 3)} months versus lower values (p=${formatP(hlNegModel.pValues[1])}).`);
+  for (const th of selectedThresholds.slice(0, 4)) {
+    summaryLines.push(`- ${th.feature} >= ${round(th.threshold, 3)} showed ${round(th.effect, 3)} months difference (p=${formatP(th.p)}).`);
+  }
+  summaryLines.push("");
+  summaryLines.push("Interaction and subgroup findings:");
+  for (const inter of selectedInteractions.slice(0, 6)) {
+    summaryLines.push(`- ${inter.a}:${inter.b} interaction effect ${round(inter.effect, 3)} months, p=${formatP(inter.p)}.`);
+  }
+  for (const sg of selectedSubgroups.slice(0, 4)) {
+    summaryLines.push(`- ${sg.binary}:z(${sg.continuous}) subgroup interaction effect ${round(sg.effect, 3)} months, p=${formatP(sg.p)}.`);
+  }
+  summaryLines.push("");
+  summaryLines.push("Null/weak probes:");
+  const weakMention = iterations.slice(-Math.min(5, iterations.length)).flatMap((it) => it.analyses).map((a) => a.result_summary);
+  for (const line of weakMention) summaryLines.push(`- ${line}`);
+  summaryLines.push("");
+  summaryLines.push("Overall conclusion:");
+  summaryLines.push("The cohort contains several strong feature-outcome associations with pfs_months despite anonymized predictors. The most reproducible signals were the top screened main effects that remained significant in adjusted OLS models. Several interaction terms were statistically significant, suggesting heterogeneity in feature effects across subgroups; however, because feature labels are opaque, these should be treated as pattern-discovery results rather than mechanistic clinical claims. Weak probes with small coefficients and p-values above 0.05 were not supported.");
+
+  fs.writeFileSync("transcript.json", `${JSON.stringify(transcript, null, 2)}\n`);
+  fs.writeFileSync("analysis_summary.txt", `${summaryLines.join("\n")}\n`);
+  console.log(`Wrote transcript.json with ${iterations.length} iterations and analysis_summary.txt.`);
+  console.log(`Top simple effects: ${byP.slice(0, 8).map((d) => `${d.feature}:${round(d.effect, 3)} p=${formatP(d.p)}`).join("; ")}`);
+  console.log(`Features: ${binary.length} binary, ${continuous.length} non-binary.`);
+}
+
+main();

