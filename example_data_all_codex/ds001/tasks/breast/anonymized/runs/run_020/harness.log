+  if (!Number.isFinite(az)) return 0;
+  if (az > 37) return 0;
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(az))));
+}
+
+function matInv(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    }
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const div = aug[col][col];
+    for (let c = 0; c < 2 * n; c++) aug[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) aug[r][c] -= f * aug[col][c];
+    }
+  }
+  return aug.map((row) => row.slice(n));
