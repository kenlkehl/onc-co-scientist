+
+function ols(y, xs) {
+  const n = y.length;
+  const p = xs.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const x of xs) row.push(x[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = matInv(xtx);
+  const beta = Array(p).fill(0);
+  for (let a = 0; a < p; a++) for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    let fitted = beta[0];
+    for (let j = 0; j < xs.length; j++) fitted += beta[j + 1] * xs[j][i];
+    const e = y[i] - fitted;
+    sse += e * e;
+  }
+  const sigma2 = sse / (n - p);
+  const se = beta.map((_, i) => Math.sqrt(Math.max(0, sigma2 * inv[i][i])));
+  const t = beta.map((b, i) => b / se[i]);
+  const pValues = t.map(twoSidedPFromZ);
+  return { beta, se, t, pValues, sse, df: n - p };
