+    4: ["codec", enumVal],
+    5: ["num_values", intVal],
+    6: ["total_uncompressed_size", intVal],
+    7: ["total_compressed_size", intVal],
+    8: ["key_value_metadata", listOf(keyValue)],
+    9: ["data_page_offset", intVal],
+    10: ["index_page_offset", intVal],
+    11: ["dictionary_page_offset", intVal],
+    12: ["statistics", statistics],
+  });
