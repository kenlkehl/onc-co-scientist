+const fs = require("fs");
+
+const DATASET_ID = "ds001_breast";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-cli-local-parquet-js@1.0";
+const MAX_ITERATIONS = 25;
+
+const TType = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+  FLOAT: 13,
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let x = 0n;
+    let shift = 0n;
+    while (true) {
+      const b = this.byte();
+      x |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return x;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  bin() {
+    const len = Number(this.varint());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  str() {
+    return this.bin().toString("utf8");
+  }
+
+  dbl() {
+    const out = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return out;
+  }
+
+  flt() {
+    const out = this.buf.readFloatLE(this.pos);
+    this.pos += 4;
+    return out;
+  }
+}
+
+function readListHeader(r) {
+  const b = r.byte();
+  let size = b >> 4;
+  const et = b & 0x0f;
+  if (size === 15) size = Number(r.varint());
+  return { size, et };
+}
+
