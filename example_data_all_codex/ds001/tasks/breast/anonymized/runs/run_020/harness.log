+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let x = 0n;
+    let shift = 0n;
+    while (true) {
+      const b = this.byte();
+      x |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return x;
+  }
