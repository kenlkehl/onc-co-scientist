+    2: ["file_offset", intVal],
+    3: ["meta_data", columnMetaData],
+    4: ["offset_index_offset", intVal],
+    5: ["offset_index_length", intVal],
+    6: ["column_index_offset", intVal],
+    7: ["column_index_length", intVal],
+  });
