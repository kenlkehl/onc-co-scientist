+  summaryLines.push(`- Highest-quartile ${topContNeg} had ${round(hlNegMd.effect, 3)} months versus lower values (p=${formatP(hlNegModel.pValues[1])}).`);
+  for (const th of selectedThresholds.slice(0, 4)) {
+    summaryLines.push(`- ${th.feature} >= ${round(th.threshold, 3)} showed ${round(th.effect, 3)} months difference (p=${formatP(th.p)}).`);
+  }
+  summaryLines.push("");
+  summaryLines.push("Interaction and subgroup findings:");
+  for (const inter of selectedInteractions.slice(0, 6)) {
