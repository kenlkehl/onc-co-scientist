+const fs = require("fs");
+
+const DATASET_ID = "ds001_breast";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-cli-local-parquet-js@1.0";
+const MAX_ITERATIONS = 25;
+
+const TType = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+  FLOAT: 13,
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let x = 0n;
+    let shift = 0n;
+    while (true) {
+      const b = this.byte();
+      x |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return x;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  bin() {
+    const len = Number(this.varint());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  str() {
+    return this.bin().toString("utf8");
+  }
+
+  dbl() {
+    const out = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return out;
+  }
+
+  flt() {
+    const out = this.buf.readFloatLE(this.pos);
+    this.pos += 4;
+    return out;
+  }
+}
+
+function readListHeader(r) {
+  const b = r.byte();
+  let size = b >> 4;
+  const et = b & 0x0f;
+  if (size === 15) size = Number(r.varint());
+  return { size, et };
+}
+
+function skipValue(r, type) {
+  switch (type) {
+    case TType.TRUE:
+    case TType.FALSE:
+      return;
+    case TType.BYTE:
+      r.byte();
+      return;
+    case TType.I16:
+    case TType.I32:
+      r.i32();
+      return;
+    case TType.I64:
+      r.i64();
+      return;
+    case TType.DOUBLE:
+      r.dbl();
+      return;
+    case TType.FLOAT:
+      r.flt();
+      return;
+    case TType.BINARY:
+      r.bin();
+      return;
+    case TType.STRUCT:
+      readStruct(r, {});
+      return;
+    case TType.LIST:
+    case TType.SET: {
+      const { size, et } = readListHeader(r);
+      for (let i = 0; i < size; i++) skipValue(r, et);
+      return;
+    }
+    case TType.MAP: {
+      const size = Number(r.varint());
+      if (size === 0) return;
+      const kt = r.byte();
+      const vt = r.byte();
+      for (let i = 0; i < size; i++) {
+        skipValue(r, kt);
+        skipValue(r, vt);
+      }
+      return;
+    }
+    default:
+      throw new Error(`Unsupported compact thrift type ${type} at byte ${r.pos}`);
+  }
+}
+
+function readStruct(r, handlers) {
+  let fid = 0;
+  const out = {};
+  while (true) {
+    const h = r.byte();
+    const type = h & 0x0f;
+    if (type === TType.STOP) break;
+    const delta = h >> 4;
+    fid = delta ? fid + delta : r.i32();
+    const handler = handlers[fid];
+    if (handler) out[handler[0]] = handler[1](r, type);
+    else skipValue(r, type);
+  }
+  return out;
+}
+
+const enumVal = (r) => r.i32();
+const intVal = (r, type) => (type === TType.I64 ? r.i64() : r.i32());
+const strVal = (r) => r.str();
+const binVal = (r) => r.bin();
+function listOf(parse) {
+  return (r) => {
+    const { size, et } = readListHeader(r);
+    const out = [];
+    for (let i = 0; i < size; i++) out.push(parse(r, et));
+    return out;
+  };
+}
+
+function schemaElement(r) {
+  return readStruct(r, {
+    1: ["type", enumVal],
+    2: ["type_length", intVal],
+    3: ["repetition_type", enumVal],
+    4: ["name", strVal],
+    5: ["num_children", intVal],
+    6: ["converted_type", enumVal],
+    7: ["scale", intVal],
+    8: ["precision", intVal],
+    9: ["field_id", intVal],
+  });
+}
+
+function keyValue(r) {
+  return readStruct(r, {
+    1: ["key", strVal],
+    2: ["value", strVal],
+  });
+}
+
+function statistics(r) {
+  return readStruct(r, {
+    1: ["max", binVal],
+    2: ["min", binVal],
+    3: ["null_count", intVal],
+    4: ["distinct_count", intVal],
+    5: ["max_value", binVal],
+    6: ["min_value", binVal],
