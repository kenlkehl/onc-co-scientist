+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    }
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const div = aug[col][col];
+    for (let c = 0; c < 2 * n; c++) aug[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) aug[r][c] -= f * aug[col][c];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function ols(y, xs) {
+  const n = y.length;
+  const p = xs.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const x of xs) row.push(x[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = matInv(xtx);
+  const beta = Array(p).fill(0);
+  for (let a = 0; a < p; a++) for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    let fitted = beta[0];
+    for (let j = 0; j < xs.length; j++) fitted += beta[j + 1] * xs[j][i];
+    const e = y[i] - fitted;
+    sse += e * e;
+  }
+  const sigma2 = sse / (n - p);
+  const se = beta.map((_, i) => Math.sqrt(Math.max(0, sigma2 * inv[i][i])));
+  const t = beta.map((b, i) => b / se[i]);
+  const pValues = t.map(twoSidedPFromZ);
+  return { beta, se, t, pValues, sse, df: n - p };
+}
+
+function standardize(arr) {
+  const mu = mean(arr);
+  const sd = Math.sqrt(variance(arr, mu));
+  return arr.map((v) => (v - mu) / sd);
+}
+
+function uniqueCount(arr) {
+  return new Set(arr).size;
+}
+
+function meanDiff(y, x, value = 1) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === value) {
+      n1++;
+      s1 += y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+    }
+  }
+  return { effect: s1 / n1 - s0 / n0, mean1: s1 / n1, mean0: s0 / n0, n1, n0 };
+}
+
+function quantile(arr, q) {
+  const s = arr.slice().sort((a, b) => a - b);
+  const pos = (s.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return s[lo];
+  return s[lo] + (s[hi] - s[lo]) * (pos - lo);
+}
+
+function binaryVector(arr, predicate) {
+  return arr.map((v) => (predicate(v) ? 1 : 0));
+}
+
+function corr(a, b) {
+  const ma = mean(a);
+  const mb = mean(b);
+  let num = 0;
+  let da = 0;
+  let db = 0;
+  for (let i = 0; i < a.length; i++) {
+    const xa = a[i] - ma;
+    const xb = b[i] - mb;
+    num += xa * xb;
+    da += xa * xa;
+    db += xb * xb;
+  }
+  return num / Math.sqrt(da * db);
+}
+
+function formatP(p) {
+  if (p === 0) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function round(x, digits = 4) {
+  if (!Number.isFinite(x)) return x;
+  const f = Math.pow(10, digits);
+  return Math.round(x * f) / f;
+}
+
+function analysisRecord(hypothesisIds, resultSummary, effectEstimate, pValue, code) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: resultSummary,
+    p_value: pValue,
+    effect_estimate: effectEstimate,
+    significant: pValue < 0.05,
+  };
+}
+
+function main() {
+  const { meta, columns } = readParquet("dataset.parquet");
+  const y = columns.pfs_months.map(Number);
+  const allFeatures = Object.keys(columns).filter((c) => c !== "patient_id" && c !== "pfs_months");
+  const summaries = {};
+  for (const f of allFeatures) {
+    const arr = columns[f].map(Number);
+    const uc = uniqueCount(arr);
+    summaries[f] = {
+      unique: uc,
+      mean: mean(arr),
+      sd: Math.sqrt(variance(arr)),
+      min: Math.min(...arr),
+      max: Math.max(...arr),
+      isBinary: uc === 2 && Math.min(...arr) === 0 && Math.max(...arr) === 1,
+      values: arr,
+    };
+  }
+  const binary = allFeatures.filter((f) => summaries[f].isBinary);
+  const continuous = allFeatures.filter((f) => !summaries[f].isBinary);
+
+  const simple = [];
+  for (const f of allFeatures) {
+    const x = summaries[f].values;
+    const model = ols(y, [x]);
+    const effect = model.beta[1];
+    simple.push({ feature: f, effect, p: model.pValues[1], unique: summaries[f].unique, r: corr(x, y) });
+  }
+  simple.sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+  const byP = simple.slice().sort((a, b) => a.p - b.p);
+  const positive = simple.filter((d) => d.effect > 0).sort((a, b) => a.p - b.p);
+  const negative = simple.filter((d) => d.effect < 0).sort((a, b) => a.p - b.p);
+
+  const contZ = {};
+  for (const f of continuous) contZ[f] = standardize(summaries[f].values);
+  const binVals = {};
+  for (const f of binary) binVals[f] = summaries[f].values;
+
+  const keyFeatures = Array.from(new Set([
+    ...positive.slice(0, 8).map((d) => d.feature),
+    ...negative.slice(0, 8).map((d) => d.feature),
+    ...byP.slice(0, 12).map((d) => d.feature),
+  ]));
+  const multiXs = keyFeatures.map((f) => summaries[f].isBinary ? summaries[f].values : contZ[f]);
+  const multi = ols(y, multiXs);
+  const adjusted = {};
+  keyFeatures.forEach((f, i) => {
+    adjusted[f] = { effect: multi.beta[i + 1], p: multi.pValues[i + 1], se: multi.se[i + 1] };
+  });
+
+  const binaryMain = binary.map((f) => {
+    const md = meanDiff(y, summaries[f].values);
+    const model = ols(y, [summaries[f].values]);
+    return { feature: f, ...md, p: model.pValues[1] };
+  }).sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+
+  const contMain = continuous.map((f) => {
+    const model = ols(y, [contZ[f]]);
+    return { feature: f, effect: model.beta[1], p: model.pValues[1] };
+  }).sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+
+  const topBin = binaryMain[0].feature;
+  const secondBin = binaryMain.find((d) => d.feature !== topBin).feature;
+  const topContPos = contMain.filter((d) => d.effect > 0)[0].feature;
+  const topContNeg = contMain.filter((d) => d.effect < 0)[0].feature;
+  const strongestAdjusted = Object.entries(adjusted).sort((a, b) => a[1].p - b[1].p).map(([feature, stats]) => ({ feature, ...stats }));
+
+  const interactionPairs = [];
+  const interCandidates = Array.from(new Set([...keyFeatures, ...binaryMain.slice(0, 8).map((d) => d.feature), ...contMain.slice(0, 8).map((d) => d.feature)]));
+  for (let i = 0; i < interCandidates.length; i++) {
+    for (let j = i + 1; j < interCandidates.length; j++) {
+      const a = interCandidates[i];
+      const b = interCandidates[j];
+      const xa = summaries[a].isBinary ? summaries[a].values : contZ[a];
+      const xb = summaries[b].isBinary ? summaries[b].values : contZ[b];
+      const xab = xa.map((v, idx) => v * xb[idx]);
+      const mod = ols(y, [xa, xb, xab]);
+      interactionPairs.push({ a, b, effect: mod.beta[3], p: mod.pValues[3] });
+    }
+  }
+  interactionPairs.sort((a, b) => a.p - b.p);
+
+  function highLow(feature) {
+    const vals = summaries[feature].values;
+    const q75 = quantile(vals, 0.75);
+    const q25 = quantile(vals, 0.25);
+    return {
+      high: binaryVector(vals, (v) => v >= q75),
+      low: binaryVector(vals, (v) => v <= q25),
+      q75,
+      q25,
+    };
+  }
+
+  const hlPos = highLow(topContPos);
+  const hlNeg = highLow(topContNeg);
+  const hlPosMd = meanDiff(y, hlPos.high);
+  const hlNegMd = meanDiff(y, hlNeg.high);
+  const hlPosModel = ols(y, [hlPos.high]);
+  const hlNegModel = ols(y, [hlNeg.high]);
+
+  const subgroupTests = [];
+  for (const bf of binaryMain.slice(0, 10).map((d) => d.feature)) {
+    for (const cf of contMain.slice(0, 10).map((d) => d.feature)) {
+      const b = summaries[bf].values;
+      const z = contZ[cf];
+      const bz = b.map((v, i) => v * z[i]);
