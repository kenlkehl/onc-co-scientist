+  const selectedInteractions = interactionPairs.slice(0, 6);
+  const selectedSubgroups = subgroupTests.slice(0, 4);
+  const selectedThresholds = thresholdTests.slice(0, 6);
+
+  const iterations = [];
+  let hypCounter = 1;
+  function addIteration(hypTexts, analyses) {
+    const hyps = hypTexts.map((h) => ({
+      id: `h${hypCounter++}`,
+      text: h.text,
+      kind: h.kind || "novel",
+    }));
+    const remapped = analyses(hyps.map((h) => h.id));
+    iterations.push({
+      index: iterations.length + 1,
+      proposed_hypotheses: hyps,
+      analyses: remapped,
+    });
+  }
+
+  const topPositive = positive[0];
+  const topNegative = negative[0];
+  const secondPositive = positive.find((d) => d.feature !== topPositive.feature);
+  const secondNegative = negative.find((d) => d.feature !== topNegative.feature);
+
+  addIteration([
+    { text: `Patients with higher \`${topPositive.feature}\` have longer mean \`pfs_months\` than patients with lower \`${topPositive.feature}\`.` },
+    { text: `Patients with higher \`${topNegative.feature}\` have shorter mean \`pfs_months\` than patients with lower \`${topNegative.feature}\`.` },
+  ], ([h1, h2]) => [
+    analysisRecord([h1], `Simple linear regression estimated a +${round(topPositive.effect, 4)} month change in pfs_months per one-unit increase in ${topPositive.feature} (p=${formatP(topPositive.p)}).`, round(topPositive.effect, 6), topPositive.p, `OLS: pfs_months ~ ${topPositive.feature}`),
+    analysisRecord([h2], `Simple linear regression estimated a ${round(topNegative.effect, 4)} month change in pfs_months per one-unit increase in ${topNegative.feature} (p=${formatP(topNegative.p)}).`, round(topNegative.effect, 6), topNegative.p, `OLS: pfs_months ~ ${topNegative.feature}`),
+  ]);
+
+  addIteration([
+    { text: `Patients with \`${topBin}\` equal to 1 have longer mean \`pfs_months\` than patients with \`${topBin}\` equal to 0.` },
+    { text: `Patients with \`${secondBin}\` equal to 1 have a different mean \`pfs_months\` than patients with \`${secondBin}\` equal to 0.` },
+  ], ([h1, h2]) => {
+    const a = binaryMain.find((d) => d.feature === topBin);
+    const b = binaryMain.find((d) => d.feature === secondBin);
+    return [
+      analysisRecord([h1], `${topBin}=1 had mean pfs_months ${round(a.mean1, 3)} vs ${round(a.mean0, 3)} for ${topBin}=0; difference +${round(a.effect, 3)} months (p=${formatP(a.p)}).`, round(a.effect, 6), a.p, `Two-group OLS/t-test: pfs_months ~ ${topBin}`),
+      analysisRecord([h2], `${secondBin}=1 had mean pfs_months ${round(b.mean1, 3)} vs ${round(b.mean0, 3)} for ${secondBin}=0; difference ${round(b.effect, 3)} months (p=${formatP(b.p)}).`, round(b.effect, 6), b.p, `Two-group OLS/t-test: pfs_months ~ ${secondBin}`),
+    ];
+  });
+
+  addIteration([
+    { text: `A one-standard-deviation increase in \`${topContPos}\` is associated with longer \`pfs_months\`.` },
+    { text: `A one-standard-deviation increase in \`${topContNeg}\` is associated with shorter \`pfs_months\`.` },
+  ], ([h1, h2]) => {
+    const a = contMain.find((d) => d.feature === topContPos);
+    const b = contMain.find((d) => d.feature === topContNeg);
+    return [
+      analysisRecord([h1], `Standardized OLS estimated +${round(a.effect, 3)} months per SD increase in ${topContPos} (p=${formatP(a.p)}).`, round(a.effect, 6), a.p, `OLS: pfs_months ~ z(${topContPos})`),
+      analysisRecord([h2], `Standardized OLS estimated ${round(b.effect, 3)} months per SD increase in ${topContNeg} (p=${formatP(b.p)}).`, round(b.effect, 6), b.p, `OLS: pfs_months ~ z(${topContNeg})`),
+    ];
+  });
+
+  addIteration([
+    { text: `The positive association between \`${topPositive.feature}\` and \`pfs_months\` remains after adjustment for the strongest screened features.` },
+    { text: `The negative association between \`${topNegative.feature}\` and \`pfs_months\` remains after adjustment for the strongest screened features.` },
+  ], ([h1, h2]) => {
+    const a = adjusted[topPositive.feature];
+    const b = adjusted[topNegative.feature];
+    return [
+      analysisRecord([h1], `In a multivariable OLS model including ${keyFeatures.length} screened features, ${topPositive.feature} retained an adjusted effect of +${round(a.effect, 3)} months (p=${formatP(a.p)}).`, round(a.effect, 6), a.p, `OLS: pfs_months ~ ${keyFeatures.join(" + ")} (continuous features standardized)`),
+      analysisRecord([h2], `In the same multivariable model, ${topNegative.feature} retained an adjusted effect of ${round(b.effect, 3)} months (p=${formatP(b.p)}).`, round(b.effect, 6), b.p, `OLS: pfs_months ~ ${keyFeatures.join(" + ")} (continuous features standardized)`),
+    ];
+  });
+
+  addIteration([
+    { text: `Patients in the highest quartile of \`${topContPos}\` have longer mean \`pfs_months\` than the rest of the cohort.` },
+    { text: `Patients in the highest quartile of \`${topContNeg}\` have shorter mean \`pfs_months\` than the rest of the cohort.` },
+  ], ([h1, h2]) => [
+    analysisRecord([h1], `Highest-quartile ${topContPos} (>=${round(hlPos.q75, 3)}) had mean pfs_months ${round(hlPosMd.mean1, 3)} vs ${round(hlPosMd.mean0, 3)} otherwise; difference +${round(hlPosMd.effect, 3)} months (p=${formatP(hlPosModel.pValues[1])}).`, round(hlPosMd.effect, 6), hlPosModel.pValues[1], `OLS: pfs_months ~ I(${topContPos} >= Q75)`),
+    analysisRecord([h2], `Highest-quartile ${topContNeg} (>=${round(hlNeg.q75, 3)}) had mean pfs_months ${round(hlNegMd.mean1, 3)} vs ${round(hlNegMd.mean0, 3)} otherwise; difference ${round(hlNegMd.effect, 3)} months (p=${formatP(hlNegModel.pValues[1])}).`, round(hlNegMd.effect, 6), hlNegModel.pValues[1], `OLS: pfs_months ~ I(${topContNeg} >= Q75)`),
+  ]);
+
+  for (const item of strongestAdjusted.slice(0, 5)) {
+    const dir = item.effect >= 0 ? "longer" : "shorter";
+    addIteration([
+      { text: `After adjustment for other strong screened variables, higher \`${item.feature}\` is independently associated with ${dir} \`pfs_months\`.` , kind: "refined"},
+    ], ([h1]) => [
+      analysisRecord([h1], `Adjusted OLS coefficient for ${item.feature} was ${round(item.effect, 3)} months (SE ${round(item.se, 3)}, p=${formatP(item.p)}).`, round(item.effect, 6), item.p, `Adjusted OLS coefficient from pfs_months ~ ${keyFeatures.join(" + ")}`),
+    ]);
+  }
+
+  for (const inter of selectedInteractions) {
+    const direction = inter.effect >= 0 ? "positive" : "negative";
+    addIteration([
+      { text: `The association of \`${inter.a}\` with \`pfs_months\` is modified by \`${inter.b}\`, with a ${direction} interaction term.` },
+    ], ([h1]) => [
+      analysisRecord([h1], `Interaction model pfs_months ~ ${inter.a} + ${inter.b} + ${inter.a}:${inter.b} estimated an interaction effect of ${round(inter.effect, 3)} months (p=${formatP(inter.p)}).`, round(inter.effect, 6), inter.p, `OLS interaction: pfs_months ~ ${inter.a} + ${inter.b} + ${inter.a}:${inter.b}`),
+    ]);
+  }
+
+  for (const sg of selectedSubgroups) {
+    const direction = sg.effect >= 0 ? "stronger/more positive" : "weaker/more negative";
+    addIteration([
+      { text: `The standardized association between \`${sg.continuous}\` and \`pfs_months\` is ${direction} among patients with \`${sg.binary}\` equal to 1 than among patients with \`${sg.binary}\` equal to 0.` },
+    ], ([h1]) => [
+      analysisRecord([h1], `Binary-by-continuous interaction ${sg.binary}:z(${sg.continuous}) was ${round(sg.effect, 3)} months (p=${formatP(sg.p)}).`, round(sg.effect, 6), sg.p, `OLS: pfs_months ~ ${sg.binary} + z(${sg.continuous}) + ${sg.binary}:z(${sg.continuous})`),
+    ]);
+  }
+
+  for (const th of selectedThresholds) {
+    const direction = th.effect >= 0 ? "longer" : "shorter";
+    addIteration([
+      { text: `Patients with \`${th.feature}\` at or above its ${Math.round(th.q * 100)}th percentile have ${direction} mean \`pfs_months\` than patients below that threshold.` },
+    ], ([h1]) => [
+      analysisRecord([h1], `Threshold ${th.feature} >= ${round(th.threshold, 3)} (q=${th.q}) had a mean difference of ${round(th.effect, 3)} months (n=${th.nHigh}, p=${formatP(th.p)}).`, round(th.effect, 6), th.p, `OLS: pfs_months ~ I(${th.feature} >= ${round(th.threshold, 6)})`),
+    ]);
+  }
+
+  // Fill to the iteration cap with directed null/robustness probes from weaker screened effects.
+  const weak = simple.filter((d) => d.p > 0.05).sort((a, b) => Math.abs(a.effect) - Math.abs(b.effect));
+  let weakIdx = 0;
+  while (iterations.length < MAX_ITERATIONS) {
+    const w = weak[weakIdx++];
+    const dir = w.effect >= 0 ? "longer" : "shorter";
+    addIteration([
+      { text: `As a negative-control-style probe, higher \`${w.feature}\` is associated with ${dir} \`pfs_months\`.` },
+    ], ([h1]) => [
+      analysisRecord([h1], `Simple OLS for ${w.feature} estimated ${round(w.effect, 4)} months per unit (p=${formatP(w.p)}), providing no statistically significant support for this small effect.`, round(w.effect, 6), w.p, `OLS: pfs_months ~ ${w.feature}`),
+    ]);
+  }
+
