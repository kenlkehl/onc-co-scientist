import pandas as pd
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', ','.join(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome summary')
print(df['pfs_months'].describe().to_string())
print('missing total', int(df.isna().sum().sum()))
# summarize unique counts and basic stats for first pass
rows=[]
for c in df.columns:
    if c=='pfs_months': continue
    s=df[c]
    rows.append((c, str(s.dtype), int(s.nunique()), float(s.mean()), float(s.std()), float(s.min()), float(s.max())))
print('feature summaries: col,dtype,nunique,mean,std,min,max')
for r in rows:
    print('\\t'.join(map(str,r)))
