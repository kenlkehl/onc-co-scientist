import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('\\noutcome summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
features=[c for c in df.columns if c"'!='"'pfs_months']
summary=[]
for c in features:
    s=df[c]
    vc=s.nunique()
    vals=s.drop_duplicates().sort_values().head(10).tolist() if vc<=10 else []
    summary.append((c,str(s.dtype),vc,float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None,float(s.std()) if pd.api.types.is_numeric_dtype(s) else None,vals))
print('\\nfeature summary')
for row in summary:
    print(row)
