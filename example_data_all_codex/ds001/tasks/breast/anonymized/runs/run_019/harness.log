+  return {
+    summaries,
+    univariate,
+    multivar,
+    groups,
+    interactions,
+    strata,
+    topInteractionStrata,
+    quadratic,
+    levels,
+    focused,
+    q25,
+    q75,
+    yMean: mean(y),
+    ySd: Math.sqrt(variance(y)),
+    rowCount,
+  };
