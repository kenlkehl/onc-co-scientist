+  );
+  if (results.topInteractionStrata.a) {
+    const ts = results.topInteractionStrata;
+    lines.push(
+      `Stratified checks confirmed that pattern: within ${ts.b}=0, ${ts.a}=1 vs 0 differed by ${fmt(
+        ts.a_in_b0.effect
+      )} months, while within ${ts.b}=1 the difference was ${fmt(ts.a_in_b1.effect)} months.`
+    );
+  }
+  lines.push("");
+  lines.push("Refinements");
+  lines.push(
+    `Feature_027 showed a dose-like adverse pattern: feature_027=2 vs 0 differed by ${fmt(
+      results.levels.f027_2_vs_0.effect
+    )} months and feature_027=1 vs 0 differed by ${fmt(results.levels.f027_1_vs_0.effect)} months, both with p=${pText(
+      results.levels.f027_2_vs_0.p
+    )} or smaller.`
+  );
+  lines.push(
+    `Feature_044 also had statistically significant curvature after centering (quadratic coefficient ${fmt(
+      results.quadratic.effect,
+      5
+    )}, p=${pText(results.quadratic.p)}), but the linear positive gradient remained the dominant feature_044 pattern on the pfs_months scale.`
+  );
+  lines.push("");
+  lines.push(
+    "Overall, this dataset shows large treatment/biomarker-like heterogeneity despite opaque feature labels: higher feature_044 and feature_046 were associated with longer pfs_months, higher feature_027, feature_039, feature_015, and feature_031 were associated with shorter pfs_months, and several interaction terms suggest subgroup-specific outcome differences rather than only additive main effects."
+  );
+  return lines.join("\n");
+}
