+  const rowCount = meta[3];
+  const rowGroup = meta[4][0];
+  const chunks = rowGroup[1];
+  const columns = {};
+  const featureNames = [];
+  for (const chunk of chunks) {
+    const name = chunk[3][3][0];
+    if (name === "patient_id") continue;
+    columns[name] = readColumn(file, chunk, rowCount);
+    if (name !== "pfs_months") featureNames.push(name);
