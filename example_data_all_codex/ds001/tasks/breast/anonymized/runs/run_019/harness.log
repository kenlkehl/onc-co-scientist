+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n++;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
