+  const hyps25 = [];
+  const analyses25 = [];
+  for (const name of nextAdjusted) {
+    const id = hid();
+    const effect = results.multivar.coef[name];
+    const p = results.multivar.p[name];
+    hyps25.push(
+      hypothesis(
