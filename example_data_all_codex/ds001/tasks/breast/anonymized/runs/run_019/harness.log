+function mean(arr, idx = null) {
+  let s = 0;
+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n++;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, m = null) {
+  const mu = m === null ? mean(arr) : m;
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - mu;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
