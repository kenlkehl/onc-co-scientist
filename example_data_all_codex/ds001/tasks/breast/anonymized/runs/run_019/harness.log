+      const def = readHybridValues(decoded, p, numValues, 1, p + defLen);
+      p += defLen;
+      const nonNullCount = def.values.reduce((s, v) => s + (v === 1 ? 1 : 0), 0);
+      if (page[2] === 8 && dictionary) {
+        const bitWidth = decoded[p++];
+        const decodedIdx = readHybridValues(decoded, p, nonNullCount, bitWidth);
+        let valuePos = 0;
+        for (const d of def.values) {
+          if (d === 1) values[outIndex++] = dictionary[decodedIdx.values[valuePos++]];
+          else values[outIndex++] = NaN;
+        }
+      } else if (page[2] === 0) {
+        const plain = decodePlainValues(decoded.slice(p), type, nonNullCount);
+        let valuePos = 0;
+        for (const d of def.values) {
+          if (d === 1) values[outIndex++] = plain[valuePos++];
+          else values[outIndex++] = NaN;
+        }
+      } else {
+        throw new Error(`Unsupported data page encoding ${page[2]}`);
+      }
+    } else if (header[1] === 3) {
+      const page = header[8];
+      const numValues = page[1];
+      const numNulls = page[2];
+      const repLen = page[5] || 0;
+      const defLen = page[6] || 0;
+      let p = repLen + defLen;
+      const nonNullCount = numValues - numNulls;
+      if (page[4] === 8 && dictionary) {
+        const bitWidth = decoded[p++];
+        const decodedIdx = readHybridValues(decoded, p, nonNullCount, bitWidth);
+        for (let i = 0; i < nonNullCount; i++) values[outIndex++] = dictionary[decodedIdx.values[i]];
+      } else {
+        throw new Error(`Unsupported data page v2 encoding ${page[4]}`);
+      }
+    } else if (header[1] === 2) {
+      continue;
+    } else {
+      throw new Error(`Unsupported page type ${header[1]}`);
+    }
+  }
+  return values;
+}
+
+function loadDataset() {
+  const file = fs.readFileSync(FILE);
+  if (file.slice(0, 4).toString("ascii") !== "PAR1") throw new Error("Not a Parquet file");
+  const meta = readFileMeta(file);
+  const rowCount = meta[3];
+  const rowGroup = meta[4][0];
+  const chunks = rowGroup[1];
+  const columns = {};
+  const featureNames = [];
+  for (const chunk of chunks) {
+    const name = chunk[3][3][0];
+    if (name === "patient_id") continue;
+    columns[name] = readColumn(file, chunk, rowCount);
+    if (name !== "pfs_months") featureNames.push(name);
+  }
+  return { rowCount, featureNames, columns };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y =
+    1 -
+    (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  if (p < 1e-300) return 0;
+  return p;
+}
+
+function mean(arr, idx = null) {
+  let s = 0;
+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n++;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, m = null) {
+  const mu = m === null ? mean(arr) : m;
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - mu;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function featureSummary(x) {
+  const n = x.length;
+  let s = 0;
+  let s2 = 0;
+  let min = Infinity;
+  let max = -Infinity;
+  const counts = new Map();
+  for (let i = 0; i < n; i++) {
+    const v = x[i];
+    s += v;
+    s2 += v * v;
+    if (v < min) min = v;
+    if (v > max) max = v;
+    if (counts.size <= 32) counts.set(v, (counts.get(v) || 0) + 1);
+  }
+  const mu = s / n;
+  const sd = Math.sqrt((s2 - n * mu * mu) / (n - 1));
+  return {
+    mean: mu,
+    sd,
+    min,
+    max,
+    unique: counts.size <= 32 ? counts.size : 33,
+    counts: counts.size <= 32 ? counts : null,
+    binary: counts.size === 2 && counts.has(0) && counts.has(1),
+  };
+}
+
+function groupStats(y, x, condition) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (condition(x[i])) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const effect = m1 - m0;
+  return { n1, n0, mean1: m1, mean0: m0, effect, se, z: effect / se, p: pFromZ(effect / se) };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    let best = Math.abs(aug[col][col]);
+    for (let r = col + 1; r < n; r++) {
+      const v = Math.abs(aug[r][col]);
+      if (v > best) {
+        best = v;
+        pivot = r;
+      }
+    }
+    if (best < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) {
+      const tmp = aug[pivot];
+      aug[pivot] = aug[col];
+      aug[col] = tmp;
+    }
+    const div = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yy = 0;
+  const row = Array(p);
+  for (let i = 0; i < n; i++) {
+    row[0] = 1;
+    for (let j = 1; j < p; j++) row[j] = predictors[j - 1][i];
+    yy += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let bxty = 0;
+  for (let i = 0; i < p; i++) bxty += beta[i] * xty[i];
+  const rss = yy - bxty;
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const z = beta.map((b, i) => b / se[i]);
+  const pvals = z.map((v) => pFromZ(v));
+  return { beta, se, z, p: pvals, rss, sigma2, n, predictors: p - 1 };
+}
+
+function centered(arr) {
+  const m = mean(arr);
+  const out = new Float64Array(arr.length);
+  for (let i = 0; i < arr.length; i++) out[i] = arr[i] - m;
+  out.mean = m;
+  return out;
+}
+
+function product(a, b) {
+  const out = new Float64Array(a.length);
+  for (let i = 0; i < a.length; i++) out[i] = a[i] * b[i];
+  return out;
+}
+
+function quantile(values, q) {
+  const a = Array.from(values).sort((x, y) => x - y);
+  const pos = (a.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return a[lo];
+  return a[lo] + (a[hi] - a[lo]) * (pos - lo);
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (x === 0) return "0";
+  const ax = Math.abs(x);
+  if (ax < 0.001) return x.toExponential(2);
+  if (ax >= 1000) return x.toFixed(1);
+  return x.toFixed(digits);
+}
