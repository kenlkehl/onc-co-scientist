+      const tmp = aug[pivot];
+      aug[pivot] = aug[col];
+      aug[col] = tmp;
+    }
+    const div = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= div;
+    for (let r = 0; r < n; r++) {
