+  console.log(`rows=${results.rowCount}`);
+  console.log(`top_univariate=${results.univariate.slice(0, 12).map((r) => `${r.name}:${fmt(r.effect)}:p=${pText(r.p)}`).join(",")}`);
+  console.log(`top_interactions=${results.interactions.slice(0, 8).map((r) => `${r.a}*${r.b}:${fmt(r.effect)}:p=${pText(r.p)}`).join(",")}`);
+  console.log(`wrote ${OUT_TRANSCRIPT} and ${OUT_SUMMARY}`);
+}
