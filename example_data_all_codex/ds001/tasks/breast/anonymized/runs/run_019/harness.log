+  let yy = 0;
+  const row = Array(p);
+  for (let i = 0; i < n; i++) {
+    row[0] = 1;
+    for (let j = 1; j < p; j++) row[j] = predictors[j - 1][i];
+    yy += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
