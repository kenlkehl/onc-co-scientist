+  if (dictOffset !== undefined) {
+    const rh = new CompactReader(file, dictOffset);
+    const header = readPageHeader(rh);
+    const payload = file.slice(rh.p, rh.p + header[3]);
+    const decoded = codec === 1 ? snappyDecode(payload) : payload;
+    dictionary = decodePlainValues(decoded, type, header[7][1]);
+  }
