+      ),
+      analysisRecord(
+        [id23b],
+        `Mean pfs_months for feature_027=1 vs 0 differed by ${fmt(
+          results.levels.f027_1_vs_0.effect
+        )} months (p=${pText(results.levels.f027_1_vs_0.p)}).`,
+        results.levels.f027_1_vs_0.effect,
+        results.levels.f027_1_vs_0.p,
+        "Pairwise level comparison for feature_027"
+      ),
+    ]
+  );
+
+  const id24 = hid();
+  add(
+    24,
+    [
+      hypothesis(
+        id24,
+        `After centering \`feature_044\`, the quadratic term for \`feature_044\` is ${
