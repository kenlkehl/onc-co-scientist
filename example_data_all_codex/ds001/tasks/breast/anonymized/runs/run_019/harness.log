+function readColumn(file, chunk, rowCount) {
+  const meta = chunk[3];
+  const type = meta[1];
+  const codec = meta[4];
+  const values = new Float64Array(rowCount);
+  const dictOffset = meta[11];
+  const dataOffset = meta[9];
+  let dictionary = null;
