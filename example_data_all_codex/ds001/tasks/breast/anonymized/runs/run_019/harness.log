+    f054_high044: compareWithinMask(y, columns.feature_054, (i) => columns.feature_044[i] >= q75, (v) => v === 1),
+    f031_in_f0541: compareWithinMask(y, columns.feature_031, (i) => columns.feature_054[i] === 1, (v) => v === 1),
+    f031_in_f0540: compareWithinMask(y, columns.feature_031, (i) => columns.feature_054[i] === 0, (v) => v === 1),
+    f073_in_f0630: compareWithinMask(y, columns.feature_073, (i) => columns.feature_063[i] === 0, (v) => v === 1),
+    f073_in_f0631: compareWithinMask(y, columns.feature_073, (i) => columns.feature_063[i] === 1, (v) => v === 1),
+  };
