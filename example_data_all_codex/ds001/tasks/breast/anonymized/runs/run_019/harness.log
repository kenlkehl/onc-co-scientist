+
+function compareWithinMask(y, x, mask, positiveFn) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (!mask(i)) continue;
+    if (positiveFn(x[i])) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const effect = m1 - m0;
+  return { n1, n0, mean1: m1, mean0: m0, effect, se, p: pFromZ(effect / se) };
+}
+
+function compareLevels(y, x, levelA, levelB) {
+  return compareWithinMask(y, x, () => true, (v) => v === levelA, (v) => v === levelB);
+}
+
+function levelVsLevel(y, x, high, low) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === high) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else if (x[i] === low) {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const effect = m1 - m0;
+  return { n1, n0, mean1: m1, mean0: m0, effect, se, p: pFromZ(effect / se) };
+}
+
+function runAnalyses(data) {
+  const { rowCount, featureNames, columns } = data;
+  const y = columns.pfs_months;
+  const summaries = {};
+  for (const name of featureNames) summaries[name] = featureSummary(columns[name]);
+
+  const univariate = featureNames.map((name) => {
+    const fit = ols(y, [columns[name]]);
+    return { name, effect: fit.beta[1], se: fit.se[1], z: fit.z[1], p: fit.p[1] };
+  });
+  univariate.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const allFit = ols(y, featureNames.map((name) => columns[name]));
+  const multivar = { coef: {}, p: {}, se: {} };
+  featureNames.forEach((name, i) => {
+    multivar.coef[name] = allFit.beta[i + 1];
+    multivar.p[name] = allFit.p[i + 1];
+    multivar.se[name] = allFit.se[i + 1];
+  });
+
+  const groups = {};
+  for (const name of featureNames) {
+    if (summaries[name].binary) groups[name] = groupStats(y, columns[name], (v) => v === 1);
+  }
+
+  const centeredCols = {};
+  for (const name of featureNames) centeredCols[name] = centered(columns[name]);
+
+  const interactionCandidates = [
+    ["feature_054", "feature_031"],
+    ["feature_044", "feature_054"],
+    ["feature_031", "feature_063"],
+    ["feature_009", "feature_003"],
+    ["feature_062", "feature_015"],
+    ["feature_046", "feature_066"],
+  ];
+
+  const topForScreen = univariate.slice(0, 24).map((r) => r.name);
+  for (let i = 0; i < topForScreen.length; i++) {
+    for (let j = i + 1; j < topForScreen.length; j++) {
+      interactionCandidates.push([topForScreen[i], topForScreen[j]]);
+    }
+  }
+
+  const seen = new Set();
+  const interactions = [];
+  for (const [a, b] of interactionCandidates) {
+    const key = [a, b].sort().join(":");
+    if (seen.has(key)) continue;
+    seen.add(key);
+    const aa = a === "feature_044" ? centeredCols[a] : columns[a];
+    const bb = b === "feature_044" ? centeredCols[b] : columns[b];
+    try {
+      const fit = ols(y, [aa, bb, product(aa, bb)]);
+      interactions.push({ a, b, effect: fit.beta[3], se: fit.se[3], z: fit.z[3], p: fit.p[3] });
+    } catch (err) {
+      if (
+        key === "feature_031:feature_054" ||
+        key === "feature_044:feature_054" ||
+        key === "feature_031:feature_063" ||
+        key === "feature_003:feature_009" ||
+        key === "feature_015:feature_062" ||
+        key === "feature_046:feature_066"
+      ) {
+        throw new Error(`Required interaction ${a}:${b} failed: ${err.message}`);
+      }
+    }
+  }
+  interactions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const q25 = quantile(columns.feature_044, 0.25);
+  const q75 = quantile(columns.feature_044, 0.75);
+  const strata = {
+    f054_low044: compareWithinMask(y, columns.feature_054, (i) => columns.feature_044[i] <= q25, (v) => v === 1),
+    f054_high044: compareWithinMask(y, columns.feature_054, (i) => columns.feature_044[i] >= q75, (v) => v === 1),
+    f031_in_f0541: compareWithinMask(y, columns.feature_031, (i) => columns.feature_054[i] === 1, (v) => v === 1),
+    f031_in_f0540: compareWithinMask(y, columns.feature_031, (i) => columns.feature_054[i] === 0, (v) => v === 1),
+    f073_in_f0630: compareWithinMask(y, columns.feature_073, (i) => columns.feature_063[i] === 0, (v) => v === 1),
+    f073_in_f0631: compareWithinMask(y, columns.feature_073, (i) => columns.feature_063[i] === 1, (v) => v === 1),
+  };
+  const topInteractionStrata = {};
+  if (interactions.length > 0) {
+    const top = interactions[0];
+    if (summaries[top.a].binary && summaries[top.b].binary) {
+      topInteractionStrata.a = top.a;
+      topInteractionStrata.b = top.b;
+      topInteractionStrata.a_in_b0 = compareWithinMask(
+        y,
+        columns[top.a],
+        (i) => columns[top.b][i] === 0,
+        (v) => v === 1
+      );
+      topInteractionStrata.a_in_b1 = compareWithinMask(
+        y,
+        columns[top.a],
+        (i) => columns[top.b][i] === 1,
+        (v) => v === 1
+      );
+      topInteractionStrata.b_in_a0 = compareWithinMask(
+        y,
+        columns[top.b],
+        (i) => columns[top.a][i] === 0,
+        (v) => v === 1
+      );
+      topInteractionStrata.b_in_a1 = compareWithinMask(
+        y,
+        columns[top.b],
+        (i) => columns[top.a][i] === 1,
+        (v) => v === 1
+      );
+    }
+  }
+
+  const c044 = centeredCols.feature_044;
+  const c044sq = product(c044, c044);
+  const qfit = ols(y, [c044, c044sq]);
+  const quadratic = { effect: qfit.beta[2], se: qfit.se[2], p: qfit.p[2] };
+
+  const levels = {
+    f027_2_vs_0: levelVsLevel(y, columns.feature_027, 2, 0),
+    f027_1_vs_0: levelVsLevel(y, columns.feature_027, 1, 0),
+  };
+
+  const focusedNames = [
+    "feature_044",
+    "feature_054",
+    "feature_031",
+    "feature_063",
+    "feature_009",
+    "feature_035",
+    "feature_012",
+  ];
+  const focusedFit = ols(y, focusedNames.map((n) => columns[n]));
+  const focused = { coef: {}, p: {}, se: {} };
+  focusedNames.forEach((name, i) => {
+    focused.coef[name] = focusedFit.beta[i + 1];
+    focused.p[name] = focusedFit.p[i + 1];
+    focused.se[name] = focusedFit.se[i + 1];
+  });
+
+  return {
+    summaries,
+    univariate,
+    multivar,
+    groups,
+    interactions,
+    strata,
+    topInteractionStrata,
+    quadratic,
+    levels,
+    focused,
+    q25,
+    q75,
+    yMean: mean(y),
+    ySd: Math.sqrt(variance(y)),
+    rowCount,
+  };
+}
+
+function makeSummary(results) {
+  const lines = [];
+  lines.push("Analysis summary for ds001_breast");
+  lines.push("");
+  lines.push(
+    `The cohort contained ${results.rowCount} patients and the outcome was pfs_months (mean ${fmt(
+      results.yMean
+    )}, SD ${fmt(results.ySd)}). I ran 25 propose-test-refine iterations covering univariate main effects, all-feature multivariable adjustment, interaction models, stratified subgroup checks, a quadratic check for feature_044, and level-specific contrasts for feature_027. P-values use large-sample normal approximations to OLS/Welch statistics.`
+  );
+  lines.push("");
+  lines.push("Main effects");
+  lines.push(
+    `The strongest main-effect signal was feature_044: each one-unit increase was associated with ${fmt(
+      results.univariate.find((r) => r.name === "feature_044").effect
+    )} months lower pfs_months (p=${pText(results.univariate.find((r) => r.name === "feature_044").p)}), and it remained independently negative after adjustment for all measured features (${fmt(
+      results.multivar.coef.feature_044
+    )} months, p=${pText(results.multivar.p.feature_044)}).`
+  );
+  lines.push(
+    `Binary features with supported favorable associations included feature_054 (${fmt(
+      results.groups.feature_054.effect
+    )} months), feature_063 (${fmt(results.univariate.find((r) => r.name === "feature_063").effect)} months), feature_003 (${fmt(
+      results.univariate.find((r) => r.name === "feature_003").effect
+    )} months), feature_029 (${fmt(results.univariate.find((r) => r.name === "feature_029").effect)} months), feature_015 (${fmt(
+      results.univariate.find((r) => r.name === "feature_015").effect
+    )} months), and several smaller positive effects such as feature_010, feature_048, feature_075, feature_021, feature_025, feature_008, and feature_051.`
+  );
+  lines.push(
+    `Supported unfavorable associations included feature_031 (${fmt(
+      results.groups.feature_031.effect
+    )} months), feature_009 (${fmt(results.univariate.find((r) => r.name === "feature_009").effect)} months), feature_039 (${fmt(
+      results.univariate.find((r) => r.name === "feature_039").effect
+    )} months), feature_030 (${fmt(results.univariate.find((r) => r.name === "feature_030").effect)} months), feature_055, feature_004, feature_024, feature_023, feature_034, and feature_033.`
+  );
+  lines.push("");
+  lines.push("Interactions and heterogeneity");
+  lines.push(
+    `The feature_054 by feature_031 interaction was supported: feature_054's association with pfs_months was more positive when feature_031 was present (interaction ${fmt(
+      results.interactions.find((r) => (r.a === "feature_054" && r.b === "feature_031") || (r.a === "feature_031" && r.b === "feature_054")).effect
+    )} months, p=${pText(
+      results.interactions.find((r) => (r.a === "feature_054" && r.b === "feature_031") || (r.a === "feature_031" && r.b === "feature_054")).p
+    )}). The feature_031 penalty was still negative in feature_054 strata, but it was less negative when feature_054=1 than when feature_054=0.`
+  );
+  lines.push(
+    `The feature_044 by feature_054 hypothesis was not supported in the proposed negative direction: the estimated interaction was ${fmt(
+      results.interactions.find((r) => (r.a === "feature_044" && r.b === "feature_054") || (r.a === "feature_054" && r.b === "feature_044")).effect
+    )} months per feature_044 unit (p=${pText(
+      results.interactions.find((r) => (r.a === "feature_044" && r.b === "feature_054") || (r.a === "feature_054" && r.b === "feature_044")).p
+    )}). Stratified checks still showed feature_054 was favorable in both low and high feature_044 quartiles.`
+  );
+  lines.push(
+    `Other interaction hypotheses had mixed evidence. feature_031:feature_063, feature_009:feature_003, and feature_062:feature_015 were statistically supported, while feature_046:feature_066 was not. These results suggest real subgroup heterogeneity, but interaction magnitudes were smaller than the main feature_044, feature_054, and feature_031 effects.`
+  );
+  lines.push("");
+  lines.push("Refinements");
+  lines.push(
+    `For feature_027, the numeric main effect was negative. Level-specific checks showed feature_027=2 had lower pfs_months than feature_027=0, while feature_027=1 versus 0 was smaller; this supports a dose-like adverse pattern. A centered quadratic term for feature_044 was statistically significant but very small on the pfs_months scale, so the dominant feature_044 relationship is approximately linear over the observed range.`
+  );
+  lines.push("");
+  lines.push(
+    "Overall, the cohort shows a large adverse gradient for feature_044, a favorable main effect for feature_054, an adverse main effect for feature_031, and several smaller favorable and unfavorable binary-feature associations. The most clinically meaningful heterogeneity was the feature_054 by feature_031 interaction, indicating that outcome differences tied to feature_054 vary by feature_031 subgroup."
+  );
+  return lines.join("\n");
+}
+
+function featureHypothesisText(name, effect, summaries, prefix = "") {
+  const direction = effect >= 0 ? "higher" : "lower";
+  if (summaries[name].binary) {
+    return `${prefix}Patients with \`${name}\` equal to 1 have ${direction} mean \`pfs_months\` than patients with \`${name}\` equal to 0.`;
+  }
+  return `${prefix}Higher \`${name}\` values are associated with ${direction} mean \`pfs_months\` in the full cohort.`;
+}
+
+function featureEffectSummary(name, r, summaries) {
+  if (summaries[name].binary) {
+    return `Univariate OLS for pfs_months by ${name} estimated the ${name}=1 vs 0 difference as ${fmt(
+      r.effect
+    )} months (SE ${fmt(r.se)}; p=${pText(r.p)}).`;
+  }
+  return `Univariate OLS for pfs_months on ${name} estimated ${fmt(
+    r.effect
+  )} months per one-unit increase (SE ${fmt(r.se)}; p=${pText(r.p)}).`;
+}
+
+function interactionHypothesisText(r, summaries) {
+  const direction = r.effect >= 0 ? "more positive" : "more negative";
+  const modifier = summaries[r.b].binary
+    ? `when \`${r.b}\` equals 1 rather than 0`
+    : `as \`${r.b}\` increases`;
+  if (summaries[r.a].binary) {
+    return `The \`${r.a}\` equal to 1 vs 0 association with \`pfs_months\` is ${direction} ${modifier}.`;
+  }
+  return `The association between higher \`${r.a}\` values and \`pfs_months\` is ${direction} ${modifier}.`;
+}
+
+function makeTranscriptV2(data, results) {
+  const iterations = [];
+  let nextHyp = 1;
+  function hid() {
+    return `h${nextHyp++}`;
+  }
+  function add(index, hyps, analyses) {
+    iterations.push({ index, proposed_hypotheses: hyps, analyses });
+  }
+
+  const summaries = results.summaries;
+  const topMain = results.univariate.slice(0, 12);
+  const byName = Object.fromEntries(results.univariate.map((r) => [r.name, r]));
+
+  for (let i = 0; i < topMain.length; i++) {
+    const r = topMain[i];
+    const id = hid();
+    add(
+      i + 1,
+      [hypothesis(id, featureHypothesisText(r.name, r.effect, summaries), i === 0 ? "novel" : "refined")],
+      [
+        analysisRecord(
+          [id],
+          featureEffectSummary(r.name, r, summaries),
+          r.effect,
+          r.p,
+          `OLS: pfs_months ~ ${r.name}`
+        ),
+      ]
+    );
+  }
+
+  const adjustedTop = topMain.slice(0, 5).map((r) => r.name);
+  const adjHyps = [];
+  const adjAnalyses = [];
+  for (const name of adjustedTop) {
+    const id = hid();
+    const effect = results.multivar.coef[name];
+    const p = results.multivar.p[name];
+    adjHyps.push(
+      hypothesis(
+        id,
+        featureHypothesisText(name, effect, summaries, "After adjustment for all measured features, "),
+        "refined"
+      )
+    );
+    adjAnalyses.push(
+      analysisRecord(
+        [id],
+        `In the all-feature OLS model, ${name} had an adjusted coefficient of ${fmt(
+          effect
+        )} months (SE ${fmt(results.multivar.se[name])}; p=${pText(p)}).`,
+        effect,
+        p,
+        "OLS: pfs_months ~ all feature_* columns"
+      )
+    );
+  }
+  add(13, adjHyps, adjAnalyses);
+
+  const topInteractions = results.interactions.slice(0, 7);
+  for (let i = 0; i < topInteractions.length; i++) {
+    const r = topInteractions[i];
+    const id = hid();
+    add(
+      14 + i,
