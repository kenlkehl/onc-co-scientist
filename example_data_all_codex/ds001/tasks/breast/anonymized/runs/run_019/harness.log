@@ -0,0 +1,1608 @@
+const fs = require("fs");
+
+const FILE = "dataset.parquet";
+const SCHEMA_FILE = "transcript_schema.json";
+const OUT_TRANSCRIPT = "transcript.json";
+const OUT_SUMMARY = "analysis_summary.txt";
+
+class CompactReader {
+  constructor(buffer, position = 0) {
+    this.b = buffer;
+    this.p = position;
+  }
+  u8() {
+    return this.b[this.p++];
+  }
+  varint() {
+    let shift = 0n;
+    let n = 0n;
+    while (true) {
+      const c = this.u8();
+      n |= BigInt(c & 0x7f) << shift;
+      if ((c & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return n;
+  }
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+  str() {
+    const len = Number(this.varint());
+    const s = this.b.slice(this.p, this.p + len).toString("utf8");
+    this.p += len;
+    return s;
+  }
+  fieldHeader(lastId) {
+    const h = this.u8();
+    const type = h & 0x0f;
+    if (type === 0) return null;
+    const delta = h >> 4;
+    const id = delta === 0 ? Number(this.zigzag(this.varint())) : lastId + delta;
+    return { id, type };
+  }
+  listHeader() {
+    const h = this.u8();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+  skip(type) {
+    if (type === 1 || type === 2) return;
+    if (type === 3) {
+      this.p += 1;
+      return;
+    }
+    if (type === 4 || type === 5 || type === 6) {
+      this.varint();
+      return;
+    }
+    if (type === 7) {
+      this.p += 8;
+      return;
+    }
+    if (type === 8) {
+      const len = Number(this.varint());
+      this.p += len;
+      return;
+    }
+    if (type === 9 || type === 10) {
+      const h = this.listHeader();
+      for (let i = 0; i < h.size; i++) this.skip(h.type);
+      return;
+    }
+    if (type === 11) {
+      const size = Number(this.varint());
+      if (size === 0) return;
+      const ktvt = this.u8();
+      const kt = (ktvt >> 4) & 0x0f;
+      const vt = ktvt & 0x0f;
+      for (let i = 0; i < size; i++) {
+        this.skip(kt);
+        this.skip(vt);
+      }
+      return;
+    }
+    if (type === 12) {
+      this.skipStruct();
+      return;
+    }
+    throw new Error(`Unsupported compact type ${type} at byte ${this.p}`);
+  }
+  skipStruct() {
+    let lastId = 0;
+    while (true) {
+      const fh = this.fieldHeader(lastId);
+      if (!fh) return;
+      lastId = fh.id;
+      this.skip(fh.type);
+    }
+  }
+}
+
+function readStruct(r, readers) {
+  const out = {};
+  let lastId = 0;
+  while (true) {
+    const fh = r.fieldHeader(lastId);
+    if (!fh) break;
+    lastId = fh.id;
+    if (readers[fh.id]) out[fh.id] = readers[fh.id](r, fh.type);
+    else r.skip(fh.type);
+  }
+  return out;
+}
+
+function readList(r, fn) {
+  const h = r.listHeader();
+  const out = [];
+  for (let i = 0; i < h.size; i++) out.push(fn(r, h.type));
+  return out;
+}
+
+function readStringList(r) {
+  return readList(r, (rr) => rr.str());
+}
+
+function readI32List(r) {
+  return readList(r, (rr) => rr.i32());
+}
+
+function readSchemaElement(r) {
+  return readStruct(r, {
+    1: (rr) => rr.i32(),
+    2: (rr) => rr.i32(),
+    3: (rr) => rr.i32(),
+    4: (rr) => rr.str(),
+    5: (rr) => rr.i32(),
+    6: (rr) => rr.i32(),
+    7: (rr) => rr.i32(),
+    8: (rr) => rr.i32(),
+    9: (rr) => rr.i32(),
+    10: (rr, t) => {
+      rr.skip(t);
+      return null;
+    },
+  });
+}
+
+function readStats(r) {
+  return readStruct(r, {
+    1: (rr) => rr.str(),
+    2: (rr) => rr.str(),
+    3: (rr) => rr.i64(),
+    4: (rr) => rr.i64(),
+    5: (rr) => rr.str(),
+    6: (rr) => rr.str(),
+    7: (rr) => rr.i64(),
+  });
+}
+
+function readColumnMeta(r) {
+  return readStruct(r, {
+    1: (rr) => rr.i32(),
+    2: (rr) => readI32List(rr),
+    3: (rr) => readStringList(rr),
+    4: (rr) => rr.i32(),
+    5: (rr) => rr.i64(),
+    6: (rr) => rr.i64(),
+    7: (rr) => rr.i64(),
+    9: (rr) => rr.i64(),
+    10: (rr) => rr.i64(),
+    11: (rr) => rr.i64(),
+    12: (rr) => readStats(rr),
+    13: (rr, t) => {
+      rr.skip(t);
+      return null;
+    },
+  });
+}
+
+function readColumnChunk(r) {
+  return readStruct(r, {
+    1: (rr) => rr.str(),
+    2: (rr) => rr.i64(),
+    3: (rr) => readColumnMeta(rr),
+    4: (rr) => rr.i64(),
+    5: (rr) => rr.i32(),
+    6: (rr) => rr.i64(),
+    7: (rr) => rr.i32(),
+  });
+}
+
+function readRowGroup(r) {
+  return readStruct(r, {
+    1: (rr) => readList(rr, (rrr) => readColumnChunk(rrr)),
+    2: (rr) => rr.i64(),
+    3: (rr) => rr.i64(),
+    5: (rr) => rr.i64(),
+    6: (rr) => rr.i64(),
+    7: (rr) => rr.i32(),
+  });
+}
+
+function readFileMeta(buffer) {
+  const footerLen = buffer.readUInt32LE(buffer.length - 8);
+  const start = buffer.length - 8 - footerLen;
+  const r = new CompactReader(buffer.slice(start, buffer.length - 8));
+  return readStruct(r, {
+    1: (rr) => rr.i32(),
+    2: (rr) => readList(rr, (rrr) => readSchemaElement(rrr)),
+    3: (rr) => rr.i64(),
+    4: (rr) => readList(rr, (rrr) => readRowGroup(rrr)),
+    5: (rr, t) => {
+      rr.skip(t);
+      return null;
+    },
+    6: (rr) => rr.str(),
+    7: (rr, t) => {
+      rr.skip(t);
+      return null;
+    },
+  });
+}
+
+function readPageHeader(r) {
+  return readStruct(r, {
+    1: (rr) => rr.i32(),
+    2: (rr) => rr.i32(),
+    3: (rr) => rr.i32(),
+    4: (rr) => rr.i32(),
+    5: (rr) =>
+      readStruct(rr, {
+        1: (rrr) => rrr.i32(),
+        2: (rrr) => rrr.i32(),
+        3: (rrr) => rrr.i32(),
+        4: (rrr) => rrr.i32(),
+        5: (rrr, t) => {
+          rrr.skip(t);
+          return null;
+        },
+      }),
+    7: (rr) =>
+      readStruct(rr, {
+        1: (rrr) => rrr.i32(),
+        2: (rrr) => rrr.i32(),
+        3: (_rrr, t) => (t === 1 ? true : t === 2 ? false : null),
+      }),
+    8: (rr) =>
+      readStruct(rr, {
+        1: (rrr) => rrr.i32(),
+        2: (rrr) => rrr.i32(),
+        3: (rrr) => rrr.i32(),
+        4: (rrr) => rrr.i32(),
+        5: (rrr) => rrr.i32(),
+        6: (rrr) => rrr.i32(),
+        7: (_rrr, t) => (t === 1 ? true : t === 2 ? false : null),
+        8: (rrr, t) => {
+          rrr.skip(t);
+          return null;
+        },
+      }),
+  });
+}
+
+function snappyDecode(input) {
+  let p = 0;
+  function readVar() {
+    let shift = 0;
+    let n = 0;
+    while (true) {
+      const c = input[p++];
+      n |= (c & 0x7f) << shift;
+      if ((c & 0x80) === 0) break;
+      shift += 7;
+    }
+    return n;
+  }
+  const outLen = readVar();
+  const out = Buffer.allocUnsafe(outLen);
+  let o = 0;
