+class CompactReader {
+  constructor(buffer, position = 0) {
+    this.b = buffer;
+    this.p = position;
+  }
+  u8() {
+    return this.b[this.p++];
+  }
+  varint() {
+    let shift = 0n;
+    let n = 0n;
+    while (true) {
+      const c = this.u8();
+      n |= BigInt(c & 0x7f) << shift;
+      if ((c & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return n;
+  }
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+  str() {
+    const len = Number(this.varint());
+    const s = this.b.slice(this.p, this.p + len).toString("utf8");
+    this.p += len;
+    return s;
+  }
+  fieldHeader(lastId) {
+    const h = this.u8();
+    const type = h & 0x0f;
+    if (type === 0) return null;
+    const delta = h >> 4;
+    const id = delta === 0 ? Number(this.zigzag(this.varint())) : lastId + delta;
+    return { id, type };
+  }
+  listHeader() {
+    const h = this.u8();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+  skip(type) {
+    if (type === 1 || type === 2) return;
+    if (type === 3) {
+      this.p += 1;
+      return;
+    }
+    if (type === 4 || type === 5 || type === 6) {
+      this.varint();
+      return;
+    }
+    if (type === 7) {
+      this.p += 8;
+      return;
+    }
+    if (type === 8) {
+      const len = Number(this.varint());
+      this.p += len;
+      return;
+    }
+    if (type === 9 || type === 10) {
+      const h = this.listHeader();
+      for (let i = 0; i < h.size; i++) this.skip(h.type);
+      return;
+    }
+    if (type === 11) {
+      const size = Number(this.varint());
+      if (size === 0) return;
+      const ktvt = this.u8();
+      const kt = (ktvt >> 4) & 0x0f;
+      const vt = ktvt & 0x0f;
+      for (let i = 0; i < size; i++) {
+        this.skip(kt);
+        this.skip(vt);
+      }
+      return;
+    }
+    if (type === 12) {
+      this.skipStruct();
+      return;
+    }
+    throw new Error(`Unsupported compact type ${type} at byte ${this.p}`);
+  }
+  skipStruct() {
+    let lastId = 0;
+    while (true) {
+      const fh = this.fieldHeader(lastId);
+      if (!fh) return;
+      lastId = fh.id;
+      this.skip(fh.type);
+    }
+  }
+}
