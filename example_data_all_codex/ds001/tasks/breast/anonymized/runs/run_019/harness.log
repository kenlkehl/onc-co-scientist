+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (condition(x[i])) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
