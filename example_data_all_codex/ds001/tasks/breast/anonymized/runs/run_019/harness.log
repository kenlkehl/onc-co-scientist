+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const effect = m1 - m0;
+  return { n1, n0, mean1: m1, mean0: m0, effect, se, z: effect / se, p: pFromZ(effect / se) };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    let best = Math.abs(aug[col][col]);
+    for (let r = col + 1; r < n; r++) {
+      const v = Math.abs(aug[r][col]);
+      if (v > best) {
+        best = v;
+        pivot = r;
+      }
+    }
+    if (best < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) {
+      const tmp = aug[pivot];
+      aug[pivot] = aug[col];
+      aug[col] = tmp;
+    }
+    const div = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yy = 0;
+  const row = Array(p);
+  for (let i = 0; i < n; i++) {
+    row[0] = 1;
+    for (let j = 1; j < p; j++) row[j] = predictors[j - 1][i];
+    yy += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let bxty = 0;
+  for (let i = 0; i < p; i++) bxty += beta[i] * xty[i];
+  const rss = yy - bxty;
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const z = beta.map((b, i) => b / se[i]);
+  const pvals = z.map((v) => pFromZ(v));
+  return { beta, se, z, p: pvals, rss, sigma2, n, predictors: p - 1 };
+}
+
+function centered(arr) {
+  const m = mean(arr);
+  const out = new Float64Array(arr.length);
+  for (let i = 0; i < arr.length; i++) out[i] = arr[i] - m;
+  out.mean = m;
+  return out;
+}
+
+function product(a, b) {
+  const out = new Float64Array(a.length);
+  for (let i = 0; i < a.length; i++) out[i] = a[i] * b[i];
+  return out;
+}
+
+function quantile(values, q) {
+  const a = Array.from(values).sort((x, y) => x - y);
+  const pos = (a.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return a[lo];
+  return a[lo] + (a[hi] - a[lo]) * (pos - lo);
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (x === 0) return "0";
+  const ax = Math.abs(x);
+  if (ax < 0.001) return x.toExponential(2);
+  if (ax >= 1000) return x.toFixed(1);
+  return x.toFixed(digits);
+}
+
+function pText(p) {
+  if (p === 0) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(3);
+}
