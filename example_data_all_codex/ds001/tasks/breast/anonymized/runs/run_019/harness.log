+    if (positiveFn(x[i])) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
