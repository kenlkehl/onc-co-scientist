+function groupStats(y, x, condition) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (condition(x[i])) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - n1 * m1 * m1) / (n1 - 1);
+  const v0 = (ss0 - n0 * m0 * m0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const effect = m1 - m0;
+  return { n1, n0, mean1: m1, mean0: m0, effect, se, z: effect / se, p: pFromZ(effect / se) };
