+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y =
+    1 -
+    (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  if (p < 1e-300) return 0;
+  return p;
+}
+
+function mean(arr, idx = null) {
+  let s = 0;
+  let n = 0;
+  if (idx) {
+    for (const i of idx) {
+      s += arr[i];
+      n++;
+    }
+  } else {
+    for (let i = 0; i < arr.length; i++) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, m = null) {
+  const mu = m === null ? mean(arr) : m;
+  let s = 0;
+  for (let i = 0; i < arr.length; i++) {
+    const d = arr[i] - mu;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function featureSummary(x) {
+  const n = x.length;
+  let s = 0;
+  let s2 = 0;
+  let min = Infinity;
+  let max = -Infinity;
+  const counts = new Map();
+  for (let i = 0; i < n; i++) {
+    const v = x[i];
+    s += v;
+    s2 += v * v;
+    if (v < min) min = v;
+    if (v > max) max = v;
+    if (counts.size <= 32) counts.set(v, (counts.get(v) || 0) + 1);
+  }
+  const mu = s / n;
+  const sd = Math.sqrt((s2 - n * mu * mu) / (n - 1));
+  return {
+    mean: mu,
+    sd,
+    min,
+    max,
+    unique: counts.size <= 32 ? counts.size : 33,
+    counts: counts.size <= 32 ? counts : null,
+    binary: counts.size === 2 && counts.has(0) && counts.has(1),
+  };
+}
