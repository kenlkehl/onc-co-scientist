+
+class CompactReader {
+  constructor(buffer, position = 0) {
+    this.b = buffer;
+    this.p = position;
+  }
+  u8() {
+    return this.b[this.p++];
+  }
+  varint() {
+    let shift = 0n;
+    let n = 0n;
+    while (true) {
+      const c = this.u8();
+      n |= BigInt(c & 0x7f) << shift;
+      if ((c & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return n;
+  }
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+  str() {
+    const len = Number(this.varint());
+    const s = this.b.slice(this.p, this.p + len).toString("utf8");
+    this.p += len;
+    return s;
+  }
+  fieldHeader(lastId) {
