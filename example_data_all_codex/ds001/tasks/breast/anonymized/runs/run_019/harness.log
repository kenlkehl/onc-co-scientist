+    if (header[1] === 0) {
+      const page = header[5];
+      const numValues = page[1];
+      let p = 0;
+      const defLen = decoded.readUInt32LE(p);
+      p += 4;
+      const def = readHybridValues(decoded, p, numValues, 1, p + defLen);
+      p += defLen;
+      const nonNullCount = def.values.reduce((s, v) => s + (v === 1 ? 1 : 0), 0);
+      if (page[2] === 8 && dictionary) {
+        const bitWidth = decoded[p++];
+        const decodedIdx = readHybridValues(decoded, p, nonNullCount, bitWidth);
+        let valuePos = 0;
+        for (const d of def.values) {
+          if (d === 1) values[outIndex++] = dictionary[decodedIdx.values[valuePos++]];
+          else values[outIndex++] = NaN;
+        }
+      } else if (page[2] === 0) {
+        const plain = decodePlainValues(decoded.slice(p), type, nonNullCount);
+        let valuePos = 0;
+        for (const d of def.values) {
+          if (d === 1) values[outIndex++] = plain[valuePos++];
+          else values[outIndex++] = NaN;
+        }
+      } else {
+        throw new Error(`Unsupported data page encoding ${page[2]}`);
+      }
+    } else if (header[1] === 3) {
+      const page = header[8];
+      const numValues = page[1];
+      const numNulls = page[2];
+      const repLen = page[5] || 0;
+      const defLen = page[6] || 0;
+      let p = repLen + defLen;
+      const nonNullCount = numValues - numNulls;
+      if (page[4] === 8 && dictionary) {
+        const bitWidth = decoded[p++];
+        const decodedIdx = readHybridValues(decoded, p, nonNullCount, bitWidth);
+        for (let i = 0; i < nonNullCount; i++) values[outIndex++] = dictionary[decodedIdx.values[i]];
+      } else {
+        throw new Error(`Unsupported data page v2 encoding ${page[4]}`);
+      }
