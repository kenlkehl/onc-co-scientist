+    })
+    .join("; ");
+  const intText = topInteractions
+    .map((r) => `${r.a}:${r.b} ${r.effect >= 0 ? "+" : ""}${fmt(r.effect)} months (p=${pText(r.p)})`)
+    .join("; ");
+  const lines = [];
+  lines.push("Analysis summary for ds001_breast");
+  lines.push("");
+  lines.push(
+    `The cohort contained ${results.rowCount} patients and one continuous outcome, pfs_months (mean ${fmt(
+      results.yMean
+    )}, SD ${fmt(results.ySd)}). I completed the 25-iteration protocol using univariate OLS, all-feature multivariable OLS, pairwise interaction models, subgroup mean comparisons, level-specific contrasts, and a centered quadratic check. P-values use large-sample normal approximations.`
+  );
+  lines.push("");
+  lines.push("Main effects");
+  lines.push(
+    `The strongest univariate associations were: ${mainText}. These hypotheses were statistically supported in the signed directions shown.`
+  );
+  lines.push(
+    `In the all-feature model, the leading effects remained directionally consistent for the top signals: ${adjText}. This supports feature_044, feature_027, feature_039, feature_046, and feature_015 as independent outcome-associated features rather than simple proxies for one another.`
+  );
+  lines.push("");
+  lines.push("Interactions and subgroups");
+  lines.push(
+    `The strongest interaction terms were: ${intText}. The largest was ${topInteractions[0].a}:${topInteractions[0].b}, indicating that the ${topInteractions[0].a} association with pfs_months changed substantially by ${topInteractions[0].b} subgroup.`
+  );
+  if (results.topInteractionStrata.a) {
+    const ts = results.topInteractionStrata;
+    lines.push(
+      `Stratified checks confirmed that pattern: within ${ts.b}=0, ${ts.a}=1 vs 0 differed by ${fmt(
+        ts.a_in_b0.effect
+      )} months, while within ${ts.b}=1 the difference was ${fmt(ts.a_in_b1.effect)} months.`
+    );
+  }
+  lines.push("");
+  lines.push("Refinements");
+  lines.push(
+    `Feature_027 showed a dose-like adverse pattern: feature_027=2 vs 0 differed by ${fmt(
+      results.levels.f027_2_vs_0.effect
+    )} months and feature_027=1 vs 0 differed by ${fmt(results.levels.f027_1_vs_0.effect)} months, both with p=${pText(
