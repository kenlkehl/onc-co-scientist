+  let pos = dataOffset;
+  let outIndex = 0;
+  while (outIndex < rowCount) {
+    const rh = new CompactReader(file, pos);
+    const header = readPageHeader(rh);
+    const payloadStart = rh.p;
+    const payload = file.slice(payloadStart, payloadStart + header[3]);
+    pos = payloadStart + header[3];
+    const decoded = codec === 1 ? snappyDecode(payload) : payload;
