+        id23a,
+        `Patients with \`feature_027\` equal to 2 have ${
+          results.levels.f027_2_vs_0.effect >= 0 ? "higher" : "lower"
+        } mean \`pfs_months\` than patients with \`feature_027\` equal to 0.`,
+        "refined"
+      ),
