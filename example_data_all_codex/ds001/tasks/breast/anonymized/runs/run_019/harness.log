+  let max = -Infinity;
+  const counts = new Map();
+  for (let i = 0; i < n; i++) {
+    const v = x[i];
+    s += v;
+    s2 += v * v;
+    if (v < min) min = v;
+    if (v > max) max = v;
+    if (counts.size <= 32) counts.set(v, (counts.get(v) || 0) + 1);
+  }
+  const mu = s / n;
+  const sd = Math.sqrt((s2 - n * mu * mu) / (n - 1));
