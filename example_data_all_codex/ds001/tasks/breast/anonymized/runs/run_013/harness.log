+  const values = [];
+  for (const group of [0, 1]) {
+    const indices = [];
+    for (let i = 0; i < y.length; i += 1) if (data[binary][i] === group) indices.push(i);
+    let meanX = 0;
+    let meanY = 0;
+    for (const idx of indices) {
+      meanX += data[continuous][idx];
+      meanY += y[idx];
+    }
+    meanX /= indices.length;
+    meanY /= indices.length;
+    let sxx = 0;
+    let sxy = 0;
+    for (const idx of indices) {
+      sxx += (data[continuous][idx] - meanX) ** 2;
+      sxy += (data[continuous][idx] - meanX) * (y[idx] - meanY);
+    }
+    values.push({ group, n: indices.length, slopePerUnit: sxy / sxx, slopePerSd: (sxy / sxx) * summaries[continuous].sd });
