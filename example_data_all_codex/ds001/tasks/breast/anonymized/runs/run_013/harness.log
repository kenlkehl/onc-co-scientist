+
+function parseStruct(reader, handlers) {
+  const object = {};
+  let previousFieldId = 0;
+  while (true) {
+    const header = reader.byte();
+    if (header === 0) break;
+    const type = header & 0x0f;
+    const delta = header >> 4;
+    const fieldId = delta === 0 ? reader.i32() : previousFieldId + delta;
+    previousFieldId = fieldId;
+    if (handlers[fieldId]) handlers[fieldId](reader, object, type);
+    else reader.skipType(type);
+  }
+  return object;
+}
+
+function readList(reader, itemReader) {
+  const { size } = reader.listHeader();
+  const values = [];
+  for (let i = 0; i < size; i += 1) values.push(itemReader(reader));
+  return values;
+}
+
+function parseSchemaElement(reader) {
+  return parseStruct(reader, {
+    1: (r, o) => { o.type = r.i32(); },
+    2: (r, o) => { o.typeLength = r.i32(); },
+    3: (r, o) => { o.repetitionType = r.i32(); },
