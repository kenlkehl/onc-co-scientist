+  listHeader() {
+    const header = this.byte();
+    let size = header >> 4;
+    const elementType = header & 0x0f;
+    if (size === 15) size = Number(this.varintBig());
+    return { size, elementType };
+  }
+
+  skipType(type) {
+    if (type === 0 || type === 1 || type === 2) return;
+    if (type === 3) {
+      this.offset += 1;
+      return;
+    }
+    if (type === 4 || type === 5 || type === 6) {
+      this.varintBig();
+      return;
+    }
+    if (type === 7) {
+      this.offset += 8;
+      return;
+    }
+    if (type === 8) {
+      const length = Number(this.varintBig());
+      this.offset += length;
+      return;
+    }
+    if (type === 9 || type === 10) {
+      const { size, elementType } = this.listHeader();
+      for (let i = 0; i < size; i += 1) this.skipType(elementType);
+      return;
+    }
+    if (type === 11) {
+      const keyType = this.byte();
+      const valueType = this.byte();
+      const size = Number(this.varintBig());
+      for (let i = 0; i < size; i += 1) {
