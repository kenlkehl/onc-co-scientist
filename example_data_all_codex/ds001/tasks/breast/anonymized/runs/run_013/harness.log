+  }
+  for (let i = 0; i < y.length; i += 1) {
+    const key = `${data[a][i]}${data[b][i]}`;
+    groups[key].n += 1;
+    groups[key].sum += y[i];
+  }
+  for (const key of Object.keys(groups)) groups[key].mean = groups[key].sum / groups[key].n;
+  const did = (groups["11"].mean - groups["10"].mean) - (groups["01"].mean - groups["00"].mean);
+  return { groups, did };
+}
