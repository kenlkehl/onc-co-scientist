  const xtw=Array(p).fill(0); for(let i=0;i<n;i++){const wi=w[i]; xtw[0]+=wi; for(let j=0;j<featureNames.length;j++) xtw[j+1]+=zdata[featureNames[j]][i]*wi;} const invAll=invertCache; const gamma=invAll.map(row=>row.reduce((s,v,j)=>s+v*xtw[j],0)); let wtw=0, projtw=0, wy=0; for(let j=0;j<p;j++) projtw += gamma[j]*xtw[j]; for(let i=0;i<n;i++){wtw+=w[i]*w[i]; wy+=w[i]*y[i];} let gammaXty=0; for(let j=0;j<p;j++) gammaXty += gamma[j]*fullXty[j]; const wres_y = wy - gammaXty; const wres_w = wtw - projtw; const beta=wres_y/wres_w; const rss=allMain.rss - beta*wres_y; const sig2=rss/(n-p-1); const se=Math.sqrt(sig2/wres_w); const t=beta/se; return {a,b,beta,se,t,p:pnorm2(t),rss}; }
// Need cached XtX inverse and Xty for full main model.
function fullMainCache(){const n=y.length,p=1+featureNames.length; const XtX=Array.from({length:p},()=>Array(p).fill(0)); const Xty=Array(p).fill(0); for(let i=0;i<n;i++){const yi=y[i]; Xty[0]+=yi; XtX[0][0]+=1; for(let a=0;a<featureNames.length;a++){const xa=zdata[featureNames[a]][i]; Xty[a+1]+=xa*yi; XtX[a+1][0]+=xa; XtX[0][a+1]+=xa; for(let b=0;b<=a;b++){XtX[a+1][b+1]+=xa*zdata[featureNames[b]][i];}}} for(let a=1;a<p;a++) for(let b=1;b<a;b++) XtX[b][a]=XtX[a][b]; return {inv:invert(XtX), Xty};}
const cache=fullMainCache(); const invertCache=cache.inv, fullXty=cache.Xty;
