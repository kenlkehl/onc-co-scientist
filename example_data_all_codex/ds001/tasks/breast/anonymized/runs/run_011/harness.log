function prod(a,b){const x=data[a],z=data[b],arr=new Float64Array(y.length);for(let i=0;i<y.length;i++)arr[i]=x[i]*z[i];return Array.from(arr);} // easier for ols
for(let i=0;i<topMain.length;i++)for(let j=i+1;j<topMain.length;j++){const a=topMain[i],b=topMain[j];const intName="'`${a}:${b}`;const model=ols([{name:a,values:data[a]},{name:b,values:data[b]},{name:intName,values:prod(a,b)}],y);const row=model.rows.find(r=>r.name===intName);interactions.push({a,b,...row,r2:model.r2});}
