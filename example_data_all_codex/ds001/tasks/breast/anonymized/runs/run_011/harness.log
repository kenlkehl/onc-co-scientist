function erf(x){const sign=x<0?-1:1;x=Math.abs(x);const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911;const t=1/(1+p*x);const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x);return sign*y;}
function normTail(x){x=Math.abs(x);if(x<8)return Math.max(0.5*(1-erf(x/Math.SQRT2)),1e-300);const phi=Math.exp(-0.5*x*x)/Math.sqrt(2*Math.PI);if(phi===0)return 1e-300;const inv=1/x;let series=1-inv*inv+3*inv**4-15*inv**6+105*inv**8;if(series<=0)series=1;return Math.max(phi*inv*series,1e-300);}function pFromT(t){return Math.min(1,Math.max(1e-300,2*normTail(Math.abs(t))));}
function invert(A){const n=A.length;const M=A.map((row,i)=>{const r=row.slice();for(let j=0;j<n;j++)r.push(i===j?1:0);return r;});for(let i=0;i<n;i++){let piv=i;let max=Math.abs(M[i][i]);for(let r=i+1;r<n;r++){const v=Math.abs(M[r][i]);if(v>max){max=v;piv=r;}}if(max<1e-12)throw new Error('singular '+i);if(piv"'!==i){const tmp=M[i];M[i]=M[piv];M[piv]=tmp;}const d=M[i][i];for(let c=0;c<2*n;c++)M[i][c]/=d;for(let r=0;r<n;r++){if(r===i)continue;const f=M[r][i];if(f!==0){for(let c=0;c<2*n;c++)M[r][c]-=f*M[i][c];}}}return M.map(row=>row.slice(n));}
function ols(vars,y){const n=y.length,k=vars.length;const means=[],sds=[],Z=[];for(let j=0;j<k;j++){const x=vars[j].values;let s=0;for(let i=0;i<n;i++)s+=x[i];const m=s/n;let ss=0;for(let i=0;i<n;i++){const d=x[i]-m;ss+=d*d;}const sd=Math.sqrt(ss/(n-1));means[j]=m;sds[j]=sd;Z[j]=new Float64Array(n);for(let i=0;i<n;i++)Z[j][i]=(x[i]-m)/sd;}let ysum=0;for(const v of y)ysum+=v;const ym=ysum/n;const yc=new Float64Array(n);let syy=0;for(let i=0;i<n;i++){yc[i]=y[i]-ym;syy+=yc[i]*yc[i];}const XtX=Array.from({length:k},()=>Array(k).fill(0));const Xty=Array(k).fill(0);for(let a=0;a<k;a++){let s=0;const Za=Z[a];for(let i=0;i<n;i++)s+=Za[i]*yc[i];Xty[a]=s;for(let b=0;b<=a;b++){let v=0;const Zb=Z[b];for(let i=0;i<n;i++)v+=Za[i]*Zb[i];XtX[a][b]=XtX[b][a]=v;}}const inv=invert(XtX);const beta=Array(k).fill(0);for(let i=0;i<k;i++){for(let j=0;j<k;j++)beta[i]+=inv[i][j]*Xty[j];}let sse=syy;for(let i=0;i<k;i++)sse-=beta[i]*Xty[i];const sigma2=sse/(n-k-1);const rows=[];for(let j=0;j<k;j++){const seZ=Math.sqrt(Math.max(0,sigma2*inv[j][j]));const t=beta[j]/seZ;rows.push({name:vars[j].name,beta:beta[j]/sds[j],se:seZ/sds[j],t,p:pFromT(t),sd:sds[j],mean:means[j]});}return{rows,sse,sigma2,r2:1-sse/syy,df:n-k-1};}
function univar(x,y){const n=y.length;let sx=0,sy=0;for(let i=0;i<n;i++){sx+=x[i];sy+=y[i];}const mx=sx/n,my=sy/n;let sxx=0,sxy=0,syy=0;for(let i=0;i<n;i++){const dx=x[i]-mx,dy=y[i]-my;sxx+=dx*dx;sxy+=dx*dy;syy+=dy*dy;}const beta=sxy/sxx;const sse=syy-beta*sxy;const se=Math.sqrt((sse/(n-2))/sxx);const t=beta/se;return{beta,se,t,p:pFromT(t),meanX:mx,meanY:my};}
function diff(x,y,cond=(v)=>v===1){let n0=0,n1=0,s0=0,s1=0,ss0=0,ss1=0;for(let i=0;i<y.length;i++){if(cond(x[i])){n1++;s1+=y[i];ss1+=y[i]*y[i];}else{n0++;s0+=y[i];ss0+=y[i]*y[i];}}const m0=s0/n0,m1=s1/n1;const v0=(ss0-s0*s0/n0)/(n0-1),v1=(ss1-s1*s1/n1)/(n1-1);const est=m1-m0;const se=Math.sqrt(v0/n0+v1/n1);return{diff:est,se,t:est/se,p:pFromT(est/se),n0,n1,m0,m1};}
const fm=readFileMeta();const cols=fm.row_groups[0].columns.map(c=>c.meta_data);const data={};for(let i=1;i<cols.length;i++){data[cols[i].path_in_schema[0]]=decodeColumn(cols[i]);}const y=data.pfs_months;const names=Object.keys(data).filter(n=>n!=='"'pfs_months');const info={};for(const n of names){const x=data[n];const uniq=new Set();let min=Infinity,max=-Infinity,sum=0;for(const v of x){min=Math.min(min,v);max=Math.max(max,v);sum+=v;if(uniq.size<20)uniq.add(v);}info[n]={binary:uniq.size===2&&uniq.has(0)&&uniq.has(1), min,max,mean:sum/x.length, unique:[...uniq].slice(0,10)};}
const all=ols(names.map(n=>({name:n,values:data[n]})),y);console.log('full model r2',all.r2,'df',all.df);for(const r of all.rows.slice().sort((a,b)=>Math.abs(b.t)-Math.abs(a.t)).slice(0,25)){console.log(r.name,'beta',r.beta,'se',r.se,'t',r.t,'p',r.p,'binary',info[r.name].binary,'mean',info[r.name].mean,'range',info[r.name].min,info[r.name].max);}
