import pandas as pd
from scipy import stats

df = pd.read_parquet('dataset.parquet')
print('shape', df.shape)
print('columns', ','.join(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('missing', int(df.isna().sum().sum()))
print('outcome')
print(df['pfs_months'].describe().to_string())
features=[c for c in df.columns if c"'!='"'pfs_months']
summary=[]
for c in features:
    s=df[c]
    nun=s.nunique()
    vals=sorted(s.unique().tolist())[:10] if nun<=10 else []
    if nun==2 and set(s.unique()).issubset({0,1,False,True}):
        g1=df.loc[s==1,'pfs_months']; g0=df.loc[s==0,'pfs_months']
        eff=float(g1.mean()-g0.mean())
        p=float(stats.ttest_ind(g1,g0,equal_var=False).pvalue)
        summary.append((c,'binary',nun,float(s.mean()),eff,p))
    else:
        r,p=stats.pearsonr(s,df['pfs_months'])
        slope=float(r*df['pfs_months'].std(ddof=1)/s.std(ddof=1))
        summary.append((c,'numeric',nun,float(s.mean()),slope,float(p)))
summary_sorted=sorted(summary,key=lambda x:x[5])
print('top main effects by p')
for row in summary_sorted[:30]:
    print(row)
print('feature summary first 20')
for row in summary[:20]:
    print(row)
