+
+while (iterations.length < 25) {
+  const item = mainEffects[iterations.length % mainEffects.length];
+  const dir = item.effect > 0 ? "higher" : "lower";
+  const h = hyp(`Exploratory follow-up: ${describeFeature(item.feature)} is associated with ${dir} pfs_months in a univariable model.`);
+  addIteration([h], [
+    analysisRecord(
+      h.id,
+      `Univariable OLS coefficient for ${item.feature} was ${item.effect.toFixed(4)} months, p=${formatP(item.p)}.`,
+      round(item.effect),
+      item.p,
+      `OLS: pfs_months ~ ${item.feature}`,
+      { q_value_bh_across_main_effects: item.q }
+    ),
+  ]);
