+const features = Object.keys(data).filter((c) => c !== "pfs_months");
+const stats = Object.fromEntries(features.map((c) => [c, summary(data[c])]));
+const yStats = summary(y);
+const binaryFeatures = features.filter((c) => stats[c].nunique === 2 && stats[c].min === 0 && stats[c].max === 1);
+const continuousFeatures = features.filter((c) => !(stats[c].nunique === 2 && stats[c].min === 0 && stats[c].max === 1));
+
+const mainEffects = features.map((c) => {
+  const model = ols(y, [data[c]]);
+  const effect = model.beta[1];
+  const p = model.p[1];
+  return { feature: c, effect, p, t: model.t[1], stat: stats[c] };
+}).sort((a, b) => Math.abs(b.t) - Math.abs(a.t));
+const mainQs = bh(mainEffects);
+for (let i = 0; i < mainEffects.length; i++) mainEffects[i].q = mainQs[i];
+
+const topMainFeatures = mainEffects.slice(0, 12).map((r) => r.feature);
+const adjusted = ols(y, topMainFeatures.map((c) => data[c]));
+const adjustedEffects = topMainFeatures.map((c, i) => ({
+  feature: c,
+  effect: adjusted.beta[i + 1],
+  p: adjusted.p[i + 1],
+  t: adjusted.t[i + 1],
