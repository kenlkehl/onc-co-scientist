+    rec = analysisRecord(
+      h.id,
+      `Stratified slopes for ${inter.b} were ${fit1.beta[1].toFixed(4)} months in ${inter.a}=1 and ${fit0.beta[1].toFixed(4)} months in ${inter.a}=0; interaction-model difference=${inter.effect.toFixed(4)}, p=${formatP(inter.p)}.`,
+      round(inter.effect),
+      inter.p,
+      `Stratified OLS by ${inter.a}; confirm with OLS: pfs_months ~ ${inter.a} + ${inter.b} + ${inter.a}:${inter.b}`,
