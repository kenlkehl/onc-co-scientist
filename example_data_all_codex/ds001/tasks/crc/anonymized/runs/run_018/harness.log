+
+const supportedMain = mainEffects.filter((r) => r.p < 0.05);
+const supportedInteractions = interactions.filter((r) => r.p < 0.05);
+const fdrMain = mainEffects.filter((r) => r.q < 0.05);
+const fdrInteractions = interactions.filter((r) => r.q < 0.05);
+
+const lines = [];
+lines.push("Analysis summary for ds001_crc");
+lines.push("");
+lines.push(`Dataset contained ${yStats.n} patients, ${features.length} de-identified features, and outcome pfs_months (mean ${yStats.mean.toFixed(3)}, SD ${yStats.sd.toFixed(3)}, range ${yStats.min.toFixed(3)}-${yStats.max.toFixed(3)}).`);
