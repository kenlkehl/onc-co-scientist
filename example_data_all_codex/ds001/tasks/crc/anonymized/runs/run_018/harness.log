+    const div = M[c][c];
+    for (let j = c; j <= n; j++) M[c][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === c) continue;
+      const f = M[r][c];
+      if (f === 0) continue;
+      for (let j = c; j <= n; j++) M[r][j] -= f * M[c][j];
