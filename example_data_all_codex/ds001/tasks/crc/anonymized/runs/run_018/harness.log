+  const extra = binaryFeatures.includes(c) ? meanByBinary(data[c], y) : null;
+  const detail = extra
+    ? `Mean pfs_months was ${extra.mean1.toFixed(3)} for ${c}=1 versus ${extra.mean0.toFixed(3)} for ${c}=0.`
+    : `The univariable slope for ${c} was ${item.effect.toFixed(4)} months per unit.`;
+  addIteration([h], [
+    analysisRecord(
+      h.id,
+      `${detail} Univariable OLS effect=${item.effect.toFixed(4)}, p=${formatP(item.p)}.`,
+      round(item.effect),
+      item.p,
+      `OLS: pfs_months ~ ${c}`,
+      { q_value_bh_across_main_effects: item.q }
+    ),
+  ]);
+}
+
+const adjKeep = adjustedEffects.slice().sort((a, b) => Math.abs(b.t) - Math.abs(a.t)).slice(0, 4);
+for (const item of adjKeep) {
+  const direction = item.effect > 0 ? "higher" : "lower";
+  const h = hyp(`After adjustment for the strongest screened features (${topMainFeatures.join(", ")}), ${describeFeature(item.feature)} remains associated with ${direction} pfs_months.`, "refined");
+  addIteration([h], [
