let pos=0;
const CT={STOP:0,TRUE:1,FALSE:2,BYTE:3,I16:4,I32:5,I64:6,DOUBLE:7,BINARY:8,LIST:9,SET:10,MAP:11,STRUCT:12};
function readVarint(){let shift=0n, result=0n; while(true){const byte=buf[pos++]; result |= BigInt(byte&0x7f)<<shift; if((byte&0x80)===0) break; shift+=7n;} return result;}
function zigzag(n){return (n>>1n) "'^ (-(n&1n));}
function num(n){const x=Number(n); return x;}
function readI(){return num(zigzag(readVarint()));}
function readBin(){const len=Number(readVarint()); const out=buf.slice(pos,pos+len); pos+=len; return out;}
function parseVal(type){
 if(type===CT.TRUE) return true; if(type===CT.FALSE) return false;
 if(type===CT.BYTE) return buf.readInt8(pos++);
 if(type===CT.I16 || type===CT.I32 || type===CT.I64) return readI();
 if(type===CT.DOUBLE){const v=buf.readDoubleLE(pos); pos+=8; return v;}
 if(type===CT.BINARY) return readBin();
 if(type===CT.LIST || type===CT.SET){const h=buf[pos++]; let size=h>>4; const et=h&0x0f; if(size===15) size=Number(readVarint()); const arr=[]; for(let i=0;i<size;i++) arr.push(parseVal(et)); return arr;}
 if(type===CT.MAP){const size=Number(readVarint()); if(size===0) return []; const types=buf[pos++]; const kt=(types>>4)&0x0f, vt=types&0x0f; const arr=[]; for(let i=0;i<size;i++) arr.push([parseVal(kt),parseVal(vt)]); return arr;}
 if(type===CT.STRUCT) return parseStruct();
 throw new Error('"'bad type '+type+' at '+pos);
}
function parseStruct(){let last=0; const o={}; while(true){const h=buf[pos++]; if(h===0) break; const type=h&0x0f; const mod=h>>4; let fid; if(mod===0) fid=readI(); else fid=last+mod; last=fid; o[fid]=parseVal(type);} return o;}
