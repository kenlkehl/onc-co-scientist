+const topBinaryNegative = mainEffects.find((r) => r.effect < 0 && binaryFeatures.includes(r.feature));
+const topContinuousPositive = mainEffects.find((r) => r.effect > 0 && continuousFeatures.includes(r.feature));
+const topContinuousNegative = mainEffects.find((r) => r.effect < 0 && continuousFeatures.includes(r.feature));
