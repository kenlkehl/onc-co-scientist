+    const highMask = high.map((v) => v === 1);
+    const lowFit = ols(subset(y, low), [subset(data[inter.a], low)]);
+    const highFit = ols(subset(y, highMask), [subset(data[inter.a], highMask)]);
+    const diff = highFit.beta[1] - lowFit.beta[1];
+    const direction = diff > 0 ? "more positive" : "more negative";
+    h = hyp(`The association between ${inter.a} and pfs_months is ${direction} in the highest quartile of ${inter.b} than in the lowest quartile of ${inter.b}.`, "refined");
