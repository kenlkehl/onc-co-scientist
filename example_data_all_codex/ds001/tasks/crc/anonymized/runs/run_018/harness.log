+    analysisRecord(
+      h.id,
+      `Highest-quartile ${c} mean pfs_months was ${means.mean1.toFixed(3)} versus ${means.mean0.toFixed(3)} below the quartile; effect=${fit.beta[1].toFixed(4)}, p=${formatP(fit.p[1])}.`,
