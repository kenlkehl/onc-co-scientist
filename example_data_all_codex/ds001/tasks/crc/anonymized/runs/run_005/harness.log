"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs = require('fs');
const b = fs.readFileSync('dataset.parquet');
function u32le(off){return b.readUInt32LE(off)}
console.log('magic start', b.slice(0,4).toString('ascii'), 'magic end', b.slice(b.length-4).toString('ascii'));
const flen = u32le(b.length-8);
const start = b.length-8-flen;
console.log({fileSize:b.length, footerLen:flen, footerStart:start});
const TYPES = ['STOP','TRUE','FALSE','BYTE','I16','I32','I64','DOUBLE','BINARY','LIST','SET','MAP','STRUCT','FLOAT'];
class R{
  constructor(buf, off=0, end=buf.length){this.buf=buf;this.off=off;this.end=end;this.last=[];}
  byte(){return this.buf[this.off++];}
  varint(){let shift=0, res=0n; while(true){const c=this.byte(); res |= BigInt(c&0x7f)<<BigInt(shift); if((c&0x80)===0) break; shift+=7;} return res;}
  zigzag(n){return (n>>1n) "'^ (-(n&1n));}
  i32(){return Number(this.zigzag(this.varint()));}
  i64(){return this.zigzag(this.varint());}
  str(){const len=Number(this.varint()); const s=this.buf.slice(this.off,this.off+len).toString('"'utf8'); this.off+=len; return s;}
  bin(){const len=Number(this.varint()); const s=this.buf.slice(this.off,this.off+len); this.off+=len; return s;}
