function snappy(src){let ip=0;function v(){let x=0,s=0;while(true){let c=src[ip++];x|=(c&0x7f)<<s;if(!(c&0x80))break;s+=7;}return x;}const olen=v();const out=Buffer.allocUnsafe(olen);let op=0;while(ip<src.length){let tag=src[ip++],typ=tag&3;if(typ===0){let len=tag>>2;if(len<60)len+=1;else{let n=len-59;len=0;for(let i=0;i<n;i++)len|=src[ip++]<<(8*i);len+=1;}src.copy(out,op,ip,ip+len);ip+=len;op+=len;}else{let len,off;if(typ===1){len=((tag>>2)&7)+4;off=((tag&0xe0)<<3)|src[ip++];}else if(typ===2){len=(tag>>2)+1;off=src[ip]|(src[ip+1]<<8);ip+=2;}else{len=(tag>>2)+1;off=(src[ip]|(src[ip+1]<<8)|(src[ip+2]<<16)|(src[ip+3]<<24))>>>0;ip+=4;}for(let i=0;i<len;i++)out[op+i]=out[op-off+i];op+=len;}}return out;}
