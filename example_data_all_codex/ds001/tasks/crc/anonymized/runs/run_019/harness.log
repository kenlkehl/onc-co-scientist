function matInv(A){const n=A.length;let M=A.map((row,i)=>row.concat(Array.from({length:n},(_,j)=>i===j?1:0)));for(let i=0;i<n;i++){let piv=i;for(let r=i+1;r<n;r++)if(Math.abs(M[r][i])>Math.abs(M[piv][i]))piv=r;if(Math.abs(M[piv][i])<1e-12)throw Error('"'singular');if(piv"'!==i){let tmp=M[i];M[i]=M[piv];M[piv]=tmp;}let div=M[i][i];for(let j=0;j<2*n;j++)M[i][j]/=div;for(let r=0;r<n;r++){if(r===i)continue;let f=M[r][i];if(f)for(let j=0;j<2*n;j++)M[r][j]-=f*M[i][j];}}return M.map(row=>row.slice(n));}
function ols(vars,y){const n=y.length,k=vars.length+1;let XtX=Array.from({length:k},()=>Array(k).fill(0)),Xty=Array(k).fill(0);for(let i=0;i<n;i++){let row=[1];for(const v of vars)row.push(v[i]);let yi=y[i];for(let a=0;a<k;a++){Xty[a]+=row[a]*yi;for(let b=0;b<k;b++)XtX[a][b]+=row[a]*row[b];}}const inv=matInv(XtX);let beta=Array(k).fill(0);for(let a=0;a<k;a++)for(let b=0;b<k;b++)beta[a]+=inv[a][b]*Xty[b];let sse=0;for(let i=0;i<n;i++){let pred=beta[0];for(let j=0;j<vars.length;j++)pred+=beta[j+1]*vars[j][i];let e=y[i]-pred;sse+=e*e;}let sig2=sse/(n-k),se=[],p=[];for(let j=0;j<k;j++){se[j]=Math.sqrt(Math.max(0,sig2*inv[j][j]));p[j]=pnorm2(beta[j]/se[j]);}return {beta,se,p};}
