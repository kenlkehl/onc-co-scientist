let interactions=[];for(let a=0;a<topMain.length;a++){for(let b=a+1;b<topMain.length;b++){const n1=topMain[a],n2=topMain[b],x=data[n1],z=data[n2];const xz=new Float64Array(y.length);for(let i=0;i<y.length;i++)xz[i]=x[i]*z[i];let fit;try{fit=ols([x,z,xz],y);}catch(e){continue;}interactions.push({a:n1,b:n2,beta:fit.beta[3],se:fit.se[3],t:fit.beta[3]/fit.se[3],p:fit.p[3]});}}
