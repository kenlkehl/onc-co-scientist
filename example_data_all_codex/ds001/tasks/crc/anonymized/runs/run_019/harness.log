function linreg1(x,y){const n=y.length;let sx=0,sy=0,sxx=0,sxy=0;for(let i=0;i<n;i++){const xi=x[i],yi=y[i];sx+=xi;sy+=yi;sxx+=xi*xi;sxy+=xi*yi;}const mx=sx/n,my=sy/n;const Sxx=sxx-sx*sx/n;const Sxy=sxy-sx*sy/n;const beta=Sxy/Sxx;const alpha=my-beta*mx;let sse=0;for(let i=0;i<n;i++){const e=y[i]-alpha-beta*x[i];sse+=e*e;}const sig2=sse/(n-2);const se=Math.sqrt(sig2/Sxx);const t=beta/se;return {beta,se,t,p:pnorm2(t),meanX:mx,meanY:my};}
