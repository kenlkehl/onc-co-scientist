function matInv(A){const n=A.length;let M=A.map((row,i)=>row.concat(Array.from({length:n},(_,j)=>i===j?1:0)));for(let i=0;i<n;i++){let piv=i;for(let r=i+1;r<n;r++)if(Math.abs(M[r][i])>Math.abs(M[piv][i]))piv=r;if(Math.abs(M[piv][i])<1e-12)throw Error('"'singular');if(piv"'!==i){const tmp=M[i];M[i]=M[piv];M[piv]=tmp;}const div=M[i][i];for(let j=0;j<2*n;j++)M[i][j]/=div;for(let r=0;r<n;r++){if(r===i)continue;const f=M[r][i];if(f!==0)for(let j=0;j<2*n;j++)M[r][j]-=f*M[i][j];}}return M.map(row=>row.slice(n));}
