function diff(outcomeName, groupName, groupVal, predName){let x=D[predName],g=D[groupName];let s1=0,n1=0,s0=0,n0=0;for(let i=0;i<n;i++)if(g[i]===groupVal){if(x[i]===1){s1+=y[i];n1++;}else if(x[i]===0){s0+=y[i];n0++;}}return {group:"'`${groupName}=${groupVal}`,pred:predName,n1,n0,m1:s1/n1,m0:s0/n0,diff:s1/n1-s0/n0};}
function slopeBy(groupName, groupVal, xName){let x=D[xName],g=D[groupName];let sx=0,sy=0,c=0;for(let i=0;i<n;i++)if(g[i]===groupVal){sx+=x[i];sy+=y[i];c++;}let mx=sx/c,my=sy/c,sxx=0,sxy=0;for(let i=0;i<n;i++)if(g[i]===groupVal){let dx=x[i]-mx;sxx+=dx*dx;sxy+=dx*(y[i]-my);}return {group:`${groupName}=${groupVal}`,x:xName,n:c,slope:sxy/sxx,meanY:my};}
