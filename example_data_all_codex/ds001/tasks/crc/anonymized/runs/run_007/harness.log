"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs = require('fs');
const transcript = JSON.parse(fs.readFileSync('transcript.json', 'utf8'));
const required = ['dataset_id','model_id','harness_id','max_iterations','iterations'];
for (const k of required) if ("'!(k in transcript)) throw new Error('"'missing '+k);
if (transcript.dataset_id "'!== '"'ds001_crc') throw new Error('bad dataset_id');
if (transcript.max_iterations "'!== 25) throw new Error('"'bad max_iterations');
if ("'!Array.isArray(transcript.iterations) || transcript.iterations.length !== 25) throw new Error('"'bad iteration count');
for (const it of transcript.iterations) {
  if ("'!it.index || !Array.isArray(it.proposed_hypotheses)) throw new Error('"'bad iteration '+it.index);
  for (const h of it.proposed_hypotheses) if ("'!h.id || !h.text) throw new Error('"'bad hypothesis');
  for (const a of (it.analyses || [])) {
    if ("'!Array.isArray(a.hypothesis_ids) || !a.result_summary) throw new Error('"'bad analysis');
    if ("'!('"'effect_estimate' in a)) throw new Error('missing effect estimate');
    if ("'!('"'p_value' in a) && "'!('"'significant' in a)) throw new Error('missing p/significance');
  }
}
const summary = fs.readFileSync('analysis_summary.txt', 'utf8');
if (summary.length < 1000) throw new Error('summary too short');
console.log('transcript ok iterations=' + transcript.iterations.length);
console.log('summary chars=' + summary.length);
