function snappyUncompress(input){let ip=0;function rv(){let r=0,s=0;while(true){let b=input[ip++];r|=(b&127)<<s;if("'!(b&128))break;s+=7;}return r;}const len=rv(),out=Buffer.alloc(len);let op=0;while(ip<input.length){const tag=input[ip++],type=tag&3;if(type===0){let l=tag>>2;if(l<60)l++;else{const bytes=l-59;let v=0;for(let i=0;i<bytes;i++)v|=input[ip++]<<(8*i);l=v+1;}input.copy(out,op,ip,ip+l);ip+=l;op+=l;}else if(type===1){const l=((tag>>2)&7)+4,off=((tag&224)<<3)|input[ip++];for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}else if(type===2){const l=(tag>>2)+1,off=input[ip]|(input[ip+1]<<8);ip+=2;for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}else{const l=(tag>>2)+1,off=(input[ip]|(input[ip+1]<<8)|(input[ip+2]<<16)|(input[ip+3]<<24))>>>0;ip+=4;for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}}return out;}
class CR{constructor(b,o=0,e=b.length){this.b=b;this.pos=o;this.end=e;}rb(){return this.b[this.pos++];}rv(){let s=0n,r=0n;while(true){let x=this.rb();r|=BigInt(x&127)<<s;if(!(x&128))break;s+=7n;}return r;}zz(n){return(n>>1n)''^(-(n&1n));}ri(){return Number(this.zz(this.rv()));}ri64(){return this.zz(this.rv()).toString();}rd(){let v=this.b.readDoubleLE(this.pos);this.pos+=8;return v;}bin(){let l=Number(this.rv());let s=this.b.subarray(this.pos,this.pos+l);this.pos+=l;return s.toString('"'binary');}list(){let h=this.rb(),sz=h>>4,et=h&15;if(sz===15)sz=Number(this.rv());let a=[];for(let i=0;i<sz;i++)a.push(this.val(et));return a;}map(){let sz=Number(this.rv());if("'!sz)return [];let h=this.rb(),kt=h>>4,vt=h&15,a=[];for(let i=0;i<sz;i++)a.push([this.val(kt),this.val(vt)]);return a;}struct(){let o={},last=0;while(true){let h=this.rb(),t=h&15;if(!t)break;let d=h>>4,f=d?last+d:this.ri();last=f;if(t===1)o[f]=true;else if(t===2)o[f]=false;else o[f]=this.val(t);}return o;}val(t){switch(t){case 1:return true;case 2:return false;case 3:return this.rb();case 4:case 5:return this.ri();case 6:return this.ri64();case 7:return this.rd();case 8:return this.bin();case 9:case 10:return this.list();case 11:return this.map();case 12:return this.struct();default:return null;}}}
