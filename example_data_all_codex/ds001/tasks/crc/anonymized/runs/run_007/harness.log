function snappyUncompress(input){let ip=0;function readVarint(){let result=0,shift=0;while(true){let b=input[ip++];result|=(b&0x7f)<<shift;if((b&0x80)===0)break;shift+=7;}return result;}const len=readVarint();const out=Buffer.alloc(len);let op=0;while(ip<input.length){const tag=input[ip++];const type=tag&3;if(type===0){let l=tag>>2;if(l<60)l=l+1;else{const bytes=l-59;let v=0;for(let i=0;i<bytes;i++)v|=input[ip++]<<(8*i);l=v+1;}input.copy(out,op,ip,ip+l);ip+=l;op+=l;}else if(type===1){const l=((tag>>2)&7)+4;const off=((tag&0xe0)<<3)|input[ip++];for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}else if(type===2){const l=(tag>>2)+1;const off=input[ip]|(input[ip+1]<<8);ip+=2;for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}else{const l=(tag>>2)+1;const off=(input[ip]|(input[ip+1]<<8)|(input[ip+2]<<16)|(input[ip+3]<<24))>>>0;ip+=4;for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}}return out;}
class CR{constructor(buf,offset=0,end=buf.length){this.b=buf;this.pos=offset;this.end=end;}rb(){return this.b[this.pos++];}rv(){let s=0n,r=0n;while(true){let x=this.rb();r|=BigInt(x&127)<<s;if("'!(x&128))break;s+=7n;}return r;}zz(n){return(n>>1n)''^(-(n&1n));}ri(){return Number(this.zz(this.rv()));}ri64(){return this.zz(this.rv()).toString();}rd(){let v=this.b.readDoubleLE(this.pos);this.pos+=8;return v;}bin(){let l=Number(this.rv());let s=this.b.subarray(this.pos,this.pos+l);this.pos+=l;return s.toString('"'binary');}list(){let h=this.rb(),sz=h>>4,et=h&15;if(sz===15)sz=Number(this.rv());let a=[];for(let i=0;i<sz;i++)a.push(this.val(et));return a;}map(){let sz=Number(this.rv());if(sz===0)return [];let h=this.rb(),kt=h>>4,vt=h&15;let a=[];for(let i=0;i<sz;i++)a.push([this.val(kt),this.val(vt)]);return a;}struct(){let o={},last=0;while(true){let h=this.rb(),t=h&15;if(t===0)break;let d=h>>4;let fid=d?last+d:this.ri();last=fid;if(t===1)o[fid]=true;else if(t===2)o[fid]=false;else o[fid]=this.val(t);}return o;}val(t){switch(t){case 0:return null;case 1:return true;case 2:return false;case 3:return this.rb();case 4:case 5:return this.ri();case 6:return this.ri64();case 7:return this.rd();case 8:return this.bin();case 9:case 10:return this.list();case 11:return this.map();case 12:return this.struct();default:throw new Error('compact type '+t);}}}
function readMeta(){const n=parquet.length,fl=parquet.readUInt32LE(n-8);return new CR(parquet,n-8-fl,n-8).struct();}
const meta=readMeta(); const columns=meta[4][0][1].map(ch=>ch[3][3][0]);
function decodePlainDict(buf,type,nvals){const vals=new Array(nvals);let p=0;for(let i=0;i<nvals;i++){if(type===2){vals[i]=Number(buf.readBigInt64LE(p));p+=8;}else if(type===5){vals[i]=buf.readDoubleLE(p);p+=8;}else if(type===6){let l=buf.readInt32LE(p);p+=4;vals[i]=buf.subarray(p,p+l).toString('utf8');p+=l;}else if(type===1){vals[i]=buf.readInt32LE(p);p+=4;}else throw new Error('type '+type);}return vals;}
function decodeHybrid(buf,pos,count,bitWidth){let out=new Array(count), outn=0;function readVar(){let r=0,shift=0;while(true){let b=buf[pos++];r|=(b&127)<<shift;if("'!(b&128))break;shift+=7;}return r;}while(outn<count){let header=readVar();if((header&1)===0){let run=header>>>1;let bytes=Math.ceil(bitWidth/8);let val=0;for(let i=0;i<bytes;i++)val|=buf[pos++]<<(8*i);for(let j=0;j<run && outn<count;j++)out[outn++]=val;}else{let groups=header>>>1;let total=groups*8;for(let k=0;k<total && outn<count;k++){let val=0;for(let b=0;b<bitWidth;b++){let bitIndex=k*bitWidth+b;let by=buf[pos+(bitIndex>>3)]; if(by & (1<<(bitIndex&7))) val|=1<<b;}out[outn++]=val;}pos += Math.ceil(total*bitWidth/8);}}return out;}
