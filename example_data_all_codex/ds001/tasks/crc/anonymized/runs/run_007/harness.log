const fs = require('fs');
const path = 'dataset.parquet';
const buf = fs.readFileSync(path);
const n = buf.length;
const footerLen = buf.readUInt32LE(n-8);
const meta = buf.subarray(n-8-footerLen, n-8);
let pos=0;
function readByte(){ if(pos>=meta.length) throw new Error('eof'); return meta[pos++]; }
function readVarint(){ let shift=0n, result=0n; while(true){ const b=readByte(); result |= BigInt(b & 0x7f) << shift; if((b & 0x80)===0) break; shift += 7n; } return result; }
function zigzag(n){ return (n >> 1n) "'^ (-(n & 1n)); }
function readI32(){ return Number(zigzag(readVarint())); }
function readI64(){ return zigzag(readVarint()).toString(); }
function readDouble(){ const v = meta.readDoubleLE(pos); pos += 8; return v; }
function readBinary(){ const len = Number(readVarint()); const s = meta.subarray(pos,pos+len); pos += len; return s.toString('"'utf8'); }
function skip(type){ readVal(type); }
function readList(){ const h=readByte(); let size=h>>4; const et=h&0x0f; if(size===15) size=Number(readVarint()); const arr=[]; for(let i=0;i<size;i++) arr.push(readVal(et)); return arr; }
function readMap(){ const size=Number(readVarint()); if(size===0) return []; const ktvt=readByte(); const kt=(ktvt>>4)&0x0f, vt=ktvt&0x0f; const arr=[]; for(let i=0;i<size;i++) arr.push([readVal(kt),readVal(vt)]); return arr; }
function readStruct(){ const obj={}; let last=0; while(true){ const h=readByte(); const type=h&0x0f; if(type===0) break; const delta=h>>4; let fid; if(delta===0) fid=readI32(); else fid=last+delta; last=fid; if(type===1){ obj[fid]=true; } else if(type===2){ obj[fid]=false; } else { obj[fid]=readVal(type); } } return obj; }
function readVal(type){ switch(type){ case 0:return null; case 1:return true; case 2:return false; case 3:return readByte(); case 4:return readI32(); case 5:return readI32(); case 6:return readI64(); case 7:return readDouble(); case 8:return readBinary(); case 9: case 10: return readList(); case 11:return readMap(); case 12:return readStruct(); default: throw new Error('unknown type '+type+' at '+pos); } }
const root=readStruct();
