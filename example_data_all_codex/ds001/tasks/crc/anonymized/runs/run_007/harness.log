function dict(buf,type,n){let vals=[],p=0;for(let i=0;i<n;i++){if(type===2){vals.push(Number(buf.readBigInt64LE(p)));p+=8;}else if(type===5){vals.push(buf.readDoubleLE(p));p+=8;}else if(type===6){let l=buf.readInt32LE(p);p+=4;vals.push(buf.subarray(p,p+l).toString('"'utf8'));p+=l;}else{vals.push(buf.readInt32LE(p));p+=4;}}return vals;}
function hybrid(buf,pos,count,bw){let out=[];function rv(){let r=0,s=0;while(true){let b=buf[pos++];r|=(b&127)<<s;if("'!(b&128))break;s+=7;}return r;}while(out.length<count){let h=rv();if((h&1)===0){let run=h>>>1,bytes=Math.ceil(bw/8),v=0;for(let i=0;i<bytes;i++)v|=buf[pos++]<<(8*i);for(let j=0;j<run&&out.length<count;j++)out.push(v);}else{let groups=h>>>1,total=groups*8;for(let k=0;k<total&&out.length<count;k++){let v=0;for(let b=0;b<bw;b++){let bi=k*bw+b;if(buf[pos+(bi>>3)]&(1<<(bi&7)))v|=1<<b;}out.push(v);}pos+=Math.ceil(total*bw/8);}}return out;}
function readCol(name){let idx=cols.indexOf(name),md=meta[4][0][1][idx][3],type=md[1],total=Number(md[5]),offset=Number(md[11]||md[9]),r=new CR(parquet,offset),ph=r.struct(),d=[];if(ph[1]===2){d=dict(snappyUncompress(parquet.subarray(r.pos,r.pos+ph[3])),type,ph[7][1]);offset=r.pos+ph[3];}let vals=[];while(vals.length<total){let pr=new CR(parquet,offset),h=pr.struct(),dec=snappyUncompress(parquet.subarray(pr.pos,pr.pos+h[3])),p=0,def=dec.readInt32LE(0);p=4+def;if(h[5][2]===8||h[5][2]===2){let bw=dec[p++];for(let ix of hybrid(dec,p,h[5][1],bw))vals.push(d[ix]);}else vals.push(...dict(dec.subarray(p),type,h[5][1]));offset=pr.pos+h[3];}return vals;}
