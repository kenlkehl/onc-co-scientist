function mean(a){let s=0;for(let v of a)s+=v;return s/a.length;}function variance(a,m=mean(a)){let s=0;for(let v of a){let d=v-m;s+=d*d;}return s/(a.length-1);}function erf(x){const sign=x<0?-1:1; x=Math.abs(x); const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911; const t=1/(1+p*x); const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x); return sign*y;}function normalP(t){let z=Math.abs(t); let tail=0.5*(1-erf(z/Math.SQRT2)); let p=2*tail; if(p===0 && z<40) p=1e-300; if(z>=40) p=1e-300; return p;}function invMat(A){const n=A.length;let M=A.map((row,i)=>row.concat(Array.from({length:n},(_,j)=>i===j?1:0)));for(let i=0;i<n;i++){let piv=i;for(let r=i+1;r<n;r++)if(Math.abs(M[r][i])>Math.abs(M[piv][i]))piv=r;if(Math.abs(M[piv][i])<1e-12)throw new Error('singular');if(piv"'!==i){let tmp=M[i];M[i]=M[piv];M[piv]=tmp;}let div=M[i][i];for(let c=0;c<2*n;c++)M[i][c]/=div;for(let r=0;r<n;r++){if(r===i)continue;let f=M[r][i];if(f!==0)for(let c=0;c<2*n;c++)M[r][c]-=f*M[i][c];}}return M.map(row=>row.slice(n));}
function ols(cols){const p=cols.length+1;let XtX=Array.from({length:p},()=>Array(p).fill(0));let Xty=Array(p).fill(0);let yy=0;for(let i=0;i<n;i++){let xs=[1];for(let c of cols)xs.push(c[i]);let yi=y[i];yy+=yi*yi;for(let a=0;a<p;a++){Xty[a]+=xs[a]*yi;for(let b=0;b<=a;b++)XtX[a][b]+=xs[a]*xs[b];}}for(let a=0;a<p;a++)for(let b=0;b<a;b++)XtX[b][a]=XtX[a][b];let inv=invMat(XtX);let beta=Array(p).fill(0);for(let i=0;i<p;i++)for(let j=0;j<p;j++)beta[i]+=inv[i][j]*Xty[j];let sse=yy;for(let j=0;j<p;j++)sse-=beta[j]*Xty[j];let mse=sse/(n-p);let se=beta.map((_,j)=>Math.sqrt(Math.max(0,mse*inv[j][j])));let t=beta.map((b,j)=>b/se[j]);let pvals=t.map(normalP);return {beta,se,t,p:pvals,mse,sse};}
