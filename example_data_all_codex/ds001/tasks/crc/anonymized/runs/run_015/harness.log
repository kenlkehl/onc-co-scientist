+        off = src[p] | (src[p + 1] << 8);
+        p += 2;
+      } else {
+        n = (tag >> 2) + 1;
+        off = (src[p] | (src[p + 1] << 8) | (src[p + 2] << 16) | (src[p + 3] << 24)) >>> 0;
+        p += 4;
+      }
+      for (let i = 0; i < n; i++) out[op + i] = out[op - off + i];
+      op += n;
+    }
+  }
+  if (op !== len) throw new Error(`Snappy length mismatch ${op} != ${len}`);
+  return out;
+}
+
+function pageAt(pos) {
+  const d = new CompactDecoder(file, pos);
+  const header = d.struct();
+  return { header, bodyOffset: d.p };
+}
+
+function decodeBody(offset, size, codec) {
+  const comp = file.slice(offset, offset + size);
+  if (codec === 0) return comp;
+  if (codec === 1) return snappyDecode(comp);
+  throw new Error(`unsupported codec ${codec}`);
+}
+
+function readHybrid(buf, pos, bitWidth, count) {
+  const out = [];
+  let p = pos;
+  const bytesForValue = Math.ceil(bitWidth / 8);
+  function readVarint() {
+    let shift = 0, result = 0;
+    while (true) {
+      const b = buf[p++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  while (out.length < count && p < buf.length) {
+    const header = readVarint();
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < bytesForValue; i++) value |= buf[p++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const totalValues = groups * 8;
+      let bits = 0, available = 0;
+      for (let i = 0; i < totalValues; i++) {
+        while (available < bitWidth) {
+          bits |= buf[p++] << available;
+          available += 8;
+        }
+        if (out.length < count) out.push(bits & ((1 << bitWidth) - 1));
+        bits >>>= bitWidth;
+        available -= bitWidth;
+      }
+    }
+  }
+  if (out.length !== count) throw new Error(`decoded ${out.length}, expected ${count}`);
+  return out;
+}
+
+function dictValues(body, parquetType, n) {
+  const out = new Array(n);
+  let p = 0;
+  for (let i = 0; i < n; i++) {
+    if (parquetType === 5) {
+      out[i] = body.readDoubleLE(p);
+      p += 8;
+    } else if (parquetType === 2) {
+      out[i] = Number(body.readBigInt64LE(p));
+      p += 8;
+    } else if (parquetType === 1) {
+      out[i] = body.readInt32LE(p);
+      p += 4;
+    } else {
+      throw new Error(`unsupported parquet type ${parquetType}`);
+    }
+  }
+  return out;
+}
+
+function readColumn(chunk, schemaElement) {
+  const md = chunk[3];
+  const name = md[3][0];
+  if (name === "patient_id") return null;
+  const codec = md[4];
+  const nValues = md[5];
+  const dictPage = pageAt(md[11]);
+  const dictHeader = dictPage.header[7];
+  const dictBody = decodeBody(dictPage.bodyOffset, dictPage.header[3], codec);
+  const dict = dictValues(dictBody, md[1], dictHeader[1]);
+  const values = [];
+  let pos = md[9];
+  while (values.length < nValues) {
+    const pg = pageAt(pos);
+    const body = decodeBody(pg.bodyOffset, pg.header[3], codec);
+    const n = pg.header[5][1];
+    let p = 0;
+    if (schemaElement[3] === 1) {
+      const defLen = body.readUInt32LE(p);
+      p += 4 + defLen;
+    }
+    const bitWidth = body[p++];
+    const indices = readHybrid(body, p, bitWidth, n);
+    for (const idx of indices) values.push(dict[idx]);
+    pos = pg.bodyOffset + pg.header[3];
+  }
+  return values;
+}
+
+function loadData() {
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const footer = file.slice(file.length - 8 - footerLen, file.length - 8);
+  const meta = new CompactDecoder(footer).struct();
+  const schema = meta[2];
+  const chunks = meta[4][0][1];
+  const data = {};
+  for (let i = 0; i < chunks.length; i++) {
+    const name = chunks[i][3][3][0];
+    if (name === "patient_id") continue;
+    data[name] = readColumn(chunks[i], schema[i + 1]);
+  }
+  return data;
+}
+
+function mean(a) {
+  let s = 0;
+  for (const x of a) s += x;
+  return s / a.length;
+}
+function variance(a, m = mean(a)) {
+  let s = 0;
+  for (const x of a) {
+    const d = x - m;
+    s += d * d;
+  }
+  return s / (a.length - 1);
+}
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741;
+  const a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t) * Math.exp(-x * x);
+  return sign * y;
+}
+function normalP(absZ) {
+  if (absZ > 38) return 0;
+  const cdf = 0.5 * (1 + erf(absZ / Math.SQRT2));
+  return Math.max(0, Math.min(1, 2 * (1 - cdf)));
+}
+function simpleRegression(x, y) {
+  const n = y.length;
+  const mx = mean(x), my = mean(y);
+  let sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx, dy = y[i] - my;
+    sxx += dx * dx;
+    sxy += dx * dy;
+    syy += dy * dy;
+  }
+  const beta = sxy / sxx;
+  const sse = syy - beta * sxy;
+  const mse = sse / (n - 2);
+  const se = Math.sqrt(mse / sxx);
+  const t = beta / se;
+  return { beta, se, t, p: normalP(Math.abs(t)), r2: 1 - sse / syy };
+}
+function groupDifference(x, y) {
+  const one = [], zero = [];
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) one.push(y[i]);
+    else if (x[i] === 0) zero.push(y[i]);
+  }
+  const m1 = mean(one), m0 = mean(zero);
+  const v1 = variance(one, m1), v0 = variance(zero, m0);
+  const diff = m1 - m0;
+  const se = Math.sqrt(v1 / one.length + v0 / zero.length);
+  return { diff, se, t: diff / se, p: normalP(Math.abs(diff / se)), mean1: m1, mean0: m0, n1: one.length, n0: zero.length };
+}
+function invert(mat) {
+  const n = mat.length;
+  const a = mat.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(a[r][i]) > Math.abs(a[pivot][i])) pivot = r;
+    if (Math.abs(a[pivot][i]) < 1e-12) throw new Error("singular matrix");
+    if (pivot !== i) [a[i], a[pivot]] = [a[pivot], a[i]];
+    const div = a[i][i];
+    for (let c = 0; c < 2 * n; c++) a[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = a[r][i];
+      for (let c = 0; c < 2 * n; c++) a[r][c] -= f * a[i][c];
+    }
+  }
+  return a.map(row => row.slice(n));
+}
+function ols(columns, y) {
+  const n = y.length, p = columns.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let j = 0; j < p; j++) {
+      const xj = columns[j][i];
+      xty[j] += xj * y[i];
+      for (let k = 0; k < p; k++) xtx[j][k] += xj * columns[k][i];
+    }
+  }
+  const inv = invert(xtx);
+  const beta = Array(p).fill(0);
+  for (let j = 0; j < p; j++) for (let k = 0; k < p; k++) beta[j] += inv[j][k] * xty[k];
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += beta[j] * columns[j][i];
+    const e = y[i] - pred;
+    sse += e * e;
+  }
+  const sigma2 = sse / (n - p);
+  const se = inv.map((row, j) => Math.sqrt(Math.max(0, sigma2 * row[j])));
+  const pvals = beta.map((b, j) => normalP(Math.abs(b / se[j])));
+  return { beta, se, p: pvals };
+}
+function countUnique(a) {
+  const s = new Set(a);
+  return s.size;
+}
+function zscore(a) {
+  const m = mean(a);
+  const sd = Math.sqrt(variance(a, m));
+  return a.map(x => (x - m) / sd);
+}
+function fmt(x, digits = 4) {
+  if (x === 0) return "0";
+  if (Math.abs(x) < 0.0001) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+const data = loadData();
+const y = data.pfs_months;
+const ones = Array(y.length).fill(1);
+const unique = {};
+for (const name of Object.keys(data)) if (name !== "pfs_months") unique[name] = countUnique(data[name]);
+
+function mainAnalysis(id, feature, type, text) {
+  let stat, effect, summary;
+  if (type === "binary") {
+    stat = groupDifference(data[feature], y);
+    effect = stat.diff;
+    summary = `Mean pfs_months was ${fmt(stat.mean1)} for ${feature}=1 (n=${stat.n1}) versus ${fmt(stat.mean0)} for ${feature}=0 (n=${stat.n0}); difference=${fmt(effect)} months, p=${fmt(stat.p, 6)}.`;
+  } else {
+    stat = simpleRegression(data[feature], y);
+    effect = stat.beta;
+    summary = `Simple OLS pfs_months ~ ${feature}: slope=${fmt(effect, 6)} months per one-unit increase, p=${fmt(stat.p, 6)}, R2=${fmt(stat.r2, 6)}.`;
+  }
+  return {
+    hypothesis: { id, text, kind: id === "h1" ? "novel" : "refined" },
+    analysis: {
+      hypothesis_ids: [id],
+      code: type === "binary" ? `Welch mean comparison: pfs_months by ${feature}=1 vs 0` : `OLS: pfs_months ~ ${feature}`,
+      result_summary: summary,
+      p_value: stat.p,
+      effect_estimate: effect,
+      significant: stat.p < 0.05
+    }
+  };
+}
+
+function transformed(feature) {
+  return unique[feature] > 8 ? zscore(data[feature]) : data[feature];
+}
+function interactionAnalysis(id, aName, bName, text, scaleText) {
+  const a = transformed(aName);
+  const b = transformed(bName);
+  const product = a.map((v, i) => v * b[i]);
+  const fit = ols([ones, a, b, product], y);
+  const effect = fit.beta[3];
+  const p = fit.p[3];
+  return {
+    hypothesis: { id, text, kind: "refined" },
+    analysis: {
+      hypothesis_ids: [id],
+      code: `OLS: pfs_months ~ ${aName} + ${bName} + ${aName}:${bName}; ${scaleText}`,
+      result_summary: `Interaction coefficient for ${aName}:${bName} was ${fmt(effect, 6)} months (${scaleText}), p=${fmt(p, 6)}.`,
+      p_value: p,
+      effect_estimate: effect,
+      significant: p < 0.05
+    }
+  };
+}
+
+const planned = [
+  mainAnalysis("h1", "feature_041", "continuous", "Higher `feature_041` is associated with longer `pfs_months`; each one-unit increase in `feature_041` increases mean progression-free survival."),
+  mainAnalysis("h2", "feature_025", "continuous", "Higher ordinal `feature_025` values are associated with shorter `pfs_months`; each one-level increase in `feature_025` decreases mean progression-free survival."),
+  mainAnalysis("h3", "feature_036", "binary", "Patients with `feature_036=1` have lower mean `pfs_months` than patients with `feature_036=0`."),
+  mainAnalysis("h4", "feature_043", "binary", "Patients with `feature_043=1` have higher mean `pfs_months` than patients with `feature_043=0`."),
+  mainAnalysis("h5", "feature_056", "continuous", "Higher `feature_056` is associated with shorter `pfs_months`; each one-unit increase in `feature_056` decreases mean progression-free survival."),
+  mainAnalysis("h6", "feature_050", "continuous", "Higher `feature_050` is associated with longer `pfs_months`; each one-unit increase in `feature_050` increases mean progression-free survival."),
+  mainAnalysis("h7", "feature_001", "binary", "Patients with `feature_001=1` have lower mean `pfs_months` than patients with `feature_001=0`."),
+  mainAnalysis("h8", "feature_015", "binary", "Patients with `feature_015=1` have lower mean `pfs_months` than patients with `feature_015=0`."),
+  mainAnalysis("h9", "feature_029", "continuous", "Higher `feature_029` is associated with shorter `pfs_months`; each one-unit increase in `feature_029` decreases mean progression-free survival."),
+  mainAnalysis("h10", "feature_066", "binary", "Patients with `feature_066=1` have lower mean `pfs_months` than patients with `feature_066=0`."),
+  mainAnalysis("h11", "feature_042", "binary", "Patients with `feature_042=1` have higher mean `pfs_months` than patients with `feature_042=0`."),
+  mainAnalysis("h12", "feature_039", "continuous", "Higher `feature_039` is associated with shorter `pfs_months`; each one-unit increase in `feature_039` decreases mean progression-free survival."),
+  mainAnalysis("h13", "feature_028", "continuous", "Higher `feature_028` is associated with shorter `pfs_months`; each one-unit increase in `feature_028` decreases mean progression-free survival."),
+  mainAnalysis("h14", "feature_012", "continuous", "Higher `feature_012` is associated with shorter `pfs_months`; each one-unit increase in `feature_012` decreases mean progression-free survival."),
+  mainAnalysis("h15", "feature_031", "binary", "Patients with `feature_031=1` have lower mean `pfs_months` than patients with `feature_031=0`."),
