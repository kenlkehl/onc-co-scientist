+const summary = [
+  "Analysis summary for ds001_crc",
+  "",
+  `I analyzed 50,000 records with 73 de-identified features and the continuous outcome pfs_months. The outcome mean was ${fmt(yMean)} months with SD ${fmt(ySd)} months. P-values are large-sample two-sided tests; p=0 means the value was below numerical display precision.`,
