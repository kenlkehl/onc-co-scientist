+function resultLine() {
+  const lines = [];
+  lines.push(`rows ${y.length} features ${featureNames.length}`);
+  lines.push(`pfs mean ${mean(y).toFixed(4)} sd ${Math.sqrt(variance(y)).toFixed(4)} min ${Math.min(...y).toFixed(4)} max ${Math.max(...y).toFixed(4)}`);
+  lines.push("\nFEATURE SUMMARIES");
+  for (const n of featureNames) {
+    const s = featureSummaries[n];
+    lines.push(`${n}\tunique=${s.nUnique}\tmean=${s.mean.toFixed(6)}\tsd=${s.sd.toFixed(6)}\tmin=${s.min}\tmax=${s.max}\tcounts=${JSON.stringify(s.counts.slice(0, 8))}`);
+  }
+  lines.push("\nTOP MAIN EFFECTS");
+  for (const r of main.slice(0, 40)) lines.push(`${r.name}\tbeta=${r.beta}\tt=${r.t}\tp=${r.p}\tr2=${r.r2}\tunique=${r.unique}`);
+  lines.push("\nTOP BINARY GROUP DIFFERENCES");
+  for (const r of binaryDiffs.slice(0, 25)) lines.push(`${r.name}\tdiff=${r.diff}\tp=${r.p}\tn1=${r.n1}\tn0=${r.n0}\tmean1=${r.mean1}\tmean0=${r.mean0}`);
+  lines.push("\nTOP INTERACTIONS");
+  for (const r of interactions.slice(0, 40)) lines.push(`${r.a}*${r.b}\tbeta=${r.beta}\tt=${r.t}\tp=${r.p}`);
+  lines.push("\nTOP SUBGROUP INTERACTIONS");
+  for (const r of subgroupEffects.slice(0, 40)) lines.push(`${r.pred} by ${r.mod}\tbeta=${r.beta}\tt=${r.t}\tp=${r.p}`);
+  return lines.join("\n");
+}
+
+fs.writeFileSync("probe_results.txt", resultLine());
+console.log(resultLine().split("\n").slice(0, 80).join("\n"));

