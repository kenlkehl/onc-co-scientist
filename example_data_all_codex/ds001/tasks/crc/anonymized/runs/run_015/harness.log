+  interactionAnalysis("h19", "feature_001", "feature_015", "The combined association of `feature_001=1` and `feature_015=1` with `pfs_months` is less negative than the sum of their separate adverse associations.", "binary-by-binary product"),
+  interactionAnalysis("h20", "feature_043", "feature_066", "The positive association between `feature_043=1` and `pfs_months` is smaller among patients with `feature_066=1` than among patients with `feature_066=0`.", "binary-by-binary product"),
