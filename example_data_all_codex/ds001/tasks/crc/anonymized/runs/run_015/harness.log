+  const h = it.proposed_hypotheses[0];
+  const a = it.analyses[0];
+  return `Iteration ${it.index} (${h.id}): ${h.text} Result: effect=${fmt(a.effect_estimate, 6)}, p=${fmt(a.p_value, 6)}, ${a.significant ? "supported" : "not supported"}.`;
