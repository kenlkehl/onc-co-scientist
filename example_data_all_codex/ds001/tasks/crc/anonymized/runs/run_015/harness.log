+const featureNames = Object.keys(data).filter(k => k !== "pfs_months");
+const featureSummaries = {};
+for (const name of featureNames) {
+  const vals = data[name];
+  const counts = uniqueCounts(vals);
+  featureSummaries[name] = {
+    nUnique: counts.length,
+    counts: counts.slice(0, 20),
+    mean: mean(vals),
+    sd: Math.sqrt(variance(vals)),
+    min: counts[0][0],
+    max: counts[counts.length - 1][0]
+  };
+}
+
+const main = featureNames.map(name => {
+  const x = data[name];
+  const s = simpleRegression(x, y);
+  return { name, beta: s.beta, p: s.p, t: s.t, r2: s.r2, unique: featureSummaries[name].nUnique };
+}).sort((a, b) => Math.abs(b.t) - Math.abs(a.t));
+
+const binaryNames = featureNames.filter(n => {
+  const c = uniqueCounts(data[n]);
+  return c.length === 2 && c[0][0] === 0 && c[1][0] === 1;
+});
+const ordinalNames = featureNames.filter(n => {
+  const c = uniqueCounts(data[n]);
+  return c.length > 2 && c.length <= 8 && c[0][0] === 0;
+});
+const continuousNames = featureNames.filter(n => featureSummaries[n].nUnique > 8);
+
+const binaryDiffs = binaryNames.map(name => ({ name, ...groupDifference(data[name], y) }))
+  .sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff));
+
+const topForInteractions = main.slice(0, 25).map(x => x.name);
+const interactions = [];
+for (let i = 0; i < topForInteractions.length; i++) {
+  for (let j = i + 1; j < topForInteractions.length; j++) {
+    const aName = topForInteractions[i], bName = topForInteractions[j];
+    const a = featureSummaries[aName].nUnique > 8 ? zscore(data[aName]) : data[aName];
+    const b = featureSummaries[bName].nUnique > 8 ? zscore(data[bName]) : data[bName];
+    const inter = interactionColumns(a, b);
+    try {
+      const fit = ols([Array(y.length).fill(1), a, b, inter], y);
+      interactions.push({ a: aName, b: bName, beta: fit.beta[3], se: fit.se[3], p: fit.p[3], t: fit.beta[3] / fit.se[3] });
+    } catch (e) {}
+  }
+}
+interactions.sort((a, b) => Math.abs(b.t) - Math.abs(a.t));
+
+const subgroupEffects = [];
+for (const modName of topForInteractions.slice(0, 20)) {
+  const mod = featureSummaries[modName].nUnique > 8 ? data[modName].map(v => v >= mean(data[modName]) ? 1 : 0) : binarizePositive(data[modName]);
+  for (const predName of topForInteractions.slice(0, 20)) {
+    if (predName === modName) continue;
+    const pred = featureSummaries[predName].nUnique > 8 ? zscore(data[predName]) : data[predName];
+    const inter = interactionColumns(pred, mod);
+    try {
+      const fit = ols([Array(y.length).fill(1), pred, mod, inter], y);
+      subgroupEffects.push({ pred: predName, mod: modName, beta: fit.beta[3], p: fit.p[3], t: fit.beta[3] / fit.se[3] });
+    } catch (e) {}
+  }
+}
+subgroupEffects.sort((a, b) => Math.abs(b.t) - Math.abs(a.t));
+
+function resultLine() {
+  const lines = [];
+  lines.push(`rows ${y.length} features ${featureNames.length}`);
+  lines.push(`pfs mean ${mean(y).toFixed(4)} sd ${Math.sqrt(variance(y)).toFixed(4)} min ${Math.min(...y).toFixed(4)} max ${Math.max(...y).toFixed(4)}`);
+  lines.push("\nFEATURE SUMMARIES");
+  for (const n of featureNames) {
+    const s = featureSummaries[n];
+    lines.push(`${n}\tunique=${s.nUnique}\tmean=${s.mean.toFixed(6)}\tsd=${s.sd.toFixed(6)}\tmin=${s.min}\tmax=${s.max}\tcounts=${JSON.stringify(s.counts.slice(0, 8))}`);
+  }
+  lines.push("\nTOP MAIN EFFECTS");
+  for (const r of main.slice(0, 40)) lines.push(`${r.name}\tbeta=${r.beta}\tt=${r.t}\tp=${r.p}\tr2=${r.r2}\tunique=${r.unique}`);
+  lines.push("\nTOP BINARY GROUP DIFFERENCES");
+  for (const r of binaryDiffs.slice(0, 25)) lines.push(`${r.name}\tdiff=${r.diff}\tp=${r.p}\tn1=${r.n1}\tn0=${r.n0}\tmean1=${r.mean1}\tmean0=${r.mean0}`);
+  lines.push("\nTOP INTERACTIONS");
+  for (const r of interactions.slice(0, 40)) lines.push(`${r.a}*${r.b}\tbeta=${r.beta}\tt=${r.t}\tp=${r.p}`);
+  lines.push("\nTOP SUBGROUP INTERACTIONS");
+  for (const r of subgroupEffects.slice(0, 40)) lines.push(`${r.pred} by ${r.mod}\tbeta=${r.beta}\tt=${r.t}\tp=${r.p}`);
+  return lines.join("\n");
+}
+
+fs.writeFileSync("probe_results.txt", resultLine());
+console.log(resultLine().split("\n").slice(0, 80).join("\n"));

