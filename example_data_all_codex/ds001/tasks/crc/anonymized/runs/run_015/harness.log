+    else if (x[i] === referenceValue) b.push(y[i]);
+  }
+  const ma = mean(a), mb = mean(b), va = variance(a, ma), vb = variance(b, mb);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const diff = ma - mb;
