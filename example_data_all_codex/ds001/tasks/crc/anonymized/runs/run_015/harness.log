+class CompactDecoder {
+  constructor(buf, pos = 0) {
+    this.b = buf;
+    this.p = pos;
+    this.stack = [0];
+  }
+  byte() { return this.b[this.p++]; }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const x = this.byte();
+      result |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  int() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
