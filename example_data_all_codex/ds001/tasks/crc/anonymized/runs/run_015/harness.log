+].join("\n");
+
+fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2) + "\n");
+fs.writeFileSync("analysis_summary.txt", summary + "\n");
+
+const check = JSON.parse(fs.readFileSync("transcript.json", "utf8"));
+for (const key of ["dataset_id", "model_id", "harness_id", "max_iterations", "iterations"]) {
+  if (!(key in check)) throw new Error(`missing ${key}`);
+}
+if (check.max_iterations !== 25 || check.iterations.length !== 25) throw new Error("iteration count mismatch");
+console.log(`Wrote transcript.json and analysis_summary.txt with ${check.iterations.length} iterations.`);

