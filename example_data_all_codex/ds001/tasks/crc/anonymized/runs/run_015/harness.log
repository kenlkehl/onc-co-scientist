+  interactionAnalysis("h22", "feature_043", "feature_042", "The positive association between `feature_043=1` and `pfs_months` is larger among patients with `feature_042=1` than among patients with `feature_042=0`.", "binary-by-binary product"),
+  interactionAnalysis("h23", "feature_041", "feature_036", "The positive association between higher `feature_041` and `pfs_months` is weaker among patients with `feature_036=1` than among patients with `feature_036=0`.", "`feature_041` standardized to one SD; `feature_036` binary"),
+  interactionAnalysis("h24", "feature_001", "feature_029", "The adverse association between `feature_001=1` and `pfs_months` is weaker as `feature_029` increases.", "`feature_029` standardized to one SD; `feature_001` binary"),
