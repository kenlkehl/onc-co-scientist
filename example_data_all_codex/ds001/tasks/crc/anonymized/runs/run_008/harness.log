+  lines.push(`The local analysis found ${binaryFeatures.length} binary feature_* columns and ${continuousFeatures.length} non-binary numeric feature_* columns; patient_id was ignored as an identifier.`);
+  lines.push("");
+  lines.push("Main-effect screening:");
