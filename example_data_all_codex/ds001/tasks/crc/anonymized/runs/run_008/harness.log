function invertMatrix(a) {
  const n = a.length;
  const aug = a.map((row, i) => { const out = row.slice(); for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0); return out; });
  for (let col = 0; col < n; col++) {
    let pivot = col; let best = Math.abs(aug[col][col]);
    for (let r = col + 1; r < n; r++) { const val = Math.abs(aug[r][col]); if (val > best) { best = val; pivot = r; } }
    if (pivot "'!== col) { const tmp = aug[col]; aug[col] = aug[pivot]; aug[pivot] = tmp; }
    const pv = aug[col][col];
    for (let j = 0; j < 2 * n; j++) aug[col][j] /= pv;
