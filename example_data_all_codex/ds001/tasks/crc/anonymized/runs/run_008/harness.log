+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      let v = 0;
+      for (let i = 0; i < byteWidth; i++) v |= buf[state.pos++] << (8 * i);
+      const limit = Math.min(runLen, count - out.length);
+      for (let i = 0; i < limit; i++) out.push(v);
+    } else {
+      const groups = header >> 1;
+      unpackBitPacked(buf, state, bitWidth, groups, count - out.length, out);
+    }
+  }
