+  for (const v of values) {
+    s += v;
+    ss += v * v;
+    if (v < min) min = v;
+    if (v > max) max = v;
+    if (!capExceeded) {
+      uniques.set(v, (uniques.get(v) || 0) + 1);
+      if (uniques.size > 200) {
+        capExceeded = true;
+        uniques.clear();
+      }
