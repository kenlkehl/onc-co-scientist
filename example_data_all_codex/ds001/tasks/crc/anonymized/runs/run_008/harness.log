+    mean: m,
+    sd: Math.sqrt(Math.max(0, (ss - s * s / n) / (n - 1))),
+    min,
+    max,
+    uniqueCount: capExceeded ? null : uniques.size,
+    values: capExceeded ? null : Array.from(uniques.keys()).sort((a, b) => a - b),
