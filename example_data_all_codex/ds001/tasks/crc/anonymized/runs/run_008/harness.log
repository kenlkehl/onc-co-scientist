+
+function readPageHeader(offset) {
+  const reader = new CompactReader(parquet, offset);
+  const header = reader.readStruct({
+    1: ["type", function () { return this.readI32(); }],
+    2: ["uncompressed_page_size", function () { return this.readI32(); }],
+    3: ["compressed_page_size", function () { return this.readI32(); }],
+    4: ["crc", function () { return this.readI32(); }],
+    5: ["data_page_header", readDataPageHeader],
+    7: ["dictionary_page_header", readDictionaryPageHeader],
+    8: ["data_page_header_v2", readDataPageHeaderV2],
