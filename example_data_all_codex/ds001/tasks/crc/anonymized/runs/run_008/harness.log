+    if (header.type === 2) {
+      dictionary = readPlainValues(payload, meta.type, header.dictionary_page_header.num_values);
+      if (columnName === DEBUG_COLUMN) console.error(`${columnName} dictionary values=${JSON.stringify(dictionary.slice(0, 10))}`);
+    } else if (header.type === 0) {
+      const dph = header.data_page_header;
