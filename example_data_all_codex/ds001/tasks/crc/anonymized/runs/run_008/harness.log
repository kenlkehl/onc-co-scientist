+function decodeRleHybrid(buf, start, bitWidth, count) {
+  const out = [];
+  const state = { pos: start };
+  if (bitWidth === 0) {
+    while (out.length < count) out.push(0);
+    return out;
+  }
+  const byteWidth = Math.ceil(bitWidth / 8);
+  while (out.length < count) {
