+    2: ["num_nulls", function () { return this.readI32(); }],
+    3: ["num_rows", function () { return this.readI32(); }],
+    4: ["encoding", function () { return this.readI32(); }],
+    5: ["definition_levels_byte_length", function () { return this.readI32(); }],
+    6: ["repetition_levels_byte_length", function () { return this.readI32(); }],
