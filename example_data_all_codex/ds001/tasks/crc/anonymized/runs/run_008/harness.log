+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
+
+  for (const row of topBinPairs.slice(0, 4)) {
+    const direction = (Math.abs(row.simpleAWhenB1) > Math.abs(row.simpleAWhenB0))
+      ? `stronger when ${row.b}=1 than when ${row.b}=0`
+      : `weaker when ${row.b}=1 than when ${row.b}=0`;
+    const text = `The association between ${row.a} and pfs_months is ${direction}.`;
+    const diff = row.simpleAWhenB1 - row.simpleAWhenB0;
+    addIteration(text, {
+      code: `stratified_difference_in_means_for_${row.a}_within_${row.b}_strata`,
+      result_summary: `${row.a}=1 vs 0 changed mean pfs_months by ${round(row.simpleAWhenB0, 4)} months when ${row.b}=0 and by ${round(row.simpleAWhenB1, 4)} months when ${row.b}=1; difference of simple effects=${round(diff, 4)} months, matching the interaction p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: diff,
+      significant: row.p < 0.05,
+    });
+  }
+
+  for (const row of mixedInteractions.slice(0, 3)) {
+    const direction = row.beta > 0 ? "more positive" : "more negative";
+    const text = `The slope of pfs_months with respect to ${row.continuous} is ${direction} among patients with ${row.binary}=1 than among patients with ${row.binary}=0.`;
+    addIteration(text, {
+      code: `ordinary_least_squares_pfs_months_on_${row.binary}_${row.continuous}_and_interaction`,
+      result_summary: `OLS model with centered ${row.continuous}, ${row.binary}, and their product estimated interaction slope=${round(row.beta, 5)} months per ${row.continuous} unit, SE=${round(row.se, 5)}, z=${round(row.z, 3)}, p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
+
+  for (const row of threeWayInteractions.slice(0, 2)) {
+    const direction = row.beta > 0 ? "higher" : "lower";
+    const text = `The two-way interaction between ${row.a} and ${row.b} is ${direction} when ${row.c}=1 than when ${row.c}=0.`;
+    addIteration(text, {
+      code: `ordinary_least_squares_three_way_interaction_${row.a}_${row.b}_${row.c}`,
+      result_summary: `OLS model containing all main effects, two-way terms, and ${row.a}:${row.b}:${row.c} estimated three-way interaction=${round(row.beta, 4)} months, SE=${round(row.se, 4)}, z=${round(row.z, 3)}, p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
+
+  while (iterations.length < MAX_ITERATIONS) {
+    const row = adjusted[iterations.length % adjusted.length];
+    const direction = row.beta > 0 ? "higher" : "lower";
