+      ? `Patients with ${row.name}=1 have ${direction} mean pfs_months than patients with ${row.name}=0.`
+      : `Each one-unit increase in ${row.name} is associated with ${direction} pfs_months.`;
+    const result = row.isBinary
+      ? `Mean pfs_months was ${round(row.m1, 3)} for ${row.name}=1 (n=${row.n1}) versus ${round(row.m0, 3)} for ${row.name}=0 (n=${row.n0}); difference=${round(row.effect, 4)} months, two-sided normal/Welch p=${formatP(row.p)}.`
+      : `Univariate linear regression of pfs_months on ${row.name} gave slope=${round(row.effect, 5)} months per unit, z=${round(row.z, 3)}, p=${formatP(row.p)}.`;
