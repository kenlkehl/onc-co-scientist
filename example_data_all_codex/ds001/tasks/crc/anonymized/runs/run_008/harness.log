+const fs = require("fs");
+
+const DATASET_ID = "ds001_crc";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-local-js-parquet@1.0.0";
+const MAX_ITERATIONS = 25;
+
+const parquet = fs.readFileSync("dataset.parquet");
+const DEBUG_COLUMN = process.env.DEBUG_COLUMN || "";
+const ONLY_COLUMN = process.env.ONLY_COLUMN || "";
+
+const CT = {
+  STOP: 0,
+  BOOL_TRUE: 1,
+  BOOL_FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buffer, pos = 0) {
+    this.buffer = buffer;
+    this.pos = pos;
+  }
+
+  readByte() {
+    return this.buffer[this.pos++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return result;
+      shift += 7n;
+    }
+  }
+
+  readI32() {
+    const n = this.readVarint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  readI64() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readDouble() {
+    const v = this.buffer.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.buffer.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  readString() {
+    return this.readBinary().toString("utf8");
+  }
+
+  readList(itemReader) {
+    const h = this.readByte();
+    let size = h >> 4;
+    const elemType = h & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const out = [];
+    for (let i = 0; i < size; i++) out.push(itemReader.call(this, elemType));
+    return out;
+  }
+
+  readStruct(decoders) {
+    const obj = {};
+    let lastField = 0;
+    while (true) {
+      const hb = this.readByte();
+      const type = hb & 0x0f;
+      if (type === CT.STOP) break;
+      const delta = hb >> 4;
+      const fieldId = delta === 0 ? this.readI32() : lastField + delta;
+      lastField = fieldId;
+      if (decoders[fieldId]) {
+        const [name, reader] = decoders[fieldId];
+        obj[name] = reader.call(this, type);
+      } else {
+        this.skip(type);
+      }
+    }
+    return obj;
+  }
+
+  skip(type) {
+    switch (type) {
+      case CT.BOOL_TRUE:
+      case CT.BOOL_FALSE:
+        return;
+      case CT.BYTE:
+        this.pos += 1;
+        return;
+      case CT.I16:
+      case CT.I32:
+        this.readI32();
+        return;
+      case CT.I64:
+        this.readI64();
+        return;
+      case CT.DOUBLE:
+        this.pos += 8;
+        return;
+      case CT.BINARY: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case CT.LIST:
+      case CT.SET: {
+        const h = this.readByte();
+        let size = h >> 4;
+        const elemType = h & 0x0f;
+        if (size === 15) size = Number(this.readVarint());
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
+      case CT.MAP: {
+        const size = Number(this.readVarint());
+        if (size === 0) return;
+        const h = this.readByte();
+        const keyType = h >> 4;
+        const valType = h & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(keyType);
+          this.skip(valType);
+        }
+        return;
+      }
+      case CT.STRUCT:
+        this.readStruct({});
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+    }
+  }
+}
+
+function readSchemaElement(type) {
+  return this.readStruct({
+    1: ["type", function () { return this.readI32(); }],
+    2: ["type_length", function () { return this.readI32(); }],
+    3: ["repetition_type", function () { return this.readI32(); }],
+    4: ["name", function () { return this.readString(); }],
+    5: ["num_children", function () { return this.readI32(); }],
+    6: ["converted_type", function () { return this.readI32(); }],
+    7: ["scale", function () { return this.readI32(); }],
+    8: ["precision", function () { return this.readI32(); }],
+    9: ["field_id", function () { return this.readI32(); }],
+    10: ["logicalType", function (t) { this.skip(t); return true; }],
+  });
+}
+
+function readColumnMetaData(type) {
+  return this.readStruct({
+    1: ["type", function () { return this.readI32(); }],
+    2: ["encodings", function () { return this.readList(function () { return this.readI32(); }); }],
+    3: ["path_in_schema", function () { return this.readList(function () { return this.readString(); }); }],
+    4: ["codec", function () { return this.readI32(); }],
+    5: ["num_values", function () { return Number(this.readI64()); }],
+    6: ["total_uncompressed_size", function () { return Number(this.readI64()); }],
+    7: ["total_compressed_size", function () { return Number(this.readI64()); }],
+    8: ["key_value_metadata", function (t) { this.skip(t); return true; }],
+    9: ["data_page_offset", function () { return Number(this.readI64()); }],
+    10: ["index_page_offset", function () { return Number(this.readI64()); }],
+    11: ["dictionary_page_offset", function () { return Number(this.readI64()); }],
+    12: ["statistics", function (t) { this.skip(t); return true; }],
+    13: ["encoding_stats", function (t) { this.skip(t); return true; }],
+    14: ["bloom_filter_offset", function () { return Number(this.readI64()); }],
+    15: ["bloom_filter_length", function () { return this.readI32(); }],
+    16: ["size_statistics", function (t) { this.skip(t); return true; }],
+  });
+}
+
+function readColumnChunk(type) {
+  return this.readStruct({
+    1: ["file_path", function () { return this.readString(); }],
+    2: ["file_offset", function () { return Number(this.readI64()); }],
+    3: ["meta_data", readColumnMetaData],
+    4: ["offset_index_offset", function () { return Number(this.readI64()); }],
+    5: ["offset_index_length", function () { return this.readI32(); }],
+    6: ["column_index_offset", function () { return Number(this.readI64()); }],
+    7: ["column_index_length", function () { return this.readI32(); }],
+    8: ["crypto_metadata", function (t) { this.skip(t); return true; }],
+    9: ["encrypted_column_metadata", function () { return this.readBinary(); }],
+  });
+}
+
+function readRowGroup(type) {
+  return this.readStruct({
+    1: ["columns", function () { return this.readList(readColumnChunk); }],
+    2: ["total_byte_size", function () { return Number(this.readI64()); }],
+    3: ["num_rows", function () { return Number(this.readI64()); }],
+    4: ["sorting_columns", function (t) { this.skip(t); return true; }],
+    5: ["file_offset", function () { return Number(this.readI64()); }],
+    6: ["total_compressed_size", function () { return Number(this.readI64()); }],
+    7: ["ordinal", function () { return Number(this.readI64()); }],
+  });
+}
+
+function readKeyValue(type) {
+  return this.readStruct({
+    1: ["key", function () { return this.readString(); }],
+    2: ["value", function () { return this.readString(); }],
+  });
+}
+
+function readFileMetaData() {
+  const footerLen = parquet.readInt32LE(parquet.length - 8);
+  const reader = new CompactReader(parquet, parquet.length - 8 - footerLen);
+  return reader.readStruct({
+    1: ["version", function () { return this.readI32(); }],
+    2: ["schema", function () { return this.readList(readSchemaElement); }],
+    3: ["num_rows", function () { return Number(this.readI64()); }],
+    4: ["row_groups", function () { return this.readList(readRowGroup); }],
+    5: ["key_value_metadata", function () { return this.readList(readKeyValue); }],
+    6: ["created_by", function () { return this.readString(); }],
+  });
+}
+
