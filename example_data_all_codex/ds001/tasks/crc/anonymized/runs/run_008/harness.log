+    if (pivot !== col) {
+      const tmp = aug[col];
+      aug[col] = aug[pivot];
+      aug[pivot] = tmp;
+    }
+    const pv = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= pv;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  xtx[0][0] = n;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const pred of predictors) row.push(pred[i]);
+    const yi = y[i];
+    yty += yi * yi;
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * yi;
+      for (let k = 0; k <= j; k++) xtx[j][k] += row[j] * row[k];
+    }
+  }
+  for (let j = 0; j < p; j++) for (let k = 0; k < j; k++) xtx[k][j] = xtx[j][k];
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((acc, v, idx) => acc + v * xty[idx], 0));
+  const bxty = beta.reduce((acc, v, idx) => acc + v * xty[idx], 0);
+  const sse = Math.max(0, yty - bxty);
+  const sigma2 = sse / Math.max(1, n - p);
+  const se = inv.map((row, idx) => Math.sqrt(Math.max(0, sigma2 * row[idx])));
+  const t = beta.map((b, idx) => se[idx] > 0 ? b / se[idx] : 0);
+  const pvals = t.map(normalTwoSided);
+  return { beta, se, t, p: pvals, sigma2, df: n - p, sse };
+}
+
+function univariate(y, x, isBinary) {
+  if (isBinary) {
+    let n0 = 0, n1 = 0, s0 = 0, s1 = 0, ss0 = 0, ss1 = 0;
+    for (let i = 0; i < y.length; i++) {
+      if (x[i] === 1) {
+        n1++; s1 += y[i]; ss1 += y[i] * y[i];
+      } else {
+        n0++; s0 += y[i]; ss0 += y[i] * y[i];
+      }
+    }
+    const m0 = s0 / n0;
+    const m1 = s1 / n1;
+    const v0 = Math.max(0, (ss0 - s0 * s0 / n0) / (n0 - 1));
+    const v1 = Math.max(0, (ss1 - s1 * s1 / n1) / (n1 - 1));
+    const se = Math.sqrt(v0 / n0 + v1 / n1);
+    const z = (m1 - m0) / se;
+    return { effect: m1 - m0, p: normalTwoSided(z), z, n0, n1, m0, m1 };
+  }
+  const fit = ols(y, [x]);
+  return { effect: fit.beta[1], p: fit.p[1], z: fit.t[1] };
+}
+
+function binaryGroupMeans(y, a, b) {
+  const cells = {
+    "00": { n: 0, s: 0 },
+    "01": { n: 0, s: 0 },
+    "10": { n: 0, s: 0 },
+    "11": { n: 0, s: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${a[i] === 1 ? 1 : 0}${b[i] === 1 ? 1 : 0}`;
+    cells[key].n++;
+    cells[key].s += y[i];
+  }
+  for (const c of Object.values(cells)) c.mean = c.s / c.n;
+  return cells;
+}
+
+function formatP(p) {
+  if (p <= 1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toPrecision(3);
+}
+
+function round(x, digits = 4) {
+  if (!Number.isFinite(x)) return x;
+  const f = 10 ** digits;
+  return Math.round(x * f) / f;
+}
+
+function makeBinaryCentered(x) {
+  return x.map((v) => v === 1 ? 1 : 0);
+}
+
+function residualize(y, predictors) {
+  const fit = ols(y, predictors);
+  const n = y.length;
+  const out = new Array(n);
+  for (let i = 0; i < n; i++) {
+    let pred = fit.beta[0];
+    for (let j = 0; j < predictors.length; j++) pred += fit.beta[j + 1] * predictors[j][i];
+    out[i] = y[i] - pred;
+  }
+  return { residuals: out, fit };
+}
+
+function percentile(values, q) {
+  const sorted = values.slice().sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] + (sorted[hi] - sorted[lo]) * (pos - lo);
+}
+
+function run() {
+  const meta = readFileMetaData();
+  const columns = meta.row_groups[0].columns;
+  const data = {};
+  const columnTypes = {};
+  for (const chunk of columns) {
+    const name = chunk.meta_data.path_in_schema[0];
+    if (name === "patient_id") continue;
+    data[name] = decodeColumn(chunk);
+    columnTypes[name] = chunk.meta_data.type;
+  }
+
+  const y = data.pfs_months;
+  delete data.pfs_months;
+  const featureNames = Object.keys(data);
+  const ySummary = summarize(y);
+
+  const featureStats = {};
+  const binaryFeatures = [];
+  const continuousFeatures = [];
+  for (const name of featureNames) {
+    const stat = summarize(data[name]);
+    const isBinary = stat.uniqueCount === 2 && stat.values.includes(0) && stat.values.includes(1);
+    stat.isBinary = isBinary;
+    featureStats[name] = stat;
+    if (isBinary) binaryFeatures.push(name);
+    else continuousFeatures.push(name);
+  }
+
+  const univ = featureNames.map((name) => ({
+    name,
+    isBinary: featureStats[name].isBinary,
+    ...univariate(y, data[name], featureStats[name].isBinary),
+  })).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const mainPredictors = featureNames.map((name) => data[name]);
+  const mainFit = ols(y, mainPredictors);
+  const adjusted = featureNames.map((name, idx) => ({
+    name,
+    beta: mainFit.beta[idx + 1],
+    se: mainFit.se[idx + 1],
+    z: mainFit.t[idx + 1],
+    p: mainFit.p[idx + 1],
+    isBinary: featureStats[name].isBinary,
+  })).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const binaryInteractions = [];
+  for (let i = 0; i < binaryFeatures.length; i++) {
+    const aName = binaryFeatures[i];
+    const a = data[aName];
+    for (let j = i + 1; j < binaryFeatures.length; j++) {
+      const bName = binaryFeatures[j];
+      const b = data[bName];
+      const ab = new Array(y.length);
+      for (let r = 0; r < y.length; r++) ab[r] = a[r] * b[r];
+      try {
+        const fit = ols(y, [a, b, ab]);
+        const cells = binaryGroupMeans(y, a, b);
