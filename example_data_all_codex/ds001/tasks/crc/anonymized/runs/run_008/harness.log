+  let capExceeded = false;
+  for (const v of values) {
+    s += v;
+    ss += v * v;
+    if (v < min) min = v;
+    if (v > max) max = v;
+    if (!capExceeded) {
+      uniques.set(v, (uniques.get(v) || 0) + 1);
+      if (uniques.size > 200) {
+        capExceeded = true;
+        uniques.clear();
+      }
+    }
+  }
+  const m = s / n;
+  return {
+    n,
+    mean: m,
+    sd: Math.sqrt(Math.max(0, (ss - s * s / n) / (n - 1))),
+    min,
+    max,
+    uniqueCount: capExceeded ? null : uniques.size,
+    values: capExceeded ? null : Array.from(uniques.keys()).sort((a, b) => a - b),
+    counts: capExceeded ? null : Object.fromEntries(Array.from(uniques.entries()).map(([k, v]) => [String(k), v])),
