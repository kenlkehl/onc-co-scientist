+function decodeDictionaryDataPage(payload, count, dictionary, columnName = "") {
+  const bitWidth = payload[0];
+  if (columnName === DEBUG_COLUMN) {
+    console.error(`${columnName} dictionary data payload length=${payload.length} count=${count} bitWidth=${bitWidth} first16=${Array.from(payload.subarray(0, 16)).map((v) => v.toString(16).padStart(2, "0")).join(" ")}`);
