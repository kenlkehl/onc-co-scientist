+      case CT.BYTE:
+        this.pos += 1;
+        return;
+      case CT.I16:
+      case CT.I32:
+        this.readI32();
+        return;
+      case CT.I64:
+        this.readI64();
+        return;
+      case CT.DOUBLE:
+        this.pos += 8;
+        return;
+      case CT.BINARY: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
