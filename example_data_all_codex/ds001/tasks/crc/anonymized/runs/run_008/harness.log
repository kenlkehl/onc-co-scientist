+  // The dataset description states no missing values, so these levels are
+  // all-present markers and can be skipped.
+  if (schemaRepetitionByName[columnName] === 1) {
+    const levelByteLength = payload.readInt32LE(0);
+    const valueStart = 4 + levelByteLength;
+    if (columnName === DEBUG_COLUMN) {
