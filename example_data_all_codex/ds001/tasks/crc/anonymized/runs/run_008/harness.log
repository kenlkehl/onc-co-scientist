+          simpleAWhenB1: cells["11"].mean - cells["01"].mean,
+          simpleBWhenA0: cells["01"].mean - cells["00"].mean,
+          simpleBWhenA1: cells["11"].mean - cells["10"].mean,
+        });
+      } catch (err) {
+        // Skip singular combinations, which can occur if two binary columns are redundant.
+      }
+    }
+  }
+  binaryInteractions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  console.error("screening mixed interactions");
+  const mixedInteractions = [];
+  const candidateContinuous = adjusted.filter((x) => !x.isBinary).slice(0, 12).map((x) => x.name);
+  const candidateBinary = binaryFeatures;
+  for (const cName of candidateContinuous) {
+    const c = data[cName];
+    const cMean = featureStats[cName].mean;
+    const centered = c.map((v) => v - cMean);
+    for (const bName of candidateBinary) {
+      const b = data[bName];
+      const bx = new Array(y.length);
+      for (let r = 0; r < y.length; r++) bx[r] = b[r] * centered[r];
+      try {
+        const fit = ols(y, [b, centered, bx]);
+        mixedInteractions.push({
+          continuous: cName,
+          binary: bName,
+          beta: fit.beta[3],
+          se: fit.se[3],
+          z: fit.t[3],
+          p: fit.p[3],
+        });
+      } catch (err) {}
+    }
+  }
+  mixedInteractions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  console.error("screening three-way interactions");
+  const topBinPairs = binaryInteractions.slice(0, 8);
+  const threeWayInteractions = [];
+  for (let i = 0; i < Math.min(4, topBinPairs.length); i++) {
+    const pair = topBinPairs[i];
+    for (const cName of binaryFeatures) {
+      if (cName === pair.a || cName === pair.b) continue;
+      const a = data[pair.a], b = data[pair.b], c = data[cName];
+      const ab = new Array(y.length), ac = new Array(y.length), bc = new Array(y.length), abc = new Array(y.length);
+      for (let r = 0; r < y.length; r++) {
+        ab[r] = a[r] * b[r];
+        ac[r] = a[r] * c[r];
+        bc[r] = b[r] * c[r];
+        abc[r] = a[r] * b[r] * c[r];
+      }
+      try {
+        const fit = ols(y, [a, b, c, ab, ac, bc, abc]);
+        threeWayInteractions.push({
+          a: pair.a,
+          b: pair.b,
+          c: cName,
+          beta: fit.beta[7],
+          se: fit.se[7],
+          z: fit.t[7],
+          p: fit.p[7],
+        });
+      } catch (err) {}
+    }
+  }
+  threeWayInteractions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const summaryRows = {
+    n: y.length,
+    ySummary,
+    binaryFeatures,
+    continuousFeatures,
+    topUnivariate: univ.slice(0, 15),
+    topAdjusted: adjusted.slice(0, 15),
+    topBinaryInteractions: binaryInteractions.slice(0, 15),
+    topMixedInteractions: mixedInteractions.slice(0, 15),
+    topThreeWayInteractions: threeWayInteractions.slice(0, 10),
+  };
+
+  const iterations = [];
+  let hid = 1;
+
+  function addIteration(text, analysis) {
+    const id = `h${hid}`;
+    iterations.push({
+      index: iterations.length + 1,
+      proposed_hypotheses: [{ id, text, kind: iterations.length === 0 ? "novel" : "refined" }],
+      analyses: [{ hypothesis_ids: [id], ...analysis }],
+    });
+    hid++;
+  }
+
+  const topMain = [];
+  for (const row of univ) {
+    if (!topMain.find((r) => r.name === row.name)) topMain.push(row);
+    if (topMain.length >= 6) break;
+  }
+  for (const row of topMain) {
+    const direction = row.effect > 0 ? "higher" : "lower";
+    const text = row.isBinary
+      ? `Patients with ${row.name}=1 have ${direction} mean pfs_months than patients with ${row.name}=0.`
+      : `Each one-unit increase in ${row.name} is associated with ${direction} pfs_months.`;
+    const result = row.isBinary
+      ? `Mean pfs_months was ${round(row.m1, 3)} for ${row.name}=1 (n=${row.n1}) versus ${round(row.m0, 3)} for ${row.name}=0 (n=${row.n0}); difference=${round(row.effect, 4)} months, two-sided normal/Welch p=${formatP(row.p)}.`
+      : `Univariate linear regression of pfs_months on ${row.name} gave slope=${round(row.effect, 5)} months per unit, z=${round(row.z, 3)}, p=${formatP(row.p)}.`;
+    addIteration(text, {
+      code: row.isBinary ? "difference_in_means_with_welch_standard_error" : "ordinary_least_squares_univariate",
+      result_summary: result,
+      p_value: row.p,
+      effect_estimate: row.effect,
+      significant: row.p < 0.05,
+    });
+  }
+
+  const adjustedChosen = [];
+  for (const row of adjusted) {
+    if (!topMain.some((r) => r.name === row.name) && !adjustedChosen.some((r) => r.name === row.name)) adjustedChosen.push(row);
+    if (adjustedChosen.length >= 4) break;
+  }
+  for (const row of adjustedChosen) {
+    const direction = row.beta > 0 ? "higher" : "lower";
+    const text = row.isBinary
+      ? `After adjusting for all other feature_* columns, ${row.name}=1 remains associated with ${direction} pfs_months compared with ${row.name}=0.`
+      : `After adjusting for all other feature_* columns, a one-unit increase in ${row.name} remains associated with ${direction} pfs_months.`;
+    addIteration(text, {
+      code: "ordinary_least_squares_pfs_months_on_all_feature_columns",
+      result_summary: `Multivariable OLS including all 73 feature_* columns estimated coefficient=${round(row.beta, 5)} months for ${row.name}, SE=${round(row.se, 5)}, z=${round(row.z, 3)}, p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
+
+  for (const row of topBinPairs.slice(0, 6)) {
+    const direction = row.beta > 0 ? "more favorable than additive" : "less favorable than additive";
+    const text = `The joint subgroup ${row.a}=1 and ${row.b}=1 has ${direction} pfs_months relative to the additive main effects of ${row.a} and ${row.b}.`;
+    addIteration(text, {
+      code: `ordinary_least_squares_pfs_months_on_${row.a}_${row.b}_and_product`,
+      result_summary: `OLS model pfs_months ~ ${row.a} + ${row.b} + ${row.a}:${row.b} estimated interaction=${round(row.beta, 4)} months (difference-in-differences). Cell means: 00=${round(row.cells["00"].mean, 3)} (n=${row.cells["00"].n}), 10=${round(row.cells["10"].mean, 3)} (n=${row.cells["10"].n}), 01=${round(row.cells["01"].mean, 3)} (n=${row.cells["01"].n}), 11=${round(row.cells["11"].mean, 3)} (n=${row.cells["11"].n}); p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
+
+  for (const row of topBinPairs.slice(0, 4)) {
+    const direction = (Math.abs(row.simpleAWhenB1) > Math.abs(row.simpleAWhenB0))
+      ? `stronger when ${row.b}=1 than when ${row.b}=0`
+      : `weaker when ${row.b}=1 than when ${row.b}=0`;
+    const text = `The association between ${row.a} and pfs_months is ${direction}.`;
+    const diff = row.simpleAWhenB1 - row.simpleAWhenB0;
+    addIteration(text, {
+      code: `stratified_difference_in_means_for_${row.a}_within_${row.b}_strata`,
+      result_summary: `${row.a}=1 vs 0 changed mean pfs_months by ${round(row.simpleAWhenB0, 4)} months when ${row.b}=0 and by ${round(row.simpleAWhenB1, 4)} months when ${row.b}=1; difference of simple effects=${round(diff, 4)} months, matching the interaction p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: diff,
+      significant: row.p < 0.05,
+    });
+  }
+
+  for (const row of mixedInteractions.slice(0, 3)) {
+    const direction = row.beta > 0 ? "more positive" : "more negative";
+    const text = `The slope of pfs_months with respect to ${row.continuous} is ${direction} among patients with ${row.binary}=1 than among patients with ${row.binary}=0.`;
+    addIteration(text, {
+      code: `ordinary_least_squares_pfs_months_on_${row.binary}_${row.continuous}_and_interaction`,
+      result_summary: `OLS model with centered ${row.continuous}, ${row.binary}, and their product estimated interaction slope=${round(row.beta, 5)} months per ${row.continuous} unit, SE=${round(row.se, 5)}, z=${round(row.z, 3)}, p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
+
+  for (const row of threeWayInteractions.slice(0, 2)) {
+    const direction = row.beta > 0 ? "higher" : "lower";
+    const text = `The two-way interaction between ${row.a} and ${row.b} is ${direction} when ${row.c}=1 than when ${row.c}=0.`;
+    addIteration(text, {
+      code: `ordinary_least_squares_three_way_interaction_${row.a}_${row.b}_${row.c}`,
+      result_summary: `OLS model containing all main effects, two-way terms, and ${row.a}:${row.b}:${row.c} estimated three-way interaction=${round(row.beta, 4)} months, SE=${round(row.se, 4)}, z=${round(row.z, 3)}, p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
+
+  while (iterations.length < MAX_ITERATIONS) {
+    const row = adjusted[iterations.length % adjusted.length];
+    const direction = row.beta > 0 ? "higher" : "lower";
+    const text = row.isBinary
+      ? `In the all-feature multivariable model, ${row.name}=1 is associated with ${direction} pfs_months compared with ${row.name}=0.`
+      : `In the all-feature multivariable model, each one-unit increase in ${row.name} is associated with ${direction} pfs_months.`;
+    addIteration(text, {
+      code: "ordinary_least_squares_pfs_months_on_all_feature_columns",
+      result_summary: `All-feature OLS coefficient for ${row.name} was ${round(row.beta, 5)} months, SE=${round(row.se, 5)}, z=${round(row.z, 3)}, p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
+
+  const transcript = {
+    dataset_id: DATASET_ID,
+    model_id: MODEL_ID,
+    harness_id: HARNESS_ID,
+    max_iterations: MAX_ITERATIONS,
+    iterations: iterations.slice(0, MAX_ITERATIONS),
+  };
+
+  const lines = [];
+  lines.push(`Dataset ${DATASET_ID}: decoded ${y.length} patient records from dataset.parquet.`);
+  lines.push(`Outcome pfs_months had mean ${round(ySummary.mean, 3)} months, SD ${round(ySummary.sd, 3)}, range ${round(ySummary.min, 3)} to ${round(ySummary.max, 3)}.`);
+  lines.push(`The local analysis found ${binaryFeatures.length} binary feature_* columns and ${continuousFeatures.length} non-binary numeric feature_* columns; patient_id was ignored as an identifier.`);
+  lines.push("");
+  lines.push("Main-effect screening:");
+  for (const row of univ.slice(0, 8)) {
+    lines.push(`- ${row.name}: univariate effect ${round(row.effect, 4)} months${row.isBinary ? " for 1 vs 0" : " per unit"}, p=${formatP(row.p)} (${row.p < 0.05 ? "significant" : "not significant"}).`);
+  }
+  lines.push("");
+  lines.push("All-feature multivariable model:");
+  for (const row of adjusted.slice(0, 8)) {
+    lines.push(`- ${row.name}: adjusted coefficient ${round(row.beta, 4)} months, p=${formatP(row.p)} (${row.p < 0.05 ? "significant" : "not significant"}).`);
+  }
+  lines.push("");
+  lines.push("Binary interaction screening:");
+  for (const row of binaryInteractions.slice(0, 8)) {
+    lines.push(`- ${row.a}:${row.b}: interaction ${round(row.beta, 4)} months, p=${formatP(row.p)}; cell means 00=${round(row.cells["00"].mean, 3)}, 10=${round(row.cells["10"].mean, 3)}, 01=${round(row.cells["01"].mean, 3)}, 11=${round(row.cells["11"].mean, 3)}.`);
+  }
+  lines.push("");
+  lines.push("Mixed continuous-by-binary interaction screening:");
+  for (const row of mixedInteractions.slice(0, 5)) {
+    lines.push(`- ${row.continuous}:${row.binary}: interaction slope ${round(row.beta, 5)} months per unit, p=${formatP(row.p)}.`);
+  }
+  lines.push("");
+  lines.push("Three-way interaction checks:");
+  for (const row of threeWayInteractions.slice(0, 5)) {
+    lines.push(`- ${row.a}:${row.b}:${row.c}: three-way coefficient ${round(row.beta, 4)} months, p=${formatP(row.p)}.`);
+  }
+  lines.push("");
+  lines.push("Synthesis:");
+  lines.push(`The strongest univariate signals were led by ${univ[0].name}, ${univ[1].name}, and ${univ[2].name}, all with statistically significant signed associations with pfs_months. The all-feature model retained several independent associations, led by ${adjusted[0].name}, ${adjusted[1].name}, and ${adjusted[2].name}, indicating that some apparent main effects were not merely proxies for the other recorded features.`);
+  if (binaryInteractions.length > 0) {
+    const bi = binaryInteractions[0];
+    lines.push(`Subgroup heterogeneity was most evident for ${bi.a} with ${bi.b}: the joint ${bi.a}=1/${bi.b}=1 subgroup differed from additivity by ${round(bi.beta, 3)} months (p=${formatP(bi.p)}). Stratified simple-effect checks confirmed that the effect of each member of the pair changed materially across levels of the other.`);
+  }
+  if (mixedInteractions.length > 0) {
+    const mi = mixedInteractions[0];
+    lines.push(`Among continuous-by-binary probes, ${mi.continuous} by ${mi.binary} showed the strongest modification of slope (${round(mi.beta, 4)} months per unit, p=${formatP(mi.p)}), supporting additional heterogeneity beyond purely binary subgroups.`);
+  }
+  if (threeWayInteractions.length > 0) {
+    const tw = threeWayInteractions[0];
+    lines.push(`Three-way checks were exploratory; the largest was ${tw.a}:${tw.b}:${tw.c} with coefficient ${round(tw.beta, 3)} months and p=${formatP(tw.p)}. This suggests higher-order structure may exist, but these terms should be treated as hypothesis-generating because many combinations were screened.`);
+  }
+  lines.push("Overall, pfs_months in this cohort is associated with multiple feature_* columns and shows clear interaction/subgroup structure. Because the feature labels are de-identified, the findings are best interpreted as statistical treatment-biomarker-outcome patterns rather than named clinical mechanisms.");
+
+  console.error("writing outputs");
+  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2));
+  fs.writeFileSync("analysis_summary.txt", lines.join("\n"));
+  fs.writeFileSync("analysis_debug_summary.json", JSON.stringify(summaryRows, null, 2));
+}
+
+try {
+  run();
+} catch (err) {
+  console.error(err && err.stack ? err.stack : err);
+  process.exit(1);
+}

