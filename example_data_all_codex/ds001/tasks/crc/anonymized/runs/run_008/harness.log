+  for (const row of mixedInteractions.slice(0, 3)) {
+    const direction = row.beta > 0 ? "more positive" : "more negative";
+    const text = `The slope of pfs_months with respect to ${row.continuous} is ${direction} among patients with ${row.binary}=1 than among patients with ${row.binary}=0.`;
+    addIteration(text, {
+      code: `ordinary_least_squares_pfs_months_on_${row.binary}_${row.continuous}_and_interaction`,
+      result_summary: `OLS model with centered ${row.continuous}, ${row.binary}, and their product estimated interaction slope=${round(row.beta, 5)} months per ${row.continuous} unit, SE=${round(row.se, 5)}, z=${round(row.z, 3)}, p=${formatP(row.p)}.`,
+      p_value: row.p,
+      effect_estimate: row.beta,
+      significant: row.p < 0.05,
+    });
+  }
