+  const cdf = 0.5 * (1 + erf(az / Math.SQRT2));
+  return finiteP(2 * (1 - cdf));
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
