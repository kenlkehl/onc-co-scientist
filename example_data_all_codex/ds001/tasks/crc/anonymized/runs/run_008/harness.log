+      result_summary: `Multivariable OLS including all 73 feature_* columns estimated coefficient=${round(row.beta, 5)} months for ${row.name}, SE=${round(row.se, 5)}, z=${round(row.z, 3)}, p=${formatP(row.p)}.`,
