+function summarize(values) {
+  const n = values.length;
+  let s = 0, ss = 0, min = Infinity, max = -Infinity;
+  const uniques = new Map();
+  let capExceeded = false;
+  for (const v of values) {
+    s += v;
+    ss += v * v;
+    if (v < min) min = v;
+    if (v > max) max = v;
+    if (!capExceeded) {
+      uniques.set(v, (uniques.get(v) || 0) + 1);
+      if (uniques.size > 200) {
+        capExceeded = true;
+        uniques.clear();
+      }
+    }
+  }
+  const m = s / n;
+  return {
+    n,
+    mean: m,
+    sd: Math.sqrt(Math.max(0, (ss - s * s / n) / (n - 1))),
+    min,
+    max,
+    uniqueCount: capExceeded ? null : uniques.size,
+    values: capExceeded ? null : Array.from(uniques.keys()).sort((a, b) => a - b),
+    counts: capExceeded ? null : Object.fromEntries(Array.from(uniques.entries()).map(([k, v]) => [String(k), v])),
+  };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    let best = Math.abs(aug[col][col]);
+    for (let r = col + 1; r < n; r++) {
+      const val = Math.abs(aug[r][col]);
+      if (val > best) {
+        best = val;
+        pivot = r;
+      }
+    }
+    if (best < 1e-12) throw new Error("Singular matrix in OLS");
+    if (pivot !== col) {
+      const tmp = aug[col];
+      aug[col] = aug[pivot];
+      aug[pivot] = tmp;
+    }
+    const pv = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= pv;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(n));
