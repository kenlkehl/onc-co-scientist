+      } else if (dph.encoding === 0) {
+        pageValues = readPlainValues(valuePayload, meta.type, dph.num_values);
+      } else {
+        throw new Error(`Unsupported data page encoding ${dph.encoding} for ${meta.path_in_schema.join(".")}`);
+      }
+      values.push(...pageValues);
+    } else if (header.type === 3) {
+      const dph = header.data_page_header_v2;
+      const levelBytes = (dph.definition_levels_byte_length || 0) + (dph.repetition_levels_byte_length || 0);
+      let dataPayload = compressed.subarray(levelBytes);
+      if (meta.codec === 1 && dph.is_compressed !== false) dataPayload = snappyUncompress(dataPayload);
+      let pageValues;
+      if (dph.encoding === 8 || dph.encoding === 2) {
+        pageValues = decodeDictionaryDataPage(dataPayload, dph.num_values, dictionary, columnName);
+      } else if (dph.encoding === 0) {
+        pageValues = readPlainValues(dataPayload, meta.type, dph.num_values);
+      } else {
