+    const m1 = s1 / n1;
+    const v0 = Math.max(0, (ss0 - s0 * s0 / n0) / (n0 - 1));
+    const v1 = Math.max(0, (ss1 - s1 * s1 / n1) / (n1 - 1));
+    const se = Math.sqrt(v0 / n0 + v1 / n1);
