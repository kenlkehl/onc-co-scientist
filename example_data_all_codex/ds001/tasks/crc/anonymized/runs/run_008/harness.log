+    let best = Math.abs(aug[col][col]);
+    for (let r = col + 1; r < n; r++) {
+      const val = Math.abs(aug[r][col]);
+      if (val > best) {
+        best = val;
+        pivot = r;
+      }
+    }
+    if (best < 1e-12) throw new Error("Singular matrix in OLS");
+    if (pivot !== col) {
+      const tmp = aug[col];
+      aug[col] = aug[pivot];
+      aug[pivot] = tmp;
+    }
+    const pv = aug[col][col];
+    for (let j = 0; j < 2 * n; j++) aug[col][j] /= pv;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
