+  while (offset < end && values.length < meta.num_values) {
+    const header = readPageHeader(offset);
+    if (columnName === DEBUG_COLUMN) {
+      console.error(`${columnName} page offset=${offset} headerEnd=${header.header_end} type=${header.type} comp=${header.compressed_page_size} uncomp=${header.uncompressed_page_size}`);
+    }
+    const dataStart = header.header_end;
+    const dataEnd = dataStart + header.compressed_page_size;
+    const compressed = parquet.subarray(dataStart, dataEnd);
+    let payload = compressed;
+    if (meta.codec === 1 && header.type !== 3) payload = snappyUncompress(compressed);
