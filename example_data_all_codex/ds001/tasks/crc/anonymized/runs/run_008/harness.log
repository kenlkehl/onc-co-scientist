+    ySummary,
+    binaryFeatures,
+    continuousFeatures,
+    topUnivariate: univ.slice(0, 15),
+    topAdjusted: adjusted.slice(0, 15),
+    topBinaryInteractions: binaryInteractions.slice(0, 15),
