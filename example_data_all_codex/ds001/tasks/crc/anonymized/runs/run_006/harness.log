+  refined.feature034_by_023_1 = subgroupBinaryDiff(y, columns.feature_034, columns.feature_023, 1);
+  refined.feature023_by_034_0 = subgroupBinaryDiff(y, columns.feature_023, columns.feature_034, 0);
