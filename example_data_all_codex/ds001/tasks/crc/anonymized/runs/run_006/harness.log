+  i32() {
+    return this.zig(this.varint());
+  }
+  i64() {
+    return this.zig(this.varint());
+  }
+  bin() {
+    const n = Number(this.varint());
+    const s = this.b.slice(this.o, this.o + n);
+    this.o += n;
+    return s;
+  }
+  str() {
+    return this.bin().toString("utf8");
+  }
+  begin() {
+    this.last.push(0);
+  }
+  end() {
