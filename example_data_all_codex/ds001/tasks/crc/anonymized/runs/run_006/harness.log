+      const r = lookupMain("feature_036").detail;
+      return analysis("h14", `Mean pfs_months was ${fmt(r.m1)} for feature_036=1 versus ${fmt(r.m0)} for feature_036=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+  ]);
+
+  const ci1 = lookupContInt("feature_001", "feature_029");
+  pushIter(15, [
+    hyp("h15", "The negative slope between `feature_029` and `pfs_months` is weaker among patients with `feature_001` equal to 1 than among patients with `feature_001` equal to 0.", "refined"),
