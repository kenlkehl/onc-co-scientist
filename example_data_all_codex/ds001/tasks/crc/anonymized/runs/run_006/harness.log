+  const lookupContInt = (a, b) => contInteract.find((r) => r.a === a && r.b === b);
+
+  pushIter(1, [
+    hyp("h1", "Patients with `feature_001` equal to 1 have higher mean `pfs_months` than patients with `feature_001` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_001").detail;
+      return analysis("h1", `Mean pfs_months was ${fmt(r.m1)} for feature_001=1 versus ${fmt(r.m0)} for feature_001=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+  ]);
+
+  pushIter(2, [
+    hyp("h2", "Patients with `feature_057` equal to 1 have higher mean `pfs_months` than patients with `feature_057` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_057").detail;
+      return analysis("h2", `Mean pfs_months was ${fmt(r.m1)} for feature_057=1 versus ${fmt(r.m0)} for feature_057=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
