+
+  pushIter(13, [
+    hyp("h13", "`feature_015` equal to 1 is associated with lower `pfs_months` than `feature_015` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_015").detail;
+      return analysis("h13", `Mean pfs_months was ${fmt(r.m1)} for feature_015=1 versus ${fmt(r.m0)} for feature_015=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
