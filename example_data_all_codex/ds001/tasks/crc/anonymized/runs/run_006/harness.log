+        for (let bit = 0; bit < bitWidth; bit++) {
+          const bitPos = i * bitWidth + bit;
+          if (buf[st.o + (bitPos >> 3)] & (1 << (bitPos & 7))) value |= 1 << bit;
+        }
+        out.push(value);
+      }
+      st.o += Math.ceil(values * bitWidth / 8);
+    }
+  }
+  return { values: out, offset: st.o };
+}
+
+function parseMetadata(file) {
+  if (file.slice(0, 4).toString("latin1") !== "PAR1" || file.slice(-4).toString("latin1") !== "PAR1") {
+    throw new Error("Not a Parquet file");
+  }
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const footerStart = file.length - 8 - footerLen;
+  return readStruct(new ThriftReader(file.slice(footerStart, footerStart + footerLen)), FileMetaData);
+}
+
+function readPageHeader(file, offset) {
+  const r = new ThriftReader(file, offset);
+  const header = readStruct(r, PageHeader);
+  return { header, next: r.o };
+}
