+
+  pushIter(14, [
+    hyp("h14", "`feature_036` equal to 1 is associated with lower `pfs_months` than `feature_036` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_036").detail;
+      return analysis("h14", `Mean pfs_months was ${fmt(r.m1)} for feature_036=1 versus ${fmt(r.m0)} for feature_036=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
