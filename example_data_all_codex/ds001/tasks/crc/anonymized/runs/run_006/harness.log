+  const q029_hi_t = quantile(columns.feature_029, 0.75);
+  const q029_lo_t = quantile(columns.feature_029, 0.25);
+  const f029hi = makeIndicator(columns.feature_029, (v) => v >= q029_hi_t);
+  const f029lo = makeIndicator(columns.feature_029, (v) => v <= q029_lo_t);
+  refined.feature029_hi_vs_rest = binaryDiff(y, f029hi);
+  refined.feature029_lo_vs_rest = binaryDiff(y, f029lo);
+  refined.feature029_hi_vs_lo = (() => {
+    const yy = [];
+    const xx = [];
+    for (let i = 0; i < y.length; i++) {
+      if (columns.feature_029[i] >= q029_hi_t) { yy.push(y[i]); xx.push(1); }
