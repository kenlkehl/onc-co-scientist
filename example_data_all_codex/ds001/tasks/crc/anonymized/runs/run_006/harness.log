+    const f043By015 = [0, 1].map((v) => ({ level: v, ...subgroupSlopeBinary("feature_043", "feature_015", v) }));
+    const f043By001 = [0, 1].map((v) => ({ level: v, ...subgroupSlopeBinary("feature_043", "feature_001", v) }));
+    const f043By066 = [0, 1].map((v) => ({ level: v, ...subgroupSlopeBinary("feature_043", "feature_066", v) }));
+    const f043By042 = [0, 1].map((v) => ({ level: v, ...subgroupSlopeBinary("feature_043", "feature_042", v) }));
