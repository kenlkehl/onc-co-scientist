+const fs = require("fs");
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class ThriftReader {
+  constructor(buf, offset = 0) {
+    this.b = buf;
+    this.o = offset;
+    this.last = [];
+  }
+  byte() {
+    return this.b[this.o++];
+  }
+  varint() {
+    let shift = 0n;
+    let res = 0n;
+    while (true) {
+      const x = this.byte();
+      res |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zig(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  i32() {
+    return this.zig(this.varint());
+  }
+  i64() {
+    return this.zig(this.varint());
+  }
+  bin() {
+    const n = Number(this.varint());
+    const s = this.b.slice(this.o, this.o + n);
+    this.o += n;
+    return s;
+  }
+  str() {
+    return this.bin().toString("utf8");
+  }
+  begin() {
+    this.last.push(0);
+  }
+  end() {
+    this.last.pop();
+  }
+  field() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === 0) return { type: 0 };
+    const delta = h >> 4;
+    let id;
+    if (delta) id = this.last[this.last.length - 1] + delta;
+    else id = this.i32();
+    this.last[this.last.length - 1] = id;
+    return { id, type };
+  }
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const et = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, et };
+  }
+  skip(type) {
+    switch (type) {
+      case CT.TRUE:
+      case CT.FALSE:
+        return;
+      case CT.BYTE:
+        this.o += 1;
+        return;
+      case CT.I16:
+      case CT.I32:
+        this.i32();
+        return;
+      case CT.I64:
+        this.i64();
+        return;
+      case CT.DOUBLE:
+        this.o += 8;
+        return;
+      case CT.BINARY:
+        this.bin();
+        return;
+      case CT.LIST:
+      case CT.SET: {
+        const { size, et } = this.listHeader();
+        for (let i = 0; i < size; i++) this.skip(et);
+        return;
+      }
+      case CT.MAP: {
+        const size = Number(this.varint());
+        if (size > 0) {
+          const h = this.byte();
+          const kt = h >> 4;
+          const vt = h & 0x0f;
+          for (let i = 0; i < size; i++) {
+            this.skip(kt);
+            this.skip(vt);
+          }
+        }
+        return;
+      }
+      case CT.STRUCT:
+        this.begin();
+        while (true) {
+          const f = this.field();
+          if (f.type === 0) break;
+          this.skip(f.type);
+        }
+        this.end();
+        return;
+      default:
+        throw new Error(`Unsupported compact thrift type ${type}`);
+    }
+  }
+}
+
+function readVal(r, type, kind, spec) {
+  if (kind === "i32" || kind === "enum") return r.i32();
+  if (kind === "i64") return r.i64();
+  if (kind === "str") return r.str();
+  if (kind === "bytes") return r.bin();
+  if (kind === "bool") {
+    if (type === CT.TRUE) return true;
+    if (type === CT.FALSE) return false;
+    return r.byte() !== 0;
+  }
+  if (kind === "struct") return readStruct(r, spec);
+  if (kind === "list") {
+    const { size, et } = r.listHeader();
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(readVal(r, et, spec.kind, spec.spec));
+    return arr;
+  }
+  throw new Error(`Unsupported read kind ${kind}`);
+}
+
+function readStruct(r, spec) {
+  const obj = {};
+  r.begin();
+  while (true) {
+    const f = r.field();
+    if (f.type === 0) break;
+    const def = spec[f.id];
+    if (!def) {
+      r.skip(f.type);
+      continue;
+    }
+    obj[def.name] = readVal(r, f.type, def.kind, def.spec);
+  }
+  r.end();
+  return obj;
+}
+
+const KeyValue = {
+  1: { name: "key", kind: "str" },
+  2: { name: "value", kind: "str" },
+};
+const Statistics = {
+  1: { name: "max", kind: "bytes" },
+  2: { name: "min", kind: "bytes" },
+  3: { name: "null_count", kind: "i64" },
+  4: { name: "distinct_count", kind: "i64" },
+  5: { name: "max_value", kind: "bytes" },
+  6: { name: "min_value", kind: "bytes" },
+};
+const ColumnMetaData = {
+  1: { name: "type", kind: "enum" },
+  2: { name: "encodings", kind: "list", spec: { kind: "enum" } },
+  3: { name: "path_in_schema", kind: "list", spec: { kind: "str" } },
+  4: { name: "codec", kind: "enum" },
+  5: { name: "num_values", kind: "i64" },
+  6: { name: "total_uncompressed_size", kind: "i64" },
+  7: { name: "total_compressed_size", kind: "i64" },
+  8: { name: "key_value_metadata", kind: "list", spec: { kind: "struct", spec: KeyValue } },
+  9: { name: "data_page_offset", kind: "i64" },
+  10: { name: "index_page_offset", kind: "i64" },
+  11: { name: "dictionary_page_offset", kind: "i64" },
+  12: { name: "statistics", kind: "struct", spec: Statistics },
+};
+const ColumnChunk = {
+  1: { name: "file_path", kind: "str" },
