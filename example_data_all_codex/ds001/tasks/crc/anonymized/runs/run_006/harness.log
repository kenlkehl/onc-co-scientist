+      if (r === col) continue;
+      const f = M[r][col];
+      if (f === 0) continue;
+      for (let c = col; c <= n; c++) M[r][c] -= f * M[col][c];
+    }
+  }
+  return M.map((row) => row[n]);
+}
+
+function invert(A) {
+  const n = A.length;
+  const inv = [];
+  for (let i = 0; i < n; i++) {
+    const e = Array(n).fill(0);
+    e[i] = 1;
+    inv.push(solveLinear(A.map((r) => r.slice()), e));
+  }
+  const out = Array.from({ length: n }, () => Array(n).fill(0));
+  for (let i = 0; i < n; i++) for (let j = 0; j < n; j++) out[j][i] = inv[i][j];
+  return out;
+}
+
+function olsFromColumns(y, cols) {
+  const n = y.length;
+  const p = cols.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const col of cols) row.push(col[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const beta = solveLinear(xtx.map((r) => r.slice()), xty.slice());
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < cols.length; j++) pred += beta[j + 1] * cols[j][i];
+    const e = y[i] - pred;
+    sse += e * e;
+  }
+  const sigma2 = sse / (n - p);
+  const inv = invert(xtx);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const t = beta.map((v, i) => v / se[i]);
+  const pvals = t.map(pFromZ);
+  return { beta, se, t, p: pvals, sse, df: n - p, sigma2 };
+}
+
+function uniqueSummary(x) {
+  const counts = new Map();
+  for (const v of x) counts.set(v, (counts.get(v) || 0) + 1);
+  const vals = [...counts.keys()].sort((a, b) => a - b);
+  return { values: vals, counts };
+}
+
+function binaryDiff(y, x) {
+  let n0 = 0, n1 = 0, s0 = 0, s1 = 0, ss0 = 0, ss1 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) {
+      n1++; s1 += y[i]; ss1 += y[i] * y[i];
+    } else if (x[i] === 0) {
+      n0++; s0 += y[i]; ss0 += y[i] * y[i];
+    }
+  }
+  const m0 = s0 / n0;
+  const m1 = s1 / n1;
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const se = Math.sqrt(v0 / n0 + v1 / n1);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: pFromZ(z), n0, n1, m0, m1, se, z };
+}
+
+function subgroupBinaryDiff(y, x, group, groupValue) {
+  const yy = [];
+  const xx = [];
+  for (let i = 0; i < y.length; i++) {
+    if (group[i] === groupValue) {
+      yy.push(y[i]);
+      xx.push(x[i]);
+    }
+  }
+  return binaryDiff(yy, xx);
+}
+
+function continuousSlope(y, x) {
+  const model = olsFromColumns(y, [x]);
+  return { effect: model.beta[1], p: model.p[1], se: model.se[1], z: model.t[1] };
+}
+
+function interactionModel(y, a, b) {
+  const ab = new Float64Array(y.length);
+  for (let i = 0; i < y.length; i++) ab[i] = a[i] * b[i];
+  const model = olsFromColumns(y, [a, b, ab]);
+  return { effect: model.beta[3], p: model.p[3], model };
+}
+
+function makeIndicator(x, predicate) {
+  const out = new Float64Array(x.length);
+  for (let i = 0; i < x.length; i++) out[i] = predicate(x[i]) ? 1 : 0;
+  return out;
+}
+
+function quantile(arr, q) {
+  const a = Array.from(arr).sort((x, y) => x - y);
+  const pos = (a.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return a[lo];
+  return a[lo] * (hi - pos) + a[hi] * (pos - lo);
+}
+
+function fdrBH(results) {
+  const sorted = results.map((r, i) => ({ ...r, i })).sort((a, b) => a.p - b.p);
+  let min = 1;
+  for (let k = sorted.length - 1; k >= 0; k--) {
+    const q = Math.min(min, (sorted[k].p * sorted.length) / (k + 1));
+    sorted[k].q = q;
+    min = q;
+  }
+  const out = Array(results.length);
+  for (const r of sorted) out[r.i] = r.q;
+  return out;
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) < 1e-300 && x !== 0) return "0";
+  if (Math.abs(x) >= 1000 || (Math.abs(x) > 0 && Math.abs(x) < 0.001)) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function pText(p) {
+  if (p === 0) return "<1e-300";
+  if (p < 0.001) return p.toExponential(3);
+  return p.toFixed(4);
+}
+
+function main() {
+  const file = fs.readFileSync("dataset.parquet");
+  const md = parseMetadata(file);
+  const rg = md.row_groups[0];
+  const schema = md.schema.slice(1);
+  const chunksByName = new Map();
+  for (const c of rg.columns) chunksByName.set(c.meta_data.path_in_schema.join("."), c);
+
+  const columns = {};
+  for (const s of schema) {
+    if (s.name === "patient_id") continue;
+    columns[s.name] = readColumn(file, chunksByName.get(s.name));
+  }
+  const y = columns.pfs_months;
+  const featureNames = Object.keys(columns).filter((c) => c !== "pfs_months");
+  const features = {};
+  for (const name of featureNames) {
+    const u = uniqueSummary(columns[name]);
