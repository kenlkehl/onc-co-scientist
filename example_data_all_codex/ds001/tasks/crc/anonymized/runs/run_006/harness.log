+  const contForSubgroups = mainEffects.filter((r) => features[r.name].kind === "continuous").slice(0, 8).map((r) => r.name);
+  for (const b of binsForSubgroups) {
+    for (const c of contForSubgroups) {
+      const r = interactionModel(y, columns[b], columns[c]);
+      if (r) contInteract.push({ a: b, b: c, effect: r.effect, p: r.p, model: r.model });
+    }
+  }
+  contInteract.sort((a, b) => a.p - b.p);
+
+  const topNegativeControls = mainEffects.filter((r) => r.p > 0.2).slice(-6);
+
+  if (process.env.DEBUG_ANALYSIS === "1") {
+    console.log(JSON.stringify({
+      features: featureNames.map((n) => ({
+        name: n,
+        kind: features[n].kind,
+        values: features[n].unique.values.slice(0, 10),
+        counts: features[n].unique.values.slice(0, 10).map((v) => features[n].unique.counts.get(v)),
+      })),
+      topMain: mainEffects.slice(0, 25).map((r) => ({ name: r.name, kind: r.kind, effect: r.effect, p: r.p, q: r.q })),
+      adjusted,
+      topInteractions: interactions.slice(0, 25).map((r) => ({ pair: `${r.a}:${r.b}`, effect: r.effect, p: r.p })),
+      topContinuousInteractions: contInteract.slice(0, 25).map((r) => ({ pair: `${r.a}:${r.b}`, effect: r.effect, p: r.p })),
