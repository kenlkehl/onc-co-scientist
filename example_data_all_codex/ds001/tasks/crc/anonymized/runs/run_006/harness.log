+
+function main() {
+  const file = fs.readFileSync("dataset.parquet");
+  const md = parseMetadata(file);
+  const rg = md.row_groups[0];
+  const schema = md.schema.slice(1);
+  const chunksByName = new Map();
+  for (const c of rg.columns) chunksByName.set(c.meta_data.path_in_schema.join("."), c);
+
+  const columns = {};
+  for (const s of schema) {
+    if (s.name === "patient_id") continue;
+    columns[s.name] = readColumn(file, chunksByName.get(s.name));
+  }
+  const y = columns.pfs_months;
+  const featureNames = Object.keys(columns).filter((c) => c !== "pfs_months");
+  const features = {};
+  for (const name of featureNames) {
+    const u = uniqueSummary(columns[name]);
+    const kind = u.values.length === 2 && u.values[0] === 0 && u.values[1] === 1
+      ? "binary"
+      : u.values.length <= 6 && u.values.every((v) => Number.isInteger(v))
+        ? "categorical"
+        : "continuous";
+    features[name] = { name, x: columns[name], unique: u, kind };
+  }
+
+  const mainEffects = [];
+  for (const name of featureNames) {
+    const f = features[name];
+    if (f.kind === "binary") {
+      const r = binaryDiff(y, f.x);
+      mainEffects.push({ name, kind: f.kind, effect: r.effect, p: r.p, detail: r });
+    } else if (f.kind === "categorical") {
+      const model = continuousSlope(y, f.x);
+      mainEffects.push({ name, kind: f.kind, effect: model.effect, p: model.p, detail: model });
+    } else {
+      const model = continuousSlope(y, f.x);
+      mainEffects.push({ name, kind: f.kind, effect: model.effect, p: model.p, detail: model });
+    }
+  }
+  const qs = fdrBH(mainEffects);
+  mainEffects.forEach((r, i) => { r.q = qs[i]; });
+  mainEffects.sort((a, b) => a.p - b.p);
+
+  const topMain = mainEffects.slice(0, 16);
+  const selected = [...new Set(topMain.slice(0, 12).map((r) => r.name))];
+  const adjustedModel = olsFromColumns(y, selected.map((n) => columns[n]));
+  const adjusted = selected.map((n, i) => ({
+    name: n,
+    effect: adjustedModel.beta[i + 1],
+    se: adjustedModel.se[i + 1],
+    p: adjustedModel.p[i + 1],
+  })).sort((a, b) => a.p - b.p);
+
+  const binaryNames = featureNames.filter((n) => features[n].kind === "binary");
+  const continuousNames = featureNames.filter((n) => features[n].kind === "continuous");
+  const candidateNames = mainEffects.slice(0, 20).map((r) => r.name);
+  const interactions = [];
+  for (let i = 0; i < candidateNames.length; i++) {
+    for (let j = i + 1; j < candidateNames.length; j++) {
+      const a = candidateNames[i], b = candidateNames[j];
+      const r = interactionModel(y, columns[a], columns[b]);
+      if (r) interactions.push({ a, b, effect: r.effect, p: r.p, model: r.model });
+    }
+  }
+  interactions.sort((a, b) => a.p - b.p);
+
+  const refined = {};
+  refined.feature001_by_057_0 = subgroupBinaryDiff(y, columns.feature_001, columns.feature_057, 0);
+  refined.feature001_by_057_1 = subgroupBinaryDiff(y, columns.feature_001, columns.feature_057, 1);
+  refined.feature057_by_001_0 = subgroupBinaryDiff(y, columns.feature_057, columns.feature_001, 0);
+  refined.feature057_by_001_1 = subgroupBinaryDiff(y, columns.feature_057, columns.feature_001, 1);
+
+  refined.feature034_by_023_0 = subgroupBinaryDiff(y, columns.feature_034, columns.feature_023, 0);
+  refined.feature034_by_023_1 = subgroupBinaryDiff(y, columns.feature_034, columns.feature_023, 1);
+  refined.feature023_by_034_0 = subgroupBinaryDiff(y, columns.feature_023, columns.feature_034, 0);
+  refined.feature023_by_034_1 = subgroupBinaryDiff(y, columns.feature_023, columns.feature_034, 1);
+
+  const f025eq2 = makeIndicator(columns.feature_025, (v) => v === 2);
+  const f025eq1 = makeIndicator(columns.feature_025, (v) => v === 1);
+  const f025gt0 = makeIndicator(columns.feature_025, (v) => v > 0);
+  refined.feature025_gt0 = binaryDiff(y, f025gt0);
+  refined.feature025_eq2 = binaryDiff(y, f025eq2);
+  refined.feature025_eq1 = binaryDiff(y, f025eq1);
+
+  const q029_hi_t = quantile(columns.feature_029, 0.75);
+  const q029_lo_t = quantile(columns.feature_029, 0.25);
+  const f029hi = makeIndicator(columns.feature_029, (v) => v >= q029_hi_t);
+  const f029lo = makeIndicator(columns.feature_029, (v) => v <= q029_lo_t);
+  refined.feature029_hi_vs_rest = binaryDiff(y, f029hi);
+  refined.feature029_lo_vs_rest = binaryDiff(y, f029lo);
+  refined.feature029_hi_vs_lo = (() => {
+    const yy = [];
+    const xx = [];
+    for (let i = 0; i < y.length; i++) {
+      if (columns.feature_029[i] >= q029_hi_t) { yy.push(y[i]); xx.push(1); }
+      else if (columns.feature_029[i] <= q029_lo_t) { yy.push(y[i]); xx.push(0); }
+    }
+    return binaryDiff(yy, xx);
+  })();
+  refined.feature029_quantiles = { q25: q029_lo_t, q75: q029_hi_t };
+
+  const q058_hi_t = quantile(columns.feature_058, 0.75);
+  const f058hi = makeIndicator(columns.feature_058, (v) => v >= q058_hi_t);
+  refined.feature058_hi_vs_rest = binaryDiff(y, f058hi);
+  refined.feature058_quantiles = { q75: q058_hi_t };
+
+  const q028_hi_t = quantile(columns.feature_028, 0.75);
+  const f028hi = makeIndicator(columns.feature_028, (v) => v >= q028_hi_t);
+  refined.feature028_hi_vs_rest = binaryDiff(y, f028hi);
+  refined.feature028_quantiles = { q75: q028_hi_t };
+
+  const contInteract = [];
+  const binsForSubgroups = ["feature_001", "feature_057", "feature_034", "feature_023", "feature_037", "feature_015", "feature_036"];
+  const contForSubgroups = mainEffects.filter((r) => features[r.name].kind === "continuous").slice(0, 8).map((r) => r.name);
+  for (const b of binsForSubgroups) {
+    for (const c of contForSubgroups) {
+      const r = interactionModel(y, columns[b], columns[c]);
+      if (r) contInteract.push({ a: b, b: c, effect: r.effect, p: r.p, model: r.model });
+    }
+  }
+  contInteract.sort((a, b) => a.p - b.p);
+
+  const topNegativeControls = mainEffects.filter((r) => r.p > 0.2).slice(-6);
+
+  if (process.env.DEBUG_ANALYSIS === "1") {
+    console.log(JSON.stringify({
+      features: featureNames.map((n) => ({
+        name: n,
+        kind: features[n].kind,
+        values: features[n].unique.values.slice(0, 10),
+        counts: features[n].unique.values.slice(0, 10).map((v) => features[n].unique.counts.get(v)),
+      })),
+      topMain: mainEffects.slice(0, 25).map((r) => ({ name: r.name, kind: r.kind, effect: r.effect, p: r.p, q: r.q })),
+      adjusted,
+      topInteractions: interactions.slice(0, 25).map((r) => ({ pair: `${r.a}:${r.b}`, effect: r.effect, p: r.p })),
+      topContinuousInteractions: contInteract.slice(0, 25).map((r) => ({ pair: `${r.a}:${r.b}`, effect: r.effect, p: r.p })),
+    }, null, 2));
+    return;
+  }
+
+  function hyp(id, text, kind = "novel") {
+    return { id, text, kind };
+  }
+  function analysis(ids, result, effect, p, significant = p < 0.05, extra = {}) {
+    return {
+      hypothesis_ids: Array.isArray(ids) ? ids : [ids],
+      result_summary: result,
+      p_value: Number(p),
+      effect_estimate: Number(effect),
+      significant,
+      ...extra,
+    };
+  }
+
+  const iterations = [];
+  const pushIter = (index, hypotheses, analyses) => iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+
+  const lookupMain = (name) => mainEffects.find((r) => r.name === name);
+  const lookupAdj = (name) => adjusted.find((r) => r.name === name);
+  const lookupInt = (a, b) => interactions.find((r) => (r.a === a && r.b === b) || (r.a === b && r.b === a));
+  const lookupContInt = (a, b) => contInteract.find((r) => r.a === a && r.b === b);
+
+  pushIter(1, [
+    hyp("h1", "Patients with `feature_001` equal to 1 have higher mean `pfs_months` than patients with `feature_001` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_001").detail;
+      return analysis("h1", `Mean pfs_months was ${fmt(r.m1)} for feature_001=1 versus ${fmt(r.m0)} for feature_001=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+  ]);
+
+  pushIter(2, [
+    hyp("h2", "Patients with `feature_057` equal to 1 have higher mean `pfs_months` than patients with `feature_057` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_057").detail;
+      return analysis("h2", `Mean pfs_months was ${fmt(r.m1)} for feature_057=1 versus ${fmt(r.m0)} for feature_057=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+  ]);
+
+  pushIter(3, [
+    hyp("h3", "The joint association of `feature_001` and `feature_057` is super-additive: the `feature_001` effect on `pfs_months` is larger when `feature_057` equals 1 than when `feature_057` equals 0.", "refined"),
+  ], [
+    (() => {
+      const r = lookupInt("feature_001", "feature_057");
