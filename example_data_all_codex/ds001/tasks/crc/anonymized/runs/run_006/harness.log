+  refined.feature029_quantiles = { q25: q029_lo_t, q75: q029_hi_t };
+
+  const q058_hi_t = quantile(columns.feature_058, 0.75);
+  const f058hi = makeIndicator(columns.feature_058, (v) => v >= q058_hi_t);
+  refined.feature058_hi_vs_rest = binaryDiff(y, f058hi);
+  refined.feature058_quantiles = { q75: q058_hi_t };
+
+  const q028_hi_t = quantile(columns.feature_028, 0.75);
+  const f028hi = makeIndicator(columns.feature_028, (v) => v >= q028_hi_t);
+  refined.feature028_hi_vs_rest = binaryDiff(y, f028hi);
+  refined.feature028_quantiles = { q75: q028_hi_t };
