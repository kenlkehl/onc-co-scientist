+    return {
+      hypothesis_ids: Array.isArray(ids) ? ids : [ids],
+      result_summary: result,
+      p_value: Number(p),
+      effect_estimate: Number(effect),
+      significant,
+      ...extra,
+    };
+  }
+
+  {
+    const iterations = [];
+    const pushIter = (index, hypotheses, analyses) => iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+    const lookupMain = (name) => mainEffects.find((r) => r.name === name);
+    const lookupAdj = (name) => adjusted.find((r) => r.name === name);
+    const lookupInt = (a, b) => interactions.find((r) => (r.a === a && r.b === b) || (r.a === b && r.b === a));
