+class ThriftReader {
+  constructor(buf, offset = 0) {
+    this.b = buf;
+    this.o = offset;
+    this.last = [];
+  }
+  byte() {
+    return this.b[this.o++];
+  }
+  varint() {
+    let shift = 0n;
+    let res = 0n;
+    while (true) {
+      const x = this.byte();
+      res |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zig(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
