+  refined.feature057_by_001_0 = subgroupBinaryDiff(y, columns.feature_057, columns.feature_001, 0);
+  refined.feature057_by_001_1 = subgroupBinaryDiff(y, columns.feature_057, columns.feature_001, 1);
+
+  refined.feature034_by_023_0 = subgroupBinaryDiff(y, columns.feature_034, columns.feature_023, 0);
