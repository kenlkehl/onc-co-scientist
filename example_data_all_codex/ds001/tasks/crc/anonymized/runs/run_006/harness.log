+
+function subgroupBinaryDiff(y, x, group, groupValue) {
+  const yy = [];
+  const xx = [];
+  for (let i = 0; i < y.length; i++) {
+    if (group[i] === groupValue) {
+      yy.push(y[i]);
+      xx.push(x[i]);
+    }
+  }
+  return binaryDiff(yy, xx);
+}
+
+function continuousSlope(y, x) {
+  const model = olsFromColumns(y, [x]);
+  return { effect: model.beta[1], p: model.p[1], se: model.se[1], z: model.t[1] };
+}
+
+function interactionModel(y, a, b) {
+  const ab = new Float64Array(y.length);
+  for (let i = 0; i < y.length; i++) ab[i] = a[i] * b[i];
+  try {
+    const model = olsFromColumns(y, [a, b, ab]);
+    return { effect: model.beta[3], p: model.p[3], model };
+  } catch (e) {
+    return null;
+  }
+}
+
+function makeIndicator(x, predicate) {
+  const out = new Float64Array(x.length);
+  for (let i = 0; i < x.length; i++) out[i] = predicate(x[i]) ? 1 : 0;
+  return out;
+}
+
+function quantile(arr, q) {
+  const a = Array.from(arr).sort((x, y) => x - y);
+  const pos = (a.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return a[lo];
+  return a[lo] * (hi - pos) + a[hi] * (pos - lo);
+}
+
+function fdrBH(results) {
+  const sorted = results.map((r, i) => ({ ...r, i })).sort((a, b) => a.p - b.p);
+  let min = 1;
+  for (let k = sorted.length - 1; k >= 0; k--) {
+    const q = Math.min(min, (sorted[k].p * sorted.length) / (k + 1));
+    sorted[k].q = q;
+    min = q;
+  }
+  const out = Array(results.length);
+  for (const r of sorted) out[r.i] = r.q;
+  return out;
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) < 1e-300 && x !== 0) return "0";
+  if (Math.abs(x) >= 1000 || (Math.abs(x) > 0 && Math.abs(x) < 0.001)) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function pText(p) {
+  if (p === 0) return "<1e-300";
+  if (p < 0.001) return p.toExponential(3);
+  return p.toFixed(4);
+}
+
+function main() {
+  const file = fs.readFileSync("dataset.parquet");
+  const md = parseMetadata(file);
+  const rg = md.row_groups[0];
+  const schema = md.schema.slice(1);
+  const chunksByName = new Map();
+  for (const c of rg.columns) chunksByName.set(c.meta_data.path_in_schema.join("."), c);
+
+  const columns = {};
+  for (const s of schema) {
+    if (s.name === "patient_id") continue;
+    columns[s.name] = readColumn(file, chunksByName.get(s.name));
+  }
+  const y = columns.pfs_months;
+  const featureNames = Object.keys(columns).filter((c) => c !== "pfs_months");
+  const features = {};
+  for (const name of featureNames) {
+    const u = uniqueSummary(columns[name]);
+    const kind = u.values.length === 2 && u.values[0] === 0 && u.values[1] === 1
+      ? "binary"
+      : u.values.length <= 6 && u.values.every((v) => Number.isInteger(v))
+        ? "categorical"
+        : "continuous";
+    features[name] = { name, x: columns[name], unique: u, kind };
+  }
+
+  const mainEffects = [];
+  for (const name of featureNames) {
+    const f = features[name];
+    if (f.kind === "binary") {
+      const r = binaryDiff(y, f.x);
+      mainEffects.push({ name, kind: f.kind, effect: r.effect, p: r.p, detail: r });
+    } else if (f.kind === "categorical") {
+      const model = continuousSlope(y, f.x);
+      mainEffects.push({ name, kind: f.kind, effect: model.effect, p: model.p, detail: model });
+    } else {
+      const model = continuousSlope(y, f.x);
+      mainEffects.push({ name, kind: f.kind, effect: model.effect, p: model.p, detail: model });
+    }
+  }
+  const qs = fdrBH(mainEffects);
+  mainEffects.forEach((r, i) => { r.q = qs[i]; });
+  mainEffects.sort((a, b) => a.p - b.p);
+
+  const topMain = mainEffects.slice(0, 16);
+  const selected = [...new Set(topMain.slice(0, 12).map((r) => r.name))];
+  const adjustedModel = olsFromColumns(y, selected.map((n) => columns[n]));
+  const adjusted = selected.map((n, i) => ({
+    name: n,
+    effect: adjustedModel.beta[i + 1],
+    se: adjustedModel.se[i + 1],
+    p: adjustedModel.p[i + 1],
+  })).sort((a, b) => a.p - b.p);
+
+  const binaryNames = featureNames.filter((n) => features[n].kind === "binary");
+  const continuousNames = featureNames.filter((n) => features[n].kind === "continuous");
+  const candidateNames = mainEffects.slice(0, 20).map((r) => r.name);
+  const interactions = [];
+  for (let i = 0; i < candidateNames.length; i++) {
+    for (let j = i + 1; j < candidateNames.length; j++) {
+      const a = candidateNames[i], b = candidateNames[j];
+      const r = interactionModel(y, columns[a], columns[b]);
+      if (r) interactions.push({ a, b, effect: r.effect, p: r.p, model: r.model });
+    }
+  }
+  interactions.sort((a, b) => a.p - b.p);
+
+  const refined = {};
+  refined.feature001_by_057_0 = subgroupBinaryDiff(y, columns.feature_001, columns.feature_057, 0);
+  refined.feature001_by_057_1 = subgroupBinaryDiff(y, columns.feature_001, columns.feature_057, 1);
+  refined.feature057_by_001_0 = subgroupBinaryDiff(y, columns.feature_057, columns.feature_001, 0);
+  refined.feature057_by_001_1 = subgroupBinaryDiff(y, columns.feature_057, columns.feature_001, 1);
+
+  refined.feature034_by_023_0 = subgroupBinaryDiff(y, columns.feature_034, columns.feature_023, 0);
+  refined.feature034_by_023_1 = subgroupBinaryDiff(y, columns.feature_034, columns.feature_023, 1);
+  refined.feature023_by_034_0 = subgroupBinaryDiff(y, columns.feature_023, columns.feature_034, 0);
+  refined.feature023_by_034_1 = subgroupBinaryDiff(y, columns.feature_023, columns.feature_034, 1);
+
+  const f025eq2 = makeIndicator(columns.feature_025, (v) => v === 2);
+  const f025eq1 = makeIndicator(columns.feature_025, (v) => v === 1);
+  const f025gt0 = makeIndicator(columns.feature_025, (v) => v > 0);
+  refined.feature025_gt0 = binaryDiff(y, f025gt0);
+  refined.feature025_eq2 = binaryDiff(y, f025eq2);
+  refined.feature025_eq1 = binaryDiff(y, f025eq1);
+
+  const q029_hi_t = quantile(columns.feature_029, 0.75);
+  const q029_lo_t = quantile(columns.feature_029, 0.25);
+  const f029hi = makeIndicator(columns.feature_029, (v) => v >= q029_hi_t);
+  const f029lo = makeIndicator(columns.feature_029, (v) => v <= q029_lo_t);
+  refined.feature029_hi_vs_rest = binaryDiff(y, f029hi);
+  refined.feature029_lo_vs_rest = binaryDiff(y, f029lo);
