+      const xx = [];
+      const gx = columns[groupName];
+      const x = columns[xName];
+      for (let i = 0; i < y.length; i++) {
+        if (gx[i] === groupValue) {
+          yy.push(y[i]);
+          xx.push(x[i]);
+        }
+      }
