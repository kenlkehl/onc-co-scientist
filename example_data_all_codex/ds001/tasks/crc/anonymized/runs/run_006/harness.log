+const fs = require("fs");
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class ThriftReader {
+  constructor(buf, offset = 0) {
+    this.b = buf;
+    this.o = offset;
+    this.last = [];
+  }
+  byte() {
+    return this.b[this.o++];
+  }
+  varint() {
+    let shift = 0n;
+    let res = 0n;
+    while (true) {
+      const x = this.byte();
+      res |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zig(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  i32() {
+    return this.zig(this.varint());
+  }
+  i64() {
+    return this.zig(this.varint());
+  }
+  bin() {
+    const n = Number(this.varint());
+    const s = this.b.slice(this.o, this.o + n);
+    this.o += n;
+    return s;
+  }
+  str() {
+    return this.bin().toString("utf8");
+  }
+  begin() {
+    this.last.push(0);
+  }
+  end() {
+    this.last.pop();
+  }
+  field() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === 0) return { type: 0 };
+    const delta = h >> 4;
+    let id;
+    if (delta) id = this.last[this.last.length - 1] + delta;
+    else id = this.i32();
+    this.last[this.last.length - 1] = id;
+    return { id, type };
+  }
+  listHeader() {
+    const h = this.byte();
+    let size = h >> 4;
+    const et = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, et };
+  }
+  skip(type) {
+    switch (type) {
+      case CT.TRUE:
+      case CT.FALSE:
+        return;
+      case CT.BYTE:
