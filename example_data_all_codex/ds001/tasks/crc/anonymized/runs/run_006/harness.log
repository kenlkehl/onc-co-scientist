+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let res = 0;
+  while (true) {
+    const x = buf[state.o++];
+    res += (x & 0x7f) * 2 ** shift;
+    if ((x & 0x80) === 0) break;
+    shift += 7;
+  }
+  return res;
