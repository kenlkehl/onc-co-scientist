+    analysis("h15", `In OLS pfs_months ~ feature_001 + feature_029 + feature_001:feature_029, the interaction coefficient was ${fmt(ci1.effect)} months per feature_029 unit (p=${pText(ci1.p)}).`, ci1.effect, ci1.p),
