+  const f025eq2 = makeIndicator(columns.feature_025, (v) => v === 2);
+  const f025eq1 = makeIndicator(columns.feature_025, (v) => v === 1);
+  const f025gt0 = makeIndicator(columns.feature_025, (v) => v > 0);
+  refined.feature025_gt0 = binaryDiff(y, f025gt0);
+  refined.feature025_eq2 = binaryDiff(y, f025eq2);
+  refined.feature025_eq1 = binaryDiff(y, f025eq1);
