+
+function readColumn(file, chunk) {
+  const meta = chunk.meta_data;
+  const type = meta.type;
+  let offset = meta.dictionary_page_offset ?? meta.data_page_offset;
+  let dict = null;
+  const values = [];
+  while (values.length < meta.num_values) {
+    const { header, next } = readPageHeader(file, offset);
+    const compressed = file.slice(next, next + header.compressed_page_size);
+    const pageBuf = meta.codec === 1 ? snappyUncompress(compressed) : compressed;
+    if (header.type === 2) {
+      dict = decodePlain(pageBuf, type, header.dictionary_page_header.num_values);
+    } else if (header.type === 0) {
+      let pos = 0;
+      // Flat optional columns: no repetition levels, one definition-level stream.
+      const defLen = pageBuf.readUInt32LE(pos);
+      pos += 4 + defLen;
+      const bitWidth = pageBuf[pos++];
+      const decoded = decodeHybrid(pageBuf, bitWidth, header.data_page_header.num_values, pos);
+      for (const idx of decoded.values) values.push(dict[idx]);
+    } else if (header.type === 3) {
+      const h = header.data_page_header_v2;
+      let pos = h.repetition_levels_byte_length + h.definition_levels_byte_length;
+      let valueBuf = pageBuf.slice(pos);
+      if (h.is_compressed !== false && meta.codec === 1) valueBuf = snappyUncompress(valueBuf);
+      const bitWidth = valueBuf[0];
+      const decoded = decodeHybrid(valueBuf, bitWidth, h.num_values - (h.num_nulls || 0), 1);
+      for (const idx of decoded.values) values.push(dict[idx]);
+    } else {
+      throw new Error(`Unsupported page type ${header.type}`);
+    }
+    offset = next + header.compressed_page_size;
+  }
+  return Float64Array.from(values);
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function variance(arr, m = mean(arr)) {
+  let s = 0;
+  for (const v of arr) {
+    const d = v - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  const az = Math.abs(z);
+  const p = 2 * (1 - normalCdf(az));
+  return Math.max(0, Math.min(1, p));
+}
+
+function solveLinear(A, b) {
+  const n = b.length;
+  const M = A.map((row, i) => row.concat([b[i]]));
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(M[r][col]) > Math.abs(M[pivot][col])) pivot = r;
+    if (Math.abs(M[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) [M[col], M[pivot]] = [M[pivot], M[col]];
+    const div = M[col][col];
+    for (let c = col; c <= n; c++) M[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = M[r][col];
+      if (f === 0) continue;
+      for (let c = col; c <= n; c++) M[r][c] -= f * M[col][c];
+    }
+  }
+  return M.map((row) => row[n]);
+}
+
+function invert(A) {
+  const n = A.length;
+  const inv = [];
+  for (let i = 0; i < n; i++) {
+    const e = Array(n).fill(0);
+    e[i] = 1;
+    inv.push(solveLinear(A.map((r) => r.slice()), e));
+  }
+  const out = Array.from({ length: n }, () => Array(n).fill(0));
+  for (let i = 0; i < n; i++) for (let j = 0; j < n; j++) out[j][i] = inv[i][j];
+  return out;
+}
+
+function olsFromColumns(y, cols) {
+  const n = y.length;
+  const p = cols.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const col of cols) row.push(col[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const beta = solveLinear(xtx.map((r) => r.slice()), xty.slice());
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < cols.length; j++) pred += beta[j + 1] * cols[j][i];
+    const e = y[i] - pred;
+    sse += e * e;
+  }
+  const sigma2 = sse / (n - p);
+  const inv = invert(xtx);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const t = beta.map((v, i) => v / se[i]);
+  const pvals = t.map(pFromZ);
+  return { beta, se, t, p: pvals, sse, df: n - p, sigma2 };
+}
+
+function uniqueSummary(x) {
+  const counts = new Map();
+  for (const v of x) counts.set(v, (counts.get(v) || 0) + 1);
+  const vals = [...counts.keys()].sort((a, b) => a - b);
+  return { values: vals, counts };
+}
+
+function binaryDiff(y, x) {
+  let n0 = 0, n1 = 0, s0 = 0, s1 = 0, ss0 = 0, ss1 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) {
+      n1++; s1 += y[i]; ss1 += y[i] * y[i];
+    } else if (x[i] === 0) {
+      n0++; s0 += y[i]; ss0 += y[i] * y[i];
+    }
+  }
+  const m0 = s0 / n0;
+  const m1 = s1 / n1;
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const se = Math.sqrt(v0 / n0 + v1 / n1);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: pFromZ(z), n0, n1, m0, m1, se, z };
+}
+
+function subgroupBinaryDiff(y, x, group, groupValue) {
+  const yy = [];
+  const xx = [];
+  for (let i = 0; i < y.length; i++) {
+    if (group[i] === groupValue) {
+      yy.push(y[i]);
+      xx.push(x[i]);
+    }
+  }
+  return binaryDiff(yy, xx);
+}
+
+function continuousSlope(y, x) {
+  const model = olsFromColumns(y, [x]);
+  return { effect: model.beta[1], p: model.p[1], se: model.se[1], z: model.t[1] };
+}
+
+function interactionModel(y, a, b) {
+  const ab = new Float64Array(y.length);
+  for (let i = 0; i < y.length; i++) ab[i] = a[i] * b[i];
+  try {
+    const model = olsFromColumns(y, [a, b, ab]);
+    return { effect: model.beta[3], p: model.p[3], model };
+  } catch (e) {
+    return null;
+  }
+}
+
+function makeIndicator(x, predicate) {
+  const out = new Float64Array(x.length);
+  for (let i = 0; i < x.length; i++) out[i] = predicate(x[i]) ? 1 : 0;
+  return out;
+}
+
+function quantile(arr, q) {
+  const a = Array.from(arr).sort((x, y) => x - y);
+  const pos = (a.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return a[lo];
+  return a[lo] * (hi - pos) + a[hi] * (pos - lo);
+}
+
+function fdrBH(results) {
+  const sorted = results.map((r, i) => ({ ...r, i })).sort((a, b) => a.p - b.p);
+  let min = 1;
+  for (let k = sorted.length - 1; k >= 0; k--) {
+    const q = Math.min(min, (sorted[k].p * sorted.length) / (k + 1));
+    sorted[k].q = q;
+    min = q;
+  }
+  const out = Array(results.length);
+  for (const r of sorted) out[r.i] = r.q;
+  return out;
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) < 1e-300 && x !== 0) return "0";
+  if (Math.abs(x) >= 1000 || (Math.abs(x) > 0 && Math.abs(x) < 0.001)) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function pText(p) {
+  if (p === 0) return "<1e-300";
+  if (p < 0.001) return p.toExponential(3);
+  return p.toFixed(4);
