+    analysis("h10", `Patients in the top quartile of feature_028 (>=${fmt(q028_hi_t)}) had ${fmt(refined.feature028_hi_vs_rest.effect)} months different mean pfs_months than the rest of the cohort (p=${pText(refined.feature028_hi_vs_rest.p)}).`, refined.feature028_hi_vs_rest.effect, refined.feature028_hi_vs_rest.p),
+  ]);
+
+  pushIter(11, [
+    hyp("h11", "The apparent associations of `feature_001`, `feature_057`, `feature_025`, `feature_029`, `feature_034`, `feature_023`, `feature_058`, and `feature_028` with `pfs_months` persist after mutual adjustment for the strongest univariate predictors.", "refined"),
