+
+  pushIter(12, [
+    hyp("h12", "`feature_037` equal to 1 is associated with higher `pfs_months` than `feature_037` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_037").detail;
+      return analysis("h12", `Mean pfs_months was ${fmt(r.m1)} for feature_037=1 versus ${fmt(r.m0)} for feature_037=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
