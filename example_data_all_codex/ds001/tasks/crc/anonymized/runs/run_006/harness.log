+      result_summary: result,
+      p_value: Number(p),
+      effect_estimate: Number(effect),
+      significant,
+      ...extra,
+    };
+  }
+
+  const iterations = [];
+  const pushIter = (index, hypotheses, analyses) => iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+
+  const lookupMain = (name) => mainEffects.find((r) => r.name === name);
+  const lookupAdj = (name) => adjusted.find((r) => r.name === name);
+  const lookupInt = (a, b) => interactions.find((r) => (r.a === a && r.b === b) || (r.a === b && r.b === a));
+  const lookupContInt = (a, b) => contInteract.find((r) => r.a === a && r.b === b);
+
+  pushIter(1, [
+    hyp("h1", "Patients with `feature_001` equal to 1 have higher mean `pfs_months` than patients with `feature_001` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_001").detail;
+      return analysis("h1", `Mean pfs_months was ${fmt(r.m1)} for feature_001=1 versus ${fmt(r.m0)} for feature_001=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+  ]);
+
+  pushIter(2, [
+    hyp("h2", "Patients with `feature_057` equal to 1 have higher mean `pfs_months` than patients with `feature_057` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_057").detail;
+      return analysis("h2", `Mean pfs_months was ${fmt(r.m1)} for feature_057=1 versus ${fmt(r.m0)} for feature_057=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+  ]);
+
+  pushIter(3, [
+    hyp("h3", "The joint association of `feature_001` and `feature_057` is super-additive: the `feature_001` effect on `pfs_months` is larger when `feature_057` equals 1 than when `feature_057` equals 0.", "refined"),
+  ], [
+    (() => {
+      const r = lookupInt("feature_001", "feature_057");
+      return analysis("h3", `In OLS pfs_months ~ feature_001 + feature_057 + feature_001:feature_057, the interaction coefficient was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+    analysis("h3", `Within feature_057=0, feature_001=1 versus 0 changed mean pfs_months by ${fmt(refined.feature001_by_057_0.effect)} months (p=${pText(refined.feature001_by_057_0.p)}).`, refined.feature001_by_057_0.effect, refined.feature001_by_057_0.p),
+    analysis("h3", `Within feature_057=1, feature_001=1 versus 0 changed mean pfs_months by ${fmt(refined.feature001_by_057_1.effect)} months (p=${pText(refined.feature001_by_057_1.p)}).`, refined.feature001_by_057_1.effect, refined.feature001_by_057_1.p),
+  ]);
+
+  pushIter(4, [
+    hyp("h4", "Higher numeric values of `feature_025` are associated with lower `pfs_months`, with the shortest `pfs_months` among patients with `feature_025` equal to 2."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_025");
+      return analysis("h4", `Treating feature_025 as ordinal 0/1/2, each one-level increase was associated with ${fmt(r.effect)} fewer months of pfs_months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+    analysis("h4", `Patients with feature_025=2 had mean pfs_months lower than all others by ${fmt(refined.feature025_eq2.effect)} months (p=${pText(refined.feature025_eq2.p)}).`, refined.feature025_eq2.effect, refined.feature025_eq2.p),
+  ]);
+
+  pushIter(5, [
+    hyp("h5", "Higher `feature_029` values are associated with lower `pfs_months`."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_029");
+      return analysis("h5", `In univariate OLS, each one-unit increase in feature_029 changed pfs_months by ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+    analysis("h5", `Patients in the top quartile of feature_029 (>=${fmt(q029_hi_t)}) had ${fmt(refined.feature029_hi_vs_lo.effect)} months different mean pfs_months than those in the bottom quartile (<=${fmt(q029_lo_t)}; p=${pText(refined.feature029_hi_vs_lo.p)}).`, refined.feature029_hi_vs_lo.effect, refined.feature029_hi_vs_lo.p),
+  ]);
+
+  pushIter(6, [
+    hyp("h6", "Patients with `feature_034` equal to 1 have lower mean `pfs_months` than patients with `feature_034` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_034").detail;
+      return analysis("h6", `Mean pfs_months was ${fmt(r.m1)} for feature_034=1 versus ${fmt(r.m0)} for feature_034=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+  ]);
+
+  pushIter(7, [
+    hyp("h7", "Patients with `feature_023` equal to 1 have lower mean `pfs_months` than patients with `feature_023` equal to 0."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_023").detail;
+      return analysis("h7", `Mean pfs_months was ${fmt(r.m1)} for feature_023=1 versus ${fmt(r.m0)} for feature_023=0; the mean difference was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+  ]);
+
+  pushIter(8, [
+    hyp("h8", "The adverse association of `feature_034` with `pfs_months` is stronger when `feature_023` equals 1 than when `feature_023` equals 0.", "refined"),
+  ], [
+    (() => {
+      const r = lookupInt("feature_034", "feature_023");
+      return analysis("h8", `In OLS pfs_months ~ feature_034 + feature_023 + feature_034:feature_023, the interaction coefficient was ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+    analysis("h8", `Within feature_023=0, feature_034=1 versus 0 changed mean pfs_months by ${fmt(refined.feature034_by_023_0.effect)} months (p=${pText(refined.feature034_by_023_0.p)}).`, refined.feature034_by_023_0.effect, refined.feature034_by_023_0.p),
+    analysis("h8", `Within feature_023=1, feature_034=1 versus 0 changed mean pfs_months by ${fmt(refined.feature034_by_023_1.effect)} months (p=${pText(refined.feature034_by_023_1.p)}).`, refined.feature034_by_023_1.effect, refined.feature034_by_023_1.p),
+  ]);
+
+  pushIter(9, [
+    hyp("h9", "Higher `feature_058` values are associated with lower `pfs_months`."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_058");
+      return analysis("h9", `In univariate OLS, each one-unit increase in feature_058 changed pfs_months by ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
+    })(),
+    analysis("h9", `Patients in the top quartile of feature_058 (>=${fmt(q058_hi_t)}) had ${fmt(refined.feature058_hi_vs_rest.effect)} months different mean pfs_months than the rest of the cohort (p=${pText(refined.feature058_hi_vs_rest.p)}).`, refined.feature058_hi_vs_rest.effect, refined.feature058_hi_vs_rest.p),
+  ]);
+
+  pushIter(10, [
+    hyp("h10", "Higher `feature_028` values are associated with lower `pfs_months`."),
+  ], [
+    (() => {
+      const r = lookupMain("feature_028");
+      return analysis("h10", `In univariate OLS, each one-unit increase in feature_028 changed pfs_months by ${fmt(r.effect)} months (p=${pText(r.p)}).`, r.effect, r.p);
