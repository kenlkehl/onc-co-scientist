+    const f041By025 = [0, 1, 2].map((v) => ({ level: v, ...subgroupSlope("feature_041", "feature_025", v) }));
+    const f041By036 = [0, 1].map((v) => ({ level: v, ...subgroupSlope("feature_041", "feature_036", v) }));
