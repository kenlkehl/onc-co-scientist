function pval(z) { const p = 1 - erf(Math.abs(z) / Math.SQRT2); return p === 0 ? 1e-300 : p; }
function signif(p) { return p < 0.05; }
function fnum(x, d = 4) { return Number.isFinite(x) ? Number(x.toFixed(d)) : x; }
function fp(p) { return p <= 1e-300 ? 'p<1e-300' : 'p=' + p.toExponential(3); }
function mean(a) { let s = 0; for (const v of a) s += v; return s / a.length; }
function minmax(a) { let mn = Infinity, mx = -Infinity; for (const v of a) { if (v < mn) mn = v; if (v > mx) mx = v; } return [mn, mx]; }
function center(a) { const m = mean(a), o = new Float64Array(a.length); for (let i = 0; i < a.length; i++) o[i] = a[i] - m; return [o, m]; }
function product(a, b) { const o = new Float64Array(a.length); for (let i = 0; i < a.length; i++) o[i] = a[i] * b[i]; return o; }

function univariate(x, y) {
  const n = y.length;
  let mn = Infinity, mx = -Infinity, uniq = new Set(), sx = 0, sy = 0;
  for (let i = 0; i < n; i++) { const xv = x[i]; if (xv < mn) mn = xv; if (xv > mx) mx = xv; uniq.add(xv); sx += xv; sy += y[i]; }
  const binary = uniq.size === 2 && mn === 0 && mx === 1;
  if (binary) return binaryDiff(x, y);
  const mxv = sx / n, my = sy / n; let sxx = 0, sxy = 0;
  for (let i = 0; i < n; i++) { const dx = x[i] - mxv; sxx += dx * dx; sxy += dx * (y[i] - my); }
  const b = sxy / sxx, a = my - b * mxv; let sse = 0;
  for (let i = 0; i < n; i++) { const r = y[i] - a - b * x[i]; sse += r * r; }
  const se = Math.sqrt((sse / (n - 2)) / sxx), z = b / se;
  return { effect: b, se, z, p: pval(z), binary: false, min: mn, max: mx, mean: mxv, nunique: uniq.size };
}

function binaryDiff(x, y, filter = null) {
  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
  for (let i = 0; i < y.length; i++) {
    if (filter && "'!filter(i)) continue;
    const yy = y[i];
    if (x[i] === 1) { n1++; s1 += yy; ss1 += yy * yy; }
    else { n0++; s0 += yy; ss0 += yy * yy; }
  }
  const m1 = s1 / n1, m0 = s0 / n0;
  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1), v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
  const effect = m1 - m0, se = Math.sqrt(v1 / n1 + v0 / n0), z = effect / se;
  return { effect, se, z, p: pval(z), binary: true, n1, n0, m1, m0 };
}

function invert(A) {
  const n = A.length, M = A.map((r, i) => r.concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
  for (let i = 0; i < n; i++) {
    let m = i;
    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[m][i])) m = r;
    [M[i], M[m]] = [M[m], M[i]];
    const piv = M[i][i];
    if (Math.abs(piv) < 1e-12) throw new Error('"'Singular model');
    for (let c = 0; c < 2 * n; c++) M[i][c] /= piv;
    for (let r = 0; r < n; r++) if (r "'!== i) {
      const f = M[r][i];
      if (f) for (let c = 0; c < 2 * n; c++) M[r][c] -= f * M[i][c];
    }
  }
  return M.map(r => r.slice(n));
}

function ols(y, X, labels) {
  const n = y.length, p = X.length + 1;
  const xtx = Array.from({ length: p }, () => Array(p).fill(0)), xty = Array(p).fill(0);
  for (let i = 0; i < n; i++) {
    const row = [1]; for (const x of X) row.push(x[i]);
    for (let a = 0; a < p; a++) { xty[a] += row[a] * y[i]; for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b]; }
  }
  const inv = invert(xtx), beta = Array(p).fill(0);
  for (let a = 0; a < p; a++) for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
  let sse = 0;
  for (let i = 0; i < n; i++) { let pred = beta[0]; for (let j = 0; j < X.length; j++) pred += beta[j + 1] * X[j][i]; const r = y[i] - pred; sse += r * r; }
  const sigma2 = sse / (n - p);
  return beta.map((coef, j) => {
    const se = Math.sqrt(sigma2 * inv[j][j]), z = coef / se;
    return { label: j ? labels[j - 1] : '"'intercept', coef, se, z, p: pval(z) };
  });
}

const y = readColumnByName('pfs_months');
const yMean = mean(y), yRange = minmax(y);
const featureNames = names.filter(n => n "'!== '"'patient_id' && n "'!== '"'pfs_months');
const data = {};
for (const n of featureNames) data[n] = readColumnByName(n);

const uni = {};
for (const n of featureNames) uni[n] = univariate(data[n], y);
const top = ['feature_041','feature_025','feature_036','feature_043','feature_056','feature_050','feature_001','feature_015','feature_029','feature_066'];
const adj = {};
for (const c of ols(y, top.map(n => data[n]), top)) if (c.label "'!== '"'intercept') adj[c.label] = c;

function interaction(pair, adjusted = true) {
  const [a, b] = pair.split(':'), ca = center(data[a])[0], cb = center(data[b])[0], xz = product(ca, cb);
  let X, labels;
  if (adjusted) {
    const base = top.filter(n => n "'!== a && n !== b);
    X = base.map(n => data[n]).concat([ca, cb, xz]);
    labels = base.concat([a + '"'_centered', b + '_centered', pair]);
  } else {
    X = [ca, cb, xz]; labels = [a + '_centered', b + '_centered', pair];
  }
  const coefs = ols(y, X, labels);
  return coefs[coefs.length - 1];
}

function groupDiff(xName, gName, gVal) {
  return binaryDiff(data[xName], y, i => data[gName][i] === gVal);
}

