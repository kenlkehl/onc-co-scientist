  'feature_041:feature_036': interaction('feature_041:feature_036'),
  'feature_001:feature_029': interaction('feature_001:feature_029'),
  'feature_015:feature_029': interaction('feature_015:feature_029'),
  'feature_041:feature_056': interaction('feature_041:feature_056'),
  'feature_015:feature_066': interaction('feature_015:feature_066'),
  'feature_025:feature_036_unadjusted': interaction('feature_025:feature_036', false),
  'feature_036:feature_043_unadjusted': interaction('feature_036:feature_043', false),
