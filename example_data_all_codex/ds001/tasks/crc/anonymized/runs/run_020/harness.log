  f043_by_f066_0: groupDiff('feature_043','feature_066',0),
  f043_by_f066_1: groupDiff('feature_043','feature_066',1)
};

function h(id, text, kind = 'novel') { return { id, text, kind }; }
function a(hids, summary, effect, p, code) { return { hypothesis_ids: Array.isArray(hids) ? hids : [hids], code: code || null, result_summary: summary, p_value: p, effect_estimate: effect, significant: signif(p) }; }
function uniSummary(name, wording) {
  const r = uni[name];
  return wording + ' Effect estimate=' + fnum(r.effect, 6) + ' months; ' + fp(r.p) + '.';
}
function adjSummary(name, wording) {
  const r = adj[name];
  return wording + ' Adjusted coefficient=' + fnum(r.coef, 6) + ' months; ' + fp(r.p) + '.';
}
function intSummary(key, wording) {
  const r = ints[key];
  return wording + ' Interaction coefficient=' + fnum(r.coef, 6) + ' months; ' + fp(r.p) + '.';
}
function stratSummary(key, wording) {
  const r = strata[key];
  return wording + ' Difference=' + fnum(r.effect, 6) + ' months; ' + fp(r.p) + ' (mean1=' + fnum(r.m1, 4) + ', mean0=' + fnum(r.m0, 4) + ').';
}

