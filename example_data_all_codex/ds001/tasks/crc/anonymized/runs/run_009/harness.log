const fs = require('fs');
const buf = fs.readFileSync('dataset.parquet');
const n = buf.length;
const footerLen = buf.readInt32LE(n-8);
let pos = n - 8 - footerLen;
const end = n - 8;
const CT={STOP:0,TRUE:1,FALSE:2,BYTE:3,I16:4,I32:5,I64:6,DOUBLE:7,BINARY:8,LIST:9,SET:10,MAP:11,STRUCT:12};
function readVarint(){ let shift=0, result=0n; while(true){ const b=buf[pos++]; result |= BigInt(b & 0x7f) << BigInt(shift); if((b & 0x80)===0) break; shift += 7; } return result; }
function zigzag(n){ return Number((n >> 1n) "'^ (-(n & 1n))); }
function readI(){ return zigzag(readVarint()); }
function readU(){ return Number(readVarint()); }
function readDouble(){ const v=buf.readDoubleLE(pos); pos+=8; return v; }
function readByte(){ return buf.readInt8(pos++); }
function readBinary(){ const len=readU(); const b=buf.subarray(pos,pos+len); pos+=len; const ascii=b.toString('"'utf8'); return ascii; }
function readList(elemType, size){ const arr=[]; for(let i=0;i<size;i++) arr.push(readValue(elemType)); return arr; }
function readValue(type){ switch(type){ case CT.TRUE: return true; case CT.FALSE: return false; case CT.BYTE: return readByte(); case CT.I16: case CT.I32: case CT.I64: return readI(); case CT.DOUBLE: return readDouble(); case CT.BINARY: return readBinary(); case CT.STRUCT: return readStruct(); case CT.LIST: case CT.SET: { const st=buf[pos++]; let size=st>>4; const et=st&0x0f; if(size===15) size=readU(); return readList(et,size); } case CT.MAP: { const size=readU(); if(size===0) return {}; const ktvt=buf[pos++]; const kt=(ktvt>>4)&0x0f, vt=ktvt&0x0f; const obj={}; for(let i=0;i<size;i++){ obj[readValue(kt)] = readValue(vt); } return obj; } default: throw new Error('type '+type+' at '+pos); }}
