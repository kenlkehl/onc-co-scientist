"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs = require('fs');
const t = JSON.parse(fs.readFileSync('transcript.json','utf8'));
const required = ['dataset_id','model_id','harness_id','max_iterations','iterations'];
for (const k of required) if ("'!(k in t)) throw new Error('"'missing top-level '+k);
if (t.max_iterations "'!== 25) throw new Error('"'max_iterations not 25');
if ("'!Array.isArray(t.iterations) || t.iterations.length !== 25) throw new Error('"'expected 25 iterations');
const ids = new Set();
for (const it of t.iterations) {
  if ("'!Number.isInteger(it.index) || it.index < 1) throw new Error('"'bad iteration index');
  if ("'!Array.isArray(it.proposed_hypotheses) || !it.proposed_hypotheses.length) throw new Error('"'missing hypotheses at '+it.index);
  for (const h of it.proposed_hypotheses) {
    if ("'!h.id || !h.text) throw new Error('"'bad hypothesis at '+it.index);
    ids.add(h.id);
  }
  if ("'!Array.isArray(it.analyses) || !it.analyses.length) throw new Error('"'missing analyses at '+it.index);
  for (const a of it.analyses) {
    if ("'!Array.isArray(a.hypothesis_ids) || !a.hypothesis_ids.length) throw new Error('"'bad hypothesis_ids at '+it.index);
    for (const id of a.hypothesis_ids) if ("'!ids.has(id)) throw new Error('"'analysis references unknown id '+id);
    if (typeof a.result_summary "'!== '"'string' || "'!a.result_summary) throw new Error('"'missing result summary at '+it.index);
    if (typeof a.effect_estimate "'!== '"'number') throw new Error('missing effect estimate at '+it.index);
    if (typeof a.p_value "'!== '"'number' && typeof a.significant "'!== '"'boolean') throw new Error('missing p/significant at '+it.index);
  }
}
const summary = fs.readFileSync('analysis_summary.txt','utf8');
if (summary.length < 1000) throw new Error('summary unexpectedly short');
console.log('validated transcript iterations=', t.iterations.length, 'summary_chars=', summary.length);
