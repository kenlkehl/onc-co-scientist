  zigzag(n){ return (n >> 1n) "'^ (-(n & 1n)); }
  i32(){ return Number(this.zigzag(this.varint())); }
  i64(){ return this.zigzag(this.varint()); }
  bin(){ const len=Number(this.varint()); const s=this.b.subarray(this.i,this.i+len); this.i+=len; return s; }
  readFieldBegin(){ const h=this.byte(); const type=h & 0x0f; if(type===0) return {type, id:0}; const delta=h >> 4; let id; if(delta===0) id=this.i32(); else id=this.lastFieldId + delta; this.lastFieldId=id; return {type,id}; }
