function mean(a){let s=0;for(const v of a)s+=v;return s/a.length;}function dot(a,b){let s=0;for(let i=0;i<a.length;i++)s+=a[i]*b[i];return s;}function sumsq(a){let s=0;for(const v of a)s+=v*v;return s;}function normSf(z){z=Math.abs(z);if(z>37)return 0;const t=1/(1+0.2316419*z),d=0.3989422804014327*Math.exp(-z*z/2);return d*t*(0.319381530+t*(-0.356563782+t*(1.781477937+t*(-1.821255978+t*1.330274429))));}function pval(t){const p=2*normSf(t);return p<1e-300?0:p;}
