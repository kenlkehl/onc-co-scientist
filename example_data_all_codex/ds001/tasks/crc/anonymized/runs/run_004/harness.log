function getChunk(name){return chunks.find(md=>md[3][0].toString('utf8')===name);}function readColumn(name){const md=getChunk(name),type=md[1],total=md[5];let pos=md[11]||md[9],dict=null,vals=[];while(vals.length<total){const h=parseCompact(parquet.subarray(pos,pos+1000));pos+=h.__bytes;const comp=parquet.subarray(pos,pos+h[3]);pos+=h[3];const body=md[4]===1?snappyDecompress(comp):comp;if(h[1]===2){dict=plainDict(body,type,h[7][1]);}else if(h[1]===0){const dph=h[5];let p=0,present=dph[1];if(dph[3]===3){const len=body.readUInt32LE(p);p+=4;const dl=readHybrid(body,p,1,dph[1],p+len);p+=len;present=dl.values.reduce((a,v)=>a+(v===1),0);if(present"'!==dph[1])throw Error('"'nulls');}const bw=body[p++];const dec=readHybrid(body,p,bw,present);for(const ix of dec.values)vals.push(dict[ix]);}else throw Error('page '+h[1]);}return vals;}
