function matVec(M,v){return M.map(row=>row.reduce((s,x,i)=>s+x*v[i],0));}
function fit(cols){const p=cols.length;const xtx=Array.from({length:p},()=>Array(p).fill(0));const xty=Array(p).fill(0);let yy=0;for(let i=0;i<n;i++){yy+=y[i]*y[i];for(let a=0;a<p;a++){const va=cols[a].x[i];xty[a]+=va*y[i];for(let b=0;b<=a;b++)xtx[a][b]+=va*cols[b].x[i];}}for(let a=0;a<p;a++)for(let b=0;b<a;b++)xtx[b][a]=xtx[a][b];const inv=invert(xtx);const beta=matVec(inv,xty);let sse=yy;for(let a=0;a<p;a++)sse-=beta[a]*xty[a];const df=n-p,sigma2=sse/df;const rows=cols.map((col,i)=>({name:col.name,beta:beta[i],se:Math.sqrt(Math.max(0,sigma2*inv[i][i])),t:beta[i]/Math.sqrt(Math.max(1e-300,sigma2*inv[i][i])),p:pval(beta[i]/Math.sqrt(Math.max(1e-300,sigma2*inv[i][i])))}));return {rows,beta,inv,xtx,xty,sse,df,sigma2,cols};}
