  function readVarint(){ let shift=0,result=0n; while(true){ const b=BigInt(readByte()); result |= (b & 0x7fn) << BigInt(shift); if((b & 0x80n)===0n) break; shift+=7; } return result; }
  const zz=n => (n >> 1n) "'^ (-(n & 1n));
  function readZ(){ return zz(readVarint()); }
  function readDouble(){ const v=slice.readDoubleLE(pos); pos+=8; return v; }
  function val(type){
    if(type===1) return true; if(type===2) return false;
    if(type===3 || type===4 || type===5) return Number(readZ());
    if(type===6){ const v=readZ(); return Number(v); }
    if(type===7) return readDouble();
    if(type===8){ const len=Number(readVarint()); const s=slice.subarray(pos,pos+len); pos+=len; return s; }
    if(type===9||type===10){ const b=readByte(); let n=b>>4; const et=b&0xf; if(n===15) n=Number(readVarint()); return Array.from({length:n},()=>val(et)); }
    if(type===11){ const n=Number(readVarint()); if(n===0) return []; const b=readByte(); const kt=b>>4, vt=b&0xf; return Array.from({length:n},()=>[val(kt),val(vt)]); }
    if(type===12) return struct();
    throw new Error('"'unknown '+type+' pos '+pos);
  }
