import pandas as pd
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print(df.shape)
print(df.dtypes.to_string())
print('\\nOutcome summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
print('\\nFeature unique counts first')
features=[c for c in df.columns if c.startswith('feature_')]
uc=df[features].nunique().sort_values()
print(uc.to_string())
print('\\nFeature means/summary for unique<=10')
small=uc[uc<=10].index.tolist()
print(df[small].agg(['mean','std','min','max']).T.to_string())
print('\\nContinuous-ish features')
cont=uc[uc>10].index.tolist()
print(cont)
if cont:
    print(df[cont].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).T.to_string())
