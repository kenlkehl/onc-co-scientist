+    4: { name: 'distinct_count', read: (r, t) => r.value(t) },
+    5: { name: 'max_value', read: (r) => r.bytes() },
+    6: { name: 'min_value', read: (r) => r.bytes() },
+  });
+}
+
+function columnMetaData(r) {
