+    if (type === T.FALSE) return false;
+    if (type === T.BYTE) return this.byte();
+    if (type === T.I16 || type === T.I32) return this.i32();
+    if (type === T.I64) return this.i64();
+    if (type === T.DOUBLE) return this.double();
+    if (type === T.BINARY) return this.binary();
+    throw new Error(`No scalar reader for type ${type}`);
+  }
+  skip(type) {
