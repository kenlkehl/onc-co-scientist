+const fs = require('fs');
+
+const T = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buf) {
+    this.buf = buf;
+    this.pos = 0;
+  }
+  byte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      result |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) return result;
+      shift += 7n;
+    }
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
+  }
+  zigzag(n) {
+    return (n >>> 1) ^ -(n & 1);
+  }
+  zigzagBig(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  i32() {
+    return this.zigzag(this.readVarint());
+  }
+  i64() {
+    return this.zigzagBig(this.readVarintBig());
+  }
+  binary() {
+    const n = this.readVarint();
+    const s = this.buf.toString('utf8', this.pos, this.pos + n);
+    this.pos += n;
+    return s;
+  }
+  bytes() {
+    const n = this.readVarint();
+    const out = this.buf.subarray(this.pos, this.pos + n);
+    this.pos += n;
+    return out;
+  }
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  field(lastId) {
+    const b = this.byte();
+    if (b === 0) return { type: T.STOP, id: 0 };
+    const type = b & 0x0f;
+    const delta = b >> 4;
+    const id = delta === 0 ? this.i32() : lastId + delta;
+    return { type, id };
+  }
+  listHeader() {
+    const b = this.byte();
+    const sizeNibble = b >> 4;
+    const elemType = b & 0x0f;
+    const size = sizeNibble === 15 ? this.readVarint() : sizeNibble;
+    return { size, elemType };
+  }
+  value(type) {
+    if (type === T.TRUE) return true;
+    if (type === T.FALSE) return false;
+    if (type === T.BYTE) return this.byte();
+    if (type === T.I16 || type === T.I32) return this.i32();
+    if (type === T.I64) return this.i64();
+    if (type === T.DOUBLE) return this.double();
+    if (type === T.BINARY) return this.binary();
+    throw new Error(`No scalar reader for type ${type}`);
+  }
+  skip(type) {
+    if (type === T.STOP || type === T.TRUE || type === T.FALSE) return;
+    if (type === T.BYTE) {
+      this.byte();
+    } else if (type === T.I16 || type === T.I32 || type === T.I64) {
+      this.readVarintBig();
+    } else if (type === T.DOUBLE) {
+      this.pos += 8;
+    } else if (type === T.BINARY) {
+      const n = this.readVarint();
+      this.pos += n;
+    } else if (type === T.LIST || type === T.SET) {
+      const h = this.listHeader();
+      for (let i = 0; i < h.size; i++) this.skip(h.elemType);
+    } else if (type === T.MAP) {
+      const n = this.readVarint();
+      if (n > 0) {
+        const kv = this.byte();
+        const kt = kv >> 4;
+        const vt = kv & 0x0f;
+        for (let i = 0; i < n; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+      }
+    } else if (type === T.STRUCT) {
+      let last = 0;
+      while (true) {
+        const f = this.field(last);
+        if (f.type === T.STOP) break;
+        last = f.id;
+        this.skip(f.type);
+      }
+    } else {
+      throw new Error(`Unknown type to skip ${type}`);
+    }
+  }
+}
+
+function parseStruct(r, handlers) {
+  const out = {};
+  let last = 0;
+  while (true) {
+    const f = r.field(last);
+    if (f.type === T.STOP) return out;
+    last = f.id;
+    const h = handlers[f.id];
+    if (h) out[h.name] = h.read(r, f.type);
+    else r.skip(f.type);
+  }
+}
+
+const readList = (itemReader) => (r) => {
+  const h = r.listHeader();
+  const arr = [];
+  for (let i = 0; i < h.size; i++) arr.push(itemReader(r, h.elemType));
+  return arr;
+};
+
+function schemaElement(r) {
+  return parseStruct(r, {
+    1: { name: 'type', read: (r, t) => r.value(t) },
+    2: { name: 'type_length', read: (r, t) => r.value(t) },
+    3: { name: 'repetition_type', read: (r, t) => r.value(t) },
+    4: { name: 'name', read: (r) => r.binary() },
+    5: { name: 'num_children', read: (r, t) => r.value(t) },
+    6: { name: 'converted_type', read: (r, t) => r.value(t) },
+  });
+}
+
+function statistics(r) {
+  return parseStruct(r, {
+    1: { name: 'max', read: (r) => r.bytes() },
+    2: { name: 'min', read: (r) => r.bytes() },
+    3: { name: 'null_count', read: (r, t) => r.value(t) },
+    4: { name: 'distinct_count', read: (r, t) => r.value(t) },
+    5: { name: 'max_value', read: (r) => r.bytes() },
+    6: { name: 'min_value', read: (r) => r.bytes() },
+  });
+}
+
+function columnMetaData(r) {
+  return parseStruct(r, {
+    1: { name: 'type', read: (r, t) => r.value(t) },
+    2: { name: 'encodings', read: readList((r, t) => r.value(t)) },
+    3: { name: 'path_in_schema', read: readList((r) => r.binary()) },
+    4: { name: 'codec', read: (r, t) => r.value(t) },
+    5: { name: 'num_values', read: (r, t) => r.value(t) },
+    6: { name: 'total_uncompressed_size', read: (r, t) => r.value(t) },
+    7: { name: 'total_compressed_size', read: (r, t) => r.value(t) },
+    9: { name: 'data_page_offset', read: (r, t) => r.value(t) },
+    10: { name: 'index_page_offset', read: (r, t) => r.value(t) },
+    11: { name: 'dictionary_page_offset', read: (r, t) => r.value(t) },
+    12: { name: 'statistics', read: (r) => statistics(r) },
+  });
+}
+
+function columnChunk(r) {
+  return parseStruct(r, {
+    1: { name: 'file_path', read: (r) => r.binary() },
+    2: { name: 'file_offset', read: (r, t) => r.value(t) },
+    3: { name: 'meta_data', read: (r) => columnMetaData(r) },
+  });
+}
+
+function rowGroup(r) {
+  return parseStruct(r, {
+    1: { name: 'columns', read: readList((r) => columnChunk(r)) },
+    2: { name: 'total_byte_size', read: (r, t) => r.value(t) },
+    3: { name: 'num_rows', read: (r, t) => r.value(t) },
+  });
+}
+
+function fileMetaData(r) {
+  return parseStruct(r, {
+    1: { name: 'version', read: (r, t) => r.value(t) },
+    2: { name: 'schema', read: readList((r) => schemaElement(r)) },
+    3: { name: 'num_rows', read: (r, t) => r.value(t) },
+    4: { name: 'row_groups', read: readList((r) => rowGroup(r)) },
+    5: { name: 'key_value_metadata', read: (r, t) => { r.skip(t); return undefined; } },
+    6: { name: 'created_by', read: (r) => r.binary() },
+  });
+}
+
+const file = fs.readFileSync('dataset.parquet');
+const magic = file.toString('ascii', 0, 4);
+const tailMagic = file.toString('ascii', file.length - 4);
+const footerLen = file.readInt32LE(file.length - 8);
+const footer = file.subarray(file.length - 8 - footerLen, file.length - 8);
+const meta = fileMetaData(new CompactReader(footer));
+console.log(JSON.stringify({
+  magic,
+  tailMagic,
+  footerLen,
+  version: meta.version,
+  num_rows: meta.num_rows,
+  created_by: meta.created_by,
+  schema: meta.schema,
+  row_groups: meta.row_groups.map(rg => ({
+    num_rows: rg.num_rows,
+    total_byte_size: rg.total_byte_size,
+    columns: rg.columns.map(c => c.meta_data),
+  })),
+}, null, 2));

