+    coefs[names[j]] = { beta: beta[j + 1], se: se[j + 1], t: beta[j + 1] / se[j + 1], p: normalP(beta[j + 1] / se[j + 1]) };
+  }
+  return { n: idx.length, df, r2: 1 - sse / sst, sigma: Math.sqrt(sigma2), coefs };
