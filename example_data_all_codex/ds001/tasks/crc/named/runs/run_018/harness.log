+  lines.push('Inflammation, nutrition, and disease burden: Higher albumin was favorable, while weight loss, CEA, LDH, and alkaline phosphatase were adverse on the natural month scale. CRP was weakly negative and only borderline/weakly significant depending on adjustment, and NLR did not support the hypothesized adverse direction. Liver and bone metastasis indicators were not significant in either the unadjusted or adjusted tests performed here.');
+  lines.push('');
+  lines.push('Comorbidities and treatment safety subgroups: The autoimmune-disease pembrolizumab subgroup and pembrolizumab-by-autoimmune interaction were not significant. In the all-variable scan, COPD and pericardial effusion had small negative adjusted associations, but the dominant signals remained clinical status, age, weight loss, selected tumor markers, albumin, CEA, LDH, and regorafenib.');
+  lines.push('');
+  lines.push(`The all-variable model included ${allNames.length} predictors and achieved R-squared ${allFit.r2.toFixed(3)}. The most statistically prominent adjusted coefficients included: ${Object.entries(allFit.coefs).filter(([k]) => k !== 'Intercept').map(([k, v]) => ({ variable: k, ...v })).sort((a, b) => Math.abs(b.t) - Math.abs(a.t)).slice(0, 12).map(x => `${x.variable} ${fmt(x.beta)} months`).join(', ')}.`);
+  lines.push('');
+  lines.push('Overall, the cohort shows strong independent associations for stage, ECOG performance status, age, cachexia/weight loss, albumin, CEA, LDH, KRAS, BRAF, right-sided primary, and treatment_regorafenib. Many clinically plausible biomarker-matched treatment interactions were refuted or remained null in this dataset, so the clearest treatment-biomarker conclusion is absence of detectable interaction rather than confirmed matched-therapy benefit.');
+
+  fs.writeFileSync('transcript.json', JSON.stringify(transcript, null, 2));
+  fs.writeFileSync('analysis_summary.txt', lines.join('\n'));
+
+  const diag = {
+    columns: columns.length,
+    n,
+    top_univariate_binary: univBinary.slice(0, 15).map(x => ({ variable: x.v, effect: round(x.effect, 3), p: x.p, n1: x.n1 })),
+    top_univariate_continuous: univCont.slice(0, 15).map(x => ({ variable: x.v, per_sd: round(x.per_sd, 3), slope: round(x.slope, 5), p: x.p })),
+    adjusted_r2: multiv.r2,
+    adjusted_top: topAdjusted.map(x => ({ variable: x.variable, beta: round(x.beta, 3), p: x.p })),
+    all_variable_r2: allFit.r2,
+    all_variable_top: Object.entries(allFit.coefs)
+      .filter(([k]) => k !== 'Intercept')
+      .map(([k, v]) => ({ variable: k, ...v }))
+      .sort((a, b) => Math.abs(b.t) - Math.abs(a.t))
+      .slice(0, 25)
+      .map(x => ({ variable: x.variable, beta: round(x.beta, 4), se: round(x.se, 4), p: x.p })),
+    interactions: interactions.map(x => ({ interaction: x.interName, beta: round(x.coef.beta, 4), p: x.coef.p })),
+  };
+  console.log(JSON.stringify(diag, null, 2));
+}
+
+main();

