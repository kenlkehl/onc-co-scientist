+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+  byte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      result |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) return result;
+      shift += 7n;
+    }
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
+  }
+  zigzag(n) {
