+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let c = 0; c < n; c++) {
+    let pivot = c;
+    let max = Math.abs(aug[c][c]);
+    for (let r = c + 1; r < n; r++) {
+      const v = Math.abs(aug[r][c]);
+      if (v > max) { max = v; pivot = r; }
+    }
+    if (max < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== c) [aug[pivot], aug[c]] = [aug[c], aug[pivot]];
+    const pv = aug[c][c];
+    for (let j = 0; j < 2 * n; j++) aug[c][j] /= pv;
+    for (let r = 0; r < n; r++) {
+      if (r === c) continue;
+      const f = aug[r][c];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) aug[r][j] -= f * aug[c][j];
