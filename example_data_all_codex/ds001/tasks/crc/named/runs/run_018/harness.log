+  const binaryVars = columns.filter(c => c !== 'pfs_months' && new Set(data[c]).size <= 5 && data[c].every(v => Number.isInteger(v)));
+  const continuousVars = columns.filter(c => c !== 'pfs_months' && !binaryVars.includes(c));
+  const univBinary = binaryVars.map(v => ({ v, ...binaryDiff(y, data[v]) })).sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
