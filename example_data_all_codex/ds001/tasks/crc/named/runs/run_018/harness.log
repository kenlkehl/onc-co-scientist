+    2: { name: 'type_length', read: (r, t) => r.value(t) },
+    3: { name: 'repetition_type', read: (r, t) => r.value(t) },
+    4: { name: 'name', read: (r) => r.binary() },
+    5: { name: 'num_children', read: (r, t) => r.value(t) },
+    6: { name: 'converted_type', read: (r, t) => r.value(t) },
+  });
+}
+
+function statistics(r) {
+  return parseStruct(r, {
+    1: { name: 'max', read: (r) => r.bytes() },
+    2: { name: 'min', read: (r) => r.bytes() },
+    3: { name: 'null_count', read: (r, t) => r.value(t) },
+    4: { name: 'distinct_count', read: (r, t) => r.value(t) },
+    5: { name: 'max_value', read: (r) => r.bytes() },
+    6: { name: 'min_value', read: (r) => r.bytes() },
