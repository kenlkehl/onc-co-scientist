+}
+
+function pageHeaderAt(buf, offset) {
+  const r = new CompactReader(buf, offset);
+  const header = parseStruct(r, {
+    1: { name: 'type', read: (r, t) => r.value(t) },
+    2: { name: 'uncompressed_page_size', read: (r, t) => r.value(t) },
+    3: { name: 'compressed_page_size', read: (r, t) => r.value(t) },
+    4: { name: 'crc', read: (r, t) => r.value(t) },
+    5: { name: 'data_page_header', read: (r) => dataPageHeader(r) },
