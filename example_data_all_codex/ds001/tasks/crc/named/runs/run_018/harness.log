+function ols(y, xs, names, subset = null) {
+  const idx = subset || Array.from({ length: y.length }, (_, i) => i);
+  const p = names.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let ySum = 0;
+  for (const i of idx) {
+    const row = [1];
+    for (const x of xs) row.push(x[i]);
+    ySum += y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map(row => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let sse = 0, sst = 0;
+  const yMean = ySum / idx.length;
+  for (const i of idx) {
+    let fit = beta[0];
+    for (let j = 0; j < xs.length; j++) fit += beta[j + 1] * xs[j][i];
+    const e = y[i] - fit;
+    sse += e * e;
+    const dy = y[i] - yMean;
+    sst += dy * dy;
+  }
+  const df = idx.length - p;
+  const sigma2 = sse / df;
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
