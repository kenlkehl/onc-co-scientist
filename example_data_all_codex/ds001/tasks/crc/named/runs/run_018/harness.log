+    } else if (type === T.I16 || type === T.I32 || type === T.I64) {
+      this.readVarintBig();
+    } else if (type === T.DOUBLE) {
+      this.pos += 8;
+    } else if (type === T.BINARY) {
+      const n = this.readVarint();
+      this.pos += n;
+    } else if (type === T.LIST || type === T.SET) {
+      const h = this.listHeader();
+      for (let i = 0; i < h.size; i++) this.skip(h.elemType);
+    } else if (type === T.MAP) {
