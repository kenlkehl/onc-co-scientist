+    2: { name: 'encodings', read: readList((r, t) => r.value(t)) },
+    3: { name: 'path_in_schema', read: readList((r) => r.binary()) },
+    4: { name: 'codec', read: (r, t) => r.value(t) },
+    5: { name: 'num_values', read: (r, t) => r.value(t) },
