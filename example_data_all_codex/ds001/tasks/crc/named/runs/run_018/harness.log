+
+function main() {
+  const { data, columns, n } = readParquet('dataset.parquet');
+  const y = data.pfs_months;
+  const qPfs = [0, .25, .5, .75, 1].map(q => quantile(y, q));
+  const allSummary = summarizeData(data);
