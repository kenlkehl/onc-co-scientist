+}
+
+function rowGroup(r) {
+  return parseStruct(r, {
+    1: { name: 'columns', read: readList((r) => columnChunk(r)) },
+    2: { name: 'total_byte_size', read: (r, t) => r.value(t) },
+    3: { name: 'num_rows', read: (r, t) => r.value(t) },
+  });
+}
+
+function fileMetaData(r) {
+  return parseStruct(r, {
+    1: { name: 'version', read: (r, t) => r.value(t) },
+    2: { name: 'schema', read: readList((r) => schemaElement(r)) },
+    3: { name: 'num_rows', read: (r, t) => r.value(t) },
+    4: { name: 'row_groups', read: readList((r) => rowGroup(r)) },
+    5: { name: 'key_value_metadata', read: (r, t) => { r.skip(t); return undefined; } },
+    6: { name: 'created_by', read: (r) => r.binary() },
+  });
+}
+
+function dataPageHeader(r) {
+  return parseStruct(r, {
+    1: { name: 'num_values', read: (r, t) => r.value(t) },
+    2: { name: 'encoding', read: (r, t) => r.value(t) },
+    3: { name: 'definition_level_encoding', read: (r, t) => r.value(t) },
+    4: { name: 'repetition_level_encoding', read: (r, t) => r.value(t) },
+    5: { name: 'statistics', read: (r) => statistics(r) },
+  });
+}
+
+function dictionaryPageHeader(r) {
+  return parseStruct(r, {
+    1: { name: 'num_values', read: (r, t) => r.value(t) },
+    2: { name: 'encoding', read: (r, t) => r.value(t) },
+    3: { name: 'is_sorted', read: (r, t) => r.value(t) },
+  });
+}
+
+function dataPageHeaderV2(r) {
+  return parseStruct(r, {
+    1: { name: 'num_values', read: (r, t) => r.value(t) },
+    2: { name: 'num_nulls', read: (r, t) => r.value(t) },
+    3: { name: 'num_rows', read: (r, t) => r.value(t) },
+    4: { name: 'encoding', read: (r, t) => r.value(t) },
+    5: { name: 'definition_levels_byte_length', read: (r, t) => r.value(t) },
+    6: { name: 'repetition_levels_byte_length', read: (r, t) => r.value(t) },
+    7: { name: 'is_compressed', read: (r, t) => r.value(t) },
+    8: { name: 'statistics', read: (r) => statistics(r) },
