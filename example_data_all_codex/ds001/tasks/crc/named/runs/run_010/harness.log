"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from scipy import stats

path = 'dataset.parquet'
df = pd.read_parquet(path)
print('shape', df.shape)
print('columns')
print('\\n'.join(df.columns))
print('\\ndtypes')
print(df.dtypes.to_string())
print('\\noutcome summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())

binary_cols=[]
for c in df.columns:
    if c == 'pfs_months':
        continue
    vals = set(df[c].dropna().unique().tolist())
    if vals.issubset({0,1,False,True}):
        binary_cols.append(c)
print('\\nbinary prevalence and mean outcome difference (1-0):')
rows=[]
for c in binary_cols:
    n1=int(df[c].sum())
    n0=len(df)-n1
    m1=df.loc[df[c]==1,'pfs_months'].mean()
    m0=df.loc[df[c]==0,'pfs_months'].mean()
    if n1>1 and n0>1:
        t,p=stats.ttest_ind(df.loc[df[c]==1,'pfs_months'], df.loc[df[c]==0,'pfs_months'], equal_var=False)
    else:
        p=np.nan
    rows.append((c,n1,n1/len(df),m1,m0,m1-m0,p))
for r in sorted(rows, key=lambda x: abs(x[5]), reverse=True)[:40]:
    print(f'{r[0]:38s} n1={r[1]:6d} prev={r[2]:.4f} mean1={r[3]:.3f} mean0={r[4]:.3f} diff={r[5]:+.3f} p={r[6]:.3g}')

cont_cols=[c for c in df.columns if c not in binary_cols and c"'!='"'pfs_months']
print('\\ncontinuous correlations with pfs_months:')
cont_rows=[]
for c in cont_cols:
    r,p=stats.pearsonr(df[c], df['pfs_months'])
    # slope y per one unit x
    slope=np.cov(df[c], df['pfs_months'], ddof=1)[0,1]/np.var(df[c], ddof=1)
    cont_rows.append((c,r,slope,p,df[c].mean(),df[c].std()))
for c,r,slope,p,mean,sd in sorted(cont_rows, key=lambda x: abs(x[1]), reverse=True):
    print(f'{c:38s} r={r:+.3f} slope={slope:+.4f} p={p:.3g} mean={mean:.3f} sd={sd:.3f}')

# treatment biomarker subgroup crude means
print('\\ntreatment by candidate biomarker crude subgroup means and ns')
pairs=[
('treatment_pembrolizumab','msi_high'),
('treatment_cetuximab','kras_mutation'),
('treatment_cetuximab','nras_mutation'),
('treatment_cetuximab','right_sided_primary'),
('treatment_encorafenib','braf_v600e'),
('treatment_trastuzumab_tucatinib','her2_amplified'),
('treatment_trastuzumab_tucatinib','her2_amplification'),
('treatment_bevacizumab','liver_mets'),
('treatment_regorafenib','ecog_ps'),
]
for tr,b in pairs:
    if tr in df and b in df:
        print(f'PAIR {tr} x {b}')
        if b in binary_cols:
            print(df.groupby([b,tr])['pfs_months'].agg(['count','mean']).to_string())
        else:
            # b continuous/integer ECOG: group by values if few
            print(df.groupby([b,tr])['pfs_months'].agg(['count','mean']).head(20).to_string())
