const fs = require('fs');
const file = fs.readFileSync('dataset.parquet');
function readFooter(buf) {
  const magic = buf.subarray(buf.length-4).toString('ascii');
  if (magic "'!== '"'PAR1') throw new Error('bad magic '+magic);
  const len = buf.readUInt32LE(buf.length-8);
  const start = buf.length - 8 - len;
  return buf.subarray(start, start+len);
}
class CompactReader {
  constructor(buf){this.buf=buf; this.pos=0;}
  readByte(){return this.buf[this.pos++];}
  readVarint(){let shift=0n, result=0n; while(true){const b=this.readByte(); result |= BigInt(b & 0x7f) << shift; if ((b & 0x80)===0) break; shift += 7n;} return result;}
