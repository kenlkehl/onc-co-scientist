+  skip(type) {
+    switch (type) {
+      case CT.STOP:
+      case CT.TRUE:
+      case CT.FALSE:
+        return;
+      case CT.BYTE:
+        this.p += 1;
+        return;
+      case CT.I16:
+      case CT.I32:
+        this.intNumber();
+        return;
+      case CT.I64:
+        this.int64();
+        return;
+      case CT.DOUBLE:
+        this.p += 8;
+        return;
+      case CT.BINARY:
+        this.binary();
+        return;
+      case CT.LIST:
+      case CT.SET: {
