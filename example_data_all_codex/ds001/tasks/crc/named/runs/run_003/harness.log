+    } else if (parquetType === 6) {
+      const len = data.readInt32LE(p);
+      p += 4;
+      values.push(data.subarray(p, p + len).toString("utf8"));
+      p += len;
+    } else {
+      throw new Error(`unsupported physical type ${parquetType}`);
+    }
+  }
+  return values;
+}
+
+function readRleBitPacked(buf, bitWidth, expectedCount) {
+  let p = 0;
+  const out = [];
+  const readUnsignedVarint = () => {
+    let n = 0;
+    let shift = 0;
+    while (true) {
+      const byte = buf[p++];
+      n |= (byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
+      shift += 7;
+    }
+    return n;
+  };
+  const bytesForValue = Math.ceil(bitWidth / 8);
+  while (out.length < expectedCount && p < buf.length) {
+    const header = readUnsignedVarint();
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < bytesForValue; i++) value |= buf[p++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < expectedCount; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const valueCount = groups * 8;
+      let bits = 0;
+      let bitPos = 0;
+      for (let i = 0; i < valueCount && out.length < expectedCount; i++) {
+        while (bitPos < bitWidth) {
+          bits |= buf[p++] << bitPos;
+          bitPos += 8;
+        }
+        out.push(bits & ((1 << bitWidth) - 1));
+        bits >>>= bitWidth;
+        bitPos -= bitWidth;
+      }
+    }
+  }
+  if (out.length !== expectedCount) throw new Error(`decoded ${out.length}, expected ${expectedCount}`);
+  return out;
+}
+
+function readParquet() {
+  const file = fs.readFileSync(PARQUET_FILE);
+  if (file.subarray(0, 4).toString("ascii") !== "PAR1") throw new Error("bad header");
+  if (file.subarray(file.length - 4).toString("ascii") !== "PAR1") throw new Error("bad footer");
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const footerStart = file.length - 8 - footerLen;
+  const meta = new CompactReader(file.subarray(footerStart, file.length - 8)).struct(FileMeta);
+  const rg = meta.row_groups[0];
+  const df = {};
+  const schemaByName = new Map();
+  for (const s of meta.schema.slice(1)) schemaByName.set(s.name, s);
+
+  for (const col of rg.columns) {
+    const md = col.meta_data;
+    const name = md.path_in_schema[0];
+    const schema = schemaByName.get(name);
+    const values = [];
+    let dictionary = null;
+    let pos = md.dictionary_page_offset ?? md.data_page_offset;
+    const end = pos + md.total_compressed_size;
+    while (pos < end && values.length < md.num_values) {
+      const reader = new CompactReader(file, pos);
+      const header = reader.struct(PageHeader);
+      pos = reader.p;
+      const pageCompressed = file.subarray(pos, pos + header.compressed_page_size);
+      pos += header.compressed_page_size;
+      const page =
+        md.codec === 1 ? snappyUncompress(pageCompressed) : Buffer.from(pageCompressed);
+      if (header.type === 2) {
+        dictionary = decodePlainDictionary(
+          page,
+          md.type,
+          header.dictionary_page_header.num_values,
+        );
+      } else if (header.type === 0) {
+        const h = header.data_page_header;
+        let body = page;
+        if (schema.repetition_type === 1) {
+          const defLevelByteLength = body.readInt32LE(0);
+          body = body.subarray(4 + defLevelByteLength);
+        }
+        if (h.encoding === 8 || h.encoding === 2) {
+          const bitWidth = body[0];
+          const indexes = readRleBitPacked(body.subarray(1), bitWidth, h.num_values);
+          for (const idx of indexes) values.push(dictionary[idx]);
+        } else if (h.encoding === 0) {
+          const plain = decodePlainDictionary(body, md.type, h.num_values);
+          values.push(...plain);
+        } else {
+          throw new Error(`unsupported data page encoding ${h.encoding} for ${name}`);
+        }
+      } else if (header.type === 3) {
+        const h = header.data_page_header_v2;
+        let body = page.subarray(
+          (h.definition_levels_byte_length || 0) + (h.repetition_levels_byte_length || 0),
+        );
+        if (h.encoding === 8 || h.encoding === 2) {
+          const bitWidth = body[0];
+          const indexes = readRleBitPacked(body.subarray(1), bitWidth, h.num_values);
+          for (const idx of indexes) values.push(dictionary[idx]);
+        } else if (h.encoding === 0) {
+          values.push(...decodePlainDictionary(body, md.type, h.num_values));
+        } else {
+          throw new Error(`unsupported data page v2 encoding ${h.encoding} for ${name}`);
+        }
+      }
+    }
+    if (values.length !== md.num_values) throw new Error(`${name}: ${values.length} != ${md.num_values}`);
+    if (schema.converted_type === 0 && md.type === 6) {
+      df[name] = values;
+    } else {
+      df[name] = values.map(Number);
+    }
+  }
