+  const footerStart = file.length - 8 - footerLen;
+  const meta = new CompactReader(file.subarray(footerStart, file.length - 8)).struct(FileMeta);
+  const rg = meta.row_groups[0];
+  const df = {};
+  const schemaByName = new Map();
+  for (const s of meta.schema.slice(1)) schemaByName.set(s.name, s);
+
+  for (const col of rg.columns) {
+    const md = col.meta_data;
+    const name = md.path_in_schema[0];
+    const schema = schemaByName.get(name);
+    const values = [];
+    let dictionary = null;
+    let pos = md.dictionary_page_offset ?? md.data_page_offset;
+    const end = pos + md.total_compressed_size;
