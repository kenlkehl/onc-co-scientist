+      "msi_high",
+      "braf_v600e",
+      "kras_mutation",
+      "her2_amplified",
+      "ntrk_fusion",
+      ...adjustNames,
+    ],
+  );
+
+  const iterations = [];
+  let hid = 1;
+  function addIteration(text, analysis) {
+    const id = `h${hid++}`;
+    iterations.push({
+      index: iterations.length + 1,
+      proposed_hypotheses: [{ id, text, kind: iterations.length === 0 ? "novel" : "refined" }],
+      analyses: [{
+        hypothesis_ids: [id],
+        code: analysis.code || null,
+        result_summary: analysis.summary,
+        p_value: analysis.p,
+        effect_estimate: analysis.effect,
+        significant: analysis.p < 0.05,
+      }],
+    });
+  }
+
+  function addTermHyp(text, term, modelDesc) {
+    addIteration(text, {
+      effect: round(term.beta),
+      p: term.p,
+      summary: `${modelDesc}: adjusted effect ${round(term.beta)} months of pfs_months (SE ${round(term.se)}, z ${round(term.z, 3)}, p=${formatP(term.p)}).`,
+      code: modelDesc,
+    });
+  }
+
+  addTermHyp("Patients with `msi_high` have higher mean `pfs_months` than patients without `msi_high`, after adjustment for age, sex, ECOG performance status, stage, sidedness, inflammatory markers, albumin, LDH, weight loss, NLR, and metastatic burden.", baselineModel.terms.msi_high, "OLS: pfs_months ~ msi_high + braf_v600e + kras_mutation + her2_amplified + ntrk_fusion + clinical covariates");
+  addTermHyp("Patients with `braf_v600e` have lower mean `pfs_months` than patients without `braf_v600e`, after the same clinical and biomarker adjustment.", baselineModel.terms.braf_v600e, "OLS: pfs_months ~ braf_v600e + other biomarkers + clinical covariates");
+  addTermHyp("Patients with `kras_mutation` have lower mean `pfs_months` than patients without `kras_mutation`, after clinical and biomarker adjustment.", baselineModel.terms.kras_mutation, "OLS: pfs_months ~ kras_mutation + other biomarkers + clinical covariates");
+  addTermHyp("Higher `albumin_g_dl` is associated with higher `pfs_months`, with the effect estimated per one standard deviation increase in albumin after adjustment.", global.albumin_g_dl_z, "OLS: pfs_months ~ albumin_g_dl_z + clinical covariates");
+  addTermHyp("Higher `ldh_u_l` is associated with lower `pfs_months`, with the effect estimated per one standard deviation increase in LDH after adjustment.", global.ldh_u_l_z, "OLS: pfs_months ~ ldh_u_l_z + clinical covariates");
+  addTermHyp("Higher `crp_mg_l` is associated with lower `pfs_months`, with the effect estimated per one standard deviation increase in CRP after adjustment.", global.crp_mg_l_z, "OLS: pfs_months ~ crp_mg_l_z + clinical covariates");
+  addTermHyp("Higher `nlr` is associated with lower `pfs_months`, with the effect estimated per one standard deviation increase in NLR after adjustment.", global.nlr_z, "OLS: pfs_months ~ nlr_z + clinical covariates");
+  addTermHyp("Patients with `liver_mets` have lower mean `pfs_months` than patients without `liver_mets`, after adjustment for clinical covariates.", global.liver_mets, "OLS: pfs_months ~ liver_mets + clinical covariates");
+  addTermHyp("Patients receiving `treatment_pembrolizumab` have a larger increase in `pfs_months` when `msi_high` is present than when `msi_high` is absent.", interactions.pembrolizumab_msi, "OLS interaction: pfs_months ~ treatment_pembrolizumab * msi_high + clinical covariates");
+  addTermHyp("Among patients with `msi_high`, `treatment_pembrolizumab` is associated with higher mean `pfs_months` than no `treatment_pembrolizumab`.", adjustedTerm("treatment_pembrolizumab_in_msi_high", df.treatment_pembrolizumab.map((v, i) => v * df.msi_high[i])), "OLS: pfs_months ~ treatment_pembrolizumab_in_msi_high + clinical covariates");
+  addTermHyp("Patients receiving `treatment_encorafenib` have a larger increase in `pfs_months` when `braf_v600e` is present than when `braf_v600e` is absent.", interactions.encorafenib_braf, "OLS interaction: pfs_months ~ treatment_encorafenib * braf_v600e + clinical covariates");
+  addTermHyp("Among patients with `braf_v600e`, `treatment_encorafenib` is associated with higher mean `pfs_months` than no `treatment_encorafenib`.", adjustedTerm("treatment_encorafenib_in_braf_v600e", df.treatment_encorafenib.map((v, i) => v * df.braf_v600e[i])), "OLS: pfs_months ~ treatment_encorafenib_in_braf_v600e + clinical covariates");
+  addTermHyp("Patients receiving `treatment_trastuzumab_tucatinib` have a larger increase in `pfs_months` when `her2_amplified` is present than when `her2_amplified` is absent.", interactions.trastuzumab_her2, "OLS interaction: pfs_months ~ treatment_trastuzumab_tucatinib * her2_amplified + clinical covariates");
