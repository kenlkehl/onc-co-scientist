+  lines.push("");
+  lines.push(`Overall mean pfs_months was ${round(mean(y), 2)} months. I used ordinary least squares models with pfs_months on its natural month scale; continuous laboratory/tumor-burden markers were standardized when used as main-effect covariates. Interaction models included the two main effects plus their product and adjusted for age_years, sex_female, ecog_ps, stage_iv, right_sided_primary, cea_ng_ml, albumin_g_dl, ldh_u_l, weight_loss_pct_6mo, crp_mg_l, nlr, liver_mets, bone_mets, and pleural_effusion.`);
