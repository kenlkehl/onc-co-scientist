+
+function ols(y, xColumns, columnNames) {
+  const n = y.length;
+  const p = xColumns.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...xColumns.map((col) => col[i])];
+    yty += y[i] * y[i];
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = 0; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let j = 0; j < p; j++) {
+    for (let k = 0; k < p; k++) beta[j] += inv[j][k] * xty[k];
