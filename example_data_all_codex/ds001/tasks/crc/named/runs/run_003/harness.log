+        Object.entries(subgroupDiff).map(([k, v]) => [k, Object.fromEntries(Object.entries(v).map(([kk, vv]) => [kk, round(vv, 4)]))]),
+      ),
+    },
+  };
+
+  const lines = [];
+  lines.push("Dataset ds001_crc: 50,000 colorectal cancer records with pfs_months as the outcome.");
+  lines.push("");
+  lines.push(`Overall mean pfs_months was ${round(mean(y), 2)} months. I used ordinary least squares models with pfs_months on its natural month scale; continuous laboratory/tumor-burden markers were standardized when used as main-effect covariates. Interaction models included the two main effects plus their product and adjusted for age_years, sex_female, ecog_ps, stage_iv, right_sided_primary, cea_ng_ml, albumin_g_dl, ldh_u_l, weight_loss_pct_6mo, crp_mg_l, nlr, liver_mets, bone_mets, and pleural_effusion.`);
+  lines.push("");
+  lines.push("Baseline prognosis and tumor biology:");
+  lines.push(`- msi_high was favorable after adjustment (effect ${round(baselineModel.terms.msi_high.beta)} months, p=${formatP(baselineModel.terms.msi_high.p)}).`);
+  lines.push(`- braf_v600e and kras_mutation were adverse (effects ${round(baselineModel.terms.braf_v600e.beta)} and ${round(baselineModel.terms.kras_mutation.beta)} months, respectively; both p=${formatP(Math.max(baselineModel.terms.braf_v600e.p, baselineModel.terms.kras_mutation.p))} or smaller).`);
+  lines.push(`- Host/tumor-burden markers showed coherent prognostic signal: albumin_g_dl was positive (${round(global.albumin_g_dl_z.beta)} months per SD, p=${formatP(global.albumin_g_dl_z.p)}), whereas ldh_u_l, crp_mg_l, and nlr were negative (${round(global.ldh_u_l_z.beta)}, ${round(global.crp_mg_l_z.beta)}, and ${round(global.nlr_z.beta)} months per SD; all significant).`);
+  lines.push(`- Metastatic/effusion features were adverse: liver_mets ${round(global.liver_mets.beta)} months, bone_mets ${round(global.bone_mets.beta)} months, and pleural_effusion ${round(global.pleural_effusion.beta)} months; all p=${formatP(Math.max(global.liver_mets.p, global.bone_mets.p, global.pleural_effusion.p))} or smaller.`);
+  lines.push("");
+  lines.push("Treatment-biomarker heterogeneity:");
+  lines.push(`- Pembrolizumab had a strong positive interaction with msi_high (interaction ${round(interactions.pembrolizumab_msi.beta)} months, p=${formatP(interactions.pembrolizumab_msi.p)}). Unadjusted subgroup contrasts were ${round(subgroupDiff.pembro_msi_high.diff)} months in MSI-high patients versus ${round(subgroupDiff.pembro_msi_low.diff)} months in non-MSI-high patients.`);
+  lines.push(`- Encorafenib was concentrated in BRAF V600E disease: the treatment_encorafenib:braf_v600e interaction was ${round(interactions.encorafenib_braf.beta)} months (p=${formatP(interactions.encorafenib_braf.p)}), and the unadjusted BRAF-positive contrast was ${round(subgroupDiff.encor_braf_pos.diff)} months.`);
+  lines.push(`- Trastuzumab/tucatinib similarly aligned with HER2 amplification: interaction ${round(interactions.trastuzumab_her2.beta)} months (p=${formatP(interactions.trastuzumab_her2.p)}), with an unadjusted HER2-positive contrast of ${round(subgroupDiff.trast_her2_pos.diff)} months.`);
+  lines.push(`- Cetuximab benefit was attenuated in KRAS-mutant, NRAS-mutant, and right-sided-primary subgroups (interactions ${round(interactions.cetuximab_kras.beta)}, ${round(interactions.cetuximab_nras.beta)}, and ${round(interactions.cetuximab_right.beta)} months; all significant).`);
+  lines.push("");
+  lines.push("Other treatment interactions and refuted hypotheses:");
+  lines.push(`- Bevacizumab showed evidence of larger association in stage_iv disease (${round(interactions.bevacizumab_stage.beta)} months, p=${formatP(interactions.bevacizumab_stage.p)}) but no statistically supported attenuation by venous_thromboembolism_history (${round(interactions.bevacizumab_vte.beta)} months, p=${formatP(interactions.bevacizumab_vte.p)}).`);
+  lines.push(`- Pembrolizumab attenuation by autoimmune_disease was not supported (${round(interactions.pembrolizumab_autoimmune.beta)} months, p=${formatP(interactions.pembrolizumab_autoimmune.p)}).`);
+  lines.push(`- Regorafenib was adverse as a main effect (${round(global.treatment_regorafenib.beta)} months, p=${formatP(global.treatment_regorafenib.p)}), while the hypothesized worsening with higher ecog_ps was not significant (${round(interactions.regorafenib_ecog.beta)} months per ECOG point, p=${formatP(interactions.regorafenib_ecog.p)}).`);
+  lines.push(`- Autoimmune disease itself was not an independent adverse prognostic factor in the adjusted model (${round(global.autoimmune_disease.beta)} months, p=${formatP(global.autoimmune_disease.p)}).`);
+  lines.push("");
+  lines.push("Overall conclusion: the strongest patterns were clinically coherent treatment-biomarker relationships: pembrolizumab with MSI-high disease, encorafenib with BRAF V600E, trastuzumab/tucatinib with HER2 amplification, and reduced cetuximab benefit in RAS-mutant or right-sided disease. Baseline inflammatory, nutritional, and metastatic-burden variables also carried independent prognostic information for progression-free survival. Several safety/comorbidity interaction ideas were tested but not statistically supported in this cohort.");
+
+  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2));
+  fs.writeFileSync("analysis_summary.txt", lines.join("\n"));
+
