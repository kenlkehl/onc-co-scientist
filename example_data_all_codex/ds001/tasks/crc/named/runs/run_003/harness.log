+  2: { name: "uncompressed_page_size", kind: "i32" },
+  3: { name: "compressed_page_size", kind: "i32" },
+  4: { name: "crc", kind: "i32" },
+  5: { name: "data_page_header", kind: "struct", spec: DataPageHeader },
+  7: { name: "dictionary_page_header", kind: "struct", spec: DictionaryPageHeader },
+  8: { name: "data_page_header_v2", kind: "struct", spec: DataPageHeaderV2 },
