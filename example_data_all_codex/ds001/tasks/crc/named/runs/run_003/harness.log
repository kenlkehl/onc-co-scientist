+  while (out.length < expectedCount && p < buf.length) {
+    const header = readUnsignedVarint();
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < bytesForValue; i++) value |= buf[p++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < expectedCount; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const valueCount = groups * 8;
