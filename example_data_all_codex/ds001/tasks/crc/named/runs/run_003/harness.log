+
+const DataPageHeaderV2 = {
+  1: { name: "num_values", kind: "i32" },
+  2: { name: "num_nulls", kind: "i32" },
+  3: { name: "num_rows", kind: "i32" },
+  4: { name: "encoding", kind: "enum" },
+  5: { name: "definition_levels_byte_length", kind: "i32" },
+  6: { name: "repetition_levels_byte_length", kind: "i32" },
+  7: { name: "is_compressed", kind: "bool" },
