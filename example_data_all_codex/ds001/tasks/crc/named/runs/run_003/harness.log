+
+function ols(y, xColumns, columnNames) {
+  const n = y.length;
+  const p = xColumns.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...xColumns.map((col) => col[i])];
+    yty += y[i] * y[i];
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = 0; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let j = 0; j < p; j++) {
+    for (let k = 0; k < p; k++) beta[j] += inv[j][k] * xty[k];
+  }
+  let sse = yty;
+  for (let j = 0; j < p; j++) sse -= beta[j] * xty[j];
+  const sigma2 = sse / (n - p);
+  const terms = { intercept: { beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]) } };
+  for (let j = 1; j < p; j++) {
+    const se = Math.sqrt(sigma2 * inv[j][j]);
+    terms[columnNames[j - 1]] = {
+      beta: beta[j],
+      se,
+      z: beta[j] / se,
+      p: pFromZ(beta[j] / se),
