+  2: { name: "total_byte_size", kind: "i64" },
+  3: { name: "num_rows", kind: "i64" },
+  5: { name: "file_offset", kind: "i64" },
+  6: { name: "total_compressed_size", kind: "i64" },
+  7: { name: "ordinal", kind: "i32" },
