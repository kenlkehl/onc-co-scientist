+  const covariates = [
+    "age_years",
+    "sex_female",
+    "ecog_ps",
+    "stage_iv",
+    "right_sided_primary",
+    "cea_ng_ml",
+    "albumin_g_dl",
+    "ldh_u_l",
+    "weight_loss_pct_6mo",
+    "crp_mg_l",
+    "nlr",
+    "liver_mets",
+    "bone_mets",
+    "pleural_effusion",
