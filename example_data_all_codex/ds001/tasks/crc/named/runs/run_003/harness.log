+
+const ColumnChunk = {
+  1: { name: "file_path", kind: "string" },
+  2: { name: "file_offset", kind: "i64" },
+  3: { name: "meta_data", kind: "struct", spec: ColumnMetaData },
+  4: { name: "offset_index_offset", kind: "i64" },
+  5: { name: "offset_index_length", kind: "i32" },
