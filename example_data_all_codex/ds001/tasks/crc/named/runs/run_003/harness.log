+
+const SchemaElement = {
+  1: { name: "type", kind: "enum" },
+  2: { name: "type_length", kind: "i32" },
+  3: { name: "repetition_type", kind: "enum" },
+  4: { name: "name", kind: "string" },
+  5: { name: "num_children", kind: "i32" },
+  6: { name: "converted_type", kind: "enum" },
+  7: { name: "scale", kind: "i32" },
+  8: { name: "precision", kind: "i32" },
+  9: { name: "field_id", kind: "i32" },
+};
+
+const ColumnMetaData = {
+  1: { name: "type", kind: "enum" },
+  2: { name: "encodings", kind: "list", elemKind: "enum" },
+  3: { name: "path_in_schema", kind: "list", elemKind: "string" },
