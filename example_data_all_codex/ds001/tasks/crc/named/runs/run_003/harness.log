+function snappyUncompress(input) {
+  let p = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const c = input[p++];
+    len |= (c & 0x7f) << shift;
+    if ((c & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (p < input.length) {
+    const tag = input[p++];
+    const type = tag & 0x03;
+    if (type === 0) {
