+function snappyUncompress(input) {
+  let p = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const c = input[p++];
+    len |= (c & 0x7f) << shift;
+    if ((c & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (p < input.length) {
+    const tag = input[p++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
+        const bytes = literalLen - 59;
+        literalLen = 1;
+        for (let i = 0; i < bytes; i++) literalLen += input[p++] << (8 * i);
+      }
+      input.copy(out, op, p, p + literalLen);
+      p += literalLen;
+      op += literalLen;
+    } else {
+      let copyLen;
+      let offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[p++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[p] | (input[p + 1] << 8);
+        p += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = input[p] | (input[p + 1] << 8) | (input[p + 2] << 16) | (input[p + 3] << 24);
