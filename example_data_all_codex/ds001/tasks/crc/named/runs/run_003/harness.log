+const fs = require("fs");
+
+const PARQUET_FILE = "dataset.parquet";
+const N_ROWS_EXPECTED = 50000;
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buf, offset = 0, limit = buf.length) {
+    this.b = buf;
+    this.p = offset;
+    this.limit = limit;
+  }
+
+  u8() {
+    if (this.p >= this.limit) throw new Error("read past end");
+    return this.b[this.p++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let n = 0n;
+    while (true) {
+      const byte = this.u8();
+      n |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return n;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  intNumber() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  int64() {
+    const v = this.zigzag(this.varint());
+    return v <= BigInt(Number.MAX_SAFE_INTEGER) && v >= BigInt(Number.MIN_SAFE_INTEGER)
+      ? Number(v)
+      : v.toString();
+  }
+
+  binary() {
+    const len = Number(this.varint());
+    const out = this.b.subarray(this.p, this.p + len);
+    this.p += len;
+    return out;
+  }
+
+  string() {
+    return this.binary().toString("utf8");
+  }
+
+  listHeader() {
+    const h = this.u8();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+
+  skip(type) {
+    switch (type) {
+      case CT.STOP:
+      case CT.TRUE:
+      case CT.FALSE:
+        return;
+      case CT.BYTE:
+        this.p += 1;
+        return;
+      case CT.I16:
+      case CT.I32:
+        this.intNumber();
+        return;
+      case CT.I64:
+        this.int64();
+        return;
+      case CT.DOUBLE:
+        this.p += 8;
+        return;
+      case CT.BINARY:
+        this.binary();
+        return;
+      case CT.LIST:
+      case CT.SET: {
+        const { size, type: elemType } = this.listHeader();
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
