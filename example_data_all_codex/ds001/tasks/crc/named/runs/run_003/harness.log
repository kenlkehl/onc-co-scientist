+  addTermHyp("Patients receiving `treatment_cetuximab` have a smaller increase in `pfs_months` when `kras_mutation` is present than when `kras_mutation` is absent.", interactions.cetuximab_kras, "OLS interaction: pfs_months ~ treatment_cetuximab * kras_mutation + clinical covariates");
+  addTermHyp("Patients receiving `treatment_cetuximab` have a smaller increase in `pfs_months` when `nras_mutation` is present than when `nras_mutation` is absent.", interactions.cetuximab_nras, "OLS interaction: pfs_months ~ treatment_cetuximab * nras_mutation + clinical covariates");
+  addTermHyp("Patients receiving `treatment_cetuximab` have a smaller increase in `pfs_months` when `right_sided_primary` is present than when `right_sided_primary` is absent.", interactions.cetuximab_right, "OLS interaction: pfs_months ~ treatment_cetuximab * right_sided_primary + clinical covariates");
