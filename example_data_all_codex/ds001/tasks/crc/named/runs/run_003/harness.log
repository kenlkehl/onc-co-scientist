+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask && !mask[i]) continue;
+    s += arr[i];
+    n++;
+  }
+  return s / n;
+}
