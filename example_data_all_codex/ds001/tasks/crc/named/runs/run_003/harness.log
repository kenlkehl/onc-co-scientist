+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask && !mask[i]) continue;
+    s += arr[i];
+    n++;
+  }
+  return s / n;
+}
+
+function countWhere(arr, value = 1) {
+  let n = 0;
+  for (const x of arr) if (x === value) n++;
+  return n;
+}
+
+function variance(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const x of arr) ss += (x - m) ** 2;
+  return ss / (arr.length - 1);
+}
