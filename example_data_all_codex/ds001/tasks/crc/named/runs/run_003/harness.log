+  varint() {
+    let shift = 0n;
+    let n = 0n;
+    while (true) {
+      const byte = this.u8();
+      n |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return n;
+  }
