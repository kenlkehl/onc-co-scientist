+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask && !mask[i]) continue;
+    s += arr[i];
+    n++;
+  }
+  return s / n;
+}
+
+function countWhere(arr, value = 1) {
+  let n = 0;
+  for (const x of arr) if (x === value) n++;
+  return n;
+}
+
+function variance(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const x of arr) ss += (x - m) ** 2;
+  return ss / (arr.length - 1);
+}
+
+function normalCdf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const z = Math.abs(x) / Math.SQRT2;
+  const t = 1 / (1 + 0.3275911 * z);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const erf = sign * (1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-z * z));
+  return 0.5 * (1 + erf);
+}
+
+function pFromZ(z) {
+  const az = Math.abs(z);
+  if (az > 37) return 1e-300;
+  const p = 2 * (1 - normalCdf(az));
+  return Math.max(p, 1e-300);
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => [
+    ...row.map(Number),
+    ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0)),
+  ]);
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    }
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error("singular matrix");
+    [aug[col], aug[pivot]] = [aug[pivot], aug[col]];
+    const div = aug[col][col];
+    for (let c = 0; c < 2 * n; c++) aug[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = aug[r][col];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) aug[r][c] -= factor * aug[col][c];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function ols(y, xColumns, columnNames) {
+  const n = y.length;
+  const p = xColumns.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...xColumns.map((col) => col[i])];
+    yty += y[i] * y[i];
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = 0; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let j = 0; j < p; j++) {
+    for (let k = 0; k < p; k++) beta[j] += inv[j][k] * xty[k];
+  }
+  let sse = yty;
+  for (let j = 0; j < p; j++) sse -= beta[j] * xty[j];
+  const sigma2 = sse / (n - p);
+  const terms = { intercept: { beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]) } };
+  for (let j = 1; j < p; j++) {
+    const se = Math.sqrt(sigma2 * inv[j][j]);
+    terms[columnNames[j - 1]] = {
+      beta: beta[j],
+      se,
+      z: beta[j] / se,
+      p: pFromZ(beta[j] / se),
+    };
+  }
+  return { n, p, beta, terms, sse, sigma2 };
+}
+
+function buildStandardized(values) {
+  const m = mean(values);
+  const sd = Math.sqrt(variance(values));
+  return values.map((v) => (v - m) / sd);
+}
+
+function product(a, b) {
+  return a.map((v, i) => v * b[i]);
+}
+
+function diffMeans(y, group) {
+  let s1 = 0;
+  let n1 = 0;
+  let s0 = 0;
+  let n0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (group[i]) {
+      s1 += y[i];
+      n1++;
+    } else {
+      s0 += y[i];
+      n0++;
+    }
+  }
+  return { mean1: s1 / n1, mean0: s0 / n0, diff: s1 / n1 - s0 / n0, n1, n0 };
+}
+
+function formatP(p) {
+  if (p < 1e-250) return "<1e-250";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toPrecision(3);
+}
+
+function round(x, digits = 4) {
+  return Number(x.toFixed(digits));
+}
