+      let bitPos = 0;
+      for (let i = 0; i < valueCount && out.length < expectedCount; i++) {
+        while (bitPos < bitWidth) {
+          bits |= buf[p++] << bitPos;
+          bitPos += 8;
+        }
+        out.push(bits & ((1 << bitWidth) - 1));
+        bits >>>= bitWidth;
+        bitPos -= bitWidth;
+      }
