+        if (h.encoding === 8 || h.encoding === 2) {
+          const bitWidth = body[0];
+          const indexes = readRleBitPacked(body.subarray(1), bitWidth, h.num_values);
+          for (const idx of indexes) values.push(dictionary[idx]);
+        } else if (h.encoding === 0) {
+          values.push(...decodePlainDictionary(body, md.type, h.num_values));
+        } else {
+          throw new Error(`unsupported data page v2 encoding ${h.encoding} for ${name}`);
+        }
+      }
