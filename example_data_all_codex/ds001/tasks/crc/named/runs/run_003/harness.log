+
+const DataPageHeader = {
+  1: { name: "num_values", kind: "i32" },
+  2: { name: "encoding", kind: "enum" },
+  3: { name: "definition_level_encoding", kind: "enum" },
+  4: { name: "repetition_level_encoding", kind: "enum" },
+};
+
+const DictionaryPageHeader = {
+  1: { name: "num_values", kind: "i32" },
+  2: { name: "encoding", kind: "enum" },
+  3: { name: "is_sorted", kind: "bool" },
+};
+
+const DataPageHeaderV2 = {
+  1: { name: "num_values", kind: "i32" },
+  2: { name: "num_nulls", kind: "i32" },
+  3: { name: "num_rows", kind: "i32" },
+  4: { name: "encoding", kind: "enum" },
+  5: { name: "definition_levels_byte_length", kind: "i32" },
+  6: { name: "repetition_levels_byte_length", kind: "i32" },
+  7: { name: "is_compressed", kind: "bool" },
+};
+
+const PageHeader = {
+  1: { name: "type", kind: "enum" },
+  2: { name: "uncompressed_page_size", kind: "i32" },
+  3: { name: "compressed_page_size", kind: "i32" },
+  4: { name: "crc", kind: "i32" },
+  5: { name: "data_page_header", kind: "struct", spec: DataPageHeader },
+  7: { name: "dictionary_page_header", kind: "struct", spec: DictionaryPageHeader },
+  8: { name: "data_page_header_v2", kind: "struct", spec: DataPageHeaderV2 },
+};
+
+function snappyUncompress(input) {
+  let p = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const c = input[p++];
+    len |= (c & 0x7f) << shift;
+    if ((c & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (p < input.length) {
+    const tag = input[p++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
+        const bytes = literalLen - 59;
+        literalLen = 1;
+        for (let i = 0; i < bytes; i++) literalLen += input[p++] << (8 * i);
+      }
+      input.copy(out, op, p, p + literalLen);
+      p += literalLen;
+      op += literalLen;
+    } else {
+      let copyLen;
+      let offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[p++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[p] | (input[p + 1] << 8);
+        p += 2;
+      } else {
