+  4: { name: "repetition_level_encoding", kind: "enum" },
+};
+
+const DictionaryPageHeader = {
+  1: { name: "num_values", kind: "i32" },
+  2: { name: "encoding", kind: "enum" },
+  3: { name: "is_sorted", kind: "bool" },
+};
+
+const DataPageHeaderV2 = {
+  1: { name: "num_values", kind: "i32" },
+  2: { name: "num_nulls", kind: "i32" },
+  3: { name: "num_rows", kind: "i32" },
+  4: { name: "encoding", kind: "enum" },
+  5: { name: "definition_levels_byte_length", kind: "i32" },
+  6: { name: "repetition_levels_byte_length", kind: "i32" },
+  7: { name: "is_compressed", kind: "bool" },
+};
+
+const PageHeader = {
+  1: { name: "type", kind: "enum" },
+  2: { name: "uncompressed_page_size", kind: "i32" },
+  3: { name: "compressed_page_size", kind: "i32" },
+  4: { name: "crc", kind: "i32" },
+  5: { name: "data_page_header", kind: "struct", spec: DataPageHeader },
+  7: { name: "dictionary_page_header", kind: "struct", spec: DictionaryPageHeader },
+  8: { name: "data_page_header_v2", kind: "struct", spec: DataPageHeaderV2 },
+};
