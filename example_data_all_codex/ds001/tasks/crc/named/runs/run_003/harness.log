+  if (p < 0.001) return p.toExponential(2);
+  return p.toPrecision(3);
+}
+
+function round(x, digits = 4) {
+  return Number(x.toFixed(digits));
+}
+
+function main() {
+  const { df } = readParquet();
+  const y = df.pfs_months;
+  if (y.length !== N_ROWS_EXPECTED) throw new Error(`expected ${N_ROWS_EXPECTED} rows`);
