+  addTermHyp("Patients with `pleural_effusion` have lower mean `pfs_months` than patients without `pleural_effusion`, after adjustment for clinical covariates.", global.pleural_effusion, "OLS: pfs_months ~ pleural_effusion + clinical covariates");
+  addTermHyp("Patients with `autoimmune_disease` have lower mean `pfs_months` than patients without `autoimmune_disease`, after adjustment for clinical covariates.", global.autoimmune_disease, "OLS: pfs_months ~ autoimmune_disease + clinical covariates");
