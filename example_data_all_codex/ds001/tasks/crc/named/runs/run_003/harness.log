+function readRleBitPacked(buf, bitWidth, expectedCount) {
+  let p = 0;
+  const out = [];
+  const readUnsignedVarint = () => {
+    let n = 0;
+    let shift = 0;
+    while (true) {
+      const byte = buf[p++];
+      n |= (byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
