+
+function decodePlainDictionary(data, parquetType, count) {
+  const values = [];
+  let p = 0;
+  for (let i = 0; i < count; i++) {
+    if (parquetType === 2) {
+      values.push(Number(data.readBigInt64LE(p)));
+      p += 8;
+    } else if (parquetType === 5) {
+      values.push(data.readDoubleLE(p));
+      p += 8;
+    } else if (parquetType === 6) {
+      const len = data.readInt32LE(p);
+      p += 4;
+      values.push(data.subarray(p, p + len).toString("utf8"));
+      p += len;
+    } else {
+      throw new Error(`unsupported physical type ${parquetType}`);
+    }
+  }
+  return values;
