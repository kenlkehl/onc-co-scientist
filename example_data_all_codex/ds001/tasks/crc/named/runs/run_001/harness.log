function ols(xs){let p=xs.length+1;let XtX=Array.from({length:p},()=>Array(p).fill(0));let Xty=Array(p).fill(0);let sy=0,sy2=0;for(let i=0;i<n;i++){let row=[1];for(let x of xs)row.push(x[i]);let yi=y[i];sy+=yi;sy2+=yi*yi;for(let a=0;a<p;a++){Xty[a]+=row[a]*yi;for(let b=0;b<=a;b++)XtX[a][b]+=row[a]*row[b];}}for(let a=0;a<p;a++)for(let b=0;b<a;b++)XtX[b][a]=XtX[a][b];let XtXinv=inv(XtX);let beta=Array(p).fill(0);for(let a=0;a<p;a++)for(let b=0;b<p;b++)beta[a]+=XtXinv[a][b]*Xty[b];let sse=0;for(let i=0;i<n;i++){let pred=beta[0];for(let j=0;j<xs.length;j++)pred+=beta[j+1]*xs[j][i];let e=y[i]-pred;sse+=e*e;}let sigma2=sse/(n-p);let se=Array(p);let t=Array(p);let pv=Array(p);for(let j=0;j<p;j++){se[j]=Math.sqrt(Math.max(0,sigma2*XtXinv[j][j]));t[j]=beta[j]/se[j];pv[j]=p2z(t[j]);}return {beta,se,t,p:pv};}
function uniqueInfo(c){let arr=data[c];let set=new Set(arr);let min=Infinity,max=-Infinity;for(const v of arr){if(v<min)min=v;if(v>max)max=v;}return {n:set.size,min,max,vals:[...set].slice(0,8).sort((a,b)=>a-b)};}
let binary=[];let continuous=[];for (const c of cols){let u=uniqueInfo(c); if(u.n===2 && u.min===0 && u.max===1) binary.push(c); else continuous.push(c);}console.log('"'binary',binary.length,'continuous/ordinal',continuous.length,continuous);
