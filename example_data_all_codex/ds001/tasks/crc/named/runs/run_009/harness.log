"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from scipy import stats

path='dataset.parquet'
df=pd.read_parquet(path)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('\\noutcome pfs describe')
print(df['pfs_months'].describe().to_string())

# identify binary-ish and continuous
cols=[c for c in df.columns if c"'!='"'pfs_months']
binary=[]; cont=[]
for c in cols:
    vals=set(df[c].dropna().unique().tolist())
    if vals <= {0,1,False,True}:
        binary.append(c)
    else:
        cont.append(c)
print('\\nbinary', len(binary), binary)
print('continuous', len(cont), cont)

print('\\nBinary feature prevalence and PFS differences top by abs diff')
rows=[]
for c in binary:
    n1=int(df[c].sum())
    n0=len(df)-n1
    if n1>0 and n0>0:
        m1=df.loc[df[c]==1,'pfs_months'].mean(); m0=df.loc[df[c]==0,'pfs_months'].mean()
        t,p=stats.ttest_ind(df.loc[df[c]==1,'pfs_months'], df.loc[df[c]==0,'pfs_months'], equal_var=False)
        rows.append((c,n1,n1/len(df),m1,m0,m1-m0,p))
rows=sorted(rows,key=lambda x:abs(x[5]), reverse=True)
for r in rows[:30]:
    print(f'{r[0]:35s} n1={r[1]:5d} prev={r[2]:.3f} mean1={r[3]:.3f} mean0={r[4]:.3f} diff={r[5]:+.3f} p={r[6]:.3g}')

print('\\nContinuous correlations top by abs Pearson')
rows=[]
for c in cont:
    r,p=stats.pearsonr(df[c], df['pfs_months'])
    rows.append((c,r,p,df[c].mean(),df[c].std()))
rows=sorted(rows,key=lambda x:abs(x[1]), reverse=True)
for r in rows[:30]:
    print(f'{r[0]:35s} r={r[1]:+.3f} p={r[2]:.3g} mean={r[3]:.3f} sd={r[4]:.3f}')

print('\\nTreatment counts and mean pfs')
for c in [x for x in binary if x.startswith('treatment_')]:
    n1=int(df[c].sum()); m1=df.loc[df[c]==1,'pfs_months'].mean(); m0=df.loc[df[c]==0,'pfs_months'].mean()
    print(c,n1,n1/len(df),m1,m0,m1-m0)
