+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseFileMetaData(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.version = thriftValue(r, f.type);
+    else if (f.id === 2) {
