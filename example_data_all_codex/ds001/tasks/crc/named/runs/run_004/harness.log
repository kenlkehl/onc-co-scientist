+      ["high_ldh_q75", "liver_mets"],
+      ["high_crp_q75", "stage_iv"],
+    ].map(([a, b]) => {
+      const r = interactionEffect(a, b);
+      return { a, b, estimate: r.estimate, p: r.pValue };
+    }),
+    counts: {
+      pembrolizumab_msi: binaryCounts("treatment_pembrolizumab", "msi_high"),
+      encorafenib_braf: binaryCounts("treatment_encorafenib", "braf_v600e"),
