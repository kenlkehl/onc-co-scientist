+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.num_values = thriftValue(r, f.type);
+    else if (f.id === 2) out.encoding = thriftValue(r, f.type);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseDataPageHeader(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.num_values = thriftValue(r, f.type);
+    else if (f.id === 2) out.encoding = thriftValue(r, f.type);
+    else if (f.id === 3) out.definition_level_encoding = thriftValue(r, f.type);
+    else if (f.id === 4) out.repetition_level_encoding = thriftValue(r, f.type);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseColumnMetaData(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = thriftValue(r, f.type);
+    else if (f.id === 2) {
+      const l = r.readListBegin();
+      out.encodings = [];
+      for (let i = 0; i < l.size; i++) out.encodings.push(thriftValue(r, l.elemType));
+    } else if (f.id === 3) {
+      const l = r.readListBegin();
+      out.path_in_schema = [];
+      for (let i = 0; i < l.size; i++) out.path_in_schema.push(thriftValue(r, l.elemType));
+    } else if (f.id === 4) out.codec = thriftValue(r, f.type);
+    else if (f.id === 5) out.num_values = thriftValue(r, f.type);
+    else if (f.id === 6) out.total_uncompressed_size = thriftValue(r, f.type);
+    else if (f.id === 7) out.total_compressed_size = thriftValue(r, f.type);
+    else if (f.id === 9) out.data_page_offset = thriftValue(r, f.type);
+    else if (f.id === 11) out.dictionary_page_offset = thriftValue(r, f.type);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseColumnChunk(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 3) out.meta_data = parseColumnMetaData(r);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseRowGroup(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) {
