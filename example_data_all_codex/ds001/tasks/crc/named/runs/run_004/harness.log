+      return { v, estimate: r.estimate, se: r.se, p: r.pValue };
+    }).sort((a, b) => Math.abs(b.estimate) - Math.abs(a.estimate)),
+    subgroupTreatmentEffects: [
+      ["treatment_cetuximab", "ras_wildtype"],
+      ["treatment_cetuximab", "ras_mutated"],
+      ["treatment_cetuximab", "left_sided_primary"],
+      ["treatment_cetuximab", "right_sided_primary"],
+      ["treatment_pembrolizumab", "msi_high"],
+      ["treatment_pembrolizumab", "autoimmune_disease"],
+      ["treatment_encorafenib", "braf_v600e"],
+      ["treatment_trastuzumab_tucatinib", "her2_amplified"],
+      ["treatment_bevacizumab", "liver_mets"],
+      ["treatment_regorafenib", "stage_iv"],
+      ["treatment_regorafenib", "ecog_ps"],
+    ].map(([t, s]) => {
+      const r = subgroupAdjustedEffect(t, s);
+      return { treatment: t, subgroup: s, estimate: r.estimate, se: r.se, p: r.pValue, subgroupCount: r.subgroupCount };
+    }),
+    counts: {
+      pembrolizumab_msi: binaryCounts("treatment_pembrolizumab", "msi_high"),
+      encorafenib_braf: binaryCounts("treatment_encorafenib", "braf_v600e"),
+      trastuzumab_her2: binaryCounts("treatment_trastuzumab_tucatinib", "her2_amplified"),
+      cetuximab_ras: binaryCounts("treatment_cetuximab", "ras_mutated"),
