+const fs = require("fs");
+
+const file = fs.readFileSync("dataset.parquet");
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+    this.stack = [];
+    this.lastFieldId = 0;
+  }
+
+  readByte() {
+    return this.buf[this.pos++];
+  }
+
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+
+  readZigZag() {
+    const n = this.readVarint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  readI64() {
+    return this.readZigZag();
+  }
+
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  readString() {
+    return this.readBinary().toString("utf8");
+  }
+
+  readFieldBegin() {
+    const b = this.readByte();
+    if (b === 0) return { type: 0, id: null };
+    const type = b & 0x0f;
+    const delta = b >> 4;
+    const id = delta === 0 ? this.readZigZag() : this.lastFieldId + delta;
+    this.lastFieldId = id;
+    return { type, id };
+  }
+
+  pushStruct() {
+    this.stack.push(this.lastFieldId);
+    this.lastFieldId = 0;
+  }
+
+  popStruct() {
+    this.lastFieldId = this.stack.pop();
+  }
+
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elemType };
+  }
+
+  skip(type) {
+    switch (type) {
+      case 0:
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.readZigZag();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case 9:
+      case 10: {
+        const l = this.readListBegin();
+        for (let i = 0; i < l.size; i++) this.skip(l.elemType);
+        return;
+      }
+      case 11: {
+        const b = this.readByte();
+        if (b === 0) return;
+        const keyType = b >> 4;
+        const valueType = b & 0x0f;
+        const size = Number(this.readVarint());
+        for (let i = 0; i < size; i++) {
+          this.skip(keyType);
+          this.skip(valueType);
+        }
+        return;
+      }
+      case 12:
+        this.pushStruct();
+        while (true) {
+          const f = this.readFieldBegin();
+          if (f.type === 0) break;
+          this.skip(f.type);
+        }
+        this.popStruct();
+        return;
+      default:
+        throw new Error(`Unsupported Thrift type ${type} at ${this.pos}`);
+    }
+  }
+}
+
+function thriftValue(r, type) {
+  if (type === 1) return true;
+  if (type === 2) return false;
+  if (type === 3) return r.readByte();
+  if (type === 4 || type === 5 || type === 6) return r.readI64();
+  if (type === 7) return r.readDouble();
+  if (type === 8) return r.readString();
+  throw new Error(`Unsupported value type ${type}`);
+}
+
+function parseSchemaElement(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = thriftValue(r, f.type);
+    else if (f.id === 3) out.repetition_type = thriftValue(r, f.type);
+    else if (f.id === 4) out.name = thriftValue(r, f.type);
+    else if (f.id === 5) out.num_children = thriftValue(r, f.type);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseDictionaryPageHeader(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.num_values = thriftValue(r, f.type);
+    else if (f.id === 2) out.encoding = thriftValue(r, f.type);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseDataPageHeader(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.num_values = thriftValue(r, f.type);
+    else if (f.id === 2) out.encoding = thriftValue(r, f.type);
+    else if (f.id === 3) out.definition_level_encoding = thriftValue(r, f.type);
+    else if (f.id === 4) out.repetition_level_encoding = thriftValue(r, f.type);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseColumnMetaData(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = thriftValue(r, f.type);
+    else if (f.id === 2) {
