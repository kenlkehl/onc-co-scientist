+
+function readUVarint(buf, pos) {
+  let result = 0;
+  let shift = 0;
+  while (true) {
+    const b = buf[pos++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: result, pos };
