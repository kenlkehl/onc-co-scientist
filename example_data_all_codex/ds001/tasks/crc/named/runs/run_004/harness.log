+  return out;
+}
+
+function parseColumnChunk(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 3) out.meta_data = parseColumnMetaData(r);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseRowGroup(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) {
+      const l = r.readListBegin();
+      out.columns = [];
+      for (let i = 0; i < l.size; i++) out.columns.push(parseColumnChunk(r));
+    } else if (f.id === 3) out.num_rows = thriftValue(r, f.type);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseFileMetaData(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.version = thriftValue(r, f.type);
+    else if (f.id === 2) {
+      const l = r.readListBegin();
+      out.schema = [];
+      for (let i = 0; i < l.size; i++) out.schema.push(parseSchemaElement(r));
+    } else if (f.id === 3) out.num_rows = thriftValue(r, f.type);
+    else if (f.id === 4) {
+      const l = r.readListBegin();
+      out.row_groups = [];
+      for (let i = 0; i < l.size; i++) out.row_groups.push(parseRowGroup(r));
+    } else if (f.id === 6) out.created_by = thriftValue(r, f.type);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parsePageHeaderAt(pos) {
+  const r = new CompactReader(file, pos);
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = thriftValue(r, f.type);
+    else if (f.id === 2) out.uncompressed_page_size = thriftValue(r, f.type);
+    else if (f.id === 3) out.compressed_page_size = thriftValue(r, f.type);
+    else if (f.id === 5) out.data_page_header = parseDataPageHeader(r);
+    else if (f.id === 7) out.dictionary_page_header = parseDictionaryPageHeader(r);
