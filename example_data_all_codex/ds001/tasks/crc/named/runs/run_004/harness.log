+  return out;
+}
+
+function parseColumnChunk(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 3) out.meta_data = parseColumnMetaData(r);
+    else r.skip(f.type);
+  }
+  r.popStruct();
+  return out;
+}
+
+function parseRowGroup(r) {
+  const out = {};
+  r.pushStruct();
+  while (true) {
+    const f = r.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) {
