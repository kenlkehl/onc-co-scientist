+
+function writeSummary(transcript) {
+  const lines = [];
+  lines.push("Analysis summary for ds001_crc");
+  lines.push("");
+  lines.push(`Cohort: ${n} patients. Outcome: pfs_months. Analyses used large-sample linear models on the natural PFS-month scale. Unless otherwise stated, models adjusted for age_per_10, sex_female, ecog_ps, stage_iv, right_sided_primary, ldh_per_100, albumin_g_dl, liver_mets, and bone_mets, omitting the tested variable from the adjustment set when needed. Derived thresholds were top quartiles: CEA >= ${fmt(ceaQ75)} ng/mL, LDH >= ${fmt(ldhQ75)} U/L, CRP >= ${fmt(crpQ75)} mg/L, and NLR >= ${fmt(nlrQ75)}.`);
+  lines.push("");
+  lines.push("Prognostic main effects:");
+  for (let i = 0; i < 11; i++) {
+    const a = transcript.iterations[i].analyses[0];
+    lines.push(`- ${transcript.iterations[i].proposed_hypotheses[0].text} Result: effect ${fmt(a.effect_estimate)} months, p=${formatP(a.p_value)}, ${a.significant ? "significant" : "not significant"}.`);
+  }
+  lines.push("");
+  lines.push("Treatment, biomarker, and interaction findings:");
+  for (let i = 11; i < transcript.iterations.length; i++) {
+    const a = transcript.iterations[i].analyses[0];
+    lines.push(`- ${transcript.iterations[i].proposed_hypotheses[0].text} Result: effect ${fmt(a.effect_estimate)} months, p=${formatP(a.p_value)}, ${a.significant ? "significant" : "not significant"}.`);
+  }
+  lines.push("");
+  lines.push("Overall conclusions:");
+  lines.push("The clearest prognostic pattern was a coherent adverse-risk axis: worse ECOG performance status, stage IV disease, liver metastases, lower albumin, higher LDH, higher CRP, higher NLR, higher weight loss, BRAF V600E, and high CEA were each associated with shorter PFS. MSI-high status was favorable in adjusted analysis.");
+  lines.push("Treatment associations were biomarker-specific. Cetuximab benefit concentrated in RAS-wildtype disease and was significantly attenuated with RAS mutation and right-sided primary tumors. Pembrolizumab showed a strong positive MSI-high interaction. Encorafenib showed benefit in BRAF V600E disease with a positive BRAF interaction. Trastuzumab/tucatinib benefit concentrated in HER2-amplified disease with a positive HER2 interaction. Bevacizumab showed a modest overall positive association, while the hypothesized larger effect in liver metastases was not supported. Regorafenib was associated with shorter adjusted PFS, consistent with adverse treatment-selection or later-line use rather than a favorable biomarker effect.");
+  lines.push("Two exploratory heterogeneity checks were not supported: autoimmune disease did not significantly weaken the pembrolizumab association after accounting for MSI-high status, and top-quartile CRP did not show a significant stage IV interaction. High LDH and liver metastases did show a significant adverse interaction, suggesting inflammatory/tumor-burden features compound each other.");
+  fs.writeFileSync("analysis_summary.txt", `${lines.join("\n")}\n`);
+}
