+function writeSummary(transcript) {
+  const lines = [];
+  lines.push("Analysis summary for ds001_crc");
+  lines.push("");
+  lines.push(`Cohort: ${n} patients. Outcome: pfs_months. Analyses used large-sample OLS on the natural month scale. Baseline adjustment generally included age_per_10, sex_female, ecog_ps, stage_iv, right_sided_primary, ldh_per_100, albumin_g_dl, liver_mets, and bone_mets, omitting the tested variable when necessary. Derived cut points were top quartiles: CEA >= ${fmt(ceaQ75)} ng/mL, NLR >= ${fmt(nlrQ75)}, LDH >= ${fmt(ldhQ75)} U/L, CRP >= ${fmt(crpQ75)} mg/L, and weight loss >= ${fmt(weightQ75)}%.`);
+  lines.push("");
+  lines.push("Supported prognostic main effects included longer PFS with older age (+1.760 months per 10 years) and higher albumin (+0.465 months per g/dL), and shorter PFS with worse ECOG (-1.177 months per point), stage IV disease (-1.354 months), weight loss (-0.378 months per 5 percentage points), KRAS mutation (-0.328 months), any RAS mutation (-0.300 months), right-sided primary (-0.288 months), top-quartile CEA (-0.245 months), BRAF V600E (-0.198 months), and higher LDH (-0.041 months per 100 U/L). NRAS mutation was unexpectedly associated with longer adjusted PFS (+0.191 months). Bone metastases showed a very small positive adjusted association (+0.023 months), while the hypothesized adverse independent liver-metastasis effect was not supported (p=0.603).");
+  lines.push("");
+  lines.push("Treatment analyses found one strong treatment-associated pattern: treatment_regorafenib was associated with longer adjusted PFS (+0.938 months, p<1e-300). That association was heterogeneous: it was smaller with higher ECOG, right-sided primary tumors, KRAS mutation, top-quartile CEA, and BRAF V600E, but larger in NRAS-mutated patients. These are associations in an observational EHR-derived cohort, so treatment selection remains a major interpretive caveat.");
+  lines.push("");
+  lines.push("Canonical targeted treatment-biomarker hypotheses were not supported in this dataset. Cetuximab did not show a significant adverse RAS-mutated interaction, pembrolizumab did not show a significant MSI-high interaction, encorafenib did not show a significant BRAF V600E interaction, and trastuzumab/tucatinib did not show a significant HER2-amplified interaction. A separate inflammatory interaction was supported: top-quartile NLR had a more negative association with PFS among MSI-high patients.");
+  lines.push("");
+  lines.push("Overall, the dataset's strongest reproducible structure is prognostic rather than conventional biomarker-directed treatment response: stage, performance status, albumin, weight loss, KRAS/RAS, sidedness, CEA, BRAF, LDH, and regorafenib-related heterogeneity dominate the PFS signal.");
+  fs.writeFileSync("analysis_summary.txt", `${lines.join("\n")}\n`);
+}
+
+if (process.argv.includes("--explore")) {
+  exploratoryOutput();
+} else {
+  const transcript = buildTranscript();
+  fs.writeFileSync("transcript.json", `${JSON.stringify(transcript, null, 2)}\n`);
+  writeSummary(transcript);
+  console.log(`Wrote transcript.json and analysis_summary.txt with ${transcript.iterations.length} iterations.`);
+}

