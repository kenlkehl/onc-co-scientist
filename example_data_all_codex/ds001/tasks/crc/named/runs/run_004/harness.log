+      let off = 0;
+      const defLen = body.readUInt32LE(off);
+      off += 4;
+      const def = decodeRleBitpacked(body, off, 1, h.num_values);
+      off += defLen;
+      const present = def.values.filter((x) => x === 1).length;
+      let decoded;
+      if (h.encoding === 8 || h.encoding === 2) {
+        const bitWidth = body[off++];
+        const idx = decodeRleBitpacked(body, off, bitWidth, present);
+        decoded = idx.values.map((i) => dict[i]);
+      } else if (h.encoding === 0) {
+        decoded = decodePlain(body.slice(off), m.type, present);
+      } else {
+        throw new Error(`Unsupported data encoding ${h.encoding} for ${name}`);
+      }
+      let j = 0;
+      for (const d of def.values) values.push(d === 1 ? decoded[j++] : null);
+    } else {
+      throw new Error(`Unsupported page type ${ph.type} for ${name}`);
+    }
