+function analysisRecord(hid, result, text, code) {
+  return {
+    hypothesis_ids: [hid],
+    code,
+    result_summary: text,
+    p_value: result.pValue === null || result.pValue === undefined ? null : Number(result.pValue.toPrecision(6)),
+    effect_estimate: Number(result.estimate.toPrecision(6)),
+    significant: result.pValue === null || result.pValue === undefined ? null : result.pValue < 0.05,
+  };
