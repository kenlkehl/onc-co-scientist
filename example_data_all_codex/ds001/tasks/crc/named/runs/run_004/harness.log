+      pembrolizumab_msi: binaryCounts("treatment_pembrolizumab", "msi_high"),
+      encorafenib_braf: binaryCounts("treatment_encorafenib", "braf_v600e"),
+      trastuzumab_her2: binaryCounts("treatment_trastuzumab_tucatinib", "her2_amplified"),
+      cetuximab_ras: binaryCounts("treatment_cetuximab", "ras_mutated"),
+    }
