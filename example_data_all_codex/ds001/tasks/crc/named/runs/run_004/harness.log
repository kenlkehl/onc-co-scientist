+  const xty = Array(p).fill(0);
+  let yty = 0;
+  let rows = 0;
+  for (let i = 0; i < n; i++) {
+    if (mask && !mask[i]) continue;
+    const row = [1];
+    let ok = true;
+    for (const f of features) {
+      const v = f.values[i];
+      if (v === null || v === undefined || Number.isNaN(v)) {
+        ok = false;
+        break;
