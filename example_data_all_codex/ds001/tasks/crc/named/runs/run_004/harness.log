+    for (let j = 0; j < m; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < m; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < m; r++) {
+      if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    }
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error("Singular matrix");
