+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let l = tag >> 2;
+      if (l < 60) {
+        l += 1;
+      } else {
