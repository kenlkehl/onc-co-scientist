+    "OLS: pfs_months ~ treatment_encorafenib * braf_v600e + baseline covariates",
+    "refined"
+  );
+
+  const trastHer2 = subgroupAdjustedEffect("treatment_trastuzumab_tucatinib", "her2_amplified");
+  addIteration(
+    iterations,
+    "Among patients with `her2_amplified` equal to 1, `treatment_trastuzumab_tucatinib` equal to 1 is associated with longer `pfs_months` than no trastuzumab/tucatinib after adjustment for baseline prognostic factors.",
+    trastHer2,
+    `Within her2_amplified=1 patients (n=${trastHer2.subgroupCount}), adjusted OLS estimated ${fmt(trastHer2.estimate)} months for trastuzumab/tucatinib-treated versus untreated (SE ${fmt(trastHer2.se)}, p=${formatP(trastHer2.pValue)}).`,
+    "Subset OLS where her2_amplified=1: pfs_months ~ treatment_trastuzumab_tucatinib + baseline covariates",
+    "refined"
+  );
+
+  const trastHer2Int = interactionEffect("treatment_trastuzumab_tucatinib", "her2_amplified");
+  addIteration(
+    iterations,
+    "The association of `treatment_trastuzumab_tucatinib` with `pfs_months` is larger in patients with `her2_amplified` equal to 1 than in patients with `her2_amplified` equal to 0.",
+    trastHer2Int,
+    `Adjusted interaction coefficient for treatment_trastuzumab_tucatinib x her2_amplified was ${fmt(trastHer2Int.estimate)} months (SE ${fmt(trastHer2Int.se)}, p=${formatP(trastHer2Int.pValue)}).`,
+    "OLS: pfs_months ~ treatment_trastuzumab_tucatinib * her2_amplified + baseline covariates",
+    "refined"
+  );
+
+  const reg = adjustedEffect("treatment_regorafenib");
+  addIteration(
+    iterations,
+    "Patients with `treatment_regorafenib` equal to 1 have shorter `pfs_months` than patients without regorafenib after adjustment for baseline prognostic factors.",
