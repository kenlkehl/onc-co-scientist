+    const id = delta === 0 ? this.readZigZag() : this.lastFieldId + delta;
+    this.lastFieldId = id;
+    return { type, id };
+  }
+
+  pushStruct() {
+    this.stack.push(this.lastFieldId);
+    this.lastFieldId = 0;
+  }
+
+  popStruct() {
+    this.lastFieldId = this.stack.pop();
+  }
+
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
