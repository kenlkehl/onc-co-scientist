+    }),
+    adjustedMainEffects: [
+      "age_per_10", "sex_female", "ecog_ps", "stage_iv", "right_sided_primary", "liver_mets", "bone_mets",
+      "albumin_g_dl", "ldh_per_100", "crp_per_10", "nlr", "weight_loss_per_5", "high_cea_q75",
+      "kras_mutation", "nras_mutation", "ras_mutated", "braf_v600e", "msi_high", "her2_amplified",
