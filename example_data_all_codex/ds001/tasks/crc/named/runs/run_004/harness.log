+    univariate: binaryVars.map((v) => {
+      const m = meanBy(v);
+      return { v, n1: m.n1, diff: m.mean1 - m.mean0, mean1: m.mean1, mean0: m.mean0 };
+    }).sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff)).slice(0, 30),
+    keyInteractions: [
