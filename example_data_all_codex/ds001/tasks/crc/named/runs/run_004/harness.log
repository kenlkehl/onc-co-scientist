+}
+
+const numericColumns = Object.keys(columnMeta).filter((name) => name !== "patient_id");
+const data = {};
+for (const name of numericColumns) data[name] = readColumn(name);
+const y = data.pfs_months;
+const n = y.length;
+
+function derive(name, arr) {
+  data[name] = arr;
+  return arr;
+}
+
+function quantile(arr, q) {
+  const sorted = Array.from(arr).sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] + (sorted[hi] - sorted[lo]) * (pos - lo);
+}
+
+const ldhQ75 = quantile(data.ldh_u_l, 0.75);
+const crpQ75 = quantile(data.crp_mg_l, 0.75);
+const nlrQ75 = quantile(data.nlr, 0.75);
+const ceaQ75 = quantile(data.cea_ng_ml, 0.75);
+const weightQ75 = quantile(data.weight_loss_pct_6mo, 0.75);
+
+derive("ras_mutated", data.kras_mutation.map((v, i) => (v === 1 || data.nras_mutation[i] === 1 ? 1 : 0)));
+derive("ras_wildtype", data.ras_mutated.map((v) => (v === 1 ? 0 : 1)));
+derive("left_sided_primary", data.right_sided_primary.map((v) => (v === 1 ? 0 : 1)));
+derive("her2_any_amplified", data.her2_amplified.map((v, i) => (v === 1 || data.her2_amplification[i] === 1 ? 1 : 0)));
+derive("hypoalbumin_lt_3_5", data.albumin_g_dl.map((v) => (v < 3.5 ? 1 : 0)));
+derive("high_ldh_q75", data.ldh_u_l.map((v) => (v >= ldhQ75 ? 1 : 0)));
+derive("high_crp_q75", data.crp_mg_l.map((v) => (v >= crpQ75 ? 1 : 0)));
+derive("high_nlr_q75", data.nlr.map((v) => (v >= nlrQ75 ? 1 : 0)));
+derive("high_cea_q75", data.cea_ng_ml.map((v) => (v >= ceaQ75 ? 1 : 0)));
+derive("high_weight_loss_q75", data.weight_loss_pct_6mo.map((v) => (v >= weightQ75 ? 1 : 0)));
+derive("age_ge_70", data.age_years.map((v) => (v >= 70 ? 1 : 0)));
+derive("ecog_ge_2", data.ecog_ps.map((v) => (v >= 2 ? 1 : 0)));
+derive("ldh_per_100", data.ldh_u_l.map((v) => v / 100));
+derive("crp_per_10", data.crp_mg_l.map((v) => v / 10));
+derive("weight_loss_per_5", data.weight_loss_pct_6mo.map((v) => v / 5));
+derive("age_per_10", data.age_years.map((v) => v / 10));
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const yv = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * yv;
+}
+
+function normalTwoSidedP(z) {
+  const a = Math.abs(z);
+  if (!Number.isFinite(a)) return null;
+  if (a < 8) return Math.max(0, 1 - erf(a / Math.SQRT2));
+  const logP = Math.log(2) - 0.5 * a * a - Math.log(a) - 0.5 * Math.log(2 * Math.PI);
+  const p = Math.exp(logP);
+  return p > 0 ? p : 1e-300;
+}
+
+function fmt(x, digits = 3) {
+  if (x === null || x === undefined || Number.isNaN(x)) return "NA";
+  if (Math.abs(x) >= 1000 || (Math.abs(x) > 0 && Math.abs(x) < 0.001)) return x.toExponential(2);
+  return x.toFixed(digits);
+}
+
+function formatP(p) {
+  if (p === null || p === undefined) return "NA";
+  if (p < 1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function invertMatrix(a) {
+  const m = a.length;
+  const aug = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < m; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < m; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < m; r++) {
+      if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    }
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const div = aug[col][col];
+    for (let j = 0; j < 2 * m; j++) aug[col][j] /= div;
+    for (let r = 0; r < m; r++) {
+      if (r === col) continue;
+      const factor = aug[r][col];
+      if (factor === 0) continue;
+      for (let j = 0; j < 2 * m; j++) aug[r][j] -= factor * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(m));
+}
+
+function makeFeature(spec) {
+  if (typeof spec === "string") return { name: spec, values: data[spec] };
+  return spec;
+}
