+derive("hypoalbumin_lt_3_5", data.albumin_g_dl.map((v) => (v < 3.5 ? 1 : 0)));
+derive("high_ldh_q75", data.ldh_u_l.map((v) => (v >= ldhQ75 ? 1 : 0)));
+derive("high_crp_q75", data.crp_mg_l.map((v) => (v >= crpQ75 ? 1 : 0)));
+derive("high_nlr_q75", data.nlr.map((v) => (v >= nlrQ75 ? 1 : 0)));
+derive("high_cea_q75", data.cea_ng_ml.map((v) => (v >= ceaQ75 ? 1 : 0)));
+derive("high_weight_loss_q75", data.weight_loss_pct_6mo.map((v) => (v >= weightQ75 ? 1 : 0)));
+derive("age_ge_70", data.age_years.map((v) => (v >= 70 ? 1 : 0)));
+derive("ecog_ge_2", data.ecog_ps.map((v) => (v >= 2 ? 1 : 0)));
+derive("ldh_per_100", data.ldh_u_l.map((v) => v / 100));
+derive("crp_per_10", data.crp_mg_l.map((v) => v / 10));
+derive("weight_loss_per_5", data.weight_loss_pct_6mo.map((v) => v / 5));
+derive("age_per_10", data.age_years.map((v) => v / 10));
