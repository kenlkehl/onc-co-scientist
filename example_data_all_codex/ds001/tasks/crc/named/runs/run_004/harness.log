+    }).sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff)).slice(0, 30),
+    keyInteractions: [
+      ["treatment_cetuximab", "ras_mutated"],
+      ["treatment_cetuximab", "right_sided_primary"],
+      ["treatment_pembrolizumab", "msi_high"],
+      ["treatment_encorafenib", "braf_v600e"],
+      ["treatment_trastuzumab_tucatinib", "her2_amplified"],
+      ["treatment_bevacizumab", "liver_mets"],
+      ["treatment_regorafenib", "ecog_ps"],
+      ["high_ldh_q75", "liver_mets"],
+      ["high_crp_q75", "stage_iv"],
+    ].map(([a, b]) => {
+      const r = interactionEffect(a, b);
+      return { a, b, estimate: r.estimate, p: r.pValue };
+    }),
