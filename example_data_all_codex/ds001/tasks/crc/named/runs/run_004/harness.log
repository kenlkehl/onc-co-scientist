+++ b/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/crc/named/analysis_runner.js
@@ -0,0 +1,1119 @@
+const fs = require("fs");
+
+const file = fs.readFileSync("dataset.parquet");
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+    this.stack = [];
+    this.lastFieldId = 0;
+  }
+
+  readByte() {
+    return this.buf[this.pos++];
+  }
+
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+
+  readZigZag() {
+    const n = this.readVarint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  readI64() {
+    return this.readZigZag();
+  }
+
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  readString() {
+    return this.readBinary().toString("utf8");
+  }
+
+  readFieldBegin() {
+    const b = this.readByte();
+    if (b === 0) return { type: 0, id: null };
+    const type = b & 0x0f;
+    const delta = b >> 4;
+    const id = delta === 0 ? this.readZigZag() : this.lastFieldId + delta;
+    this.lastFieldId = id;
+    return { type, id };
+  }
+
+  pushStruct() {
+    this.stack.push(this.lastFieldId);
+    this.lastFieldId = 0;
+  }
+
+  popStruct() {
+    this.lastFieldId = this.stack.pop();
+  }
+
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elemType };
+  }
+
+  skip(type) {
+    switch (type) {
+      case 0:
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.readZigZag();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case 9:
+      case 10: {
+        const l = this.readListBegin();
