+
+function snappyUncompress(input) {
+  let pos = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[pos++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let l = tag >> 2;
+      if (l < 60) {
+        l += 1;
+      } else {
+        const bytes = l - 59;
+        l = 0;
+        for (let i = 0; i < bytes; i++) l |= input[pos++] << (8 * i);
+        l += 1;
+      }
+      input.copy(out, op, pos, pos + l);
+      pos += l;
+      op += l;
+    } else {
+      let l;
+      let offset;
+      if (type === 1) {
+        l = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        l = (tag >> 2) + 1;
+        offset = input.readUInt16LE(pos);
