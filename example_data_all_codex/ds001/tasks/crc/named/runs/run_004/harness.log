+  const msiNlr = interactionEffect("msi_high", "high_nlr_q75");
+  addIteration(iterations,
+    `The negative association of top-quartile \`nlr\` (>=${fmt(nlrQ75)}) with \`pfs_months\` is larger in patients with \`msi_high\` equal to 1 than in patients with \`msi_high\` equal to 0.`,
+    msiNlr,
+    `Adjusted interaction coefficient for msi_high x high_nlr_q75 was ${fmt(msiNlr.estimate)} months (SE ${fmt(msiNlr.se)}, p=${formatP(msiNlr.pValue)}).`,
+    "OLS: pfs_months ~ msi_high * high_nlr_q75 + baseline covariates",
+    "refined"
+  );
