"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from scipy import stats

path='dataset.parquet'
df=pd.read_parquet(path)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('\\noutcome summary')
print(df['pfs_months'].describe().to_string())
print('missing total', int(df.isna().sum().sum()))
# binary detection
preds=[c for c in df.columns if c"'!='"'pfs_months']
binary=[]; continuous=[]
for c in preds:
    vals=set(df[c].dropna().unique().tolist())
    if vals.issubset({0,1,False,True}): binary.append(c)
    else: continuous.append(c)
print('\\nbinary count', len(binary), binary)
print('continuous count', len(continuous), continuous)
print('\\nbinary prevalence')
print(df[binary].mean().sort_values(ascending=False).to_string())
print('\\ncontinuous summary')
print(df[continuous].describe().T[['mean','std','min','25%','50%','75%','max']].to_string())
# univariate tests: binary mean diff and continuous pearson/slope
rows=[]
y=df['pfs_months'].astype(float)
for c in binary:
    x=df[c]
    y1=y[x==1]; y0=y[x==0]
    diff=y1.mean()-y0.mean()
    t,p=stats.ttest_ind(y1,y0,equal_var=False)
    rows.append((c,'binary',diff,p,y1.mean(),y0.mean(),len(y1),len(y0)))
for c in continuous:
    x=df[c].astype(float)
    slope,intercept,r,p,se=stats.linregress(x,y)
    rows.append((c,'continuous_slope',slope,p,np.corrcoef(x,y)[0,1],se,x.mean(),x.std()))
print('\\nunivariate top by p')
for row in sorted(rows, key=lambda r: (np.nan_to_num(r[3], nan=1.0), -abs(r[2])))[:80]:
    print(row)
