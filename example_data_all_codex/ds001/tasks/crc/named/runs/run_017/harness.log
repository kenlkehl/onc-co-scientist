import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('pfs summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
# binary proportions for 0/1 columns
binary=[]
for c in df.columns:
    if c=='pfs_months': continue
    vals=set(df[c].dropna().unique().tolist())
    if vals.issubset({0,1,0.0,1.0,False,True}):
        binary.append(c)
print('binary count', len(binary))
for c in binary:
    print(c, df[c].mean(), int(df[c].sum()))
print('numeric summaries')
for c in [c for c in df.columns if c not in binary and c"'!='"'pfs_months']:
    s=df[c]
    print(c, 'mean', float(s.mean()), 'sd', float(s.std()), 'p1', float(s.quantile(.01)), 'p99', float(s.quantile(.99)))
