function unpackBitpacked(buf, pos, bitWidth, nvals){let vals=[];let bitpos=0;for(let i=0;i<nvals;i++){let val=0;for(let bit=0;bit<bitWidth;bit++){let abs=bitpos+bit;let byte=buf[pos + (abs>>3)];let bitval=(byte >> (abs & 7)) & 1;val |= bitval << bit;}vals.push(val);bitpos += bitWidth;}let consumed=Math.ceil(bitpos/8);return [vals,pos+consumed];}
