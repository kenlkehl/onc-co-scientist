function mean(arr){return arr.reduce((a,v)=>a+v,0)/arr.length;}
function sd(arr){let m=mean(arr);return Math.sqrt(arr.reduce((a,v)=>a+(v-m)*(v-m),0)/(arr.length-1));}
function erf(x){const sign=x<0?-1:1; x=Math.abs(x); const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911; const t=1/(1+p*x); const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x); return sign*y;}
function normCdf(z){return 0.5*(1+erf(z/Math.SQRT2));}
function pFromZ(z){return Math.max(0, Math.min(1, 2*(1-normCdf(Math.abs(z)))));}
function propDiff(x,y){let n1=0,s1=0,n0=0,s0=0;for(let i=0;i<y.length;i++){if(x[i]===1){n1++;s1+=y[i];}else if(x[i]===0){n0++;s0+=y[i];}}let p1=s1/n1,p0=s0/n0,rd=p1-p0,se=Math.sqrt(p1*(1-p1)/n1 + p0*(1-p0)/n0),z=rd/se;return {n1,n0,s1,s0,p1,p0,rd,z,p:pFromZ(z)};}
