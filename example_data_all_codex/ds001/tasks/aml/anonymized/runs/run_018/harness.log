function matInv(A){let n=A.length;let M=A.map((r,i)=>r.concat(Array.from({length:n},(_,j)=>i===j?1:0)));for(let i=0;i<n;i++){let piv=i;for(let r=i+1;r<n;r++) if(Math.abs(M[r][i])>Math.abs(M[piv][i])) piv=r;if(Math.abs(M[piv][i])<1e-12) throw new Error('singular');[M[i],M[piv]]=[M[piv],M[i]];let d=M[i][i];for(let c=0;c<2*n;c++) M[i][c]/=d;for(let r=0;r<n;r++) if(r"'!==i){let f=M[r][i];if(f!==0) for(let c=0;c<2*n;c++) M[r][c]-=f*M[i][c];}}return M.map(r=>r.slice(n));}
function ols(y, cols){let n=y.length,p=cols.length;let XtX=Array.from({length:p},()=>Array(p).fill(0));let Xty=Array(p).fill(0);for(let i=0;i<n;i++){for(let a=0;a<p;a++){let va=cols[a].x[i];Xty[a]+=va*y[i];for(let bb=0;bb<p;bb++) XtX[a][bb]+=va*cols[bb].x[i];}}let inv=matInv(XtX);let beta=Array(p).fill(0);for(let a=0;a<p;a++) for(let bb=0;bb<p;bb++) beta[a]+=inv[a][bb]*Xty[bb];let meat=Array.from({length:p},()=>Array(p).fill(0));let rss=0;for(let i=0;i<n;i++){let fit=0;for(let a=0;a<p;a++) fit+=beta[a]*cols[a].x[i];let e=y[i]-fit;rss+=e*e;for(let a=0;a<p;a++){let xa=cols[a].x[i]*e;for(let bb=0;bb<p;bb++) meat[a][bb]+=xa*cols[bb].x[i]*e;}}let tmp=Array.from({length:p},()=>Array(p).fill(0));for(let i=0;i<p;i++)for(let j=0;j<p;j++)for(let k=0;k<p;k++)tmp[i][j]+=inv[i][k]*meat[k][j];let cov=Array.from({length:p},()=>Array(p).fill(0));let hc=n/(n-p);for(let i=0;i<p;i++)for(let j=0;j<p;j++)for(let k=0;k<p;k++)cov[i][j]+=tmp[i][k]*inv[k][j]*hc;let rows=[];for(let a=0;a<p;a++){let se=Math.sqrt(Math.max(cov[a][a],0));let z=beta[a]/se;rows.push({name:cols[a].name,beta:beta[a],se,z,p:pFromZ(z)});}return rows;}
