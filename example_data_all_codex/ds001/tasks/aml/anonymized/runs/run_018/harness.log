"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome values')
print(df['objective_response'].value_counts(dropna=False).sort_index().to_string())
print('head')
print(df.head().to_string())
summary=[]
for c in df.columns:
    s=df[c]
    vals=s.dropna().unique()
    if len(vals)<=10:
        valstr=','.join(map(str, sorted(vals)))
    else:
        valstr='many'
    summary.append((c,str(s.dtype),len(vals),s.min(),s.max(),s.mean() if np.issubdtype(s.dtype, np.number) else None,valstr))
print('column_profile')
for row in summary:
    print(row)
