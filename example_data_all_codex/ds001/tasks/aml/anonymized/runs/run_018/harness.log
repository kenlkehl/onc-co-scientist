function snappy(buf){let p=0;function v(){let shift=0,res=0;while(true){let x=buf[p++];res|=(x&0x7f)<<shift;if("'!(x&0x80))break;shift+=7;}return res;}const out=Buffer.alloc(v());let op=0;while(p<buf.length){let tag=buf[p++], type=tag&3;if(type===0){let len=tag>>2;if(len<60)len+=1;else{let n=len-59;len=0;for(let i=0;i<n;i++)len|=buf[p++]<<(8*i);len+=1;}buf.copy(out,op,p,p+len);op+=len;p+=len;}else{let len,off;if(type===1){len=4+((tag>>2)&7);off=((tag&0xe0)<<3)|buf[p++];}else if(type===2){len=1+(tag>>2);off=buf[p]|(buf[p+1]<<8);p+=2;}else{len=1+(tag>>2);off=(buf[p]|(buf[p+1]<<8)|(buf[p+2]<<16)|(buf[p+3]<<24))>>>0;p+=4;}for(let i=0;i<len;i++){out[op]=out[op-off];op++;}}}if(op!==out.length) throw new Error('"'snappy length mismatch '+op+' '+out.length);return out;}
function readPlain(buf, type, count){const vals=[];let p=0;for(let i=0;i<count;i++){if(type===1){vals.push(buf.readInt32LE(p));p+=4;}else if(type===2){vals.push(Number(buf.readBigInt64LE(p)));p+=8;}else if(type===5){vals.push(buf.readDoubleLE(p));p+=8;}else if(type===6){let n=buf.readInt32LE(p);p+=4;vals.push(buf.slice(p,p+n).toString('utf8'));p+=n;}else{throw new Error('plain type '+type);} }return vals;}
