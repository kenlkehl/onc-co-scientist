"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs = require('fs');
const b = fs.readFileSync('dataset.parquet');
function zigzag(n){ return (n >> 1n) "'^ (-(n & 1n)); }
class CompactReader{
  constructor(buf, off=0){ this.buf=buf; this.off=off; this.stack=[]; }
  u8(){ return this.buf[this.off++]; }
  varint(){ let shift=0n, res=0n; while(true){ const byte=this.u8(); res |= BigInt(byte & 0x7f) << shift; if((byte & 0x80)===0) break; shift += 7n; } return res; }
  i16(){ return Number(zigzag(this.varint())); }
  i32(){ return Number(zigzag(this.varint())); }
  i64(){ return Number(zigzag(this.varint())); }
  binary(){ const len = Number(this.varint()); const s=this.buf.slice(this.off,this.off+len); this.off += len; return s.toString('"'utf8'); }
  val(type){
    switch(type){
      case 1: return true;
      case 2: return false;
      case 3: return this.u8();
      case 4: return this.i16();
      case 5: return this.i32();
      case 6: return this.i64();
      case 7: { const v=this.buf.readDoubleLE(this.off); this.off+=8; return v; }
      case 8: return this.binary();
      case 9: return this.list();
      case 12: return this.struct();
      default: throw new Error('unsupported type '+type+' at '+this.off);
    }
  }
  list(){
    const h=this.u8(); let size=h>>4; const etype=h&0xf; if(size===15) size=Number(this.varint());
    const arr=[]; for(let i=0;i<size;i++) arr.push(this.val(etype)); return arr;
  }
  struct(){
    let last=0; const obj={};
    while(true){
      const h=this.u8(); const type=h & 0xf; if(type===0) break;
      const delta=h>>4; let fid; if(delta===0) fid=this.i16(); else fid=last+delta; last=fid;
      obj[fid]=this.val(type);
    }
    return obj;
  }
}
const footerLen = b.readUInt32LE(b.length-8);
const metaStart = b.length - 8 - footerLen;
const r = new CompactReader(b, metaStart);
