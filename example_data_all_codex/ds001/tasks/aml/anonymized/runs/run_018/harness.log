function readColumn(rg, idx){const cm=rg[1][idx][3];const type=cm[1];let pos=cm[11] ?? cm[9];let dict=null;let out=[];while(out.length<cm[5]){let cr=new CompactReader(b,pos);let ph=cr.struct();let dataStart=cr.off;let comp=b.slice(dataStart,dataStart+ph[3]);let raw=cm[4]===1?snappy(comp):comp;pos=dataStart+ph[3];if(ph[1]===2){dict=readPlain(raw,type,ph[7][1]);continue;}if(ph[1]!==0) throw new Error('"'unsupported page '+ph[1]);let dph=ph[5];let nvals=dph[1];let p=0;let levelLen=raw.readUInt32LE(p);p+=4;let def=decodeHybrid(raw,p,1,nvals,p+levelLen)[0];p += levelLen;let presentCount=def.reduce((a,v)=>a+(v===1),0);if(presentCount"'!==nvals) throw new Error('"'unexpected nulls');let vals=[];if(dph[2]===8){let bw=raw[p++];let rr=decodeHybrid(raw,p,bw,presentCount);vals=rr[0].map(i=>dict[i]);}else if(dph[2]===0){vals=readPlain(raw.slice(p),type,presentCount);}else throw new Error('encoding '+dph[2]);out.push(...vals);}return out.slice(0,cm[5]);}
