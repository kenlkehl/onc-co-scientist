function readPlain(buf, type, count){const vals=[];let p=0;for(let i=0;i<count;i++){if(type===1){vals.push(buf.readInt32LE(p));p+=4;}else if(type===2){vals.push(Number(buf.readBigInt64LE(p)));p+=8;}else if(type===5){vals.push(buf.readDoubleLE(p));p+=8;}else if(type===6){let n=buf.readInt32LE(p);p+=4;vals.push(buf.slice(p,p+n).toString('utf8'));p+=n;}else{throw new Error('plain type '+type);} }return vals;}
