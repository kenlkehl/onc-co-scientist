import pandas as pd
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.value_counts())
print(df.dtypes.to_string())
print('\\noutcome counts')
print(df['objective_response'].value_counts(dropna=False).to_string())
print('outcome mean', df['objective_response'].mean())
summary=[]
for c in df.columns:
    s=df[c]
    summary.append((c, str(s.dtype), int(s.nunique(dropna=False)), float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, float(s.min()) if pd.api.types.is_numeric_dtype(s) else None, float(s.max()) if pd.api.types.is_numeric_dtype(s) else None))
print('\\nfeature summaries: col dtype nunique mean min max')
for row in summary:
    print(row)
