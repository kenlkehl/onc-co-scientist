function matInv(A){const m=A.length; const M=A.map((row,i)=>row.concat(Array.from({length:m},(_,j)=>i===j?1:0))); for(let col=0;col<m;col++){let piv=col; for(let r=col+1;r<m;r++) if(Math.abs(M[r][col])>Math.abs(M[piv][col])) piv=r; if(Math.abs(M[piv][col])<1e-12) throw Error('singular'); [M[col],M[piv]]=[M[piv],M[col]]; const d=M[col][col]; for(let c=0;c<2*m;c++) M[col][c]/=d; for(let r=0;r<m;r++){if(r===col)continue; const f=M[r][col]; for(let c=0;c<2*m;c++) M[r][c]-=f*M[col][c];}} return M.map(row=>row.slice(m));}
