+summaryLines.push("");
+summaryLines.push("Continuous-feature analyses:");
+for (const r of topContinuousByP.slice(0, 5)) {
+  summaryLines.push(`- ${r.name}: one-SD linear probability effect ${fixed(r.effect)}; p=${formatP(r.p)}.`);
