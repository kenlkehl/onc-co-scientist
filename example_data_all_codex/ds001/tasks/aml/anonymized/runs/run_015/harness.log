+  const model = modifierModels[`${xName}:${zName}`];
+  const r = getTerm(model, `${xName}:${zName}`);
+  return baseAnalysis(
+    hypothesisId,
+    `In a linear probability model with ${xName}, ${zName}, and their product, the ${xName}:${zName} interaction coefficient was ${signed(r.effect)} (${pText(r.p)}).`,
