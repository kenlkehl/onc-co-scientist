+const scanPayload = {
+  rows: y.length,
+  response_rate: yMean,
+  feature_summaries: summaries.map((s) => ({
+    name: s.name,
+    mean: s.mean,
+    sd: s.sd,
+    min: s.min,
+    max: s.max,
+    uniqueCount: s.uniqueCount,
+    values: s.values,
+    isBinary: s.isBinary,
