import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome counts')
print(df['objective_response'].value_counts(dropna=False).to_string())
print('outcome mean', df['objective_response'].mean())
rows=[]
for c in df.columns:
    if c == 'objective_response':
        continue
    s=df[c]
    rows.append((c, str(s.dtype), int(s.nunique()), float(s.mean()), float(s.std()), float(s.min()), float(s.max())))
prof=pd.DataFrame(rows, columns=['col','dtype','nunique','mean','std','min','max'])
print(prof.sort_values(['nunique','col']).to_string(index=False))
