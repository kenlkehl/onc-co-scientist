+function snappyUncompress(input) {
+  let pos = 0;
+  let expected = 0;
+  let shift = 0;
+  while (true) {
+    const byte = input[pos++];
+    expected |= (byte & 0x7f) << shift;
+    if ((byte & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(expected);
+  let outPos = 0;
+
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let length;
+      if (lenCode < 60) {
+        length = lenCode + 1;
+      } else {
+        const bytes = lenCode - 59;
+        length = 0;
+        for (let i = 0; i < bytes; i++) {
+          length |= input[pos++] << (8 * i);
+        }
+        length += 1;
+      }
+      input.copy(out, outPos, pos, pos + length);
+      pos += length;
+      outPos += length;
+    } else {
+      let length;
+      let offset;
+      if (type === 1) {
+        length = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        length = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        length = (tag >> 2) + 1;
+        offset =
+          input[pos] |
+          (input[pos + 1] << 8) |
+          (input[pos + 2] << 16) |
+          (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < length; i++) {
+        out[outPos] = out[outPos - offset];
+        outPos += 1;
+      }
+    }
+  }
