+
+function parseFooter() {
+  if (file.subarray(0, 4).toString() !== 'PAR1') {
+    throw new Error('Missing leading PAR1 magic');
+  }
+  if (file.subarray(file.length - 4).toString() !== 'PAR1') {
+    throw new Error('Missing trailing PAR1 magic');
+  }
