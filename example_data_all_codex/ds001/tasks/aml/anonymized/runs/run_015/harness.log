+
+const allTriad = twoPropFromIndicators(y.map((_, i) => t015.values[i] === 1 && t025.values[i] === 1 && t023.values[i] === 1));
+const noneTriad = twoPropFromIndicators(y.map((_, i) => !(t015.values[i] === 1 || t025.values[i] === 1 || t023.values[i] === 1)));
+
+console.log(JSON.stringify({
+  rows: y.length,
+  response_rate: yMean,
+  feature_summaries: summaries.map((s) => ({
+    name: s.name,
+    mean: s.mean,
+    sd: s.sd,
+    min: s.min,
+    max: s.max,
+    uniqueCount: s.uniqueCount,
+    values: s.values,
+    isBinary: s.isBinary,
+    isTernary: s.isTernary,
+  })),
+  top_univariate: univariate.slice(0, 25),
+  top_positive: [...univariate].sort((a, b) => b.effect - a.effect).slice(0, 15),
+  top_negative: [...univariate].sort((a, b) => a.effect - b.effect).slice(0, 15),
+  top_interactions: interactions.slice(0, 25).map((r) => ({
+    a: r.a,
+    b: r.b,
+    ruleA: indicators.get(r.a).rule,
+    ruleB: indicators.get(r.b).rule,
+    effect: r.effect,
+    se: r.se,
+    z: r.z,
+    p: r.p,
+    cells: r.cells,
+  })),
+  adjusted_main_model: adjustedMainModel,
+  triad_model: triadModel,
+  full_model: fullModel,
+  triad_count_rates: rateByTriadCount(),
+  triad_combo_rates: rateByValues(['feature_015', 'feature_025', 'feature_023']),
+  feature_027_level_rates: rateByValues(['feature_027']),
+  all_triad_vs_not_all: allTriad,
+  none_triad_vs_any: noneTriad,
+  modifier_models: modifierModels,
+}, null, 2));

