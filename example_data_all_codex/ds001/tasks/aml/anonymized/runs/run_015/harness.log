+const fs = require('fs');
+
+const file = fs.readFileSync('dataset.parquet');
+
+const CompactType = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+  FLOAT: 13,
+};
+
+function makeCompactReader(buf, start, end) {
+  let off = start;
+
+  function readVarBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      if (off >= end) throw new Error('Unexpected EOF while reading varint');
+      const byte = buf[off++];
+      result |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  function readVar() {
+    const value = readVarBig();
+    if (value > BigInt(Number.MAX_SAFE_INTEGER)) {
+      throw new Error(`Varint too large for Number: ${value}`);
+    }
+    return Number(value);
+  }
+
+  function zigzag(value) {
+    const decoded = (value >> 1n) ^ (-(value & 1n));
+    if (
+      decoded < BigInt(Number.MIN_SAFE_INTEGER) ||
+      decoded > BigInt(Number.MAX_SAFE_INTEGER)
+    ) {
+      throw new Error(`Zigzag value too large for Number: ${decoded}`);
+    }
+    return Number(decoded);
+  }
+
+  function readString() {
+    const len = readVar();
+    const value = buf.subarray(off, off + len).toString('utf8');
+    off += len;
+    return value;
+  }
+
+  function readListHeader() {
+    const header = buf[off++];
+    let size = header >> 4;
+    const elementType = header & 0x0f;
+    if (size === 15) size = readVar();
+    return { size, elementType };
+  }
+
+  function readValue(type) {
+    switch (type) {
+      case CompactType.TRUE:
+        return true;
+      case CompactType.FALSE:
+        return false;
+      case CompactType.BYTE: {
+        const value = buf.readInt8(off);
+        off += 1;
+        return value;
+      }
+      case CompactType.I16:
+      case CompactType.I32:
+      case CompactType.I64:
+        return zigzag(readVarBig());
+      case CompactType.DOUBLE: {
+        const value = buf.readDoubleLE(off);
+        off += 8;
+        return value;
+      }
+      case CompactType.FLOAT: {
+        const value = buf.readFloatLE(off);
+        off += 4;
+        return value;
+      }
+      case CompactType.BINARY:
+        return readString();
+      case CompactType.LIST:
+      case CompactType.SET: {
+        const { size, elementType } = readListHeader();
+        const values = [];
+        for (let i = 0; i < size; i++) values.push(readValue(elementType));
+        return values;
+      }
+      case CompactType.MAP: {
+        const size = readVar();
+        if (size === 0) return [];
+        const typeByte = buf[off++];
+        const keyType = (typeByte >> 4) & 0x0f;
+        const valueType = typeByte & 0x0f;
+        const entries = [];
+        for (let i = 0; i < size; i++) {
+          entries.push([readValue(keyType), readValue(valueType)]);
+        }
+        return entries;
+      }
+      case CompactType.STRUCT:
+        return readStruct();
+      default:
+        throw new Error(`Unknown compact type ${type} at offset ${off}`);
+    }
+  }
+
+  function readStruct() {
+    const obj = {};
+    let previousFieldId = 0;
+    while (true) {
+      const header = buf[off++];
+      const type = header & 0x0f;
+      if (type === CompactType.STOP) break;
+      const delta = header >> 4;
+      let fieldId;
+      if (delta === 0) fieldId = zigzag(readVarBig());
+      else fieldId = previousFieldId + delta;
+      previousFieldId = fieldId;
+      obj[fieldId] = readValue(type);
+    }
+    return obj;
+  }
+
+  return {
+    readStruct,
+    get offset() {
+      return off;
+    },
+  };
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let expected = 0;
+  let shift = 0;
+  while (true) {
