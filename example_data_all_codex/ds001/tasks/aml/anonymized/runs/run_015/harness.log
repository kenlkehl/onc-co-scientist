+  top_univariate: univariate.slice(0, 25),
+  top_positive: [...univariate].sort((a, b) => b.effect - a.effect).slice(0, 15),
+  top_negative: [...univariate].sort((a, b) => a.effect - b.effect).slice(0, 15),
+  top_interactions: interactions.slice(0, 25).map((r) => ({
