+}
+
+function readColumn(columnChunk, schemaElement) {
+  const metadata = columnChunk[3];
+  const parquetType = metadata[1];
+  const codec = metadata[4];
+  const totalCompressedSize = metadata[7];
+  const dataPageOffset = metadata[9];
+  const dictionaryPageOffset = metadata[11];
+  const numValues = metadata[5];
+  const columnStart = dictionaryPageOffset || dataPageOffset;
+  const columnEnd = columnStart + totalCompressedSize;
+  let offset = columnStart;
+  let dictionary = null;
+  const values = [];
