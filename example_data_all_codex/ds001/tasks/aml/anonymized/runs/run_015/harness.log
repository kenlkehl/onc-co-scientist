+
+const metadata = parseFooter();
+const schema = metadata[2];
+const rowGroup = metadata[4][0];
+const columns = rowGroup[1];
+const decoded = {};
+for (let i = 0; i < columns.length; i++) {
+  const schemaElement = schema[i + 1];
+  const name = schemaElement[4];
+  if (name === 'patient_id') continue;
+  decoded[name] = readColumn(columns[i], schemaElement);
+}
+
+const y = decoded.objective_response;
+console.log('rows', y.length, 'response_rate', y.reduce((a, b) => a + b, 0) / y.length);
+for (const name of Object.keys(decoded).filter((c) => c !== 'objective_response').slice(0, 10)) {
+  const x = decoded[name];
+  let min = Infinity;
+  let max = -Infinity;
+  let sum = 0;
+  const uniques = new Set();
+  for (const v of x) {
+    if (v < min) min = v;
+    if (v > max) max = v;
+    sum += v;
+    if (uniques.size < 20) uniques.add(v);
+  }
+  console.log(name, 'mean', sum / x.length, 'min', min, 'max', max, 'unique_sample', Array.from(uniques).slice(0, 10));
+}

codex
The first decode pass found the Parquet columns are optional at the file-format level, so I’m preserving definition levels explicitly. That keeps row alignment correct even if the file has rare encoded null markers despite the dataset note.
