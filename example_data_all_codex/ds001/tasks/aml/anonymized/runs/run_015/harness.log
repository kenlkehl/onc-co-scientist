+  const variance = Math.max(0, sumSq / x.length - m * m);
+  const values = Array.from(counts.keys()).sort((a, b) => a - b);
+  return {
+    name,
+    mean: m,
+    sd: Math.sqrt(variance),
+    min,
+    max,
+    uniqueCount: values.length,
+    values: values.slice(0, 20),
+    counts,
