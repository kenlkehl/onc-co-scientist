+const y = decoded.objective_response;
+console.log('rows', y.length, 'response_rate', y.reduce((a, b) => a + b, 0) / y.length);
+for (const name of Object.keys(decoded).filter((c) => c !== 'objective_response').slice(0, 10)) {
+  const x = decoded[name];
+  let min = Infinity;
+  let max = -Infinity;
+  let sum = 0;
