+      let offset;
+      if (type === 1) {
+        length = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        length = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        length = (tag >> 2) + 1;
+        offset =
