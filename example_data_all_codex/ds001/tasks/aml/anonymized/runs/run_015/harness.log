+function levelCompare(name, highValue, lowValue) {
+  let highY = 0, lowY = 0, highN = 0, lowN = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (decoded[name][i] === highValue) {
+      highY += y[i];
+      highN++;
+    } else if (decoded[name][i] === lowValue) {
+      lowY += y[i];
+      lowN++;
+    }
+  }
+  const highRate = highY / highN;
+  const lowRate = lowY / lowN;
+  const effect = highRate - lowRate;
+  const se = Math.sqrt((highRate * (1 - highRate)) / highN + (lowRate * (1 - lowRate)) / lowN);
+  const z = effect / se;
+  return { highN, lowN, highRate, lowRate, effect, p: twoSidedNormalP(z), z };
+}
