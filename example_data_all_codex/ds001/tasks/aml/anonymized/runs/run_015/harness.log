+    if (v < min) min = v;
+    if (v > max) max = v;
+    sum += v;
+    if (uniques.size < 20) uniques.add(v);
+  }
+  console.log(name, 'mean', sum / x.length, 'min', min, 'max', max, 'unique_sample', Array.from(uniques).slice(0, 10));
