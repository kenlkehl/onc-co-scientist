+    const header = readUnsignedVarintFrom(buf, state);
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      const value = width === 0 ? 0 : readLittleEndianValue(buf, state, byteWidth);
+      for (let i = 0; i < runLength && values.length < count; i++) {
+        values.push(value);
+      }
+    } else {
+      const groups = header >> 1;
+      const totalValues = groups * 8;
+      let bitBuffer = 0;
+      let bitsInBuffer = 0;
+      for (let i = 0; i < totalValues; i++) {
+        while (bitsInBuffer < width) {
+          bitBuffer |= buf[state.offset++] << bitsInBuffer;
+          bitsInBuffer += 8;
+        }
+        const mask = width === 32 ? 0xffffffff : (1 << width) - 1;
+        const value = width === 0 ? 0 : bitBuffer & mask;
