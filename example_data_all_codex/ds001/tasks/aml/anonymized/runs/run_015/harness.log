+        }
+        const decoded = decodeHybrid(levelBody, levelOffset, bitWidth(maxDefinitionLevel), pageValueCount);
+        bodyOffset = definitionLevelEncoding === 3 ? levelEnd : decoded.offset;
+        definitionLevels = decoded.values;
+        nonNullCount = definitionLevels.reduce((acc, level) => acc + (level === maxDefinitionLevel ? 1 : 0), 0);
+      }
+
+      let pageValues;
+      if (encoding === 8 || encoding === 2) {
+        const width = body[bodyOffset++];
+        const decoded = decodeHybrid(body, bodyOffset, width, nonNullCount);
+        pageValues = decoded.values.map((idx) => dictionary[idx]);
+      } else if (encoding === 0) {
+        pageValues = decodePlainValues(body.subarray(bodyOffset), parquetType, nonNullCount);
+      } else {
+        throw new Error(`Unsupported data page encoding ${encoding} for ${schemaElement[4]}`);
+      }
+      if (definitionLevels) {
+        let valueIndex = 0;
+        for (const level of definitionLevels) {
+          values.push(level === maxDefinitionLevel ? pageValues[valueIndex++] : null);
+        }
+      } else {
+        values.push(...pageValues);
+      }
+    } else if (pageType === 3) {
+      const dataHeader = header[8];
+      const pageValueCount = dataHeader[1];
+      const numNulls = dataHeader[2];
+      const encoding = dataHeader[4];
+      const defBytes = dataHeader[5] || 0;
+      const repBytes = dataHeader[6] || 0;
+      let definitionLevels = null;
+      if (defBytes > 0 && maxDefinitionLevel > 0) {
+        definitionLevels = decodeHybrid(body.subarray(0, defBytes), 0, bitWidth(maxDefinitionLevel), pageValueCount).values;
+      }
+      let bodyOffset = repBytes + defBytes;
+      const nonNullCount = pageValueCount - numNulls;
+      let pageValues;
+      if (encoding === 8 || encoding === 2) {
+        const width = body[bodyOffset++];
+        const decoded = decodeHybrid(body, bodyOffset, width, nonNullCount);
+        pageValues = decoded.values.map((idx) => dictionary[idx]);
+      } else if (encoding === 0) {
+        pageValues = decodePlainValues(body.subarray(bodyOffset), parquetType, nonNullCount);
+      } else {
+        throw new Error(`Unsupported data page v2 encoding ${encoding} for ${schemaElement[4]}`);
+      }
+      if (definitionLevels) {
+        let valueIndex = 0;
+        for (const level of definitionLevels) {
+          values.push(level === maxDefinitionLevel ? pageValues[valueIndex++] : null);
+        }
+      } else {
+        values.push(...pageValues);
+      }
+    }
+  }
+
+  if (values.length !== numValues) {
+    throw new Error(`Decoded ${values.length} values for ${schemaElement[4]}, expected ${numValues}`);
+  }
+  return values;
+}
+
+const metadata = parseFooter();
+const schema = metadata[2];
+const rowGroup = metadata[4][0];
+const columns = rowGroup[1];
+const decoded = {};
+for (let i = 0; i < columns.length; i++) {
+  const schemaElement = schema[i + 1];
+  const name = schemaElement[4];
+  if (name === 'patient_id') continue;
+  decoded[name] = readColumn(columns[i], schemaElement);
+}
+
+const y = decoded.objective_response;
+const featureNames = Object.keys(decoded).filter((c) => c !== 'objective_response');
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const value = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * value;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedNormalP(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function mean(arr) {
+  return arr.reduce((a, b) => a + b, 0) / arr.length;
+}
+
+function summarizeFeature(name) {
+  const x = decoded[name];
+  let sum = 0;
+  let sumSq = 0;
+  let min = Infinity;
+  let max = -Infinity;
+  const counts = new Map();
+  for (const v of x) {
+    sum += v;
+    sumSq += v * v;
+    if (v < min) min = v;
+    if (v > max) max = v;
+    counts.set(v, (counts.get(v) || 0) + 1);
+  }
+  const m = sum / x.length;
+  const variance = Math.max(0, sumSq / x.length - m * m);
+  const values = Array.from(counts.keys()).sort((a, b) => a - b);
+  return {
+    name,
+    mean: m,
+    sd: Math.sqrt(variance),
+    min,
+    max,
+    uniqueCount: values.length,
+    values: values.slice(0, 20),
+    counts,
+    isBinary: values.length === 2 && values[0] === 0 && values[1] === 1,
+    isTernary: values.length === 3,
+  };
+}
+
+function simpleLinearEffect(name) {
+  const x = decoded[name];
+  const n = x.length;
+  const sx = summarizeFeature(name);
+  const yMean = mean(y);
+  let xMean = sx.mean;
+  let xSd = sx.sd;
+  let xs = new Array(n);
+  if (sx.isBinary) {
+    xSd = 1;
+    xMean = 0;
+    xs = x;
+  } else {
+    for (let i = 0; i < n; i++) xs[i] = (x[i] - xMean) / xSd;
+    xMean = 0;
+  }
+  let sxx = 0;
+  let sxy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = xs[i] - xMean;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - yMean);
+  }
+  const beta = sxy / sxx;
+  let sse = 0;
+  const intercept = yMean - beta * xMean;
+  for (let i = 0; i < n; i++) {
+    const residual = y[i] - (intercept + beta * xs[i]);
+    sse += residual * residual;
+  }
+  const se = Math.sqrt((sse / (n - 2)) / sxx);
+  const z = beta / se;
+  const p = twoSidedNormalP(z);
+
+  if (sx.isBinary) {
+    let y1 = 0, y0 = 0, n1 = 0, n0 = 0;
+    for (let i = 0; i < n; i++) {
+      if (x[i] === 1) {
+        y1 += y[i];
+        n1++;
+      } else {
+        y0 += y[i];
+        n0++;
+      }
+    }
+    const p1 = y1 / n1;
+    const p0 = y0 / n0;
+    const se2 = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+    const z2 = (p1 - p0) / se2;
+    return { name, kind: 'binary', effect: p1 - p0, p: twoSidedNormalP(z2), z: z2, n1, n0, p1, p0 };
+  }
+
+  return { name, kind: 'continuous_1sd', effect: beta, p, z, mean: sx.mean, sd: sx.sd };
+}
+
+function median(values) {
+  const sorted = [...values].sort((a, b) => a - b);
+  const n = sorted.length;
+  return n % 2 ? sorted[(n - 1) / 2] : (sorted[n / 2 - 1] + sorted[n / 2]) / 2;
+}
+
+function binaryIndicator(name) {
+  const sx = summarizeFeature(name);
+  const x = decoded[name];
+  if (sx.isBinary) {
+    return { label: `${name}=1`, values: x.map((v) => v === 1 ? 1 : 0), rule: `${name} is 1` };
+  }
+  if (sx.isTernary) {
+    const highValue = sx.max;
+    return { label: `${name}=${highValue}`, values: x.map((v) => v === highValue ? 1 : 0), rule: `${name} is ${highValue}` };
+  }
+  const med = median(x);
+  return { label: `${name}>=median`, values: x.map((v) => v >= med ? 1 : 0), rule: `${name} is at or above its median (${med.toFixed(4)})`, threshold: med };
+}
+
+function interactionEffect(indA, indB) {
+  const cells = {
+    '00': { n: 0, y: 0 },
+    '01': { n: 0, y: 0 },
+    '10': { n: 0, y: 0 },
+    '11': { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${indA.values[i]}${indB.values[i]}`;
+    cells[key].n++;
+    cells[key].y += y[i];
+  }
+  for (const cell of Object.values(cells)) cell.rate = cell.y / cell.n;
+  if (Object.values(cells).some((c) => c.n < 50)) return null;
+  const effect = cells['11'].rate - cells['10'].rate - cells['01'].rate + cells['00'].rate;
+  const variance = Object.values(cells).reduce((acc, c) => acc + (c.rate * (1 - c.rate)) / c.n, 0);
+  const se = Math.sqrt(variance);
+  const z = effect / se;
+  return { effect, se, z, p: twoSidedNormalP(z), cells };
+}
+
+const yMean = mean(y);
+const summaries = featureNames.map(summarizeFeature);
+const univariate = featureNames.map(simpleLinearEffect).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+const indicators = new Map(featureNames.map((name) => [name, binaryIndicator(name)]));
+const interactions = [];
+for (let i = 0; i < featureNames.length; i++) {
+  for (let j = i + 1; j < featureNames.length; j++) {
+    const a = featureNames[i];
+    const b = featureNames[j];
+    const result = interactionEffect(indicators.get(a), indicators.get(b));
+    if (result) interactions.push({ a, b, ...result });
+  }
+}
+interactions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+console.log(JSON.stringify({
+  rows: y.length,
+  response_rate: yMean,
+  feature_summaries: summaries.map((s) => ({
+    name: s.name,
+    mean: s.mean,
+    sd: s.sd,
+    min: s.min,
+    max: s.max,
+    uniqueCount: s.uniqueCount,
+    values: s.values,
+    isBinary: s.isBinary,
+    isTernary: s.isTernary,
+  })),
+  top_univariate: univariate.slice(0, 25),
+  top_positive: [...univariate].sort((a, b) => b.effect - a.effect).slice(0, 15),
+  top_negative: [...univariate].sort((a, b) => a.effect - b.effect).slice(0, 15),
+  top_interactions: interactions.slice(0, 25).map((r) => ({
+    a: r.a,
+    b: r.b,
+    ruleA: indicators.get(r.a).rule,
+    ruleB: indicators.get(r.b).rule,
+    effect: r.effect,
+    se: r.se,
+    z: r.z,
+    p: r.p,
+    cells: r.cells,
+  })),
+}, null, 2));

