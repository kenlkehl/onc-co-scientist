+    for (let i = 0; i < n; i++) {
+      if (x[i] === 1) {
+        y1 += y[i];
+        n1++;
+      } else {
+        y0 += y[i];
+        n0++;
+      }
+    }
+    const p1 = y1 / n1;
+    const p0 = y0 / n0;
+    const se2 = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+    const z2 = (p1 - p0) / se2;
+    return { name, kind: 'binary', effect: p1 - p0, p: twoSidedNormalP(z2), z: z2, n1, n0, p1, p0 };
+  }
+
+  return { name, kind: 'continuous_1sd', effect: beta, p, z, mean: sx.mean, sd: sx.sd };
+}
+
+function median(values) {
+  const sorted = [...values].sort((a, b) => a - b);
+  const n = sorted.length;
+  return n % 2 ? sorted[(n - 1) / 2] : (sorted[n / 2 - 1] + sorted[n / 2]) / 2;
+}
+
+function binaryIndicator(name) {
+  const sx = summarizeFeature(name);
+  const x = decoded[name];
+  if (sx.isBinary) {
+    return { label: `${name}=1`, values: x.map((v) => v === 1 ? 1 : 0), rule: `${name} is 1` };
+  }
+  if (sx.isTernary) {
+    const highValue = sx.max;
+    return { label: `${name}=${highValue}`, values: x.map((v) => v === highValue ? 1 : 0), rule: `${name} is ${highValue}` };
+  }
+  const med = median(x);
+  return { label: `${name}>=median`, values: x.map((v) => v >= med ? 1 : 0), rule: `${name} is at or above its median (${med.toFixed(4)})`, threshold: med };
+}
+
+function interactionEffect(indA, indB) {
+  const cells = {
+    '00': { n: 0, y: 0 },
+    '01': { n: 0, y: 0 },
+    '10': { n: 0, y: 0 },
+    '11': { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${indA.values[i]}${indB.values[i]}`;
+    cells[key].n++;
+    cells[key].y += y[i];
+  }
+  for (const cell of Object.values(cells)) cell.rate = cell.y / cell.n;
+  if (Object.values(cells).some((c) => c.n < 50)) return null;
+  const effect = cells['11'].rate - cells['10'].rate - cells['01'].rate + cells['00'].rate;
+  const variance = Object.values(cells).reduce((acc, c) => acc + (c.rate * (1 - c.rate)) / c.n, 0);
+  const se = Math.sqrt(variance);
+  const z = effect / se;
+  return { effect, se, z, p: twoSidedNormalP(z), cells };
+}
+
+const yMean = mean(y);
+const summaries = featureNames.map(summarizeFeature);
+const univariate = featureNames.map(simpleLinearEffect).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+const indicators = new Map(featureNames.map((name) => [name, binaryIndicator(name)]));
+const interactions = [];
+for (let i = 0; i < featureNames.length; i++) {
+  for (let j = i + 1; j < featureNames.length; j++) {
+    const a = featureNames[i];
+    const b = featureNames[j];
+    const result = interactionEffect(indicators.get(a), indicators.get(b));
+    if (result) interactions.push({ a, b, ...result });
+  }
+}
+interactions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+function fitOls(terms) {
+  const n = y.length;
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...terms.map((term) => term.values[i])];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    let fitted = beta[0];
+    for (let j = 0; j < terms.length; j++) fitted += beta[j + 1] * terms[j].values[i];
+    const residual = y[i] - fitted;
+    sse += residual * residual;
+  }
+  const sigma2 = sse / (n - p);
+  const results = terms.map((term, idx) => {
+    const se = Math.sqrt(sigma2 * inv[idx + 1][idx + 1]);
+    const z = beta[idx + 1] / se;
+    return {
+      term: term.name,
+      effect: beta[idx + 1],
+      se,
+      z,
+      p: twoSidedNormalP(z),
+    };
+  });
+  return {
+    intercept: beta[0],
+    sigma2,
+    results,
+  };
+}
+
+function invertMatrix(matrix) {
+  const n = matrix.length;
+  const a = matrix.map((row, i) => [
+    ...row,
+    ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0)),
+  ]);
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let row = col + 1; row < n; row++) {
+      if (Math.abs(a[row][col]) > Math.abs(a[pivot][col])) pivot = row;
+    }
+    if (Math.abs(a[pivot][col]) < 1e-12) throw new Error('Singular matrix in OLS');
+    if (pivot !== col) [a[pivot], a[col]] = [a[col], a[pivot]];
+    const divisor = a[col][col];
+    for (let j = 0; j < 2 * n; j++) a[col][j] /= divisor;
+    for (let row = 0; row < n; row++) {
+      if (row === col) continue;
+      const factor = a[row][col];
+      for (let j = 0; j < 2 * n; j++) a[row][j] -= factor * a[col][j];
+    }
+  }
+  return a.map((row) => row.slice(n));
+}
+
+function standardizedTerm(name) {
+  const sx = summarizeFeature(name);
+  return { name: `${name}_per_1sd`, values: decoded[name].map((v) => (v - sx.mean) / sx.sd) };
+}
+
+function binaryTerm(name) {
+  return { name, values: decoded[name].map((v) => v === 1 ? 1 : 0) };
+}
+
+function indicatorTerm(name) {
+  const ind = indicators.get(name);
+  return { name: ind.label, values: ind.values };
+}
+
+function productTerm(name, ...terms) {
+  return {
+    name,
+    values: y.map((_, i) => terms.reduce((acc, term) => acc * term.values[i], 1)),
+  };
+}
+
+function rateByValues(names) {
+  const groups = new Map();
+  for (let i = 0; i < y.length; i++) {
+    const key = names.map((name) => decoded[name][i]).join('|');
+    const current = groups.get(key) || { n: 0, y: 0 };
+    current.n++;
+    current.y += y[i];
+    groups.set(key, current);
+  }
+  return Object.fromEntries(Array.from(groups.entries()).sort(([a], [b]) => a.localeCompare(b)).map(([key, value]) => [
+    key,
+    { n: value.n, rate: value.y / value.n },
+  ]));
+}
+
+function rateByTriadCount() {
+  const a = binaryTerm('feature_015').values;
+  const b = binaryTerm('feature_025').values;
+  const c = binaryTerm('feature_023').values;
+  const groups = Array.from({ length: 4 }, () => ({ n: 0, y: 0 }));
+  for (let i = 0; i < y.length; i++) {
+    const count = a[i] + b[i] + c[i];
+    groups[count].n++;
+    groups[count].y += y[i];
+  }
+  return groups.map((g, count) => ({ count, n: g.n, rate: g.y / g.n }));
+}
+
+function twoPropFromIndicators(ind) {
+  let y1 = 0, y0 = 0, n1 = 0, n0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (ind[i]) {
+      y1 += y[i];
+      n1++;
+    } else {
+      y0 += y[i];
+      n0++;
+    }
+  }
+  const p1 = y1 / n1;
+  const p0 = y0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+  const z = effect / se;
+  return { effect, p: twoSidedNormalP(z), z, n1, n0, p1, p0 };
+}
+
+const adjustedMainTerms = [
+  standardizedTerm('feature_027'),
+  binaryTerm('feature_025'),
+  binaryTerm('feature_015'),
+  binaryTerm('feature_023'),
+  standardizedTerm('feature_004'),
+  standardizedTerm('feature_031'),
+  standardizedTerm('feature_059'),
+  binaryTerm('feature_001'),
+  binaryTerm('feature_032'),
+  standardizedTerm('feature_053'),
+];
+const adjustedMainModel = fitOls(adjustedMainTerms);
+
+const t015 = binaryTerm('feature_015');
+const t025 = binaryTerm('feature_025');
+const t023 = binaryTerm('feature_023');
+const triadModel = fitOls([
+  t015,
+  t025,
+  t023,
+  productTerm('feature_015:feature_025', t015, t025),
+  productTerm('feature_015:feature_023', t015, t023),
+  productTerm('feature_025:feature_023', t025, t023),
+  productTerm('feature_015:feature_025:feature_023', t015, t025, t023),
+]);
+
+const fullModel = fitOls([
+  t015,
+  t025,
+  t023,
+  productTerm('feature_015:feature_025', t015, t025),
+  productTerm('feature_015:feature_023', t015, t023),
+  productTerm('feature_025:feature_023', t025, t023),
+  productTerm('feature_015:feature_025:feature_023', t015, t025, t023),
+  standardizedTerm('feature_027'),
+  standardizedTerm('feature_004'),
+  standardizedTerm('feature_031'),
+  standardizedTerm('feature_059'),
+  binaryTerm('feature_001'),
+  binaryTerm('feature_032'),
+  standardizedTerm('feature_053'),
+]);
+
+const modifierModels = {};
+for (const [xName, zName] of [
+  ['feature_025', 'feature_001'],
+  ['feature_025', 'feature_032'],
+  ['feature_015', 'feature_001'],
+  ['feature_023', 'feature_032'],
+  ['feature_023', 'feature_001'],
+  ['feature_015', 'feature_032'],
+]) {
+  const xTerm = binaryTerm(xName);
+  const zTerm = binaryTerm(zName);
+  modifierModels[`${xName}:${zName}`] = fitOls([xTerm, zTerm, productTerm(`${xName}:${zName}`, xTerm, zTerm)]);
+}
+
+const allTriad = twoPropFromIndicators(y.map((_, i) => t015.values[i] === 1 && t025.values[i] === 1 && t023.values[i] === 1));
+const noneTriad = twoPropFromIndicators(y.map((_, i) => !(t015.values[i] === 1 || t025.values[i] === 1 || t023.values[i] === 1)));
+
+console.log(JSON.stringify({
+  rows: y.length,
+  response_rate: yMean,
+  feature_summaries: summaries.map((s) => ({
+    name: s.name,
+    mean: s.mean,
