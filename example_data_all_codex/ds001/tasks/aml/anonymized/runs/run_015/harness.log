+      const pageValueCount = dataHeader[1];
+      const numNulls = dataHeader[2];
+      const encoding = dataHeader[4];
+      const defBytes = dataHeader[5] || 0;
+      const repBytes = dataHeader[6] || 0;
+      let definitionLevels = null;
+      if (defBytes > 0 && maxDefinitionLevel > 0) {
+        definitionLevels = decodeHybrid(body.subarray(0, defBytes), 0, bitWidth(maxDefinitionLevel), pageValueCount).values;
+      }
+      let bodyOffset = repBytes + defBytes;
+      const nonNullCount = pageValueCount - numNulls;
+      let pageValues;
+      if (encoding === 8 || encoding === 2) {
+        const width = body[bodyOffset++];
+        const decoded = decodeHybrid(body, bodyOffset, width, nonNullCount);
+        pageValues = decoded.values.map((idx) => dictionary[idx]);
+      } else if (encoding === 0) {
+        pageValues = decodePlainValues(body.subarray(bodyOffset), parquetType, nonNullCount);
+      } else {
+        throw new Error(`Unsupported data page v2 encoding ${encoding} for ${schemaElement[4]}`);
+      }
+      if (definitionLevels) {
