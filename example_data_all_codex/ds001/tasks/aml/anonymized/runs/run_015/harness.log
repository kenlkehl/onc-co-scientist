+        let levelOffset = bodyOffset;
+        let levelEnd = body.length;
+        if (definitionLevelEncoding === 3) {
+          const levelByteLength = body.readInt32LE(bodyOffset);
+          bodyOffset += 4;
+          levelOffset = bodyOffset;
+          levelEnd = bodyOffset + levelByteLength;
+          levelBody = body.subarray(0, levelEnd);
+        }
+        const decoded = decodeHybrid(levelBody, levelOffset, bitWidth(maxDefinitionLevel), pageValueCount);
+        bodyOffset = definitionLevelEncoding === 3 ? levelEnd : decoded.offset;
+        definitionLevels = decoded.values;
+        nonNullCount = definitionLevels.reduce((acc, level) => acc + (level === maxDefinitionLevel ? 1 : 0), 0);
