+
+function readUnsignedVarintFrom(buf, state) {
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const byte = buf[state.offset++];
+    result += (byte & 0x7f) * 2 ** shift;
+    if ((byte & 0x80) === 0) break;
+    shift += 7;
+  }
+  return result;
