+  let xMean = sx.mean;
+  let xSd = sx.sd;
+  let xs = new Array(n);
+  if (sx.isBinary) {
+    xSd = 1;
+    xMean = 0;
+    xs = x;
+  } else {
+    for (let i = 0; i < n; i++) xs[i] = (x[i] - xMean) / xSd;
+    xMean = 0;
+  }
+  let sxx = 0;
+  let sxy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = xs[i] - xMean;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - yMean);
+  }
+  const beta = sxy / sxx;
+  let sse = 0;
+  const intercept = yMean - beta * xMean;
+  for (let i = 0; i < n; i++) {
