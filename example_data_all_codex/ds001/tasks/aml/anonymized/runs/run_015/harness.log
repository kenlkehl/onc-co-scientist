+  all_triad_vs_not_all: allTriad,
+  none_triad_vs_any: noneTriad,
+  modifier_models: modifierModels,
+};
+
+function jsonP(p) {
+  if (p === 0) return 1e-300;
+  return Number(p.toPrecision(6));
+}
+
+function sig(p) {
+  return p < 0.05;
+}
+
+function signed(value, digits = 4) {
+  const fixed = value.toFixed(digits);
+  return value >= 0 ? `+${fixed}` : fixed;
+}
+
+function pct(value) {
+  return `${(100 * value).toFixed(1)}%`;
+}
+
+function pText(p) {
+  if (p === 0 || p < 1e-300) return 'p<1e-300';
+  if (p < 0.001) return `p=${p.toExponential(2)}`;
+  return `p=${p.toFixed(4)}`;
+}
+
+function byName(name) {
+  return univariate.find((r) => r.name === name);
+}
+
+function getInteraction(a, b) {
+  const found = interactions.find((r) => (r.a === a && r.b === b) || (r.a === b && r.b === a));
+  if (!found) throw new Error(`Missing interaction ${a}:${b}`);
+  return found;
+}
+
+function getTerm(model, term) {
+  const found = model.results.find((r) => r.term === term);
+  if (!found) throw new Error(`Missing model term ${term}`);
+  return found;
+}
+
+function baseAnalysis(hypothesisId, resultSummary, effect, p, method, extra = {}) {
+  return {
+    hypothesis_ids: Array.isArray(hypothesisId) ? hypothesisId : [hypothesisId],
+    result_summary: resultSummary,
+    p_value: jsonP(p),
+    effect_estimate: Number(effect.toPrecision(8)),
+    significant: sig(p),
+    method,
+    ...extra,
+  };
+}
+
+function univariateAnalysis(hypothesisId, name) {
+  const r = byName(name);
+  if (r.kind === 'binary') {
+    return baseAnalysis(
+      hypothesisId,
+      `${name}=1 had objective_response ${pct(r.p1)} vs ${pct(r.p0)} for ${name}=0; absolute risk difference ${signed(r.effect)} (${pText(r.p)}).`,
+      r.effect,
+      r.p,
+      'Two-proportion z test / univariate linear probability contrast',
+      { n_exposed: r.n1, n_unexposed: r.n0, rate_exposed: r.p1, rate_unexposed: r.p0 },
+    );
+  }
+  return baseAnalysis(
+    hypothesisId,
+    `A one-standard-deviation increase in ${name} changed objective_response probability by ${signed(r.effect)} in a univariate linear probability model (${pText(r.p)}).`,
+    r.effect,
+    r.p,
+    'Univariate linear probability model with standardized predictor',
+    { feature_mean: r.mean, feature_sd: r.sd },
+  );
+}
+
+function interactionAnalysis(hypothesisId, a, b) {
+  const r = getInteraction(a, b);
+  const c = r.cells;
+  return baseAnalysis(
+    hypothesisId,
+    `Risk-difference interaction for ${a} and ${b} was ${signed(r.effect)}; cell response rates were 00=${pct(c['00'].rate)}, 10=${pct(c['10'].rate)}, 01=${pct(c['01'].rate)}, and 11=${pct(c['11'].rate)} (${pText(r.p)}).`,
+    r.effect,
+    r.p,
+    '2x2 linear probability interaction / difference-in-differences',
+    {
+      rule_a: indicators.get(a).rule,
+      rule_b: indicators.get(b).rule,
+      cell_rates: c,
+    },
+  );
+}
+
+function modifierAnalysis(hypothesisId, xName, zName) {
+  const model = modifierModels[`${xName}:${zName}`];
+  const r = getTerm(model, `${xName}:${zName}`);
+  return baseAnalysis(
+    hypothesisId,
+    `In a linear probability model with ${xName}, ${zName}, and their product, the ${xName}:${zName} interaction coefficient was ${signed(r.effect)} (${pText(r.p)}).`,
+    r.effect,
+    r.p,
+    'Adjusted two-feature linear probability interaction model',
+  );
+}
+
+function modelTermAnalysis(hypothesisId, model, term, label) {
+  const r = getTerm(model, term);
+  return baseAnalysis(
+    hypothesisId,
+    `${label} coefficient was ${signed(r.effect)} in the adjusted linear probability model (${pText(r.p)}).`,
+    r.effect,
+    r.p,
+    'Multivariable linear probability model',
+  );
+}
+
+function levelCompare(name, highValue, lowValue) {
+  let highY = 0, lowY = 0, highN = 0, lowN = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (decoded[name][i] === highValue) {
+      highY += y[i];
+      highN++;
+    } else if (decoded[name][i] === lowValue) {
+      lowY += y[i];
+      lowN++;
+    }
+  }
+  const highRate = highY / highN;
+  const lowRate = lowY / lowN;
+  const effect = highRate - lowRate;
+  const se = Math.sqrt((highRate * (1 - highRate)) / highN + (lowRate * (1 - lowRate)) / lowN);
+  const z = effect / se;
+  return { highN, lowN, highRate, lowRate, effect, p: twoSidedNormalP(z), z };
+}
