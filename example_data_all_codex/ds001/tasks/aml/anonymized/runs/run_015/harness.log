+const t015 = binaryTerm('feature_015');
+const t025 = binaryTerm('feature_025');
+const t023 = binaryTerm('feature_023');
+const triadModel = fitOls([
+  t015,
+  t025,
+  t023,
+  productTerm('feature_015:feature_025', t015, t025),
+  productTerm('feature_015:feature_023', t015, t023),
+  productTerm('feature_025:feature_023', t025, t023),
+  productTerm('feature_015:feature_025:feature_023', t015, t025, t023),
