+function binaryAssociation(x, y) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < y.length; i += 1) {
+    if (x[i] === 1) {
+      n1 += 1;
+      s1 += y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+    }
+  }
+  const p1 = s1 / n1;
+  const p0 = s0 / n0;
+  const pooled = (s1 + s0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
+  const effect = p1 - p0;
+  const z = effect / se;
+  return { n1, n0, s1, s0, p1, p0, effect, se, z, p: normalTwoSidedP(z) };
