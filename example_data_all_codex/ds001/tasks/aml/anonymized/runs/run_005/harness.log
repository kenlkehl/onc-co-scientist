+    result_summary: resultSummary,
+    p_value: stat && Number.isFinite(stat.p) ? round(stat.p, 10) : null,
+    effect_estimate: stat && Number.isFinite(stat.effect) ? round(stat.effect, 6) : null,
+    significant: stat && Number.isFinite(stat.p) ? stat.p < 0.05 : null,
+  };
