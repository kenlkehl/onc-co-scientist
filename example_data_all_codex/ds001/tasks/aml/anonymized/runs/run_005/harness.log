+function decodeColumn(columnIndex) {
+  const meta = columns[columnIndex][3];
+  const type = meta[1];
+  const total = meta[5];
+  const codec = meta[4];
+  const dictOffset = meta[11];
+  if (dictOffset == null) throw new Error(`Column ${columnIndex} is not dictionary encoded`);
