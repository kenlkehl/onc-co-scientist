+  const effect = p1 - p0;
+  const z = effect / se;
+  return { n1, n0, s1, s0, p1, p0, effect, se, z, p: normalTwoSidedP(z) };
+}
+
+function thresholdAssociation(x, y, threshold, op = 'ge') {
+  const b = x.map((value) => (op === 'ge' ? value >= threshold : value > threshold) ? 1 : 0);
+  return binaryAssociation(b, y);
+}
+
+function levelAssociation(x, y, level) {
+  const b = x.map((value) => (value === level ? 1 : 0));
+  return binaryAssociation(b, y);
+}
+
+function continuousAssociation(x, y) {
+  const n = y.length;
+  const mx = mean(x);
+  const my = mean(y);
+  const sx = sd(x, mx);
+  let cov = 0;
+  let sy2 = 0;
+  for (let i = 0; i < n; i += 1) {
+    cov += (x[i] - mx) * (y[i] - my);
+    sy2 += (y[i] - my) ** 2;
+  }
+  const beta = cov / ((n - 1) * sx * sx);
+  const effectPerSd = beta * sx;
+  const r = cov / Math.sqrt(((n - 1) * sx * sx) * sy2);
+  const t = r * Math.sqrt((n - 2) / Math.max(1e-12, 1 - r * r));
+  return { beta, effectPerSd, r, z: t, p: normalTwoSidedP(t), mean: mx, sd: sx };
+}
+
+function interaction2(a, b, y) {
+  let n00 = 0;
+  let n01 = 0;
+  let n10 = 0;
+  let n11 = 0;
+  let s00 = 0;
+  let s01 = 0;
+  let s10 = 0;
+  let s11 = 0;
+  for (let i = 0; i < y.length; i += 1) {
+    if (a[i] === 1 && b[i] === 1) {
+      n11 += 1;
+      s11 += y[i];
+    } else if (a[i] === 1) {
+      n10 += 1;
+      s10 += y[i];
+    } else if (b[i] === 1) {
+      n01 += 1;
+      s01 += y[i];
+    } else {
+      n00 += 1;
+      s00 += y[i];
+    }
+  }
+  const p00 = s00 / n00;
+  const p01 = s01 / n01;
+  const p10 = s10 / n10;
+  const p11 = s11 / n11;
+  const effect = p11 - p10 - p01 + p00;
+  const se = Math.sqrt(
+    p00 * (1 - p00) / n00 +
+      p01 * (1 - p01) / n01 +
+      p10 * (1 - p10) / n10 +
+      p11 * (1 - p11) / n11
+  );
+  return { n00, n01, n10, n11, p00, p01, p10, p11, effect, se, z: effect / se, p: normalTwoSidedP(effect / se) };
+}
+
+function threeWayInteraction(a, b, c, y) {
+  const n = Array(8).fill(0);
+  const s = Array(8).fill(0);
+  for (let i = 0; i < y.length; i += 1) {
+    const idx = (a[i] ? 4 : 0) + (b[i] ? 2 : 0) + (c[i] ? 1 : 0);
+    n[idx] += 1;
+    s[idx] += y[i];
+  }
+  const p = n.map((count, idx) => s[idx] / count);
+  const effect = p[7] - p[6] - p[5] - p[3] + p[4] + p[2] + p[1] - p[0];
+  const se = Math.sqrt(p.reduce((acc, rate, idx) => acc + rate * (1 - rate) / n[idx], 0));
+  return { n, rates: p, effect, se, z: effect / se, p: normalTwoSidedP(effect / se) };
+}
+
+function matrixInvert(matrix) {
+  const n = matrix.length;
+  const aug = matrix.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j += 1) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let col = 0; col < n; col += 1) {
+    let pivot = col;
+    for (let row = col + 1; row < n; row += 1) {
+      if (Math.abs(aug[row][col]) > Math.abs(aug[pivot][col])) pivot = row;
+    }
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const div = aug[col][col];
+    for (let j = 0; j < 2 * n; j += 1) aug[col][j] /= div;
+    for (let row = 0; row < n; row += 1) {
+      if (row === col) continue;
+      const factor = aug[row][col];
+      for (let j = 0; j < 2 * n; j += 1) aug[row][j] -= factor * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function ols(y, specs) {
+  const n = y.length;
+  const p = specs.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i += 1) {
+    const row = [1, ...specs.map((spec) => spec.values[i])];
+    for (let a = 0; a < p; a += 1) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b += 1) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = matrixInvert(xtx);
+  const beta = inv.map((row) => row.reduce((acc, value, idx) => acc + value * xty[idx], 0));
+
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  let rss = 0;
+  for (let i = 0; i < n; i += 1) {
+    const row = [1, ...specs.map((spec) => spec.values[i])];
+    const pred = row.reduce((acc, value, idx) => acc + value * beta[idx], 0);
+    const resid = y[i] - pred;
+    rss += resid * resid;
+    for (let a = 0; a < p; a += 1) {
+      for (let b = 0; b < p; b += 1) meat[a][b] += row[a] * row[b] * resid * resid;
+    }
+  }
+  const vcov = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let a = 0; a < p; a += 1) {
+    for (let b = 0; b < p; b += 1) {
+      let value = 0;
+      for (let c = 0; c < p; c += 1) {
+        for (let d = 0; d < p; d += 1) value += inv[a][c] * meat[c][d] * inv[d][b];
+      }
+      vcov[a][b] = value;
+    }
+  }
+  const rows = specs.map((spec, idx) => {
+    const coef = beta[idx + 1];
+    const se = Math.sqrt(Math.max(0, vcov[idx + 1][idx + 1]));
+    const z = coef / se;
+    return { name: spec.name, coef, se, z, p: normalTwoSidedP(z) };
+  });
+  return { intercept: beta[0], rows, rss };
+}
+
+function product(valuesA, valuesB) {
+  return valuesA.map((value, idx) => value * valuesB[idx]);
+}
+
+function standardize(values) {
+  const avg = mean(values);
+  const stdev = sd(values, avg);
+  return values.map((value) => (value - avg) / stdev);
+}
+
+function round(value, digits = 6) {
+  if (value === 0) return 0;
+  if (!Number.isFinite(value)) return value;
+  if (Math.abs(value) < 1e-6) return Number(value.toExponential(6));
+  return Number(value.toFixed(digits));
+}
+
+function fmtPct(value) {
+  return `${(100 * value).toFixed(1)}%`;
+}
+
+function analysisRecord(hypothesisIds, resultSummary, stat, code = null) {
+  return {
+    hypothesis_ids: Array.isArray(hypothesisIds) ? hypothesisIds : [hypothesisIds],
+    code,
+    result_summary: resultSummary,
+    p_value: stat && Number.isFinite(stat.p) ? round(stat.p, 10) : null,
+    effect_estimate: stat && Number.isFinite(stat.effect) ? round(stat.effect, 6) : null,
+    significant: stat && Number.isFinite(stat.p) ? stat.p < 0.05 : null,
+  };
+}
