+  const beta = cov / ((n - 1) * sx * sx);
+  const effectPerSd = beta * sx;
+  const r = cov / Math.sqrt(((n - 1) * sx * sx) * sy2);
+  const t = r * Math.sqrt((n - 2) / Math.max(1e-12, 1 - r * r));
