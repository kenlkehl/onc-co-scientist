+const footerLen = buf.readUInt32LE(buf.length - 8);
+const footer = buf.subarray(buf.length - 8 - footerLen, buf.length - 8);
+const metadata = convertThrift(new CompactReader(footer).readStruct());
+const schema = metadata[2];
+const rowGroup = metadata[4][0];
+const columns = rowGroup[1];
+const columnNames = schema.slice(1).map((entry) => entry[4]);
