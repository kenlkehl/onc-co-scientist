+const fs = require('fs');
+
+const buf = fs.readFileSync('dataset.parquet');
+
+class CompactReader {
+  constructor(buf, start = 0) {
+    this.buf = buf;
+    this.pos = start;
+    this.lastField = [];
+  }
+
+  readByte() {
+    if (this.pos >= this.buf.length) throw new Error('Unexpected EOF');
+    return this.buf[this.pos++];
+  }
+
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+
+  zigzag(u) {
+    return Number((u >> 1n) ^ (-(u & 1n)));
+  }
+
+  readI16() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readI32() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const value = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return value;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const value = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return value;
+  }
+
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = (b & 0xf0) >> 4;
+    const id = delta === 0 ? this.readI16() : (this.lastField[this.lastField.length - 1] || 0) + delta;
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+
+  readListBegin() {
+    const b = this.readByte();
+    let size = (b & 0xf0) >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elemType };
+  }
+
+  readVal(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return this.readByte();
+      case 4:
+        return this.readI16();
+      case 5:
+        return this.readI32();
+      case 6:
+        return this.readI64();
+      case 7:
+        return this.readDouble();
+      case 8:
+        return this.readBinary();
+      case 9:
