+    }
+  }
+
+  readList() {
+    const { size, elemType } = this.readListBegin();
+    const values = [];
+    for (let i = 0; i < size; i += 1) values.push(this.readVal(elemType));
+    return values;
+  }
+
+  readStruct() {
