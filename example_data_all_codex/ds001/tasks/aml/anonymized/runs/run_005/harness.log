+function interaction2(a, b, y) {
+  let n00 = 0;
+  let n01 = 0;
+  let n10 = 0;
+  let n11 = 0;
+  let s00 = 0;
+  let s01 = 0;
+  let s10 = 0;
+  let s11 = 0;
+  for (let i = 0; i < y.length; i += 1) {
+    if (a[i] === 1 && b[i] === 1) {
+      n11 += 1;
+      s11 += y[i];
+    } else if (a[i] === 1) {
+      n10 += 1;
+      s10 += y[i];
+    } else if (b[i] === 1) {
+      n01 += 1;
+      s01 += y[i];
+    } else {
+      n00 += 1;
+      s00 += y[i];
+    }
+  }
+  const p00 = s00 / n00;
+  const p01 = s01 / n01;
+  const p10 = s10 / n10;
+  const p11 = s11 / n11;
+  const effect = p11 - p10 - p01 + p00;
+  const se = Math.sqrt(
+    p00 * (1 - p00) / n00 +
