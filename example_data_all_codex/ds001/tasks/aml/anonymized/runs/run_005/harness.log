+  let offset = meta[9];
+  const values = [];
+  while (values.length < total) {
+    const reader = new CompactReader(buf, offset);
+    const pageHeader = convertThrift(reader.readStruct());
+    let pageBody = buf.subarray(reader.pos, reader.pos + pageHeader[3]);
+    if (codec === 1) pageBody = snappyUncompress(pageBody);
+    if (pageHeader[1] !== 0) throw new Error(`Unsupported page type ${pageHeader[1]}`);
