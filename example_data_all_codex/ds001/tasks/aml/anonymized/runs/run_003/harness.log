import pandas as pd
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.value_counts())
print('outcome unique/counts')
print(df['objective_response'].value_counts(dropna=False).sort_index())
print('outcome mean', df['objective_response'].mean())
print('missing total', df.isna().sum().sum())
summary = []
for c in df.columns:
    if c == 'objective_response':
        continue
    s = df[c]
    summary.append((c, str(s.dtype), s.nunique(), s.min(), s.max(), s.mean() if pd.api.types.is_numeric_dtype(s) else None, s.value_counts().head(5).to_dict()))
for row in summary[:80]:
    print(row)
