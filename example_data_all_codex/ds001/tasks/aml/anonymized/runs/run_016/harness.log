+      proposed.push(hyp(id, `The joint presence of ${r.aVar.interactionHighText} and ${r.bVar.interactionHighText} has a ${dir} association with mean \`${outcome}\` than expected from adding their separate associations.`, kind));
+      const c = r.cells;
+      analyses.push(analysis(
+        [id],
+        `Cell response rates were both low/absent: ${pct(c['00'].p)} (n=${c['00'].n}), ${r.aVar.interactionHighText} only: ${pct(c['10'].p)} (n=${c['10'].n}), ${r.bVar.interactionHighText} only: ${pct(c['01'].p)} (n=${c['01'].n}), and both high/present: ${pct(c['11'].p)} (n=${c['11'].n}); difference-in-differences ${fmt(r.did)}, z-test p=${fmt(r.pValue)}, BH q=${fmt(r.qValue)}.`,
+        r.pValue,
+        r.did,
+        `Four-cell difference-in-differences test for ${r.a} x ${r.b} on objective_response.`
+      ));
+    }
+    iterations.push({ index, proposed_hypotheses: proposed, analyses });
+  }
+
+  addInteractionIteration(6, posInteractions.slice(0, 2));
+  addInteractionIteration(7, negInteractions.slice(0, 2));
+  addInteractionIteration(8, posInteractions.slice(2, 4), 'refined');
+  addInteractionIteration(9, negInteractions.slice(2, 4), 'refined');
+  addInteractionIteration(10, sortedInteractions.slice(8, 10), 'refined');
+
+  function addSubgroupIteration(index, feature, modifier) {
+    const featureVar = typeof feature === 'string' ? varByFeature[feature] : feature;
+    const modifierVar = typeof modifier === 'string' ? varByFeature[modifier] : modifier;
