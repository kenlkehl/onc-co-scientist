+  const sigMain = mainEffects.filter((r) => r.pValue < 0.05).length;
+  const sigMainFdr = mainEffects.filter((r) => r.qValue < 0.05).length;
+  const sigInter = pairwise.filter((r) => r.pValue < 0.05).length;
+  const sigInterFdr = pairwise.filter((r) => r.qValue < 0.05).length;
+
+  const summary = [
+    `Dataset ds001_aml contained ${numRows} patients, ${features.length} binary feature columns, and the binary outcome objective_response. The overall response rate was ${pct(responseRate)}.`,
+    '',
+    `Across 25 iterations, I first screened single-feature associations with objective_response using two-proportion z-tests. ${sigMain} of ${features.length} features had nominal p<0.05, and ${sigMainFdr} remained significant after Benjamini-Hochberg correction. The strongest single-feature signals were:`,
