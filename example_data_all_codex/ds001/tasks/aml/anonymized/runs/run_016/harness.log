+  const did = cells['11'].p - cells['10'].p - cells['01'].p + cells['00'].p;
+  const se = Math.sqrt(Object.values(cells).reduce((acc, c) => acc + c.p * (1 - c.p) / c.n, 0));
+  const zScore = se > 0 ? did / se : 0;
+  return { a, b, cells, did, z: zScore, pValue: twoSidedP(zScore) };
+}
+
+function tripleInteractionEffect(data, a, b, c, outcome) {
+  const xa = data[a], xb = data[b], xc = data[c], y = data[outcome];
+  const cells = {};
+  for (const ia of [0, 1]) for (const ib of [0, 1]) for (const ic of [0, 1]) cells[`${ia}${ib}${ic}`] = { n: 0, y: 0 };
+  for (let i = 0; i < y.length; i++) {
+    cells[`${xa[i]}${xb[i]}${xc[i]}`].n++;
+    cells[`${xa[i]}${xb[i]}${xc[i]}`].y += y[i];
+  }
+  for (const cell of Object.values(cells)) cell.p = cell.y / cell.n;
+  const effect =
+    cells['111'].p - cells['110'].p - cells['101'].p - cells['011'].p +
+    cells['100'].p + cells['010'].p + cells['001'].p - cells['000'].p;
