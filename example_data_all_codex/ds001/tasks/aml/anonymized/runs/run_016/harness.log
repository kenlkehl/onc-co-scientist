+  const topMainLines = sortedMain.slice(0, 12).map((r, i) =>
+    `${i + 1}. ${r.feature}: ${r.variable.highText} vs ${r.variable.lowText}, risk difference ${fmt(r.diff)} (${pct(r.p1)} vs ${pct(r.p0)}), p=${fmt(r.pValue)}, q=${fmt(r.qValue)}`
+  );
+  const topInteractionLines = sortedInteractions.slice(0, 10).map((r, i) =>
+    `${i + 1}. ${r.a} x ${r.b}: high/present group DID ${fmt(r.did)}, p=${fmt(r.pValue)}, q=${fmt(r.qValue)}`
