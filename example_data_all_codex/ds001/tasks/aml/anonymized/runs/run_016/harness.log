+    .filter((r) => r.a === leadMain || r.b === leadMain)
+    .slice(0, 3)
+    .map((r) => (r.a === leadMain ? r.b : r.a));
+  addSubgroupIteration(21, leadMain, modifiersForLead[0] || sortedMain[1].feature);
+  addSubgroupIteration(22, leadMain, modifiersForLead[1] || sortedMain[2].feature);
