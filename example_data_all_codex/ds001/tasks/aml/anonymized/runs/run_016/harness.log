+const fs = require('fs');
+const zlib = require('zlib');
+
+const CWD = process.cwd();
+const DATASET = 'dataset.parquet';
+
+const TType = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      result |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  binary() {
+    const len = Number(this.varint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out.toString('utf8');
+  }
+
+  value(type) {
+    switch (type) {
+      case TType.TRUE:
+        return true;
+      case TType.FALSE:
+        return false;
+      case TType.BYTE: {
+        const b = this.byte();
+        return b > 127 ? b - 256 : b;
+      }
+      case TType.I16:
+      case TType.I32:
+      case TType.I64:
+        return this.zigzag();
+      case TType.DOUBLE: {
+        const v = this.buf.readDoubleLE(this.pos);
+        this.pos += 8;
+        return v;
+      }
+      case TType.BINARY:
+        return this.binary();
+      case TType.LIST:
+      case TType.SET:
+        return this.list();
+      case TType.MAP:
+        return this.map();
+      case TType.STRUCT:
+        return this.struct();
+      default:
+        throw new Error(`Unsupported compact thrift type ${type} at ${this.pos}`);
+    }
+  }
+
+  list() {
+    const header = this.byte();
+    let size = header >> 4;
+    const elemType = header & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    const out = [];
+    for (let i = 0; i < size; i++) out.push(this.value(elemType));
+    return out;
+  }
+
+  map() {
+    const size = Number(this.varint());
+    if (size === 0) return [];
+    const types = this.byte();
+    const keyType = types >> 4;
+    const valType = types & 0x0f;
+    const out = [];
+    for (let i = 0; i < size; i++) out.push([this.value(keyType), this.value(valType)]);
+    return out;
+  }
+
+  struct() {
+    const out = {};
+    let lastField = 0;
+    while (true) {
+      const header = this.byte();
+      const type = header & 0x0f;
+      if (type === TType.STOP) break;
+      const delta = header >> 4;
+      const fieldId = delta === 0 ? this.zigzag() : lastField + delta;
+      lastField = fieldId;
+      out[fieldId] = type === TType.TRUE ? true : type === TType.FALSE ? false : this.value(type);
+    }
+    return out;
+  }
+}
+
+function parseFooter(buf) {
+  if (buf.slice(0, 4).toString('ascii') !== 'PAR1' || buf.slice(buf.length - 4).toString('ascii') !== 'PAR1') {
+    throw new Error('Not a Parquet file');
+  }
+  const footerLen = buf.readInt32LE(buf.length - 8);
+  const footerStart = buf.length - 8 - footerLen;
+  const reader = new CompactReader(buf, footerStart);
+  return reader.struct();
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[pos++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
+        const bytes = literalLen - 59;
+        literalLen = 1;
+        let n = 0;
+        for (let i = 0; i < bytes; i++) n |= input[pos++] << (8 * i);
+        literalLen += n;
+      }
+      input.copy(out, outPos, pos, pos + literalLen);
+      pos += literalLen;
+      outPos += literalLen;
+    } else {
+      let copyLen;
+      let offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < copyLen; i++) {
+        out[outPos] = out[outPos - offset];
+        outPos++;
+      }
+    }
+  }
+  if (outPos !== len) throw new Error(`Snappy length mismatch ${outPos} != ${len}`);
+  return out;
+}
+
+function decompress(buf, codec, expectedSize) {
+  if (codec === 0) return buf;
+  if (codec === 1) {
+    const out = snappyUncompress(buf);
+    if (expectedSize != null && out.length !== expectedSize) {
+      throw new Error(`Snappy output length ${out.length} did not match expected ${expectedSize}`);
+    }
+    return out;
+  }
+  if (codec === 2) return zlib.gunzipSync(buf);
+  if (codec === 4) return zlib.brotliDecompressSync(buf);
+  throw new Error(`Unsupported Parquet compression codec ${codec}`);
+}
+
+function uvarintAt(buf, pos) {
+  let shift = 0;
+  let result = 0;
+  let p = pos;
+  while (true) {
+    const b = buf[p++];
+    result += (b & 0x7f) * Math.pow(2, shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: result, pos: p };
+}
+
+function readUnsignedLE(buf, pos, bytes) {
+  let v = 0;
+  for (let i = 0; i < bytes; i++) v += buf[pos + i] * Math.pow(2, 8 * i);
+  return v;
+}
+
+function bitWidth(maxValue) {
+  if (maxValue <= 0) return 0;
+  return Math.ceil(Math.log2(maxValue + 1));
+}
+
+function bitPackedValue(buf, bitOffset, width) {
+  let v = 0;
+  for (let b = 0; b < width; b++) {
+    const bit = (buf[(bitOffset + b) >> 3] >> ((bitOffset + b) & 7)) & 1;
+    v |= bit << b;
+  }
+  return v;
+}
+
+function decodeRleBitPacked(buf, width, count, pos = 0, byteLength = null) {
+  const end = byteLength == null ? buf.length : pos + byteLength;
+  const values = [];
+  while (values.length < count && pos < end) {
+    const header = uvarintAt(buf, pos);
+    pos = header.pos;
+    if ((header.value & 1) === 0) {
+      const runLength = header.value >> 1;
+      const bytes = Math.ceil(width / 8);
+      const value = width === 0 ? 0 : readUnsignedLE(buf, pos, bytes);
+      pos += bytes;
+      const needed = Math.min(runLength, count - values.length);
+      for (let i = 0; i < needed; i++) values.push(value);
+    } else {
+      const groups = header.value >> 1;
+      const runLength = groups * 8;
+      const bytes = Math.ceil((runLength * width) / 8);
+      const needed = Math.min(runLength, count - values.length);
+      for (let i = 0; i < needed; i++) values.push(width === 0 ? 0 : bitPackedValue(buf, pos * 8 + i * width, width));
+      pos += bytes;
+    }
+  }
+  if (values.length !== count) throw new Error(`Decoded ${values.length} RLE values, expected ${count}`);
+  return { values, pos };
+}
+
+function decodePlain(buf, type, count, typeLength = null, pos = 0) {
+  const values = [];
+  if (type === 0) {
+    for (let i = 0; i < count; i++) values.push((buf[pos + (i >> 3)] >> (i & 7)) & 1);
+    return values;
+  }
+  for (let i = 0; i < count; i++) {
+    if (type === 1) {
+      values.push(buf.readInt32LE(pos));
+      pos += 4;
+    } else if (type === 2) {
+      values.push(Number(buf.readBigInt64LE(pos)));
+      pos += 8;
+    } else if (type === 4) {
+      values.push(buf.readFloatLE(pos));
+      pos += 4;
+    } else if (type === 5) {
+      values.push(buf.readDoubleLE(pos));
+      pos += 8;
+    } else if (type === 6) {
+      const len = buf.readInt32LE(pos);
+      pos += 4;
+      values.push(buf.slice(pos, pos + len).toString('utf8'));
+      pos += len;
+    } else if (type === 7) {
+      values.push(buf.slice(pos, pos + typeLength));
+      pos += typeLength;
+    } else {
+      throw new Error(`Unsupported plain Parquet type ${type}`);
+    }
+  }
+  return values;
+}
+
+function maxDefinitionLevels(schema) {
+  const out = {};
+  for (let i = 1; i < schema.length; i++) {
+    const el = schema[i];
+    if (el[1] == null) continue;
+    const name = el[4];
+    const repetition = el[3] == null ? 0 : el[3];
+    out[name] = repetition === 1 ? 1 : 0;
+  }
+  return out;
+}
+
+function readColumn(buf, chunk, schemaByName, maxDefByName) {
+  const meta = chunk[3];
+  const parquetType = meta[1];
+  const codec = meta[4] == null ? 0 : meta[4];
+  const numValues = meta[5];
+  const totalCompressed = meta[7];
+  const dataPageOffset = meta[9];
+  const dictPageOffset = meta[11];
+  const path = meta[3];
+  const name = path[path.length - 1];
+  const typeLength = schemaByName[name][2] == null ? null : schemaByName[name][2];
+  const maxDef = maxDefByName[name] || 0;
+  const start = dictPageOffset != null ? dictPageOffset : dataPageOffset;
+  const end = start + totalCompressed;
+  let pos = start;
+  let dictionary = null;
+  const values = [];
+  while (values.length < numValues && pos < end) {
+    const reader = new CompactReader(buf, pos);
+    const header = reader.struct();
+    pos = reader.pos;
+    const pageType = header[1];
+    const uncompressedSize = header[2];
+    const compressedSize = header[3];
+    const bodyCompressed = buf.slice(pos, pos + compressedSize);
+    pos += compressedSize;
+
+    if (pageType === 2) {
+      const dictHeader = header[7];
+      const dictValues = dictHeader[1];
+      const dictBody = decompress(bodyCompressed, codec, uncompressedSize);
+      dictionary = decodePlain(dictBody, parquetType, dictValues, typeLength);
+      continue;
+    }
+
+    if (pageType === 0) {
+      const dph = header[5];
+      const pageValues = dph[1];
+      const encoding = dph[2];
+      const defEncoding = dph[3];
+      const body = decompress(bodyCompressed, codec, uncompressedSize);
+      let offset = 0;
+      let levels = null;
+      if (maxDef > 0) {
+        const width = bitWidth(maxDef);
+        if (defEncoding !== 3) throw new Error(`Unsupported definition level encoding ${defEncoding}`);
+        const levelBytes = body.readInt32LE(offset);
+        offset += 4;
+        const decoded = decodeRleBitPacked(body, width, pageValues, offset, levelBytes);
+        levels = decoded.values;
+        offset += levelBytes;
+      } else {
+        levels = new Array(pageValues).fill(0);
+      }
+      const nonNull = levels.filter((v) => v === maxDef).length;
+      let decodedValues;
+      if (encoding === 2 || encoding === 8) {
+        if (!dictionary) throw new Error(`Dictionary data page before dictionary for ${name}`);
+        const width = body[offset++];
+        const indexes = decodeRleBitPacked(body, width, nonNull, offset).values;
+        decodedValues = indexes.map((idx) => dictionary[idx]);
+      } else if (encoding === 0) {
+        decodedValues = decodePlain(body.slice(offset), parquetType, nonNull, typeLength);
+      } else {
+        throw new Error(`Unsupported data page encoding ${encoding} for ${name}`);
+      }
+      let vi = 0;
+      for (const level of levels) values.push(level === maxDef ? decodedValues[vi++] : null);
+      continue;
+    }
+
+    if (pageType === 3) {
+      const dph = header[8];
+      const pageValues = dph[1];
+      const numNulls = dph[2] || 0;
+      const encoding = dph[4];
+      const defLen = dph[5] || 0;
+      const repLen = dph[6] || 0;
+      const isCompressed = dph[7] == null ? true : dph[7];
+      let offset = repLen;
+      let levels = new Array(pageValues).fill(maxDef);
+      if (maxDef > 0) {
+        const decoded = decodeRleBitPacked(bodyCompressed, bitWidth(maxDef), pageValues, offset, defLen);
+        levels = decoded.values;
+      }
+      offset += defLen;
+      let valueBody = bodyCompressed.slice(offset);
+      if (isCompressed && codec !== 0) valueBody = decompress(valueBody, codec, null);
+      const nonNull = pageValues - numNulls;
+      let decodedValues;
+      if (encoding === 2 || encoding === 8) {
+        if (!dictionary) throw new Error(`Dictionary data page before dictionary for ${name}`);
+        const width = valueBody[0];
+        const indexes = decodeRleBitPacked(valueBody, width, nonNull, 1).values;
+        decodedValues = indexes.map((idx) => dictionary[idx]);
+      } else if (encoding === 0) {
+        decodedValues = decodePlain(valueBody, parquetType, nonNull, typeLength);
+      } else {
+        throw new Error(`Unsupported V2 data page encoding ${encoding} for ${name}`);
+      }
+      let vi = 0;
+      for (const level of levels) values.push(level === maxDef ? decodedValues[vi++] : null);
+      continue;
+    }
+  }
+  if (values.length !== numValues) throw new Error(`Column ${name} length ${values.length}, expected ${numValues}`);
+  return values;
+}
+
+function readParquet(path) {
+  const buf = fs.readFileSync(path);
+  const footer = parseFooter(buf);
+  const schema = footer[2];
+  const schemaByName = {};
+  for (const el of schema) {
+    if (el[4]) schemaByName[el[4]] = el;
+  }
+  const maxDefByName = maxDefinitionLevels(schema);
+  const rowGroup = footer[4][0];
+  const columns = rowGroup[1];
+  const data = {};
+  for (const chunk of columns) {
+    const meta = chunk[3];
+    const pathInSchema = meta[3];
+    const name = pathInSchema[pathInSchema.length - 1];
+    data[name] = readColumn(buf, chunk, schemaByName, maxDefByName);
+  }
+  return { data, schema, numRows: footer[3] };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedP(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function propTest(n1, y1, n0, y0) {
+  const p1 = y1 / n1;
+  const p0 = y0 / n0;
+  const diff = p1 - p0;
+  const p = (y1 + y0) / (n1 + n0);
+  const se = Math.sqrt(p * (1 - p) * (1 / n1 + 1 / n0));
+  const z = se > 0 ? diff / se : 0;
+  return { n1, y1, p1, n0, y0, p0, diff, z, pValue: twoSidedP(z) };
+}
+
+function featureEffect(data, feature, outcome) {
+  const x = data[feature];
+  const y = data[outcome];
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (x[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  return propTest(n1, y1, n0, y0);
+}
+
+function subgroupEffect(data, feature, modifier, modifierValue, outcome) {
+  const x = data[feature], m = data[modifier], y = data[outcome];
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (m[i] !== modifierValue) continue;
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (x[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  return propTest(n1, y1, n0, y0);
+}
+
+function interactionEffect(data, a, b, outcome) {
+  const x = data[a], z = data[b], y = data[outcome];
+  const cells = {
+    '00': { n: 0, y: 0 },
+    '01': { n: 0, y: 0 },
+    '10': { n: 0, y: 0 },
+    '11': { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${x[i]}${z[i]}`;
+    cells[key].n++;
+    cells[key].y += y[i];
+  }
+  for (const c of Object.values(cells)) c.p = c.y / c.n;
+  const did = cells['11'].p - cells['10'].p - cells['01'].p + cells['00'].p;
+  const se = Math.sqrt(Object.values(cells).reduce((acc, c) => acc + c.p * (1 - c.p) / c.n, 0));
+  const zScore = se > 0 ? did / se : 0;
+  return { a, b, cells, did, z: zScore, pValue: twoSidedP(zScore) };
+}
+
+function tripleInteractionEffect(data, a, b, c, outcome) {
+  const xa = data[a], xb = data[b], xc = data[c], y = data[outcome];
+  const cells = {};
+  for (const ia of [0, 1]) for (const ib of [0, 1]) for (const ic of [0, 1]) cells[`${ia}${ib}${ic}`] = { n: 0, y: 0 };
+  for (let i = 0; i < y.length; i++) {
+    cells[`${xa[i]}${xb[i]}${xc[i]}`].n++;
+    cells[`${xa[i]}${xb[i]}${xc[i]}`].y += y[i];
+  }
+  for (const cell of Object.values(cells)) cell.p = cell.y / cell.n;
+  const effect =
+    cells['111'].p - cells['110'].p - cells['101'].p - cells['011'].p +
+    cells['100'].p + cells['010'].p + cells['001'].p - cells['000'].p;
+  const se = Math.sqrt(Object.values(cells).reduce((acc, cell) => acc + cell.p * (1 - cell.p) / cell.n, 0));
+  const z = se > 0 ? effect / se : 0;
+  return { a, b, c, cells, effect, z, pValue: twoSidedP(z) };
+}
+
+function bhAdjust(items, pField = 'pValue') {
+  const sorted = [...items].sort((a, b) => a[pField] - b[pField]);
+  let minQ = 1;
+  for (let i = sorted.length - 1; i >= 0; i--) {
+    const q = Math.min(minQ, sorted[i][pField] * sorted.length / (i + 1));
+    sorted[i].qValue = q;
+    minQ = q;
+  }
+  return items;
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) > 0 && Math.abs(x) < 0.0001) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function pct(x) {
+  return `${(100 * x).toFixed(2)}%`;
+}
+
+function hyp(id, text, kind = 'novel') {
+  return { id, text, kind };
+}
+
+function analysis(hypothesisIds, resultSummary, pValue, effectEstimate, code = null) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: resultSummary,
+    p_value: pValue,
+    effect_estimate: effectEstimate,
+    significant: pValue < 0.05,
+  };
+}
+
+function main() {
+  const { data, numRows } = readParquet(DATASET);
+  const outcome = 'objective_response';
+  const features = Object.keys(data).filter((c) => c !== outcome);
+  const y = data[outcome];
+  const responseRate = y.reduce((a, b) => a + b, 0) / y.length;
+
+  const invalid = features.filter((f) => !data[f].every((v) => v === 0 || v === 1));
+  if (invalid.length > 0 || !y.every((v) => v === 0 || v === 1)) {
+    throw new Error(`This analysis expected binary features/outcome. Non-binary features: ${invalid.join(', ')}`);
+  }
+
+  const mainEffects = bhAdjust(features.map((f) => ({ feature: f, ...featureEffect(data, f, outcome) })));
+  const sortedMain = [...mainEffects].sort((a, b) => a.pValue - b.pValue);
+  const positives = [...mainEffects].filter((r) => r.diff > 0).sort((a, b) => a.pValue - b.pValue);
+  const negatives = [...mainEffects].filter((r) => r.diff < 0).sort((a, b) => a.pValue - b.pValue);
+
+  const pairwise = [];
+  for (let i = 0; i < features.length; i++) {
+    for (let j = i + 1; j < features.length; j++) {
+      const r = interactionEffect(data, features[i], features[j], outcome);
+      const minCell = Math.min(...Object.values(r.cells).map((c) => c.n));
+      if (minCell >= 100) pairwise.push({ ...r, minCell });
+    }
+  }
+  bhAdjust(pairwise);
+  const sortedInteractions = [...pairwise].sort((a, b) => a.pValue - b.pValue);
+  const posInteractions = [...pairwise].filter((r) => r.did > 0).sort((a, b) => a.pValue - b.pValue);
+  const negInteractions = [...pairwise].filter((r) => r.did < 0).sort((a, b) => a.pValue - b.pValue);
+
+  const topForTriples = sortedMain.slice(0, 12).map((r) => r.feature);
+  const triples = [];
+  for (let i = 0; i < topForTriples.length; i++) {
