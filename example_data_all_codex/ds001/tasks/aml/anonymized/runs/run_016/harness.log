+  const interactionLeads = sortedInteractions.slice(0, 6);
+  addSubgroupIteration(11, interactionLeads[0].a, interactionLeads[0].b);
+  addSubgroupIteration(12, interactionLeads[1].a, interactionLeads[1].b);
+  addSubgroupIteration(13, interactionLeads[2].a, interactionLeads[2].b);
+  addSubgroupIteration(14, interactionLeads[3].a, interactionLeads[3].b);
+
+  function addTripleIteration(index, records) {
+    const proposed = [];
+    const analyses = [];
+    for (const r of records) {
+      const id = nextHypId();
+      proposed.push(hyp(id, `The three-way combination \`${r.a}\`, \`${r.b}\`, and \`${r.c}\` changes mean \`${outcome}\` beyond the lower-order two-feature patterns.`, 'refined'));
+      analyses.push(analysis(
+        [id],
+        `Eight-cell three-way difference-in-differences estimate was ${fmt(r.effect)} with minimum cell n=${r.minCell}; z-test p=${fmt(r.pValue)}, BH q=${fmt(r.qValue)}.`,
+        r.pValue,
+        r.effect,
+        `Three-way difference-in-differences test for ${r.a} x ${r.b} x ${r.c}.`
+      ));
+    }
+    iterations.push({ index, proposed_hypotheses: proposed, analyses });
+  }
+
+  addTripleIteration(15, sortedTriples.slice(0, 2));
+  addTripleIteration(16, sortedTriples.slice(2, 4));
+
+  addMainIteration(17, sortedMain.slice(8, 10), 'feature=1 minus feature=0');
+  addMainIteration(18, sortedMain.slice(10, 12), 'feature=1 minus feature=0');
+  addInteractionIteration(19, sortedInteractions.slice(10, 12), 'refined');
+  addInteractionIteration(20, sortedInteractions.slice(12, 14), 'refined');
+
+  const leadMain = sortedMain[0].feature;
+  const modifiersForLead = sortedInteractions
+    .filter((r) => r.a === leadMain || r.b === leadMain)
