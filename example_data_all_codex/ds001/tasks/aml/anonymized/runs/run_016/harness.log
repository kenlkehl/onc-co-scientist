+    const h1 = nextHypId();
+    const h2 = nextHypId();
+    const proposed = [
+      hyp(h0, `Among patients with ${modifierVar.interactionLowText}, patients with ${featureVar.interactionHighText} have ${eff0.diff >= 0 ? 'higher' : 'lower'} mean \`${outcome}\` than patients with ${featureVar.interactionLowText}.`, 'refined'),
+      hyp(h1, `Among patients with ${modifierVar.interactionHighText}, patients with ${featureVar.interactionHighText} have ${eff1.diff >= 0 ? 'higher' : 'lower'} mean \`${outcome}\` than patients with ${featureVar.interactionLowText}.`, 'refined'),
+      hyp(h2, `The association between ${featureVar.interactionHighText} and mean \`${outcome}\` differs between the ${modifierVar.interactionHighText} and ${modifierVar.interactionLowText} subgroups.`, 'refined'),
