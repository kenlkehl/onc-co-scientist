+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
