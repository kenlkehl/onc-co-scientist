+  }
+  const maxDefByName = maxDefinitionLevels(schema);
+  const rowGroup = footer[4][0];
+  const columns = rowGroup[1];
+  const data = {};
+  for (const chunk of columns) {
+    const meta = chunk[3];
+    const pathInSchema = meta[3];
+    const name = pathInSchema[pathInSchema.length - 1];
