+    '11': { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const xv = x[i], zv = z[i];
+    if ((xv !== 0 && xv !== 1) || (zv !== 0 && zv !== 1)) continue;
+    const key = `${xv}${zv}`;
+    cells[key].n++;
+    cells[key].y += y[i];
+  }
+  for (const c of Object.values(cells)) c.p = c.y / c.n;
+  const did = cells['11'].p - cells['10'].p - cells['01'].p + cells['00'].p;
+  const se = Math.sqrt(Object.values(cells).reduce((acc, c) => acc + c.p * (1 - c.p) / c.n, 0));
+  const zScore = se > 0 ? did / se : 0;
+  return { a: aVar.feature, b: bVar.feature, aVar, bVar, cells, did, z: zScore, pValue: twoSidedP(zScore) };
+}
+
+function tripleInteractionEffectVar(aVar, bVar, cVar, y) {
+  const xa = aVar.interactionGroup, xb = bVar.interactionGroup, xc = cVar.interactionGroup;
+  const cells = {};
+  for (const ia of [0, 1]) for (const ib of [0, 1]) for (const ic of [0, 1]) cells[`${ia}${ib}${ic}`] = { n: 0, y: 0 };
+  for (let i = 0; i < y.length; i++) {
+    const av = xa[i], bv = xb[i], cv = xc[i];
+    if ((av !== 0 && av !== 1) || (bv !== 0 && bv !== 1) || (cv !== 0 && cv !== 1)) continue;
+    cells[`${av}${bv}${cv}`].n++;
+    cells[`${av}${bv}${cv}`].y += y[i];
+  }
+  for (const cell of Object.values(cells)) cell.p = cell.y / cell.n;
+  const effect =
+    cells['111'].p - cells['110'].p - cells['101'].p - cells['011'].p +
+    cells['100'].p + cells['010'].p + cells['001'].p - cells['000'].p;
+  const se = Math.sqrt(Object.values(cells).reduce((acc, cell) => acc + cell.p * (1 - cell.p) / cell.n, 0));
+  const z = se > 0 ? effect / se : 0;
+  return { a: aVar.feature, b: bVar.feature, c: cVar.feature, aVar, bVar, cVar, cells, effect, z, pValue: twoSidedP(z) };
+}
+
+function featureEffect(data, feature, outcome) {
+  const x = data[feature];
+  const y = data[outcome];
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (x[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  return propTest(n1, y1, n0, y0);
+}
+
+function subgroupEffect(data, feature, modifier, modifierValue, outcome) {
+  const x = data[feature], m = data[modifier], y = data[outcome];
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (m[i] !== modifierValue) continue;
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (x[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  return propTest(n1, y1, n0, y0);
+}
+
+function interactionEffect(data, a, b, outcome) {
+  const x = data[a], z = data[b], y = data[outcome];
+  const cells = {
+    '00': { n: 0, y: 0 },
+    '01': { n: 0, y: 0 },
+    '10': { n: 0, y: 0 },
+    '11': { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${x[i]}${z[i]}`;
+    cells[key].n++;
+    cells[key].y += y[i];
+  }
+  for (const c of Object.values(cells)) c.p = c.y / c.n;
+  const did = cells['11'].p - cells['10'].p - cells['01'].p + cells['00'].p;
+  const se = Math.sqrt(Object.values(cells).reduce((acc, c) => acc + c.p * (1 - c.p) / c.n, 0));
+  const zScore = se > 0 ? did / se : 0;
+  return { a, b, cells, did, z: zScore, pValue: twoSidedP(zScore) };
+}
+
+function tripleInteractionEffect(data, a, b, c, outcome) {
+  const xa = data[a], xb = data[b], xc = data[c], y = data[outcome];
+  const cells = {};
+  for (const ia of [0, 1]) for (const ib of [0, 1]) for (const ic of [0, 1]) cells[`${ia}${ib}${ic}`] = { n: 0, y: 0 };
+  for (let i = 0; i < y.length; i++) {
+    cells[`${xa[i]}${xb[i]}${xc[i]}`].n++;
+    cells[`${xa[i]}${xb[i]}${xc[i]}`].y += y[i];
+  }
+  for (const cell of Object.values(cells)) cell.p = cell.y / cell.n;
+  const effect =
+    cells['111'].p - cells['110'].p - cells['101'].p - cells['011'].p +
+    cells['100'].p + cells['010'].p + cells['001'].p - cells['000'].p;
+  const se = Math.sqrt(Object.values(cells).reduce((acc, cell) => acc + cell.p * (1 - cell.p) / cell.n, 0));
+  const z = se > 0 ? effect / se : 0;
+  return { a, b, c, cells, effect, z, pValue: twoSidedP(z) };
+}
+
+function bhAdjust(items, pField = 'pValue') {
+  const sorted = [...items].sort((a, b) => a[pField] - b[pField]);
+  let minQ = 1;
+  for (let i = sorted.length - 1; i >= 0; i--) {
+    const q = Math.min(minQ, sorted[i][pField] * sorted.length / (i + 1));
+    sorted[i].qValue = q;
+    minQ = q;
+  }
+  return items;
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) > 0 && Math.abs(x) < 0.0001) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function pct(x) {
+  return `${(100 * x).toFixed(2)}%`;
+}
+
+function hyp(id, text, kind = 'novel') {
+  return { id, text, kind };
+}
+
+function analysis(hypothesisIds, resultSummary, pValue, effectEstimate, code = null) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: resultSummary,
+    p_value: pValue,
+    effect_estimate: effectEstimate,
+    significant: pValue < 0.05,
+  };
+}
+
+function main() {
+  const { data, numRows } = readParquet(DATASET);
+  const outcome = 'objective_response';
+  const features = Object.keys(data).filter((c) => c !== outcome && c !== 'patient_id');
+  const y = data[outcome];
+  const responseRate = y.reduce((a, b) => a + b, 0) / y.length;
+
+  if (!y.every((v) => v === 0 || v === 1)) {
+    throw new Error('This analysis expected binary objective_response.');
+  }
+
+  const variables = features.map((f) => makeAnalysisVariable(f, data[f]));
+  const varByFeature = Object.fromEntries(variables.map((v) => [v.feature, v]));
+  const mainEffects = bhAdjust(variables.map((v) => ({ feature: v.feature, variable: v, ...contrastEffect(v.mainGroup, y) })));
+  const sortedMain = [...mainEffects].sort((a, b) => a.pValue - b.pValue);
+  const positives = [...mainEffects].filter((r) => r.diff > 0).sort((a, b) => a.pValue - b.pValue);
+  const negatives = [...mainEffects].filter((r) => r.diff < 0).sort((a, b) => a.pValue - b.pValue);
+
+  const pairwise = [];
+  for (let i = 0; i < variables.length; i++) {
+    for (let j = i + 1; j < variables.length; j++) {
+      const r = interactionEffectVar(variables[i], variables[j], y);
+      const minCell = Math.min(...Object.values(r.cells).map((c) => c.n));
+      if (minCell >= 100) pairwise.push({ ...r, minCell });
+    }
+  }
+  bhAdjust(pairwise);
+  const sortedInteractions = [...pairwise].sort((a, b) => a.pValue - b.pValue);
+  const posInteractions = [...pairwise].filter((r) => r.did > 0).sort((a, b) => a.pValue - b.pValue);
+  const negInteractions = [...pairwise].filter((r) => r.did < 0).sort((a, b) => a.pValue - b.pValue);
+
+  const topForTriples = sortedMain.slice(0, 12).map((r) => r.variable);
+  const triples = [];
+  for (let i = 0; i < topForTriples.length; i++) {
+    for (let j = i + 1; j < topForTriples.length; j++) {
+      for (let k = j + 1; k < topForTriples.length; k++) {
+        const r = tripleInteractionEffectVar(topForTriples[i], topForTriples[j], topForTriples[k], y);
+        const minCell = Math.min(...Object.values(r.cells).map((cell) => cell.n));
+        if (minCell >= 50) triples.push({ ...r, minCell });
+      }
+    }
+  }
+  bhAdjust(triples);
+  const sortedTriples = [...triples].sort((a, b) => a.pValue - b.pValue);
+
+  const iterations = [];
+  let nextId = 1;
+  const nextHypId = () => `h${nextId++}`;
+
+  function addMainIteration(index, records, directionLabel) {
+    const proposed = [];
+    const analyses = [];
+    for (const r of records) {
+      const id = nextHypId();
+      const dir = r.diff > 0 ? 'higher' : 'lower';
+      proposed.push(hyp(id, `Patients with \`${r.feature}=1\` have ${dir} mean \`${outcome}\` than patients with \`${r.feature}=0\`.`));
+      analyses.push(analysis(
+        [id],
+        `Response was ${pct(r.p1)} for ${r.feature}=1 (n=${r.n1}) versus ${pct(r.p0)} for ${r.feature}=0 (n=${r.n0}); risk difference ${fmt(r.diff)} (${directionLabel}), two-proportion z-test p=${fmt(r.pValue)}, BH q=${fmt(r.qValue)}.`,
+        r.pValue,
+        r.diff,
+        `Two-proportion z-test comparing objective_response by ${r.feature}.`
+      ));
+    }
+    iterations.push({ index, proposed_hypotheses: proposed, analyses });
+  }
+
+  addMainIteration(1, positives.slice(0, 2), 'feature=1 minus feature=0');
+  addMainIteration(2, negatives.slice(0, 2), 'feature=1 minus feature=0');
+  addMainIteration(3, positives.slice(2, 4), 'feature=1 minus feature=0');
+  addMainIteration(4, negatives.slice(2, 4), 'feature=1 minus feature=0');
+
+  const weak = [...mainEffects].sort((a, b) => Math.abs(a.diff) - Math.abs(b.diff)).slice(0, 2);
+  addMainIteration(5, weak, 'feature=1 minus feature=0');
+
+  function addInteractionIteration(index, records, kind = 'novel') {
+    const proposed = [];
+    const analyses = [];
+    for (const r of records) {
+      const id = nextHypId();
+      const dir = r.did > 0 ? 'more positive' : 'more negative';
+      proposed.push(hyp(id, `The joint presence of \`${r.a}=1\` and \`${r.b}=1\` has a ${dir} association with mean \`${outcome}\` than expected from adding their separate associations.`, kind));
+      const c = r.cells;
+      analyses.push(analysis(
+        [id],
+        `Cell response rates were ${r.a}=0/${r.b}=0: ${pct(c['00'].p)} (n=${c['00'].n}), ${r.a}=1/${r.b}=0: ${pct(c['10'].p)} (n=${c['10'].n}), ${r.a}=0/${r.b}=1: ${pct(c['01'].p)} (n=${c['01'].n}), and both=1: ${pct(c['11'].p)} (n=${c['11'].n}); difference-in-differences ${fmt(r.did)}, z-test p=${fmt(r.pValue)}, BH q=${fmt(r.qValue)}.`,
+        r.pValue,
+        r.did,
+        `Four-cell difference-in-differences test for ${r.a} x ${r.b} on objective_response.`
+      ));
+    }
+    iterations.push({ index, proposed_hypotheses: proposed, analyses });
+  }
+
+  addInteractionIteration(6, posInteractions.slice(0, 2));
+  addInteractionIteration(7, negInteractions.slice(0, 2));
+  addInteractionIteration(8, posInteractions.slice(2, 4), 'refined');
+  addInteractionIteration(9, negInteractions.slice(2, 4), 'refined');
+  addInteractionIteration(10, sortedInteractions.slice(8, 10), 'refined');
+
+  function addSubgroupIteration(index, feature, modifier) {
+    const eff0 = subgroupEffect(data, feature, modifier, 0, outcome);
+    const eff1 = subgroupEffect(data, feature, modifier, 1, outcome);
+    const inter = interactionEffect(data, feature, modifier, outcome);
+    const h0 = nextHypId();
+    const h1 = nextHypId();
+    const h2 = nextHypId();
+    const proposed = [
+      hyp(h0, `Among patients with \`${modifier}=0\`, patients with \`${feature}=1\` have ${eff0.diff >= 0 ? 'higher' : 'lower'} mean \`${outcome}\` than patients with \`${feature}=0\`.`, 'refined'),
+      hyp(h1, `Among patients with \`${modifier}=1\`, patients with \`${feature}=1\` have ${eff1.diff >= 0 ? 'higher' : 'lower'} mean \`${outcome}\` than patients with \`${feature}=0\`.`, 'refined'),
+      hyp(h2, `The association between \`${feature}\` and mean \`${outcome}\` differs between the \`${modifier}=1\` and \`${modifier}=0\` subgroups.`, 'refined'),
+    ];
+    const analyses = [
+      analysis(
+        [h0],
+        `Within ${modifier}=0, response was ${pct(eff0.p1)} for ${feature}=1 (n=${eff0.n1}) versus ${pct(eff0.p0)} for ${feature}=0 (n=${eff0.n0}); risk difference ${fmt(eff0.diff)}, p=${fmt(eff0.pValue)}.`,
+        eff0.pValue,
+        eff0.diff,
+        `Two-proportion z-test for ${feature} within ${modifier}=0.`
+      ),
+      analysis(
+        [h1],
+        `Within ${modifier}=1, response was ${pct(eff1.p1)} for ${feature}=1 (n=${eff1.n1}) versus ${pct(eff1.p0)} for ${feature}=0 (n=${eff1.n0}); risk difference ${fmt(eff1.diff)}, p=${fmt(eff1.pValue)}.`,
+        eff1.pValue,
+        eff1.diff,
+        `Two-proportion z-test for ${feature} within ${modifier}=1.`
+      ),
+      analysis(
+        [h2],
+        `The subgroup contrast in risk differences was ${fmt(inter.did)} (${feature} effect in ${modifier}=1 minus effect in ${modifier}=0); interaction z-test p=${fmt(inter.pValue)}.`,
+        inter.pValue,
+        inter.did,
+        `Difference-in-differences interaction test for ${feature} by ${modifier}.`
+      ),
+    ];
+    iterations.push({ index, proposed_hypotheses: proposed, analyses });
+  }
