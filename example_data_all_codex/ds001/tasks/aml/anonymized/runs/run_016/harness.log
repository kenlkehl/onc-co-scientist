+const fs = require('fs');
+const zlib = require('zlib');
+
+const CWD = process.cwd();
+const DATASET = 'dataset.parquet';
+
+const TType = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      result |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  binary() {
+    const len = Number(this.varint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out.toString('utf8');
+  }
+
+  value(type) {
+    switch (type) {
+      case TType.TRUE:
+        return true;
+      case TType.FALSE:
+        return false;
+      case TType.BYTE: {
+        const b = this.byte();
+        return b > 127 ? b - 256 : b;
+      }
+      case TType.I16:
+      case TType.I32:
+      case TType.I64:
+        return this.zigzag();
+      case TType.DOUBLE: {
+        const v = this.buf.readDoubleLE(this.pos);
+        this.pos += 8;
+        return v;
+      }
