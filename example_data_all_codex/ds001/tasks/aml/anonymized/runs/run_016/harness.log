+const fs = require('fs');
+const zlib = require('zlib');
+
+const CWD = process.cwd();
+const DATASET = 'dataset.parquet';
+
+const TType = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
