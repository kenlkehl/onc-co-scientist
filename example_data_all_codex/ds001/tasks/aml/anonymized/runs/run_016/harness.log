+  const negInteractions = [...pairwise].filter((r) => r.did < 0).sort((a, b) => a.pValue - b.pValue);
+
+  const topForTriples = sortedMain.slice(0, 12).map((r) => r.feature);
+  const triples = [];
+  for (let i = 0; i < topForTriples.length; i++) {
+    for (let j = i + 1; j < topForTriples.length; j++) {
+      for (let k = j + 1; k < topForTriples.length; k++) {
+        const r = tripleInteractionEffect(data, topForTriples[i], topForTriples[j], topForTriples[k], outcome);
+        const minCell = Math.min(...Object.values(r.cells).map((cell) => cell.n));
