+    if (values[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (values[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p0 = y0 / n0;
+  const p1 = y1 / n1;
+  const diff = p1 - p0;
+  const pooled = (y0 + y1) / (n0 + n1);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n0 + 1 / n1));
+  const z = diff / se;
