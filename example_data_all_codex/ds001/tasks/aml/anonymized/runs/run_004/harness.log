+const allMainColumns = featureColumns.map((c) => c.values);
+const allMainModel = ols(allMainColumns, y);
+const multivariable = featureColumns.map((c, idx) => ({
+  name: c.name,
+  coef: allMainModel.beta[idx + 1],
+  se: allMainModel.se[idx + 1],
+  p: allMainModel.p[idx + 1],
+  z: allMainModel.t[idx + 1],
+  summary: c.summary,
+}));
+multivariable.sort((a, b) => a.p - b.p);
+
+const topBinary = binaryFeatures
+  .map((c) => ({ c, assoc: binaryAssociation(c.values, y) }))
+  .sort((a, b) => a.assoc.p - b.assoc.p)
