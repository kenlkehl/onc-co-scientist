+  if (codec !== 1) throw new Error(`Unsupported codec for ${path}: ${codec}`);
+
+  let reader = new ThriftReader(buf, meta[11]);
+  const dictHeader = reader.readStruct();
+  if (dictHeader[1] !== 2) throw new Error(`Expected dictionary page for ${path}`);
+  const dictCompressed = buf.subarray(reader.pos, reader.pos + dictHeader[3]);
+  const dictPage = snappyDecode(dictCompressed);
+  const dictCount = dictHeader[7][1];
+  const dictionary = readPlainDictionary(dictPage, type, dictCount);
+
+  const values = new Array(totalValues);
+  let written = 0;
+  let pos = meta[9];
+  while (written < totalValues) {
+    const pageReader = new ThriftReader(buf, pos);
+    const pageHeader = pageReader.readStruct();
+    pos = pageReader.pos;
+    const pageType = pageHeader[1];
+    const compressedSize = pageHeader[3];
+    const pageCompressed = buf.subarray(pos, pos + compressedSize);
+    pos += compressedSize;
+    if (pageType !== 0) continue;
+    const page = snappyDecode(pageCompressed);
+    const dataHeader = pageHeader[5];
+    const pageValueCount = dataHeader[1];
+    const definitionLen = page.readInt32LE(0);
+    let dataPos = 4 + definitionLen;
+    const bitWidth = page[dataPos++];
+    const decoded = readHybridValues(page, dataPos, bitWidth, pageValueCount).values;
+    for (let i = 0; i < decoded.length; i++) values[written++] = dictionary[decoded[i]];
+  }
+  return values;
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  const az = Math.abs(z);
+  if (!Number.isFinite(az)) return 0;
+  if (az > 37) return 1e-300;
+  const p = 2 * (1 - normalCdf(az));
+  if (p <= 0) return 1e-300;
+  return p;
+}
+
+function summarizeFeature(values) {
+  const counts = new Map();
+  let min = Infinity;
+  let max = -Infinity;
+  let s = 0;
+  let ss = 0;
+  for (const v of values) {
+    counts.set(v, (counts.get(v) || 0) + 1);
+    if (v < min) min = v;
+    if (v > max) max = v;
+    s += v;
+    ss += v * v;
+  }
+  const n = values.length;
+  return {
+    n,
+    unique: counts.size,
+    counts,
+    min,
+    max,
+    mean: s / n,
+    sd: Math.sqrt(Math.max(0, (ss - (s * s) / n) / (n - 1))),
+  };
+}
+
+function binaryAssociation(values, y) {
+  let n0 = 0, n1 = 0, y0 = 0, y1 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (values[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (values[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p0 = y0 / n0;
+  const p1 = y1 / n1;
+  const diff = p1 - p0;
+  const pooled = (y0 + y1) / (n0 + n1);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n0 + 1 / n1));
+  const z = diff / se;
+  return { effect: diff, p: pFromZ(z), z, n0, n1, p0, p1 };
+}
+
+function continuousAssociation(values, y) {
+  const n = y.length;
+  let sx = 0, sy = 0, sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const x = values[i];
+    const yi = y[i];
+    sx += x;
+    sy += yi;
+    sxx += x * x;
+    sxy += x * yi;
+    syy += yi * yi;
+  }
+  const xbar = sx / n;
+  const ybar = sy / n;
+  const Sxx = sxx - sx * xbar;
+  const Sxy = sxy - sx * ybar;
+  const beta = Sxy / Sxx;
+  const alpha = ybar - beta * xbar;
+  const sse = syy - alpha * sy - beta * sxy;
+  const sigma2 = sse / (n - 2);
+  const se = Math.sqrt(sigma2 / Sxx);
+  const z = beta / se;
+  return { effect: beta, p: pFromZ(z), z, alpha, se };
+}
+
+function matInv(A) {
+  const n = A.length;
+  const M = new Array(n);
+  for (let i = 0; i < n; i++) {
+    M[i] = new Array(2 * n).fill(0);
+    for (let j = 0; j < n; j++) M[i][j] = A[i][j];
+    M[i][n + i] = 1;
+  }
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let row = col + 1; row < n; row++) {
+      if (Math.abs(M[row][col]) > Math.abs(M[pivot][col])) pivot = row;
+    }
+    if (Math.abs(M[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) [M[pivot], M[col]] = [M[col], M[pivot]];
+    const div = M[col][col];
+    for (let j = 0; j < 2 * n; j++) M[col][j] /= div;
+    for (let row = 0; row < n; row++) {
+      if (row === col) continue;
+      const factor = M[row][col];
+      if (factor === 0) continue;
+      for (let j = 0; j < 2 * n; j++) M[row][j] -= factor * M[col][j];
+    }
+  }
+  const inv = new Array(n);
+  for (let i = 0; i < n; i++) inv[i] = M[i].slice(n);
+  return inv;
+}
+
+function ols(columns, y) {
+  const n = y.length;
+  const p = columns.length + 1;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const col of columns) row.push(col[i]);
+    const yi = y[i];
+    yty += yi * yi;
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * yi;
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = matInv(xtx);
+  const beta = new Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let bxty = 0;
+  for (let i = 0; i < p; i++) bxty += beta[i] * xty[i];
+  const sse = Math.max(0, yty - bxty);
+  const sigma2 = sse / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const t = beta.map((b, i) => b / se[i]);
+  const pvals = t.map(pFromZ);
+  return { beta, se, t, p: pvals, sigma2 };
+}
+
+function centered(values) {
+  const m = mean(values);
+  return values.map((v) => v - m);
+}
+
+function binaryBinaryInteraction(a, b, y) {
+  const counts = {
+    "00": { n: 0, y: 0 },
+    "01": { n: 0, y: 0 },
+    "10": { n: 0, y: 0 },
+    "11": { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${a[i] === 1 ? 1 : 0}${b[i] === 1 ? 1 : 0}`;
+    counts[key].n++;
+    counts[key].y += y[i];
+  }
+  const r = {};
+  for (const key of Object.keys(counts)) {
+    r[key] = counts[key].y / counts[key].n;
+  }
+  const effect = r["11"] - r["10"] - r["01"] + r["00"];
+  let variance = 0;
+  for (const key of Object.keys(counts)) {
+    const p = r[key];
+    variance += p * (1 - p) / counts[key].n;
+  }
+  const se = Math.sqrt(variance);
+  const z = effect / se;
+  return { effect, p: pFromZ(z), z, rates: r, counts };
+}
+
+function subgroupBinaryEffect(effectValues, subgroupValues, subgroupValue, y) {
+  let n0 = 0, n1 = 0, y0 = 0, y1 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (subgroupValues[i] !== subgroupValue) continue;
+    if (effectValues[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (effectValues[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p0 = y0 / n0;
+  const p1 = y1 / n1;
+  const effect = p1 - p0;
+  const pooled = (y0 + y1) / (n0 + n1);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n0 + 1 / n1));
+  return { effect, p: pFromZ(effect / se), n0, n1, p0, p1 };
