"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs = require('fs');
const buf = fs.readFileSync('dataset.parquet');
function zigzag(n){ return Number((n >> 1n) "'^ (-(n & 1n))); }
class Reader{
  constructor(buf, pos=0){this.buf=buf;this.pos=pos;this.lastField=[];}
  readByte(){return this.buf[this.pos++];}
