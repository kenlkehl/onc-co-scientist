+function snappyDecode(input) {
+  let ip = 0;
+  function readVarint() {
+    let out = 0;
+    let shift = 0;
+    while (true) {
+      const b = input[ip++];
+      out |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return out;
+  }
