+function readHybridValues(buf, pos, bitWidth, count) {
+  const values = [];
+  const byteWidth = Math.ceil(bitWidth / 8);
+  function readUnsignedVarint() {
+    let out = 0;
+    let shift = 0;
+    while (true) {
+      const b = buf[pos++];
+      out |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return out;
+  }
+
+  while (values.length < count) {
+    const header = readUnsignedVarint();
+    if ((header & 1) === 0) {
