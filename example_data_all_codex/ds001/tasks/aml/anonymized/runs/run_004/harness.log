+
+// Iteration 1: strongest univariate binary effects.
+{
+  const picks = topBinary.slice(0, 3);
+  const hs = picks.map((p) => hyp(`Patients with ${p.c.name}=1 have a ${p.assoc.effect > 0 ? "higher" : "lower"} objective_response rate than patients with ${p.c.name}=0.`));
