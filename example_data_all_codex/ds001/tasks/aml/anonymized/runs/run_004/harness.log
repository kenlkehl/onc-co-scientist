+    } else if (type === 5) {
+      values.push(page.readDoubleLE(pos));
+      pos += 8;
+    } else if (type === 6) {
+      const len = page.readInt32LE(pos);
+      pos += 4;
+      values.push(page.subarray(pos, pos + len).toString("utf8"));
