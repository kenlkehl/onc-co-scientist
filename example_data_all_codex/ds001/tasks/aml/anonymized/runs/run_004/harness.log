+  for (const key of Object.keys(counts)) {
+    r[key] = counts[key].y / counts[key].n;
+  }
+  const effect = r["11"] - r["10"] - r["01"] + r["00"];
+  let variance = 0;
+  for (const key of Object.keys(counts)) {
