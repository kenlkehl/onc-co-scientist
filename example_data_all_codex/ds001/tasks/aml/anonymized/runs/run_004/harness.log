+}
+
+const file = fs.readFileSync(DATASET);
+const metadata = parquetFooter(file);
+const rowGroup = metadata[4][0];
+const chunks = rowGroup[1];
+const data = {};
+const columns = [];
+for (const chunk of chunks) {
