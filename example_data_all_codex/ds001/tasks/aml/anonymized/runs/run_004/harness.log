+}
+contBinaryInteractions.sort((a, b) => a.p - b.p);
+
+const allContInteractions = [];
+for (let i = 0; i < topContinuous.length; i++) {
+  for (let j = i + 1; j < topContinuous.length; j++) {
+    const xi = centered(topContinuous[i].c.values);
