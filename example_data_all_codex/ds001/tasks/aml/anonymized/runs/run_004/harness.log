+  return out;
+}
+
+function parquetFooter(buf) {
+  if (buf.subarray(0, 4).toString("ascii") !== "PAR1" || buf.subarray(buf.length - 4).toString("ascii") !== "PAR1") {
+    throw new Error("Not a Parquet file");
+  }
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  return new ThriftReader(buf.subarray(buf.length - 8 - footerLen, buf.length - 8)).readStruct();
+}
+
+function readPlainDictionary(page, type, count) {
+  const values = [];
+  let pos = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === 2) {
+      values.push(Number(page.readBigInt64LE(pos)));
+      pos += 8;
+    } else if (type === 5) {
+      values.push(page.readDoubleLE(pos));
+      pos += 8;
+    } else if (type === 6) {
+      const len = page.readInt32LE(pos);
+      pos += 4;
+      values.push(page.subarray(pos, pos + len).toString("utf8"));
