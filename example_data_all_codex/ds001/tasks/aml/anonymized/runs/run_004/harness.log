+const fs = require("fs");
+
+const DATASET = "dataset.parquet";
+const OUTCOME = "objective_response";
+const N_MAX_ITERATIONS = 25;
+
+function zigzag(n) {
+  return Number((n >> 1n) ^ (-(n & 1n)));
+}
+
+class ThriftReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  readByte() {
+    return this.buf[this.pos++];
+  }
+
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  readI32() {
+    return zigzag(this.readVarintBig());
+  }
+
+  readI64() {
+    return zigzag(this.readVarintBig());
+  }
+
+  readDouble() {
+    const value = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return value;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarintBig());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out.toString("binary");
+  }
+
+  readStruct() {
+    const out = {};
+    let lastField = 0;
+    while (true) {
+      const head = this.readByte();
+      const type = head & 0x0f;
+      if (type === 0) break;
+      const delta = head >> 4;
+      const fieldId = delta === 0 ? this.readI32() : lastField + delta;
+      lastField = fieldId;
+      out[fieldId] = this.readValue(type);
+    }
+    return out;
+  }
+
+  readValue(type) {
+    switch (type) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3:
+        return (this.readByte() << 24) >> 24;
+      case 4:
+      case 5:
+        return this.readI32();
+      case 6:
+        return this.readI64();
+      case 7:
+        return this.readDouble();
+      case 8:
+        return this.readBinary();
+      case 9:
+      case 10: {
+        const head = this.readByte();
+        let size = head >> 4;
+        const elemType = head & 0x0f;
+        if (size === 15) size = Number(this.readVarintBig());
+        const arr = [];
+        for (let i = 0; i < size; i++) arr.push(this.readValue(elemType));
+        return arr;
+      }
+      case 11: {
+        const size = Number(this.readVarintBig());
+        if (size === 0) return {};
+        const head = this.readByte();
+        const keyType = head >> 4;
+        const valueType = head & 0x0f;
+        const map = {};
+        for (let i = 0; i < size; i++) {
+          map[this.readValue(keyType)] = this.readValue(valueType);
+        }
+        return map;
+      }
+      case 12:
+        return this.readStruct();
+      default:
+        throw new Error(`Unsupported compact thrift type ${type} at offset ${this.pos}`);
+    }
+  }
+}
+
+function snappyDecode(input) {
+  let ip = 0;
+  function readVarint() {
+    let out = 0;
+    let shift = 0;
+    while (true) {
+      const b = input[ip++];
+      out |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return out;
+  }
+
+  const outLen = readVarint();
+  const out = Buffer.alloc(outLen);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const kind = tag & 3;
+    if (kind === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const n = len - 59;
+        len = 0;
+        for (let i = 0; i < n; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (kind === 1) {
+        len = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (kind === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = (input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24)) >>> 0;
+        ip += 4;
+      }
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    }
+  }
