    if c=='objective_response': continue
    s=df[c]
    rows.append((c, str(s.dtype), int(s.nunique()), float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, s.min() if pd.api.types.is_numeric_dtype(s) else None, s.max() if pd.api.types.is_numeric_dtype(s) else None, s.value_counts().head(5).to_dict()))
for r in rows:
