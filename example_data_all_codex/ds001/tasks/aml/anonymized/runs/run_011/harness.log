function decodePlain(buf,type,count){let arr=[],p=0;for(let i=0;i<count;i++){if(type===2){arr.push(Number(buf.readBigInt64LE(p)));p+=8;}else if(type===1){arr.push(buf.readInt32LE(p));p+=4;}else if(type===5){arr.push(buf.readDoubleLE(p));p+=8;}else if(type===4){arr.push(buf.readFloatLE(p));p+=4;}else if(type===6){let l=buf.readUInt32LE(p);p+=4;arr.push(buf.slice(p,p+l).toString('"'utf8'));p+=l;}else throw Error('plain type '+type);}return arr;}
function decodeColumn(colIdx){const cm=meta.row_groups[0].columns[colIdx].meta_data;const leaf=meta.schema[colIdx+1];let dict=null;if(cm.dictionary_page_offset"'!==undefined){let pg=readPage(cm.dictionary_page_offset);let body=cm.codec===1?snappy(pg.body):pg.body;dict=decodePlain(body,cm.type,pg.header.dictionary_page_header.num_values);}let vals=[];let off=cm.data_page_offset;while(vals.length<cm.num_values){let pg=readPage(off);off=pg.next;let body=cm.codec===1?snappy(pg.body):pg.body;if(pg.header.type!==0)continue;let h=pg.header.data_page_header;let pos=0;let defs=null;let maxDef=(leaf.repetition_type===1)?1:0;if(maxDef>0){let len=body.readUInt32LE(pos);pos+=4;let dec=decodeHybrid(body.slice(pos,pos+len),bitWidth(maxDef),h.num_values);defs=dec.values;pos+=len;}let nonNull=defs?defs.filter(v=>v===maxDef).length:h.num_values;let pageVals=[];if(h.encoding===8||h.encoding===2){let bw=body[pos++];let dec=decodeHybrid(body.slice(pos),bw,nonNull);pageVals=dec.values.map(i=>dict[i]);}else if(h.encoding===0){pageVals=decodePlain(body.slice(pos),cm.type,nonNull);}else throw Error('"'encoding '+h.encoding+' col '+cm.path_in_schema[0]);let j=0;if(defs){for(let d of defs) vals.push(d===maxDef?pageVals[j++]:null);}else vals.push(...pageVals);}return vals;}
function normCdf(x){return 0.5*(1+erf(x/Math.SQRT2));}function erf(x){const sign=x<0?-1:1;x=Math.abs(x);const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911;const t=1/(1+p*x);const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x);return sign*y;}function pFromZ(z){return Math.max(0,Math.min(1,2*(1-normCdf(Math.abs(z)))));}function mean(a){let s=0;for(const x of a)s+=x;return s/a.length;}
const rg=meta.row_groups[0];const names=rg.columns.map(c=>c.meta_data.path_in_schema[0]);const data={};for(let ci=1;ci<rg.columns.length;ci++){data[names[ci]]=decodeColumn(ci);}const y=data.objective_response;const n=y.length;const yMean=mean(y);console.log('rows',n,'outcome_mean',yMean.toFixed(6));
const features=names.slice(1,-1);const summaries=[];for(const f of features){const x=data[f];let min=Infinity,max=-Infinity,s=0;const counts=new Map();for(const v of x){if(v<min)min=v;if(v>max)max=v;s+=v;counts.set(v,(counts.get(v)||0)+1);}summaries.push({f,min,max,mean:s/n,nunique:counts.size,counts:[...counts.entries()].sort((a,b)=>a[0]-b[0]).slice(0,8)});}console.log('summaries first',JSON.stringify(summaries.slice(0,12),null,2));
function binaryEffect(f){const x=data[f];let n1=0,y1=0,n0=0,y0=0;for(let i=0;i<n;i++){if(x[i]===1){n1++;y1+=y[i];}else if(x[i]===0){n0++;y0+=y[i];}}let p1=y1/n1,p0=y0/n0,d=p1-p0,se=Math.sqrt(p1*(1-p1)/n1+p0*(1-p0)/n0),z=d/se,p=pFromZ(z);return{f,n1,n0,p1,p0,effect:d,se,z,p};}
const binary=summaries.filter(s=>s.nunique===2 && s.min===0 && s.max===1).map(s=>s.f);const main=binary.map(binaryEffect).sort((a,b)=>a.p-b.p);console.log('binary count',binary.length);console.log('top main',JSON.stringify(main.slice(0,25),null,2));
function contEffect(f,scale=10){const x=data[f];let sx=0,sy=0;for(let i=0;i<n;i++){sx+=x[i];sy+=y[i];}let mx=sx/n,my=sy/n;let sxx=0,sxy=0;for(let i=0;i<n;i++){let dx=x[i]-mx;sxx+=dx*dx;sxy+=dx*(y[i]-my);}let b=sxy/sxx;let a=my-b*mx;let rss=0;for(let i=0;i<n;i++){let r=y[i]-a-b*x[i];rss+=r*r;}let sigma2=rss/(n-2);let se=Math.sqrt(sigma2/sxx);let z=b/se;return{f,effect_per_unit:b,effect:b*scale,se:se*scale,z,p:pFromZ(z),scale};}
console.log('feature_044 continuous',JSON.stringify(contEffect('feature_044',10),null,2));
function catRates(f){const x=data[f];const groups=new Map();for(let i=0;i<n;i++){let g=groups.get(x[i])||{n:0,y:0};g.n++;g.y+=y[i];groups.set(x[i],g);}return [...groups.entries()].sort((a,b)=>a[0]-b[0]).map(([v,g])=>({v,n:g.n,rate:g.y/g.n}));}
for(const s of summaries.filter(s=>"'!(s.nunique===2&&s.min===0&&s.max===1)&&s.f!=='"'feature_044'))console.log('nonbinary',s.f,JSON.stringify(s),JSON.stringify(catRates(s.f)));
function didEffect(a,b){const xa=data[a],xb=data[b];let cells={};for(const va of [0,1])for(const vb of [0,1])cells["'`${va}${vb}`]={n:0,y:0};for(let i=0;i<n;i++){const va=xa[i],vb=xb[i];if((va===0||va===1)&&(vb===0||vb===1)){const c=cells[`${va}${vb}`];c.n++;c.y+=y[i];}}for(const k in cells){cells[k].p=cells[k].y/cells[k].n;}const eff=(cells['"'11'].p-cells['01'].p)-(cells['10'].p-cells['00'].p);const se=Math.sqrt(Object.values(cells).reduce((acc,c)=>acc+(c.p*(1-c.p)/c.n),0));return{a,b,effect:eff,se,z:eff/se,p:pFromZ(eff/se),cells};}
let interactions=[];for(let i=0;i<binary.length;i++){for(let j=i+1;j<binary.length;j++){let r=didEffect(binary[i],binary[j]);let minN=Math.min(...Object.values(r.cells).map(c=>c.n));if(minN>=50)interactions.push(r);}}interactions.sort((a,b)=>a.p-b.p);console.log('top interactions',JSON.stringify(interactions.slice(0,30).map(r=>({a:r.a,b:r.b,effect:r.effect,se:r.se,z:r.z,p:r.p,cells:r.cells})),null,2));
function slopeByGroup(cont,bin){const x=data[cont],b=data[bin];const res=[];for(const gval of [0,1]){let idx=[];for(let i=0;i<n;i++)if(b[i]===gval)idx.push(i);let mX=0,mY=0;for(const i of idx){mX+=x[i];mY+=y[i];}mX/=idx.length;mY/=idx.length;let sxx=0,sxy=0;for(const i of idx){let dx=x[i]-mX;sxx+=dx*dx;sxy+=dx*(y[i]-mY);}let beta=sxy/sxx;let alpha=mY-beta*mX;let rss=0;for(const i of idx){let r=y[i]-alpha-beta*x[i];rss+=r*r;}let se=Math.sqrt((rss/(idx.length-2))/sxx);res.push({g:gval,n:idx.length,slope:beta,se});}let diff=res[1].slope-res[0].slope;let se=Math.sqrt(res[0].se**2+res[1].se**2);return{cont,bin,effect_per_unit:diff,effect:diff*10,se:se*10,z:diff/se,p:pFromZ(diff/se),groups:res};}
let cints=binary.map(b=>slopeByGroup('feature_044',b)).sort((a,b)=>a.p-b.p);console.log('top continuous interactions',JSON.stringify(cints.slice(0,20),null,2));
