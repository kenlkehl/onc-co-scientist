+  while (vals.length < cm.num_values) {
+    const pg = readPage(off);
+    off = pg.next;
+    const body = cm.codec === 1 ? snappy(pg.body) : pg.body;
+    if (pg.header.type !== 0) continue;
+    const h = pg.header.data_page_header;
+    let pos = 0;
+    let defs = null;
