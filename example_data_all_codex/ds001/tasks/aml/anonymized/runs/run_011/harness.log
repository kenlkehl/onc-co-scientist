+      pageVals = decodePlain(body.slice(pos), cm.type, nonNull);
+    } else {
+      throw new Error(`Unsupported data encoding ${h.encoding} for ${cm.path_in_schema[0]}`);
+    }
+    if (defs) {
+      let j = 0;
+      for (const d of defs) vals.push(d === maxDef ? pageVals[j++] : null);
