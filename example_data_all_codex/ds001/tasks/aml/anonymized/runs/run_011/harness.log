+  return Math.max(0, Math.min(1, 2 * tail));
+}
+function mean(a) { let s = 0; for (const x of a) s += x; return s / a.length; }
+
+const data = {};
+for (let ci = 1; ci < rg.columns.length; ci++) data[names[ci]] = decodeColumn(ci);
+const y = data.objective_response;
+const n = y.length;
+
+const features = names.slice(1, -1);
+const summaries = features.map(f => {
+  const x = data[f];
+  let min = Infinity, max = -Infinity, sum = 0;
+  const counts = new Map();
+  for (const v of x) {
+    if (v < min) min = v;
+    if (v > max) max = v;
+    sum += v;
+    counts.set(v, (counts.get(v) || 0) + 1);
+  }
+  return { f, min, max, mean: sum / n, nunique: counts.size, counts: [...counts.entries()].sort((a, b) => a[0] - b[0]) };
+});
+
+const binary = summaries.filter(s => s.nunique === 2 && s.min === 0 && s.max === 1).map(s => s.f);
+function binaryEffect(f) {
+  const x = data[f];
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < n; i++) {
+    if (x[i] === 1) { n1++; y1 += y[i]; }
+    else if (x[i] === 0) { n0++; y0 += y[i]; }
+  }
+  const p1 = y1 / n1, p0 = y0 / n0, effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  const z = effect / se;
+  return { f, n1, n0, p1, p0, effect, se, z, p: normalP(z) };
+}
+function continuousEffect(f, scale = 10) {
+  const x = data[f];
+  const mx = mean(x), my = mean(y);
+  let sxx = 0, sxy = 0;
+  for (let i = 0; i < n; i++) { const dx = x[i] - mx; sxx += dx * dx; sxy += dx * (y[i] - my); }
+  const b = sxy / sxx;
+  const a = my - b * mx;
+  let rss = 0;
+  for (let i = 0; i < n; i++) { const r = y[i] - a - b * x[i]; rss += r * r; }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  const z = b / se;
+  return { f, scale, effect: b * scale, effect_per_unit: b, se: se * scale, z, p: normalP(z) };
+}
+function ordinalEffect(f, scale = 1) {
+  return continuousEffect(f, scale);
+}
+function quantileBinaryEffect(f, threshold, highGreater = true) {
+  const x = data[f];
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < n; i++) {
+    const hi = highGreater ? x[i] >= threshold : x[i] <= threshold;
+    if (hi) { n1++; y1 += y[i]; } else { n0++; y0 += y[i]; }
+  }
+  const p1 = y1 / n1, p0 = y0 / n0, effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
