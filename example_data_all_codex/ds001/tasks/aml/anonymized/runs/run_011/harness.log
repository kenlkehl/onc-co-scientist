+}
+function continuousInteraction(cont, bin, scale = 10) {
+  const x = data[cont], b = data[bin];
+  const groups = [];
+  for (const gval of [0, 1]) {
+    const idx = [];
+    for (let i = 0; i < n; i++) if (b[i] === gval) idx.push(i);
+    let mx = 0, my = 0;
+    for (const i of idx) { mx += x[i]; my += y[i]; }
+    mx /= idx.length; my /= idx.length;
+    let sxx = 0, sxy = 0;
+    for (const i of idx) { const dx = x[i] - mx; sxx += dx * dx; sxy += dx * (y[i] - my); }
