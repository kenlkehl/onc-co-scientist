+    for (let j = 0; j < 2 * m; j++) aug[c][j] /= div;
+    for (let r = 0; r < m; r++) {
+      if (r === c) continue;
+      const factor = aug[r][c];
+      for (let j = 0; j < 2 * m; j++) aug[r][j] -= factor * aug[c][j];
+    }
+  }
+  return aug.map(row => row.slice(m));
+}
+
+const main = binary.map(binaryEffect).sort((a, b) => a.p - b.p);
+const interactions = [];
+for (let i = 0; i < binary.length; i++) {
+  for (let j = i + 1; j < binary.length; j++) {
+    const r = didEffect(binary[i], binary[j]);
+    if (Math.min(...Object.values(r.cells).map(c => c.n)) >= 50) interactions.push(r);
+  }
+}
+interactions.sort((a, b) => a.p - b.p);
+const contInts044 = binary.map(b => continuousInteraction('feature_044', b)).sort((a, b) => a.p - b.p);
+const contInts053 = binary.map(b => continuousInteraction('feature_053', b)).sort((a, b) => a.p - b.p);
+
+const selectedFeatures = ['feature_015', 'feature_025', 'feature_023', 'feature_001', 'feature_032'];
+const adjustedTerms = [
