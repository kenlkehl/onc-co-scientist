+  }
+  for (const k of Object.keys(cells)) cells[k].p = cells[k].y / cells[k].n;
+  const effect = (cells['11'].p - cells['01'].p) - (cells['10'].p - cells['00'].p);
+  const se = Math.sqrt(Object.values(cells).reduce((acc, c) => acc + c.p * (1 - c.p) / c.n, 0));
+  const z = effect / se;
+  return { a, b, effect, se, z, p: normalP(z), cells };
+}
+function subgroupEffect(feature, subgroup, subgroupValue) {
+  const x = data[feature], s = data[subgroup];
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < n; i++) {
+    if (s[i] !== subgroupValue) continue;
+    if (x[i] === 1) { n1++; y1 += y[i]; }
+    else if (x[i] === 0) { n0++; y0 += y[i]; }
+  }
+  const p1 = y1 / n1, p0 = y0 / n0, effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  const z = effect / se;
