+const fs = require('fs');
+
+const file = fs.readFileSync('dataset.parquet');
+const CT = { STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6, DOUBLE: 7, BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12, FLOAT: 13 };
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.b = buf;
+    this.p = pos;
+  }
+  byte() { return this.b[this.p++]; }
+  varint() {
+    let shift = 0n, res = 0n;
+    while (true) {
+      const c = this.byte();
+      res |= BigInt(c & 127) << shift;
+      if (!(c & 128)) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zigzag() {
+    const n = this.varint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  int() { return Number(this.zigzag()); }
+  string() {
+    const len = Number(this.varint());
+    const s = this.b.slice(this.p, this.p + len).toString('utf8');
+    this.p += len;
+    return s;
+  }
+  listBegin() {
+    const x = this.byte();
+    let size = x >> 4;
+    const elemType = x & 15;
+    if (size === 15) size = Number(this.varint());
+    return { size, elemType };
+  }
+  field(lastId) {
+    const x = this.byte();
+    const type = x & 15;
+    if (type === 0) return { type };
+    const delta = x >> 4;
+    return { id: delta ? lastId + delta : this.int(), type };
+  }
+  skip(type) {
+    if (type === CT.STOP || type === CT.TRUE || type === CT.FALSE) return;
+    if (type === CT.BYTE) { this.p++; return; }
+    if (type === CT.I16 || type === CT.I32 || type === CT.I64) { this.zigzag(); return; }
+    if (type === CT.DOUBLE) { this.p += 8; return; }
+    if (type === CT.FLOAT) { this.p += 4; return; }
+    if (type === CT.BINARY) { const len = Number(this.varint()); this.p += len; return; }
+    if (type === CT.LIST || type === CT.SET) {
+      const { size, elemType } = this.listBegin();
+      for (let i = 0; i < size; i++) this.skip(elemType);
+      return;
+    }
+    if (type === CT.MAP) {
+      const size = Number(this.varint());
+      if (size) {
+        const ktvt = this.byte();
+        const kt = ktvt >> 4, vt = ktvt & 15;
+        for (let i = 0; i < size; i++) { this.skip(kt); this.skip(vt); }
+      }
+      return;
+    }
+    if (type === CT.STRUCT) { this.skipStruct(); return; }
+    throw new Error(`Unsupported compact type ${type}`);
+  }
+  skipStruct() {
+    let last = 0;
+    while (true) {
+      const f = this.field(last);
+      if (!f.type) return;
+      last = f.id;
+      this.skip(f.type);
+    }
+  }
+  value(type, spec) {
+    if (type === CT.TRUE) return true;
+    if (type === CT.FALSE) return false;
+    if (spec?.kind === 'struct') return this.struct(spec.fields);
+    if (spec?.kind === 'list') {
+      const { size, elemType } = this.listBegin();
+      const arr = [];
+      for (let i = 0; i < size; i++) arr.push(this.value(elemType, spec.elem));
+      return arr;
+    }
+    if (type === CT.BINARY) return this.string();
+    if (type === CT.I16 || type === CT.I32 || type === CT.I64) return this.int();
+    if (type === CT.BYTE) return this.byte();
+    if (type === CT.DOUBLE) { const v = this.b.readDoubleLE(this.p); this.p += 8; return v; }
+    if (type === CT.FLOAT) { const v = this.b.readFloatLE(this.p); this.p += 4; return v; }
+    if (type === CT.STRUCT) return this.struct({});
+    if (type === CT.LIST) {
+      const { size, elemType } = this.listBegin();
+      const arr = [];
+      for (let i = 0; i < size; i++) arr.push(this.value(elemType, null));
+      return arr;
+    }
+    this.skip(type);
+    return null;
+  }
+  struct(fields) {
+    const obj = {};
+    let last = 0;
+    while (true) {
+      const f = this.field(last);
+      if (!f.type) break;
+      last = f.id;
+      const spec = fields[f.id];
+      if (spec) obj[spec.name] = this.value(f.type, spec);
+      else this.skip(f.type);
+    }
+    return obj;
+  }
+}
