+function didEffect(a, b) {
+  const xa = data[a], xb = data[b];
+  const cells = {};
+  for (const va of [0, 1]) for (const vb of [0, 1]) cells[`${va}${vb}`] = { n: 0, y: 0 };
+  for (let i = 0; i < n; i++) {
+    const va = xa[i], vb = xb[i];
+    if ((va === 0 || va === 1) && (vb === 0 || vb === 1)) {
+      const c = cells[`${va}${vb}`];
+      c.n++; c.y += y[i];
+    }
+  }
+  for (const k of Object.keys(cells)) cells[k].p = cells[k].y / cells[k].n;
+  const effect = (cells['11'].p - cells['01'].p) - (cells['10'].p - cells['00'].p);
+  const se = Math.sqrt(Object.values(cells).reduce((acc, c) => acc + c.p * (1 - c.p) / c.n, 0));
