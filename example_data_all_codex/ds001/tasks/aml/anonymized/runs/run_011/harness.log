+  }
+  const diff = groups[1].slope - groups[0].slope;
+  const se = Math.sqrt(groups[0].se ** 2 + groups[1].se ** 2);
+  const z = diff / se;
+  return { cont, bin, scale, effect: diff * scale, effect_per_unit: diff, se: se * scale, z, p: normalP(z), groups };
+}
+
+function ols(terms) {
+  const p = terms.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = terms.map(t => t.fn(i));
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invert(xtx);
+  const beta = inv.map(row => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += beta[j] * terms[j].fn(i);
+    const r = y[i] - pred;
+    rss += r * r;
+  }
+  const sigma2 = rss / (n - p);
+  const result = {};
+  for (let j = 0; j < p; j++) {
+    const se = Math.sqrt(sigma2 * inv[j][j]);
+    const z = beta[j] / se;
+    result[terms[j].name] = { beta: beta[j], se, z, p: normalP(z) };
+  }
+  return result;
+}
+function invert(a) {
+  const m = a.length;
+  const aug = a.map((row, i) => row.concat(Array.from({ length: m }, (_, j) => i === j ? 1 : 0)));
+  for (let c = 0; c < m; c++) {
+    let pivot = c;
+    for (let r = c + 1; r < m; r++) if (Math.abs(aug[r][c]) > Math.abs(aug[pivot][c])) pivot = r;
+    if (pivot !== c) [aug[c], aug[pivot]] = [aug[pivot], aug[c]];
+    const div = aug[c][c];
+    for (let j = 0; j < 2 * m; j++) aug[c][j] /= div;
+    for (let r = 0; r < m; r++) {
+      if (r === c) continue;
+      const factor = aug[r][c];
+      for (let j = 0; j < 2 * m; j++) aug[r][j] -= factor * aug[c][j];
+    }
+  }
+  return aug.map(row => row.slice(m));
+}
+
+const main = binary.map(binaryEffect).sort((a, b) => a.p - b.p);
+const continuousTop = summaries
+  .filter(s => !(s.nunique === 2 && s.min === 0 && s.max === 1))
+  .map(s => continuousEffect(s.f, 1))
+  .sort((a, b) => a.p - b.p);
+const interactions = [];
+for (let i = 0; i < binary.length; i++) {
+  for (let j = i + 1; j < binary.length; j++) {
+    const r = didEffect(binary[i], binary[j]);
+    if (Math.min(...Object.values(r.cells).map(c => c.n)) >= 50) interactions.push(r);
+  }
+}
+interactions.sort((a, b) => a.p - b.p);
+const contInts044 = binary.map(b => continuousInteraction('feature_044', b)).sort((a, b) => a.p - b.p);
+const contInts053 = binary.map(b => continuousInteraction('feature_053', b)).sort((a, b) => a.p - b.p);
+
+const selectedFeatures = ['feature_015', 'feature_025', 'feature_023', 'feature_001', 'feature_032'];
+const adjustedTerms = [
+  { name: 'intercept', fn: () => 1 },
+  { name: 'feature_015', fn: i => data.feature_015[i] },
+  { name: 'feature_025', fn: i => data.feature_025[i] },
+  { name: 'feature_023', fn: i => data.feature_023[i] },
+  { name: 'feature_001', fn: i => data.feature_001[i] },
+  { name: 'feature_032', fn: i => data.feature_032[i] },
+  { name: 'feature_027', fn: i => data.feature_027[i] },
+  { name: 'feature_044_per10', fn: i => data.feature_044[i] / 10 },
+  { name: 'feature_053_per10', fn: i => data.feature_053[i] / 10 },
+];
+const adjusted = ols(adjustedTerms);
+
+const interactionOls = ols([
+  { name: 'intercept', fn: () => 1 },
+  { name: 'feature_015', fn: i => data.feature_015[i] },
+  { name: 'feature_025', fn: i => data.feature_025[i] },
+  { name: 'feature_015_x_feature_025', fn: i => data.feature_015[i] * data.feature_025[i] },
+  { name: 'feature_023', fn: i => data.feature_023[i] },
+  { name: 'feature_001', fn: i => data.feature_001[i] },
+  { name: 'feature_032', fn: i => data.feature_032[i] },
+  { name: 'feature_027', fn: i => data.feature_027[i] },
+]);
+
+function ordinalInteraction(bin, ord) {
+  const term = `${bin}_x_${ord}`;
+  const fit = ols([
+    { name: 'intercept', fn: () => 1 },
+    { name: bin, fn: i => data[bin][i] },
+    { name: ord, fn: i => data[ord][i] },
+    { name: term, fn: i => data[bin][i] * data[ord][i] },
+  ]);
+  const subgroupRates = ratesByValue(ord).map(g => {
+    const rr = subgroupEffect(bin, ord, g.value);
+    return { value: g.value, n1: rr.n1, n0: rr.n0, p1: rr.p1, p0: rr.p0, effect: rr.effect, p: rr.p };
+  });
+  return { bin, ord, interaction: fit[term], subgroupRates };
+}
+
+const ordinalInteractions = Object.fromEntries(
+  ['feature_015', 'feature_025', 'feature_023', 'feature_001', 'feature_032']
+    .map(f => [`${f}_feature_027`, ordinalInteraction(f, 'feature_027')])
+);
+
+function comboRates(vars) {
+  const groups = new Map();
+  for (let i = 0; i < n; i++) {
+    const key = vars.map(v => data[v][i]).join('');
+    const g = groups.get(key) || { n: 0, y: 0 };
+    g.n++; g.y += y[i]; groups.set(key, g);
+  }
+  return [...groups.entries()].sort((a, b) => a[0].localeCompare(b[0]))
+    .map(([key, g]) => ({ key, n: g.n, rate: g.y / g.n }));
+}
+
+const topThreeInteractionOls = ols([
+  { name: 'intercept', fn: () => 1 },
+  { name: 'feature_015', fn: i => data.feature_015[i] },
+  { name: 'feature_025', fn: i => data.feature_025[i] },
+  { name: 'feature_023', fn: i => data.feature_023[i] },
+  { name: 'feature_015_x_feature_025', fn: i => data.feature_015[i] * data.feature_025[i] },
+  { name: 'feature_015_x_feature_023', fn: i => data.feature_015[i] * data.feature_023[i] },
+  { name: 'feature_025_x_feature_023', fn: i => data.feature_025[i] * data.feature_023[i] },
+  { name: 'feature_015_x_feature_025_x_feature_023', fn: i => data.feature_015[i] * data.feature_025[i] * data.feature_023[i] },
+  { name: 'feature_001', fn: i => data.feature_001[i] },
+  { name: 'feature_032', fn: i => data.feature_032[i] },
+  { name: 'feature_027', fn: i => data.feature_027[i] },
+]);
+
+const adjustedExtended = ols([
+  { name: 'intercept', fn: () => 1 },
+  { name: 'feature_015', fn: i => data.feature_015[i] },
+  { name: 'feature_025', fn: i => data.feature_025[i] },
+  { name: 'feature_023', fn: i => data.feature_023[i] },
+  { name: 'feature_001', fn: i => data.feature_001[i] },
+  { name: 'feature_032', fn: i => data.feature_032[i] },
+  { name: 'feature_027', fn: i => data.feature_027[i] },
+  { name: 'feature_004', fn: i => data.feature_004[i] },
+  { name: 'feature_031_per10', fn: i => data.feature_031[i] / 10 },
+  { name: 'feature_059', fn: i => data.feature_059[i] },
+  { name: 'feature_033', fn: i => data.feature_033[i] },
+  { name: 'feature_053_per10', fn: i => data.feature_053[i] / 10 },
+  { name: 'feature_044_per10', fn: i => data.feature_044[i] / 10 },
+]);
+
+const results = {
+  n,
+  outcome_rate: mean(y),
+  feature_summaries: summaries.map(s => ({ f: s.f, min: s.min, max: s.max, mean: s.mean, nunique: s.nunique, counts: s.counts.length <= 8 ? s.counts : undefined })),
+  binary_count: binary.length,
+  main_top: main.slice(0, 15),
+  continuous_top: continuousTop.slice(0, 20),
+  main_named: Object.fromEntries(selectedFeatures.map(f => [f, binaryEffect(f)])),
+  feature_044: continuousEffect('feature_044', 10),
+  feature_053: continuousEffect('feature_053', 10),
+  feature_053_high20: quantileBinaryEffect('feature_053', 20, true),
+  feature_027: { ordinal: ordinalEffect('feature_027', 1), rates: ratesByValue('feature_027') },
+  interactions_top: interactions.slice(0, 20),
+  named_interactions: {
+    feature_015_feature_025: didEffect('feature_015', 'feature_025'),
+    feature_015_feature_023: didEffect('feature_015', 'feature_023'),
+    feature_025_feature_023: didEffect('feature_025', 'feature_023'),
+    feature_001_feature_032: didEffect('feature_001', 'feature_032'),
+  },
+  ordinal_interactions: ordinalInteractions,
+  top_three_interaction_ols: topThreeInteractionOls,
+  top_three_combo_rates: comboRates(['feature_015', 'feature_025', 'feature_023']),
+  subgroups: {
+    feature_015_with_feature_025_0: subgroupEffect('feature_015', 'feature_025', 0),
+    feature_015_with_feature_025_1: subgroupEffect('feature_015', 'feature_025', 1),
+    feature_025_with_feature_015_0: subgroupEffect('feature_025', 'feature_015', 0),
+    feature_025_with_feature_015_1: subgroupEffect('feature_025', 'feature_015', 1),
+    feature_023_with_feature_027_0: subgroupEffect('feature_023', 'feature_027', 0),
+    feature_023_with_feature_027_2: subgroupEffect('feature_023', 'feature_027', 2),
+  },
+  cont_interactions_044_top: contInts044.slice(0, 10),
+  cont_interactions_053_top: contInts053.slice(0, 10),
+  adjusted,
+  adjusted_extended: adjustedExtended,
+  interaction_ols: interactionOls,
+};
+
+console.log(JSON.stringify(results, null, 2));

