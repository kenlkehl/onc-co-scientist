+    if (type === 2) { arr.push(Number(buf.readBigInt64LE(p))); p += 8; }
+    else if (type === 1) { arr.push(buf.readInt32LE(p)); p += 4; }
+    else if (type === 5) { arr.push(buf.readDoubleLE(p)); p += 8; }
+    else if (type === 4) { arr.push(buf.readFloatLE(p)); p += 4; }
