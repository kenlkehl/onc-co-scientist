function snappy(src){let pos=0;function readVar(){let res=0,shift=0;while(true){let c=src[pos++];res|=(c&127)<<shift;if("'!(c&128))break;shift+=7;}return res;}const len=readVar();const out=Buffer.alloc(len);let op=0;while(pos<src.length){let tag=src[pos++],type=tag&3;if(type===0){let l=tag>>2;if(l<60)l+=1;else{let n=l-59;l=0;for(let i=0;i<n;i++)l|=src[pos++]<<(8*i);l+=1;}src.copy(out,op,pos,pos+l);pos+=l;op+=l;}else if(type===1){let l=((tag>>2)&7)+4,off=((tag&224)<<3)|src[pos++];for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}else if(type===2){let l=(tag>>2)+1,off=src[pos]|(src[pos+1]<<8);pos+=2;for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}else{let l=(tag>>2)+1,off=src[pos]|(src[pos+1]<<8)|(src[pos+2]<<16)|(src[pos+3]<<24);pos+=4;for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}}return out;}
function bitWidth(n){let w=0;while((1<<w)<=n)w++;return w;}
function readUVar(buf,state){let shift=0,res=0;while(true){let c=buf[state.pos++];res|=(c&127)<<shift;if(!(c&128))break;shift+=7;}return res;}
function decodeHybrid(buf,bw,count){const out=[];const st={pos:0};if(bw===0){return{values:Array(count).fill(0),consumed:0};}while(out.length<count && st.pos<buf.length){let header=readUVar(buf,st);if((header&1)===0){let run=header>>1;let bytes=Math.ceil(bw/8);let val=0;for(let i=0;i<bytes;i++)val|=buf[st.pos++]<<(8*i);for(let i=0;i<run && out.length<count;i++)out.push(val);}else{let groups=header>>1;let nvals=groups*8;let totalBits=nvals*bw;let bytes=Math.ceil(totalBits/8);let start=st.pos;for(let i=0;i<nvals && out.length<count;i++){let v=0;let bitBase=i*bw;for(let bit=0;bit<bw;bit++){let absolute=bitBase+bit;let by=buf[start+(absolute>>3)];let bi=absolute&7;if((by>>bi)&1)v|=1<<bit;}out.push(v);}st.pos+=bytes;}}
