+  for (let i = 0; i < n; i++) {
+    if (s[i] !== subgroupValue) continue;
+    if (x[i] === 1) { n1++; y1 += y[i]; }
+    else if (x[i] === 0) { n0++; y0 += y[i]; }
+  }
+  const p1 = y1 / n1, p0 = y0 / n0, effect = p1 - p0;
