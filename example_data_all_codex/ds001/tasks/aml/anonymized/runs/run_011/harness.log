+  varint() {
+    let shift = 0n, res = 0n;
+    while (true) {
+      const c = this.byte();
+      res |= BigInt(c & 127) << shift;
+      if (!(c & 128)) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zigzag() {
+    const n = this.varint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  int() { return Number(this.zigzag()); }
