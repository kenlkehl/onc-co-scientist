+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < n; i++) {
+    const hi = highGreater ? x[i] >= threshold : x[i] <= threshold;
+    if (hi) { n1++; y1 += y[i]; } else { n0++; y0 += y[i]; }
+  }
+  const p1 = y1 / n1, p0 = y0 / n0, effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
