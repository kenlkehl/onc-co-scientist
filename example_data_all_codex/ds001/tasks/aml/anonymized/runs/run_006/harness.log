import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('objective_response unique/counts')
print(df['objective_response'].value_counts(dropna=False).sort_index().to_string())
print('objective_response mean', df['objective_response'].mean())
features = [c for c in df.columns if c "'!= '"'objective_response']
rows=[]
for c in features:
    s=df[c]
    vc=s.value_counts().sort_index()
    rows.append((c, str(s.dtype), int(s.nunique()), float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, vc.head(10).to_dict()))
for row in rows[:80]:
    print(row)
