+      const bytes = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < bytes; i++) value |= buf[p++] << (8 * i);
+      for (let i = 0; i < run && out.length < expected; i++) out.push(value);
+    } else {
