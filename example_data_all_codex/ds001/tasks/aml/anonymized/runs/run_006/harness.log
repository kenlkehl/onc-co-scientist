+const fs = require('fs');
+
+class CompactReader {
+  constructor(buf, start = 0) {
+    this.buf = buf;
+    this.pos = start;
+    this.lastField = [];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  zigzag(u) {
+    return Number((u >> 1n) ^ (-(u & 1n)));
+  }
+  readI16() {
+    return this.zigzag(this.readVarint());
+  }
+  readI32() {
+    return this.zigzag(this.readVarint());
+  }
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+  readDouble() {
+    const value = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return value;
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const slice = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return slice;
+  }
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 15;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = b >> 4;
+    const id = delta ? ((this.lastField.at(-1) || 0) + delta) : this.readI16();
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 15;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, elemType };
+  }
+  readVal(type) {
+    switch (type) {
+      case 1: return true;
+      case 2: return false;
+      case 3: return this.readByte();
+      case 4: return this.readI16();
+      case 5: return this.readI32();
+      case 6: return this.readI64();
+      case 7: return this.readDouble();
+      case 8: return this.readBinary();
+      case 9: return this.readList();
+      case 12: return this.readStruct();
+      default: throw new Error(`Unsupported thrift type ${type}`);
+    }
+  }
+  readList() {
+    const { size, elemType } = this.readListBegin();
+    return Array.from({ length: size }, () => this.readVal(elemType));
+  }
+  readStruct() {
+    const out = {};
+    this.lastField.push(0);
+    while (true) {
+      const field = this.readFieldBegin();
+      if (field.type === 0) break;
+      out[field.id] = this.readVal(field.type);
+    }
+    this.lastField.pop();
+    return out;
+  }
+}
+
+function convertThrift(value) {
+  if (Buffer.isBuffer(value)) return value.toString('utf8');
+  if (Array.isArray(value)) return value.map(convertThrift);
+  if (value && typeof value === 'object') {
+    const out = {};
+    for (const key of Object.keys(value)) out[key] = convertThrift(value[key]);
+    return out;
+  }
+  return value;
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  function readVar() {
+    let result = 0;
+    let shift = 0;
+    while (true) {
+      const b = input[ip++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const outLen = readVar();
+  const out = Buffer.alloc(outLen);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else if (type === 1) {
+      const len = ((tag >> 2) & 7) + 4;
+      const off = ((tag & 0xe0) << 3) | input[ip++];
+      for (let i = 0; i < len; i++) out[op + i] = out[op - off + i];
+      op += len;
+    } else if (type === 2) {
+      const len = (tag >> 2) + 1;
+      const off = input[ip] | (input[ip + 1] << 8);
+      ip += 2;
+      for (let i = 0; i < len; i++) out[op + i] = out[op - off + i];
+      op += len;
+    } else {
+      const len = (tag >> 2) + 1;
+      const off = input.readUInt32LE(ip);
+      ip += 4;
+      for (let i = 0; i < len; i++) out[op + i] = out[op - off + i];
+      op += len;
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch ${op} ${outLen}`);
+  return out;
+}
+
+function readPlainDict(type, body, n) {
+  const values = [];
+  let p = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === 2) {
+      values.push(Number(body.readBigInt64LE(p)));
+      p += 8;
+    } else if (type === 5) {
+      values.push(body.readDoubleLE(p));
+      p += 8;
+    } else if (type === 6) {
+      const len = body.readInt32LE(p);
