+  const effect = p1 - p0;
+  const pooled = (r1 + r0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
+  const p = normalP(effect / se);
+  return { effect, p, p1, p0, n1, n0, r1, r0 };
+}
+
+function thresholdAssociation(x, y, threshold, ge = true) {
+  return binaryAssociation(x.map((v) => (ge ? v >= threshold : v > threshold) ? 1 : 0), y);
+}
+
+function interaction2(a, b, y) {
+  const n = [0, 0, 0, 0];
+  const r = [0, 0, 0, 0];
+  for (let i = 0; i < y.length; i++) {
+    const cell = a[i] * 2 + b[i];
+    n[cell]++;
+    r[cell] += y[i];
+  }
+  const rate = n.map((count, i) => r[i] / count);
+  const effect = rate[3] - rate[2] - rate[1] + rate[0];
+  const variance = rate.reduce((s, p, i) => s + p * (1 - p) / n[i], 0);
+  const p = normalP(effect / Math.sqrt(variance));
+  return { effect, p, rate, n, r };
+}
+
+function threeWayInteraction(a, b, c, y) {
+  const n = Array(8).fill(0);
+  const r = Array(8).fill(0);
+  for (let i = 0; i < y.length; i++) {
+    const cell = a[i] * 4 + b[i] * 2 + c[i];
+    n[cell]++;
+    r[cell] += y[i];
+  }
+  const rate = n.map((count, i) => r[i] / count);
+  const signs = [-1, 1, 1, -1, 1, -1, -1, 1];
+  const effect = signs.reduce((s, sign, i) => s + sign * rate[i], 0);
+  const variance = rate.reduce((s, p, i) => s + p * (1 - p) / n[i], 0);
+  const p = normalP(effect / Math.sqrt(variance));
+  return { effect, p, rate, n, r };
+}
+
+function simpleSlope(x, y, scale = 1) {
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0, sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    sxx += (x[i] - mx) * (x[i] - mx);
+    sxy += (x[i] - mx) * (y[i] - my);
+  }
+  const beta = sxy / sxx;
+  const alpha = my - beta * mx;
+  let rss = 0;
+  for (let i = 0; i < x.length; i++) {
+    const e = y[i] - alpha - beta * x[i];
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (x.length - 2)) / sxx);
+  return { effect: beta * scale, p: normalP(beta / se), beta, se };
+}
