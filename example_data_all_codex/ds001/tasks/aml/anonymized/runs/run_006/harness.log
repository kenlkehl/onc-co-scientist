+function snappyUncompress(input) {
+  let ip = 0;
+  function readVar() {
+    let result = 0;
+    let shift = 0;
+    while (true) {
+      const b = input[ip++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  const outLen = readVar();
+  const out = Buffer.alloc(outLen);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[ip++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, ip, ip + len);
+      ip += len;
+      op += len;
+    } else if (type === 1) {
+      const len = ((tag >> 2) & 7) + 4;
+      const off = ((tag & 0xe0) << 3) | input[ip++];
+      for (let i = 0; i < len; i++) out[op + i] = out[op - off + i];
+      op += len;
+    } else if (type === 2) {
+      const len = (tag >> 2) + 1;
+      const off = input[ip] | (input[ip + 1] << 8);
+      ip += 2;
+      for (let i = 0; i < len; i++) out[op + i] = out[op - off + i];
+      op += len;
+    } else {
+      const len = (tag >> 2) + 1;
+      const off = input.readUInt32LE(ip);
+      ip += 4;
+      for (let i = 0; i < len; i++) out[op + i] = out[op - off + i];
+      op += len;
+    }
+  }
+  if (op !== outLen) throw new Error(`Snappy length mismatch ${op} ${outLen}`);
+  return out;
+}
+
+function readPlainDict(type, body, n) {
+  const values = [];
+  let p = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === 2) {
+      values.push(Number(body.readBigInt64LE(p)));
+      p += 8;
+    } else if (type === 5) {
+      values.push(body.readDoubleLE(p));
+      p += 8;
+    } else if (type === 6) {
+      const len = body.readInt32LE(p);
+      p += 4;
+      values.push(body.subarray(p, p + len).toString('utf8'));
+      p += len;
+    } else if (type === 1) {
+      values.push(body.readInt32LE(p));
+      p += 4;
+    } else {
+      throw new Error(`Unsupported plain dictionary type ${type}`);
+    }
+  }
+  return values;
+}
+
+function readVarintAt(buf, p) {
+  let result = 0;
+  let shift = 0;
+  while (true) {
+    const b = buf[p++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return [result, p];
+}
+
+function decodeHybrid(buf, bitWidth, expected) {
+  if (bitWidth === 0) return Array(expected).fill(0);
+  let p = 0;
+  const out = [];
+  while (out.length < expected && p < buf.length) {
+    let header;
+    [header, p] = readVarintAt(buf, p);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const bytes = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < bytes; i++) value |= buf[p++] << (8 * i);
+      for (let i = 0; i < run && out.length < expected; i++) out.push(value);
+    } else {
+      const count = (header >> 1) * 8;
+      let bitOffset = 0;
+      for (let i = 0; i < count && out.length < expected; i++) {
+        let value = 0;
+        for (let j = 0; j < bitWidth; j++) {
+          const bi = bitOffset + j;
+          value |= ((buf[p + (bi >> 3)] >> (bi & 7)) & 1) << j;
+        }
+        out.push(value);
+        bitOffset += bitWidth;
+      }
+      p += Math.ceil(count * bitWidth / 8);
+    }
+  }
+  return out;
+}
+
+function readParquet(path) {
+  const buf = fs.readFileSync(path);
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const metaBuf = buf.subarray(buf.length - 8 - footerLen, buf.length - 8);
+  const meta = convertThrift(new CompactReader(metaBuf).readStruct());
+  const schema = meta[2];
+  const rowGroup = meta[4][0];
+  const cols = rowGroup[1];
+  const names = schema.slice(1).map((s) => s[4]);
+  function decodeColumn(j) {
+    const md = cols[j][3];
+    const type = md[1];
+    const total = md[5];
+    let dict = null;
+    if (md[11] == null) throw new Error(`Column ${names[j]} lacks dictionary page`);
+    {
+      const r = new CompactReader(buf, md[11]);
+      const ph = convertThrift(r.readStruct());
+      let body = buf.subarray(r.pos, r.pos + ph[3]);
+      if (md[4] === 1) body = snappyUncompress(body);
+      dict = readPlainDict(type, body, ph[7][1]);
+    }
+    let off = md[9];
+    const values = [];
+    while (values.length < total) {
+      const r = new CompactReader(buf, off);
+      const ph = convertThrift(r.readStruct());
+      let body = buf.subarray(r.pos, r.pos + ph[3]);
+      if (md[4] === 1) body = snappyUncompress(body);
+      if (ph[1] !== 0) throw new Error(`Unexpected page type ${ph[1]} for ${names[j]}`);
+      const dph = ph[5];
+      const n = dph[1];
+      let p = 0;
+      const defLen = body.readInt32LE(p);
+      p += 4;
+      const defBytes = body.subarray(p, p + defLen);
+      p += defLen;
+      const defs = decodeHybrid(defBytes, 1, n);
+      const present = defs.filter((x) => x === 1).length;
+      if (dph[2] !== 8) throw new Error(`Unsupported encoding ${dph[2]} for ${names[j]}`);
+      const bitWidth = body[p++];
+      const idx = decodeHybrid(body.subarray(p), bitWidth, present);
+      for (const k of idx) values.push(dict[k]);
+      off = r.pos + ph[3];
+    }
+    return values;
+  }
+  const data = {};
+  for (let j = 0; j < cols.length; j++) data[names[j]] = decodeColumn(j);
+  return data;
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalP(z) {
+  const p = 2 * (1 - (0.5 * (1 + erf(Math.abs(z) / Math.SQRT2))));
+  if (!Number.isFinite(p) || p <= 0) return 1e-300;
+  return p;
+}
+
+function mean(a) {
+  return a.reduce((s, x) => s + x, 0) / a.length;
+}
+
+function sd(a) {
+  const m = mean(a);
+  return Math.sqrt(a.reduce((s, x) => s + (x - m) * (x - m), 0) / (a.length - 1));
+}
+
+function quantile(a, q) {
+  const x = [...a].sort((u, v) => u - v);
+  const pos = (x.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  const frac = pos - lo;
+  return x[lo] * (1 - frac) + x[hi] * frac;
+}
+
+function binaryAssociation(g, y) {
+  let n1 = 0, n0 = 0, r1 = 0, r0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (g[i] === 1) {
+      n1++;
+      r1 += y[i];
+    } else {
+      n0++;
+      r0 += y[i];
+    }
+  }
+  const p1 = r1 / n1;
+  const p0 = r0 / n0;
+  const effect = p1 - p0;
+  const pooled = (r1 + r0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
+  const p = normalP(effect / se);
+  return { effect, p, p1, p0, n1, n0, r1, r0 };
+}
+
+function thresholdAssociation(x, y, threshold, ge = true) {
+  return binaryAssociation(x.map((v) => (ge ? v >= threshold : v > threshold) ? 1 : 0), y);
+}
+
+function interaction2(a, b, y) {
+  const n = [0, 0, 0, 0];
+  const r = [0, 0, 0, 0];
+  for (let i = 0; i < y.length; i++) {
+    const cell = a[i] * 2 + b[i];
+    n[cell]++;
+    r[cell] += y[i];
+  }
+  const rate = n.map((count, i) => r[i] / count);
+  const effect = rate[3] - rate[2] - rate[1] + rate[0];
+  const variance = rate.reduce((s, p, i) => s + p * (1 - p) / n[i], 0);
+  const p = normalP(effect / Math.sqrt(variance));
+  return { effect, p, rate, n, r };
+}
+
+function threeWayInteraction(a, b, c, y) {
+  const n = Array(8).fill(0);
+  const r = Array(8).fill(0);
+  for (let i = 0; i < y.length; i++) {
+    const cell = a[i] * 4 + b[i] * 2 + c[i];
+    n[cell]++;
+    r[cell] += y[i];
+  }
+  const rate = n.map((count, i) => r[i] / count);
+  const signs = [-1, 1, 1, -1, 1, -1, -1, 1];
+  const effect = signs.reduce((s, sign, i) => s + sign * rate[i], 0);
+  const variance = rate.reduce((s, p, i) => s + p * (1 - p) / n[i], 0);
+  const p = normalP(effect / Math.sqrt(variance));
+  return { effect, p, rate, n, r };
+}
+
+function simpleSlope(x, y, scale = 1) {
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0, sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    sxx += (x[i] - mx) * (x[i] - mx);
+    sxy += (x[i] - mx) * (y[i] - my);
+  }
+  const beta = sxy / sxx;
+  const alpha = my - beta * mx;
+  let rss = 0;
+  for (let i = 0; i < x.length; i++) {
+    const e = y[i] - alpha - beta * x[i];
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (x.length - 2)) / sxx);
+  return { effect: beta * scale, p: normalP(beta / se), beta, se };
+}
+
+function standardize(x) {
+  const m = mean(x);
+  const s = sd(x);
+  return x.map((v) => (v - m) / s);
+}
+
+function product(a, b) {
+  return a.map((v, i) => v * b[i]);
+}
