+const feature027Slope = simpleSlope(data.feature_027, y, 1);
+const feature027SlopeSd = simpleSlope(data.feature_027, y, sd(data.feature_027));
+const q004 = quantile(data.feature_004, 0.75);
+const q031 = quantile(data.feature_031, 0.75);
+const q059 = quantile(data.feature_059, 0.75);
+const q053 = quantile(data.feature_053, 0.75);
+const med004 = quantile(data.feature_004, 0.5);
+const high004 = data.feature_004.map((v) => v >= med004 ? 1 : 0);
+const high004Q = thresholdAssociation(data.feature_004, y, q004);
+const high031Q = thresholdAssociation(data.feature_031, y, q031);
+const high059Q = thresholdAssociation(data.feature_059, y, q059);
+const high053Q = thresholdAssociation(data.feature_053, y, q053);
+const slope004Sd = simpleSlope(data.feature_004, y, sd(data.feature_004));
+const slope031Sd = simpleSlope(data.feature_031, y, sd(data.feature_031));
