+      rec('h25', `Adjusted linear probability coefficient for feature_004_per_sd was ${fmtPct(adj.feature_004_per_sd.coef)}.`, adjStat('feature_004_per_sd'), 'Robust-SE linear probability model with selected main effects and interactions.')
