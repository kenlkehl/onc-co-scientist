+    analyses: [rec('h33', `The feature_025-by-high-feature_004 additive interaction was ${fmtPct(int025004.effect)}, indicating no meaningful subgroup modification by median-split feature_004.`, int025004, 'Additive interaction z-test for feature_025 and median-split feature_004.')]
+  },
