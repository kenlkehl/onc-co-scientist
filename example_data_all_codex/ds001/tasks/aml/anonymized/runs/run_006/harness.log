+    analyses: [rec('h34', `The feature_025-by-feature_027_level_2 additive interaction was ${fmtPct(int025027.effect)}, indicating no statistically significant modification.`, int025027, 'Additive interaction z-test for feature_025 and feature_027 level 2.')]
+  },
