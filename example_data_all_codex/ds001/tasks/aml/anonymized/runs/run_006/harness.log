+function standardize(x) {
+  const m = mean(x);
+  const s = sd(x);
+  return x.map((v) => (v - m) / s);
+}
+
+function product(a, b) {
+  return a.map((v, i) => v * b[i]);
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error('Singular matrix');
+    [m[i], m[pivot]] = [m[pivot], m[i]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = m[r][i];
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= f * m[i][c];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function matVec(m, v) {
+  return m.map((row) => row.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function matMul(a, b) {
+  const out = Array.from({ length: a.length }, () => Array(b[0].length).fill(0));
+  for (let i = 0; i < a.length; i++) {
+    for (let k = 0; k < b.length; k++) {
+      for (let j = 0; j < b[0].length; j++) out[i][j] += a[i][k] * b[k][j];
+    }
+  }
+  return out;
+}
+
+function ols(y, specs) {
+  const n = y.length;
+  const p = specs.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...specs.map((s) => s.values[i])];
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = 0; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = matVec(inv, xty);
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...specs.map((s) => s.values[i])];
+    const fit = row.reduce((s, x, j) => s + x * beta[j], 0);
+    const e2 = (y[i] - fit) * (y[i] - fit);
+    for (let j = 0; j < p; j++) for (let k = 0; k < p; k++) meat[j][k] += e2 * row[j] * row[k];
+  }
+  const robust = matMul(matMul(inv, meat), inv);
+  const rows = [{ name: 'intercept', coef: beta[0], se: Math.sqrt(robust[0][0]), p: normalP(beta[0] / Math.sqrt(robust[0][0])) }];
+  for (let j = 1; j < p; j++) {
+    const se = Math.sqrt(robust[j][j]);
+    rows.push({ name: specs[j - 1].name, coef: beta[j], se, p: normalP(beta[j] / se) });
+  }
+  return rows;
+}
