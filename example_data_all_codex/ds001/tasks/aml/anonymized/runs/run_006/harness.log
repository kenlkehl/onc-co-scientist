+function fmtPct(x, digits = 1) {
+  return `${(100 * x).toFixed(digits)}%`;
+}
+
+function rec(ids, summary, stat, code) {
+  return {
+    hypothesis_ids: Array.isArray(ids) ? ids : [ids],
+    code,
+    result_summary: summary,
+    p_value: Number(stat.p.toPrecision(10)),
+    effect_estimate: Number(stat.effect.toPrecision(10)),
+    significant: stat.p < 0.05,
+  };
