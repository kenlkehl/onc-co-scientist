+      values.push(body.readInt32LE(p));
+      p += 4;
+    } else {
+      throw new Error(`Unsupported plain dictionary type ${type}`);
+    }
+  }
+  return values;
+}
+
+function readVarintAt(buf, p) {
+  let result = 0;
+  let shift = 0;
+  while (true) {
+    const b = buf[p++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return [result, p];
+}
+
+function decodeHybrid(buf, bitWidth, expected) {
+  if (bitWidth === 0) return Array(expected).fill(0);
+  let p = 0;
+  const out = [];
+  while (out.length < expected && p < buf.length) {
+    let header;
+    [header, p] = readVarintAt(buf, p);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const bytes = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < bytes; i++) value |= buf[p++] << (8 * i);
+      for (let i = 0; i < run && out.length < expected; i++) out.push(value);
+    } else {
+      const count = (header >> 1) * 8;
+      let bitOffset = 0;
+      for (let i = 0; i < count && out.length < expected; i++) {
+        let value = 0;
+        for (let j = 0; j < bitWidth; j++) {
+          const bi = bitOffset + j;
+          value |= ((buf[p + (bi >> 3)] >> (bi & 7)) & 1) << j;
+        }
+        out.push(value);
+        bitOffset += bitWidth;
+      }
+      p += Math.ceil(count * bitWidth / 8);
+    }
+  }
+  return out;
+}
+
+function readParquet(path) {
+  const buf = fs.readFileSync(path);
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const metaBuf = buf.subarray(buf.length - 8 - footerLen, buf.length - 8);
+  const meta = convertThrift(new CompactReader(metaBuf).readStruct());
+  const schema = meta[2];
+  const rowGroup = meta[4][0];
+  const cols = rowGroup[1];
+  const names = schema.slice(1).map((s) => s[4]);
+  function decodeColumn(j) {
+    const md = cols[j][3];
+    const type = md[1];
+    const total = md[5];
+    let dict = null;
+    if (md[11] == null) throw new Error(`Column ${names[j]} lacks dictionary page`);
+    {
