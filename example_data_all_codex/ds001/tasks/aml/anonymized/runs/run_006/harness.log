+    proposed_hypotheses: [{ id: 'h30', text: '`feature_040` and `feature_046` interact positively: the combined `feature_040=1` and `feature_046=1` subgroup has a higher `objective_response` rate than expected from adding their separate risk differences.', kind: 'novel' }],
+    analyses: [rec('h30', `The feature_040-by-feature_046 additive interaction was ${fmtPct(interaction2(data.feature_040, data.feature_046, y).effect)}; the double-positive cell response was ${fmtPct(interaction2(data.feature_040, data.feature_046, y).rate[3])}.`, interaction2(data.feature_040, data.feature_046, y), 'Exploratory additive interaction z-test over binary feature pairs.')]
+  },
+  {
+    index: 21,
+    proposed_hypotheses: [{ id: 'h31', text: '`feature_050` and `feature_071` interact negatively: the combined `feature_050=1` and `feature_071=1` subgroup has a lower `objective_response` rate than expected from adding their separate risk differences.', kind: 'novel' }],
+    analyses: [rec('h31', `The feature_050-by-feature_071 additive interaction was ${fmtPct(interaction2(data.feature_050, data.feature_071, y).effect)}; the double-positive cell response was ${fmtPct(interaction2(data.feature_050, data.feature_071, y).rate[3])}.`, interaction2(data.feature_050, data.feature_071, y), 'Exploratory additive interaction z-test over binary feature pairs.')]
+  },
+  {
+    index: 22,
+    proposed_hypotheses: [{ id: 'h32', text: '`feature_005` and `feature_013` interact negatively: the combined `feature_005=1` and `feature_013=1` subgroup has a lower `objective_response` rate than expected from adding their separate risk differences.', kind: 'novel' }],
+    analyses: [rec('h32', `The feature_005-by-feature_013 additive interaction was ${fmtPct(int005013.effect)}, but the evidence did not reach p<0.05.`, int005013, 'Exploratory additive interaction z-test over binary feature pairs.')]
+  },
