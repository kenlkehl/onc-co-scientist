+      rec('h27', `At feature_053 >= ${q053.toFixed(2)}, response was ${fmtPct(high053Q.p1)} versus ${fmtPct(high053Q.p0)} below that threshold (risk difference ${fmtPct(high053Q.effect)}).`, high053Q, 'Two-proportion z-test using the top quartile threshold of feature_053.')
+    ]
