+    ],
+    analyses: [
+      rec('h28', `Response was ${fmtPct(bin.feature_005.p1)} with feature_005=1 versus ${fmtPct(bin.feature_005.p0)} with feature_005=0 (risk difference ${fmtPct(bin.feature_005.effect)}).`, bin.feature_005, 'Two-proportion z-test of objective_response by feature_005.'),
+      rec('h29', `Response was ${fmtPct(bin.feature_074.p1)} with feature_074=1 versus ${fmtPct(bin.feature_074.p0)} with feature_074=0 (risk difference ${fmtPct(bin.feature_074.effect)}).`, bin.feature_074, 'Two-proportion z-test of objective_response by feature_074.')
+    ]
