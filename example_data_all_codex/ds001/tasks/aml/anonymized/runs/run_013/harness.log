+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(M[r][col]) > Math.abs(M[pivot][col])) pivot = r;
+    [M[col], M[pivot]] = [M[pivot], M[col]];
+    const div = M[col][col];
+    if (Math.abs(div) < 1e-12) throw new Error("singular matrix");
+    for (let j = col; j <= n; j++) M[col][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = M[r][col];
+      for (let j = col; j <= n; j++) M[r][j] -= f * M[col][j];
+    }
+  }
+  return M.map(row => row[n]);
+}
+function invert(A) {
+  const n = A.length;
+  const inv = [];
+  for (let k = 0; k < n; k++) {
+    const e = Array(n).fill(0);
+    e[k] = 1;
+    inv.push(solve(A, e));
+  }
+  const out = Array.from({ length: n }, () => Array(n).fill(0));
+  for (let c = 0; c < n; c++) for (let r = 0; r < n; r++) out[r][c] = inv[c][r];
+  return out;
+}
+function ols(colsSpec) {
+  const p = colsSpec.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < N; i++) {
+    const row = [1, ...colsSpec.map(c => c.values[i])];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const beta = solve(xtx, xty);
+  let sse = 0;
+  for (let i = 0; i < N; i++) {
+    const pred = beta[0] + colsSpec.reduce((acc, c, j) => acc + beta[j + 1] * c.values[i], 0);
+    const r = y[i] - pred;
+    sse += r * r;
+  }
+  const sigma2 = sse / (N - p);
+  const inv = invert(xtx);
+  const se = beta.map((_, i) => Math.sqrt(Math.max(inv[i][i] * sigma2, 0)));
+  const pvals = beta.map((b, i) => normalP(b / se[i]));
+  const out = { beta, se, pvals, names: ["intercept", ...colsSpec.map(c => c.name)] };
+  out.get = name => {
+    const idx = out.names.indexOf(name);
+    return { beta: beta[idx], se: se[idx], pValue: pvals[idx] };
+  };
+  return out;
+}
