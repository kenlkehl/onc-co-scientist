  i64() { const n = this.varint(); return Number((n >> 1n) ''^ (-(n & 1n))); }
  bin() { const n = Number(this.varint()); const v = this.b.slice(this.o, this.o + n); this.o += n; return v; }
  dbl() { const v = this.b.readDoubleLE(this.o); this.o += 8; return v; }
  struct() {
