+class CompactReader {
+  constructor(b, o = 0) {
+    this.b = b;
+    this.o = o;
+    this.stack = [];
+  }
+  byte() { return this.b[this.o++]; }
+  varint() {
+    let x = 0n, s = 0n;
+    while (true) {
+      const b = this.byte();
+      x |= BigInt(b & 127) << s;
+      if (!(b & 128)) break;
+      s += 7n;
+    }
+    return x;
+  }
+  zig(n) { return Number((n >> 1n) ^ (-(n & 1n))); }
+  i32() { return this.zig(this.varint()); }
+  i64() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  bin() {
+    const n = Number(this.varint());
+    const v = this.b.slice(this.o, this.o + n);
+    this.o += n;
+    return v;
+  }
+  dbl() {
+    const v = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return v;
+  }
+  struct() {
+    this.stack.push(0);
+    const obj = {};
+    while (true) {
+      const h = this.byte();
+      if (h === 0) break;
+      const t = h & 15;
+      const d = h >> 4;
+      const fid = d === 0 ? this.i32() : this.stack[this.stack.length - 1] + d;
+      this.stack[this.stack.length - 1] = fid;
+      obj[fid] = this.val(t);
+    }
+    this.stack.pop();
+    return obj;
+  }
+  list() {
+    let h = this.byte();
+    let n = h >> 4;
+    const t = h & 15;
+    if (n === 15) n = Number(this.varint());
+    const a = [];
+    for (let i = 0; i < n; i++) a.push(this.val(t));
+    return a;
+  }
+  val(t) {
+    switch (t) {
+      case 1: return true;
+      case 2: return false;
+      case 3: return this.byte();
+      case 4:
+      case 5: return this.i32();
+      case 6: return this.i64();
+      case 7: return this.dbl();
+      case 8: return this.bin();
+      case 9: return this.list();
+      case 12: return this.struct();
+      default: throw new Error(`compact type ${t} at ${this.o}`);
+    }
