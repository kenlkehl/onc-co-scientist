  }
  list() { let h = this.byte(); let n = h >> 4, t = h & 15; if (n === 15) n = Number(this.varint()); const a = []; for (let i = 0; i < n; i++) a.push(this.val(t)); return a; }
  val(t) {
    switch (t) {
