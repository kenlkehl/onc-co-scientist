function modelAnalysis(hid, label, codeLabel) {
  const r = fullModel[label];
  return analysis(hid, r, "'`Adjusted linear probability model coefficient for ${label}: ${num(r.effect)} (robust SE ${num(r.se)}, p=${num(r.p)}).`, codeLabel);
}
