+function readPageHeader(off) {
+  const c = new Compact(buf, off, 10000);
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = c.i32();
+    else if (f.id === 2) out.uncompressed_page_size = c.i32();
+    else if (f.id === 3) out.compressed_page_size = c.i32();
