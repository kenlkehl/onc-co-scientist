+const fs = require('fs');
+
+const parquetPath = 'dataset.parquet';
+const buf = fs.readFileSync(parquetPath);
+
+function readU32LE(b, o) {
+  return b[o] | (b[o + 1] << 8) | (b[o + 2] << 16) | (b[o + 3] << 24);
+}
+
+class Compact {
+  constructor(buffer, off = 0, len = buffer.length - off) {
+    this.buf = buffer;
+    this.off = off;
+    this.end = off + len;
+    this.fieldStack = [];
+    this.lastField = 0;
+  }
+
+  byte() {
+    if (this.off >= this.end) throw new Error(`EOF at ${this.off}`);
+    return this.buf[this.off++];
+  }
+
+  varint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if (!(b & 0x80)) break;
+      shift += 7;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  i32() {
+    return this.zigzag(this.varint());
+  }
+
+  i64() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  bin() {
+    const n = Number(this.varint());
+    const out = this.buf.slice(this.off, this.off + n);
+    this.off += n;
+    return out;
+  }
+
+  dbl() {
+    const v = this.buf.readDoubleLE(this.off);
+    this.off += 8;
+    return v;
+  }
+
+  beginStruct() {
+    this.fieldStack.push(this.lastField);
+    this.lastField = 0;
+  }
+
+  endStruct() {
+    this.lastField = this.fieldStack.pop() ?? 0;
+  }
+
+  field() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === 0) return { type: 0, id: null };
+    const delta = h >> 4;
+    const id = delta === 0 ? this.i32() : this.lastField + delta;
+    this.lastField = id;
+    return { type, id };
+  }
+
+  listHeader() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    let size = h >> 4;
+    if (size === 15) size = Number(this.varint());
+    return { type, size };
+  }
+
+  skip(type) {
+    switch (type) {
+      case 0:
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.byte();
+        return;
+      case 4:
+      case 5:
+        this.i32();
+        return;
+      case 6:
+        this.i64();
+        return;
+      case 7:
+        this.dbl();
+        return;
+      case 8:
+        this.bin();
+        return;
+      case 9:
+      case 10: {
+        const lh = this.listHeader();
+        for (let i = 0; i < lh.size; i++) this.skip(lh.type);
+        return;
+      }
+      case 11: {
+        const keyVal = this.byte();
+        const size = Number(this.varint());
+        const kt = (keyVal >> 4) & 0x0f;
+        const vt = keyVal & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12:
+        this.beginStruct();
+        while (true) {
+          const f = this.field();
+          if (f.type === 0) break;
+          this.skip(f.type);
+        }
+        this.endStruct();
+        return;
+      default:
+        throw new Error(`Unknown thrift type ${type}`);
+    }
+  }
+}
+
+function readString(c) {
+  return c.bin().toString('utf8');
+}
+
+function readSchemaElement(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = c.i32();
+    else if (f.id === 2) out.type_length = c.i32();
+    else if (f.id === 3) out.repetition_type = c.i32();
+    else if (f.id === 4) out.name = readString(c);
+    else if (f.id === 5) out.num_children = c.i32();
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
+}
+
+function readColumnMetaData(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = c.i32();
+    else if (f.id === 2) {
+      const lh = c.listHeader();
+      out.encodings = [];
+      for (let i = 0; i < lh.size; i++) out.encodings.push(c.i32());
+    } else if (f.id === 3) {
+      const lh = c.listHeader();
+      out.path_in_schema = [];
+      for (let i = 0; i < lh.size; i++) out.path_in_schema.push(readString(c));
+    } else if (f.id === 4) out.codec = c.i32();
+    else if (f.id === 5) out.num_values = c.i64();
+    else if (f.id === 6) out.total_uncompressed_size = c.i64();
+    else if (f.id === 7) out.total_compressed_size = c.i64();
+    else if (f.id === 9) out.data_page_offset = c.i64();
+    else if (f.id === 11) out.dictionary_page_offset = c.i64();
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
+}
+
+function readColumnChunk(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 3) out.meta_data = readColumnMetaData(c);
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
+}
+
+function readRowGroup(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) {
+      const lh = c.listHeader();
+      out.columns = [];
+      for (let i = 0; i < lh.size; i++) out.columns.push(readColumnChunk(c));
+    } else if (f.id === 3) out.num_rows = c.i64();
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
+}
+
+function readFileMeta(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 2) {
+      const lh = c.listHeader();
+      out.schema = [];
+      for (let i = 0; i < lh.size; i++) out.schema.push(readSchemaElement(c));
+    } else if (f.id === 3) out.num_rows = c.i64();
+    else if (f.id === 4) {
+      const lh = c.listHeader();
+      out.row_groups = [];
+      for (let i = 0; i < lh.size; i++) out.row_groups.push(readRowGroup(c));
+    } else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
+}
+
+function readDataPageHeader(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.num_values = c.i32();
+    else if (f.id === 2) out.encoding = c.i32();
+    else if (f.id === 3) out.definition_level_encoding = c.i32();
+    else if (f.id === 4) out.repetition_level_encoding = c.i32();
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
+}
+
+function readDictPageHeader(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.num_values = c.i32();
+    else if (f.id === 2) out.encoding = c.i32();
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
+}
+
+function readPageHeader(off) {
+  const c = new Compact(buf, off, 10000);
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = c.i32();
+    else if (f.id === 2) out.uncompressed_page_size = c.i32();
+    else if (f.id === 3) out.compressed_page_size = c.i32();
+    else if (f.id === 5) out.data_page_header = readDataPageHeader(c);
+    else if (f.id === 7) out.dictionary_page_header = readDictPageHeader(c);
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  out.header_end = c.off;
+  return out;
+}
+
+function snappyUncompress(src) {
+  let pos = 0;
+  function readVar() {
+    let shift = 0;
+    let n = 0;
+    while (true) {
+      const b = src[pos++];
+      n |= (b & 0x7f) << shift;
+      if (!(b & 0x80)) break;
+      shift += 7;
+    }
+    return n;
+  }
+  const outLen = readVar();
+  const out = Buffer.alloc(outLen);
+  let outp = 0;
+  while (pos < src.length) {
+    const tag = src[pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) len += 1;
+      else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= src[pos++] << (8 * i);
+        len += 1;
+      }
+      src.copy(out, outp, pos, pos + len);
+      pos += len;
+      outp += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 7) + 4;
+        offset = src[pos++] | ((tag & 0xe0) << 3);
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = src[pos] | (src[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = (src[pos] | (src[pos + 1] << 8) | (src[pos + 2] << 16) | (src[pos + 3] << 24)) >>> 0;
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) out[outp + i] = out[outp - offset + i];
+      outp += len;
+    }
+  }
+  if (outp !== outLen) throw new Error(`Snappy length mismatch ${outp} != ${outLen}`);
+  return out;
+}
+
+function readPlainDictionary(type, data, n) {
+  const vals = new Array(n);
+  let p = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === 2) {
+      vals[i] = Number(data.readBigInt64LE(p));
+      p += 8;
+    } else if (type === 5) {
+      vals[i] = data.readDoubleLE(p);
+      p += 8;
+    } else if (type === 6) {
+      const len = data.readInt32LE(p);
+      p += 4 + len;
+      vals[i] = i;
+    } else throw new Error(`Unsupported plain dictionary type ${type}`);
+  }
+  return vals;
+}
+
+function readUVar(data, state) {
+  let shift = 0;
+  let n = 0;
+  while (true) {
+    const b = data[state.p++];
+    n |= (b & 0x7f) << shift;
+    if (!(b & 0x80)) break;
+    shift += 7;
+  }
+  return n;
+}
+
+function readPacked(data, state, bitWidth, count, out, dict, outOffset, needed) {
+  let bitbuf = 0;
+  let bits = 0;
+  let written = 0;
+  const mask = bitWidth === 32 ? 0xffffffff : ((1 << bitWidth) - 1);
+  for (let i = 0; i < count; i++) {
+    while (bits < bitWidth) {
+      bitbuf |= data[state.p++] << bits;
+      bits += 8;
+    }
+    if (written < needed) out[outOffset + written] = dict[bitbuf & mask];
+    written++;
+    bitbuf >>>= bitWidth;
+    bits -= bitWidth;
+  }
+  return Math.min(written, needed);
+}
+
+function decodeDictionaryData(data, p, bitWidth, needed, dict, out, outOffset) {
+  const state = { p };
+  const bytes = Math.ceil(bitWidth / 8);
+  let written = 0;
+  while (written < needed && state.p < data.length) {
+    const header = readUVar(data, state);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      let idx = 0;
+      for (let i = 0; i < bytes; i++) idx |= data[state.p++] << (8 * i);
+      const value = dict[idx];
+      const take = Math.min(run, needed - written);
+      for (let i = 0; i < take; i++) out[outOffset + written + i] = value;
+      written += take;
+    } else {
+      const groups = header >> 1;
+      written += readPacked(data, state, bitWidth, groups * 8, out, dict, outOffset + written, needed - written);
+    }
+  }
+  return written;
+}
+
+const footerLen = readU32LE(buf, buf.length - 8);
+const meta = readFileMeta(new Compact(buf, buf.length - 8 - footerLen, footerLen));
+const schema = {};
+for (const s of meta.schema.slice(1)) schema[s.name] = s;
+const columnMeta = {};
+for (const cc of meta.row_groups[0].columns) columnMeta[cc.meta_data.path_in_schema[0]] = cc.meta_data;
+
+function readColumn(name) {
+  const m = columnMeta[name];
+  const type = schema[name].type;
+  const dictHdr = readPageHeader(m.dictionary_page_offset);
+  const dictCompressed = buf.slice(dictHdr.header_end, dictHdr.header_end + dictHdr.compressed_page_size);
+  const dict = readPlainDictionary(type, snappyUncompress(dictCompressed), dictHdr.dictionary_page_header.num_values);
+  const out = new Float64Array(m.num_values);
+  let valuesRead = 0;
+  let off = m.data_page_offset;
+  while (valuesRead < m.num_values) {
+    const page = readPageHeader(off);
+    if (page.type !== 0) throw new Error(`Unexpected page type ${page.type} in ${name}`);
+    const data = snappyUncompress(buf.slice(page.header_end, page.header_end + page.compressed_page_size));
+    let p = 0;
+    const defLen = data.readInt32LE(p);
+    p += 4 + defLen;
+    const bitWidth = data[p++];
+    valuesRead += decodeDictionaryData(data, p, bitWidth, page.data_page_header.num_values, dict, out, valuesRead);
+    off = page.header_end + page.compressed_page_size;
+  }
+  return out;
+}
+
+const names = Object.keys(columnMeta).filter((x) => x !== 'patient_id');
+const df = {};
+for (const name of names) df[name] = readColumn(name);
+const y = df.objective_response;
+const n = y.length;
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const yy = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * yy;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function mean(a) {
+  let s = 0;
+  for (let i = 0; i < a.length; i++) s += a[i];
+  return s / a.length;
+}
+
+function sd(a) {
+  const m = mean(a);
+  let s = 0;
+  for (let i = 0; i < a.length; i++) {
+    const d = a[i] - m;
+    s += d * d;
+  }
+  return Math.sqrt(s / (a.length - 1));
+}
+
+function twoGroup(feature, maskFn = null) {
+  const x = df[feature];
+  let n1 = 0, n0 = 0, y1 = 0, y0 = 0;
+  for (let i = 0; i < n; i++) {
+    if (maskFn && !maskFn(i)) continue;
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p1 = y1 / n1;
+  const p0 = y0 / n0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  return { feature, n1, n0, p1, p0, rd: p1 - p0, p: pFromZ((p1 - p0) / se) };
+}
+
+function contZ(feature) {
+  const x = df[feature];
+  const mx = mean(x);
+  const sx = sd(x);
+  let sxy = 0, sxx = 0;
+  const my = mean(y);
+  for (let i = 0; i < n; i++) {
+    const z = (x[i] - mx) / sx;
+    sxy += z * (y[i] - my);
+    sxx += z * z;
+  }
+  const beta = sxy / sxx;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    const z = (x[i] - mx) / sx;
+    const e = y[i] - (my + beta * z);
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  return { feature, beta, p: pFromZ(beta / se), mean: mx, sd: sx };
+}
+
+function invert(a) {
+  const m = a.length;
+  const aug = new Array(m);
+  for (let i = 0; i < m; i++) {
+    aug[i] = new Array(2 * m).fill(0);
+    for (let j = 0; j < m; j++) aug[i][j] = a[i][j];
+    aug[i][m + i] = 1;
+  }
+  for (let col = 0; col < m; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < m; r++) if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const div = aug[col][col];
+    for (let j = 0; j < 2 * m; j++) aug[col][j] /= div;
+    for (let r = 0; r < m; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * m; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(m));
+}
+
+function matVec(mat, vec) {
+  return mat.map((row) => row.reduce((s, v, i) => s + v * vec[i], 0));
+}
+
+const stdCache = {};
+function stdCol(name) {
+  if (!stdCache[name]) {
+    const x = df[name];
+    const mx = mean(x);
+    const sx = sd(x);
+    const z = new Float64Array(n);
+    for (let i = 0; i < n; i++) z[i] = (x[i] - mx) / sx;
+    stdCache[name] = z;
+  }
+  return stdCache[name];
+}
+
+function ols(terms, maskFn = null) {
+  const idx = [];
+  for (let i = 0; i < n; i++) if (!maskFn || maskFn(i)) idx.push(i);
+  terms = terms.filter((t) => {
+    let min = Infinity;
+    let max = -Infinity;
+    for (const i of idx) {
+      const v = t.values[i];
+      if (v < min) min = v;
+      if (v > max) max = v;
+    }
+    return max - min > 1e-12;
+  });
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  const row = new Array(p);
+  for (const i of idx) {
+    row[0] = 1;
+    for (let j = 0; j < terms.length; j++) row[j + 1] = terms[j].values[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invert(xtx);
+  const beta = matVec(inv, xty);
+  const meat = Array.from({ length: p }, () => new Array(p).fill(0));
+  for (const i of idx) {
+    row[0] = 1;
+    for (let j = 0; j < terms.length; j++) row[j + 1] = terms[j].values[i];
+    let fit = 0;
+    for (let a = 0; a < p; a++) fit += row[a] * beta[a];
+    const e2 = (y[i] - fit) ** 2;
+    for (let a = 0; a < p; a++) {
