+    for (let r = 0; r < m; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * m; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(m));
+}
+
+function matVec(mat, vec) {
+  return mat.map((row) => row.reduce((s, v, i) => s + v * vec[i], 0));
+}
+
+const stdCache = {};
+function stdCol(name) {
+  if (!stdCache[name]) {
+    const x = df[name];
+    const mx = mean(x);
+    const sx = sd(x);
+    const z = new Float64Array(n);
+    for (let i = 0; i < n; i++) z[i] = (x[i] - mx) / sx;
+    stdCache[name] = z;
+  }
+  return stdCache[name];
+}
+
+function ols(terms, maskFn = null) {
+  const idx = [];
+  for (let i = 0; i < n; i++) if (!maskFn || maskFn(i)) idx.push(i);
+  terms = terms.filter((t) => {
+    let min = Infinity;
+    let max = -Infinity;
+    for (const i of idx) {
+      const v = t.values[i];
+      if (v < min) min = v;
+      if (v > max) max = v;
+    }
+    return max - min > 1e-12;
+  });
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  const row = new Array(p);
+  for (const i of idx) {
+    row[0] = 1;
+    for (let j = 0; j < terms.length; j++) row[j + 1] = terms[j].values[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invert(xtx);
+  const beta = matVec(inv, xty);
+  const meat = Array.from({ length: p }, () => new Array(p).fill(0));
+  for (const i of idx) {
+    row[0] = 1;
+    for (let j = 0; j < terms.length; j++) row[j + 1] = terms[j].values[i];
+    let fit = 0;
+    for (let a = 0; a < p; a++) fit += row[a] * beta[a];
+    const e2 = (y[i] - fit) ** 2;
+    for (let a = 0; a < p; a++) {
+      for (let b = 0; b < p; b++) meat[a][b] += row[a] * row[b] * e2;
+    }
+  }
+  const tmp = Array.from({ length: p }, () => new Array(p).fill(0));
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) for (let k = 0; k < p; k++) tmp[i][j] += inv[i][k] * meat[k][j];
+  const vcov = Array.from({ length: p }, () => new Array(p).fill(0));
+  const scale = idx.length / (idx.length - p);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) for (let k = 0; k < p; k++) vcov[i][j] += tmp[i][k] * inv[k][j] * scale;
+  return {
+    n: idx.length,
+    beta,
+    se: vcov.map((row, i) => Math.sqrt(Math.max(0, row[i]))),
+    names: ['Intercept'].concat(terms.map((t) => t.name)),
+  };
+}
+
+function term(name, values = null) {
+  return { name, values: values || df[name] };
+}
+
+function interactionTerm(a, b, name = `${a}:${b}`) {
+  const v = new Float64Array(n);
+  const x = df[a], z = df[b];
+  for (let i = 0; i < n; i++) v[i] = x[i] * z[i];
+  return { name, values: v };
+}
+
+const baseTerms = [
+  { name: 'age_years_z', values: stdCol('age_years') },
+  term('sex_female'),
+  { name: 'ecog_ps_z', values: stdCol('ecog_ps') },
+  term('secondary_aml'),
+  term('unfit_for_intensive'),
+  term('complex_karyotype'),
+  term('tp53_mutation'),
+  term('npm1_mutation'),
+  term('flt3_itd'),
+  term('flt3_tkd'),
+  term('idh1_mutation'),
+  term('idh2_mutation'),
+  { name: 'wbc_k_per_ul_z', values: stdCol('wbc_k_per_ul') },
+  { name: 'blast_pct_marrow_z', values: stdCol('blast_pct_marrow') },
+  { name: 'albumin_g_dl_z', values: stdCol('albumin_g_dl') },
+  { name: 'ldh_u_l_z', values: stdCol('ldh_u_l') },
+  { name: 'crp_mg_l_z', values: stdCol('crp_mg_l') },
+  { name: 'nlr_z', values: stdCol('nlr') },
+  term('treatment_midostaurin'),
+  term('treatment_gilteritinib'),
+  term('treatment_ivosidenib'),
+  term('treatment_enasidenib'),
+  term('treatment_venetoclax_azacitidine'),
+  term('treatment_7plus3'),
+];
+
+const clinicalTerms = baseTerms.filter((t) => !t.name.startsWith('treatment_'));
+
+function adjustedOne(name, values = null, extraTerms = []) {
+  const omit = new Set([name]);
+  const terms = [term(name, values)].concat(baseTerms.filter((t) => !omit.has(t.name)), extraTerms);
+  const res = ols(terms);
+  const j = res.names.indexOf(name);
+  const beta = res.beta[j], se = res.se[j];
+  return { name, beta, p: pFromZ(beta / se), se, n: res.n };
+}
+
+function adjustedInteraction(treat, marker) {
+  const inter = interactionTerm(treat, marker);
+  const terms = [term(treat), term(marker), inter].concat(clinicalTerms.filter((t) => ![marker].includes(t.name)));
+  const res = ols(terms);
+  const j = res.names.indexOf(inter.name);
+  return { treat, marker, beta: res.beta[j], se: res.se[j], p: pFromZ(res.beta[j] / res.se[j]), n: res.n };
+}
+
+function adjustedSubgroupTreatment(treat, marker) {
+  const terms = [term(treat)].concat(clinicalTerms.filter((t) => t.name !== marker));
+  const res = ols(terms, (i) => df[marker][i] === 1);
+  const j = res.names.indexOf(treat);
+  return { treat, marker, beta: res.beta[j], se: res.se[j], p: pFromZ(res.beta[j] / res.se[j]), n: res.n };
+}
+
+function fmt(x) {
+  if (x === 0) return '0';
+  if (Math.abs(x) < 1e-4) return x.toExponential(3);
+  return x.toFixed(6);
+}
+
+console.log('n', n, 'overall_response', mean(y));
+const binary = names.filter((name) => name !== 'objective_response' && new Set(df[name]).size <= 8 && Array.from(new Set(df[name])).every((v) => Number.isInteger(v)));
+const continuous = names.filter((name) => name !== 'objective_response' && !binary.includes(name));
+
+console.log('\\nTop crude binary effects');
+twoBinary = binary.map((b) => twoGroup(b)).sort((a, b) => Math.abs(b.rd) - Math.abs(a.rd));
+for (const r of twoBinary.slice(0, 25)) console.log(r.feature, 'rd', fmt(r.rd), 'p', fmt(r.p), 'p1', fmt(r.p1), 'p0', fmt(r.p0), 'n1', r.n1);
+
+console.log('\\nTop continuous z effects');
+const cont = continuous.map((c) => contZ(c)).sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta));
+for (const r of cont.slice(0, 25)) console.log(r.feature, 'beta_per_sd', fmt(r.beta), 'p', fmt(r.p), 'mean', fmt(r.mean), 'sd', fmt(r.sd));
+
+console.log('\\nAdjusted selected main effects');
+for (const name of ['tp53_mutation','npm1_mutation','flt3_itd','flt3_tkd','idh1_mutation','idh2_mutation','complex_karyotype','secondary_aml','unfit_for_intensive','treatment_midostaurin','treatment_gilteritinib','treatment_ivosidenib','treatment_enasidenib','treatment_venetoclax_azacitidine','treatment_7plus3']) {
+  const r = adjustedOne(name);
+  console.log(name, 'beta', fmt(r.beta), 'p', fmt(r.p));
+}
+for (const name of ['albumin_g_dl','ldh_u_l','crp_mg_l','nlr','wbc_k_per_ul','blast_pct_marrow','hemoglobin_g_dl','platelets_k_ul','age_years']) {
+  const r = adjustedOne(`${name}_z`, stdCol(name));
+  console.log(`${name}_z`, 'beta', fmt(r.beta), 'p', fmt(r.p));
+}
+
+console.log('\\nTargeted subgroup treatment effects');
+for (const [t, m] of [
+  ['treatment_midostaurin','flt3_itd'],
+  ['treatment_midostaurin','flt3_tkd'],
+  ['treatment_gilteritinib','flt3_itd'],
+  ['treatment_gilteritinib','flt3_tkd'],
+  ['treatment_ivosidenib','idh1_mutation'],
+  ['treatment_enasidenib','idh2_mutation'],
+  ['treatment_venetoclax_azacitidine','unfit_for_intensive'],
+  ['treatment_7plus3','unfit_for_intensive'],
+]) {
+  const crude = twoGroup(t, (i) => df[m][i] === 1);
+  const adj = adjustedSubgroupTreatment(t, m);
+  console.log(`${t} within ${m}=1`, 'crude_rd', fmt(crude.rd), 'crude_p', fmt(crude.p), 'adj_beta', fmt(adj.beta), 'adj_p', fmt(adj.p), 'n', adj.n, 'treated', crude.n1);
+}
+
+console.log('\\nTargeted interactions');
+for (const [t, m] of [
+  ['treatment_midostaurin','flt3_itd'],
+  ['treatment_midostaurin','flt3_tkd'],
+  ['treatment_gilteritinib','flt3_itd'],
+  ['treatment_gilteritinib','flt3_tkd'],
+  ['treatment_ivosidenib','idh1_mutation'],
+  ['treatment_enasidenib','idh2_mutation'],
+  ['treatment_venetoclax_azacitidine','unfit_for_intensive'],
+  ['treatment_7plus3','unfit_for_intensive'],
+  ['treatment_venetoclax_azacitidine','tp53_mutation'],
+  ['treatment_7plus3','tp53_mutation'],
+]) {
+  const r = adjustedInteraction(t, m);
+  console.log(`${t}:${m}`, 'int_beta', fmt(r.beta), 'p', fmt(r.p));
+}

