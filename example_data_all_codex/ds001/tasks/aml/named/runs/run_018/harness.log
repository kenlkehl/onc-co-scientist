+  let bits = 0;
+  let written = 0;
+  const mask = bitWidth === 32 ? 0xffffffff : ((1 << bitWidth) - 1);
+  for (let i = 0; i < count; i++) {
+    while (bits < bitWidth) {
+      bitbuf |= data[state.p++] << bits;
+      bits += 8;
+    }
+    if (written < needed) out[outOffset + written] = dict[bitbuf & mask];
+    written++;
+    bitbuf >>>= bitWidth;
+    bits -= bitWidth;
+  }
+  return Math.min(written, needed);
+}
+
+function decodeDictionaryData(data, p, bitWidth, needed, dict, out, outOffset) {
+  const state = { p };
+  const bytes = Math.ceil(bitWidth / 8);
+  let written = 0;
+  while (written < needed && state.p < data.length) {
+    const header = readUVar(data, state);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      let idx = 0;
+      for (let i = 0; i < bytes; i++) idx |= data[state.p++] << (8 * i);
+      const value = dict[idx];
+      const take = Math.min(run, needed - written);
+      for (let i = 0; i < take; i++) out[outOffset + written + i] = value;
+      written += take;
+    } else {
+      const groups = header >> 1;
+      written += readPacked(data, state, bitWidth, groups * 8, out, dict, outOffset + written, needed - written);
+    }
+  }
+  return written;
+}
+
+const footerLen = readU32LE(buf, buf.length - 8);
+const meta = readFileMeta(new Compact(buf, buf.length - 8 - footerLen, footerLen));
+const schema = {};
+for (const s of meta.schema.slice(1)) schema[s.name] = s;
+const columnMeta = {};
+for (const cc of meta.row_groups[0].columns) columnMeta[cc.meta_data.path_in_schema[0]] = cc.meta_data;
+
+function readColumn(name) {
+  const m = columnMeta[name];
+  const type = schema[name].type;
+  const dictHdr = readPageHeader(m.dictionary_page_offset);
+  const dictCompressed = buf.slice(dictHdr.header_end, dictHdr.header_end + dictHdr.compressed_page_size);
+  const dict = readPlainDictionary(type, snappyUncompress(dictCompressed), dictHdr.dictionary_page_header.num_values);
+  const out = new Float64Array(m.num_values);
+  let valuesRead = 0;
+  let off = m.data_page_offset;
+  while (valuesRead < m.num_values) {
+    const page = readPageHeader(off);
+    if (page.type !== 0) throw new Error(`Unexpected page type ${page.type} in ${name}`);
+    const data = snappyUncompress(buf.slice(page.header_end, page.header_end + page.compressed_page_size));
+    let p = 0;
+    const defLen = data.readInt32LE(p);
+    p += 4 + defLen;
+    const bitWidth = data[p++];
+    valuesRead += decodeDictionaryData(data, p, bitWidth, page.data_page_header.num_values, dict, out, valuesRead);
+    off = page.header_end + page.compressed_page_size;
+  }
+  return out;
+}
+
+const names = Object.keys(columnMeta).filter((x) => x !== 'patient_id');
+const df = {};
+for (const name of names) df[name] = readColumn(name);
+const y = df.objective_response;
+const n = y.length;
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const yy = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * yy;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function mean(a) {
+  let s = 0;
+  for (let i = 0; i < a.length; i++) s += a[i];
+  return s / a.length;
+}
+
+function sd(a) {
+  const m = mean(a);
+  let s = 0;
+  for (let i = 0; i < a.length; i++) {
+    const d = a[i] - m;
+    s += d * d;
+  }
+  return Math.sqrt(s / (a.length - 1));
+}
+
+function twoGroup(feature, maskFn = null) {
+  const x = df[feature];
+  let n1 = 0, n0 = 0, y1 = 0, y0 = 0;
+  for (let i = 0; i < n; i++) {
+    if (maskFn && !maskFn(i)) continue;
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p1 = y1 / n1;
+  const p0 = y0 / n0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  return { feature, n1, n0, p1, p0, rd: p1 - p0, p: pFromZ((p1 - p0) / se) };
+}
+
+function contZ(feature) {
+  const x = df[feature];
+  const mx = mean(x);
+  const sx = sd(x);
+  let sxy = 0, sxx = 0;
+  const my = mean(y);
+  for (let i = 0; i < n; i++) {
+    const z = (x[i] - mx) / sx;
+    sxy += z * (y[i] - my);
+    sxx += z * z;
+  }
+  const beta = sxy / sxx;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    const z = (x[i] - mx) / sx;
+    const e = y[i] - (my + beta * z);
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  return { feature, beta, p: pFromZ(beta / se), mean: mx, sd: sx };
+}
+
+function invert(a) {
+  const m = a.length;
+  const aug = new Array(m);
+  for (let i = 0; i < m; i++) {
+    aug[i] = new Array(2 * m).fill(0);
+    for (let j = 0; j < m; j++) aug[i][j] = a[i][j];
+    aug[i][m + i] = 1;
+  }
+  for (let col = 0; col < m; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < m; r++) if (Math.abs(aug[r][col]) > Math.abs(aug[pivot][col])) pivot = r;
+    if (Math.abs(aug[pivot][col]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const div = aug[col][col];
+    for (let j = 0; j < 2 * m; j++) aug[col][j] /= div;
+    for (let r = 0; r < m; r++) {
+      if (r === col) continue;
+      const f = aug[r][col];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * m; j++) aug[r][j] -= f * aug[col][j];
+    }
+  }
+  return aug.map((row) => row.slice(m));
+}
+
+function matVec(mat, vec) {
+  return mat.map((row) => row.reduce((s, v, i) => s + v * vec[i], 0));
+}
+
+const stdCache = {};
+function stdCol(name) {
+  if (!stdCache[name]) {
+    const x = df[name];
+    const mx = mean(x);
+    const sx = sd(x);
+    const z = new Float64Array(n);
+    for (let i = 0; i < n; i++) z[i] = (x[i] - mx) / sx;
+    stdCache[name] = z;
+  }
+  return stdCache[name];
+}
+
+function ols(terms, maskFn = null) {
+  const idx = [];
+  for (let i = 0; i < n; i++) if (!maskFn || maskFn(i)) idx.push(i);
+  terms = terms.filter((t) => {
+    let min = Infinity;
+    let max = -Infinity;
+    for (const i of idx) {
+      const v = t.values[i];
+      if (v < min) min = v;
+      if (v > max) max = v;
+    }
+    return max - min > 1e-12;
+  });
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  const row = new Array(p);
+  for (const i of idx) {
+    row[0] = 1;
+    for (let j = 0; j < terms.length; j++) row[j + 1] = terms[j].values[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invert(xtx);
+  const beta = matVec(inv, xty);
+  const meat = Array.from({ length: p }, () => new Array(p).fill(0));
+  for (const i of idx) {
+    row[0] = 1;
+    for (let j = 0; j < terms.length; j++) row[j + 1] = terms[j].values[i];
+    let fit = 0;
+    for (let a = 0; a < p; a++) fit += row[a] * beta[a];
+    const e2 = (y[i] - fit) ** 2;
+    for (let a = 0; a < p; a++) {
+      for (let b = 0; b < p; b++) meat[a][b] += row[a] * row[b] * e2;
+    }
+  }
+  const tmp = Array.from({ length: p }, () => new Array(p).fill(0));
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) for (let k = 0; k < p; k++) tmp[i][j] += inv[i][k] * meat[k][j];
+  const vcov = Array.from({ length: p }, () => new Array(p).fill(0));
+  const scale = idx.length / (idx.length - p);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) for (let k = 0; k < p; k++) vcov[i][j] += tmp[i][k] * inv[k][j] * scale;
+  return {
+    n: idx.length,
+    beta,
+    se: vcov.map((row, i) => Math.sqrt(Math.max(0, row[i]))),
+    names: ['Intercept'].concat(terms.map((t) => t.name)),
+  };
+}
+
+function term(name, values = null) {
+  return { name, values: values || df[name] };
+}
+
+function interactionTerm(a, b, name = `${a}:${b}`) {
+  const v = new Float64Array(n);
+  const x = df[a], z = df[b];
+  for (let i = 0; i < n; i++) v[i] = x[i] * z[i];
+  return { name, values: v };
+}
+
+const baseTerms = [
+  { name: 'age_years_z', values: stdCol('age_years') },
+  term('sex_female'),
+  { name: 'ecog_ps_z', values: stdCol('ecog_ps') },
+  term('secondary_aml'),
+  term('unfit_for_intensive'),
+  term('complex_karyotype'),
+  term('tp53_mutation'),
+  term('npm1_mutation'),
+  term('flt3_itd'),
+  term('flt3_tkd'),
+  term('idh1_mutation'),
+  term('idh2_mutation'),
+  { name: 'wbc_k_per_ul_z', values: stdCol('wbc_k_per_ul') },
+  { name: 'blast_pct_marrow_z', values: stdCol('blast_pct_marrow') },
+  { name: 'albumin_g_dl_z', values: stdCol('albumin_g_dl') },
+  { name: 'ldh_u_l_z', values: stdCol('ldh_u_l') },
+  { name: 'crp_mg_l_z', values: stdCol('crp_mg_l') },
+  { name: 'nlr_z', values: stdCol('nlr') },
+  term('treatment_midostaurin'),
+  term('treatment_gilteritinib'),
+  term('treatment_ivosidenib'),
+  term('treatment_enasidenib'),
+  term('treatment_venetoclax_azacitidine'),
+  term('treatment_7plus3'),
+];
+
+const clinicalTerms = baseTerms.filter((t) => !t.name.startsWith('treatment_'));
+
+function adjustedOne(name, values = null, extraTerms = []) {
+  const omit = new Set([name]);
+  const terms = [term(name, values)].concat(baseTerms.filter((t) => !omit.has(t.name)), extraTerms);
