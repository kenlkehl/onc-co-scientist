+function adjustedOne(name, values = null, extraTerms = []) {
+  const omit = new Set([name]);
+  const terms = [term(name, values)].concat(baseTerms.filter((t) => !omit.has(t.name)), extraTerms);
+  const res = ols(terms);
+  const beta = res.beta[1], se = res.se[1];
+  return { name, beta, p: pFromZ(beta / se), se, n: res.n };
