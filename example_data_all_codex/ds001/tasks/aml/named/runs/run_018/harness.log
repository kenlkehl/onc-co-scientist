+const fs = require('fs');
+
+const parquetPath = 'dataset.parquet';
+const buf = fs.readFileSync(parquetPath);
+
+function readU32LE(b, o) {
+  return b[o] | (b[o + 1] << 8) | (b[o + 2] << 16) | (b[o + 3] << 24);
+}
+
+class Compact {
+  constructor(buffer, off = 0, len = buffer.length - off) {
+    this.buf = buffer;
+    this.off = off;
+    this.end = off + len;
+    this.fieldStack = [];
+    this.lastField = 0;
+  }
+
+  byte() {
+    if (this.off >= this.end) throw new Error(`EOF at ${this.off}`);
+    return this.buf[this.off++];
+  }
+
+  varint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if (!(b & 0x80)) break;
+      shift += 7;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  i32() {
+    return this.zigzag(this.varint());
+  }
+
+  i64() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  bin() {
+    const n = Number(this.varint());
+    const out = this.buf.slice(this.off, this.off + n);
+    this.off += n;
+    return out;
+  }
+
+  dbl() {
+    const v = this.buf.readDoubleLE(this.off);
+    this.off += 8;
+    return v;
+  }
+
+  beginStruct() {
+    this.fieldStack.push(this.lastField);
+    this.lastField = 0;
+  }
+
+  endStruct() {
+    this.lastField = this.fieldStack.pop() ?? 0;
+  }
+
+  field() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === 0) return { type: 0, id: null };
+    const delta = h >> 4;
+    const id = delta === 0 ? this.i32() : this.lastField + delta;
+    this.lastField = id;
+    return { type, id };
+  }
+
+  listHeader() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    let size = h >> 4;
+    if (size === 15) size = Number(this.varint());
+    return { type, size };
+  }
+
+  skip(type) {
+    switch (type) {
+      case 0:
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.byte();
+        return;
+      case 4:
+      case 5:
+        this.i32();
+        return;
+      case 6:
+        this.i64();
+        return;
+      case 7:
+        this.dbl();
+        return;
+      case 8:
+        this.bin();
+        return;
+      case 9:
+      case 10: {
+        const lh = this.listHeader();
+        for (let i = 0; i < lh.size; i++) this.skip(lh.type);
+        return;
+      }
+      case 11: {
+        const keyVal = this.byte();
+        const size = Number(this.varint());
+        const kt = (keyVal >> 4) & 0x0f;
+        const vt = keyVal & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12:
+        this.beginStruct();
+        while (true) {
+          const f = this.field();
+          if (f.type === 0) break;
+          this.skip(f.type);
+        }
+        this.endStruct();
+        return;
+      default:
+        throw new Error(`Unknown thrift type ${type}`);
+    }
+  }
+}
+
+function readString(c) {
+  return c.bin().toString('utf8');
+}
+
+function readSchemaElement(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = c.i32();
+    else if (f.id === 2) out.type_length = c.i32();
+    else if (f.id === 3) out.repetition_type = c.i32();
+    else if (f.id === 4) out.name = readString(c);
+    else if (f.id === 5) out.num_children = c.i32();
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
+}
+
+function readColumnMetaData(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = c.i32();
+    else if (f.id === 2) {
+      const lh = c.listHeader();
+      out.encodings = [];
+      for (let i = 0; i < lh.size; i++) out.encodings.push(c.i32());
+    } else if (f.id === 3) {
+      const lh = c.listHeader();
+      out.path_in_schema = [];
+      for (let i = 0; i < lh.size; i++) out.path_in_schema.push(readString(c));
