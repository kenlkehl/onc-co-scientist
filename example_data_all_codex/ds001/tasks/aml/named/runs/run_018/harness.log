+function pFromZ(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function mean(a) {
+  let s = 0;
+  for (let i = 0; i < a.length; i++) s += a[i];
+  return s / a.length;
+}
+
+function sd(a) {
+  const m = mean(a);
+  let s = 0;
+  for (let i = 0; i < a.length; i++) {
+    const d = a[i] - m;
+    s += d * d;
+  }
+  return Math.sqrt(s / (a.length - 1));
+}
+
+function twoGroup(feature, maskFn = null) {
+  const x = df[feature];
+  let n1 = 0, n0 = 0, y1 = 0, y0 = 0;
+  for (let i = 0; i < n; i++) {
+    if (maskFn && !maskFn(i)) continue;
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p1 = y1 / n1;
+  const p0 = y0 / n0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  return { feature, n1, n0, p1, p0, rd: p1 - p0, p: pFromZ((p1 - p0) / se) };
+}
+
+function contZ(feature) {
+  const x = df[feature];
+  const mx = mean(x);
+  const sx = sd(x);
+  let sxy = 0, sxx = 0;
+  const my = mean(y);
+  for (let i = 0; i < n; i++) {
+    const z = (x[i] - mx) / sx;
+    sxy += z * (y[i] - my);
+    sxx += z * z;
+  }
+  const beta = sxy / sxx;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    const z = (x[i] - mx) / sx;
+    const e = y[i] - (my + beta * z);
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
