function readU32LE(b,o){ return b[o] | (b[o+1]<<8) | (b[o+2]<<16) | (b[o+3]<<24); }
class Compact {
  constructor(buf, off=0, len=buf.length-off){ this.buf=buf; this.off=off; this.end=off+len; this.fieldStack=[]; this.lastField=0; }
