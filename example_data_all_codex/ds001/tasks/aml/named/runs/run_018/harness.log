+  term('unfit_for_intensive'),
+  term('complex_karyotype'),
+  term('tp53_mutation'),
+  term('npm1_mutation'),
+  term('flt3_itd'),
+  term('flt3_tkd'),
+  term('idh1_mutation'),
+  term('idh2_mutation'),
