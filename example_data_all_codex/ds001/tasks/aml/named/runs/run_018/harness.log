+function snappyUncompress(src) {
+  let pos = 0;
+  function readVar() {
+    let shift = 0;
+    let n = 0;
+    while (true) {
+      const b = src[pos++];
+      n |= (b & 0x7f) << shift;
+      if (!(b & 0x80)) break;
+      shift += 7;
+    }
+    return n;
+  }
+  const outLen = readVar();
+  const out = Buffer.alloc(outLen);
+  let outp = 0;
+  while (pos < src.length) {
+    const tag = src[pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) len += 1;
+      else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= src[pos++] << (8 * i);
+        len += 1;
+      }
+      src.copy(out, outp, pos, pos + len);
+      pos += len;
+      outp += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 7) + 4;
+        offset = src[pos++] | ((tag & 0xe0) << 3);
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = src[pos] | (src[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = (src[pos] | (src[pos + 1] << 8) | (src[pos + 2] << 16) | (src[pos + 3] << 24)) >>> 0;
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) out[outp + i] = out[outp - offset + i];
+      outp += len;
+    }
+  }
+  if (outp !== outLen) throw new Error(`Snappy length mismatch ${outp} != ${outLen}`);
+  return out;
+}
+
+function readPlainDictionary(type, data, n) {
+  const vals = new Array(n);
+  let p = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === 2) {
+      vals[i] = Number(data.readBigInt64LE(p));
+      p += 8;
+    } else if (type === 5) {
+      vals[i] = data.readDoubleLE(p);
+      p += 8;
+    } else if (type === 6) {
+      const len = data.readInt32LE(p);
