+      out.path_in_schema = [];
+      for (let i = 0; i < lh.size; i++) out.path_in_schema.push(readString(c));
+    } else if (f.id === 4) out.codec = c.i32();
+    else if (f.id === 5) out.num_values = c.i64();
+    else if (f.id === 6) out.total_uncompressed_size = c.i64();
+    else if (f.id === 7) out.total_compressed_size = c.i64();
+    else if (f.id === 9) out.data_page_offset = c.i64();
