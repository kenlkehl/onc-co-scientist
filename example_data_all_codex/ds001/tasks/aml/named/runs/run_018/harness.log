+
+function adjustedSubgroupTreatment(treat, marker) {
+  const terms = [term(treat)].concat(clinicalTerms.filter((t) => t.name !== marker));
+  const res = ols(terms, (i) => df[marker][i] === 1);
+  const j = res.names.indexOf(treat);
+  return { treat, marker, beta: res.beta[j], se: res.se[j], p: pFromZ(res.beta[j] / res.se[j]), n: res.n };
+}
+
+function fmt(x) {
+  if (x === 0) return '0';
+  if (Math.abs(x) < 1e-4) return x.toExponential(3);
+  return x.toFixed(6);
+}
+
+console.log('n', n, 'overall_response', mean(y));
+const binary = names.filter((name) => name !== 'objective_response' && new Set(df[name]).size <= 8 && Array.from(new Set(df[name])).every((v) => Number.isInteger(v)));
+const continuous = names.filter((name) => name !== 'objective_response' && !binary.includes(name));
+
+console.log('\\nTop crude binary effects');
+twoBinary = binary.map((b) => twoGroup(b)).sort((a, b) => Math.abs(b.rd) - Math.abs(a.rd));
+for (const r of twoBinary.slice(0, 25)) console.log(r.feature, 'rd', fmt(r.rd), 'p', fmt(r.p), 'p1', fmt(r.p1), 'p0', fmt(r.p0), 'n1', r.n1);
+
+console.log('\\nTop continuous z effects');
+const cont = continuous.map((c) => contZ(c)).sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta));
+for (const r of cont.slice(0, 25)) console.log(r.feature, 'beta_per_sd', fmt(r.beta), 'p', fmt(r.p), 'mean', fmt(r.mean), 'sd', fmt(r.sd));
+
+console.log('\\nAdjusted selected main effects');
+for (const name of ['tp53_mutation','npm1_mutation','flt3_itd','flt3_tkd','idh1_mutation','idh2_mutation','complex_karyotype','secondary_aml','unfit_for_intensive','treatment_midostaurin','treatment_gilteritinib','treatment_ivosidenib','treatment_enasidenib','treatment_venetoclax_azacitidine','treatment_7plus3']) {
+  const r = adjustedOne(name);
+  console.log(name, 'beta', fmt(r.beta), 'p', fmt(r.p));
+}
+for (const name of ['albumin_g_dl','ldh_u_l','crp_mg_l','nlr','wbc_k_per_ul','blast_pct_marrow','hemoglobin_g_dl','platelets_k_ul','age_years']) {
+  const r = adjustedOne(`${name}_z`, stdCol(name));
+  console.log(`${name}_z`, 'beta', fmt(r.beta), 'p', fmt(r.p));
+}
+
+console.log('\\nTargeted subgroup treatment effects');
+for (const [t, m] of [
+  ['treatment_midostaurin','flt3_itd'],
+  ['treatment_midostaurin','flt3_tkd'],
+  ['treatment_gilteritinib','flt3_itd'],
+  ['treatment_gilteritinib','flt3_tkd'],
+  ['treatment_ivosidenib','idh1_mutation'],
+  ['treatment_enasidenib','idh2_mutation'],
+  ['treatment_venetoclax_azacitidine','unfit_for_intensive'],
+  ['treatment_7plus3','unfit_for_intensive'],
+]) {
+  const crude = twoGroup(t, (i) => df[m][i] === 1);
+  const adj = adjustedSubgroupTreatment(t, m);
+  console.log(`${t} within ${m}=1`, 'crude_rd', fmt(crude.rd), 'crude_p', fmt(crude.p), 'adj_beta', fmt(adj.beta), 'adj_p', fmt(adj.p), 'n', adj.n, 'treated', crude.n1);
+}
+
+console.log('\\nTargeted interactions');
+for (const [t, m] of [
+  ['treatment_midostaurin','flt3_itd'],
+  ['treatment_midostaurin','flt3_tkd'],
+  ['treatment_gilteritinib','flt3_itd'],
+  ['treatment_gilteritinib','flt3_tkd'],
+  ['treatment_ivosidenib','idh1_mutation'],
+  ['treatment_enasidenib','idh2_mutation'],
+  ['treatment_venetoclax_azacitidine','unfit_for_intensive'],
+  ['treatment_7plus3','unfit_for_intensive'],
+  ['treatment_venetoclax_azacitidine','tp53_mutation'],
+  ['treatment_7plus3','tp53_mutation'],
+]) {
+  const r = adjustedInteraction(t, m);
+  console.log(`${t}:${m}`, 'int_beta', fmt(r.beta), 'p', fmt(r.p));
+}
+
+console.log('\\nVenetoclax strata and interactions');
+for (const m of ['unfit_for_intensive','tp53_mutation','npm1_mutation','complex_karyotype','secondary_aml','age_years','ecog_ps','albumin_g_dl','blast_pct_marrow','crp_mg_l']) {
+  if (df[m]) {
+    if (new Set(df[m]).size <= 8 && Array.from(new Set(df[m])).every((v) => Number.isInteger(v))) {
+      const r = adjustedInteraction('treatment_venetoclax_azacitidine', m);
+      console.log(`venetoclax:${m}`, 'int_beta', fmt(r.beta), 'p', fmt(r.p));
+    }
+  }
+}
+for (const m of ['unfit_for_intensive','tp53_mutation','npm1_mutation','complex_karyotype']) {
+  for (const val of [0,1]) {
+    const r = twoGroup('treatment_venetoclax_azacitidine', (i) => df[m][i] === val);
+    console.log(`venetoclax RD within ${m}=${val}`, 'rd', fmt(r.rd), 'p', fmt(r.p), 'p1', fmt(r.p1), 'p0', fmt(r.p0), 'treated', r.n1, 'untreated', r.n0);
+  }
+}
+
+console.log('\\nAdjusted ecog and weight loss');
+for (const name of ['ecog_ps','weight_loss_pct_6mo']) {
+  const r = adjustedOne(`${name}_z`, stdCol(name));
+  console.log(`${name}_z`, 'beta', fmt(r.beta), 'p', fmt(r.p));
+}

