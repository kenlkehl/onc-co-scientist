+  byte() {
+    if (this.off >= this.end) throw new Error(`EOF at ${this.off}`);
+    return this.buf[this.off++];
+  }
+
+  varint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if (!(b & 0x80)) break;
+      shift += 7;
+    }
+    return result;
+  }
