+function readDictPageHeader(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 1) out.num_values = c.i32();
+    else if (f.id === 2) out.encoding = c.i32();
+    else c.skip(f.type);
