+function readPacked(data, state, bitWidth, count, out, dict, outOffset, needed) {
+  let bitbuf = 0;
+  let bits = 0;
+  let written = 0;
+  const mask = bitWidth === 32 ? 0xffffffff : ((1 << bitWidth) - 1);
+  for (let i = 0; i < count; i++) {
+    while (bits < bitWidth) {
+      bitbuf |= data[state.p++] << bits;
+      bits += 8;
+    }
+    if (written < needed) out[outOffset + written] = dict[bitbuf & mask];
+    written++;
+    bitbuf >>>= bitWidth;
+    bits -= bitWidth;
+  }
+  return Math.min(written, needed);
