+
+console.log('n', n, 'overall_response', mean(y));
+const binary = names.filter((name) => name !== 'objective_response' && new Set(df[name]).size <= 8 && Array.from(new Set(df[name])).every((v) => Number.isInteger(v)));
+const continuous = names.filter((name) => name !== 'objective_response' && !binary.includes(name));
