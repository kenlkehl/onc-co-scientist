+function readColumnChunk(c) {
+  const out = {};
+  c.beginStruct();
+  while (true) {
+    const f = c.field();
+    if (f.type === 0) break;
+    if (f.id === 3) out.meta_data = readColumnMetaData(c);
+    else c.skip(f.type);
+  }
+  c.endStruct();
+  return out;
