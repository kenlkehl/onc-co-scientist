+    const defLen = data.readInt32LE(p);
+    p += 4 + defLen;
+    const bitWidth = data[p++];
+    valuesRead += decodeDictionaryData(data, p, bitWidth, page.data_page_header.num_values, dict, out, valuesRead);
+    off = page.header_end + page.compressed_page_size;
