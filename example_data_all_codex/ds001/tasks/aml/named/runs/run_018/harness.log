+  beginStruct() {
+    this.fieldStack.push(this.lastField);
+    this.lastField = 0;
+  }
+
+  endStruct() {
+    this.lastField = this.fieldStack.pop() ?? 0;
+  }
+
+  field() {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === 0) return { type: 0, id: null };
+    const delta = h >> 4;
+    const id = delta === 0 ? this.i32() : this.lastField + delta;
+    this.lastField = id;
+    return { type, id };
