+      let idx = 0;
+      for (let i = 0; i < bytes; i++) idx |= data[state.p++] << (8 * i);
+      const value = dict[idx];
+      const take = Math.min(run, needed - written);
+      for (let i = 0; i < take; i++) out[outOffset + written + i] = value;
+      written += take;
+    } else {
+      const groups = header >> 1;
+      written += readPacked(data, state, bitWidth, groups * 8, out, dict, outOffset + written, needed - written);
