const fs = require('fs');

const base = JSON.parse(fs.readFileSync('runs/run_001/transcript.json', 'utf8'));
const enrich = JSON.parse(fs.readFileSync('runs/run_003/transcript.json', 'utf8'));

base.dataset_id = 'ds001_aml';
base.model_id = 'gpt-5-codex';
base.harness_id = 'codex-local-analysis@2026-05-01';
base.max_iterations = 25;

function findHyp(id) {
  for (const it of enrich.iterations) {
    const hyp = it.proposed_hypotheses.find(h => h.id === id);
    if (hyp) return hyp;
  }
  throw new Error('missing hypothesis ' + id);
}

function findAnalyses(id) {
  const out = [];
  for (const it of enrich.iterations) {
    for (const a of it.analyses || []) {
      if (a.hypothesis_ids.includes(id)) out.push(a);
    }
  }
  if ("'!out.length) throw new Error('"'missing analyses for ' + id);
  return out;
}

function add(targetIndex, sourceId, newId) {
  const target = base.iterations.find(it => it.index === targetIndex);
  if ("'!target) throw new Error('"'missing target iteration ' + targetIndex);
  const hyp = JSON.parse(JSON.stringify(findHyp(sourceId)));
  hyp.id = newId;
  if ("'!hyp.kind) hyp.kind = '"'refined';
  target.proposed_hypotheses.push(hyp);
  for (const sourceAnalysis of findAnalyses(sourceId)) {
    const a = JSON.parse(JSON.stringify(sourceAnalysis));
    a.hypothesis_ids = a.hypothesis_ids.map(id => id === sourceId ? newId : id);
    target.analyses.push(a);
  }
}

