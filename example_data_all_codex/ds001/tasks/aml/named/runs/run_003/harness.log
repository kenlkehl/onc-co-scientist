import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print(df.shape)
print(df.dtypes.to_string())
print('objective_response mean', df['objective_response'].mean(), 'sum', int(df['objective_response'].sum()))
print('\\nHead cols', list(df.columns))
binary=[]; cont=[]
for c in df.columns:
    vals = set(pd.unique(df[c]))
    if vals <= {0,1}:
        binary.append(c)
    else:
        cont.append(c)
print('binary', len(binary), binary)
print('continuous', len(cont), cont)
print('\\nBinary prevalence:')
print(df[binary].mean().sort_values(ascending=False).to_string())
print('\\nContinuous summary:')
print(df[cont].describe().T[['mean','std','min','25%','50%','75%','max']].to_string())
treat=[c for c in df.columns if c.startswith('treatment_')]
print('\\nTreatment counts:')
print(df[treat].sum().sort_values(ascending=False).to_string())
print('\\nTreatment row sum counts:')
print(df[treat].sum(axis=1).value_counts().sort_index().to_string())
print('\\nTreatment correlations:')
print(df[treat].corr().round(3).to_string())
