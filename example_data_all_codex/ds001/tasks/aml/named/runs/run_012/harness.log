    print(c, 'n=', int(df[c].sum()), 'rate=', df[c].mean(), 'resp_on=', df.loc[df[c]==1,'objective_response'].mean(), 'resp_off=', df.loc[df[c]==0,'objective_response'].mean(), 'diff=', df.loc[df[c]==1,'objective_response'].mean()-df.loc[df[c]==0,'objective_response'].mean())
print('\\nBinary feature rates and response diffs')
