"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from scipy import stats

path = 'dataset.parquet'
df = pd.read_parquet(path)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
y = 'objective_response'
print('outcome_mean', df[y].mean(), 'sum', int(df[y].sum()))

# Basic prevalence/means and univariate risk differences for all non-outcome columns
rows=[]
for c in df.columns:
    if c == y:
        continue
    x=df[c]
    if set(np.unique(x)).issubset({0,1}):
        n1=int((x==1).sum()); n0=int((x==0).sum())
        p1=df.loc[x==1,y].mean(); p0=df.loc[x==0,y].mean()
        table=pd.crosstab(x, df[y])
        try:
            p=stats.chi2_contingency(table)[1]
        except Exception:
            p=np.nan
        rows.append((c,'binary',n1,n0,p1,p0,p1-p0,p))
    else:
        # point-biserial slope per SD via simple linear regression/correlation
        xs=(x-x.mean())/x.std(ddof=0)
        r,p=stats.pearsonr(xs, df[y])
        slope=r*df[y].std(ddof=0) # prob diff per SD of x
        rows.append((c,'cont',float(x.mean()),float(x.std(ddof=0)),None,None,float(slope),p))
rows_sorted=sorted(rows, key=lambda r: abs(r[6]) if not pd.isna(r[6]) else -1, reverse=True)
print('\\nTop univariate effects by abs risk diff / per-SD prob diff:')
for r in rows_sorted[:35]:
    print(r)

# Treatment prevalence and response
print('\\nTreatment prevalence and response')
for c in [c for c in df.columns if c.startswith('treatment_')]:
    print(c, int(df[c].sum()), df.loc[df[c]==1,y].mean(), df.loc[df[c]==0,y].mean(), df.loc[df[c]==1,y].mean()-df.loc[df[c]==0,y].mean())

# Mutation prevalences and response
print('\\nBiomarker prevalence and response')
for c in ['flt3_itd','flt3_tkd','idh1_mutation','idh2_mutation','npm1_mutation','tp53_mutation','complex_karyotype','secondary_aml','unfit_for_intensive']:
    print(c, int(df[c].sum()), df.loc[df[c]==1,y].mean(), df.loc[df[c]==0,y].mean(), df.loc[df[c]==1,y].mean()-df.loc[df[c]==0,y].mean())
