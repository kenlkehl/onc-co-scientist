import pandas as pd
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome mean', df['objective_response'].mean(), 'sum', int(df['objective_response'].sum()))
print('head')
print(df.head(3).to_string())
# summarize binary columns prevalences and continuous basics
for col in df.columns:
    vals = df[col].dropna().unique()
    if len(vals) <= 5 and set(vals).issubset({0,1,False,True}):
        print('binary', col, df[col].mean(), int(df[col].sum()))
print('continuous summary')
print(df.describe().T[['mean','std','min','25%','50%','75%','max']].to_string())
