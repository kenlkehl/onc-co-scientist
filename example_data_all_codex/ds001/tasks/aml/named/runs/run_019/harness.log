+    const end = offset + columnMeta[7] + 256;
+    let dictionary = null;
+    const values = [];
+    while (offset < end && values.length < columnMeta[5]) {
+      const reader = makeCompactReader(file, offset);
+      const header = reader.readStruct('PageHeader');
+      const bodyStart = reader.pos;
+      const body = file.subarray(bodyStart, bodyStart + header[3]);
+      const decoded = snappyUncompress(body);
+      offset = bodyStart + header[3];
+      if (header[1] === 2) {
+        dictionary = decodePlainDictionary(decoded, physicalType, header[7][1]);
+      } else if (header[1] === 0) {
+        const dataHeader = header[5];
+        const numValues = dataHeader[1];
+        let pos = 0;
+        let definitionLevels = Array(numValues).fill(1);
+        if (dataHeader[3] === 3) {
+          const defLen = decoded.readInt32LE(pos);
+          pos += 4;
+          definitionLevels = decodeRleBitpacked(decoded.subarray(pos, pos + defLen), 0, 1, numValues).values;
