+    .map(c => ({ col: c, ...adjustedWith(c) })).sort((a, b) => a.beta - b.beta);
+
+  const interactionsToTest = [
+    ['treatment_midostaurin', 'flt3_itd'],
+    ['treatment_gilteritinib', 'flt3_itd'],
+    ['treatment_ivosidenib', 'idh1_mutation'],
+    ['treatment_enasidenib', 'idh2_mutation'],
+    ['treatment_venetoclax_azacitidine', 'unfit_for_intensive'],
+    ['treatment_7plus3', 'unfit_for_intensive'],
+    ['treatment_7plus3', 'age_years'],
+    ['treatment_venetoclax_azacitidine', 'age_years'],
+    ['treatment_7plus3', 'complex_karyotype'],
+    ['treatment_venetoclax_azacitidine', 'tp53_mutation'],
+    ['treatment_midostaurin', 'npm1_mutation'],
+    ['treatment_gilteritinib', 'complex_karyotype']
+  ];
+  function interactionFitScaled(a, b) {
+    const intName = `${a}_x_${b}`;
+    const bScale = b === 'age_years' ? 10 : 1;
+    const bCenter = b === 'age_years' ? center.age_years : 0;
+    const predictors = baseCovars.concat([
+      makePredictor(a, columns),
+      makePredictor(b, columns, bScale, b === 'age_years' ? center.age_years : null),
+      interactionPredictor(intName, columns, a, b, 1, bScale, 0, bCenter)
