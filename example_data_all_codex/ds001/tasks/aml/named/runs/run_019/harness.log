+        if (dataHeader[2] === 8) {
+          const bitWidth = decoded[pos++];
+          const idx = decodeRleBitpacked(decoded, pos, bitWidth, presentCount).values;
+          let j = 0;
+          for (const level of definitionLevels) values.push(level > 0 ? dictionary[idx[j++]] : null);
+        } else if (dataHeader[2] === 0) {
+          const plain = decodePlainDictionary(decoded.subarray(pos), physicalType, presentCount);
+          let j = 0;
+          for (const level of definitionLevels) values.push(level > 0 ? plain[j++] : null);
+        } else {
+          throw new Error(`Unsupported data encoding ${dataHeader[2]} for ${name}`);
+        }
+      } else {
+        throw new Error(`Unsupported page type ${header[1]} for ${name}`);
+      }
+    }
+    if (values.length !== columnMeta[5]) {
+      throw new Error(`Column ${name} decoded ${values.length}, expected ${columnMeta[5]}`);
+    }
+    columns[name] = values;
+  }
+  return { columns, n: rowGroup[3], schemaNames: schema.slice(1).map(x => x[4]) };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedP(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function proportionEffect(x, y, predicate = null) {
+  let n1 = 0, s1 = 0, n0 = 0, s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i] === null || y[i] === null || Number.isNaN(x[i]) || Number.isNaN(y[i])) continue;
+    if (x[i]) { n1++; s1 += y[i]; } else { n0++; s0 += y[i]; }
+  }
+  const p1 = s1 / n1;
+  const p0 = s0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  return { n1, n0, p1, p0, effect, se, z: effect / se, p: twoSidedP(effect / se) };
+}
+
+function continuousEffectPerUnit(x, y, scale = 1, predicate = null) {
+  let n = 0, sx = 0, sy = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i] === null || y[i] === null || Number.isNaN(x[i]) || Number.isNaN(y[i])) continue;
+    n++;
+    sx += x[i] / scale;
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0, sxy = 0, rss = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i] === null || y[i] === null || Number.isNaN(x[i]) || Number.isNaN(y[i])) continue;
+    const xi = x[i] / scale;
+    sxx += (xi - mx) * (xi - mx);
+    sxy += (xi - mx) * (y[i] - my);
+  }
+  const beta = sxy / sxx;
+  const alpha = my - beta * mx;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i] === null || y[i] === null || Number.isNaN(x[i]) || Number.isNaN(y[i])) continue;
+    const e = y[i] - alpha - beta * (x[i] / scale);
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  return { n, effect: beta, se, z: beta / se, p: twoSidedP(beta / se) };
+}
+
+function matInv(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= f * M[i][c];
+    }
+  }
+  return M.map(row => row.slice(n));
+}
+
+function ols(y, predictors, predicate = null) {
+  const names = ['intercept'].concat(predictors.map(p => p.name));
+  const p = names.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let n = 0;
+  const rows = [];
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    const row = [1].concat(predictors.map(pr => pr.fn(i)));
+    if (y[i] === null || row.some(v => v === null || Number.isNaN(v))) continue;
+    rows.push([row, y[i]]);
+    n++;
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = matInv(xtx);
+  const beta = inv.map(row => row.reduce((acc, v, j) => acc + v * xty[j], 0));
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (const [row, yi] of rows) {
+    const fitted = beta.reduce((acc, b, j) => acc + b * row[j], 0);
+    const e = yi - fitted;
+    for (let a = 0; a < p; a++) {
+      for (let b = 0; b < p; b++) meat[a][b] += row[a] * row[b] * e * e;
+    }
+  }
+  const scale = n / (n - p);
+  const cov = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) {
+      let v = 0;
+      for (let k = 0; k < p; k++) for (let l = 0; l < p; l++) v += inv[a][k] * meat[k][l] * inv[l][b];
+      cov[a][b] = v * scale;
+    }
+  }
+  const result = {};
+  for (let j = 0; j < p; j++) {
+    const se = Math.sqrt(Math.max(0, cov[j][j]));
+    result[names[j]] = { beta: beta[j], se, z: beta[j] / se, p: twoSidedP(beta[j] / se) };
+  }
+  return { n, names, result };
+}
+
+function mean(arr) {
+  let s = 0, n = 0;
+  for (const v of arr) {
+    if (v === null || Number.isNaN(v)) continue;
+    s += v;
+    n++;
+  }
+  return s / n;
+}
+
+function quantile(arr, q) {
+  const sorted = Array.from(arr).sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] + (sorted[hi] - sorted[lo]) * (pos - lo);
+}
+
+function fmtPct(x) {
+  return `${(100 * x).toFixed(1)}%`;
+}
+
+function fmtP(p) {
+  if (p === 0) return '<1e-300';
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function makePredictor(col, columns, scale = 1, center = null) {
+  const c = columns[col];
+  const m = center === null ? 0 : center;
+  return { name: col, fn: i => (c[i] - m) / scale };
+}
+
+function interactionPredictor(name, columns, a, b, aScale = 1, bScale = 1, aCenter = 0, bCenter = 0) {
+  const ca = columns[a], cb = columns[b];
+  return { name, fn: i => ((ca[i] - aCenter) / aScale) * ((cb[i] - bCenter) / bScale) };
+}
+
+function main() {
+  const { columns, n } = readParquetColumns();
+  const y = columns.objective_response;
+  const binaryCols = Object.keys(columns).filter(c => c !== 'objective_response' && columns[c].every(v => v === 0 || v === 1));
+  const treatmentCols = binaryCols.filter(c => c.startsWith('treatment_'));
+  const mutationCols = binaryCols.filter(c => c.endsWith('_mutation') || c.includes('flt3_') || c === 'npm1_mutation' || c === 'complex_karyotype');
+  const clinicalBinary = binaryCols.filter(c => !treatmentCols.includes(c) && !mutationCols.includes(c));
+
+  const univariate = binaryCols.map(c => ({ col: c, ...proportionEffect(columns[c], y) }))
+    .sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+  const treatmentEffects = treatmentCols.map(c => ({ col: c, ...proportionEffect(columns[c], y) }))
+    .sort((a, b) => b.effect - a.effect);
+  const continuousScales = {
+    age_years: 10,
+    wbc_k_per_ul: 10,
+    blast_pct_marrow: 10,
+    albumin_g_dl: 1,
+    ldh_u_l: 100,
+    weight_loss_pct_6mo: 5,
+    crp_mg_l: 10,
+    nlr: 1,
+    hemoglobin_g_dl: 1,
+    creatinine_mg_dl: 1,
+    platelets_k_ul: 50,
+    bmi: 5,
+    heart_rate_bpm: 10,
+    spo2_pct: 1
+  };
+  const continuousCols = Object.keys(continuousScales);
+  const continuous = continuousCols.map(c => ({ col: c, scale: continuousScales[c], ...continuousEffectPerUnit(columns[c], y, continuousScales[c]) }))
+    .sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+
+  const center = {};
+  for (const c of Object.keys(columns)) center[c] = mean(columns[c]);
+  const baseCovars = [
+    makePredictor('age_years', columns, 10, center.age_years),
+    makePredictor('sex_female', columns),
+    makePredictor('ecog_ps', columns),
+    makePredictor('secondary_aml', columns),
+    makePredictor('unfit_for_intensive', columns),
+    makePredictor('complex_karyotype', columns),
+    makePredictor('tp53_mutation', columns),
+    makePredictor('flt3_itd', columns),
+    makePredictor('idh1_mutation', columns),
+    makePredictor('idh2_mutation', columns),
+    makePredictor('npm1_mutation', columns),
+    makePredictor('wbc_k_per_ul', columns, 10, center.wbc_k_per_ul),
+    makePredictor('albumin_g_dl', columns, 1, center.albumin_g_dl),
+    makePredictor('crp_mg_l', columns, 10, center.crp_mg_l),
+    makePredictor('weight_loss_pct_6mo', columns, 5, center.weight_loss_pct_6mo)
+  ];
