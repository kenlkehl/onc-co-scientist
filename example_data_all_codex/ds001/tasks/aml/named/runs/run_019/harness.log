+    univariate: univariate.slice(0, 30),
+    continuous,
+    adjustedTreatments,
+    adjustedBiomarkers,
+    interactions,
+    subgroups,
+    lowAlbumin,
+    highCrp,
+    highLdh,
+    highWbc,
+    inflamedEffect,
+    proliferativeEffect
