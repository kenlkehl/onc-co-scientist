+  const summary = {
+    n,
+    outcomeMean: mean(y),
+    outcomeSum: y.reduce((a, b) => a + b, 0),
+    binaryPrevalence: Object.fromEntries(binaryCols.map(c => [c, mean(columns[c])])),
+    treatmentEffects,
+    univariate: univariate.slice(0, 30),
+    continuous,
+    adjustedTreatments,
+    adjustedBiomarkers,
+    interactions,
+    subgroups,
+    lowAlbumin,
+    highCrp,
+    highLdh,
+    highWbc,
+    inflamedEffect,
+    proliferativeEffect
+  };
+  fs.writeFileSync('analysis_results.json', JSON.stringify(summary, null, 2));
+  console.log(JSON.stringify(summary, null, 2));
+}
+
+main();

