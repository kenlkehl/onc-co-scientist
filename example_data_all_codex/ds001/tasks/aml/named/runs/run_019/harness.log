+  subgroups.midostaurin_flt3_neg = proportionEffect(columns.treatment_midostaurin, y, i => columns.flt3_itd[i] === 0);
+  subgroups.gilteritinib_flt3_pos = proportionEffect(columns.treatment_gilteritinib, y, i => columns.flt3_itd[i] === 1);
+  subgroups.gilteritinib_flt3_neg = proportionEffect(columns.treatment_gilteritinib, y, i => columns.flt3_itd[i] === 0);
+  subgroups.ivosidenib_idh1_pos = proportionEffect(columns.treatment_ivosidenib, y, i => columns.idh1_mutation[i] === 1);
+  subgroups.ivosidenib_idh1_neg = proportionEffect(columns.treatment_ivosidenib, y, i => columns.idh1_mutation[i] === 0);
+  subgroups.enasidenib_idh2_pos = proportionEffect(columns.treatment_enasidenib, y, i => columns.idh2_mutation[i] === 1);
+  subgroups.enasidenib_idh2_neg = proportionEffect(columns.treatment_enasidenib, y, i => columns.idh2_mutation[i] === 0);
+  subgroups.ven_unfit_pos = proportionEffect(columns.treatment_venetoclax_azacitidine, y, i => columns.unfit_for_intensive[i] === 1);
+  subgroups.ven_unfit_neg = proportionEffect(columns.treatment_venetoclax_azacitidine, y, i => columns.unfit_for_intensive[i] === 0);
+  subgroups.seven3_unfit_pos = proportionEffect(columns.treatment_7plus3, y, i => columns.unfit_for_intensive[i] === 1);
+  subgroups.seven3_unfit_neg = proportionEffect(columns.treatment_7plus3, y, i => columns.unfit_for_intensive[i] === 0);
+
+  const lowAlbumin = quantile(columns.albumin_g_dl, 0.25);
+  const highCrp = quantile(columns.crp_mg_l, 0.75);
+  const highLdh = quantile(columns.ldh_u_l, 0.75);
+  const highWbc = quantile(columns.wbc_k_per_ul, 0.75);
