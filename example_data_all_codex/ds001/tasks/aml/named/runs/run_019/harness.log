+    interactions,
+    subgroups,
+    lowAlbumin,
+    highCrp,
+    highLdh,
+    highWbc,
+    inflamedEffect,
+    proliferativeEffect
+  };
+  fs.writeFileSync('analysis_results.json', JSON.stringify(summary, null, 2));
