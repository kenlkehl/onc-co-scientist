+function makePredictor(col, columns, scale = 1, center = null) {
+  const c = columns[col];
+  const m = center === null ? 0 : center;
+  return { name: col, fn: i => (c[i] - m) / scale };
+}
+
+function interactionPredictor(name, columns, a, b, aScale = 1, bScale = 1, aCenter = 0, bCenter = 0) {
+  const ca = columns[a], cb = columns[b];
+  return { name, fn: i => ((ca[i] - aCenter) / aScale) * ((cb[i] - bCenter) / bScale) };
+}
+
+function main() {
+  const { columns, n } = readParquetColumns();
+  const y = columns.objective_response;
+  const binaryCols = Object.keys(columns).filter(c => c !== 'objective_response' && columns[c].every(v => v === 0 || v === 1));
+  const treatmentCols = binaryCols.filter(c => c.startsWith('treatment_'));
+  const mutationCols = binaryCols.filter(c => c.endsWith('_mutation') || c.includes('flt3_') || c === 'npm1_mutation' || c === 'complex_karyotype');
+  const clinicalBinary = binaryCols.filter(c => !treatmentCols.includes(c) && !mutationCols.includes(c));
+
+  const univariate = binaryCols.map(c => ({ col: c, ...proportionEffect(columns[c], y) }))
+    .sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+  const treatmentEffects = treatmentCols.map(c => ({ col: c, ...proportionEffect(columns[c], y) }))
+    .sort((a, b) => b.effect - a.effect);
+  const continuousScales = {
+    age_years: 10,
+    wbc_k_per_ul: 10,
+    blast_pct_marrow: 10,
+    albumin_g_dl: 1,
+    ldh_u_l: 100,
+    weight_loss_pct_6mo: 5,
+    crp_mg_l: 10,
+    nlr: 1,
+    hemoglobin_g_dl: 1,
+    creatinine_mg_dl: 1,
+    platelets_k_ul: 50,
+    bmi: 5,
+    heart_rate_bpm: 10,
+    spo2_pct: 1
+  };
+  const continuousCols = Object.keys(continuousScales);
+  const continuous = continuousCols.map(c => ({ col: c, scale: continuousScales[c], ...continuousEffectPerUnit(columns[c], y, continuousScales[c]) }))
+    .sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+
+  const center = {};
+  for (const c of Object.keys(columns)) center[c] = mean(columns[c]);
+  const baseCovars = [
+    makePredictor('age_years', columns, 10, center.age_years),
+    makePredictor('sex_female', columns),
+    makePredictor('ecog_ps', columns),
+    makePredictor('secondary_aml', columns),
+    makePredictor('unfit_for_intensive', columns),
+    makePredictor('complex_karyotype', columns),
+    makePredictor('tp53_mutation', columns),
+    makePredictor('flt3_itd', columns),
+    makePredictor('idh1_mutation', columns),
+    makePredictor('idh2_mutation', columns),
+    makePredictor('npm1_mutation', columns),
+    makePredictor('wbc_k_per_ul', columns, 10, center.wbc_k_per_ul),
+    makePredictor('albumin_g_dl', columns, 1, center.albumin_g_dl),
+    makePredictor('crp_mg_l', columns, 10, center.crp_mg_l),
+    makePredictor('weight_loss_pct_6mo', columns, 5, center.weight_loss_pct_6mo)
+  ];
+
+  function adjustedTerm(term, extra = []) {
+    const fit = ols(y, baseCovars.concat(extra), null);
+    return fit.result[term];
+  }
+  function adjustedWith(termCol) {
+    const fit = ols(y, baseCovars.concat([makePredictor(termCol, columns)]), null);
+    return fit.result[termCol];
+  }
+  function interactionFit(a, b, extraCols = []) {
+    const intName = `${a}_x_${b}`;
+    const predictors = baseCovars.concat(extraCols.map(c => makePredictor(c, columns)), [
+      makePredictor(a, columns),
+      makePredictor(b, columns),
+      interactionPredictor(intName, columns, a, b)
+    ]);
+    const fit = ols(y, predictors, null);
+    return fit.result[intName];
+  }
+
+  const adjustedTreatments = treatmentCols.map(c => ({ col: c, ...adjustedWith(c) }))
+    .sort((a, b) => b.beta - a.beta);
+  const adjustedBiomarkers = ['flt3_itd', 'idh1_mutation', 'idh2_mutation', 'npm1_mutation', 'tp53_mutation', 'complex_karyotype', 'secondary_aml']
+    .map(c => ({ col: c, ...adjustedWith(c) })).sort((a, b) => a.beta - b.beta);
+
+  const interactionsToTest = [
+    ['treatment_midostaurin', 'flt3_itd'],
+    ['treatment_gilteritinib', 'flt3_itd'],
+    ['treatment_ivosidenib', 'idh1_mutation'],
+    ['treatment_enasidenib', 'idh2_mutation'],
+    ['treatment_venetoclax_azacitidine', 'unfit_for_intensive'],
+    ['treatment_7plus3', 'unfit_for_intensive'],
+    ['treatment_7plus3', 'age_years'],
+    ['treatment_venetoclax_azacitidine', 'age_years'],
+    ['treatment_7plus3', 'complex_karyotype'],
+    ['treatment_venetoclax_azacitidine', 'tp53_mutation'],
+    ['treatment_midostaurin', 'npm1_mutation'],
+    ['treatment_gilteritinib', 'complex_karyotype']
+  ];
+  function interactionFitScaled(a, b) {
+    const intName = `${a}_x_${b}`;
+    const bScale = b === 'age_years' ? 10 : 1;
+    const bCenter = b === 'age_years' ? center.age_years : 0;
+    const predictors = baseCovars.concat([
+      makePredictor(a, columns),
+      makePredictor(b, columns, bScale, b === 'age_years' ? center.age_years : null),
+      interactionPredictor(intName, columns, a, b, 1, bScale, 0, bCenter)
+    ]);
+    const fit = ols(y, predictors, null);
+    return fit.result[intName];
+  }
+  const interactions = interactionsToTest.map(([a, b]) => ({ a, b, ...interactionFitScaled(a, b) }))
+    .sort((x, y2) => Math.abs(y2.beta) - Math.abs(x.beta));
+
+  const subgroups = {};
+  subgroups.midostaurin_flt3_pos = proportionEffect(columns.treatment_midostaurin, y, i => columns.flt3_itd[i] === 1);
+  subgroups.midostaurin_flt3_neg = proportionEffect(columns.treatment_midostaurin, y, i => columns.flt3_itd[i] === 0);
+  subgroups.gilteritinib_flt3_pos = proportionEffect(columns.treatment_gilteritinib, y, i => columns.flt3_itd[i] === 1);
+  subgroups.gilteritinib_flt3_neg = proportionEffect(columns.treatment_gilteritinib, y, i => columns.flt3_itd[i] === 0);
+  subgroups.ivosidenib_idh1_pos = proportionEffect(columns.treatment_ivosidenib, y, i => columns.idh1_mutation[i] === 1);
+  subgroups.ivosidenib_idh1_neg = proportionEffect(columns.treatment_ivosidenib, y, i => columns.idh1_mutation[i] === 0);
+  subgroups.enasidenib_idh2_pos = proportionEffect(columns.treatment_enasidenib, y, i => columns.idh2_mutation[i] === 1);
+  subgroups.enasidenib_idh2_neg = proportionEffect(columns.treatment_enasidenib, y, i => columns.idh2_mutation[i] === 0);
+  subgroups.ven_unfit_pos = proportionEffect(columns.treatment_venetoclax_azacitidine, y, i => columns.unfit_for_intensive[i] === 1);
+  subgroups.ven_unfit_neg = proportionEffect(columns.treatment_venetoclax_azacitidine, y, i => columns.unfit_for_intensive[i] === 0);
+  subgroups.seven3_unfit_pos = proportionEffect(columns.treatment_7plus3, y, i => columns.unfit_for_intensive[i] === 1);
+  subgroups.seven3_unfit_neg = proportionEffect(columns.treatment_7plus3, y, i => columns.unfit_for_intensive[i] === 0);
+
+  const lowAlbumin = quantile(columns.albumin_g_dl, 0.25);
+  const highCrp = quantile(columns.crp_mg_l, 0.75);
+  const highLdh = quantile(columns.ldh_u_l, 0.75);
+  const highWbc = quantile(columns.wbc_k_per_ul, 0.75);
+  const inflamed = Array.from({ length: n }, (_, i) => columns.albumin_g_dl[i] < lowAlbumin && columns.crp_mg_l[i] > highCrp);
+  const proliferative = Array.from({ length: n }, (_, i) => columns.wbc_k_per_ul[i] > highWbc && columns.ldh_u_l[i] > highLdh);
+  const inflamedEffect = proportionEffect(inflamed, y);
+  const proliferativeEffect = proportionEffect(proliferative, y);
+
+  const summary = {
+    n,
+    outcomeMean: mean(y),
+    outcomeSum: y.reduce((a, b) => a + b, 0),
+    binaryPrevalence: Object.fromEntries(binaryCols.map(c => [c, mean(columns[c])])),
+    treatmentEffects,
+    univariate: univariate.slice(0, 30),
+    continuous,
+    adjustedTreatments,
+    adjustedBiomarkers,
+    interactions,
+    subgroups,
+    lowAlbumin,
+    highCrp,
+    highLdh,
+    highWbc,
+    inflamedEffect,
+    proliferativeEffect
+  };
+  fs.writeFileSync('analysis_results.json', JSON.stringify(summary, null, 2));
+  console.log(JSON.stringify(summary, null, 2));
+}
+
+main();

