+const fs = require('fs');
+
+const PARQUET_FILE = 'dataset.parquet';
+
+function makeCompactReader(buf, start = 0) {
+  let pos = start;
+  function readByte() {
+    if (pos >= buf.length) throw new Error(`Unexpected EOF at ${pos}`);
+    return buf[pos++];
+  }
+  function readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
