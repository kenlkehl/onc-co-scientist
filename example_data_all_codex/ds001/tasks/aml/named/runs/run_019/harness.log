+const PARQUET_FILE = 'dataset.parquet';
+
+function makeCompactReader(buf, start = 0) {
+  let pos = start;
+  function readByte() {
+    if (pos >= buf.length) throw new Error(`Unexpected EOF at ${pos}`);
+    return buf[pos++];
+  }
