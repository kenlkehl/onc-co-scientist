+    age_years: 10,
+    wbc_k_per_ul: 10,
+    blast_pct_marrow: 10,
+    albumin_g_dl: 1,
+    ldh_u_l: 100,
+    weight_loss_pct_6mo: 5,
+    crp_mg_l: 10,
+    nlr: 1,
+    hemoglobin_g_dl: 1,
+    creatinine_mg_dl: 1,
+    platelets_k_ul: 50,
+    bmi: 5,
+    heart_rate_bpm: 10,
+    spo2_pct: 1
