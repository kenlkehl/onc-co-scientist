+        copyLen = (tag >> 2) + 1;
+        offset = src[pos] | (src[pos + 1] << 8);
+        pos += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = (src[pos] | (src[pos + 1] << 8) | (src[pos + 2] << 16) | (src[pos + 3] << 24)) >>> 0;
+        pos += 4;
+      }
+      for (let i = 0; i < copyLen; i++) out[op++] = out[op - offset];
+    }
+  }
+  if (op !== len) throw new Error(`Snappy length mismatch ${op} != ${len}`);
+  return out;
+}
+
+function decodePlainDictionary(buf, physicalType, count) {
+  const values = [];
+  let pos = 0;
+  for (let i = 0; i < count; i++) {
+    if (physicalType === 1) {
+      values.push(buf.readInt32LE(pos));
+      pos += 4;
+    } else if (physicalType === 2) {
+      values.push(Number(buf.readBigInt64LE(pos)));
+      pos += 8;
+    } else if (physicalType === 5) {
+      values.push(buf.readDoubleLE(pos));
+      pos += 8;
+    } else if (physicalType === 6) {
+      const len = buf.readInt32LE(pos);
+      pos += 4;
+      values.push(buf.subarray(pos, pos + len).toString());
+      pos += len;
+    } else {
+      throw new Error(`Unsupported physical type ${physicalType}`);
+    }
+  }
+  return values;
+}
+
+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = buf[state.pos++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return result;
+}
+
+function decodeRleBitpacked(buf, start, bitWidth, expectedCount) {
+  const out = [];
+  const state = { pos: start };
+  const valueBytes = Math.ceil(bitWidth / 8);
+  const mask = bitWidth >= 31 ? 0xffffffff : ((1 << bitWidth) - 1);
+  while (out.length < expectedCount && state.pos < buf.length) {
+    const header = readVarintFrom(buf, state);
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      let value = 0;
+      for (let i = 0; i < valueBytes; i++) value |= buf[state.pos++] << (8 * i);
+      for (let i = 0; i < runLen && out.length < expectedCount; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bitBuffer = 0;
+      let bits = 0;
+      for (let i = 0; i < total; i++) {
+        while (bits < bitWidth) {
+          bitBuffer |= buf[state.pos++] << bits;
+          bits += 8;
+        }
+        out.push(bitBuffer & mask);
+        bitBuffer >>>= bitWidth;
+        bits -= bitWidth;
+        if (out.length === expectedCount) {
+          const remainingBits = (total - i - 1) * bitWidth - bits;
+          if (remainingBits > 0) state.pos += Math.ceil(remainingBits / 8);
+          break;
+        }
+      }
+    }
+  }
+  return { values: out, pos: state.pos };
+}
+
+function readParquetColumns() {
+  const file = fs.readFileSync(PARQUET_FILE);
+  if (file.subarray(0, 4).toString() !== 'PAR1' || file.subarray(file.length - 4).toString() !== 'PAR1') {
+    throw new Error('Not a Parquet file');
+  }
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const footer = file.subarray(file.length - 8 - footerLen, file.length - 8);
+  const meta = makeCompactReader(footer).readStruct('FileMetaData');
+  const schema = meta[2];
+  const rowGroup = meta[4][0];
+  const columns = {};
+  const physicalTypes = {};
+  for (let i = 1; i < schema.length; i++) {
+    physicalTypes[schema[i][4]] = schema[i][1];
+  }
+  for (const chunk of rowGroup[1]) {
+    const columnMeta = chunk[3];
+    const name = columnMeta[3][0];
+    if (name === 'patient_id') continue;
+    const physicalType = columnMeta[1];
+    const codec = columnMeta[4];
+    if (codec !== 1) throw new Error(`Unsupported codec ${codec} for ${name}`);
+    let offset = columnMeta[11] || columnMeta[9];
+    const end = offset + columnMeta[7] + 256;
+    let dictionary = null;
+    const values = [];
+    while (offset < end && values.length < columnMeta[5]) {
+      const reader = makeCompactReader(file, offset);
+      const header = reader.readStruct('PageHeader');
+      const bodyStart = reader.pos;
+      const body = file.subarray(bodyStart, bodyStart + header[3]);
+      const decoded = snappyUncompress(body);
+      offset = bodyStart + header[3];
+      if (header[1] === 2) {
+        dictionary = decodePlainDictionary(decoded, physicalType, header[7][1]);
+      } else if (header[1] === 0) {
+        const dataHeader = header[5];
+        const numValues = dataHeader[1];
+        let pos = 0;
+        if (dataHeader[3] === 3) {
+          const defLen = decoded.readInt32LE(pos);
+          pos += 4 + defLen;
+        }
+        if (dataHeader[2] === 8) {
+          const bitWidth = decoded[pos++];
+          const idx = decodeRleBitpacked(decoded, pos, bitWidth, numValues).values;
+          if (name === 'bone_mets') console.log('bone page', values.length, 'num', numValues, 'decoded idx', idx.length, 'bitWidth', bitWidth, 'decodedLen', decoded.length, 'pos', pos);
+          for (const ix of idx) values.push(dictionary[ix]);
+        } else if (dataHeader[2] === 0) {
+          const plain = decodePlainDictionary(decoded.subarray(pos), physicalType, numValues);
+          values.push(...plain);
+        } else {
+          throw new Error(`Unsupported data encoding ${dataHeader[2]} for ${name}`);
+        }
+      } else {
+        throw new Error(`Unsupported page type ${header[1]} for ${name}`);
+      }
+    }
+    if (values.length !== columnMeta[5]) {
+      throw new Error(`Column ${name} decoded ${values.length}, expected ${columnMeta[5]}`);
+    }
+    columns[name] = values;
+  }
+  return { columns, n: rowGroup[3], schemaNames: schema.slice(1).map(x => x[4]) };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function twoSidedP(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function proportionEffect(x, y, predicate = null) {
+  let n1 = 0, s1 = 0, n0 = 0, s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i]) { n1++; s1 += y[i]; } else { n0++; s0 += y[i]; }
+  }
+  const p1 = s1 / n1;
+  const p0 = s0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  return { n1, n0, p1, p0, effect, se, z: effect / se, p: twoSidedP(effect / se) };
+}
+
+function continuousEffectPerUnit(x, y, scale = 1, predicate = null) {
+  let n = 0, sx = 0, sy = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    n++;
+    sx += x[i] / scale;
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0, sxy = 0, rss = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    const xi = x[i] / scale;
+    sxx += (xi - mx) * (xi - mx);
+    sxy += (xi - mx) * (y[i] - my);
+  }
+  const beta = sxy / sxx;
+  const alpha = my - beta * mx;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    const e = y[i] - alpha - beta * (x[i] / scale);
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  return { n, effect: beta, se, z: beta / se, p: twoSidedP(beta / se) };
+}
+
+function matInv(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= f * M[i][c];
+    }
+  }
+  return M.map(row => row.slice(n));
+}
+
+function ols(y, predictors, predicate = null) {
+  const names = ['intercept'].concat(predictors.map(p => p.name));
+  const p = names.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let n = 0;
+  const rows = [];
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    const row = [1].concat(predictors.map(pr => pr.fn(i)));
+    rows.push([row, y[i]]);
+    n++;
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = matInv(xtx);
+  const beta = inv.map(row => row.reduce((acc, v, j) => acc + v * xty[j], 0));
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (const [row, yi] of rows) {
+    const fitted = beta.reduce((acc, b, j) => acc + b * row[j], 0);
+    const e = yi - fitted;
+    for (let a = 0; a < p; a++) {
+      for (let b = 0; b < p; b++) meat[a][b] += row[a] * row[b] * e * e;
+    }
+  }
+  const scale = n / (n - p);
+  const cov = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) {
+      let v = 0;
+      for (let k = 0; k < p; k++) for (let l = 0; l < p; l++) v += inv[a][k] * meat[k][l] * inv[l][b];
+      cov[a][b] = v * scale;
+    }
+  }
+  const result = {};
+  for (let j = 0; j < p; j++) {
+    const se = Math.sqrt(Math.max(0, cov[j][j]));
+    result[names[j]] = { beta: beta[j], se, z: beta[j] / se, p: twoSidedP(beta[j] / se) };
+  }
+  return { n, names, result };
+}
+
+function mean(arr) {
+  return arr.reduce((a, b) => a + b, 0) / arr.length;
+}
+
+function quantile(arr, q) {
+  const sorted = Array.from(arr).sort((a, b) => a - b);
+  const pos = (sorted.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  if (lo === hi) return sorted[lo];
+  return sorted[lo] + (sorted[hi] - sorted[lo]) * (pos - lo);
+}
+
+function fmtPct(x) {
+  return `${(100 * x).toFixed(1)}%`;
+}
+
+function fmtP(p) {
+  if (p === 0) return '<1e-300';
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function makePredictor(col, columns, scale = 1, center = null) {
+  const c = columns[col];
+  const m = center === null ? 0 : center;
+  return { name: col, fn: i => (c[i] - m) / scale };
+}
+
+function interactionPredictor(name, columns, a, b, aScale = 1, bScale = 1, aCenter = 0, bCenter = 0) {
+  const ca = columns[a], cb = columns[b];
+  return { name, fn: i => ((ca[i] - aCenter) / aScale) * ((cb[i] - bCenter) / bScale) };
+}
+
+function main() {
+  const { columns, n } = readParquetColumns();
+  const y = columns.objective_response;
+  const binaryCols = Object.keys(columns).filter(c => c !== 'objective_response' && columns[c].every(v => v === 0 || v === 1));
+  const treatmentCols = binaryCols.filter(c => c.startsWith('treatment_'));
+  const mutationCols = binaryCols.filter(c => c.endsWith('_mutation') || c.includes('flt3_') || c === 'npm1_mutation' || c === 'complex_karyotype');
+  const clinicalBinary = binaryCols.filter(c => !treatmentCols.includes(c) && !mutationCols.includes(c));
+
+  const univariate = binaryCols.map(c => ({ col: c, ...proportionEffect(columns[c], y) }))
+    .sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+  const treatmentEffects = treatmentCols.map(c => ({ col: c, ...proportionEffect(columns[c], y) }))
+    .sort((a, b) => b.effect - a.effect);
+  const continuousScales = {
+    age_years: 10,
+    wbc_k_per_ul: 10,
+    blast_pct_marrow: 10,
+    albumin_g_dl: 1,
+    ldh_u_l: 100,
+    weight_loss_pct_6mo: 5,
+    crp_mg_l: 10,
+    nlr: 1,
+    hemoglobin_g_dl: 1,
+    creatinine_mg_dl: 1,
+    platelets_k_ul: 50,
+    bmi: 5,
+    heart_rate_bpm: 10,
+    spo2_pct: 1
+  };
+  const continuousCols = Object.keys(continuousScales);
+  const continuous = continuousCols.map(c => ({ col: c, scale: continuousScales[c], ...continuousEffectPerUnit(columns[c], y, continuousScales[c]) }))
+    .sort((a, b) => Math.abs(b.effect) - Math.abs(a.effect));
+
+  const center = {};
+  for (const c of Object.keys(columns)) center[c] = mean(columns[c]);
+  const baseCovars = [
+    makePredictor('age_years', columns, 10, center.age_years),
+    makePredictor('sex_female', columns),
+    makePredictor('ecog_ps', columns),
+    makePredictor('secondary_aml', columns),
+    makePredictor('unfit_for_intensive', columns),
+    makePredictor('complex_karyotype', columns),
+    makePredictor('tp53_mutation', columns),
+    makePredictor('flt3_itd', columns),
+    makePredictor('idh1_mutation', columns),
+    makePredictor('idh2_mutation', columns),
+    makePredictor('npm1_mutation', columns),
+    makePredictor('wbc_k_per_ul', columns, 10, center.wbc_k_per_ul),
+    makePredictor('albumin_g_dl', columns, 1, center.albumin_g_dl),
+    makePredictor('crp_mg_l', columns, 10, center.crp_mg_l),
+    makePredictor('weight_loss_pct_6mo', columns, 5, center.weight_loss_pct_6mo)
+  ];
+
+  function adjustedTerm(term, extra = []) {
+    const fit = ols(y, baseCovars.concat(extra), null);
+    return fit.result[term];
+  }
+  function adjustedWith(termCol) {
+    const fit = ols(y, baseCovars.concat([makePredictor(termCol, columns)]), null);
+    return fit.result[termCol];
+  }
+  function interactionFit(a, b, extraCols = []) {
+    const intName = `${a}_x_${b}`;
+    const predictors = baseCovars.concat(extraCols.map(c => makePredictor(c, columns)), [
+      makePredictor(a, columns),
+      makePredictor(b, columns),
+      interactionPredictor(intName, columns, a, b)
+    ]);
+    const fit = ols(y, predictors, null);
+    return fit.result[intName];
+  }
+
+  const adjustedTreatments = treatmentCols.map(c => ({ col: c, ...adjustedWith(c) }))
+    .sort((a, b) => b.beta - a.beta);
+  const adjustedBiomarkers = ['flt3_itd', 'idh1_mutation', 'idh2_mutation', 'npm1_mutation', 'tp53_mutation', 'complex_karyotype', 'secondary_aml']
+    .map(c => ({ col: c, ...adjustedWith(c) })).sort((a, b) => a.beta - b.beta);
+
+  const interactionsToTest = [
+    ['treatment_midostaurin', 'flt3_itd'],
+    ['treatment_gilteritinib', 'flt3_itd'],
+    ['treatment_ivosidenib', 'idh1_mutation'],
+    ['treatment_enasidenib', 'idh2_mutation'],
+    ['treatment_venetoclax_azacitidine', 'unfit_for_intensive'],
+    ['treatment_7plus3', 'unfit_for_intensive'],
+    ['treatment_7plus3', 'age_years'],
+    ['treatment_venetoclax_azacitidine', 'age_years'],
+    ['treatment_7plus3', 'complex_karyotype'],
+    ['treatment_venetoclax_azacitidine', 'tp53_mutation'],
+    ['treatment_midostaurin', 'npm1_mutation'],
+    ['treatment_gilteritinib', 'complex_karyotype']
+  ];
+  function interactionFitScaled(a, b) {
+    const intName = `${a}_x_${b}`;
+    const bScale = b === 'age_years' ? 10 : 1;
+    const bCenter = b === 'age_years' ? center.age_years : 0;
+    const predictors = baseCovars.concat([
+      makePredictor(a, columns),
+      makePredictor(b, columns, bScale, b === 'age_years' ? center.age_years : null),
+      interactionPredictor(intName, columns, a, b, 1, bScale, 0, bCenter)
+    ]);
+    const fit = ols(y, predictors, null);
+    return fit.result[intName];
+  }
+  const interactions = interactionsToTest.map(([a, b]) => ({ a, b, ...interactionFitScaled(a, b) }))
+    .sort((x, y2) => Math.abs(y2.beta) - Math.abs(x.beta));
+
+  const subgroups = {};
+  subgroups.midostaurin_flt3_pos = proportionEffect(columns.treatment_midostaurin, y, i => columns.flt3_itd[i] === 1);
+  subgroups.midostaurin_flt3_neg = proportionEffect(columns.treatment_midostaurin, y, i => columns.flt3_itd[i] === 0);
+  subgroups.gilteritinib_flt3_pos = proportionEffect(columns.treatment_gilteritinib, y, i => columns.flt3_itd[i] === 1);
+  subgroups.gilteritinib_flt3_neg = proportionEffect(columns.treatment_gilteritinib, y, i => columns.flt3_itd[i] === 0);
+  subgroups.ivosidenib_idh1_pos = proportionEffect(columns.treatment_ivosidenib, y, i => columns.idh1_mutation[i] === 1);
+  subgroups.ivosidenib_idh1_neg = proportionEffect(columns.treatment_ivosidenib, y, i => columns.idh1_mutation[i] === 0);
+  subgroups.enasidenib_idh2_pos = proportionEffect(columns.treatment_enasidenib, y, i => columns.idh2_mutation[i] === 1);
+  subgroups.enasidenib_idh2_neg = proportionEffect(columns.treatment_enasidenib, y, i => columns.idh2_mutation[i] === 0);
+  subgroups.ven_unfit_pos = proportionEffect(columns.treatment_venetoclax_azacitidine, y, i => columns.unfit_for_intensive[i] === 1);
+  subgroups.ven_unfit_neg = proportionEffect(columns.treatment_venetoclax_azacitidine, y, i => columns.unfit_for_intensive[i] === 0);
+  subgroups.seven3_unfit_pos = proportionEffect(columns.treatment_7plus3, y, i => columns.unfit_for_intensive[i] === 1);
+  subgroups.seven3_unfit_neg = proportionEffect(columns.treatment_7plus3, y, i => columns.unfit_for_intensive[i] === 0);
+
+  const lowAlbumin = quantile(columns.albumin_g_dl, 0.25);
+  const highCrp = quantile(columns.crp_mg_l, 0.75);
+  const highLdh = quantile(columns.ldh_u_l, 0.75);
+  const highWbc = quantile(columns.wbc_k_per_ul, 0.75);
+  const inflamed = Array.from({ length: n }, (_, i) => columns.albumin_g_dl[i] < lowAlbumin && columns.crp_mg_l[i] > highCrp);
+  const proliferative = Array.from({ length: n }, (_, i) => columns.wbc_k_per_ul[i] > highWbc && columns.ldh_u_l[i] > highLdh);
+  const inflamedEffect = proportionEffect(inflamed, y);
+  const proliferativeEffect = proportionEffect(proliferative, y);
+
+  const summary = {
+    n,
+    outcomeMean: mean(y),
+    outcomeSum: y.reduce((a, b) => a + b, 0),
+    binaryPrevalence: Object.fromEntries(binaryCols.map(c => [c, mean(columns[c])])),
+    treatmentEffects,
+    univariate: univariate.slice(0, 30),
+    continuous,
+    adjustedTreatments,
+    adjustedBiomarkers,
+    interactions,
+    subgroups,
+    lowAlbumin,
+    highCrp,
+    highLdh,
+    highWbc,
+    inflamedEffect,
+    proliferativeEffect
+  };
+  fs.writeFileSync('analysis_results.json', JSON.stringify(summary, null, 2));
+  console.log(JSON.stringify(summary, null, 2));
+}
+
+main();

