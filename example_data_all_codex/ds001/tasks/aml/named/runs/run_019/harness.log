+
+function proportionEffect(x, y, predicate = null) {
+  let n1 = 0, s1 = 0, n0 = 0, s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i] === null || y[i] === null || Number.isNaN(x[i]) || Number.isNaN(y[i])) continue;
+    if (x[i]) { n1++; s1 += y[i]; } else { n0++; s0 += y[i]; }
+  }
+  const p1 = s1 / n1;
+  const p0 = s0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  return { n1, n0, p1, p0, effect, se, z: effect / se, p: twoSidedP(effect / se) };
+}
+
+function continuousEffectPerUnit(x, y, scale = 1, predicate = null) {
+  let n = 0, sx = 0, sy = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i] === null || y[i] === null || Number.isNaN(x[i]) || Number.isNaN(y[i])) continue;
+    n++;
+    sx += x[i] / scale;
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0, sxy = 0, rss = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i] === null || y[i] === null || Number.isNaN(x[i]) || Number.isNaN(y[i])) continue;
+    const xi = x[i] / scale;
+    sxx += (xi - mx) * (xi - mx);
+    sxy += (xi - mx) * (y[i] - my);
+  }
+  const beta = sxy / sxx;
+  const alpha = my - beta * mx;
+  for (let i = 0; i < y.length; i++) {
+    if (predicate && !predicate(i)) continue;
+    if (x[i] === null || y[i] === null || Number.isNaN(x[i]) || Number.isNaN(y[i])) continue;
+    const e = y[i] - alpha - beta * (x[i] / scale);
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  return { n, effect: beta, se, z: beta / se, p: twoSidedP(beta / se) };
