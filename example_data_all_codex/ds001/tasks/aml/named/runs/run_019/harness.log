+const fs = require('fs');
+
+const PARQUET_FILE = 'dataset.parquet';
+
+function makeCompactReader(buf, start = 0) {
+  let pos = start;
+  function readByte() {
+    if (pos >= buf.length) throw new Error(`Unexpected EOF at ${pos}`);
+    return buf[pos++];
+  }
+  function readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  function readZigzag() {
+    const n = readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  function readString() {
+    const len = Number(readVarint());
+    const s = buf.subarray(pos, pos + len).toString();
+    pos += len;
+    return s;
+  }
+  function skip(type) {
+    if (type === 0 || type === 1 || type === 2) return;
+    if (type === 3) {
+      pos += 1;
+      return;
+    }
+    if (type === 4 || type === 5 || type === 6) {
+      readZigzag();
+      return;
+    }
+    if (type === 7) {
+      pos += 8;
+      return;
+    }
+    if (type === 13) {
+      pos += 4;
+      return;
+    }
+    if (type === 8) {
+      pos += Number(readVarint());
+      return;
+    }
+    if (type === 9 || type === 10) {
+      const b = readByte();
+      let size = b >> 4;
+      const elemType = b & 0x0f;
+      if (size === 15) size = Number(readVarint());
+      for (let i = 0; i < size; i++) skip(elemType);
+      return;
+    }
+    if (type === 11) {
+      const size = Number(readVarint());
+      if (size > 0) {
+        const b = readByte();
+        const keyType = (b >> 4) & 0x0f;
+        const valueType = b & 0x0f;
+        for (let i = 0; i < size; i++) {
+          skip(keyType);
+          skip(valueType);
+        }
+      }
+      return;
+    }
+    if (type === 12) {
+      readStruct(null);
+      return;
+    }
+    throw new Error(`Unknown compact type ${type}`);
+  }
+  function fieldHeader(lastId) {
+    const b = readByte();
+    const type = b & 0x0f;
+    if (type === 0) return null;
+    const delta = b >> 4;
+    return { id: delta ? lastId + delta : Number(readZigzag()), type };
+  }
+  function childKind(kind, id) {
+    if (kind === 'FileMetaData' && id === 2) return 'SchemaElementList';
+    if (kind === 'FileMetaData' && id === 4) return 'RowGroupList';
+    if (kind === 'RowGroup' && id === 1) return 'ColumnChunkList';
+    if (kind === 'ColumnChunk' && id === 3) return 'ColumnMetaData';
+    if (kind === 'ColumnMetaData' && id === 2) return 'I32List';
+    if (kind === 'ColumnMetaData' && id === 3) return 'StringList';
+    if (kind === 'PageHeader' && id === 5) return 'DataPageHeader';
+    if (kind === 'PageHeader' && id === 7) return 'DictionaryPageHeader';
+    if (kind === 'PageHeader' && id === 8) return 'DataPageHeaderV2';
+    return null;
+  }
+  function readValue(type, kind) {
+    if (type === 1) return true;
+    if (type === 2) return false;
+    if (type === 3) return readByte();
+    if (type === 4 || type === 5) return Number(readZigzag());
+    if (type === 6) return Number(readZigzag());
+    if (type === 7) {
+      const v = buf.readDoubleLE(pos);
+      pos += 8;
+      return v;
+    }
+    if (type === 13) {
+      const v = buf.readFloatLE(pos);
+      pos += 4;
+      return v;
+    }
+    if (type === 8) return readString();
+    if (type === 12) return readStruct(kind);
+    if (type === 9 || type === 10) {
+      const b = readByte();
+      let size = b >> 4;
+      const elemType = b & 0x0f;
+      if (size === 15) size = Number(readVarint());
+      let elemKind = null;
+      if (kind === 'SchemaElementList') elemKind = 'SchemaElement';
+      if (kind === 'RowGroupList') elemKind = 'RowGroup';
+      if (kind === 'ColumnChunkList') elemKind = 'ColumnChunk';
+      const arr = [];
+      for (let i = 0; i < size; i++) arr.push(readValue(elemType, elemKind));
+      return arr;
+    }
+    if (type === 11) {
+      skip(type);
+      return null;
+    }
+    throw new Error(`Unknown value compact type ${type}`);
+  }
+  function readStruct(kind) {
+    let lastId = 0;
+    const obj = {};
+    while (pos < buf.length) {
+      const header = fieldHeader(lastId);
+      if (!header) break;
+      lastId = header.id;
+      obj[header.id] = readValue(header.type, childKind(kind, header.id));
+    }
+    return obj;
+  }
+  return { readStruct, get pos() { return pos; } };
+}
+
+function snappyUncompress(src) {
+  let pos = 0;
+  let shift = 0;
+  let len = 0;
+  while (true) {
+    const b = src[pos++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let op = 0;
+  while (pos < src.length) {
+    const tag = src[pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
+        const bytes = literalLen - 59;
+        literalLen = 0;
+        for (let i = 0; i < bytes; i++) literalLen |= src[pos++] << (8 * i);
+        literalLen += 1;
+      }
+      src.copy(out, op, pos, pos + literalLen);
+      pos += literalLen;
+      op += literalLen;
+    } else {
+      let copyLen;
+      let offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | src[pos++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = src[pos] | (src[pos + 1] << 8);
+        pos += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = (src[pos] | (src[pos + 1] << 8) | (src[pos + 2] << 16) | (src[pos + 3] << 24)) >>> 0;
+        pos += 4;
+      }
+      for (let i = 0; i < copyLen; i++) {
+        out[op] = out[op - offset];
+        op++;
+      }
+    }
+  }
+  if (op !== len) throw new Error(`Snappy length mismatch ${op} != ${len}`);
+  return out;
+}
