+function readField(r, last) {
+  const h = r.readByte();
+  if (h === 0) return null;
+  const type = h & 15;
+  const delta = h >> 4;
+  return { id: delta ? last + delta : r.readI16(), type };
+}
+
+function readListHeader(r) {
+  const h = r.readByte();
+  let size = h >> 4;
+  const type = h & 15;
+  if (size === 15) size = Number(r.readVar());
+  return { size, type };
