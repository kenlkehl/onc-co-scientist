+function regress(y, cols) {
+  const n = y.length, p = cols.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = cols[a].x[i];
+      xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += xa * cols[b].x[i];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = a + 1; b < p; b++) xtx[a][b] = xtx[b][a];
+  const inv = inverse(xtx);
+  const beta = inv.map(row => row.reduce((s, v, j) => s + v * xty[j], 0));
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let a = 0; a < p; a++) pred += beta[a] * cols[a].x[i];
+    const e2 = (y[i] - pred) ** 2;
+    for (let a = 0; a < p; a++) {
