+function readUnsignedVar(buf, state) {
+  let shift = 0;
+  let n = 0;
+  while (true) {
+    const b = buf[state.p++];
+    n |= (b & 0x7f) << shift;
+    if (!(b & 0x80)) break;
+    shift += 7;
+  }
+  return n;
+}
+
+function readIntLEWidth(buf, state, width) {
+  let v = 0;
+  const bytes = Math.ceil(width / 8);
+  for (let i = 0; i < bytes; i++) v |= buf[state.p++] << (8 * i);
+  return v;
+}
+
+function decodeHybrid(buf, offset, width, count) {
+  const out = [];
+  const state = { p: offset };
+  while (out.length < count) {
+    const header = readUnsignedVar(buf, state);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const value = readIntLEWidth(buf, state, width);
+      for (let i = 0; i < run && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bitPos = 0;
+      const bytes = Math.ceil((total * width) / 8);
+      const start = state.p;
+      for (let i = 0; i < total && out.length < count; i++) {
+        let v = 0;
+        for (let b = 0; b < width; b++) {
+          const byte = buf[start + ((bitPos + b) >> 3)];
+          const bit = (byte >> ((bitPos + b) & 7)) & 1;
+          v |= bit << b;
+        }
+        bitPos += width;
+        out.push(v);
+      }
+      state.p += bytes;
+    }
+  }
+  return { values: out, bytesRead: state.p - offset };
+}
+
+function decodePlainDictionary(buf, type, count) {
+  const out = [];
+  let p = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === 2) {
+      out.push(Number(buf.readBigInt64LE(p)));
+      p += 8;
+    } else if (type === 5) {
+      out.push(buf.readDoubleLE(p));
+      p += 8;
+    } else if (type === 6) {
+      const len = buf.readInt32LE(p);
+      p += 4;
+      out.push(buf.subarray(p, p + len).toString("utf8"));
+      p += len;
+    } else {
