+function readUnsignedVar(buf, state) {
+  let shift = 0;
+  let n = 0;
+  while (true) {
+    const b = buf[state.p++];
+    n |= (b & 0x7f) << shift;
+    if (!(b & 0x80)) break;
+    shift += 7;
+  }
+  return n;
