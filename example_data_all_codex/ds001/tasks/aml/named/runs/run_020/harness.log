+    { name: b, x: columns[b] },
+    { name: `${a}:${b}`, x: ix },
+    ...baseCovars.filter(c => c.name !== a && c.name !== b),
+    ...treatmentNames.map(n => ({ name: n, x: columns[n] })),
+  ];
+  try {
+    const fit = regress(y, covars).find(r => r.name === `${a}:${b}`);
+    console.log(`${a}:${b}`, "interaction_RD", fit.beta.toFixed(4), "p", fit.p.toExponential(3));
+  } catch (e) {
+    console.log(`${a}:${b}`, "failed", e.message);
+  }
+}
+
+console.log("\\nTreatment x continuous interactions, adjusted");
+const contForInteraction = ["ecog_ps", "weight_loss_pct_6mo", "blast_pct_marrow", "wbc_k_per_ul", "albumin_g_dl", "crp_mg_l", "nlr", "age_years"];
