+const fs = require("fs");
+
+const CT = { STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6, DOUBLE: 7, BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12 };
+
+class ThriftReader {
+  constructor(buffer, offset = 0) {
+    this.b = buffer;
+    this.p = offset;
+  }
+  readByte() { return this.b[this.p++]; }
+  readVar() {
+    let shift = 0n;
+    let n = 0n;
+    while (true) {
+      const x = this.readByte();
+      n |= BigInt(x & 0x7f) << shift;
+      if (!(x & 0x80)) break;
+      shift += 7n;
+    }
+    return n;
+  }
+  zz(n) { return Number((n >> 1n) ^ (-(n & 1n))); }
+  readI16() { return this.zz(this.readVar()); }
+  readI32() { return this.zz(this.readVar()); }
+  readI64() { return this.zz(this.readVar()); }
+  readDouble() {
+    const v = this.b.readDoubleLE(this.p);
+    this.p += 8;
+    return v;
+  }
+  readBin() {
+    const len = Number(this.readVar());
+    const s = this.b.subarray(this.p, this.p + len);
+    this.p += len;
+    return s;
+  }
+}
+
+function readField(r, last) {
+  const h = r.readByte();
+  if (h === 0) return null;
+  const type = h & 15;
+  const delta = h >> 4;
+  return { id: delta ? last + delta : r.readI16(), type };
+}
+
+function readListHeader(r) {
+  const h = r.readByte();
+  let size = h >> 4;
+  const type = h & 15;
+  if (size === 15) size = Number(r.readVar());
+  return { size, type };
+}
+
+function skip(r, type) {
+  switch (type) {
+    case CT.STOP:
+    case CT.TRUE:
+    case CT.FALSE:
+      return;
+    case CT.BYTE:
+      r.p += 1; return;
+    case CT.I16:
+      r.readI16(); return;
+    case CT.I32:
+      r.readI32(); return;
+    case CT.I64:
+      r.readI64(); return;
+    case CT.DOUBLE:
+      r.p += 8; return;
+    case CT.BINARY:
+      r.readBin(); return;
+    case CT.LIST:
+    case CT.SET: {
+      const { size, type: t } = readListHeader(r);
+      for (let i = 0; i < size; i++) skip(r, t);
+      return;
+    }
+    case CT.MAP: {
+      const size = Number(r.readVar());
+      if (size) {
+        const types = r.readByte();
+        const kt = types >> 4;
+        const vt = types & 15;
+        for (let i = 0; i < size; i++) {
+          skip(r, kt);
+          skip(r, vt);
+        }
+      }
+      return;
+    }
+    case CT.STRUCT: {
+      let last = 0;
+      while (true) {
+        const f = readField(r, last);
+        if (!f) break;
+        last = f.id;
+        skip(r, f.type);
+      }
+      return;
+    }
+    default:
+      throw new Error(`unknown compact type ${type} at ${r.p}`);
+  }
+}
+
+function readString(r) { return r.readBin().toString("utf8"); }
+function readList(r, elemReader) {
+  const { size } = readListHeader(r);
+  const arr = [];
+  for (let i = 0; i < size; i++) arr.push(elemReader(r));
+  return arr;
+}
+
+function readSchemaElement(r) {
+  const o = {};
+  let last = 0;
+  while (true) {
+    const f = readField(r, last);
+    if (!f) break;
+    last = f.id;
+    if (f.id === 1) o.type = r.readI32();
+    else if (f.id === 2) o.type_length = r.readI32();
+    else if (f.id === 3) o.repetition_type = r.readI32();
+    else if (f.id === 4) o.name = readString(r);
+    else if (f.id === 5) o.num_children = r.readI32();
+    else if (f.id === 6) o.converted_type = r.readI32();
+    else if (f.id === 7) o.scale = r.readI32();
+    else if (f.id === 8) o.precision = r.readI32();
+    else if (f.id === 9) o.field_id = r.readI32();
+    else skip(r, f.type);
+  }
+  return o;
+}
+
+function readKeyValue(r) {
+  const o = {};
+  let last = 0;
+  while (true) {
+    const f = readField(r, last);
+    if (!f) break;
+    last = f.id;
+    if (f.id === 1) o.key = readString(r);
+    else if (f.id === 2) o.value = readString(r);
+    else skip(r, f.type);
+  }
+  return o;
+}
+
+function readStats(r) {
+  const o = {};
+  let last = 0;
+  while (true) {
+    const f = readField(r, last);
+    if (!f) break;
+    last = f.id;
+    if ([1, 2, 5, 6].includes(f.id)) o[`f${f.id}`] = r.readBin();
+    else if (f.id === 3) o.null_count = r.readI64();
+    else if (f.id === 4) o.distinct_count = r.readI64();
+    else skip(r, f.type);
+  }
+  return o;
+}
+
+function readColumnMeta(r) {
+  const o = {};
+  let last = 0;
+  while (true) {
+    const f = readField(r, last);
+    if (!f) break;
+    last = f.id;
+    if (f.id === 1) o.type = r.readI32();
+    else if (f.id === 2) o.encodings = readList(r, rr => rr.readI32());
+    else if (f.id === 3) o.path_in_schema = readList(r, readString);
+    else if (f.id === 4) o.codec = r.readI32();
+    else if (f.id === 5) o.num_values = r.readI64();
+    else if (f.id === 6) o.total_uncompressed_size = r.readI64();
+    else if (f.id === 7) o.total_compressed_size = r.readI64();
+    else if (f.id === 8) o.key_value_metadata = readList(r, readKeyValue);
+    else if (f.id === 9) o.data_page_offset = r.readI64();
+    else if (f.id === 10) o.index_page_offset = r.readI64();
+    else if (f.id === 11) o.dictionary_page_offset = r.readI64();
+    else if (f.id === 12) o.statistics = readStats(r);
+    else skip(r, f.type);
+  }
+  return o;
+}
+
+function readColumnChunk(r) {
+  const o = {};
+  let last = 0;
+  while (true) {
+    const f = readField(r, last);
+    if (!f) break;
+    last = f.id;
+    if (f.id === 1) o.file_path = readString(r);
+    else if (f.id === 2) o.file_offset = r.readI64();
+    else if (f.id === 3) o.meta_data = readColumnMeta(r);
+    else if (f.id === 4) o.offset_index_offset = r.readI64();
+    else if (f.id === 5) o.offset_index_length = r.readI32();
+    else if (f.id === 6) o.column_index_offset = r.readI64();
+    else if (f.id === 7) o.column_index_length = r.readI32();
+    else skip(r, f.type);
+  }
+  return o;
+}
+
+function readRowGroup(r) {
+  const o = {};
+  let last = 0;
+  while (true) {
+    const f = readField(r, last);
+    if (!f) break;
+    last = f.id;
+    if (f.id === 1) o.columns = readList(r, readColumnChunk);
+    else if (f.id === 2) o.total_byte_size = r.readI64();
+    else if (f.id === 3) o.num_rows = r.readI64();
+    else if (f.id === 5) o.file_offset = r.readI64();
+    else if (f.id === 6) o.total_compressed_size = r.readI64();
+    else if (f.id === 7) o.ordinal = r.readI16();
+    else skip(r, f.type);
+  }
+  return o;
+}
+
+function readFileMeta(buffer) {
+  const len = buffer.readUInt32LE(buffer.length - 8);
+  const meta = buffer.subarray(buffer.length - 8 - len, buffer.length - 8);
+  const r = new ThriftReader(meta);
+  const o = {};
+  let last = 0;
+  while (true) {
+    const f = readField(r, last);
+    if (!f) break;
+    last = f.id;
+    if (f.id === 1) o.version = r.readI32();
+    else if (f.id === 2) o.schema = readList(r, readSchemaElement);
+    else if (f.id === 3) o.num_rows = r.readI64();
