+for (const t of treatmentNames) {
+  for (const b of binary.filter(n => !n.startsWith("treatment_"))) {
+    const ix = columns[t].map((v, i) => v * columns[b][i]);
+    const covars = [
+      { name: "intercept", x: Array(y.length).fill(1) },
