+    const raw = snappyUncompress(buffer.subarray(h.body_start, h.body_start + h.compressed_page_size));
+    dict = decodePlainDictionary(raw, md.type, h.dictionary_page_header.num_values);
+  }
+  const values = [];
+  let pos = md.data_page_offset;
+  while (values.length < md.num_values) {
+    const h = readPageHeader(buffer, pos);
+    const body = snappyUncompress(buffer.subarray(h.body_start, h.body_start + h.compressed_page_size));
+    if (h.data_page_header) {
