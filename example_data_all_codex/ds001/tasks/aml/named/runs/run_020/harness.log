+  const p1 = s1 / n1, p0 = s0 / n0, p = (s1 + s0) / (n1 + n0);
+  const se = Math.sqrt(p * (1 - p) * (1 / n1 + 1 / n0));
+  return { n1, n0, p1, p0, rd: p1 - p0, z: (p1 - p0) / se, p: pFromZ((p1 - p0) / se) };
