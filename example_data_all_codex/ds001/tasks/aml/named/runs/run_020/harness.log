+function decodeHybrid(buf, offset, width, count) {
+  const out = [];
+  const state = { p: offset };
+  while (out.length < count) {
+    const header = readUnsignedVar(buf, state);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const value = readIntLEWidth(buf, state, width);
+      for (let i = 0; i < run && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bitPos = 0;
+      const bytes = Math.ceil((total * width) / 8);
+      const start = state.p;
+      for (let i = 0; i < total && out.length < count; i++) {
+        let v = 0;
+        for (let b = 0; b < width; b++) {
+          const byte = buf[start + ((bitPos + b) >> 3)];
+          const bit = (byte >> ((bitPos + b) & 7)) & 1;
+          v |= bit << b;
+        }
+        bitPos += width;
+        out.push(v);
+      }
+      state.p += bytes;
+    }
+  }
+  return { values: out, bytesRead: state.p - offset };
