+  const p1 = s1 / n1, p0 = s0 / n0, p = (s1 + s0) / (n1 + n0);
+  const se = Math.sqrt(p * (1 - p) * (1 / n1 + 1 / n0));
+  return { n1, n0, p1, p0, rd: p1 - p0, z: (p1 - p0) / se, p: pFromZ((p1 - p0) / se) };
+}
+
+function inverse(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error("singular matrix");
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= f * M[i][c];
+    }
+  }
+  return M.map(row => row.slice(n));
+}
+
+function regress(y, cols) {
+  const n = y.length, p = cols.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = cols[a].x[i];
+      xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += xa * cols[b].x[i];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = a + 1; b < p; b++) xtx[a][b] = xtx[b][a];
+  const inv = inverse(xtx);
+  const beta = inv.map(row => row.reduce((s, v, j) => s + v * xty[j], 0));
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let a = 0; a < p; a++) pred += beta[a] * cols[a].x[i];
+    const e2 = (y[i] - pred) ** 2;
+    for (let a = 0; a < p; a++) {
+      const xa = cols[a].x[i];
+      for (let b = 0; b <= a; b++) meat[a][b] += xa * cols[b].x[i] * e2;
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = a + 1; b < p; b++) meat[a][b] = meat[b][a];
+  const cov = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) {
+      let s = 0;
+      for (let k = 0; k < p; k++) for (let l = 0; l < p; l++) s += inv[a][k] * meat[k][l] * inv[l][b];
+      cov[a][b] = s * n / (n - p);
+    }
+  }
+  return cols.map((c, j) => {
+    const se = Math.sqrt(Math.max(0, cov[j][j]));
+    return { name: c.name, beta: beta[j], se, z: beta[j] / se, p: pFromZ(beta[j] / se) };
+  });
+}
+
+function zscore(x) {
+  const m = mean(x), s = sd(x);
+  return x.map(v => (v - m) / s);
+}
+
+const buffer = fs.readFileSync("dataset.parquet");
+const meta = readFileMeta(buffer);
+const columns = {};
+for (const col of meta.row_groups[0].columns) {
+  const name = col.meta_data.path_in_schema.join(".");
+  if (name === "patient_id") continue;
+  columns[name] = readColumn(buffer, col);
+}
+
+const y = columns.objective_response;
+console.log("rows", y.length, "overall response", mean(y).toFixed(4));
+const names = Object.keys(columns).filter(n => n !== "objective_response");
+
+const binary = names.filter(n => {
+  const vals = new Set(columns[n]);
+  return vals.size === 2 && vals.has(0) && vals.has(1);
+});
+const continuous = names.filter(n => !binary.includes(n));
+console.log("binary", binary.length, "continuous", continuous.length);
+console.log("treatments");
+for (const n of names.filter(n => n.startsWith("treatment_"))) {
+  const r = propTest(columns[n], y);
+  console.log(n, "n", r.n1, "rate1", r.p1.toFixed(4), "rate0", r.p0.toFixed(4), "RD", r.rd.toFixed(4), "p", r.p.toExponential(3));
+}
+console.log("\\nTop binary univariate");
+binary.map(n => ({ n, ...propTest(columns[n], y) }))
+  .sort((a, b) => Math.abs(b.rd) - Math.abs(a.rd))
+  .slice(0, 35)
+  .forEach(r => console.log(r.n, "n1", r.n1, "rate1", r.p1.toFixed(4), "rate0", r.p0.toFixed(4), "RD", r.rd.toFixed(4), "p", r.p.toExponential(3)));
+
+console.log("\\nContinuous per-SD LPM univariate");
+const uniCont = [];
+for (const n of continuous) {
+  const fit = regress(y, [{ name: "intercept", x: Array(y.length).fill(1) }, { name: n, x: zscore(columns[n]) }])[1];
+  uniCont.push({ n, ...fit });
+}
+uniCont.sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta)).forEach(r => console.log(r.n, "beta_per_sd", r.beta.toFixed(4), "p", r.p.toExponential(3)));
+
+console.log("\\nSelected interactions adjusted for age/sex/ecog/secondary/unfit/complex/tp53/wbc/blasts/albumin/crp/nlr");
+const baseCovars = [
+  { name: "age_years_z", x: zscore(columns.age_years) },
+  { name: "sex_female", x: columns.sex_female },
+  { name: "ecog_ps_z", x: zscore(columns.ecog_ps) },
+  { name: "secondary_aml", x: columns.secondary_aml },
+  { name: "unfit_for_intensive", x: columns.unfit_for_intensive },
+  { name: "complex_karyotype", x: columns.complex_karyotype },
+  { name: "tp53_mutation", x: columns.tp53_mutation },
+  { name: "wbc_k_per_ul_z", x: zscore(columns.wbc_k_per_ul) },
+  { name: "blast_pct_marrow_z", x: zscore(columns.blast_pct_marrow) },
+  { name: "albumin_g_dl_z", x: zscore(columns.albumin_g_dl) },
+  { name: "crp_mg_l_z", x: zscore(columns.crp_mg_l) },
+  { name: "nlr_z", x: zscore(columns.nlr) },
+];
+const interactions = [
+  ["treatment_midostaurin", "flt3_itd"],
+  ["treatment_midostaurin", "flt3_tkd"],
+  ["treatment_gilteritinib", "flt3_itd"],
+  ["treatment_gilteritinib", "flt3_tkd"],
+  ["treatment_ivosidenib", "idh1_mutation"],
+  ["treatment_enasidenib", "idh2_mutation"],
+  ["treatment_venetoclax_azacitidine", "unfit_for_intensive"],
+  ["treatment_venetoclax_azacitidine", "tp53_mutation"],
+  ["treatment_7plus3", "unfit_for_intensive"],
+  ["treatment_7plus3", "npm1_mutation"],
+  ["treatment_7plus3", "tp53_mutation"],
+  ["treatment_7plus3", "complex_karyotype"],
+];
+for (const [a, b] of interactions) {
+  const ix = columns[a].map((v, i) => v * columns[b][i]);
+  const fit = regress(y, [
+    { name: "intercept", x: Array(y.length).fill(1) },
+    { name: a, x: columns[a] },
+    { name: b, x: columns[b] },
+    { name: `${a}:${b}`, x: ix },
+    ...baseCovars.filter(c => ![a, b].includes(c.name)),
+  ]).find(r => r.name === `${a}:${b}`);
+  console.log(`${a}:${b}`, "interaction_RD", fit.beta.toFixed(4), "p", fit.p.toExponential(3));
+}
+
+console.log("\\nWithin-biomarker treatment rates");
+for (const [t, biom] of interactions.slice(0, 8)) {
+  const sub = columns[biom];
+  let n11 = 0, s11 = 0, n01 = 0, s01 = 0, n10 = 0, s10 = 0, n00 = 0, s00 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (sub[i] === 1 && columns[t][i] === 1) { n11++; s11 += y[i]; }
+    else if (sub[i] === 1) { n01++; s01 += y[i]; }
+    else if (columns[t][i] === 1) { n10++; s10 += y[i]; }
+    else { n00++; s00 += y[i]; }
+  }
+  console.log(`${t} among ${biom}=1`, n11, (s11/n11).toFixed(4), "vs", n01, (s01/n01).toFixed(4), "RD", (s11/n11-s01/n01).toFixed(4),
+              "| biom=0 RD", (s10/n10-s00/n00).toFixed(4));
+}
+
+console.log("\\nFull adjusted main effects");
+const fullTerms = [
+  { name: "intercept", x: Array(y.length).fill(1) },
+  ...names.filter(n => n.startsWith("treatment_")).map(n => ({ name: n, x: columns[n] })),
+  ...["age_years", "ecog_ps", "wbc_k_per_ul", "blast_pct_marrow", "albumin_g_dl", "ldh_u_l", "weight_loss_pct_6mo", "crp_mg_l", "nlr"].map(n => ({ name: `${n}_z`, x: zscore(columns[n]) })),
+  ...["sex_female", "secondary_aml", "unfit_for_intensive", "complex_karyotype", "flt3_itd", "flt3_tkd", "idh1_mutation", "idh2_mutation", "npm1_mutation", "tp53_mutation"].map(n => ({ name: n, x: columns[n] })),
+];
+regress(y, fullTerms).filter(r => r.name !== "intercept")
+  .sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta))
+  .forEach(r => console.log(r.name, "adj_beta", r.beta.toFixed(4), "p", r.p.toExponential(3)));
