+function snappyUncompress(input) {
+  let ip = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[ip++];
+    len |= (b & 0x7f) << shift;
+    if (!(b & 0x80)) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let l = tag >> 2;
+      if (l < 60) l += 1;
+      else {
+        const n = l - 59;
+        l = 0;
+        for (let i = 0; i < n; i++) l |= input[ip++] << (8 * i);
+        l += 1;
+      }
+      input.copy(out, op, ip, ip + l);
+      ip += l;
+      op += l;
+    } else {
+      let l, off;
+      if (type === 1) {
+        l = ((tag >> 2) & 7) + 4;
+        off = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        l = (tag >> 2) + 1;
+        off = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        l = (tag >> 2) + 1;
+        off = (input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24)) >>> 0;
+        ip += 4;
+      }
+      for (let i = 0; i < l; i++) out[op + i] = out[op - off + i];
+      op += l;
+    }
