+
+class ThriftReader {
+  constructor(buffer, offset = 0) {
+    this.b = buffer;
+    this.p = offset;
+  }
+  readByte() { return this.b[this.p++]; }
+  readVar() {
+    let shift = 0n;
+    let n = 0n;
+    while (true) {
+      const x = this.readByte();
+      n |= BigInt(x & 0x7f) << shift;
+      if (!(x & 0x80)) break;
+      shift += 7n;
+    }
+    return n;
+  }
+  zz(n) { return Number((n >> 1n) ^ (-(n & 1n))); }
+  readI16() { return this.zz(this.readVar()); }
+  readI32() { return this.zz(this.readVar()); }
+  readI64() { return this.zz(this.readVar()); }
+  readDouble() {
+    const v = this.b.readDoubleLE(this.p);
+    this.p += 8;
+    return v;
+  }
+  readBin() {
+    const len = Number(this.readVar());
+    const s = this.b.subarray(this.p, this.p + len);
+    this.p += len;
+    return s;
+  }
+}
+
+function readField(r, last) {
+  const h = r.readByte();
+  if (h === 0) return null;
+  const type = h & 15;
+  const delta = h >> 4;
+  return { id: delta ? last + delta : r.readI16(), type };
+}
