+  { name: "tp53_mutation", x: columns.tp53_mutation },
+  { name: "wbc_k_per_ul_z", x: zscore(columns.wbc_k_per_ul) },
+  { name: "blast_pct_marrow_z", x: zscore(columns.blast_pct_marrow) },
+  { name: "albumin_g_dl_z", x: zscore(columns.albumin_g_dl) },
+  { name: "crp_mg_l_z", x: zscore(columns.crp_mg_l) },
+  { name: "nlr_z", x: zscore(columns.nlr) },
+];
+const interactions = [
+  ["treatment_midostaurin", "flt3_itd"],
+  ["treatment_midostaurin", "flt3_tkd"],
+  ["treatment_gilteritinib", "flt3_itd"],
+  ["treatment_gilteritinib", "flt3_tkd"],
+  ["treatment_ivosidenib", "idh1_mutation"],
+  ["treatment_enasidenib", "idh2_mutation"],
+  ["treatment_venetoclax_azacitidine", "unfit_for_intensive"],
+  ["treatment_venetoclax_azacitidine", "tp53_mutation"],
+  ["treatment_7plus3", "unfit_for_intensive"],
+  ["treatment_7plus3", "npm1_mutation"],
+  ["treatment_7plus3", "tp53_mutation"],
+  ["treatment_7plus3", "complex_karyotype"],
+];
+for (const [a, b] of interactions) {
+  const ix = columns[a].map((v, i) => v * columns[b][i]);
+  const fit = regress(y, [
+    { name: "intercept", x: Array(y.length).fill(1) },
+    { name: a, x: columns[a] },
+    { name: b, x: columns[b] },
