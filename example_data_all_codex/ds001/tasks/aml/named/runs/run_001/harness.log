+function matMul(A, B) {
+  const out = Array.from({ length: A.length }, () => Array(B[0].length).fill(0));
+  for (let i = 0; i < A.length; i++) {
+    for (let k = 0; k < B.length; k++) {
+      for (let j = 0; j < B[0].length; j++) out[i][j] += A[i][k] * B[k][j];
+    }
+  }
+  return out;
+}
+
+function lpm(cols, terms, filter = null) {
+  const yAll = cols[OUTCOME];
+  const A = [];
+  const y = [];
+  for (let i = 0; i < yAll.length; i++) {
+    if (filter && !filter(i)) continue;
+    A.push(terms.map((term) => term.fn(i)));
+    y.push(yAll[i]);
+  }
+  const xtx = transposeMultiply(A);
+  const xtxInv = invertMatrix(xtx);
+  const xty = transposeMultiply(A, y);
+  const beta = matVec(xtxInv, xty);
+  const k = terms.length;
+  const meat = Array.from({ length: k }, () => Array(k).fill(0));
+  for (let i = 0; i < A.length; i++) {
+    const fitted = A[i].reduce((s, x, j) => s + x * beta[j], 0);
+    const e2 = (y[i] - fitted) * (y[i] - fitted);
+    for (let a = 0; a < k; a++) {
+      for (let b = 0; b < k; b++) meat[a][b] += A[i][a] * A[i][b] * e2;
+    }
+  }
+  const hc1 = A.length / (A.length - k);
+  const variance = matMul(matMul(xtxInv, meat), xtxInv).map((row) => row.map((v) => v * hc1));
+  return {
+    n: A.length,
+    terms: terms.map((t) => t.name),
+    beta,
+    se: variance.map((row, i) => Math.sqrt(Math.max(0, row[i]))),
+  };
+}
+
+function adjustedInteraction(cols, treatment, marker, extraCovariates = []) {
+  const age = cols.age_years;
+  const treatmentValues = cols[treatment];
+  const markerValues = cols[marker];
+  const terms = [
+    { name: "intercept", fn: () => 1 },
+    { name: treatment, fn: (i) => treatmentValues[i] },
+    { name: marker, fn: (i) => markerValues[i] },
+    { name: `${treatment}:${marker}`, fn: (i) => treatmentValues[i] * markerValues[i] },
+  ];
+  const baseCovariates = [
+    { name: "age_years_per_10", fn: (i) => age[i] / 10 },
+    { name: "sex_female", fn: (i) => cols.sex_female[i] },
+    { name: "ecog_ps", fn: (i) => cols.ecog_ps[i] },
+    { name: "secondary_aml", fn: (i) => cols.secondary_aml[i] },
+    { name: "unfit_for_intensive", fn: (i) => cols.unfit_for_intensive[i] },
+    { name: "complex_karyotype", fn: (i) => cols.complex_karyotype[i] },
+    { name: "tp53_mutation", fn: (i) => cols.tp53_mutation[i] },
+  ];
+  const used = new Set(terms.map((t) => t.name));
+  for (const term of baseCovariates) {
+    if (!used.has(term.name)) {
+      terms.push(term);
+      used.add(term.name);
+    }
+  }
+  for (const c of extraCovariates) {
+    if (!used.has(c)) {
+      terms.push({ name: c, fn: (i) => cols[c][i] });
+      used.add(c);
+    }
+  }
+  const fit = lpm(cols, terms);
+  const idx = fit.terms.indexOf(`${treatment}:${marker}`);
+  const effect = fit.beta[idx];
+  const se = fit.se[idx];
+  const z = effect / se;
+  const p = pFromZ(z);
+  return { n: fit.n, effect, se, z, p, significant: p < 0.05 };
+}
+
+function adjustedBinaryEffect(cols, feature, extraTerms = []) {
+  const x = cols[feature];
+  const terms = [
+    { name: "intercept", fn: () => 1 },
+    { name: feature, fn: (i) => x[i] },
+  ];
+  const baseCovariates = [
+    { name: "age_years_per_10", fn: (i) => cols.age_years[i] / 10 },
+    { name: "sex_female", fn: (i) => cols.sex_female[i] },
+    { name: "ecog_ps", fn: (i) => cols.ecog_ps[i] },
+    { name: "secondary_aml", fn: (i) => cols.secondary_aml[i] },
+    { name: "unfit_for_intensive", fn: (i) => cols.unfit_for_intensive[i] },
+    { name: "complex_karyotype", fn: (i) => cols.complex_karyotype[i] },
+    { name: "tp53_mutation", fn: (i) => cols.tp53_mutation[i] },
+  ];
+  const used = new Set(terms.map((t) => t.name));
+  for (const term of baseCovariates) {
+    if (!used.has(term.name)) {
+      terms.push(term);
+      used.add(term.name);
+    }
+  }
+  for (const c of extraTerms) {
+    if (!used.has(c)) {
+      terms.push({ name: c, fn: (i) => cols[c][i] });
+      used.add(c);
+    }
+  }
+  const fit = lpm(cols, terms);
+  const effect = fit.beta[1];
+  const se = fit.se[1];
+  const z = effect / se;
+  const p = pFromZ(z);
+  return { n: fit.n, effect, se, z, p, significant: p < 0.05 };
+}
+
+function record(hypothesisIds, label, result, summary) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code: label,
+    result_summary: summary,
+    p_value: Number(result.p.toPrecision(12)),
+    effect_estimate: Number(result.effect.toPrecision(12)),
+    significant: result.p < 0.05,
+  };
+}
+
+function run() {
+  const { columns: cols, n } = readParquet(DATASET);
+  if (n !== 50000) throw new Error(`Expected 50000 rows; found ${n}`);
+
+  const iterations = [];
+  let hid = 1;
+  const newHyp = (text, kind = "novel") => ({ id: `h${hid++}`, text, kind });
+  const addIter = (proposed, analyses) => {
+    iterations.push({ index: iterations.length + 1, proposed_hypotheses: proposed, analyses });
+  };
+
+  const treatmentVars = [
+    "treatment_midostaurin",
+    "treatment_gilteritinib",
+    "treatment_ivosidenib",
+    "treatment_enasidenib",
+    "treatment_venetoclax_azacitidine",
+    "treatment_7plus3",
+  ];
+
+  const mutationVars = [
+    "flt3_itd",
+    "flt3_tkd",
+    "idh1_mutation",
+    "idh2_mutation",
+    "npm1_mutation",
+    "tp53_mutation",
+    "complex_karyotype",
+    "secondary_aml",
+  ];
+
+  // 1. Broad treatment main effects.
+  const h1 = newHyp("Patients with `treatment_venetoclax_azacitidine` have a higher `objective_response` rate than patients without `treatment_venetoclax_azacitidine`.");
+  const h2 = newHyp("Patients with `treatment_7plus3` have a higher `objective_response` rate than patients without `treatment_7plus3`.");
+  const h3 = newHyp("Patients with any FLT3/IDH targeted treatment (`treatment_midostaurin`, `treatment_gilteritinib`, `treatment_ivosidenib`, or `treatment_enasidenib`) have a higher `objective_response` rate than patients without that class of treatment.");
+  const anyTargeted = cols[OUTCOME].map((_, i) => (
+    cols.treatment_midostaurin[i] || cols.treatment_gilteritinib[i] || cols.treatment_ivosidenib[i] || cols.treatment_enasidenib[i] ? 1 : 0
+  ));
+  cols.any_targeted_treatment = anyTargeted;
+  const ven = binaryRiskDifference(cols, "treatment_venetoclax_azacitidine");
+  const plus3 = binaryRiskDifference(cols, "treatment_7plus3");
+  const targeted = binaryRiskDifference(cols, "any_targeted_treatment");
+  addIter([h1, h2, h3], [
+    record([h1.id], "risk_difference(objective_response ~ treatment_venetoclax_azacitidine)", ven, `Response was ${fmtPct(ven.p1)} with treatment_venetoclax_azacitidine vs ${fmtPct(ven.p0)} without it; risk difference ${fmtPct(ven.effect)} (p=${fmtP(ven.p)}).`),
+    record([h2.id], "risk_difference(objective_response ~ treatment_7plus3)", plus3, `Response was ${fmtPct(plus3.p1)} with treatment_7plus3 vs ${fmtPct(plus3.p0)} without it; risk difference ${fmtPct(plus3.effect)} (p=${fmtP(plus3.p)}).`),
+    record([h3.id], "risk_difference(objective_response ~ any_targeted_treatment)", targeted, `Response was ${fmtPct(targeted.p1)} with any FLT3/IDH targeted treatment vs ${fmtPct(targeted.p0)} without it; risk difference ${fmtPct(targeted.effect)} (p=${fmtP(targeted.p)}).`),
+  ]);
+
+  // 2. Molecular risk.
+  const h4 = newHyp("Patients with `tp53_mutation` have a lower `objective_response` rate than patients without `tp53_mutation`.");
+  const h5 = newHyp("Patients with `complex_karyotype` have a lower `objective_response` rate than patients without `complex_karyotype`.");
+  const h6 = newHyp("Patients with `npm1_mutation` have a higher `objective_response` rate than patients without `npm1_mutation`.");
+  const tp53 = binaryRiskDifference(cols, "tp53_mutation");
+  const complex = binaryRiskDifference(cols, "complex_karyotype");
+  const npm1 = binaryRiskDifference(cols, "npm1_mutation");
+  addIter([h4, h5, h6], [
+    record([h4.id], "risk_difference(objective_response ~ tp53_mutation)", tp53, `Response was ${fmtPct(tp53.p1)} with tp53_mutation vs ${fmtPct(tp53.p0)} without it; risk difference ${fmtPct(tp53.effect)} (p=${fmtP(tp53.p)}).`),
+    record([h5.id], "risk_difference(objective_response ~ complex_karyotype)", complex, `Response was ${fmtPct(complex.p1)} with complex_karyotype vs ${fmtPct(complex.p0)} without it; risk difference ${fmtPct(complex.effect)} (p=${fmtP(complex.p)}).`),
+    record([h6.id], "risk_difference(objective_response ~ npm1_mutation)", npm1, `Response was ${fmtPct(npm1.p1)} with npm1_mutation vs ${fmtPct(npm1.p0)} without it; risk difference ${fmtPct(npm1.effect)} (p=${fmtP(npm1.p)}).`),
+  ]);
+
+  // 3. Fitness and disease burden.
+  const h7 = newHyp("Patients with `unfit_for_intensive` have a lower `objective_response` rate than patients without `unfit_for_intensive`.");
+  const h8 = newHyp("Each one-standard-deviation increase in `age_years` is associated with a lower `objective_response` probability.");
+  const h9 = newHyp("Each one-standard-deviation increase in `ecog_ps` is associated with a lower `objective_response` probability.");
+  const unfit = binaryRiskDifference(cols, "unfit_for_intensive");
+  const age = continuousEffectPerSd(cols, "age_years");
+  const ecog = continuousEffectPerSd(cols, "ecog_ps");
+  addIter([h7, h8, h9], [
+    record([h7.id], "risk_difference(objective_response ~ unfit_for_intensive)", unfit, `Response was ${fmtPct(unfit.p1)} among unfit_for_intensive patients vs ${fmtPct(unfit.p0)} among others; risk difference ${fmtPct(unfit.effect)} (p=${fmtP(unfit.p)}).`),
+    record([h8.id], "linear_probability(objective_response ~ age_years_per_sd)", age, `A 1-SD increase in age_years (${age.sdX.toFixed(1)} years) changed response probability by ${fmtPct(age.effect)} (p=${fmtP(age.p)}).`),
+    record([h9.id], "linear_probability(objective_response ~ ecog_ps_per_sd)", ecog, `A 1-SD increase in ecog_ps (${ecog.sdX.toFixed(2)} points) changed response probability by ${fmtPct(ecog.effect)} (p=${fmtP(ecog.p)}).`),
+  ]);
+
+  // 4. FLT3 ITD and midostaurin.
+  const h10 = newHyp("Among patients with `flt3_itd`, `treatment_midostaurin` is associated with higher `objective_response` than no `treatment_midostaurin`.");
+  const h11 = newHyp("The positive association of `treatment_midostaurin` with `objective_response` is stronger in `flt3_itd` patients than in non-`flt3_itd` patients.");
+  const midFlt3 = riskDifferenceTwoBinary(cols, "treatment_midostaurin", "flt3_itd");
+  const midFlt3Ix = interactionRiskDifference(cols, "treatment_midostaurin", "flt3_itd");
+  const midFlt3Adj = adjustedInteraction(cols, "treatment_midostaurin", "flt3_itd");
+  addIter([h10, h11], [
+    record([h10.id], "risk_difference(objective_response ~ treatment_midostaurin | flt3_itd=1)", midFlt3, `Within flt3_itd patients, response was ${fmtPct(midFlt3.p1)} with treatment_midostaurin vs ${fmtPct(midFlt3.p0)} without it; risk difference ${fmtPct(midFlt3.effect)} (p=${fmtP(midFlt3.p)}).`),
+    record([h11.id], "difference_in_differences(treatment_midostaurin x flt3_itd)", midFlt3Ix, `Observed interaction risk difference was ${fmtPct(midFlt3Ix.effect)}: midostaurin RD ${fmtPct(midFlt3Ix.rdSub)} in flt3_itd vs ${fmtPct(midFlt3Ix.rdOther)} in non-flt3_itd patients (p=${fmtP(midFlt3Ix.p)}).`),
+    record([h11.id], "adjusted_lpm(objective_response ~ treatment_midostaurin * flt3_itd + age + sex + ecog + secondary_aml + unfit + complex_karyotype + tp53)", midFlt3Adj, `After adjustment, the treatment_midostaurin by flt3_itd interaction was ${fmtPct(midFlt3Adj.effect)} on the response-probability scale (p=${fmtP(midFlt3Adj.p)}).`),
+  ]);
+
+  // 5. FLT3 TKD and gilteritinib.
+  const h12 = newHyp("Among patients with `flt3_tkd`, `treatment_gilteritinib` is associated with higher `objective_response` than no `treatment_gilteritinib`.");
+  const h13 = newHyp("The positive association of `treatment_gilteritinib` with `objective_response` is stronger in `flt3_tkd` patients than in non-`flt3_tkd` patients.");
+  const giltTkd = riskDifferenceTwoBinary(cols, "treatment_gilteritinib", "flt3_tkd");
+  const giltTkdIx = interactionRiskDifference(cols, "treatment_gilteritinib", "flt3_tkd");
+  const giltTkdAdj = adjustedInteraction(cols, "treatment_gilteritinib", "flt3_tkd");
+  addIter([h12, h13], [
+    record([h12.id], "risk_difference(objective_response ~ treatment_gilteritinib | flt3_tkd=1)", giltTkd, `Within flt3_tkd patients, response was ${fmtPct(giltTkd.p1)} with treatment_gilteritinib vs ${fmtPct(giltTkd.p0)} without it; risk difference ${fmtPct(giltTkd.effect)} (p=${fmtP(giltTkd.p)}).`),
+    record([h13.id], "difference_in_differences(treatment_gilteritinib x flt3_tkd)", giltTkdIx, `Observed interaction risk difference was ${fmtPct(giltTkdIx.effect)}: gilteritinib RD ${fmtPct(giltTkdIx.rdSub)} in flt3_tkd vs ${fmtPct(giltTkdIx.rdOther)} in non-flt3_tkd patients (p=${fmtP(giltTkdIx.p)}).`),
+    record([h13.id], "adjusted_lpm(objective_response ~ treatment_gilteritinib * flt3_tkd + covariates)", giltTkdAdj, `After adjustment, the treatment_gilteritinib by flt3_tkd interaction was ${fmtPct(giltTkdAdj.effect)} (p=${fmtP(giltTkdAdj.p)}).`),
+  ]);
+
+  // 6. IDH targeted treatment.
+  const h14 = newHyp("Among patients with `idh1_mutation`, `treatment_ivosidenib` is associated with higher `objective_response` than no `treatment_ivosidenib`.");
+  const h15 = newHyp("Among patients with `idh2_mutation`, `treatment_enasidenib` is associated with higher `objective_response` than no `treatment_enasidenib`.");
+  const ivoIdh1 = riskDifferenceTwoBinary(cols, "treatment_ivosidenib", "idh1_mutation");
+  const enaIdh2 = riskDifferenceTwoBinary(cols, "treatment_enasidenib", "idh2_mutation");
+  const ivoIx = interactionRiskDifference(cols, "treatment_ivosidenib", "idh1_mutation");
+  const enaIx = interactionRiskDifference(cols, "treatment_enasidenib", "idh2_mutation");
+  addIter([h14, h15], [
+    record([h14.id], "risk_difference(objective_response ~ treatment_ivosidenib | idh1_mutation=1)", ivoIdh1, `Within idh1_mutation patients, response was ${fmtPct(ivoIdh1.p1)} with treatment_ivosidenib vs ${fmtPct(ivoIdh1.p0)} without it; risk difference ${fmtPct(ivoIdh1.effect)} (p=${fmtP(ivoIdh1.p)}).`),
+    record([h14.id], "difference_in_differences(treatment_ivosidenib x idh1_mutation)", ivoIx, `The observed treatment_ivosidenib by idh1_mutation interaction was ${fmtPct(ivoIx.effect)} (p=${fmtP(ivoIx.p)}).`),
+    record([h15.id], "risk_difference(objective_response ~ treatment_enasidenib | idh2_mutation=1)", enaIdh2, `Within idh2_mutation patients, response was ${fmtPct(enaIdh2.p1)} with treatment_enasidenib vs ${fmtPct(enaIdh2.p0)} without it; risk difference ${fmtPct(enaIdh2.effect)} (p=${fmtP(enaIdh2.p)}).`),
+    record([h15.id], "difference_in_differences(treatment_enasidenib x idh2_mutation)", enaIx, `The observed treatment_enasidenib by idh2_mutation interaction was ${fmtPct(enaIx.effect)} (p=${fmtP(enaIx.p)}).`),
+  ]);
+
+  // 7. Venetoclax-azacitidine in fitness-defined strata.
+  const h16 = newHyp("Among patients with `unfit_for_intensive`, `treatment_venetoclax_azacitidine` is associated with higher `objective_response` than no `treatment_venetoclax_azacitidine`.");
+  const h17 = newHyp("The positive association of `treatment_venetoclax_azacitidine` with `objective_response` is stronger in `unfit_for_intensive` patients than in fit patients.");
+  const venUnfit = riskDifferenceTwoBinary(cols, "treatment_venetoclax_azacitidine", "unfit_for_intensive");
+  const venUnfitIx = interactionRiskDifference(cols, "treatment_venetoclax_azacitidine", "unfit_for_intensive");
+  const venUnfitAdj = adjustedInteraction(cols, "treatment_venetoclax_azacitidine", "unfit_for_intensive");
+  addIter([h16, h17], [
+    record([h16.id], "risk_difference(objective_response ~ treatment_venetoclax_azacitidine | unfit_for_intensive=1)", venUnfit, `Within unfit_for_intensive patients, response was ${fmtPct(venUnfit.p1)} with treatment_venetoclax_azacitidine vs ${fmtPct(venUnfit.p0)} without it; risk difference ${fmtPct(venUnfit.effect)} (p=${fmtP(venUnfit.p)}).`),
+    record([h17.id], "difference_in_differences(treatment_venetoclax_azacitidine x unfit_for_intensive)", venUnfitIx, `Observed interaction risk difference was ${fmtPct(venUnfitIx.effect)}: venetoclax/azacitidine RD ${fmtPct(venUnfitIx.rdSub)} in unfit vs ${fmtPct(venUnfitIx.rdOther)} in fit patients (p=${fmtP(venUnfitIx.p)}).`),
+    record([h17.id], "adjusted_lpm(objective_response ~ treatment_venetoclax_azacitidine * unfit_for_intensive + covariates)", venUnfitAdj, `After adjustment, the treatment_venetoclax_azacitidine by unfit_for_intensive interaction was ${fmtPct(venUnfitAdj.effect)} (p=${fmtP(venUnfitAdj.p)}).`),
+  ]);
+
+  // 8. 7+3 in fit vs unfit.
+  const h18 = newHyp("Among patients without `unfit_for_intensive`, `treatment_7plus3` is associated with higher `objective_response` than no `treatment_7plus3`.");
+  const h19 = newHyp("The positive association of `treatment_7plus3` with `objective_response` is weaker in `unfit_for_intensive` patients than in fit patients.");
+  const plus3Fit = riskDifferenceTwoBinary(cols, "treatment_7plus3", "unfit_for_intensive", 0);
+  const plus3UnfitIx = interactionRiskDifference(cols, "treatment_7plus3", "unfit_for_intensive");
+  const plus3UnfitAdj = adjustedInteraction(cols, "treatment_7plus3", "unfit_for_intensive");
+  addIter([h18, h19], [
+    record([h18.id], "risk_difference(objective_response ~ treatment_7plus3 | unfit_for_intensive=0)", plus3Fit, `Within fit patients, response was ${fmtPct(plus3Fit.p1)} with treatment_7plus3 vs ${fmtPct(plus3Fit.p0)} without it; risk difference ${fmtPct(plus3Fit.effect)} (p=${fmtP(plus3Fit.p)}).`),
+    record([h19.id], "difference_in_differences(treatment_7plus3 x unfit_for_intensive)", plus3UnfitIx, `Observed interaction risk difference was ${fmtPct(plus3UnfitIx.effect)}: 7plus3 RD ${fmtPct(plus3UnfitIx.rdSub)} in unfit vs ${fmtPct(plus3UnfitIx.rdOther)} in fit patients (p=${fmtP(plus3UnfitIx.p)}).`),
+    record([h19.id], "adjusted_lpm(objective_response ~ treatment_7plus3 * unfit_for_intensive + covariates)", plus3UnfitAdj, `After adjustment, the treatment_7plus3 by unfit_for_intensive interaction was ${fmtPct(plus3UnfitAdj.effect)} (p=${fmtP(plus3UnfitAdj.p)}).`),
+  ]);
+
+  // 9. Inflammation/nutrition.
+  const h20 = newHyp("Each one-standard-deviation increase in `albumin_g_dl` is associated with a higher `objective_response` probability.");
+  const h21 = newHyp("Each one-standard-deviation increase in `crp_mg_l` is associated with a lower `objective_response` probability.");
+  const h22 = newHyp("Each one-standard-deviation increase in `nlr` is associated with a lower `objective_response` probability.");
+  const alb = continuousEffectPerSd(cols, "albumin_g_dl");
+  const crp = continuousEffectPerSd(cols, "crp_mg_l");
+  const nlr = continuousEffectPerSd(cols, "nlr");
+  addIter([h20, h21, h22], [
+    record([h20.id], "linear_probability(objective_response ~ albumin_g_dl_per_sd)", alb, `A 1-SD increase in albumin_g_dl (${alb.sdX.toFixed(2)} g/dL) changed response probability by ${fmtPct(alb.effect)} (p=${fmtP(alb.p)}).`),
+    record([h21.id], "linear_probability(objective_response ~ crp_mg_l_per_sd)", crp, `A 1-SD increase in crp_mg_l (${crp.sdX.toFixed(1)} mg/L) changed response probability by ${fmtPct(crp.effect)} (p=${fmtP(crp.p)}).`),
+    record([h22.id], "linear_probability(objective_response ~ nlr_per_sd)", nlr, `A 1-SD increase in nlr (${nlr.sdX.toFixed(2)}) changed response probability by ${fmtPct(nlr.effect)} (p=${fmtP(nlr.p)}).`),
+  ]);
+
+  // 10. Disease burden continuous markers.
+  const h23 = newHyp("Each one-standard-deviation increase in `wbc_k_per_ul` is associated with a lower `objective_response` probability.");
+  const h24 = newHyp("Each one-standard-deviation increase in `blast_pct_marrow` is associated with a lower `objective_response` probability.");
+  const h25 = newHyp("Each one-standard-deviation increase in `ldh_u_l` is associated with a lower `objective_response` probability.");
+  const wbc = continuousEffectPerSd(cols, "wbc_k_per_ul");
+  const blast = continuousEffectPerSd(cols, "blast_pct_marrow");
+  const ldh = continuousEffectPerSd(cols, "ldh_u_l");
+  addIter([h23, h24, h25], [
+    record([h23.id], "linear_probability(objective_response ~ wbc_k_per_ul_per_sd)", wbc, `A 1-SD increase in wbc_k_per_ul (${wbc.sdX.toFixed(1)} k/uL) changed response probability by ${fmtPct(wbc.effect)} (p=${fmtP(wbc.p)}).`),
+    record([h24.id], "linear_probability(objective_response ~ blast_pct_marrow_per_sd)", blast, `A 1-SD increase in blast_pct_marrow (${blast.sdX.toFixed(1)} percentage points) changed response probability by ${fmtPct(blast.effect)} (p=${fmtP(blast.p)}).`),
+    record([h25.id], "linear_probability(objective_response ~ ldh_u_l_per_sd)", ldh, `A 1-SD increase in ldh_u_l (${ldh.sdX.toFixed(1)} U/L) changed response probability by ${fmtPct(ldh.effect)} (p=${fmtP(ldh.p)}).`),
+  ]);
+
