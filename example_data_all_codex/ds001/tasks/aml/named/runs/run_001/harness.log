+
+function readPlainValues(body, physicalType, count) {
+  const out = [];
+  let p = 0;
+  for (let i = 0; i < count; i++) {
+    if (physicalType === PHYS.INT64) {
+      out.push(Number(body.readBigInt64LE(p)));
+      p += 8;
+    } else if (physicalType === PHYS.INT32) {
+      out.push(body.readInt32LE(p));
+      p += 4;
+    } else if (physicalType === PHYS.DOUBLE) {
+      out.push(body.readDoubleLE(p));
+      p += 8;
+    } else if (physicalType === PHYS.BYTE_ARRAY) {
+      const len = body.readUInt32LE(p);
+      p += 4;
+      out.push(body.slice(p, p + len).toString("utf8"));
+      p += len;
+    } else if (physicalType === PHYS.BOOLEAN) {
+      throw new Error("Plain BOOLEAN is not implemented because this dataset stores flags as INT64");
+    } else {
+      throw new Error(`Unsupported physical type ${physicalType}`);
+    }
+  }
+  return out;
+}
+
+function readHybridValues(body, pos, bitWidth, count) {
+  const out = [];
+  let p = pos;
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (out.length < count) {
+    let shift = 0;
+    let header = 0;
+    while (true) {
+      const b = body[p++];
+      header |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < valueBytes; i++) value |= body[p++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const runLength = groups * 8;
+      const bytesStart = p;
+      for (let i = 0; i < runLength && out.length < count; i++) {
+        let value = 0;
+        const bitIndex = i * bitWidth;
+        for (let b = 0; b < bitWidth; b++) {
+          const absoluteBit = bitIndex + b;
+          const bit = (body[bytesStart + (absoluteBit >> 3)] >> (absoluteBit & 7)) & 1;
+          value |= bit << b;
