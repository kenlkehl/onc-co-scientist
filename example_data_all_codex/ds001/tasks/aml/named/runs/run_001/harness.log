+    { name: feature, fn: (i) => x[i] },
+    { name: "age_years_per_10", fn: (i) => cols.age_years[i] / 10 },
+    { name: "sex_female", fn: (i) => cols.sex_female[i] },
+    { name: "ecog_ps", fn: (i) => cols.ecog_ps[i] },
+    { name: "secondary_aml", fn: (i) => cols.secondary_aml[i] },
+    { name: "unfit_for_intensive", fn: (i) => cols.unfit_for_intensive[i] },
+    { name: "complex_karyotype", fn: (i) => cols.complex_karyotype[i] },
+    { name: "tp53_mutation", fn: (i) => cols.tp53_mutation[i] },
+  ];
+  for (const c of extraTerms) terms.push({ name: c, fn: (i) => cols[c][i] });
+  const fit = lpm(cols, terms);
+  const effect = fit.beta[1];
+  const se = fit.se[1];
+  const z = effect / se;
+  const p = pFromZ(z);
+  return { n: fit.n, effect, se, z, p, significant: p < 0.05 };
+}
+
+function record(hypothesisIds, label, result, summary) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code: label,
+    result_summary: summary,
+    p_value: Number(result.p.toPrecision(12)),
+    effect_estimate: Number(result.effect.toPrecision(12)),
+    significant: result.p < 0.05,
+  };
+}
+
+function run() {
+  const { columns: cols, n } = readParquet(DATASET);
+  if (n !== 50000) throw new Error(`Expected 50000 rows; found ${n}`);
+
+  const iterations = [];
+  let hid = 1;
+  const newHyp = (text, kind = "novel") => ({ id: `h${hid++}`, text, kind });
+  const addIter = (proposed, analyses) => {
+    iterations.push({ index: iterations.length + 1, proposed_hypotheses: proposed, analyses });
+  };
+
+  const treatmentVars = [
+    "treatment_midostaurin",
+    "treatment_gilteritinib",
+    "treatment_ivosidenib",
+    "treatment_enasidenib",
+    "treatment_venetoclax_azacitidine",
+    "treatment_7plus3",
+  ];
+
+  const mutationVars = [
+    "flt3_itd",
+    "flt3_tkd",
+    "idh1_mutation",
+    "idh2_mutation",
+    "npm1_mutation",
+    "tp53_mutation",
+    "complex_karyotype",
+    "secondary_aml",
+  ];
+
+  // 1. Broad treatment main effects.
+  const h1 = newHyp("Patients with `treatment_venetoclax_azacitidine` have a higher `objective_response` rate than patients without `treatment_venetoclax_azacitidine`.");
+  const h2 = newHyp("Patients with `treatment_7plus3` have a higher `objective_response` rate than patients without `treatment_7plus3`.");
+  const h3 = newHyp("Patients with any FLT3/IDH targeted treatment (`treatment_midostaurin`, `treatment_gilteritinib`, `treatment_ivosidenib`, or `treatment_enasidenib`) have a higher `objective_response` rate than patients without that class of treatment.");
+  const anyTargeted = cols[OUTCOME].map((_, i) => (
+    cols.treatment_midostaurin[i] || cols.treatment_gilteritinib[i] || cols.treatment_ivosidenib[i] || cols.treatment_enasidenib[i] ? 1 : 0
+  ));
+  cols.any_targeted_treatment = anyTargeted;
+  const ven = binaryRiskDifference(cols, "treatment_venetoclax_azacitidine");
+  const plus3 = binaryRiskDifference(cols, "treatment_7plus3");
+  const targeted = binaryRiskDifference(cols, "any_targeted_treatment");
+  addIter([h1, h2, h3], [
+    record([h1.id], "risk_difference(objective_response ~ treatment_venetoclax_azacitidine)", ven, `Response was ${fmtPct(ven.p1)} with treatment_venetoclax_azacitidine vs ${fmtPct(ven.p0)} without it; risk difference ${fmtPct(ven.effect)} (p=${fmtP(ven.p)}).`),
+    record([h2.id], "risk_difference(objective_response ~ treatment_7plus3)", plus3, `Response was ${fmtPct(plus3.p1)} with treatment_7plus3 vs ${fmtPct(plus3.p0)} without it; risk difference ${fmtPct(plus3.effect)} (p=${fmtP(plus3.p)}).`),
+    record([h3.id], "risk_difference(objective_response ~ any_targeted_treatment)", targeted, `Response was ${fmtPct(targeted.p1)} with any FLT3/IDH targeted treatment vs ${fmtPct(targeted.p0)} without it; risk difference ${fmtPct(targeted.effect)} (p=${fmtP(targeted.p)}).`),
+  ]);
+
+  // 2. Molecular risk.
+  const h4 = newHyp("Patients with `tp53_mutation` have a lower `objective_response` rate than patients without `tp53_mutation`.");
+  const h5 = newHyp("Patients with `complex_karyotype` have a lower `objective_response` rate than patients without `complex_karyotype`.");
+  const h6 = newHyp("Patients with `npm1_mutation` have a higher `objective_response` rate than patients without `npm1_mutation`.");
+  const tp53 = binaryRiskDifference(cols, "tp53_mutation");
+  const complex = binaryRiskDifference(cols, "complex_karyotype");
+  const npm1 = binaryRiskDifference(cols, "npm1_mutation");
+  addIter([h4, h5, h6], [
+    record([h4.id], "risk_difference(objective_response ~ tp53_mutation)", tp53, `Response was ${fmtPct(tp53.p1)} with tp53_mutation vs ${fmtPct(tp53.p0)} without it; risk difference ${fmtPct(tp53.effect)} (p=${fmtP(tp53.p)}).`),
+    record([h5.id], "risk_difference(objective_response ~ complex_karyotype)", complex, `Response was ${fmtPct(complex.p1)} with complex_karyotype vs ${fmtPct(complex.p0)} without it; risk difference ${fmtPct(complex.effect)} (p=${fmtP(complex.p)}).`),
+    record([h6.id], "risk_difference(objective_response ~ npm1_mutation)", npm1, `Response was ${fmtPct(npm1.p1)} with npm1_mutation vs ${fmtPct(npm1.p0)} without it; risk difference ${fmtPct(npm1.effect)} (p=${fmtP(npm1.p)}).`),
+  ]);
+
+  // 3. Fitness and disease burden.
+  const h7 = newHyp("Patients with `unfit_for_intensive` have a lower `objective_response` rate than patients without `unfit_for_intensive`.");
+  const h8 = newHyp("Each one-standard-deviation increase in `age_years` is associated with a lower `objective_response` probability.");
+  const h9 = newHyp("Each one-standard-deviation increase in `ecog_ps` is associated with a lower `objective_response` probability.");
+  const unfit = binaryRiskDifference(cols, "unfit_for_intensive");
+  const age = continuousEffectPerSd(cols, "age_years");
+  const ecog = continuousEffectPerSd(cols, "ecog_ps");
+  addIter([h7, h8, h9], [
+    record([h7.id], "risk_difference(objective_response ~ unfit_for_intensive)", unfit, `Response was ${fmtPct(unfit.p1)} among unfit_for_intensive patients vs ${fmtPct(unfit.p0)} among others; risk difference ${fmtPct(unfit.effect)} (p=${fmtP(unfit.p)}).`),
+    record([h8.id], "linear_probability(objective_response ~ age_years_per_sd)", age, `A 1-SD increase in age_years (${age.sdX.toFixed(1)} years) changed response probability by ${fmtPct(age.effect)} (p=${fmtP(age.p)}).`),
+    record([h9.id], "linear_probability(objective_response ~ ecog_ps_per_sd)", ecog, `A 1-SD increase in ecog_ps (${ecog.sdX.toFixed(2)} points) changed response probability by ${fmtPct(ecog.effect)} (p=${fmtP(ecog.p)}).`),
+  ]);
+
+  // 4. FLT3 ITD and midostaurin.
+  const h10 = newHyp("Among patients with `flt3_itd`, `treatment_midostaurin` is associated with higher `objective_response` than no `treatment_midostaurin`.");
+  const h11 = newHyp("The positive association of `treatment_midostaurin` with `objective_response` is stronger in `flt3_itd` patients than in non-`flt3_itd` patients.");
+  const midFlt3 = riskDifferenceTwoBinary(cols, "treatment_midostaurin", "flt3_itd");
+  const midFlt3Ix = interactionRiskDifference(cols, "treatment_midostaurin", "flt3_itd");
+  const midFlt3Adj = adjustedInteraction(cols, "treatment_midostaurin", "flt3_itd");
+  addIter([h10, h11], [
+    record([h10.id], "risk_difference(objective_response ~ treatment_midostaurin | flt3_itd=1)", midFlt3, `Within flt3_itd patients, response was ${fmtPct(midFlt3.p1)} with treatment_midostaurin vs ${fmtPct(midFlt3.p0)} without it; risk difference ${fmtPct(midFlt3.effect)} (p=${fmtP(midFlt3.p)}).`),
+    record([h11.id], "difference_in_differences(treatment_midostaurin x flt3_itd)", midFlt3Ix, `Observed interaction risk difference was ${fmtPct(midFlt3Ix.effect)}: midostaurin RD ${fmtPct(midFlt3Ix.rdSub)} in flt3_itd vs ${fmtPct(midFlt3Ix.rdOther)} in non-flt3_itd patients (p=${fmtP(midFlt3Ix.p)}).`),
+    record([h11.id], "adjusted_lpm(objective_response ~ treatment_midostaurin * flt3_itd + age + sex + ecog + secondary_aml + unfit + complex_karyotype + tp53)", midFlt3Adj, `After adjustment, the treatment_midostaurin by flt3_itd interaction was ${fmtPct(midFlt3Adj.effect)} on the response-probability scale (p=${fmtP(midFlt3Adj.p)}).`),
+  ]);
+
+  // 5. FLT3 TKD and gilteritinib.
+  const h12 = newHyp("Among patients with `flt3_tkd`, `treatment_gilteritinib` is associated with higher `objective_response` than no `treatment_gilteritinib`.");
+  const h13 = newHyp("The positive association of `treatment_gilteritinib` with `objective_response` is stronger in `flt3_tkd` patients than in non-`flt3_tkd` patients.");
+  const giltTkd = riskDifferenceTwoBinary(cols, "treatment_gilteritinib", "flt3_tkd");
+  const giltTkdIx = interactionRiskDifference(cols, "treatment_gilteritinib", "flt3_tkd");
+  const giltTkdAdj = adjustedInteraction(cols, "treatment_gilteritinib", "flt3_tkd");
+  addIter([h12, h13], [
+    record([h12.id], "risk_difference(objective_response ~ treatment_gilteritinib | flt3_tkd=1)", giltTkd, `Within flt3_tkd patients, response was ${fmtPct(giltTkd.p1)} with treatment_gilteritinib vs ${fmtPct(giltTkd.p0)} without it; risk difference ${fmtPct(giltTkd.effect)} (p=${fmtP(giltTkd.p)}).`),
+    record([h13.id], "difference_in_differences(treatment_gilteritinib x flt3_tkd)", giltTkdIx, `Observed interaction risk difference was ${fmtPct(giltTkdIx.effect)}: gilteritinib RD ${fmtPct(giltTkdIx.rdSub)} in flt3_tkd vs ${fmtPct(giltTkdIx.rdOther)} in non-flt3_tkd patients (p=${fmtP(giltTkdIx.p)}).`),
+    record([h13.id], "adjusted_lpm(objective_response ~ treatment_gilteritinib * flt3_tkd + covariates)", giltTkdAdj, `After adjustment, the treatment_gilteritinib by flt3_tkd interaction was ${fmtPct(giltTkdAdj.effect)} (p=${fmtP(giltTkdAdj.p)}).`),
+  ]);
+
+  // 6. IDH targeted treatment.
+  const h14 = newHyp("Among patients with `idh1_mutation`, `treatment_ivosidenib` is associated with higher `objective_response` than no `treatment_ivosidenib`.");
+  const h15 = newHyp("Among patients with `idh2_mutation`, `treatment_enasidenib` is associated with higher `objective_response` than no `treatment_enasidenib`.");
+  const ivoIdh1 = riskDifferenceTwoBinary(cols, "treatment_ivosidenib", "idh1_mutation");
+  const enaIdh2 = riskDifferenceTwoBinary(cols, "treatment_enasidenib", "idh2_mutation");
+  const ivoIx = interactionRiskDifference(cols, "treatment_ivosidenib", "idh1_mutation");
+  const enaIx = interactionRiskDifference(cols, "treatment_enasidenib", "idh2_mutation");
+  addIter([h14, h15], [
+    record([h14.id], "risk_difference(objective_response ~ treatment_ivosidenib | idh1_mutation=1)", ivoIdh1, `Within idh1_mutation patients, response was ${fmtPct(ivoIdh1.p1)} with treatment_ivosidenib vs ${fmtPct(ivoIdh1.p0)} without it; risk difference ${fmtPct(ivoIdh1.effect)} (p=${fmtP(ivoIdh1.p)}).`),
+    record([h14.id], "difference_in_differences(treatment_ivosidenib x idh1_mutation)", ivoIx, `The observed treatment_ivosidenib by idh1_mutation interaction was ${fmtPct(ivoIx.effect)} (p=${fmtP(ivoIx.p)}).`),
+    record([h15.id], "risk_difference(objective_response ~ treatment_enasidenib | idh2_mutation=1)", enaIdh2, `Within idh2_mutation patients, response was ${fmtPct(enaIdh2.p1)} with treatment_enasidenib vs ${fmtPct(enaIdh2.p0)} without it; risk difference ${fmtPct(enaIdh2.effect)} (p=${fmtP(enaIdh2.p)}).`),
+    record([h15.id], "difference_in_differences(treatment_enasidenib x idh2_mutation)", enaIx, `The observed treatment_enasidenib by idh2_mutation interaction was ${fmtPct(enaIx.effect)} (p=${fmtP(enaIx.p)}).`),
+  ]);
+
+  // 7. Venetoclax-azacitidine in fitness-defined strata.
+  const h16 = newHyp("Among patients with `unfit_for_intensive`, `treatment_venetoclax_azacitidine` is associated with higher `objective_response` than no `treatment_venetoclax_azacitidine`.");
+  const h17 = newHyp("The positive association of `treatment_venetoclax_azacitidine` with `objective_response` is stronger in `unfit_for_intensive` patients than in fit patients.");
+  const venUnfit = riskDifferenceTwoBinary(cols, "treatment_venetoclax_azacitidine", "unfit_for_intensive");
+  const venUnfitIx = interactionRiskDifference(cols, "treatment_venetoclax_azacitidine", "unfit_for_intensive");
+  const venUnfitAdj = adjustedInteraction(cols, "treatment_venetoclax_azacitidine", "unfit_for_intensive");
+  addIter([h16, h17], [
+    record([h16.id], "risk_difference(objective_response ~ treatment_venetoclax_azacitidine | unfit_for_intensive=1)", venUnfit, `Within unfit_for_intensive patients, response was ${fmtPct(venUnfit.p1)} with treatment_venetoclax_azacitidine vs ${fmtPct(venUnfit.p0)} without it; risk difference ${fmtPct(venUnfit.effect)} (p=${fmtP(venUnfit.p)}).`),
+    record([h17.id], "difference_in_differences(treatment_venetoclax_azacitidine x unfit_for_intensive)", venUnfitIx, `Observed interaction risk difference was ${fmtPct(venUnfitIx.effect)}: venetoclax/azacitidine RD ${fmtPct(venUnfitIx.rdSub)} in unfit vs ${fmtPct(venUnfitIx.rdOther)} in fit patients (p=${fmtP(venUnfitIx.p)}).`),
+    record([h17.id], "adjusted_lpm(objective_response ~ treatment_venetoclax_azacitidine * unfit_for_intensive + covariates)", venUnfitAdj, `After adjustment, the treatment_venetoclax_azacitidine by unfit_for_intensive interaction was ${fmtPct(venUnfitAdj.effect)} (p=${fmtP(venUnfitAdj.p)}).`),
+  ]);
+
+  // 8. 7+3 in fit vs unfit.
+  const h18 = newHyp("Among patients without `unfit_for_intensive`, `treatment_7plus3` is associated with higher `objective_response` than no `treatment_7plus3`.");
+  const h19 = newHyp("The positive association of `treatment_7plus3` with `objective_response` is weaker in `unfit_for_intensive` patients than in fit patients.");
+  const plus3Fit = riskDifferenceTwoBinary(cols, "treatment_7plus3", "unfit_for_intensive", 0);
+  const plus3UnfitIx = interactionRiskDifference(cols, "treatment_7plus3", "unfit_for_intensive");
+  const plus3UnfitAdj = adjustedInteraction(cols, "treatment_7plus3", "unfit_for_intensive");
+  addIter([h18, h19], [
+    record([h18.id], "risk_difference(objective_response ~ treatment_7plus3 | unfit_for_intensive=0)", plus3Fit, `Within fit patients, response was ${fmtPct(plus3Fit.p1)} with treatment_7plus3 vs ${fmtPct(plus3Fit.p0)} without it; risk difference ${fmtPct(plus3Fit.effect)} (p=${fmtP(plus3Fit.p)}).`),
+    record([h19.id], "difference_in_differences(treatment_7plus3 x unfit_for_intensive)", plus3UnfitIx, `Observed interaction risk difference was ${fmtPct(plus3UnfitIx.effect)}: 7plus3 RD ${fmtPct(plus3UnfitIx.rdSub)} in unfit vs ${fmtPct(plus3UnfitIx.rdOther)} in fit patients (p=${fmtP(plus3UnfitIx.p)}).`),
+    record([h19.id], "adjusted_lpm(objective_response ~ treatment_7plus3 * unfit_for_intensive + covariates)", plus3UnfitAdj, `After adjustment, the treatment_7plus3 by unfit_for_intensive interaction was ${fmtPct(plus3UnfitAdj.effect)} (p=${fmtP(plus3UnfitAdj.p)}).`),
+  ]);
+
+  // 9. Inflammation/nutrition.
+  const h20 = newHyp("Each one-standard-deviation increase in `albumin_g_dl` is associated with a higher `objective_response` probability.");
+  const h21 = newHyp("Each one-standard-deviation increase in `crp_mg_l` is associated with a lower `objective_response` probability.");
+  const h22 = newHyp("Each one-standard-deviation increase in `nlr` is associated with a lower `objective_response` probability.");
+  const alb = continuousEffectPerSd(cols, "albumin_g_dl");
+  const crp = continuousEffectPerSd(cols, "crp_mg_l");
+  const nlr = continuousEffectPerSd(cols, "nlr");
+  addIter([h20, h21, h22], [
+    record([h20.id], "linear_probability(objective_response ~ albumin_g_dl_per_sd)", alb, `A 1-SD increase in albumin_g_dl (${alb.sdX.toFixed(2)} g/dL) changed response probability by ${fmtPct(alb.effect)} (p=${fmtP(alb.p)}).`),
+    record([h21.id], "linear_probability(objective_response ~ crp_mg_l_per_sd)", crp, `A 1-SD increase in crp_mg_l (${crp.sdX.toFixed(1)} mg/L) changed response probability by ${fmtPct(crp.effect)} (p=${fmtP(crp.p)}).`),
+    record([h22.id], "linear_probability(objective_response ~ nlr_per_sd)", nlr, `A 1-SD increase in nlr (${nlr.sdX.toFixed(2)}) changed response probability by ${fmtPct(nlr.effect)} (p=${fmtP(nlr.p)}).`),
+  ]);
+
+  // 10. Disease burden continuous markers.
+  const h23 = newHyp("Each one-standard-deviation increase in `wbc_k_per_ul` is associated with a lower `objective_response` probability.");
+  const h24 = newHyp("Each one-standard-deviation increase in `blast_pct_marrow` is associated with a lower `objective_response` probability.");
+  const h25 = newHyp("Each one-standard-deviation increase in `ldh_u_l` is associated with a lower `objective_response` probability.");
+  const wbc = continuousEffectPerSd(cols, "wbc_k_per_ul");
+  const blast = continuousEffectPerSd(cols, "blast_pct_marrow");
+  const ldh = continuousEffectPerSd(cols, "ldh_u_l");
+  addIter([h23, h24, h25], [
+    record([h23.id], "linear_probability(objective_response ~ wbc_k_per_ul_per_sd)", wbc, `A 1-SD increase in wbc_k_per_ul (${wbc.sdX.toFixed(1)} k/uL) changed response probability by ${fmtPct(wbc.effect)} (p=${fmtP(wbc.p)}).`),
+    record([h24.id], "linear_probability(objective_response ~ blast_pct_marrow_per_sd)", blast, `A 1-SD increase in blast_pct_marrow (${blast.sdX.toFixed(1)} percentage points) changed response probability by ${fmtPct(blast.effect)} (p=${fmtP(blast.p)}).`),
+    record([h25.id], "linear_probability(objective_response ~ ldh_u_l_per_sd)", ldh, `A 1-SD increase in ldh_u_l (${ldh.sdX.toFixed(1)} U/L) changed response probability by ${fmtPct(ldh.effect)} (p=${fmtP(ldh.p)}).`),
+  ]);
+
+  // 11. Secondary AML and venetoclax/azacitidine.
+  const h26 = newHyp("Patients with `secondary_aml` have a lower `objective_response` rate than patients without `secondary_aml`.");
+  const h27 = newHyp("Among patients with `secondary_aml`, `treatment_venetoclax_azacitidine` is associated with higher `objective_response` than no `treatment_venetoclax_azacitidine`.");
+  const h28 = newHyp("The positive association of `treatment_venetoclax_azacitidine` with `objective_response` is stronger in `secondary_aml` patients than in de novo AML patients.");
+  const sec = binaryRiskDifference(cols, "secondary_aml");
+  const venSec = riskDifferenceTwoBinary(cols, "treatment_venetoclax_azacitidine", "secondary_aml");
+  const venSecIx = interactionRiskDifference(cols, "treatment_venetoclax_azacitidine", "secondary_aml");
+  addIter([h26, h27, h28], [
+    record([h26.id], "risk_difference(objective_response ~ secondary_aml)", sec, `Response was ${fmtPct(sec.p1)} with secondary_aml vs ${fmtPct(sec.p0)} without it; risk difference ${fmtPct(sec.effect)} (p=${fmtP(sec.p)}).`),
+    record([h27.id], "risk_difference(objective_response ~ treatment_venetoclax_azacitidine | secondary_aml=1)", venSec, `Within secondary_aml patients, response was ${fmtPct(venSec.p1)} with treatment_venetoclax_azacitidine vs ${fmtPct(venSec.p0)} without it; risk difference ${fmtPct(venSec.effect)} (p=${fmtP(venSec.p)}).`),
+    record([h28.id], "difference_in_differences(treatment_venetoclax_azacitidine x secondary_aml)", venSecIx, `Observed interaction risk difference was ${fmtPct(venSecIx.effect)}: venetoclax/azacitidine RD ${fmtPct(venSecIx.rdSub)} in secondary_aml vs ${fmtPct(venSecIx.rdOther)} in de novo AML (p=${fmtP(venSecIx.p)}).`),
+  ]);
+
+  // 12. TP53/complex adverse overlap.
+  cols.tp53_or_complex = cols[OUTCOME].map((_, i) => (cols.tp53_mutation[i] || cols.complex_karyotype[i] ? 1 : 0));
+  cols.tp53_and_complex = cols[OUTCOME].map((_, i) => (cols.tp53_mutation[i] && cols.complex_karyotype[i] ? 1 : 0));
+  const h29 = newHyp("Patients with either `tp53_mutation` or `complex_karyotype` have a lower `objective_response` rate than patients with neither adverse feature.");
+  const h30 = newHyp("Patients with both `tp53_mutation` and `complex_karyotype` have a lower `objective_response` rate than patients without both features.");
+  const h31 = newHyp("The adverse association of `tp53_mutation` with `objective_response` is stronger in patients with `complex_karyotype` than in patients without `complex_karyotype`.");
+  const tp53OrComplex = binaryRiskDifference(cols, "tp53_or_complex");
+  const both = binaryRiskDifference(cols, "tp53_and_complex");
+  const tp53ComplexIx = interactionRiskDifference(cols, "tp53_mutation", "complex_karyotype");
+  addIter([h29, h30, h31], [
+    record([h29.id], "risk_difference(objective_response ~ tp53_or_complex)", tp53OrComplex, `Response was ${fmtPct(tp53OrComplex.p1)} with tp53_mutation or complex_karyotype vs ${fmtPct(tp53OrComplex.p0)} with neither; risk difference ${fmtPct(tp53OrComplex.effect)} (p=${fmtP(tp53OrComplex.p)}).`),
+    record([h30.id], "risk_difference(objective_response ~ tp53_and_complex)", both, `Response was ${fmtPct(both.p1)} with both tp53_mutation and complex_karyotype vs ${fmtPct(both.p0)} otherwise; risk difference ${fmtPct(both.effect)} (p=${fmtP(both.p)}).`),
+    record([h31.id], "difference_in_differences(tp53_mutation x complex_karyotype)", tp53ComplexIx, `Observed interaction risk difference was ${fmtPct(tp53ComplexIx.effect)}: tp53 RD ${fmtPct(tp53ComplexIx.rdSub)} in complex_karyotype vs ${fmtPct(tp53ComplexIx.rdOther)} without complex_karyotype (p=${fmtP(tp53ComplexIx.p)}).`),
+  ]);
+
+  // 13. NPM1 and FLT3 background.
+  const h32 = newHyp("Among patients without `flt3_itd`, `npm1_mutation` is associated with higher `objective_response` than no `npm1_mutation`.");
+  const h33 = newHyp("The favorable association of `npm1_mutation` with `objective_response` is weaker in `flt3_itd` patients than in non-`flt3_itd` patients.");
+  const npmNoFlt3 = binaryRiskDifference(cols, "npm1_mutation", (i) => cols.flt3_itd[i] === 0);
+  const npmFlt3Ix = interactionRiskDifference(cols, "npm1_mutation", "flt3_itd");
+  const npmAdj = adjustedInteraction(cols, "npm1_mutation", "flt3_itd");
+  addIter([h32, h33], [
+    record([h32.id], "risk_difference(objective_response ~ npm1_mutation | flt3_itd=0)", npmNoFlt3, `Within flt3_itd-negative patients, response was ${fmtPct(npmNoFlt3.p1)} with npm1_mutation vs ${fmtPct(npmNoFlt3.p0)} without it; risk difference ${fmtPct(npmNoFlt3.effect)} (p=${fmtP(npmNoFlt3.p)}).`),
+    record([h33.id], "difference_in_differences(npm1_mutation x flt3_itd)", npmFlt3Ix, `Observed interaction risk difference was ${fmtPct(npmFlt3Ix.effect)}: npm1 RD ${fmtPct(npmFlt3Ix.rdSub)} in flt3_itd vs ${fmtPct(npmFlt3Ix.rdOther)} in flt3_itd-negative patients (p=${fmtP(npmFlt3Ix.p)}).`),
+    record([h33.id], "adjusted_lpm(objective_response ~ npm1_mutation * flt3_itd + covariates)", npmAdj, `After adjustment, the npm1_mutation by flt3_itd interaction was ${fmtPct(npmAdj.effect)} (p=${fmtP(npmAdj.p)}).`),
+  ]);
+
+  // 14. Treatment specificity: targeted treatment outside biomarkers.
+  const h34 = newHyp("Among patients without `flt3_itd`, `treatment_midostaurin` is not associated with higher `objective_response` than no `treatment_midostaurin`.");
+  const h35 = newHyp("Among patients without `idh1_mutation`, `treatment_ivosidenib` is not associated with higher `objective_response` than no `treatment_ivosidenib`.");
+  const h36 = newHyp("Among patients without `idh2_mutation`, `treatment_enasidenib` is not associated with higher `objective_response` than no `treatment_enasidenib`.");
+  const midNoFlt3 = riskDifferenceTwoBinary(cols, "treatment_midostaurin", "flt3_itd", 0);
+  const ivoNoIdh1 = riskDifferenceTwoBinary(cols, "treatment_ivosidenib", "idh1_mutation", 0);
+  const enaNoIdh2 = riskDifferenceTwoBinary(cols, "treatment_enasidenib", "idh2_mutation", 0);
+  addIter([h34, h35, h36], [
+    record([h34.id], "risk_difference(objective_response ~ treatment_midostaurin | flt3_itd=0)", midNoFlt3, `Within flt3_itd-negative patients, response was ${fmtPct(midNoFlt3.p1)} with treatment_midostaurin vs ${fmtPct(midNoFlt3.p0)} without it; risk difference ${fmtPct(midNoFlt3.effect)} (p=${fmtP(midNoFlt3.p)}).`),
+    record([h35.id], "risk_difference(objective_response ~ treatment_ivosidenib | idh1_mutation=0)", ivoNoIdh1, `Within idh1_mutation-negative patients, response was ${fmtPct(ivoNoIdh1.p1)} with treatment_ivosidenib vs ${fmtPct(ivoNoIdh1.p0)} without it; risk difference ${fmtPct(ivoNoIdh1.effect)} (p=${fmtP(ivoNoIdh1.p)}).`),
+    record([h36.id], "risk_difference(objective_response ~ treatment_enasidenib | idh2_mutation=0)", enaNoIdh2, `Within idh2_mutation-negative patients, response was ${fmtPct(enaNoIdh2.p1)} with treatment_enasidenib vs ${fmtPct(enaNoIdh2.p0)} without it; risk difference ${fmtPct(enaNoIdh2.effect)} (p=${fmtP(enaNoIdh2.p)}).`),
+  ]);
+
+  // 15. FLT3 dual treatment sensitivity.
+  cols.flt3_any = cols[OUTCOME].map((_, i) => (cols.flt3_itd[i] || cols.flt3_tkd[i] ? 1 : 0));
+  const h37 = newHyp("Among patients with either `flt3_itd` or `flt3_tkd`, `treatment_gilteritinib` is associated with higher `objective_response` than no `treatment_gilteritinib`.");
+  const h38 = newHyp("The positive association of `treatment_gilteritinib` with `objective_response` is stronger in patients with either `flt3_itd` or `flt3_tkd` than in patients with neither FLT3 alteration.");
+  const giltFlt3Any = riskDifferenceTwoBinary(cols, "treatment_gilteritinib", "flt3_any");
+  const giltFlt3AnyIx = interactionRiskDifference(cols, "treatment_gilteritinib", "flt3_any");
+  addIter([h37, h38], [
+    record([h37.id], "risk_difference(objective_response ~ treatment_gilteritinib | flt3_any=1)", giltFlt3Any, `Within patients with either flt3_itd or flt3_tkd, response was ${fmtPct(giltFlt3Any.p1)} with treatment_gilteritinib vs ${fmtPct(giltFlt3Any.p0)} without it; risk difference ${fmtPct(giltFlt3Any.effect)} (p=${fmtP(giltFlt3Any.p)}).`),
+    record([h38.id], "difference_in_differences(treatment_gilteritinib x flt3_any)", giltFlt3AnyIx, `Observed interaction risk difference was ${fmtPct(giltFlt3AnyIx.effect)}: gilteritinib RD ${fmtPct(giltFlt3AnyIx.rdSub)} in FLT3-altered vs ${fmtPct(giltFlt3AnyIx.rdOther)} in FLT3-wild-type patients (p=${fmtP(giltFlt3AnyIx.p)}).`),
+  ]);
+
+  // 16. IDH aggregate and venetoclax.
+  cols.idh_any = cols[OUTCOME].map((_, i) => (cols.idh1_mutation[i] || cols.idh2_mutation[i] ? 1 : 0));
+  const h39 = newHyp("Patients with either `idh1_mutation` or `idh2_mutation` have a higher `objective_response` rate than patients with neither IDH mutation.");
+  const h40 = newHyp("Among patients with either `idh1_mutation` or `idh2_mutation`, `treatment_venetoclax_azacitidine` is associated with higher `objective_response` than no `treatment_venetoclax_azacitidine`.");
+  const idhAny = binaryRiskDifference(cols, "idh_any");
+  const venIdhAny = riskDifferenceTwoBinary(cols, "treatment_venetoclax_azacitidine", "idh_any");
+  const venIdhAnyIx = interactionRiskDifference(cols, "treatment_venetoclax_azacitidine", "idh_any");
+  addIter([h39, h40], [
+    record([h39.id], "risk_difference(objective_response ~ idh_any)", idhAny, `Response was ${fmtPct(idhAny.p1)} with idh1_mutation or idh2_mutation vs ${fmtPct(idhAny.p0)} with neither; risk difference ${fmtPct(idhAny.effect)} (p=${fmtP(idhAny.p)}).`),
+    record([h40.id], "risk_difference(objective_response ~ treatment_venetoclax_azacitidine | idh_any=1)", venIdhAny, `Within IDH-mutated patients, response was ${fmtPct(venIdhAny.p1)} with treatment_venetoclax_azacitidine vs ${fmtPct(venIdhAny.p0)} without it; risk difference ${fmtPct(venIdhAny.effect)} (p=${fmtP(venIdhAny.p)}).`),
+    record([h40.id], "difference_in_differences(treatment_venetoclax_azacitidine x idh_any)", venIdhAnyIx, `Observed venetoclax/azacitidine by IDH-any interaction was ${fmtPct(venIdhAnyIx.effect)} (p=${fmtP(venIdhAnyIx.p)}).`),
+  ]);
+
+  // 17. Cytopenias and organ function.
+  const h41 = newHyp("Each one-standard-deviation increase in `hemoglobin_g_dl` is associated with a higher `objective_response` probability.");
+  const h42 = newHyp("Each one-standard-deviation increase in `platelets_k_ul` is associated with a higher `objective_response` probability.");
+  const h43 = newHyp("Each one-standard-deviation increase in `creatinine_mg_dl` is associated with a lower `objective_response` probability.");
+  const hgb = continuousEffectPerSd(cols, "hemoglobin_g_dl");
+  const plt = continuousEffectPerSd(cols, "platelets_k_ul");
+  const cr = continuousEffectPerSd(cols, "creatinine_mg_dl");
+  addIter([h41, h42, h43], [
+    record([h41.id], "linear_probability(objective_response ~ hemoglobin_g_dl_per_sd)", hgb, `A 1-SD increase in hemoglobin_g_dl (${hgb.sdX.toFixed(2)} g/dL) changed response probability by ${fmtPct(hgb.effect)} (p=${fmtP(hgb.p)}).`),
+    record([h42.id], "linear_probability(objective_response ~ platelets_k_ul_per_sd)", plt, `A 1-SD increase in platelets_k_ul (${plt.sdX.toFixed(1)} k/uL) changed response probability by ${fmtPct(plt.effect)} (p=${fmtP(plt.p)}).`),
+    record([h43.id], "linear_probability(objective_response ~ creatinine_mg_dl_per_sd)", cr, `A 1-SD increase in creatinine_mg_dl (${cr.sdX.toFixed(2)} mg/dL) changed response probability by ${fmtPct(cr.effect)} (p=${fmtP(cr.p)}).`),
+  ]);
+
+  // 18. Comorbidities.
+  const h44 = newHyp("Patients with `chronic_kidney_disease` have a lower `objective_response` rate than patients without `chronic_kidney_disease`.");
+  const h45 = newHyp("Patients with `heart_failure` have a lower `objective_response` rate than patients without `heart_failure`.");
+  const h46 = newHyp("Patients with `diabetes_mellitus` have a lower `objective_response` rate than patients without `diabetes_mellitus`.");
+  const ckd = binaryRiskDifference(cols, "chronic_kidney_disease");
+  const hf = binaryRiskDifference(cols, "heart_failure");
+  const dm = binaryRiskDifference(cols, "diabetes_mellitus");
+  addIter([h44, h45, h46], [
+    record([h44.id], "risk_difference(objective_response ~ chronic_kidney_disease)", ckd, `Response was ${fmtPct(ckd.p1)} with chronic_kidney_disease vs ${fmtPct(ckd.p0)} without it; risk difference ${fmtPct(ckd.effect)} (p=${fmtP(ckd.p)}).`),
+    record([h45.id], "risk_difference(objective_response ~ heart_failure)", hf, `Response was ${fmtPct(hf.p1)} with heart_failure vs ${fmtPct(hf.p0)} without it; risk difference ${fmtPct(hf.effect)} (p=${fmtP(hf.p)}).`),
+    record([h46.id], "risk_difference(objective_response ~ diabetes_mellitus)", dm, `Response was ${fmtPct(dm.p1)} with diabetes_mellitus vs ${fmtPct(dm.p0)} without it; risk difference ${fmtPct(dm.effect)} (p=${fmtP(dm.p)}).`),
+  ]);
+
+  // 19. Adjusted adverse biology.
+  const h47 = newHyp("After adjustment for age, sex, ECOG, secondary AML, fitness, complex karyotype, and TP53 status, `npm1_mutation` remains positively associated with `objective_response`.");
+  const h48 = newHyp("After adjustment for age, sex, ECOG, secondary AML, fitness, complex karyotype, and TP53 status, `tp53_mutation` remains negatively associated with `objective_response`.");
+  const h49 = newHyp("After adjustment for age, sex, ECOG, secondary AML, fitness, complex karyotype, and TP53 status, `complex_karyotype` remains negatively associated with `objective_response`.");
+  const npmAdjMain = adjustedBinaryEffect(cols, "npm1_mutation");
+  const tp53AdjMain = adjustedBinaryEffect(cols, "tp53_mutation", ["npm1_mutation"]);
+  const complexAdjMain = adjustedBinaryEffect(cols, "complex_karyotype", ["npm1_mutation"]);
+  addIter([h47, h48, h49], [
+    record([h47.id], "adjusted_lpm(objective_response ~ npm1_mutation + covariates)", npmAdjMain, `Adjusted npm1_mutation association was ${fmtPct(npmAdjMain.effect)} on the response-probability scale (p=${fmtP(npmAdjMain.p)}).`),
+    record([h48.id], "adjusted_lpm(objective_response ~ tp53_mutation + covariates)", tp53AdjMain, `Adjusted tp53_mutation association was ${fmtPct(tp53AdjMain.effect)} on the response-probability scale (p=${fmtP(tp53AdjMain.p)}).`),
+    record([h49.id], "adjusted_lpm(objective_response ~ complex_karyotype + covariates)", complexAdjMain, `Adjusted complex_karyotype association was ${fmtPct(complexAdjMain.effect)} on the response-probability scale (p=${fmtP(complexAdjMain.p)}).`),
+  ]);
+
+  // 20. Decoy solid-tumor markers.
+  const h50 = newHyp("Solid-tumor marker `her2_amplification` is not associated with higher `objective_response` in this AML cohort.");
+  const h51 = newHyp("Solid-tumor marker `met_exon14_skipping` is not associated with higher `objective_response` in this AML cohort.");
+  const h52 = newHyp("Solid-tumor marker `ros1_fusion` is not associated with higher `objective_response` in this AML cohort.");
+  const her2 = binaryRiskDifference(cols, "her2_amplification");
+  const met = binaryRiskDifference(cols, "met_exon14_skipping");
+  const ros1 = binaryRiskDifference(cols, "ros1_fusion");
+  addIter([h50, h51, h52], [
+    record([h50.id], "risk_difference(objective_response ~ her2_amplification)", her2, `Response was ${fmtPct(her2.p1)} with her2_amplification vs ${fmtPct(her2.p0)} without it; risk difference ${fmtPct(her2.effect)} (p=${fmtP(her2.p)}).`),
+    record([h51.id], "risk_difference(objective_response ~ met_exon14_skipping)", met, `Response was ${fmtPct(met.p1)} with met_exon14_skipping vs ${fmtPct(met.p0)} without it; risk difference ${fmtPct(met.effect)} (p=${fmtP(met.p)}).`),
+    record([h52.id], "risk_difference(objective_response ~ ros1_fusion)", ros1, `Response was ${fmtPct(ros1.p1)} with ros1_fusion vs ${fmtPct(ros1.p0)} without it; risk difference ${fmtPct(ros1.effect)} (p=${fmtP(ros1.p)}).`),
+  ]);
+
+  // 21. Effusions/metastasis-like fields.
+  const h53 = newHyp("Patients with `pleural_effusion` have a lower `objective_response` rate than patients without `pleural_effusion`.");
+  const h54 = newHyp("Patients with `pericardial_effusion` have a lower `objective_response` rate than patients without `pericardial_effusion`.");
+  const h55 = newHyp("Patients with `liver_mets` have a lower `objective_response` rate than patients without `liver_mets`.");
+  const pleural = binaryRiskDifference(cols, "pleural_effusion");
+  const pericardial = binaryRiskDifference(cols, "pericardial_effusion");
+  const liver = binaryRiskDifference(cols, "liver_mets");
+  addIter([h53, h54, h55], [
+    record([h53.id], "risk_difference(objective_response ~ pleural_effusion)", pleural, `Response was ${fmtPct(pleural.p1)} with pleural_effusion vs ${fmtPct(pleural.p0)} without it; risk difference ${fmtPct(pleural.effect)} (p=${fmtP(pleural.p)}).`),
+    record([h54.id], "risk_difference(objective_response ~ pericardial_effusion)", pericardial, `Response was ${fmtPct(pericardial.p1)} with pericardial_effusion vs ${fmtPct(pericardial.p0)} without it; risk difference ${fmtPct(pericardial.effect)} (p=${fmtP(pericardial.p)}).`),
+    record([h55.id], "risk_difference(objective_response ~ liver_mets)", liver, `Response was ${fmtPct(liver.p1)} with liver_mets vs ${fmtPct(liver.p0)} without it; risk difference ${fmtPct(liver.effect)} (p=${fmtP(liver.p)}).`),
+  ]);
+
+  // 22. Blood pressure and vitals.
+  const h56 = newHyp("Each one-standard-deviation increase in `heart_rate_bpm` is associated with a lower `objective_response` probability.");
+  const h57 = newHyp("Each one-standard-deviation increase in `spo2_pct` is associated with a higher `objective_response` probability.");
+  const h58 = newHyp("Each one-standard-deviation increase in `bmi` is associated with `objective_response` probability.");
+  const hr = continuousEffectPerSd(cols, "heart_rate_bpm");
+  const spo2 = continuousEffectPerSd(cols, "spo2_pct");
+  const bmi = continuousEffectPerSd(cols, "bmi");
+  addIter([h56, h57, h58], [
+    record([h56.id], "linear_probability(objective_response ~ heart_rate_bpm_per_sd)", hr, `A 1-SD increase in heart_rate_bpm (${hr.sdX.toFixed(1)} bpm) changed response probability by ${fmtPct(hr.effect)} (p=${fmtP(hr.p)}).`),
+    record([h57.id], "linear_probability(objective_response ~ spo2_pct_per_sd)", spo2, `A 1-SD increase in spo2_pct (${spo2.sdX.toFixed(2)} percentage points) changed response probability by ${fmtPct(spo2.effect)} (p=${fmtP(spo2.p)}).`),
+    record([h58.id], "linear_probability(objective_response ~ bmi_per_sd)", bmi, `A 1-SD increase in bmi (${bmi.sdX.toFixed(1)} kg/m2) changed response probability by ${fmtPct(bmi.effect)} (p=${fmtP(bmi.p)}).`),
+  ]);
+
+  // 23. Liver tests.
+  const h59 = newHyp("Each one-standard-deviation increase in `ast_u_l` is associated with a lower `objective_response` probability.");
+  const h60 = newHyp("Each one-standard-deviation increase in `alt_u_l` is associated with a lower `objective_response` probability.");
+  const h61 = newHyp("Each one-standard-deviation increase in `total_bilirubin_mg_dl` is associated with a lower `objective_response` probability.");
+  const ast = continuousEffectPerSd(cols, "ast_u_l");
+  const alt = continuousEffectPerSd(cols, "alt_u_l");
+  const bili = continuousEffectPerSd(cols, "total_bilirubin_mg_dl");
+  addIter([h59, h60, h61], [
+    record([h59.id], "linear_probability(objective_response ~ ast_u_l_per_sd)", ast, `A 1-SD increase in ast_u_l (${ast.sdX.toFixed(1)} U/L) changed response probability by ${fmtPct(ast.effect)} (p=${fmtP(ast.p)}).`),
+    record([h60.id], "linear_probability(objective_response ~ alt_u_l_per_sd)", alt, `A 1-SD increase in alt_u_l (${alt.sdX.toFixed(1)} U/L) changed response probability by ${fmtPct(alt.effect)} (p=${fmtP(alt.p)}).`),
+    record([h61.id], "linear_probability(objective_response ~ total_bilirubin_mg_dl_per_sd)", bili, `A 1-SD increase in total_bilirubin_mg_dl (${bili.sdX.toFixed(2)} mg/dL) changed response probability by ${fmtPct(bili.effect)} (p=${fmtP(bili.p)}).`),
+  ]);
+
+  // 24. Treatment selection by molecular features.
+  const h62 = newHyp("Patients with `flt3_itd` are more likely to receive `treatment_midostaurin` than patients without `flt3_itd`.");
+  const h63 = newHyp("Patients with `idh1_mutation` are more likely to receive `treatment_ivosidenib` than patients without `idh1_mutation`.");
+  const h64 = newHyp("Patients with `idh2_mutation` are more likely to receive `treatment_enasidenib` than patients without `idh2_mutation`.");
+  const oldOutcome = cols[OUTCOME];
+  cols.objective_response = cols.treatment_midostaurin;
+  const selMid = binaryRiskDifference(cols, "flt3_itd");
+  cols.objective_response = cols.treatment_ivosidenib;
+  const selIvo = binaryRiskDifference(cols, "idh1_mutation");
+  cols.objective_response = cols.treatment_enasidenib;
+  const selEna = binaryRiskDifference(cols, "idh2_mutation");
+  cols.objective_response = oldOutcome;
+  addIter([h62, h63, h64], [
+    record([h62.id], "risk_difference(treatment_midostaurin ~ flt3_itd)", selMid, `Midostaurin use was ${fmtPct(selMid.p1)} with flt3_itd vs ${fmtPct(selMid.p0)} without flt3_itd; risk difference ${fmtPct(selMid.effect)} (p=${fmtP(selMid.p)}).`),
+    record([h63.id], "risk_difference(treatment_ivosidenib ~ idh1_mutation)", selIvo, `Ivosidenib use was ${fmtPct(selIvo.p1)} with idh1_mutation vs ${fmtPct(selIvo.p0)} without idh1_mutation; risk difference ${fmtPct(selIvo.effect)} (p=${fmtP(selIvo.p)}).`),
+    record([h64.id], "risk_difference(treatment_enasidenib ~ idh2_mutation)", selEna, `Enasidenib use was ${fmtPct(selEna.p1)} with idh2_mutation vs ${fmtPct(selEna.p0)} without idh2_mutation; risk difference ${fmtPct(selEna.effect)} (p=${fmtP(selEna.p)}).`),
+  ]);
+
+  // 25. Final multivariable treatment-biomarker checks.
+  const h65 = newHyp("After adjustment for baseline covariates, the `treatment_ivosidenib` by `idh1_mutation` interaction remains positively associated with `objective_response`.");
+  const h66 = newHyp("After adjustment for baseline covariates, the `treatment_enasidenib` by `idh2_mutation` interaction remains positively associated with `objective_response`.");
+  const h67 = newHyp("After adjustment for baseline covariates, the `treatment_gilteritinib` by `flt3_any` interaction remains positively associated with `objective_response`.");
+  const ivoAdj = adjustedInteraction(cols, "treatment_ivosidenib", "idh1_mutation");
+  const enaAdj = adjustedInteraction(cols, "treatment_enasidenib", "idh2_mutation");
+  const giltAnyAdj = adjustedInteraction(cols, "treatment_gilteritinib", "flt3_any");
+  addIter([h65, h66, h67], [
+    record([h65.id], "adjusted_lpm(objective_response ~ treatment_ivosidenib * idh1_mutation + covariates)", ivoAdj, `Adjusted treatment_ivosidenib by idh1_mutation interaction was ${fmtPct(ivoAdj.effect)} (p=${fmtP(ivoAdj.p)}).`),
+    record([h66.id], "adjusted_lpm(objective_response ~ treatment_enasidenib * idh2_mutation + covariates)", enaAdj, `Adjusted treatment_enasidenib by idh2_mutation interaction was ${fmtPct(enaAdj.effect)} (p=${fmtP(enaAdj.p)}).`),
+    record([h67.id], "adjusted_lpm(objective_response ~ treatment_gilteritinib * flt3_any + covariates)", giltAnyAdj, `Adjusted treatment_gilteritinib by flt3_any interaction was ${fmtPct(giltAnyAdj.effect)} (p=${fmtP(giltAnyAdj.p)}).`),
+  ]);
+
+  const transcript = {
+    dataset_id: "ds001_aml",
+    model_id: "gpt-5-codex",
+    harness_id: "codex-local-node-parquet-analysis@1.0",
+    max_iterations: 25,
+    iterations,
+  };
+
+  const overallResponse = mean(cols[OUTCOME]);
+  const lines = [];
+  lines.push("Analysis summary for ds001_aml");
+  lines.push("");
+  lines.push(`The cohort contains ${n} AML patient records with no missing values in the analyzed columns. The overall objective_response rate was ${fmtPct(overallResponse)}.`);
+  lines.push("");
+  lines.push("Across 25 propose-test-update iterations, the strongest supported patterns were treatment-biomarker specificity and adverse-risk biology. Venetoclax/azacitidine, 7+3, and the targeted FLT3/IDH agents all showed positive unadjusted associations with objective_response. The largest and most specific response gains appeared when targeted therapies matched their biomarkers: midostaurin in flt3_itd disease, gilteritinib in FLT3-altered disease, ivosidenib in idh1_mutation disease, and enasidenib in idh2_mutation disease. Interaction tests generally supported this specificity, including adjusted linear-probability interaction models for midostaurin by flt3_itd, ivosidenib by idh1_mutation, enasidenib by idh2_mutation, and gilteritinib by flt3_any.");
+  lines.push("");
+  lines.push(`Adverse disease biology was consistently associated with lower response. tp53_mutation had an unadjusted risk difference of ${fmtPct(tp53.effect)} and remained negative after adjustment (${fmtPct(tp53AdjMain.effect)}). complex_karyotype had an unadjusted risk difference of ${fmtPct(complex.effect)} and remained negative after adjustment (${fmtPct(complexAdjMain.effect)}). secondary_aml, unfit_for_intensive, older age, worse ECOG performance status, higher inflammatory markers, higher WBC/blast burden, and higher LDH were also associated with lower response probability in the expected direction.`);
+  lines.push("");
+  lines.push(`Favorable-risk biology was also visible. npm1_mutation was associated with higher response unadjusted (${fmtPct(npm1.effect)}) and after adjustment (${fmtPct(npmAdjMain.effect)}). IDH-mutated disease showed a positive main-effect association, and IDH-mutated patients treated with venetoclax/azacitidine had higher response than IDH-mutated patients not treated with that regimen.`);
+  lines.push("");
+  lines.push("Fitness-stratified treatment patterns were clinically coherent. Venetoclax/azacitidine showed a strong positive association among unfit_for_intensive patients and also among secondary_aml patients. 7+3 showed a strong positive association among fit patients, while the 7+3 by unfit_for_intensive interaction was negative, indicating weaker benefit in the unfit subgroup.");
+  lines.push("");
+  lines.push("Several non-AML or likely decoy variables were probed. Solid-tumor alteration fields such as her2_amplification, met_exon14_skipping, and ros1_fusion had small or inconsistent associations compared with canonical AML biomarkers. Effusion/metastasis-like fields and broad comorbidity markers generally had weaker effects than molecular risk, treatment, fitness, and inflammatory disease-burden variables.");
+  lines.push("");
+  lines.push("Overall conclusion: objective_response in this cohort is shaped by matched therapy-biomarker relationships, with strong positive interactions for FLT3- and IDH-directed therapies, and by baseline AML risk/fitness factors. TP53 mutation, complex karyotype, secondary AML, unfitness, older age, worse ECOG, inflammatory state, and higher disease burden mark lower response, while NPM1 mutation and biomarker-matched targeted therapy mark higher response.");
+
+  fs.writeFileSync(TRANSCRIPT, JSON.stringify(transcript, null, 2));
+  fs.writeFileSync(SUMMARY, lines.join("\n") + "\n");
+  console.log(`Wrote ${TRANSCRIPT} and ${SUMMARY}`);
+}
+
+run();

