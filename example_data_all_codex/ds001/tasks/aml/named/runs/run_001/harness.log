+      for (let i = 0; i < l.size; i++) o.schema.push(readSchemaElement(r));
+    } else if (f.id === 3) o.num_rows = r.i64();
+    else if (f.id === 4) {
+      const l = r.list();
+      o.row_groups = [];
+      for (let i = 0; i < l.size; i++) o.row_groups.push(readRowGroup(r));
+    } else if (f.id === 5) {
+      const l = r.list();
+      o.key_value_metadata = [];
+      for (let i = 0; i < l.size; i++) o.key_value_metadata.push(readKeyValue(r));
