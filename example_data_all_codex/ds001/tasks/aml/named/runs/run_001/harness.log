+function snappyUncompress(input) {
+  let p = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[p++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let o = 0;
+  while (p < input.length) {
+    const op = input[p++];
+    const tag = op & 0x03;
+    if (tag === 0) {
+      let l = op >> 2;
+      if (l < 60) {
+        l += 1;
+      } else {
+        const bytes = l - 59;
+        l = 0;
+        for (let i = 0; i < bytes; i++) l |= input[p++] << (8 * i);
+        l += 1;
+      }
+      input.copy(out, o, p, p + l);
+      p += l;
+      o += l;
+    } else {
+      let l;
+      let offset;
+      if (tag === 1) {
+        l = ((op >> 2) & 0x07) + 4;
+        offset = ((op & 0xe0) << 3) | input[p++];
+      } else if (tag === 2) {
+        l = (op >> 2) + 1;
+        offset = input[p] | (input[p + 1] << 8);
+        p += 2;
+      } else {
+        l = (op >> 2) + 1;
+        offset = (input[p] | (input[p + 1] << 8) | (input[p + 2] << 16) | (input[p + 3] << 24)) >>> 0;
+        p += 4;
+      }
+      for (let i = 0; i < l; i++) out[o + i] = out[o - offset + i];
+      o += l;
+    }
+  }
+  if (o !== len) throw new Error(`Snappy length mismatch ${o} != ${len}`);
+  return out;
+}
+
+function uncompressPage(buf, page, codec) {
