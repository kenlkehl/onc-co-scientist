+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readColumnChunk(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.file_path = r.string();
+    else if (f.id === 2) o.file_offset = r.i64();
+    else if (f.id === 3) o.meta_data = readColumnMetaData(r);
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readRowGroup(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) {
+      const l = r.list();
+      o.columns = [];
+      for (let i = 0; i < l.size; i++) o.columns.push(readColumnChunk(r));
+    } else if (f.id === 2) o.total_byte_size = r.i64();
+    else if (f.id === 3) o.num_rows = r.i64();
+    else if (f.id === 5) o.file_offset = r.i64();
+    else if (f.id === 6) o.total_compressed_size = r.i64();
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readFileMetaData(buf) {
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const footerStart = buf.length - 8 - footerLen;
+  const r = new CompactReader(buf.slice(footerStart, buf.length - 8));
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.version = r.i32();
+    else if (f.id === 2) {
+      const l = r.list();
+      o.schema = [];
+      for (let i = 0; i < l.size; i++) o.schema.push(readSchemaElement(r));
+    } else if (f.id === 3) o.num_rows = r.i64();
+    else if (f.id === 4) {
+      const l = r.list();
+      o.row_groups = [];
+      for (let i = 0; i < l.size; i++) o.row_groups.push(readRowGroup(r));
+    } else if (f.id === 5) {
+      const l = r.list();
+      o.key_value_metadata = [];
+      for (let i = 0; i < l.size; i++) o.key_value_metadata.push(readKeyValue(r));
+    } else if (f.id === 6) o.created_by = r.string();
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readDataPageHeader(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.num_values = r.i32();
+    else if (f.id === 2) o.encoding = r.i32();
+    else if (f.id === 3) o.definition_level_encoding = r.i32();
+    else if (f.id === 4) o.repetition_level_encoding = r.i32();
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readDataPageHeaderV2(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.num_values = r.i32();
+    else if (f.id === 2) o.num_nulls = r.i32();
+    else if (f.id === 3) o.num_rows = r.i32();
+    else if (f.id === 4) o.encoding = r.i32();
+    else if (f.id === 5) o.definition_levels_byte_length = r.i32();
+    else if (f.id === 6) o.repetition_levels_byte_length = r.i32();
+    else if (f.id === 7) o.is_compressed = f.type === COMPACT.TRUE;
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readDictionaryPageHeader(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.num_values = r.i32();
+    else if (f.id === 2) o.encoding = r.i32();
+    else if (f.id === 3) o.is_sorted = f.type === COMPACT.TRUE;
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readPageHeader(buf, pos) {
+  const r = new CompactReader(buf, pos);
+  let last = 0;
+  const o = { start: pos };
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.type = r.i32();
+    else if (f.id === 2) o.uncompressed_page_size = r.i32();
+    else if (f.id === 3) o.compressed_page_size = r.i32();
+    else if (f.id === 5) o.data_page_header = readDataPageHeader(r);
+    else if (f.id === 7) o.dictionary_page_header = readDictionaryPageHeader(r);
+    else if (f.id === 8) o.data_page_header_v2 = readDataPageHeaderV2(r);
+    else r.skip(f.type);
+  }
