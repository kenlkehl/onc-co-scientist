+const fs = require("fs");
+
+const DATASET = "dataset.parquet";
+const OUTCOME = "objective_response";
+const TRANSCRIPT = "transcript.json";
+const SUMMARY = "analysis_summary.txt";
+
+const PHYS = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+};
+
+const COMPACT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
