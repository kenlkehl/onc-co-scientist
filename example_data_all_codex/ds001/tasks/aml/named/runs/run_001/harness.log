+  const h1 = newHyp("Patients with `treatment_venetoclax_azacitidine` have a higher `objective_response` rate than patients without `treatment_venetoclax_azacitidine`.");
+  const h2 = newHyp("Patients with `treatment_7plus3` have a higher `objective_response` rate than patients without `treatment_7plus3`.");
