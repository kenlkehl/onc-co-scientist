@@ -0,0 +1,1312 @@
+const fs = require("fs");
+
+const DATASET = "dataset.parquet";
+const OUTCOME = "objective_response";
+const TRANSCRIPT = "transcript.json";
+const SUMMARY = "analysis_summary.txt";
+
+const PHYS = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+};
+
+const COMPACT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  number(n) {
+    const x = Number(n);
+    return Number.isSafeInteger(x) ? x : Number(n.toString());
+  }
+
+  i16() {
+    return this.number(this.zigzag(this.varint()));
+  }
+
+  i32() {
