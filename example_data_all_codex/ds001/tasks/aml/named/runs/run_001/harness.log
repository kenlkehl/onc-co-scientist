+++ b/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/aml/named/analysis_runner.js
@@ -0,0 +1,1310 @@
+const fs = require("fs");
+
+const DATASET = "dataset.parquet";
+const OUTCOME = "objective_response";
+const TRANSCRIPT = "transcript.json";
+const SUMMARY = "analysis_summary.txt";
+
+const PHYS = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+};
+
+const COMPACT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  number(n) {
+    const x = Number(n);
+    return Number.isSafeInteger(x) ? x : Number(n.toString());
+  }
+
+  i16() {
+    return this.number(this.zigzag(this.varint()));
+  }
+
+  i32() {
+    return this.number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return this.number(this.zigzag(this.varint()));
+  }
+
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+
+  binary() {
+    const len = Number(this.varint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  string() {
+    return this.binary().toString("utf8");
+  }
+
+  field(lastFieldId) {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === COMPACT.STOP) return { type, id: 0 };
+    const delta = h >> 4;
+    const id = delta === 0 ? this.i16() : lastFieldId + delta;
+    return { type, id };
+  }
+
+  list() {
+    const h = this.byte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+
+  skip(type) {
+    if (type === COMPACT.STOP || type === COMPACT.TRUE || type === COMPACT.FALSE) return;
+    if (type === COMPACT.BYTE) {
+      this.pos++;
+      return;
+    }
+    if (type === COMPACT.I16 || type === COMPACT.I32 || type === COMPACT.I64) {
+      this.varint();
+      return;
+    }
+    if (type === COMPACT.DOUBLE) {
+      this.pos += 8;
+      return;
+    }
+    if (type === COMPACT.BINARY) {
+      const len = Number(this.varint());
+      this.pos += len;
+      return;
+    }
+    if (type === COMPACT.LIST || type === COMPACT.SET) {
+      const l = this.list();
+      for (let i = 0; i < l.size; i++) this.skip(l.type);
+      return;
+    }
+    if (type === COMPACT.MAP) {
+      const size = Number(this.varint());
+      if (size > 0) {
+        const types = this.byte();
+        const keyType = (types >> 4) & 0x0f;
+        const valueType = types & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(keyType);
+          this.skip(valueType);
+        }
+      }
+      return;
+    }
+    if (type === COMPACT.STRUCT) {
+      let last = 0;
+      while (true) {
+        const f = this.field(last);
+        if (f.type === COMPACT.STOP) break;
+        last = f.id;
+        this.skip(f.type);
+      }
+      return;
+    }
+    throw new Error(`Unsupported compact type ${type}`);
+  }
+}
+
+function readIntList(r) {
+  const l = r.list();
+  const out = [];
+  for (let i = 0; i < l.size; i++) out.push(r.i32());
+  return out;
+}
+
+function readStringList(r) {
+  const l = r.list();
+  const out = [];
+  for (let i = 0; i < l.size; i++) out.push(r.string());
+  return out;
+}
+
+function readSchemaElement(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.type = r.i32();
+    else if (f.id === 2) o.type_length = r.i32();
+    else if (f.id === 3) o.repetition_type = r.i32();
+    else if (f.id === 4) o.name = r.string();
+    else if (f.id === 5) o.num_children = r.i32();
+    else if (f.id === 6) o.converted_type = r.i32();
+    else if (f.id === 7) o.scale = r.i32();
+    else if (f.id === 8) o.precision = r.i32();
+    else if (f.id === 9) o.field_id = r.i32();
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readKeyValue(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.key = r.string();
+    else if (f.id === 2) o.value = r.string();
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readColumnMetaData(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.type = r.i32();
+    else if (f.id === 2) o.encodings = readIntList(r);
+    else if (f.id === 3) o.path_in_schema = readStringList(r);
+    else if (f.id === 4) o.codec = r.i32();
+    else if (f.id === 5) o.num_values = r.i64();
+    else if (f.id === 6) o.total_uncompressed_size = r.i64();
+    else if (f.id === 7) o.total_compressed_size = r.i64();
+    else if (f.id === 9) o.data_page_offset = r.i64();
+    else if (f.id === 10) o.index_page_offset = r.i64();
+    else if (f.id === 11) o.dictionary_page_offset = r.i64();
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readColumnChunk(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) o.file_path = r.string();
+    else if (f.id === 2) o.file_offset = r.i64();
+    else if (f.id === 3) o.meta_data = readColumnMetaData(r);
+    else r.skip(f.type);
+  }
+  return o;
+}
+
+function readRowGroup(r) {
+  let last = 0;
+  const o = {};
+  while (true) {
+    const f = r.field(last);
+    if (f.type === COMPACT.STOP) break;
+    last = f.id;
+    if (f.id === 1) {
+      const l = r.list();
+      o.columns = [];
+      for (let i = 0; i < l.size; i++) o.columns.push(readColumnChunk(r));
+    } else if (f.id === 2) o.total_byte_size = r.i64();
+    else if (f.id === 3) o.num_rows = r.i64();
