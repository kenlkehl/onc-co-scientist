+const fs = require("fs");
+
+const DATASET = "dataset.parquet";
+const OUTCOME = "objective_response";
+const TRANSCRIPT = "transcript.json";
+const SUMMARY = "analysis_summary.txt";
+
+const PHYS = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+};
+
+const COMPACT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  number(n) {
+    const x = Number(n);
+    return Number.isSafeInteger(x) ? x : Number(n.toString());
+  }
+
+  i16() {
+    return this.number(this.zigzag(this.varint()));
+  }
+
+  i32() {
+    return this.number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return this.number(this.zigzag(this.varint()));
+  }
+
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+
+  binary() {
+    const len = Number(this.varint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  string() {
+    return this.binary().toString("utf8");
+  }
+
+  field(lastFieldId) {
+    const h = this.byte();
+    const type = h & 0x0f;
+    if (type === COMPACT.STOP) return { type, id: 0 };
+    const delta = h >> 4;
+    const id = delta === 0 ? this.i16() : lastFieldId + delta;
+    return { type, id };
+  }
+
+  list() {
+    const h = this.byte();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+
+  skip(type) {
+    if (type === COMPACT.STOP || type === COMPACT.TRUE || type === COMPACT.FALSE) return;
+    if (type === COMPACT.BYTE) {
+      this.pos++;
+      return;
+    }
+    if (type === COMPACT.I16 || type === COMPACT.I32 || type === COMPACT.I64) {
+      this.varint();
+      return;
+    }
+    if (type === COMPACT.DOUBLE) {
+      this.pos += 8;
+      return;
+    }
+    if (type === COMPACT.BINARY) {
+      const len = Number(this.varint());
+      this.pos += len;
+      return;
+    }
+    if (type === COMPACT.LIST || type === COMPACT.SET) {
+      const l = this.list();
+      for (let i = 0; i < l.size; i++) this.skip(l.type);
+      return;
+    }
+    if (type === COMPACT.MAP) {
+      const size = Number(this.varint());
+      if (size > 0) {
+        const types = this.byte();
+        const keyType = (types >> 4) & 0x0f;
+        const valueType = types & 0x0f;
