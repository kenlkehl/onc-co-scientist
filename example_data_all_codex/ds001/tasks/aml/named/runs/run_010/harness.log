class R{constructor(b){this.b=b;this.i=0;} u8(){return this.b[this.i++];} bytes(n){const s=this.b.subarray(this.i,this.i+n);this.i+=n;return s;} varint(){let shift=0n,res=0n;while(true){const byte=this.u8();res|=BigInt(byte&0x7f)<<shift;if((byte&0x80)===0)break;shift+=7n;}return res;} zig(n){return (n>>1n) "'^ (-(n&1n));} i32(){return Number(this.zig(this.varint()));} i64(){return this.zig(this.varint());} len(){return Number(this.varint());} str(){const n=this.len();return this.bytes(n).toString('"'utf8');} dbl(){const v=this.b.readDoubleLE(this.i);this.i+=8;return v;} flt(){const v=this.b.readFloatLE(this.i);this.i+=4;return v;} }
function skip(r,t){switch(t){case 1:case 2: return; case 3: r.u8(); return; case 4: r.i32(); return; case 5: r.i32(); return; case 6: r.i64(); return; case 7: r.dbl(); return; case 8: {const n=r.len(); r.i+=n; return;} case 9:case 10:{const h=r.u8(); const et=h&0x0f; const sz=h>>4 || r.len(); for(let k=0;k<sz;k++) skip(r,et); return;} case 11:{const h=r.u8(); const kt=(h>>4)&0x0f, vt=h&0x0f; const sz=r.len(); for(let k=0;k<sz;k++){skip(r,kt);skip(r,vt);} return;} case 12: readStruct(r); return; default: throw new Error('skip type '+t+' at '+r.i);}}
function readVal(r,t){switch(t){case 1:return true;case 2:return false;case 3:return r.u8();case 4:return r.i32();case 5:return r.i32();case 6:return r.i64().toString();case 7:return r.dbl();case 8:return r.str();case 9:case 10:{const h=r.u8(); const et=h&0x0f; const sz=h>>4 || r.len(); const a=[]; for(let k=0;k<sz;k++) a.push(readVal(r,et)); return a;}case 11:{const h=r.u8(); const kt=(h>>4)&0x0f, vt=h&0x0f; const sz=r.len(); const o={}; for(let k=0;k<sz;k++) o[readVal(r,kt)]=readVal(r,vt); return o;}case 12:return readStruct(r);default: throw new Error('val type '+t+' at '+r.i);}}
