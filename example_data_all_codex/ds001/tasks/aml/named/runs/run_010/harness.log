function analysis(hids,summary,effect,p,code){return{hypothesis_ids:Array.isArray(hids)?hids:[hids],code,result_summary:summary,p_value:p,effect_estimate:round(effect),significant:p<0.05}}function coefAnalysis(hid,label,r,code){return analysis(hid,"'`${label}: coefficient ${round(r.b,4)} response-probability units (SE ${round(r.se,4)}, p=${fmtP(r.p)}).`,r.b,r.p,code)}function diffAnalysis(hid,label,r,code){return analysis(hid,`${label}: ${fmtPct(r.p1)} vs ${fmtPct(r.p0)} (n=${r.n1} vs ${r.n0}); response-rate difference ${round(r.d,4)} (p=${fmtP(r.p)}).`,r.d,r.p,code)}
