const stats={overall_y:y.reduce((a,b)=>a+b,0)/N,npm1:binDiff('npm1_mutation'),tp53:binDiff('tp53_mutation'),complex:binDiff('complex_karyotype'),ven:binDiff('treatment_venetoclax_azacitidine'),unfit:binDiff('unfit_for_intensive'),flt3_itd:binDiff('flt3_itd'),flt3_tkd:binDiff('flt3_tkd'),idh1:binDiff('idh1_mutation'),idh2:binDiff('idh2_mutation'),age:get(adj,'age_years'),sex:get(adj,'sex_female'),ecog:get(adj,'ecog_ps'),weight:get(adj,'weight_loss_pct_6mo'),blast:get(adj,'blast_pct_marrow'),wbc:get(adj,'wbc_k_per_ul'),albumin:get(adj,'albumin_g_dl'),crp:get(adj,'crp_mg_l'),adj_npm1:get(adj,'npm1_mutation'),adj_unfit:get(adj,'unfit_for_intensive'),adj_ven:get(adj,'treatment_venetoclax_azacitidine'),adj_tp53:get(adj,'tp53_mutation'),adj_complex:get(adj,'complex_karyotype'),adj_7plus3:get(adj,'treatment_7plus3'),mid_flt3:interaction('treatment_midostaurin','flt3_itd',covs),gilt_flt3:interaction('treatment_gilteritinib','flt3_itd',covs),gilt_tkd:interaction('treatment_gilteritinib','flt3_tkd',covs),ivo_idh1:interaction('treatment_ivosidenib','idh1_mutation',covs),ena_idh2:interaction('treatment_enasidenib','idh2_mutation',covs),ven_unfit:interaction('treatment_venetoclax_azacitidine','unfit_for_intensive',covs),ven_npm1:interaction('treatment_venetoclax_azacitidine','npm1_mutation',covs),ven_tp53:interaction('treatment_venetoclax_azacitidine','tp53_mutation',covs),ven_complex:interaction('treatment_venetoclax_azacitidine','complex_karyotype',covs),npm1_tp53:simpleInteraction('npm1_mutation','tp53_mutation'),npm1_complex:simpleInteraction('npm1_mutation','complex_karyotype'),seven_complex:get(comb,'7plus3*complex'),triple:get(triple,'ven*npm1*unfit')};
