function snappy(input){let ip=0;function rv(){let s=0,n=0;while(true){const b=input[ip++];n|=(b&127)<<s;if(!(b&128))break;s+=7;}return n;}const len=rv(),out=Buffer.allocUnsafe(len);let op=0;while(ip<input.length){const tag=input[ip++],type=tag&3;if(type===0){let l=tag>>2;if(l<60)l++;else{const bytes=l-59;l=0;for(let i=0;i<bytes;i++)l|=input[ip++]<<(8*i);l++;}input.copy(out,op,ip,ip+l);ip+=l;op+=l;}else{let l,off;if(type===1){l=((tag>>2)&7)+4;off=((tag&224)<<3)|input[ip++];}else if(type===2){l=(tag>>2)+1;off=input[ip]|(input[ip+1]<<8);ip+=2;}else{l=(tag>>2)+1;off=(input[ip]|(input[ip+1]<<8)|(input[ip+2]<<16)|(input[ip+3]<<24))>>>0;ip+=4;}for(let k=0;k<l;k++)out[op+k]=out[op-off+k];op+=l;}}return out;}function pData(h){return snappy(parquet.subarray(h.headerEnd,h.headerEnd+h.compressed_page_size));}
function plain(data,type,n){const a=[];let o=0;for(let i=0;i<n;i++){if(type===5){a.push(data.readDoubleLE(o));o+=8;}else if(type===2){a.push(Number(data.readBigInt64LE(o)));o+=8;}else if(type===6){const l=data.readInt32LE(o);o+=4;a.push(data.subarray(o,o+l).toString('"'utf8'));o+=l;}else throw Error('type '+type);}return a;}function hybrid(data,o,count,bw){const vals=[];let p=o;function uv(){let s=0,n=0;while(true){const b=data[p++];n|=(b&127)<<s;if("'!(b&128))break;s+=7;}return n;}while(vals.length<count){const h=uv();if((h&1)===0){const run=h>>1;let v=0;const bytes=Math.ceil(bw/8);for(let b=0;b<bytes;b++)v|=data[p++]<<(8*b);for(let k=0;k<run&&vals.length<count;k++)vals.push(v);}else{const groups=h>>1;for(let g=0;g<groups;g++){let bitbuf=0,bits=0;for(let j=0;j<8;j++){while(bits<bw){bitbuf|=data[p++]<<bits;bits+=8;}const v=bitbuf&((1<<bw)-1);bitbuf>>=bw;bits-=bw;if(vals.length<count)vals.push(v);}}}}return{vals,off:p};}
