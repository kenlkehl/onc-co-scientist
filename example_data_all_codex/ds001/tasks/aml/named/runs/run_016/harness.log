+const fs = require("fs");
+
+const parquet = fs.readFileSync("dataset.parquet");
+
+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.i = offset;
+    this.stack = [];
+    this.lastField = 0;
+  }
+
+  u8() {
+    return this.buf[this.i++];
+  }
+
+  varint() {
+    let shift = 0;
+    let n = 0n;
+    while (true) {
+      const b = this.u8();
+      n |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return n;
+  }
+
+  i32() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  i64z() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+
+  binary() {
+    const len = Number(this.varint());
+    const out = this.buf.subarray(this.i, this.i + len);
+    this.i += len;
+    return out;
+  }
+
+  string() {
+    return this.binary().toString("utf8");
+  }
+
+  field() {
+    const b = this.u8();
+    if (b === 0) return null;
+    const type = b & 0x0f;
+    const delta = b >> 4;
+    const id = delta === 0 ? this.i32() : this.lastField + delta;
+    this.lastField = id;
+    return { id, type };
+  }
+
+  enter() {
+    this.stack.push(this.lastField);
+    this.lastField = 0;
+  }
+
+  exit() {
+    this.lastField = this.stack.pop();
+  }
+
+  listHeader() {
+    const b = this.u8();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, elemType };
+  }
+
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.u8();
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.varint();
+        return;
+      case 7:
+        this.i += 8;
+        return;
+      case 8:
+        this.binary();
+        return;
+      case 9:
+      case 10: {
+        const h = this.listHeader();
+        for (let k = 0; k < h.size; k++) this.skip(h.elemType);
+        return;
+      }
+      case 11: {
+        const b = this.u8();
+        if (b === 0) return;
+        const size = Number(this.varint());
+        const keyType = (b >> 4) & 0x0f;
+        const valType = b & 0x0f;
+        for (let k = 0; k < size; k++) {
+          this.skip(keyType);
+          this.skip(valType);
+        }
+        return;
+      }
+      case 12:
+        this.enter();
+        while (true) {
+          const f = this.field();
+          if (!f) break;
+          this.skip(f.type);
+        }
+        this.exit();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.i}`);
+    }
+  }
+}
+
+function skipStruct(r) {
+  r.enter();
+  while (true) {
+    const f = r.field();
+    if (!f) break;
+    r.skip(f.type);
+  }
+  r.exit();
+}
+
+function readSchemaElement(r) {
+  const o = {};
+  r.enter();
+  while (true) {
+    const f = r.field();
+    if (!f) break;
+    if (f.id === 1) o.type = r.i32();
+    else if (f.id === 3) o.repetition_type = r.i32();
+    else if (f.id === 4) o.name = r.string();
+    else if (f.id === 5) o.num_children = r.i32();
+    else r.skip(f.type);
+  }
+  r.exit();
+  return o;
+}
+
+function readColumnMeta(r) {
+  const o = {};
+  r.enter();
+  while (true) {
+    const f = r.field();
+    if (!f) break;
+    switch (f.id) {
+      case 1:
+        o.type = r.i32();
+        break;
+      case 3: {
+        const h = r.listHeader();
+        o.path = [];
+        for (let k = 0; k < h.size; k++) o.path.push(r.string());
+        break;
+      }
+      case 4:
+        o.codec = r.i32();
+        break;
+      case 5:
+        o.num_values = r.i64z();
+        break;
+      case 9:
+        o.data_page_offset = r.i64z();
+        break;
+      case 11:
+        o.dictionary_page_offset = r.i64z();
+        break;
+      case 12:
+        skipStruct(r);
+        break;
+      default:
+        r.skip(f.type);
+    }
+  }
+  r.exit();
+  return o;
+}
