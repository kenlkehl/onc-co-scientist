+const fs = require("fs");
+
+const parquet = fs.readFileSync("dataset.parquet");
+
+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.i = offset;
+    this.stack = [];
+    this.lastField = 0;
+  }
+
+  u8() {
+    return this.buf[this.i++];
+  }
+
+  varint() {
