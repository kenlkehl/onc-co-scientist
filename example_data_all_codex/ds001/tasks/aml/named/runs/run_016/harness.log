+
+function twoSidedP(z) {
+  const p = 2 * (1 - pnorm(Math.abs(z)));
+  return p === 0 ? 1e-300 : p;
+}
+
+function mean(arr, indexes = null) {
+  let s = 0;
+  let n = 0;
+  if (indexes) {
+    for (const i of indexes) {
+      s += arr[i];
+      n++;
+    }
+  } else {
+    for (const v of arr) {
+      s += v;
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let s = 0;
+  for (const v of arr) {
+    const d = v - m;
+    s += d * d;
+  }
+  return Math.sqrt(s / (arr.length - 1));
+}
+
+function riskDiff(exposure, outcome) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < outcome.length; i++) {
+    if (exposure[i] === 1) {
+      n1++;
+      s1 += outcome[i];
+    } else {
+      n0++;
+      s0 += outcome[i];
+    }
+  }
+  const p1 = s1 / n1;
+  const p0 = s0 / n0;
+  const effect = p1 - p0;
+  const pooled = (s1 + s0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
+  return { n1, n0, p1, p0, effect, p_value: twoSidedP(effect / se) };
+}
+
+function levelDiff(values, high, low, outcome) {
+  let nHigh = 0;
+  let nLow = 0;
+  let sHigh = 0;
+  let sLow = 0;
+  for (let i = 0; i < outcome.length; i++) {
+    if (values[i] === high) {
+      nHigh++;
+      sHigh += outcome[i];
+    } else if (values[i] === low) {
+      nLow++;
+      sLow += outcome[i];
+    }
+  }
+  const pHigh = sHigh / nHigh;
+  const pLow = sLow / nLow;
+  const effect = pHigh - pLow;
+  const pooled = (sHigh + sLow) / (nHigh + nLow);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / nHigh + 1 / nLow));
+  return { nHigh, nLow, pHigh, pLow, effect, p_value: twoSidedP(effect / se) };
+}
+
+function continuousPerSd(values, outcome) {
+  const mx = mean(values);
+  const my = mean(outcome);
+  const sx = sd(values);
+  let sxx = 0;
+  let sxy = 0;
+  for (let i = 0; i < outcome.length; i++) {
+    const dx = values[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (outcome[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < outcome.length; i++) {
+    const e = outcome[i] - (intercept + slope * values[i]);
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (outcome.length - 2)) / sxx);
+  return { slope, sd: sx, effect: slope * sx, p_value: twoSidedP(slope / se) };
+}
+
+function invert(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    }
+    [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    if (Math.abs(div) < 1e-12) throw new Error("Singular design matrix");
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = M[r][i];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= factor * M[i][c];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function ols(outcome, columns, names) {
+  const n = outcome.length;
+  const p = columns.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const col of columns) row.push(col[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * outcome[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invert(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 1; j < p; j++) pred += beta[j] * columns[j - 1][i];
+    const e = outcome[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const out = {};
+  ["Intercept", ...names].forEach((name, i) => {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    out[name] = { coef: beta[i], se, p_value: twoSidedP(beta[i] / se) };
+  });
+  return out;
+}
+
+function subgroupTreatmentEffect(treatment, subgroup, value, outcome) {
+  let nT = 0;
+  let nC = 0;
+  let sT = 0;
+  let sC = 0;
+  for (let i = 0; i < outcome.length; i++) {
+    if (subgroup[i] !== value) continue;
+    if (treatment[i] === 1) {
+      nT++;
+      sT += outcome[i];
+    } else {
+      nC++;
+      sC += outcome[i];
+    }
+  }
+  const pT = sT / nT;
+  const pC = sC / nC;
+  const effect = pT - pC;
+  const pooled = (sT + sC) / (nT + nC);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / nT + 1 / nC));
+  return { nT, nC, pT, pC, effect, p_value: twoSidedP(effect / se) };
+}
+
+function pFmt(p) {
+  if (p <= 1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(3);
+}
+
+function nFmt(x) {
+  return Number(x.toFixed(6));
+}
+
+function pNum(p) {
+  if (p <= 1e-300) return 1e-300;
+  return Number(p.toPrecision(6));
+}
+
+function pct(x) {
+  return `${(100 * x).toFixed(1)}%`;
+}
+
+function analysisRecord(hypothesis_ids, result_summary, effect, p, method) {
+  return {
+    hypothesis_ids,
+    code: null,
+    method,
+    result_summary,
+    p_value: pNum(p),
+    effect_estimate: nFmt(effect),
+    significant: p < 0.05,
+  };
+}
+
+const meta = readFileMeta();
+const columns = meta.row_groups[0].columns;
+const data = {};
