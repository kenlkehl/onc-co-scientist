+function hybridDecode(data, offset, count, bitWidth) {
+  const vals = [];
+  let pos = offset;
+  function readUVarint() {
+    let shift = 0;
+    let n = 0;
+    while (true) {
+      const b = data[pos++];
+      n |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return n;
+  }
