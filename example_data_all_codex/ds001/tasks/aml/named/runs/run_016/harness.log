+  const pLow = sLow / nLow;
+  const effect = pHigh - pLow;
+  const pooled = (sHigh + sLow) / (nHigh + nLow);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / nHigh + 1 / nLow));
