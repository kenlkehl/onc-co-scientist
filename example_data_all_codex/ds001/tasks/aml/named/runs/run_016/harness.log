+    sxx += dx * dx;
+    sxy += dx * (outcome[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < outcome.length; i++) {
+    const e = outcome[i] - (intercept + slope * values[i]);
+    rss += e * e;
+  }
