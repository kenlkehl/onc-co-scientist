+  while (vals.length < count) {
+    const header = readUVarint();
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      let value = 0;
+      const bytes = Math.ceil(bitWidth / 8);
+      for (let b = 0; b < bytes; b++) value |= data[pos++] << (8 * b);
+      for (let k = 0; k < run && vals.length < count; k++) vals.push(value);
+    } else {
+      const groups = header >> 1;
+      for (let g = 0; g < groups; g++) {
+        let bitbuf = 0;
+        let bits = 0;
+        for (let j = 0; j < 8; j++) {
+          while (bits < bitWidth) {
+            bitbuf |= data[pos++] << bits;
+            bits += 8;
+          }
+          const mask = (1 << bitWidth) - 1;
+          const value = bitbuf & mask;
+          bitbuf >>= bitWidth;
+          bits -= bitWidth;
+          if (vals.length < count) vals.push(value);
