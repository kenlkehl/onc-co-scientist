function erf(x){const s=x<0?-1:1; x=Math.abs(x);const a1=.254829592,a2=-.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=.3275911,t=1/(1+p*x);const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x);return s*y;}function pnorm(z){return .5*(1+erf(z/Math.SQRT2));}function p2(z){const p=2*(1-pnorm(Math.abs(z)));return p===0?1e-300:p;}
function mean(a,idx=null){let s=0,n=0;if(idx){for(const i of idx){s+=a[i];n++;}}else{for(const v of a){s+=v;n++;}}return s/n;}function sd(a){const m=mean(a);let s=0;for(const v of a){const d=v-m;s+=d*d;}return Math.sqrt(s/(a.length-1));}
function binTest(x,y){let n1=0,n0=0,s1=0,s0=0;for(let i=0;i<y.length;i++){if(x[i]===1){n1++;s1+=y[i];}else{n0++;s0+=y[i];}}const p1=s1/n1,p0=s0/n0,d=p1-p0,p=(s1+s0)/(n1+n0),se=Math.sqrt(p*(1-p)*(1/n1+1/n0));return{n1,n0,p1,p0,effect:d,p:p2(d/se)};}
function contTest(x,y){const mx=mean(x),my=mean(y),sx=sd(x);let sxx=0,sxy=0;for(let i=0;i<x.length;i++){const dx=x[i]-mx;sxx+=dx*dx;sxy+=dx*(y[i]-my);}const b=sxy/sxx;let rss=0;for(let i=0;i<x.length;i++){const e=y[i]-(my-b*mx+b*x[i]);rss+=e*e;}const se=Math.sqrt((rss/(x.length-2))/sxx);return{effect:b*sx,slope:b,p:p2(b/se),sd:sx};}
function invert(A){const n=A.length,M=A.map((r,i)=>r.concat(Array.from({length:n},(_,j)=>i===j?1:0)));for(let i=0;i<n;i++){let piv=i;for(let r=i+1;r<n;r++)if(Math.abs(M[r][i])>Math.abs(M[piv][i]))piv=r;[M[i],M[piv]]=[M[piv],M[i]];const div=M[i][i];if(Math.abs(div)<1e-12)throw Error('"'singular');for(let c=0;c<2*n;c++)M[i][c]/=div;for(let r=0;r<n;r++){if(r===i)continue;const f=M[r][i];if(f===0)continue;for(let c=0;c<2*n;c++)M[r][c]-=f*M[i][c];}}return M.map(r=>r.slice(n));}
