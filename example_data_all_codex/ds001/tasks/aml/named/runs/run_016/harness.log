+        for (let i = 0; i < bytes; i++) litLen |= input[ip++] << (8 * i);
+        litLen += 1;
+      }
+      input.copy(out, op, ip, ip + litLen);
+      ip += litLen;
+      op += litLen;
+    } else {
+      let copyLen;
+      let offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = (input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24)) >>> 0;
+        ip += 4;
+      }
+      for (let k = 0; k < copyLen; k++) out[op + k] = out[op - offset + k];
+      op += copyLen;
+    }
+  }
+  if (op !== len) throw new Error(`Snappy decoded ${op} bytes, expected ${len}`);
+  return out;
+}
+
+function pageData(header) {
+  const compressed = parquet.subarray(header.headerEnd, header.headerEnd + header.compressed_page_size);
+  return snappyUncompress(compressed);
+}
+
+function plainDecodeDictionary(data, type, n) {
+  const vals = [];
+  let offset = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === 5) {
+      vals.push(data.readDoubleLE(offset));
+      offset += 8;
+    } else if (type === 2) {
+      vals.push(Number(data.readBigInt64LE(offset)));
+      offset += 8;
+    } else if (type === 6) {
+      const len = data.readInt32LE(offset);
+      offset += 4;
+      vals.push(data.subarray(offset, offset + len).toString("utf8"));
+      offset += len;
+    } else {
+      throw new Error(`Unsupported physical type ${type}`);
+    }
+  }
+  return vals;
