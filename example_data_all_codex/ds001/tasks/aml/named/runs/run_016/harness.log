+      nT++;
+      sT += outcome[i];
+    } else {
+      nC++;
+      sC += outcome[i];
+    }
+  }
+  const pT = sT / nT;
+  const pC = sC / nC;
+  const effect = pT - pC;
+  const pooled = (sT + sC) / (nT + nC);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / nT + 1 / nC));
