+function pnorm(z) {
+  return 0.5 * (1 + erf(z / Math.SQRT2));
+}
+
+function twoSidedP(z) {
+  const p = 2 * (1 - pnorm(Math.abs(z)));
+  return p === 0 ? 1e-300 : p;
