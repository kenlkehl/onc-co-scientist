+
+function invert(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    }
+    [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    if (Math.abs(div) < 1e-12) throw new Error("Singular design matrix");
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = M[r][i];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= factor * M[i][c];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function ols(outcome, columns, names) {
+  const n = outcome.length;
+  const p = columns.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const col of columns) row.push(col[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * outcome[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invert(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 1; j < p; j++) pred += beta[j] * columns[j - 1][i];
+    const e = outcome[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const out = {};
+  ["Intercept", ...names].forEach((name, i) => {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    out[name] = { coef: beta[i], se, p_value: twoSidedP(beta[i] / se) };
+  });
