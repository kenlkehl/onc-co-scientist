class R{constructor(buf,off=0){this.buf=buf;this.i=off;this.stack=[];this.lastField=0;}u8(){return this.buf[this.i++];}varint(){let s=0,n=0n;while(true){const b=this.u8();n|=BigInt(b&127)<<BigInt(s);if("'!(b&128))break;s+=7;}return n;}i32(){const n=this.varint();return Number((n>>1n)''^(-(n&1n)));}i64z(){const n=this.varint();return Number((n>>1n)''^(-(n&1n)));}bin(){const l=Number(this.varint());const x=this.buf.subarray(this.i,this.i+l);this.i+=l;return x;}str(){return this.bin().toString('"'utf8');}field(){const b=this.u8();if(b===0)return null;const typ=b&15,d=b>>4;let id;if(d===0)id=this.i32();else id=this.lastField+d;this.lastField=id;return{id,typ};}enter(){this.stack.push(this.lastField);this.lastField=0;}exit(){this.lastField=this.stack.pop();}listHeader(){const b=this.u8();let size=b>>4,et=b&15;if(size===15)size=Number(this.varint());return{size,et};}skip(t){switch(t){case 1:case 2:return;case 3:this.u8();return;case 4:case 5:case 6:this.varint();return;case 7:this.i+=8;return;case 8:this.bin();return;case 9:case 10:{const h=this.listHeader();for(let k=0;k<h.size;k++)this.skip(h.et);return;}case 11:{const b=this.u8();if(b===0)return;const size=Number(this.varint()),kt=(b>>4)&15,vt=b&15;for(let k=0;k<size;k++){this.skip(kt);this.skip(vt);}return;}case 12:{this.enter();while(true){const f=this.field();if("'!f)break;this.skip(f.typ);}this.exit();return;}default:throw Error('"'skip '+t+' at '+this.i);}}}
