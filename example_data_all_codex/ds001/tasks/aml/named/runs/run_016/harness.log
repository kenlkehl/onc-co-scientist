  varint(){let shift=0,n=0n;while(true){const b=this.u8();n|=BigInt(b&0x7f)<<BigInt(shift);if("'!(b&0x80))break;shift+=7;}return n;}
  zig(n){return Number((n>>1n) ''^ (-(n&1n)));}
  i32(){return this.zig(this.varint());}
  i64(){return (this.varint()>>1n) ''^ (-(this.varint()&0n));}
  i64z(){const n=this.varint(); return Number((n>>1n) ''^ (-(n&1n)));}
  dbl(){const v=this.buf.readDoubleLE(this.i);this.i+=8;return v;}
  bin(){const l=Number(this.varint());const s=this.buf.subarray(this.i,this.i+l);this.i+=l;return s;}
  str(){return this.bin().toString('"'utf8');}
