+function adjustedInteraction(treatmentName, biomarkerName) {
+  const treatment = data[treatmentName];
+  const biomarker = data[biomarkerName];
+  const interaction = treatment.map((v, i) => v * biomarker[i]);
+  const covarNames = adjustmentCovars.filter((n) => n !== treatmentName && n !== biomarkerName);
+  const names = ["treatment", "subgroup", "interaction", ...covarNames];
+  const cols = [treatment, biomarker, interaction, ...covarNames.map((n) => data[n])];
+  const fit = ols(y, cols, names);
+  return { effect: fit.interaction.coef, p_value: fit.interaction.p_value, fit };
