+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let litLen = tag >> 2;
+      if (litLen < 60) {
+        litLen += 1;
+      } else {
+        const bytes = litLen - 59;
+        litLen = 0;
+        for (let i = 0; i < bytes; i++) litLen |= input[ip++] << (8 * i);
+        litLen += 1;
+      }
+      input.copy(out, op, ip, ip + litLen);
+      ip += litLen;
+      op += litLen;
+    } else {
+      let copyLen;
+      let offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = (input[ip] | (input[ip + 1] << 8) | (input[ip + 2] << 16) | (input[ip + 3] << 24)) >>> 0;
+        ip += 4;
+      }
+      for (let k = 0; k < copyLen; k++) out[op + k] = out[op - offset + k];
+      op += copyLen;
+    }
+  }
