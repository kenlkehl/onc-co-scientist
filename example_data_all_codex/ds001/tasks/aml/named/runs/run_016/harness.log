+function riskDiff(exposure, outcome) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < outcome.length; i++) {
+    if (exposure[i] === 1) {
+      n1++;
+      s1 += outcome[i];
+    } else {
+      n0++;
+      s0 += outcome[i];
+    }
+  }
+  const p1 = s1 / n1;
+  const p0 = s0 / n0;
+  const effect = p1 - p0;
+  const pooled = (s1 + s0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
