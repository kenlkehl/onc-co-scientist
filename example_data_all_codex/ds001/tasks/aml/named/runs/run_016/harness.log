+  const covarNames = adjustmentCovars.filter((n) => n !== featureName && !exclude.includes(n));
+  const names = [featureName, ...covarNames];
+  const fit = ols(y, [data[featureName], ...covarNames.map((n) => data[n])], names);
+  return fit[featureName];
+}
