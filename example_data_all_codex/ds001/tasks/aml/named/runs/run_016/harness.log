+  const names = ["treatment", "subgroup", "interaction", ...covarNames];
+  const cols = [treatment, biomarker, interaction, ...covarNames.map((n) => data[n])];
+  const fit = ols(y, cols, names);
+  return { effect: fit.interaction.coef, p_value: fit.interaction.p_value, fit };
