+
+function decodeColumn(column) {
+  const m = column.meta_data;
+  const dictHeader = readPageHeader(m.dictionary_page_offset);
+  const dict = plainDecodeDictionary(pageData(dictHeader), m.type, dictHeader.dictionary_page_header.num_values);
+  const vals = [];
+  let offset = m.data_page_offset;
+  while (vals.length < m.num_values) {
+    const h = readPageHeader(offset);
+    if (h.type !== 0) throw new Error(`Unsupported page type ${h.type} for ${m.path.join(".")}`);
+    const body = pageData(h);
+    const n = h.data_page_header.num_values;
+    const def = hybridDecode(body, 0, n, 1);
+    let pos = def.offset;
+    const bitWidth = body[pos++];
+    const indexes = hybridDecode(body, pos, n, bitWidth).vals;
+    for (let i = 0; i < n; i++) vals.push(dict[indexes[i]]);
