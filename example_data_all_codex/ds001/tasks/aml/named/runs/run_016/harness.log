+}
+
+function pageData(header) {
+  const compressed = parquet.subarray(header.headerEnd, header.headerEnd + header.compressed_page_size);
+  return snappyUncompress(compressed);
+}
+
+function plainDecodeDictionary(data, type, n) {
+  const vals = [];
+  let offset = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === 5) {
+      vals.push(data.readDoubleLE(offset));
+      offset += 8;
+    } else if (type === 2) {
+      vals.push(Number(data.readBigInt64LE(offset)));
+      offset += 8;
+    } else if (type === 6) {
+      const len = data.readInt32LE(offset);
+      offset += 4;
+      vals.push(data.subarray(offset, offset + len).toString("utf8"));
+      offset += len;
+    } else {
+      throw new Error(`Unsupported physical type ${type}`);
