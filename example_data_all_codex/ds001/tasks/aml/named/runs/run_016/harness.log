+}
+
+const y = data.objective_response;
+data.age_years_ge_70 = data.age_years.map((v) => (v >= 70 ? 1 : 0));
+data.ecog_ps_eq_2 = data.ecog_ps.map((v) => (v === 2 ? 1 : 0));
