+
+function levelDiff(values, high, low, outcome) {
+  let nHigh = 0;
+  let nLow = 0;
+  let sHigh = 0;
+  let sLow = 0;
+  for (let i = 0; i < outcome.length; i++) {
+    if (values[i] === high) {
+      nHigh++;
+      sHigh += outcome[i];
+    } else if (values[i] === low) {
+      nLow++;
+      sLow += outcome[i];
+    }
+  }
