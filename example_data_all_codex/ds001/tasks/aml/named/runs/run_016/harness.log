+function mean(arr, indexes = null) {
+  let s = 0;
+  let n = 0;
+  if (indexes) {
+    for (const i of indexes) {
+      s += arr[i];
+      n++;
+    }
+  } else {
+    for (const v of arr) {
+      s += v;
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let s = 0;
+  for (const v of arr) {
+    const d = v - m;
+    s += d * d;
+  }
+  return Math.sqrt(s / (arr.length - 1));
