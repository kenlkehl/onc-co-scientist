+const fs = require("fs");
+
+const FILE = fs.readFileSync("dataset.parquet");
+const T = { STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6, DOUBLE: 7, BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12 };
+
+function makeReader(buf, start = 0) {
+  let pos = start;
+  function readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const byte = buf[pos++];
+      out |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) return out;
+      shift += 7n;
+    }
+  }
+  function zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  function readI32() { return zigzag(readVarint()); }
+  function readI64() {
+    const n = readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  function readBinary() {
+    const len = Number(readVarint());
+    const out = buf.subarray(pos, pos + len);
+    pos += len;
+    return out;
+  }
+  function readDouble() {
+    const out = buf.readDoubleLE(pos);
+    pos += 8;
+    return out;
+  }
+  function readListHeader() {
+    const header = buf[pos++];
+    let size = header >> 4;
+    const elemType = header & 0x0f;
+    if (size === 15) size = Number(readVarint());
+    return { size, elemType };
+  }
+  function skip(type) {
+    switch (type) {
+      case T.TRUE:
+      case T.FALSE:
+        return;
+      case T.BYTE:
+        pos += 1;
+        return;
+      case T.I16:
+      case T.I32:
+        readI32();
+        return;
+      case T.I64:
+        readI64();
+        return;
+      case T.DOUBLE:
+        readDouble();
+        return;
+      case T.BINARY:
+        readBinary();
+        return;
+      case T.LIST:
+      case T.SET: {
+        const { size, elemType } = readListHeader();
+        for (let i = 0; i < size; i++) skip(elemType);
+        return;
+      }
+      case T.MAP: {
+        const size = Number(readVarint());
+        if (size === 0) return;
+        const header = buf[pos++];
+        const keyType = header >> 4;
+        const valType = header & 0x0f;
+        for (let i = 0; i < size; i++) {
+          skip(keyType);
+          skip(valType);
+        }
+        return;
+      }
+      case T.STRUCT: {
+        let lastField = 0;
+        while (true) {
+          const header = buf[pos++];
+          const fieldType = header & 0x0f;
+          if (fieldType === T.STOP) return;
+          const delta = header >> 4;
+          lastField = delta ? lastField + delta : readI32();
+          skip(fieldType);
+        }
+      }
+      default:
+        throw new Error(`unsupported thrift type ${type} at ${pos}`);
+    }
+  }
+  function readStruct(handler) {
+    let lastField = 0;
+    const out = {};
+    while (true) {
+      const header = buf[pos++];
+      const fieldType = header & 0x0f;
+      if (fieldType === T.STOP) return out;
