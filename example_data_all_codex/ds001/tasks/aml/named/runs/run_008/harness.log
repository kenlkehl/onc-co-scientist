+  if (b) {
+    const out = Array(k).fill(0);
+    for (let i = 0; i < n; i++) for (let j = 0; j < k; j++) out[j] += A[i][j] * b[i];
+    return out;
+  }
+  const out = Array.from({ length: k }, () => Array(k).fill(0));
+  for (let i = 0; i < n; i++) {
+    const row = A[i];
+    for (let j = 0; j < k; j++) for (let l = 0; l < k; l++) out[j][l] += row[j] * row[l];
+  }
+  return out;
+}
+
+function invert(mat) {
+  const n = mat.length;
+  const a = mat.map((row, i) => [...row, ...Array.from({ length: n }, (_, j) => i === j ? 1 : 0)]);
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(a[r][i]) > Math.abs(a[pivot][i])) pivot = r;
+    if (Math.abs(a[pivot][i]) < 1e-12) throw new Error("singular matrix");
+    [a[i], a[pivot]] = [a[pivot], a[i]];
+    const div = a[i][i];
+    for (let c = 0; c < 2 * n; c++) a[i][c] /= div;
+    for (let r = 0; r < n; r++) if (r !== i) {
+      const f = a[r][i];
+      for (let c = 0; c < 2 * n; c++) a[r][c] -= f * a[i][c];
+    }
+  }
+  return a.map(row => row.slice(n));
+}
+
+function matVec(M, v) {
+  return M.map(row => row.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function ols(y, rows, names) {
+  const X = rows;
+  const xtx = transposeTimes(X);
+  const inv = invert(xtx);
+  const xty = transposeTimes(X, y);
+  const beta = matVec(inv, xty);
+  const n = y.length, k = beta.length;
+  const meat = Array.from({ length: k }, () => Array(k).fill(0));
+  for (let i = 0; i < n; i++) {
+    let fit = 0;
+    for (let j = 0; j < k; j++) fit += X[i][j] * beta[j];
+    const e2 = (y[i] - fit) ** 2;
+    for (let j = 0; j < k; j++) for (let l = 0; l < k; l++) meat[j][l] += X[i][j] * X[i][l] * e2;
+  }
+  const tmp = inv.map(row => meat[0].map((_, j) => row.reduce((s, x, l) => s + x * meat[l][j], 0)));
+  const cov = tmp.map(row => inv[0].map((_, j) => row.reduce((s, x, l) => s + x * inv[l][j], 0) * n / (n - k)));
