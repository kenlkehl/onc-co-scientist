+    const term = fit2.find(r => r.name === label);
+    console.log(label, "beta", fmt(term.beta), "se", fmt(term.se), "p", fmt(term.p, 6), "unadj_did", fmt(interactionDid(y, data[a], data[b]).effect));
+  }
+}
