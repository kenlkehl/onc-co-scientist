+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(a[r][i]) > Math.abs(a[pivot][i])) pivot = r;
+    if (Math.abs(a[pivot][i]) < 1e-12) throw new Error("singular matrix");
+    [a[i], a[pivot]] = [a[pivot], a[i]];
+    const div = a[i][i];
+    for (let c = 0; c < 2 * n; c++) a[i][c] /= div;
+    for (let r = 0; r < n; r++) if (r !== i) {
