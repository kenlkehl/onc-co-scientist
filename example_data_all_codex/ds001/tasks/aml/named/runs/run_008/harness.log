index 0000000000000000000000000000000000000000..652fd7fbe534766f80424bdc2ae638dcfac59e14
--- /dev/null
+++ b/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/aml/named/analysis_work.js
@@ -0,0 +1,620 @@
+const fs = require("fs");
+
+const FILE = fs.readFileSync("dataset.parquet");
+const T = { STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6, DOUBLE: 7, BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12 };
+
+function makeReader(buf, start = 0) {
+  let pos = start;
+  function readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const byte = buf[pos++];
+      out |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) return out;
+      shift += 7n;
+    }
+  }
+  function zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  function readI32() { return zigzag(readVarint()); }
+  function readI64() {
+    const n = readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  function readBinary() {
+    const len = Number(readVarint());
+    const out = buf.subarray(pos, pos + len);
+    pos += len;
+    return out;
+  }
+  function readDouble() {
+    const out = buf.readDoubleLE(pos);
+    pos += 8;
+    return out;
+  }
+  function readListHeader() {
+    const header = buf[pos++];
+    let size = header >> 4;
+    const elemType = header & 0x0f;
+    if (size === 15) size = Number(readVarint());
+    return { size, elemType };
+  }
+  function skip(type) {
+    switch (type) {
+      case T.TRUE:
+      case T.FALSE:
+        return;
+      case T.BYTE:
+        pos += 1;
