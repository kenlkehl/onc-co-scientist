+    else if (fid === 4) {
+      const lh = r.readListHeader();
+      out.row_groups = [];
+      for (let i = 0; i < lh.size; i++) out.row_groups.push(rowGroup());
+    } else if (fid === 6) out.created_by = r.readBinary().toString();
+    else r.skip(type);
+  });
+}
+
+function parsePageHeader(offset) {
+  const r = makeReader(FILE, offset);
+  function dataPageHeader() {
+    return r.readStruct((fid, type, out) => {
+      if (fid === 1) out.num_values = r.readI32();
+      else if (fid === 2) out.encoding = r.readI32();
+      else if (fid === 3) out.definition_level_encoding = r.readI32();
+      else if (fid === 4) out.repetition_level_encoding = r.readI32();
+      else r.skip(type);
+    });
+  }
+  function dictionaryPageHeader() {
+    return r.readStruct((fid, type, out) => {
+      if (fid === 1) out.num_values = r.readI32();
+      else if (fid === 2) out.encoding = r.readI32();
+      else if (fid === 3) out.is_sorted = type === T.TRUE;
+      else r.skip(type);
+    });
+  }
+  const out = r.readStruct((fid, type, obj) => {
+    if (fid === 1) obj.type = r.readI32();
+    else if (fid === 2) obj.uncompressed_page_size = r.readI32();
+    else if (fid === 3) obj.compressed_page_size = r.readI32();
+    else if (fid === 5) obj.data_page_header = dataPageHeader();
+    else if (fid === 7) obj.dictionary_page_header = dictionaryPageHeader();
+    else r.skip(type);
