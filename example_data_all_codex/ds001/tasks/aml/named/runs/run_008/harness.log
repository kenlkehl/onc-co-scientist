+    const adjusters = [
+      ["age_decade", i => data.age_years[i] / 10],
+      ["ecog_ps", i => data.ecog_ps[i]],
+      ["secondary_aml", i => data.secondary_aml[i]],
+      ["complex_karyotype", i => data.complex_karyotype[i]],
+      ["tp53_mutation", i => data.tp53_mutation[i]],
+      ["npm1_mutation", i => data.npm1_mutation[i]],
+      ["unfit_for_intensive", i => data.unfit_for_intensive[i]],
