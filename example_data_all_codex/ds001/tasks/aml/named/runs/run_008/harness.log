+  out.body_offset = r.pos;
+  return out;
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let shift = 0;
+  let expected = 0;
+  while (true) {
+    const b = input[pos++];
+    expected |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(expected);
+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let lenCode = tag >> 2;
+      let len;
+      if (lenCode < 60) len = lenCode + 1;
+      else {
+        const bytes = lenCode - 59;
+        len = 1;
+        let raw = 0;
+        for (let i = 0; i < bytes; i++) raw |= input[pos++] << (8 * i);
+        len = raw + 1;
+      }
+      input.copy(out, outPos, pos, pos + len);
+      pos += len;
+      outPos += len;
+    } else {
+      let len, offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = input.readUInt32LE(pos);
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) out[outPos + i] = out[outPos - offset + i];
+      outPos += len;
+    }
+  }
+  if (outPos !== expected) throw new Error(`snappy size mismatch ${outPos} != ${expected}`);
+  return out;
+}
+
+function decodePlain(buf, type, count) {
+  const out = new Array(count);
+  let pos = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === 2) {
+      out[i] = Number(buf.readBigInt64LE(pos));
+      pos += 8;
+    } else if (type === 5) {
+      out[i] = buf.readDoubleLE(pos);
+      pos += 8;
+    } else if (type === 6) {
+      const len = buf.readInt32LE(pos);
+      pos += 4;
+      out[i] = buf.subarray(pos, pos + len).toString();
+      pos += len;
+    } else {
+      throw new Error(`unsupported plain type ${type}`);
+    }
+  }
+  return out;
+}
+
+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let out = 0;
+  while (true) {
+    const b = buf[state.pos++];
+    out |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) return out;
+    shift += 7;
+  }
+}
+
+function decodeRleBitpacked(buf, state, bitWidth, count) {
+  const out = [];
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (out.length < count) {
+    const header = readVarintFrom(buf, state);
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      let value = 0;
+      for (let i = 0; i < valueBytes; i++) value |= buf[state.pos++] << (8 * i);
+      for (let i = 0; i < runLen && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const bytes = groups * bitWidth;
+      let bitPos = 0;
+      const total = groups * 8;
+      for (let i = 0; i < total; i++) {
+        let value = 0;
+        for (let bit = 0; bit < bitWidth; bit++) {
+          const byte = buf[state.pos + (bitPos >> 3)];
+          value |= ((byte >> (bitPos & 7)) & 1) << bit;
+          bitPos++;
+        }
+        if (out.length < count) out.push(value);
+      }
+      state.pos += bytes;
+    }
+  }
+  return out;
+}
+
+function readColumn(col) {
+  const meta = col.meta_data;
+  let offset = meta.dictionary_page_offset ?? meta.data_page_offset;
+  let remaining = meta.total_compressed_size;
+  let dictionary = null;
+  const values = [];
+  while (remaining > 0 && values.length < meta.num_values) {
+    const header = parsePageHeader(offset);
+    const compressed = FILE.subarray(header.body_offset, header.body_offset + header.compressed_page_size);
+    const page = meta.codec === 1 ? snappyUncompress(compressed) : Buffer.from(compressed);
+    if (page.length !== header.uncompressed_page_size) {
+      throw new Error(`${meta.path_in_schema.join(".")} page length mismatch`);
+    }
+    if (header.type === 2) {
+      dictionary = decodePlain(page, meta.type, header.dictionary_page_header.num_values);
+    } else if (header.type === 0) {
+      if (!dictionary) throw new Error(`missing dictionary for ${meta.path_in_schema.join(".")}`);
+      const numValues = header.data_page_header.num_values;
+      const state = { pos: 0 };
+      decodeRleBitpacked(page, state, 1, numValues);
+      const bitWidth = page[state.pos++];
+      const indexes = decodeRleBitpacked(page, state, bitWidth, numValues);
+      for (const idx of indexes) values.push(dictionary[idx]);
+    } else {
+      throw new Error(`unsupported page type ${header.type}`);
+    }
+    const used = header.header_len + header.compressed_page_size;
+    offset = header.body_offset + header.compressed_page_size;
+    remaining -= used;
+  }
+  if (values.length !== meta.num_values) {
+    throw new Error(`${meta.path_in_schema.join(".")} decoded ${values.length}, expected ${meta.num_values}`);
+  }
+  return values;
+}
+
+function loadData() {
+  const meta = parseFooter();
+  const cols = meta.row_groups[0].columns;
+  const data = {};
+  for (const col of cols) {
+    const name = col.meta_data.path_in_schema[0];
+    data[name] = readColumn(col);
+  }
+  return { meta, data };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741, a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
