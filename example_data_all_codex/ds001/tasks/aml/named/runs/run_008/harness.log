index 0000000000000000000000000000000000000000..652fd7fbe534766f80424bdc2ae638dcfac59e14
--- /dev/null
+++ b/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/aml/named/analysis_work.js
@@ -0,0 +1,620 @@
+const fs = require("fs");
+
+const FILE = fs.readFileSync("dataset.parquet");
+const T = { STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6, DOUBLE: 7, BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12 };
+
+function makeReader(buf, start = 0) {
+  let pos = start;
+  function readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const byte = buf[pos++];
+      out |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) return out;
+      shift += 7n;
+    }
+  }
+  function zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  function readI32() { return zigzag(readVarint()); }
+  function readI64() {
+    const n = readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  function readBinary() {
+    const len = Number(readVarint());
+    const out = buf.subarray(pos, pos + len);
+    pos += len;
+    return out;
+  }
+  function readDouble() {
+    const out = buf.readDoubleLE(pos);
+    pos += 8;
+    return out;
+  }
+  function readListHeader() {
+    const header = buf[pos++];
+    let size = header >> 4;
+    const elemType = header & 0x0f;
+    if (size === 15) size = Number(readVarint());
+    return { size, elemType };
+  }
+  function skip(type) {
+    switch (type) {
+      case T.TRUE:
+      case T.FALSE:
+        return;
+      case T.BYTE:
+        pos += 1;
+        return;
+      case T.I16:
+      case T.I32:
+        readI32();
+        return;
+      case T.I64:
+        readI64();
+        return;
+      case T.DOUBLE:
+        readDouble();
+        return;
+      case T.BINARY:
+        readBinary();
+        return;
+      case T.LIST:
+      case T.SET: {
+        const { size, elemType } = readListHeader();
+        for (let i = 0; i < size; i++) skip(elemType);
+        return;
+      }
+      case T.MAP: {
+        const size = Number(readVarint());
+        if (size === 0) return;
+        const header = buf[pos++];
+        const keyType = header >> 4;
+        const valType = header & 0x0f;
+        for (let i = 0; i < size; i++) {
+          skip(keyType);
+          skip(valType);
+        }
+        return;
+      }
+      case T.STRUCT: {
+        let lastField = 0;
+        while (true) {
+          const header = buf[pos++];
+          const fieldType = header & 0x0f;
+          if (fieldType === T.STOP) return;
+          const delta = header >> 4;
+          lastField = delta ? lastField + delta : readI32();
+          skip(fieldType);
+        }
+      }
+      default:
+        throw new Error(`unsupported thrift type ${type} at ${pos}`);
+    }
+  }
+  function readStruct(handler) {
+    let lastField = 0;
+    const out = {};
+    while (true) {
+      const header = buf[pos++];
+      const fieldType = header & 0x0f;
+      if (fieldType === T.STOP) return out;
+      const delta = header >> 4;
+      const fieldId = delta ? lastField + delta : readI32();
+      lastField = fieldId;
+      handler(fieldId, fieldType, out);
+    }
+  }
+  return { get pos() { return pos; }, readI32, readI64, readBinary, readListHeader, readStruct, skip };
+}
+
+function parseFooter() {
+  if (FILE.subarray(0, 4).toString() !== "PAR1" || FILE.subarray(FILE.length - 4).toString() !== "PAR1") {
+    throw new Error("not a Parquet file");
+  }
+  const footerLen = FILE.readUInt32LE(FILE.length - 8);
+  const footerStart = FILE.length - 8 - footerLen;
+  const r = makeReader(FILE.subarray(footerStart, FILE.length - 8));
+
+  function schemaElement() {
+    return r.readStruct((fid, type, out) => {
+      if (fid === 1) out.type = r.readI32();
+      else if (fid === 3) out.repetition_type = r.readI32();
+      else if (fid === 4) out.name = r.readBinary().toString();
+      else if (fid === 5) out.num_children = r.readI32();
+      else r.skip(type);
+    });
+  }
+  function columnMetaData() {
+    return r.readStruct((fid, type, out) => {
+      if (fid === 1) out.type = r.readI32();
+      else if (fid === 2) {
+        const lh = r.readListHeader();
+        out.encodings = [];
+        for (let i = 0; i < lh.size; i++) out.encodings.push(r.readI32());
+      } else if (fid === 3) {
+        const lh = r.readListHeader();
+        out.path_in_schema = [];
+        for (let i = 0; i < lh.size; i++) out.path_in_schema.push(r.readBinary().toString());
+      } else if (fid === 4) out.codec = r.readI32();
+      else if (fid === 5) out.num_values = Number(r.readI64());
+      else if (fid === 6) out.total_uncompressed_size = Number(r.readI64());
+      else if (fid === 7) out.total_compressed_size = Number(r.readI64());
+      else if (fid === 9) out.data_page_offset = Number(r.readI64());
+      else if (fid === 11) out.dictionary_page_offset = Number(r.readI64());
+      else r.skip(type);
+    });
+  }
+  function columnChunk() {
+    return r.readStruct((fid, type, out) => {
+      if (fid === 3) out.meta_data = columnMetaData();
+      else r.skip(type);
+    });
+  }
+  function rowGroup() {
+    return r.readStruct((fid, type, out) => {
+      if (fid === 1) {
+        const lh = r.readListHeader();
+        out.columns = [];
+        for (let i = 0; i < lh.size; i++) out.columns.push(columnChunk());
+      } else if (fid === 3) out.num_rows = Number(r.readI64());
+      else r.skip(type);
+    });
+  }
+  return r.readStruct((fid, type, out) => {
+    if (fid === 1) out.version = r.readI32();
+    else if (fid === 2) {
+      const lh = r.readListHeader();
+      out.schema = [];
+      for (let i = 0; i < lh.size; i++) out.schema.push(schemaElement());
+    } else if (fid === 3) out.num_rows = Number(r.readI64());
+    else if (fid === 4) {
+      const lh = r.readListHeader();
+      out.row_groups = [];
+      for (let i = 0; i < lh.size; i++) out.row_groups.push(rowGroup());
