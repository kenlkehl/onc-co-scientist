+
+function main() {
+  const { meta, data } = loadData();
+  const y = data.objective_response;
+  console.log("rows", meta.num_rows, "cols", Object.keys(data).length, "response", fmt(mean(y)));
+  const treatmentCols = Object.keys(data).filter(c => c.startsWith("treatment_"));
+  const binaryCols = Object.keys(data).filter(c => c !== "patient_id" && c !== "objective_response" && new Set(data[c]).size === 2);
+  const nonBinaryCols = Object.keys(data).filter(c => c !== "patient_id" && c !== "objective_response" && new Set(data[c]).size > 2);
+  console.log("treatments");
+  for (const c of treatmentCols) console.log(c, data[c].reduce((s, v) => s + v, 0), fmt(rdBinary(y, data[c]).effect), fmt(rdBinary(y, data[c]).p, 6));
