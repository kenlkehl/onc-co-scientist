+}
+
+function quartiles(x) {
+  const xs = [...x].sort((a, b) => a - b);
+  const q = (p) => xs[Math.floor((xs.length - 1) * p)];
+  return { q1: q(0.25), med: q(0.5), q3: q(0.75) };
+}
+
+function transposeTimes(A, b = null) {
