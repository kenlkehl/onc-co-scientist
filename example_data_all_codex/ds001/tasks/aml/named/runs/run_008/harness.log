+    let fit = 0;
+    for (let j = 0; j < k; j++) fit += X[i][j] * beta[j];
+    const e2 = (y[i] - fit) ** 2;
+    for (let j = 0; j < k; j++) for (let l = 0; l < k; l++) meat[j][l] += X[i][j] * X[i][l] * e2;
+  }
+  const tmp = inv.map(row => meat[0].map((_, j) => row.reduce((s, x, l) => s + x * meat[l][j], 0)));
+  const cov = tmp.map(row => inv[0].map((_, j) => row.reduce((s, x, l) => s + x * inv[l][j], 0) * n / (n - k)));
