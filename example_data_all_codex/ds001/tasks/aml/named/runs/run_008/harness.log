+    let lastField = 0;
+    const out = {};
+    while (true) {
+      const header = buf[pos++];
+      const fieldType = header & 0x0f;
+      if (fieldType === T.STOP) return out;
+      const delta = header >> 4;
+      const fieldId = delta ? lastField + delta : readI32();
+      lastField = fieldId;
+      handler(fieldId, fieldType, out);
+    }
+  }
+  return { get pos() { return pos; }, readI32, readI64, readBinary, readListHeader, readStruct, skip };
+}
+
+function parseFooter() {
+  if (FILE.subarray(0, 4).toString() !== "PAR1" || FILE.subarray(FILE.length - 4).toString() !== "PAR1") {
+    throw new Error("not a Parquet file");
+  }
+  const footerLen = FILE.readUInt32LE(FILE.length - 8);
+  const footerStart = FILE.length - 8 - footerLen;
+  const r = makeReader(FILE.subarray(footerStart, FILE.length - 8));
+
+  function schemaElement() {
+    return r.readStruct((fid, type, out) => {
+      if (fid === 1) out.type = r.readI32();
+      else if (fid === 3) out.repetition_type = r.readI32();
+      else if (fid === 4) out.name = r.readBinary().toString();
+      else if (fid === 5) out.num_children = r.readI32();
