+function mean(arr, mask = null) {
+  let s = 0, n = 0;
+  for (let i = 0; i < arr.length; i++) if (!mask || mask(i)) { s += arr[i]; n++; }
+  return s / n;
+}
+
+function rdBinary(y, x, positive = 1) {
+  let n1 = 0, n0 = 0, y1 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === positive) { n1++; y1 += y[i]; }
+    else { n0++; y0 += y[i]; }
+  }
+  const p1 = y1 / n1, p0 = y0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  return { n1, n0, p1, p0, effect, se, z: effect / se, p: pFromZ(effect / se) };
+}
+
+function rdMask(y, m1, m0) {
+  let n1 = 0, n0 = 0, y1 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (m1(i)) { n1++; y1 += y[i]; }
+    else if (m0(i)) { n0++; y0 += y[i]; }
+  }
+  const p1 = y1 / n1, p0 = y0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt(p1 * (1 - p1) / n1 + p0 * (1 - p0) / n0);
+  return { n1, n0, p1, p0, effect, se, z: effect / se, p: pFromZ(effect / se) };
+}
+
+function interactionDid(y, a, b) {
+  const cells = {};
+  for (const av of [0, 1]) for (const bv of [0, 1]) cells[`${av}${bv}`] = { n: 0, s: 0 };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${a[i] ? 1 : 0}${b[i] ? 1 : 0}`;
+    cells[key].n++;
+    cells[key].s += y[i];
+  }
+  for (const k of Object.keys(cells)) cells[k].p = cells[k].s / cells[k].n;
+  const effect = (cells["11"].p - cells["01"].p) - (cells["10"].p - cells["00"].p);
+  const se = Math.sqrt(Object.values(cells).reduce((s, c) => s + c.p * (1 - c.p) / c.n, 0));
