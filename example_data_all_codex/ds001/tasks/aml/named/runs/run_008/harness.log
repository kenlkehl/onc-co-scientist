+function makeReader(buf, start = 0) {
+  let pos = start;
+  function readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const byte = buf[pos++];
+      out |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) return out;
+      shift += 7n;
+    }
