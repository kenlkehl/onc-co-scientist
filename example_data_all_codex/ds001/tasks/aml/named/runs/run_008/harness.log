+    "treatment_midostaurin","treatment_gilteritinib","treatment_ivosidenib","treatment_enasidenib","treatment_venetoclax_azacitidine","treatment_7plus3",
+    "flt3_itd","flt3_tkd","idh1_mutation","idh2_mutation","npm1_mutation","tp53_mutation","complex_karyotype","secondary_aml","unfit_for_intensive",
+    "sex_female","diabetes_mellitus","chronic_kidney_disease","heart_failure"
+  ];
+  const contCovars = [
+    ["age_decade", i => data.age_years[i] / 10],
+    ["ecog_ps", i => data.ecog_ps[i]],
+    ["albumin_g_dl", i => data.albumin_g_dl[i]],
+    ["log_wbc_k_per_ul", i => Math.log1p(data.wbc_k_per_ul[i])],
+    ["blast_pct_10", i => data.blast_pct_marrow[i] / 10],
+    ["weight_loss_pct_6mo", i => data.weight_loss_pct_6mo[i]],
+    ["log_crp_mg_l", i => Math.log1p(data.crp_mg_l[i])],
+    ["log_ldh_u_l", i => Math.log1p(data.ldh_u_l[i])]
+  ];
+  const names = ["intercept", ...covars, ...contCovars.map(x => x[0])];
+  const rows = y.map((_, i) => [1, ...covars.map(c => data[c][i]), ...contCovars.map(([, f]) => f(i))]);
+  const fit = ols(y, rows, names);
+  for (const r of fit.filter(r => r.name !== "intercept").sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta)).slice(0, 35)) {
+    console.log(r.name, "beta", fmt(r.beta), "se", fmt(r.se), "p", fmt(r.p, 6));
+  }
+  console.log("\\nSelected adjusted interactions");
+  const adjustedSpecs = [
+    ["midostaurin_x_flt3_itd", "treatment_midostaurin", "flt3_itd"],
+    ["gilteritinib_x_flt3_itd", "treatment_gilteritinib", "flt3_itd"],
+    ["ivosidenib_x_idh1_mutation", "treatment_ivosidenib", "idh1_mutation"],
+    ["enasidenib_x_idh2_mutation", "treatment_enasidenib", "idh2_mutation"],
+    ["ven_aza_x_unfit", "treatment_venetoclax_azacitidine", "unfit_for_intensive"],
+    ["7plus3_x_unfit", "treatment_7plus3", "unfit_for_intensive"],
+    ["npm1_x_flt3_itd", "npm1_mutation", "flt3_itd"],
+    ["tp53_x_complex", "tp53_mutation", "complex_karyotype"],
+    ["secondary_x_tp53", "secondary_aml", "tp53_mutation"]
+  ];
+  for (const [label, a, b] of adjustedSpecs) {
+    const base = ["intercept", a, b, label, "age_decade", "ecog_ps", "secondary_aml", "complex_karyotype", "tp53_mutation", "unfit_for_intensive"];
+    const rowFun = (i) => [1, data[a][i], data[b][i], data[a][i] * data[b][i], data.age_years[i] / 10, data.ecog_ps[i], data.secondary_aml[i], data.complex_karyotype[i], data.tp53_mutation[i], data.unfit_for_intensive[i]];
