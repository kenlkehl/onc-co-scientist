  return `Adjusted linear probability coefficient per 1-SD increase in ${name} was ${fmt(res.coef, 5)} (${direction}; p=${ptxt(res.p)}).`;
}
function interactionSummary(term, res) {
  return `In a joint interaction linear probability model, the ${term} interaction coefficient was ${fmt(res.coef, 5)}, indicating a smaller enzalutamide-associated response difference in that subgroup (p=${ptxt(res.p)}).`;
}
function stratSummary(t, m, res, expected) {
  return `Among patients with ${m}=1, response was ${fmt(res.p1)} with ${t}=1 (n=${res.n1}) versus ${fmt(res.p0)} with ${t}=0 (n=${res.n0}); the difference was ${fmt(res.coef, 5)} (${expected}; p=${ptxt(res.p)}).`;
}

