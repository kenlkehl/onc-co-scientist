import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('missing', int(df.isna().sum().sum()))
print('outcome mean', df['objective_response'].mean(), 'sum', int(df['objective_response'].sum()))
print('\\nTreatment prevalences and response rates:')
for c in [x for x in df.columns if x.startswith('treatment_')]:
    m=df[c].mean(); n=int(df[c].sum())
    r1=df.loc[df[c]==1,'objective_response'].mean(); r0=df.loc[df[c]==0,'objective_response'].mean()
    print(c, 'n',n,'prev',round(m,4),'resp1',round(r1,4),'resp0',round(r0,4),'diff',round(r1-r0,4))
print('\\nBinary feature prevalences and response diffs:')
binary=[]
for c in df.columns:
    vals=set(df[c].unique())
    if vals.issubset({0,1}) and c"'!='"'objective_response' and not c.startswith('treatment_'):
        binary.append(c)
for c in binary:
    n=int(df[c].sum());
    if n and n<len(df):
        r1=df.loc[df[c]==1,'objective_response'].mean(); r0=df.loc[df[c]==0,'objective_response'].mean()
        print(c, 'n',n,'prev',round(df[c].mean(),4),'resp1',round(r1,4),'resp0',round(r0,4),'diff',round(r1-r0,4))
print('\\nContinuous correlations with objective_response:')
cont=[c for c in df.columns if c not in binary and not c.startswith('treatment_') and c"'!='"'objective_response']
for c in cont:
    corr=np.corrcoef(df[c], df['objective_response'])[0,1]
    q0=df.loc[df.objective_response==0,c].mean(); q1=df.loc[df.objective_response==1,c].mean()
    print(c, 'corr',round(corr,4),'mean_resp',round(q1,3),'mean_no',round(q0,3),'diff',round(q1-q0,3))
