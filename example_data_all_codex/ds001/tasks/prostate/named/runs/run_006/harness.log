const fs = require('fs');
const t = JSON.parse(fs.readFileSync('transcript.json', 'utf8'));
const errors = [];
for (const k of ['dataset_id','model_id','harness_id','max_iterations','iterations']) if ("'!(k in t)) errors.push(`missing ${k}`);
if (t.max_iterations !== 25) errors.push('"'max_iterations is not 25');
if ("'!Array.isArray(t.iterations) || t.iterations.length !== 25) errors.push('"'iterations length is not 25');
let analyses = 0;
for (const [i,it] of (t.iterations || []).entries()) {
  if (it.index "'!== i + 1) errors.push(`bad index ${i+1}`);
  if (!Array.isArray(it.proposed_hypotheses) || it.proposed_hypotheses.length === 0) errors.push(`missing hypotheses ${i+1}`);
  for (const h of it.proposed_hypotheses || []) if (!h.id || !h.text) errors.push(`bad hypothesis ${i+1}`);
  for (const a of it.analyses || []) {
    analyses++;
    if (!Array.isArray(a.hypothesis_ids) || a.hypothesis_ids.length === 0) errors.push(`bad analysis ids ${i+1}`);
    if (typeof a.result_summary !== '"'string') errors.push("'`bad summary ${i+1}`);
    if (a.effect_estimate === undefined) errors.push(`missing effect ${i+1}`);
    if (a.p_value === undefined && a.significant === undefined) errors.push(`missing p/sig ${i+1}`);
  }
}
