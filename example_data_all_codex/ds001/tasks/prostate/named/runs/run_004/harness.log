+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.b = buf;
+    this.o = offset;
+    this.last = 0;
+  }
+  u8() {
+    return this.b[this.o++];
+  }
+  varint() {
+    let shift = 0;
+    let n = 0n;
+    while (true) {
+      const c = this.u8();
+      n |= BigInt(c & 0x7f) << BigInt(shift);
+      if ((c & 0x80) === 0) break;
+      shift += 7;
+    }
+    return n;
+  }
+  zigzag() {
+    const n = this.varint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  str() {
+    const n = Number(this.varint());
+    const s = this.b.subarray(this.o, this.o + n).toString();
+    this.o += n;
+    return s;
+  }
+  dbl() {
+    const v = this.b.readDoubleLE(this.o);
+    this.o += 8;
+    return v;
+  }
+  value(type, spec) {
+    if (type === 1) return true;
+    if (type === 2) return false;
+    if (type === 3) return this.u8();
+    if (type === 4 || type === 5 || type === 6) return this.zigzag();
+    if (type === 7) return this.dbl();
+    if (type === 8) return this.str();
+    if (type === 12) return this.struct(spec || {});
+    if (type === 9 || type === 10) {
+      const h = this.u8();
+      let n = h >> 4;
+      const et = h & 15;
+      if (n === 15) n = Number(this.varint());
+      const a = [];
+      for (let i = 0; i < n; i++) a.push(this.value(et, spec && spec.elem));
+      return a;
+    }
+    if (type === 11) {
+      const h = this.u8();
+      const kt = h >> 4;
+      const vt = h & 15;
+      const n = Number(this.varint());
+      const a = [];
+      for (let i = 0; i < n; i++) a.push([this.value(kt), this.value(vt)]);
+      return a;
+    }
+    throw new Error(`Unsupported compact type ${type} at ${this.o}`);
+  }
+  struct(spec) {
+    const out = {};
+    const saved = this.last;
+    this.last = 0;
+    while (true) {
+      const h = this.u8();
+      if (h === 0) break;
+      const type = h & 15;
+      const delta = h >> 4;
+      const fid = delta ? this.last + delta : this.zigzag();
+      this.last = fid;
+      const fspec = spec[fid];
+      out[fspec ? fspec.name : String(fid)] = this.value(type, fspec && fspec.spec);
+    }
