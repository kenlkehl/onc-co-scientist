+function ols(cols, y) {
+  const n = y.length;
+  const p = cols.length;
+  const XtX = Array.from({ length: p }, () => Array(p).fill(0));
+  const Xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = cols[a][i];
+      Xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) XtX[a][b] += xa * cols[b][i];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) XtX[b][a] = XtX[a][b];
+  const inv = invert(XtX);
+  const beta = Array(p).fill(0);
+  for (let a = 0; a < p; a++) for (let b = 0; b < p; b++) beta[a] += inv[a][b] * Xty[b];
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let a = 0; a < p; a++) pred += beta[a] * cols[a][i];
+    const e2 = (y[i] - pred) * (y[i] - pred);
+    for (let a = 0; a < p; a++) {
+      const xa = cols[a][i];
+      for (let b = 0; b <= a; b++) meat[a][b] += xa * cols[b][i] * e2;
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) meat[b][a] = meat[a][b];
+  const cov = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) {
+      for (let c = 0; c < p; c++) {
+        for (let d = 0; d < p; d++) cov[a][b] += inv[a][c] * meat[c][d] * inv[d][b];
+      }
+    }
+  }
+  const scale = n / (n - p);
+  const se = beta.map((_, i) => Math.sqrt(Math.max(0, cov[i][i] * scale)));
+  return { beta, se, p_value: beta.map((v, i) => pNormal(v / se[i])) };
+}
+
+function loadDataset() {
+  const buf = fs.readFileSync("dataset.parquet");
+  const meta = readMeta(buf);
+  const names = meta.schema.slice(1).map((s) => s.name);
+  const data = {};
+  for (let i = 1; i < names.length; i++) data[names[i]] = readColumn(buf, meta, i);
+  return { data, names: names.slice(1), n: meta.num_rows };
+}
+
+function fmt(x, digits = 3) {
+  if (Math.abs(x) < 0.001 && x !== 0) return x.toExponential(2);
+  return x.toFixed(digits);
+}
+
+function fmtP(p) {
+  if (p <= 1.1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(3);
+}
