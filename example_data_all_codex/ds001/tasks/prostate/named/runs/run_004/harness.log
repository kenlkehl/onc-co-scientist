+  output_files: ["transcript.json", "analysis_summary.txt"],
+  enzalutamide_non_mcrpc_rd: results.h15.effect,
+  enzalutamide_mcrpc_rd: results.h16.effect,
+  enzalutamide_mcrpc_interaction: results.h14.effect,
+  enzalutamide_arv7_joint_interaction: results.h17.effect,
+}, null, 2));

