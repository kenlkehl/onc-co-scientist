+function loadDataset() {
+  const buf = fs.readFileSync("dataset.parquet");
+  const meta = readMeta(buf);
+  const names = meta.schema.slice(1).map((s) => s.name);
+  const data = {};
+  for (let i = 1; i < names.length; i++) data[names[i]] = readColumn(buf, meta, i);
+  return { data, names: names.slice(1), n: meta.num_rows };
+}
+
+function fmt(x, digits = 3) {
+  if (Math.abs(x) < 0.001 && x !== 0) return x.toExponential(2);
+  return x.toFixed(digits);
+}
+
+function fmtP(p) {
+  if (p <= 1.1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(3);
+}
+
+const { data, n } = loadDataset();
+const y = data.objective_response;
+const allVars = Object.keys(data).filter((x) => x !== "objective_response");
+const binaryVars = allVars.filter((name) => {
+  const vals = new Set(data[name]);
+  return vals.size <= 2 && [...vals].every((v) => v === 0 || v === 1);
+});
+const contVars = allVars.filter((name) => !binaryVars.includes(name));
+const standard = {};
+for (const name of contVars) {
+  const m = mean(data[name]);
+  const s = sd(data[name]);
+  standard[name] = {
+    z: data[name].map((v) => (v - m) / s),
+    mean: m,
+    sd: s,
+    q25: quantile(data[name], 0.25),
+    q75: quantile(data[name], 0.75),
+  };
+}
+
+function vector(name) {
+  return contVars.includes(name) ? standard[name].z : data[name];
+}
+
+function fit(terms, interactions = []) {
+  const labels = ["intercept"];
+  const cols = [Array(n).fill(1)];
+  for (const t of terms) {
+    labels.push(contVars.includes(t) ? `${t}(perSD)` : t);
+    cols.push(vector(t));
+  }
+  for (const [a, b] of interactions) {
+    const va = vector(a);
+    const vb = vector(b);
+    labels.push(`${a}*${b}`);
+    cols.push(va.map((x, i) => x * vb[i]));
+  }
+  const res = ols(cols, y);
+  const out = {};
+  labels.forEach((lab, i) => {
+    out[lab] = { effect: res.beta[i], se: res.se[i], p_value: res.p_value[i], significant: res.p_value[i] < 0.05 };
+  });
+  return out;
+}
+
+function continuousIqr(name) {
+  const st = standard[name];
+  const res = ols([Array(n).fill(1), st.z], y);
+  const iqrSd = (st.q75 - st.q25) / st.sd;
+  const effect = res.beta[1] * iqrSd;
+  return {
+    effect,
+    p_value: res.p_value[1],
+    significant: res.p_value[1] < 0.05,
+    q25: st.q25,
+    q75: st.q75,
+  };
+}
+
+function subsetIndex(name, value) {
+  const idx = [];
+  for (let i = 0; i < n; i++) if (data[name][i] === value) idx.push(i);
+  return idx;
+}
+
+const treatments = [
+  "treatment_enzalutamide",
+  "treatment_abiraterone",
+  "treatment_docetaxel",
+  "treatment_olaparib",
+  "treatment_lu177_psma",
+  "treatment_pembrolizumab",
+];
+const base = [
+  "age_years",
+  "ecog_ps",
