+function snappyUncompress(input, expected) {
+  let ip = 0;
+  function readVar() {
+    let shift = 0;
+    let n = 0;
+    while (true) {
+      const c = input[ip++];
+      n |= (c & 0x7f) << shift;
+      if ((c & 0x80) === 0) break;
+      shift += 7;
+    }
+    return n;
+  }
+  const len = readVar();
+  const out = Buffer.alloc(expected || len);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let l = tag >> 2;
+      if (l < 60) {
+        l += 1;
+      } else {
+        const bytes = l - 59;
+        l = 0;
+        for (let i = 0; i < bytes; i++) l |= input[ip++] << (8 * i);
+        l += 1;
+      }
+      input.copy(out, op, ip, ip + l);
+      ip += l;
+      op += l;
+    } else if (type === 1) {
+      const l = ((tag >> 2) & 7) + 4;
