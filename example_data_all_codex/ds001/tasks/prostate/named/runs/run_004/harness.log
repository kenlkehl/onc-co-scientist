+const { data, n } = loadDataset();
+const y = data.objective_response;
+const allVars = Object.keys(data).filter((x) => x !== "objective_response");
+const binaryVars = allVars.filter((name) => {
+  const vals = new Set(data[name]);
+  return vals.size <= 2 && [...vals].every((v) => v === 0 || v === 1);
+});
+const contVars = allVars.filter((name) => !binaryVars.includes(name));
+const standard = {};
+for (const name of contVars) {
+  const m = mean(data[name]);
+  const s = sd(data[name]);
+  standard[name] = {
+    z: data[name].map((v) => (v - m) / s),
+    mean: m,
+    sd: s,
+    q25: quantile(data[name], 0.25),
+    q75: quantile(data[name], 0.75),
+  };
+}
+
+function vector(name) {
+  return contVars.includes(name) ? standard[name].z : data[name];
+}
+
+function fit(terms, interactions = []) {
+  const labels = ["intercept"];
+  const cols = [Array(n).fill(1)];
+  for (const t of terms) {
+    labels.push(contVars.includes(t) ? `${t}(perSD)` : t);
+    cols.push(vector(t));
+  }
+  for (const [a, b] of interactions) {
+    const va = vector(a);
+    const vb = vector(b);
+    labels.push(`${a}*${b}`);
+    cols.push(va.map((x, i) => x * vb[i]));
+  }
+  const res = ols(cols, y);
+  const out = {};
+  labels.forEach((lab, i) => {
+    out[lab] = { effect: res.beta[i], se: res.se[i], p_value: res.p_value[i], significant: res.p_value[i] < 0.05 };
+  });
+  return out;
+}
