+function readColumn(buf, meta, colIndex) {
+  const cm = meta.row_groups[0].columns[colIndex].meta_data;
+  let p = cm.dictionary_page_offset;
+  let dict = null;
+  const vals = [];
+  while (vals.length < cm.num_values) {
+    const reader = new CompactReader(buf, p);
+    const h = reader.struct(pageHeader);
+    p = reader.o;
+    const comp = buf.subarray(p, p + h.compressed_page_size);
+    p += h.compressed_page_size;
+    const page = cm.codec === 1 ? snappyUncompress(comp, h.uncompressed_page_size) : comp;
+    if (h.type === 2) {
