+  while (vals.length < cm.num_values) {
+    const reader = new CompactReader(buf, p);
+    const h = reader.struct(pageHeader);
+    p = reader.o;
+    const comp = buf.subarray(p, p + h.compressed_page_size);
+    p += h.compressed_page_size;
+    const page = cm.codec === 1 ? snappyUncompress(comp, h.uncompressed_page_size) : comp;
+    if (h.type === 2) {
+      dict = decodePlain(page, cm.type, h.dictionary_page_header.num_values);
+    } else if (h.type === 0) {
+      let off = 0;
+      const n = h.data_page_header.num_values;
+      const defLen = page.readUInt32LE(off);
+      off += 4;
+      const defs = rleDecode(page.subarray(off, off + defLen), 0, 1, n).values;
+      off += defLen;
+      const nonNull = defs.reduce((acc, x) => acc + (x === 1 ? 1 : 0), 0);
+      const bw = page[off++];
+      const idx = rleDecode(page, off, bw, nonNull).values;
+      let j = 0;
+      for (const def of defs) vals.push(def === 1 ? dict[idx[j++]] : null);
+    } else {
+      throw new Error(`Unsupported page type ${h.type}`);
+    }
+  }
