+const mainModel = fit(base);
+const interactionBase = base.filter((x) => !["treatment_enzalutamide"].includes(x));
+const enzaJoint = fit(interactionBase.concat(["treatment_enzalutamide"]), [
+  ["treatment_enzalutamide", "mcrpc"],
+  ["treatment_enzalutamide", "ar_v7_positive"],
+]);
