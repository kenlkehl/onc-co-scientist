+function invert(A) {
+  const n = A.length;
+  const M = A.map((r, i) => r.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let c = 0; c < n; c++) {
+    let piv = c;
+    for (let r = c + 1; r < n; r++) if (Math.abs(M[r][c]) > Math.abs(M[piv][c])) piv = r;
+    if (Math.abs(M[piv][c]) < 1e-12) throw new Error("Singular design matrix");
+    [M[c], M[piv]] = [M[piv], M[c]];
+    const div = M[c][c];
+    for (let j = 0; j < 2 * n; j++) M[c][j] /= div;
+    for (let r = 0; r < n; r++) {
