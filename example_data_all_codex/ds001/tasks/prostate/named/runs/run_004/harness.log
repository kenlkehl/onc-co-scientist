+function decodePlain(buf, type, count) {
+  const a = [];
+  let p = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === 2) {
+      a.push(Number(buf.readBigInt64LE(p)));
+      p += 8;
+    } else if (type === 5) {
+      a.push(buf.readDoubleLE(p));
+      p += 8;
+    } else if (type === 1) {
+      a.push(buf.readInt32LE(p));
+      p += 4;
+    } else if (type === 6) {
+      const n = buf.readInt32LE(p);
+      p += 4;
+      a.push(buf.subarray(p, p + n).toString());
+      p += n;
+    } else {
+      throw new Error(`Unsupported PLAIN type ${type}`);
+    }
+  }
