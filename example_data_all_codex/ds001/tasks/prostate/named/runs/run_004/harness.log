+function binaryEffect(x, y, idx = null) {
+  let n1 = 0;
+  let s1 = 0;
+  let n0 = 0;
+  let s0 = 0;
+  const iter = idx || x.map((_, i) => i);
+  for (const i of iter) {
+    if (x[i] === 1) {
+      n1++;
+      s1 += y[i];
+    } else if (x[i] === 0) {
+      n0++;
+      s0 += y[i];
+    }
+  }
+  const p1 = s1 / n1;
+  const p0 = s0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+  return { n1, n0, p1, p0, effect, p_value: pNormal(effect / se), significant: pNormal(effect / se) < 0.05 };
+}
+
+function invert(A) {
+  const n = A.length;
+  const M = A.map((r, i) => r.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let c = 0; c < n; c++) {
+    let piv = c;
+    for (let r = c + 1; r < n; r++) if (Math.abs(M[r][c]) > Math.abs(M[piv][c])) piv = r;
+    if (Math.abs(M[piv][c]) < 1e-12) throw new Error("Singular design matrix");
+    [M[c], M[piv]] = [M[piv], M[c]];
+    const div = M[c][c];
+    for (let j = 0; j < 2 * n; j++) M[c][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === c) continue;
+      const f = M[r][c];
+      if (f !== 0) for (let j = 0; j < 2 * n; j++) M[r][j] -= f * M[c][j];
+    }
+  }
+  return M.map((r) => r.slice(n));
+}
+
+function ols(cols, y) {
+  const n = y.length;
+  const p = cols.length;
+  const XtX = Array.from({ length: p }, () => Array(p).fill(0));
+  const Xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = cols[a][i];
+      Xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) XtX[a][b] += xa * cols[b][i];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) XtX[b][a] = XtX[a][b];
+  const inv = invert(XtX);
+  const beta = Array(p).fill(0);
+  for (let a = 0; a < p; a++) for (let b = 0; b < p; b++) beta[a] += inv[a][b] * Xty[b];
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let a = 0; a < p; a++) pred += beta[a] * cols[a][i];
+    const e2 = (y[i] - pred) * (y[i] - pred);
+    for (let a = 0; a < p; a++) {
+      const xa = cols[a][i];
+      for (let b = 0; b <= a; b++) meat[a][b] += xa * cols[b][i] * e2;
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) meat[b][a] = meat[a][b];
+  const cov = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) {
+      for (let c = 0; c < p; c++) {
+        for (let d = 0; d < p; d++) cov[a][b] += inv[a][c] * meat[c][d] * inv[d][b];
+      }
+    }
+  }
+  const scale = n / (n - p);
+  const se = beta.map((_, i) => Math.sqrt(Math.max(0, cov[i][i] * scale)));
+  return { beta, se, p_value: beta.map((v, i) => pNormal(v / se[i])) };
+}
+
+function loadDataset() {
