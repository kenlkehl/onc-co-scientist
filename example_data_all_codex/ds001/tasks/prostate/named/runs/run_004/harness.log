+function continuousIqr(name) {
+  const st = standard[name];
+  const res = ols([Array(n).fill(1), st.z], y);
+  const iqrSd = (st.q75 - st.q25) / st.sd;
+  const effect = res.beta[1] * iqrSd;
+  return {
+    effect,
+    p_value: res.p_value[1],
+    significant: res.p_value[1] < 0.05,
+    q25: st.q25,
+    q75: st.q75,
+  };
+}
