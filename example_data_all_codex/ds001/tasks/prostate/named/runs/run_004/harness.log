+function rleDecode(buf, off, bitWidth, count) {
+  const values = [];
+  let p = off;
+  function getVar() {
+    let shift = 0;
+    let n = 0;
+    while (true) {
+      const c = buf[p++];
+      n |= (c & 0x7f) << shift;
+      if ((c & 0x80) === 0) break;
+      shift += 7;
+    }
+    return n;
+  }
+  while (values.length < count) {
+    const header = getVar();
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const bytes = Math.ceil(bitWidth / 8);
+      let v = 0;
+      for (let i = 0; i < bytes; i++) v |= buf[p++] << (8 * i);
+      for (let i = 0; i < run && values.length < count; i++) values.push(v);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bitpos = 0;
+      const start = p;
+      for (let i = 0; i < total && values.length < count; i++) {
