+function quantile(a, q) {
+  const b = Array.from(a).sort((x, y) => x - y);
+  const pos = (b.length - 1) * q;
+  const lo = Math.floor(pos);
+  const hi = Math.ceil(pos);
+  return lo === hi ? b[lo] : b[lo] + (b[hi] - b[lo]) * (pos - lo);
