+  let value = 0;
+  while (true) {
+    const b = buf[pos++];
+    value += (b & 0x7f) * Math.pow(2, shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value, offset: pos };
