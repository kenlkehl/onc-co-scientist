+const allInteractionNames = [];
+for (const tx of treatmentNames) {
+  for (const bm of biomarkerNames) {
+    const nm = `${tx}:${bm}`;
+    allInteractionNames.push(nm);
+    allInteractionPredictors.push({ name: nm, values: df[tx].map((v, i) => v * df[bm][i]) });
+  }
