+  const meta = new ThriftCompact(metaBuf).readStruct(fileMetaSpec);
+  const schemaByName = new Map();
+  for (const s of meta.schema) if (s.name && s.name !== 'schema') schemaByName.set(s.name, s);
+  const rg = meta.row_groups[0];
+  const columns = {};
+  for (const col of rg.columns) {
+    const md = col.meta_data;
+    const name = md.path_in_schema[0];
