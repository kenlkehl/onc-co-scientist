+function readRleBitPackedWithLength(buf, offset, bw, count) {
+  const byteLen = buf.readInt32LE(offset);
+  const dec = readRleBitPacked(buf.slice(offset + 4, offset + 4 + byteLen), 0, bw, count);
+  return { values: dec.values, offset: offset + 4 + byteLen };
