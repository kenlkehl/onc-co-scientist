+  const byteWidth = Math.ceil(bw / 8);
+  while (values.length < count) {
+    const hv = readUnsignedVarint(buf, pos);
+    const header = hv.value;
+    pos = hv.offset;
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < byteWidth; i++) value |= buf[pos++] << (8 * i);
+      const n = Math.min(runLength, count - values.length);
+      for (let i = 0; i < n; i++) values.push(value);
+    } else {
+      const groups = header >> 1;
+      const packedCount = groups * 8;
+      let bitPos = 0;
+      const bytes = Math.ceil((packedCount * bw) / 8);
+      for (let i = 0; i < packedCount && values.length < count; i++) {
+        let value = 0;
+        for (let b = 0; b < bw; b++) {
+          const bit = (buf[pos + (bitPos >> 3)] >> (bitPos & 7)) & 1;
+          value |= bit << b;
+          bitPos++;
+        }
+        values.push(value);
+      }
+      pos += bytes;
+    }
+  }
+  return { values, offset: pos };
+}
+
+function readRleBitPackedWithLength(buf, offset, bw, count) {
+  const byteLen = buf.readInt32LE(offset);
+  const dec = readRleBitPacked(buf.slice(offset + 4, offset + 4 + byteLen), 0, bw, count);
+  return { values: dec.values, offset: offset + 4 + byteLen };
