+    p_value: safeP(p),
+    effect_estimate: beta,
+    significant: safeP(p) < 0.05,
+    estimate_scale: 'absolute interaction risk difference in objective_response probability',
+  };
+}
+
+function diseaseInteractionAnalysis(hid, detail, label) {
+  return {
+    hypothesis_ids: [hid],
+    code: diseaseInteractionCode,
+    result_summary: `${label}: interaction effect ${rdLabel(detail.beta)} (${pLabel(detail.p)}). Cell rates: no treatment/no subgroup ${pp(detail.r00)} (n=${detail.n00}), treatment/no subgroup ${pp(detail.r10)} (n=${detail.n10}), no treatment/subgroup ${pp(detail.r01)} (n=${detail.n01}), treatment/subgroup ${pp(detail.r11)} (n=${detail.n11}).`,
+    p_value: safeP(detail.p),
+    effect_estimate: detail.beta,
+    significant: safeP(detail.p) < 0.05,
+    estimate_scale: 'absolute interaction risk difference in objective_response probability',
+  };
+}
+
+function continuousAnalysis(hid, display, modelTerm) {
