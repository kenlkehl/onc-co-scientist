+  return {
+    hypothesis_ids: [hid],
+    code: biomarkerInteractionCode,
+    result_summary: `${label}: interaction effect ${rdLabel(beta)} (${pLabel(p)}). Cell rates: no treatment/no marker ${pp(detail.r00)} (n=${detail.n00}), treatment/no marker ${pp(detail.r10)} (n=${detail.n10}), no treatment/marker ${pp(detail.r01)} (n=${detail.n01}), treatment/marker ${pp(detail.r11)} (n=${detail.n11}).`,
