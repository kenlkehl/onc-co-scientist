+function decodePlain(buf, type, count) {
+  const vals = [];
+  let pos = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === 5) {
+      vals.push(buf.readDoubleLE(pos));
+      pos += 8;
+    } else if (type === 2) {
+      vals.push(Number(buf.readBigInt64LE(pos)));
+      pos += 8;
+    } else if (type === 1) {
+      vals.push(buf.readInt32LE(pos));
+      pos += 4;
+    } else if (type === 0) {
+      throw new Error('plain boolean not implemented');
+    } else if (type === 6) {
+      const len = buf.readInt32LE(pos);
+      pos += 4;
+      vals.push(buf.slice(pos, pos + len).toString('utf8'));
+      pos += len;
+    } else {
+      throw new Error(`plain parquet type ${type} not implemented`);
