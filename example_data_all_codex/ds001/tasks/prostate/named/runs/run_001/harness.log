+      off = h.body_offset + h.compressed_page_size;
+    }
+    columns[name] = values;
+  }
+  return { meta, columns, n: meta.num_rows };
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const v of arr) {
+    const d = v - m;
+    ss += d * d;
+  }
+  return Math.sqrt(ss / (arr.length - 1));
+}
+
+function uniqueValues(arr) {
+  return [...new Set(arr)].sort((a, b) => a - b);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741;
+  const a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function binaryRiskDiff(x, y) {
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) { n1++; s1 += y[i]; } else if (x[i] === 0) { n0++; s0 += y[i]; }
+  }
+  const p1 = s1 / n1, p0 = s0 / n0;
+  const diff = p1 - p0;
+  const pooled = (s1 + s0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
+  return { n1, n0, p1, p0, diff, z: diff / se, p: pFromZ(diff / se) };
+}
