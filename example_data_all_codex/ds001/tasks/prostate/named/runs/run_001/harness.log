+      6: { name: 'column_index_offset' }, 7: { name: 'column_index_length' },
+    } } },
+    2: { name: 'total_byte_size' }, 3: { name: 'num_rows' },
+  } } },
+  5: { name: 'key_value_metadata' },
+  6: { name: 'created_by' },
+};
+
+const pageHeaderSpec = {
+  1: { name: 'type' },
+  2: { name: 'uncompressed_page_size' },
+  3: { name: 'compressed_page_size' },
+  4: { name: 'crc' },
+  5: { name: 'data_page_header', spec: {
+    1: { name: 'num_values' }, 2: { name: 'encoding' },
+    3: { name: 'definition_level_encoding' }, 4: { name: 'repetition_level_encoding' },
+    5: { name: 'statistics' },
+  } },
+  6: { name: 'index_page_header' },
+  7: { name: 'dictionary_page_header', spec: {
+    1: { name: 'num_values' }, 2: { name: 'encoding' }, 3: { name: 'is_sorted' },
+  } },
+  8: { name: 'data_page_header_v2', spec: {
+    1: { name: 'num_values' }, 2: { name: 'num_nulls' }, 3: { name: 'num_rows' },
+    4: { name: 'encoding' }, 5: { name: 'definition_levels_byte_length' },
+    6: { name: 'repetition_levels_byte_length' }, 7: { name: 'is_compressed' },
