+    1: { name: 'num_values' }, 2: { name: 'num_nulls' }, 3: { name: 'num_rows' },
+    4: { name: 'encoding' }, 5: { name: 'definition_levels_byte_length' },
+    6: { name: 'repetition_levels_byte_length' }, 7: { name: 'is_compressed' },
+    8: { name: 'statistics' },
+  } },
+};
+
+function readPageHeaderAt(offset) {
+  const r = new ThriftCompact(buf, offset);
+  const h = r.readStruct(pageHeaderSpec);
+  h.header_size = r.pos - offset;
+  h.body_offset = r.pos;
+  return h;
+}
+
+console.log('page headers');
+for (const c of rg.columns.slice(0, 8).concat(rg.columns.slice(-2))) {
+  const md = c.meta_data;
+  let off = md.dictionary_page_offset || md.data_page_offset;
+  console.log('column', md.path_in_schema.join('.'));
+  for (let i = 0; i < 3 && off < (md.data_page_offset + md.total_compressed_size + 1000); i++) {
+    const h = readPageHeaderAt(off);
+    console.log(' ', h);
+    off = h.body_offset + h.compressed_page_size;
+    if (off >= (md.data_page_offset + md.total_compressed_size)) break;
+  }
+}

