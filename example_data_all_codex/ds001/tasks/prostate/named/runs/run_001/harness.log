+function binaryRiskDiff(x, y) {
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) { n1++; s1 += y[i]; } else if (x[i] === 0) { n0++; s0 += y[i]; }
+  }
+  const p1 = s1 / n1, p0 = s0 / n0;
+  const diff = p1 - p0;
+  const pooled = (s1 + s0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
+  return { n1, n0, p1, p0, diff, z: diff / se, p: pFromZ(diff / se) };
