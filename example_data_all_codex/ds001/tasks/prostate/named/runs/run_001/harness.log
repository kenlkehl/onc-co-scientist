+      off = h.body_offset + h.compressed_page_size;
+    }
+    columns[name] = values;
+  }
+  return { meta, columns, n: meta.num_rows };
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const v of arr) {
+    const d = v - m;
+    ss += d * d;
+  }
+  return Math.sqrt(ss / (arr.length - 1));
+}
+
+function uniqueValues(arr) {
+  return [...new Set(arr)].sort((a, b) => a - b);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741;
+  const a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
