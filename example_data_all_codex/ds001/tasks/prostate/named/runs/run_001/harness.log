+class ThriftCompact {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+    this.boolValue = null;
+  }
+  u8() { return this.buf[this.pos++]; }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.u8();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  i16() { return zigzagFromVarint(this.varint()); }
+  i32() { return zigzagFromVarint(this.varint()); }
+  i64() {
+    const v = this.varint();
+    return Number((v >> 1n) ^ (-(v & 1n)));
+  }
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  bytes() {
+    const len = Number(this.varint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
