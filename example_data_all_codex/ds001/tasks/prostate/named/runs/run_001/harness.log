+const fs = require('fs');
+
+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+  }
+  u8() { return this.buf[this.pos++]; }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.u8();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  i32() { return this.zigzag(this.varint()); }
+  i64() {
+    const v = this.varint();
+    return Number((v >> 1n) ^ (-(v & 1n)));
+  }
+}
+
+const T = {
+  STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6,
+  DOUBLE: 7, BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12,
+};
+
+function zigzagFromVarint(v) {
+  return Number((v >> 1n) ^ (-(v & 1n)));
+}
+
+class ThriftCompact {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+    this.boolValue = null;
+  }
+  u8() { return this.buf[this.pos++]; }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.u8();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  i16() { return zigzagFromVarint(this.varint()); }
+  i32() { return zigzagFromVarint(this.varint()); }
+  i64() {
+    const v = this.varint();
+    return Number((v >> 1n) ^ (-(v & 1n)));
+  }
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  bytes() {
+    const len = Number(this.varint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  string() { return this.bytes().toString('utf8'); }
+  fieldBegin(prev) {
+    const b = this.u8();
+    const type = b & 0x0f;
+    if (type === T.STOP) return null;
+    const delta = b >> 4;
+    const id = delta === 0 ? this.i16() : prev + delta;
+    let actualType = type;
+    let boolValue = null;
+    if (type === T.TRUE) { actualType = T.TRUE; boolValue = true; }
+    if (type === T.FALSE) { actualType = T.FALSE; boolValue = false; }
+    return { id, type: actualType, boolValue };
