+class CompactReader {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+  }
+  u8() { return this.buf[this.pos++]; }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.u8();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
