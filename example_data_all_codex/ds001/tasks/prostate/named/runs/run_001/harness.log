+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const pr of predictors) row.push(pr.values[i]);
+    sumY2 += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = matInv(xtx);
+  const beta = Array(p).fill(0);
+  for (let a = 0; a < p; a++) for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < predictors.length; j++) pred += beta[j + 1] * predictors[j].values[i];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const terms = [{ name: '(Intercept)', beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]), p: null }];
+  terms[0].p = pFromZ(terms[0].beta / terms[0].se);
+  for (let j = 0; j < predictors.length; j++) {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[j + 1][j + 1]));
+    terms.push({ name: predictors[j].name, beta: beta[j + 1], se, p: pFromZ(beta[j + 1] / se) });
+  }
+  return { terms, rss, df: n - p };
+}
+
+function standardized(values) {
+  const m = mean(values);
+  const s = sd(values);
+  return values.map(v => (v - m) / s);
+}
+
+function fmtPct(x) { return `${(100 * x).toFixed(1)}%`; }
+function fmtNum(x, digits = 4) {
+  if (x === 0) return '0';
+  if (Math.abs(x) < 0.0001) return x.toExponential(2);
+  return x.toFixed(digits);
+}
+
+const { columns: df, n } = readParquetNumeric('dataset.parquet');
+const y = df.objective_response;
+if (!y || y.length !== 50000) throw new Error('objective_response missing or wrong length');
+
+const names = Object.keys(df);
+const binaryNames = names.filter(name => name !== 'objective_response' && uniqueValues(df[name]).length <= 2 && uniqueValues(df[name]).every(v => v === 0 || v === 1));
+const treatmentNames = binaryNames.filter(nm => nm.startsWith('treatment_'));
+const biomarkerNames = ['brca2_mutation', 'ar_v7_positive', 'msi_high', 'psma_high', 'her2_amplification', 'met_exon14_skipping', 'ret_fusion', 'ros1_fusion', 'braf_v600e'];
+const diseaseBinary = ['mcrpc', 'visceral_mets', 'liver_mets', 'bone_mets', 'adrenal_mets', 'pleural_effusion', 'pericardial_effusion', 'contralateral_lung_mets'];
+const continuousNames = ['age_years', 'psa_ng_ml', 'albumin_g_dl', 'ldh_u_l', 'weight_loss_pct_6mo', 'crp_mg_l', 'nlr', 'hemoglobin_g_dl', 'alkaline_phosphatase_u_l', 'ast_u_l', 'alt_u_l', 'total_bilirubin_mg_dl', 'creatinine_mg_dl', 'bun_mg_dl', 'sodium_meq_l', 'potassium_meq_l', 'calcium_mg_dl', 'glucose_mg_dl', 'platelets_k_ul', 'wbc_k_ul', 'anc_k_ul', 'alc_k_ul', 'ca_125_u_ml', 'cea_ng_ml', 'tsh_uiu_ml', 'inr', 'bmi', 'systolic_bp_mmhg', 'diastolic_bp_mmhg', 'heart_rate_bpm', 'spo2_pct'];
+
+const prevalences = Object.fromEntries(binaryNames.map(nm => [nm, mean(df[nm])]));
+const outcomeRate = mean(y);
+
+const binaryEffects = [];
+for (const nm of binaryNames) {
+  const st = binaryRiskDiff(df[nm], y);
+  if (Number.isFinite(st.diff) && st.n1 > 20 && st.n0 > 20) binaryEffects.push({ name: nm, ...st });
+}
+binaryEffects.sort((a, b) => Math.abs(b.diff) - Math.abs(a.diff));
+
+const continuousEffects = [];
+for (const nm of continuousNames) {
+  const xs = standardized(df[nm]);
+  const model = ols(y, [{ name: nm, values: xs }]);
+  const t = model.terms[1];
+  continuousEffects.push({ name: nm, beta: t.beta, p: t.p, mean: mean(df[nm]), sd: sd(df[nm]) });
+}
+continuousEffects.sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta));
+
+const adjustmentVars = [
+  { name: 'age_years_z', values: standardized(df.age_years) },
+  { name: 'ecog_ps', values: df.ecog_ps },
+  { name: 'mcrpc', values: df.mcrpc },
+  { name: 'visceral_mets', values: df.visceral_mets },
+  { name: 'psa_ng_ml_z', values: standardized(df.psa_ng_ml) },
+  { name: 'gleason_score_z', values: standardized(df.gleason_score) },
+  { name: 'albumin_g_dl_z', values: standardized(df.albumin_g_dl) },
+  { name: 'ldh_u_l_z', values: standardized(df.ldh_u_l) },
+  { name: 'weight_loss_pct_6mo_z', values: standardized(df.weight_loss_pct_6mo) },
+  { name: 'crp_mg_l_z', values: standardized(df.crp_mg_l) },
+  { name: 'nlr_z', values: standardized(df.nlr) },
+  ...treatmentNames.map(nm => ({ name: nm, values: df[nm] })),
+  ...biomarkerNames.map(nm => ({ name: nm, values: df[nm] })),
+].filter(v => sd(v.values) > 0);
+const adjustedMain = ols(y, adjustmentVars);
+
+function term(model, name) {
+  return model.terms.find(t => t.name === name);
+}
+
+const interactionRows = [];
+for (const tx of treatmentNames) {
+  for (const bm of biomarkerNames) {
+    if (prevalences[bm] <= 0 || prevalences[tx] <= 0) continue;
+    const interVals = df[tx].map((v, i) => v * df[bm][i]);
+    if (mean(interVals) === 0) continue;
+    const preds = [
+      { name: tx, values: df[tx] },
+      { name: bm, values: df[bm] },
+      { name: `${tx}:${bm}`, values: interVals },
+      { name: 'age_years_z', values: standardized(df.age_years) },
+      { name: 'ecog_ps', values: df.ecog_ps },
+      { name: 'mcrpc', values: df.mcrpc },
+      { name: 'visceral_mets', values: df.visceral_mets },
+      { name: 'psa_ng_ml_z', values: standardized(df.psa_ng_ml) },
+      { name: 'gleason_score_z', values: standardized(df.gleason_score) },
+      { name: 'albumin_g_dl_z', values: standardized(df.albumin_g_dl) },
+      { name: 'ldh_u_l_z', values: standardized(df.ldh_u_l) },
+    ].filter(v => sd(v.values) > 0);
+    const model = ols(y, preds);
+    const it = term(model, `${tx}:${bm}`);
+    const g00 = groupRate(i => df[tx][i] === 0 && df[bm][i] === 0, y);
+    const g10 = groupRate(i => df[tx][i] === 1 && df[bm][i] === 0, y);
+    const g01 = groupRate(i => df[tx][i] === 0 && df[bm][i] === 1, y);
+    const g11 = groupRate(i => df[tx][i] === 1 && df[bm][i] === 1, y);
+    const did = (g11.rate - g01.rate) - (g10.rate - g00.rate);
+    interactionRows.push({ tx, bm, beta: it.beta, p: it.p, did, g00, g10, g01, g11 });
+  }
+}
+interactionRows.sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta));
+
+const diseaseInteractions = [];
+for (const tx of treatmentNames) {
+  for (const dz of diseaseBinary) {
+    if (prevalences[dz] <= 0 || prevalences[tx] <= 0) continue;
+    const interVals = df[tx].map((v, i) => v * df[dz][i]);
+    if (mean(interVals) === 0) continue;
+    const preds = [
+      { name: tx, values: df[tx] },
+      { name: dz, values: df[dz] },
+      { name: `${tx}:${dz}`, values: interVals },
+      { name: 'age_years_z', values: standardized(df.age_years) },
+      { name: 'ecog_ps', values: df.ecog_ps },
+      { name: 'psa_ng_ml_z', values: standardized(df.psa_ng_ml) },
+      { name: 'gleason_score_z', values: standardized(df.gleason_score) },
+      { name: 'albumin_g_dl_z', values: standardized(df.albumin_g_dl) },
+      { name: 'ldh_u_l_z', values: standardized(df.ldh_u_l) },
+    ].filter(v => sd(v.values) > 0);
+    const model = ols(y, preds);
+    const it = term(model, `${tx}:${dz}`);
+    diseaseInteractions.push({ tx, dz, beta: it.beta, p: it.p });
+  }
+}
+diseaseInteractions.sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta));
+
+// Print an audit summary for development runs.
+console.log(JSON.stringify({
+  n, outcomeRate,
+  selectedColumns: ['sex_female','mcrpc','brca2_mutation','treatment_olaparib','objective_response'].map(nm => ({
+    name: nm,
+    present: df[nm] != null,
+    first10: df[nm] ? df[nm].slice(0, 10) : null,
+    unique: df[nm] ? uniqueValues(df[nm]).slice(0, 20) : null,
+    mean: df[nm] ? mean(df[nm]) : null,
+  })),
+  treatmentRates: Object.fromEntries(treatmentNames.map(nm => [nm, prevalences[nm]])),
+  biomarkerRates: Object.fromEntries(biomarkerNames.map(nm => [nm, prevalences[nm]])),
+  binaryTop: binaryEffects.slice(0, 15).map(x => ({ name: x.name, diff: x.diff, p: x.p, p1: x.p1, p0: x.p0, n1: x.n1 })),
+  continuousTop: continuousEffects.slice(0, 12).map(x => ({ name: x.name, beta: x.beta, p: x.p })),
+  adjustedTerms: adjustedMain.terms.filter(t => t.name !== '(Intercept)').sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta)).slice(0, 20),
+  interactionsTop: interactionRows.slice(0, 20).map(x => ({ tx: x.tx, bm: x.bm, beta: x.beta, p: x.p, did: x.did, n11: x.g11.n, r11: x.g11.rate, r01: x.g01.rate, r10: x.g10.rate, r00: x.g00.rate })),
+  diseaseInteractionsTop: diseaseInteractions.slice(0, 12),
+}, null, 2));
