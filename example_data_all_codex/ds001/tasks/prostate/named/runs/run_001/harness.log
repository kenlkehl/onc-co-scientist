+const fs = require('fs');
+
+const T = {
+  STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6,
+  DOUBLE: 7, BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12,
+};
+
+function zz(v) {
+  return Number((v >> 1n) ^ (-(v & 1n)));
+}
+
+class ThriftCompact {
+  constructor(buf, offset = 0) {
+    this.buf = buf;
+    this.pos = offset;
+  }
+  u8() { return this.buf[this.pos++]; }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.u8();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  i16() { return zz(this.varint()); }
+  i32() { return zz(this.varint()); }
+  i64() { return zz(this.varint()); }
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  bytes() {
+    const len = Number(this.varint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  string() { return this.bytes().toString('utf8'); }
+  fieldBegin(prev) {
+    const b = this.u8();
+    const type = b & 0x0f;
+    if (type === T.STOP) return null;
+    const delta = b >> 4;
+    const id = delta === 0 ? this.i16() : prev + delta;
+    return { id, type };
+  }
+  listBegin() {
+    const b = this.u8();
+    let size = b >> 4;
+    const type = b & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+  readValue(type, spec) {
+    if (type === T.TRUE) return true;
+    if (type === T.FALSE) return false;
+    if (type === T.BYTE) return this.u8();
+    if (type === T.I16) return this.i16();
+    if (type === T.I32) return this.i32();
+    if (type === T.I64) return this.i64();
+    if (type === T.DOUBLE) return this.double();
+    if (type === T.BINARY) return this.string();
+    if (type === T.LIST || type === T.SET) {
+      const lb = this.listBegin();
+      const arr = [];
+      for (let i = 0; i < lb.size; i++) arr.push(this.readValue(lb.type, spec && spec.elem));
+      return arr;
+    }
+    if (type === T.MAP) {
+      const size = Number(this.varint());
+      if (size === 0) return [];
+      const kt = this.u8();
+      const keyType = kt >> 4;
+      const valType = kt & 0x0f;
+      const arr = [];
+      for (let i = 0; i < size; i++) arr.push([this.readValue(keyType), this.readValue(valType)]);
+      return arr;
+    }
+    if (type === T.STRUCT) return this.readStruct(spec || {});
+    throw new Error(`unsupported thrift type ${type} at ${this.pos}`);
+  }
