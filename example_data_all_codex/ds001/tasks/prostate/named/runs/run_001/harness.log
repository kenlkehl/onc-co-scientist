+      off = h.body_offset + h.compressed_page_size;
+    }
+    const values = [];
+    while (values.length < md.num_values) {
+      const h = readPageHeader(buf, off);
+      const comp = buf.slice(h.body_offset, h.body_offset + h.compressed_page_size);
+      const body = md.codec === 1 ? snappyUncompress(comp, h.uncompressed_page_size) : comp;
+      if (h.type === 0) {
+        const dph = h.data_page_header;
