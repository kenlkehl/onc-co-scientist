+      6: { name: 'column_index_offset' }, 7: { name: 'column_index_length' },
+    } } },
+    2: { name: 'total_byte_size' }, 3: { name: 'num_rows' },
+  } } },
+  5: { name: 'key_value_metadata' },
+  6: { name: 'created_by' },
+};
+
+const buf = fs.readFileSync('dataset.parquet');
+console.log('magic', buf.slice(0, 4).toString(), buf.slice(buf.length - 4).toString());
+const footerLen = buf.readUInt32LE(buf.length - 8);
+console.log('footerLen', footerLen, 'fileLen', buf.length);
+const metaBuf = buf.slice(buf.length - 8 - footerLen, buf.length - 8);
+const reader = new ThriftCompact(metaBuf);
+const meta = reader.readStruct(fileMetaSpec);
+console.log('version', meta.version, 'num_rows', meta.num_rows, 'created_by', meta.created_by);
+console.log('schema length', meta.schema.length, 'row groups', meta.row_groups.length);
+for (const s of meta.schema.slice(0, 10)) console.log('schema', s);
+const rg = meta.row_groups[0];
