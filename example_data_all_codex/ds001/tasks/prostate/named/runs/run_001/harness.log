+  console.log(md.path_in_schema.join('.'), 'type', md.type, 'codec', md.codec, 'enc', md.encodings, 'values', md.num_values, 'data', md.data_page_offset, 'dict', md.dictionary_page_offset, 'comp', md.total_compressed_size);
+}
+
+const pageHeaderSpec = {
+  1: { name: 'type' },
+  2: { name: 'uncompressed_page_size' },
+  3: { name: 'compressed_page_size' },
+  4: { name: 'crc' },
+  5: { name: 'data_page_header', spec: {
