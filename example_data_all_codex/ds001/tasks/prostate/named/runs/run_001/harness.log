+  let sumY2 = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const pr of predictors) row.push(pr.values[i]);
+    sumY2 += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
