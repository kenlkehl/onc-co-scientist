+function snappyUncompress(input, expectedLength) {
+  let ip = 0;
+  let shift = 0;
+  let len = 0;
+  while (true) {
+    const b = input[ip++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let l = tag >> 2;
+      if (l < 60) {
