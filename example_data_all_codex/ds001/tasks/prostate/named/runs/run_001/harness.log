+  }
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const metaBuf = buf.slice(buf.length - 8 - footerLen, buf.length - 8);
+  const meta = new ThriftCompact(metaBuf).readStruct(fileMetaSpec);
+  const schemaByName = new Map();
+  for (const s of meta.schema) if (s.name && s.name !== 'schema') schemaByName.set(s.name, s);
+  const rg = meta.row_groups[0];
+  const columns = {};
+  for (const col of rg.columns) {
+    const md = col.meta_data;
+    const name = md.path_in_schema[0];
+    if (name === 'patient_id') continue;
+    const schema = schemaByName.get(name);
+    const maxDefLevel = schema.repetition_type === 1 ? 1 : 0;
+    let dict = null;
+    let off = md.dictionary_page_offset || md.data_page_offset;
+    if (md.dictionary_page_offset != null) {
+      const h = readPageHeader(buf, off);
+      if (h.type !== 2) throw new Error(`expected dictionary page for ${name}`);
+      const comp = buf.slice(h.body_offset, h.body_offset + h.compressed_page_size);
+      const body = md.codec === 1 ? snappyUncompress(comp, h.uncompressed_page_size) : comp;
+      dict = decodePlain(body, md.type, h.dictionary_page_header.num_values);
+      off = h.body_offset + h.compressed_page_size;
+    }
+    const values = [];
+    while (values.length < md.num_values) {
+      const h = readPageHeader(buf, off);
+      const comp = buf.slice(h.body_offset, h.body_offset + h.compressed_page_size);
+      const body = md.codec === 1 ? snappyUncompress(comp, h.uncompressed_page_size) : comp;
+      if (h.type === 0) {
+        const dph = h.data_page_header;
+        let pos = 0;
+        if (bitWidth(0) > 0) throw new Error('repetition levels not expected');
+        let levels = null;
+        if (maxDefLevel > 0) {
+          const dec = readRleBitPackedWithLength(body, pos, bitWidth(maxDefLevel), dph.num_values);
+          levels = dec.values;
+          pos = dec.offset;
+        }
+        const nonNull = levels ? levels.filter(v => v === maxDefLevel).length : dph.num_values;
+        if (dph.encoding === 8) {
+          const bw = body[pos++];
+          const dec = readRleBitPacked(body, pos, bw, nonNull);
+          const idx = dec.values;
+          let j = 0;
+          if (levels) {
+            for (const lv of levels) values.push(lv === maxDefLevel ? dict[idx[j++]] : null);
+          } else {
+            for (const ii of idx) values.push(dict[ii]);
+          }
+        } else if (dph.encoding === 0) {
+          const raw = body.slice(pos);
+          const vals = decodePlain(raw, md.type, nonNull);
+          let j = 0;
+          if (levels) {
+            for (const lv of levels) values.push(lv === maxDefLevel ? vals[j++] : null);
+          } else {
+            values.push(...vals);
+          }
+        } else {
+          throw new Error(`unsupported data encoding ${dph.encoding} for ${name}`);
+        }
+      } else if (h.type !== 2) {
+        throw new Error(`unsupported page type ${h.type} for ${name}`);
+      }
