import pandas as pd
import numpy as np
from scipy import stats
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print(df.shape)
print(df.dtypes.to_string())
print('\\nOutcome mean', df['objective_response'].mean(), 'sum', df['objective_response'].sum())
# detect binary cols
binary=[]
cont=[]
for c in df.columns:
    vals=df[c].dropna().unique()
    if len(vals)<=2 and set(vals).issubset({0,1,False,True}):
        binary.append(c)
    else:
        cont.append(c)
print('\\nBinary columns', len(binary), binary)
print('\\nContinuous columns', len(cont), cont)
# treatment and biomarker rates
for c in [x for x in df.columns if x.startswith('treatment_')]+['brca2_mutation','ar_v7_positive','msi_high','psma_high','mcrpc','visceral_mets','liver_mets','bone_mets']:
    print(c, df[c].mean(), df[c].sum())
# univariate binary risk differences and p-values
rows=[]
y=df['objective_response'].astype(float)
for c in binary:
    if c=='objective_response': continue
    x=df[c]
    p1=y[x==1].mean(); p0=y[x==0].mean(); n1=(x==1).sum(); n0=(x==0).sum()
    # chi2 or z via stats.contingency
    tab=pd.crosstab(x,y)
    chi2,p,_,_=stats.chi2_contingency(tab)
    rows.append((c,n1,p1,p0,p1-p0,p))
rows=sorted(rows,key=lambda r: abs(r[4]), reverse=True)
print('\\nTop binary risk diffs:')
for r in rows[:40]: print(r)
# continuous logistic-ish t-tests: mean diff outcome responders vs not
rows=[]
for c in cont:
    if c=='objective_response': continue
    a=df.loc[y==1,c]; b=df.loc[y==0,c]
    t,p=stats.ttest_ind(a,b,equal_var=False)
    rows.append((c,a.mean(),b.mean(),a.mean()-b.mean(),p))
print('\\nTop continuous responder mean diffs by p/abs standardized:')
for r in sorted(rows,key=lambda r: r[4])[:40]: print(r)
