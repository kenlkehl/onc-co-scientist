+  const start = pos + 4;
+  const end = start + byteLength;
+  const bitWidth = Math.ceil(Math.log2(maxLevel + 1));
+  const decoded = decodeRleBitPacked(buf, start, end, bitWidth, valueCount);
+  return { levels: decoded.values, pos: end };
+}
+
+function decodeLevelsV2(buf, pos, byteLength, maxLevel, valueCount) {
+  if (maxLevel === 0 || byteLength === 0) {
