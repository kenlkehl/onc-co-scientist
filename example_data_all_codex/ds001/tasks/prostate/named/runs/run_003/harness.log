+const fs = require("fs");
+
+const PARQUET_FILE = "dataset.parquet";
+const TRANSCRIPT_FILE = "transcript.json";
+const SUMMARY_FILE = "analysis_summary.txt";
+
+const T = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+const TYPE_NAMES = {
+  0: "BOOLEAN",
+  1: "INT32",
+  2: "INT64",
+  3: "INT96",
+  4: "FLOAT",
+  5: "DOUBLE",
+  6: "BYTE_ARRAY",
+  7: "FIXED_LEN_BYTE_ARRAY",
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let value = 0n;
+    while (true) {
+      const b = this.byte();
+      value |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return value;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  binaryBuffer() {
+    const len = Number(this.varint());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  binary() {
+    return this.binaryBuffer().toString("utf8");
+  }
+
+  listBegin() {
+    const b = this.byte();
+    let size = b >> 4;
+    const etype = b & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, etype };
+  }
+
+  fieldBegin(lastFieldId) {
+    const b = this.byte();
+    const type = b & 0x0f;
+    if (type === T.STOP) return { type };
+    const delta = b >> 4;
+    const id = delta === 0 ? this.i32() : lastFieldId + delta;
+    return { type, id };
+  }
+
+  skip(type) {
+    switch (type) {
+      case T.TRUE:
+      case T.FALSE:
+        return;
+      case T.BYTE:
+        this.byte();
+        return;
+      case T.I16:
+      case T.I32:
+        this.i32();
+        return;
+      case T.I64:
+        this.i64();
+        return;
+      case T.DOUBLE:
+        this.pos += 8;
+        return;
+      case T.BINARY:
+        this.binaryBuffer();
+        return;
+      case T.LIST:
+      case T.SET: {
+        const l = this.listBegin();
+        for (let i = 0; i < l.size; i++) this.skip(l.etype);
+        return;
+      }
+      case T.MAP: {
+        const size = Number(this.varint());
+        if (size === 0) return;
+        const b = this.byte();
+        const ktype = b >> 4;
+        const vtype = b & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(ktype);
+          this.skip(vtype);
+        }
+        return;
+      }
+      case T.STRUCT: {
+        let last = 0;
+        while (true) {
+          const f = this.fieldBegin(last);
+          if (f.type === T.STOP) break;
+          last = f.id;
+          this.skip(f.type);
+        }
+        return;
+      }
+      default:
+        throw new Error(`Cannot skip compact type ${type} at ${this.pos}`);
+    }
+  }
+}
+
+function readStruct(reader, handlers) {
+  const obj = {};
+  let last = 0;
+  while (true) {
+    const f = reader.fieldBegin(last);
+    if (f.type === T.STOP) break;
+    last = f.id;
+    const handler = handlers[f.id];
+    if (handler) obj[handler[0]] = handler[1](reader, f.type);
+    else reader.skip(f.type);
+  }
+  return obj;
+}
+
+function readList(reader, fn) {
+  const l = reader.listBegin();
+  const out = [];
+  for (let i = 0; i < l.size; i++) out.push(fn(reader, l.etype));
+  return out;
+}
+
+const readI32 = (r) => r.i32();
+const readI64 = (r) => r.i64();
+const readString = (r) => r.binary();
+const readBool = (r, type) => type === T.TRUE;
+
+function readSchemaElement(r) {
+  return readStruct(r, {
+    1: ["type", readI32],
+    2: ["type_length", readI32],
+    3: ["repetition_type", readI32],
+    4: ["name", readString],
+    5: ["num_children", readI32],
+    6: ["converted_type", readI32],
+    7: ["scale", readI32],
+    8: ["precision", readI32],
+    9: ["field_id", readI32],
+    10: ["logicalType", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+  });
+}
+
+function readColumnMetaData(r) {
+  return readStruct(r, {
+    1: ["type", readI32],
+    2: ["encodings", (reader) => readList(reader, readI32)],
+    3: ["path_in_schema", (reader) => readList(reader, readString)],
+    4: ["codec", readI32],
+    5: ["num_values", readI64],
+    6: ["total_uncompressed_size", readI64],
+    7: ["total_compressed_size", readI64],
+    8: ["key_value_metadata", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+    9: ["data_page_offset", readI64],
+    10: ["index_page_offset", readI64],
+    11: ["dictionary_page_offset", readI64],
+    12: ["statistics", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+    13: ["encoding_stats", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+  });
+}
+
+function readColumnChunk(r) {
+  return readStruct(r, {
+    1: ["file_path", readString],
+    2: ["file_offset", readI64],
+    3: ["meta_data", readColumnMetaData],
+    4: ["offset_index_offset", readI64],
+    5: ["offset_index_length", readI32],
+    6: ["column_index_offset", readI64],
+    7: ["column_index_length", readI32],
+  });
+}
+
+function readRowGroup(r) {
+  return readStruct(r, {
+    1: ["columns", (reader) => readList(reader, readColumnChunk)],
+    2: ["total_byte_size", readI64],
+    3: ["num_rows", readI64],
+    4: ["sorting_columns", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+    5: ["file_offset", readI64],
+    6: ["total_compressed_size", readI64],
+    7: ["ordinal", readI32],
+  });
+}
+
+function readFileMetaData(r) {
+  return readStruct(r, {
+    1: ["version", readI32],
+    2: ["schema", (reader) => readList(reader, readSchemaElement)],
+    3: ["num_rows", readI64],
+    4: ["row_groups", (reader) => readList(reader, readRowGroup)],
+    5: ["key_value_metadata", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+    6: ["created_by", readString],
+    7: ["column_orders", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+  });
+}
+
+function readDataPageHeader(r) {
+  return readStruct(r, {
+    1: ["num_values", readI32],
+    2: ["encoding", readI32],
+    3: ["definition_level_encoding", readI32],
+    4: ["repetition_level_encoding", readI32],
+    5: ["statistics", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+  });
+}
+
+function readDataPageHeaderV2(r) {
+  return readStruct(r, {
+    1: ["num_values", readI32],
+    2: ["num_nulls", readI32],
+    3: ["num_rows", readI32],
+    4: ["encoding", readI32],
+    5: ["definition_levels_byte_length", readI32],
+    6: ["repetition_levels_byte_length", readI32],
+    7: ["is_compressed", readBool],
+    8: ["statistics", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+  });
+}
+
+function readDictionaryPageHeader(r) {
+  return readStruct(r, {
+    1: ["num_values", readI32],
+    2: ["encoding", readI32],
+    3: ["is_sorted", readBool],
+  });
+}
+
+function readPageHeader(buf, pos) {
+  const r = new CompactReader(buf, pos);
+  const header = readStruct(r, {
+    1: ["type", readI32],
+    2: ["uncompressed_page_size", readI32],
+    3: ["compressed_page_size", readI32],
+    4: ["crc", readI32],
+    5: ["data_page_header", readDataPageHeader],
+    6: ["index_page_header", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+    7: ["dictionary_page_header", readDictionaryPageHeader],
+    8: ["data_page_header_v2", readDataPageHeaderV2],
+  });
+  header.headerSize = r.pos - pos;
+  header.nextPos = r.pos;
+  return header;
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[ip++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let op = 0;
+  while (ip < input.length && op < len) {
+    const tag = input[ip++];
+    const kind = tag & 0x03;
+    if (kind === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
+        const bytes = literalLen - 59;
+        literalLen = 1;
+        let n = 0;
+        for (let i = 0; i < bytes; i++) n |= input[ip++] << (8 * i);
+        literalLen += n;
+      }
+      input.copy(out, op, ip, ip + literalLen);
+      ip += literalLen;
+      op += literalLen;
+    } else if (kind === 1) {
+      const copyLen = ((tag >> 2) & 0x07) + 4;
+      const offset = ((tag & 0xe0) << 3) | input[ip++];
+      for (let i = 0; i < copyLen; i++) out[op + i] = out[op - offset + i];
+      op += copyLen;
+    } else if (kind === 2) {
+      const copyLen = (tag >> 2) + 1;
+      const offset = input[ip] | (input[ip + 1] << 8);
+      ip += 2;
+      for (let i = 0; i < copyLen; i++) out[op + i] = out[op - offset + i];
+      op += copyLen;
+    } else {
+      const copyLen = (tag >> 2) + 1;
+      const offset =
+        (input[ip]) |
+        (input[ip + 1] << 8) |
+        (input[ip + 2] << 16) |
+        (input[ip + 3] << 24);
+      ip += 4;
+      for (let i = 0; i < copyLen; i++) out[op + i] = out[op - offset + i];
