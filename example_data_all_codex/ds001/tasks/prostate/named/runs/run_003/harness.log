+  stats.hemoglobin = { mean: mean(base.map((r) => r.hemoglobin_g_dl)), sd: sd(base.map((r) => r.hemoglobin_g_dl)) };
+  stats.albumin = { mean: mean(base.map((r) => r.albumin_g_dl)), sd: sd(base.map((r) => r.albumin_g_dl)) };
+  stats.weight_loss = { mean: mean(base.map((r) => r.weight_loss_pct_6mo)), sd: sd(base.map((r) => r.weight_loss_pct_6mo)) };
+  stats.bmi = { mean: mean(base.map((r) => r.bmi)), sd: sd(base.map((r) => r.bmi)) };
+  stats.sodium = { mean: mean(base.map((r) => r.sodium_meq_l)), sd: sd(base.map((r) => r.sodium_meq_l)) };
