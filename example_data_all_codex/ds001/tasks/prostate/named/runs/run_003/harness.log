+
+function inverseAndSolve(a, b) {
+  const n = a.length;
+  const m = a.map((row, i) => row.concat([b[i]], Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(m[r][col]) > Math.abs(m[pivot][col])) pivot = r;
+    }
+    if (Math.abs(m[pivot][col]) < 1e-10) {
+      m[pivot][col] += 1e-8;
+    }
+    if (pivot !== col) {
+      const tmp = m[col];
+      m[col] = m[pivot];
+      m[pivot] = tmp;
+    }
+    const div = m[col][col];
+    for (let c = col; c < 2 * n + 1; c++) m[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = m[r][col];
+      if (factor === 0) continue;
+      for (let c = col; c < 2 * n + 1; c++) m[r][c] -= factor * m[col][c];
+    }
+  }
+  const solution = m.map((row) => row[n]);
+  const inv = m.map((row) => row.slice(n + 1));
+  return { solution, inv };
+}
+
+function fitLogit(y, rows, terms) {
+  const n = y.length;
+  const p = terms.length + 1;
+  const x = Array.from({ length: n }, (_, i) => {
+    const row = [1];
+    for (const term of terms) row.push(term.fn(rows[i]));
+    return row;
+  });
+  let beta = Array(p).fill(0);
+  let inv = null;
+  for (let iter = 0; iter < 60; iter++) {
+    const grad = Array(p).fill(0);
+    const hess = Array.from({ length: p }, () => Array(p).fill(0));
+    for (let i = 0; i < n; i++) {
+      let eta = 0;
+      for (let j = 0; j < p; j++) eta += x[i][j] * beta[j];
+      const mu = eta >= 0 ? 1 / (1 + Math.exp(-eta)) : Math.exp(eta) / (1 + Math.exp(eta));
+      const w = Math.max(mu * (1 - mu), 1e-8);
+      const resid = y[i] - mu;
+      for (let j = 0; j < p; j++) {
+        grad[j] += x[i][j] * resid;
+        for (let k = 0; k <= j; k++) hess[j][k] += x[i][j] * w * x[i][k];
+      }
+    }
+    for (let j = 0; j < p; j++) {
+      for (let k = j + 1; k < p; k++) hess[j][k] = hess[k][j];
+      hess[j][j] += 1e-8;
+    }
+    const solved = inverseAndSolve(hess, grad);
+    inv = solved.inv;
+    const delta = solved.solution;
+    let maxDelta = 0;
+    for (let j = 0; j < p; j++) {
+      beta[j] += delta[j];
+      maxDelta = Math.max(maxDelta, Math.abs(delta[j]));
+    }
+    if (maxDelta < 1e-7) break;
+  }
+  const se = inv.map((row, i) => Math.sqrt(Math.abs(row[i])));
+  const z = beta.map((v, i) => v / se[i]);
+  const pvals = z.map(twoSidedNormalP);
+  return { beta, se, z, pvals, terms };
+}
+
+function sigmoid(x) {
+  if (x >= 0) return 1 / (1 + Math.exp(-x));
+  const e = Math.exp(x);
+  return e / (1 + e);
+}
+
+function predict(model, row) {
+  let eta = model.beta[0];
+  for (let j = 0; j < model.terms.length; j++) eta += model.beta[j + 1] * model.terms[j].fn(row);
+  return sigmoid(eta);
+}
+
+function averageMarginalBinary(model, rows, variable, onValue = 1, offValue = 0) {
+  let s = 0;
+  for (const row of rows) {
+    const a = { ...row, [variable]: onValue };
+    const b = { ...row, [variable]: offValue };
+    s += predict(model, a) - predict(model, b);
+  }
+  return s / rows.length;
+}
+
+function averageMarginalContinuous(model, rows, variable, delta) {
+  let s = 0;
+  for (const row of rows) {
+    const a = { ...row, [variable]: row[variable] + delta };
+    const b = { ...row, [variable]: row[variable] };
+    s += predict(model, a) - predict(model, b);
+  }
+  return s / rows.length;
+}
+
+function averageInteractionDiff(model, rows, treatment, marker) {
+  let s = 0;
+  for (const row of rows) {
+    const a = { ...row, [treatment]: 1, [marker]: 1 };
+    const b = { ...row, [treatment]: 0, [marker]: 1 };
+    const c = { ...row, [treatment]: 1, [marker]: 0 };
+    const d = { ...row, [treatment]: 0, [marker]: 0 };
+    s += (predict(model, a) - predict(model, b)) - (predict(model, c) - predict(model, d));
+  }
+  return s / rows.length;
+}
+
+function fmtPct(x) {
+  return `${(100 * x).toFixed(1)} percentage points`;
+}
+
+function fmtP(p) {
+  if (p < 1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function round(x, digits = 6) {
+  if (!Number.isFinite(x)) return x;
+  if (Math.abs(x) > 0 && Math.abs(x) < 10 ** -digits) return x;
+  const m = 10 ** digits;
+  return Math.round(x * m) / m;
+}
+
+function term(name, fn) {
+  return { name, fn };
+}
+
+function fitOLS(y, rows, terms) {
+  const n = y.length;
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+
+  for (let i = 0; i < n; i++) {
+    const xi = Array(p);
+    xi[0] = 1;
+    for (let j = 0; j < terms.length; j++) xi[j + 1] = terms[j].fn(rows[i]);
+    const yi = y[i];
+    for (let j = 0; j < p; j++) {
+      xty[j] += xi[j] * yi;
+      for (let k = 0; k <= j; k++) xtx[j][k] += xi[j] * xi[k];
+    }
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = j + 1; k < p; k++) xtx[j][k] = xtx[k][j];
+    xtx[j][j] += 1e-8;
+  }
+
+  const solved = inverseAndSolve(xtx, xty);
+  const beta = solved.solution;
+  const inv = solved.inv;
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+
+  for (let i = 0; i < n; i++) {
+    const xi = Array(p);
+    xi[0] = 1;
+    for (let j = 0; j < terms.length; j++) xi[j + 1] = terms[j].fn(rows[i]);
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += xi[j] * beta[j];
+    const e2 = (y[i] - pred) ** 2;
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k <= j; k++) meat[j][k] += xi[j] * xi[k] * e2;
+    }
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = j + 1; k < p; k++) meat[j][k] = meat[k][j];
+  }
+
+  const scale = n / (n - p);
+  const variance = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      let s = 0;
+      for (let a = 0; a < p; a++) {
+        for (let b = 0; b < p; b++) s += inv[i][a] * meat[a][b] * inv[b][j];
+      }
+      variance[i][j] = s * scale;
+    }
+  }
+  const se = variance.map((row, i) => Math.sqrt(Math.max(row[i], 1e-16)));
+  const z = beta.map((v, i) => v / se[i]);
+  const pvals = z.map(twoSidedNormalP);
+  return { beta, se, z, pvals, terms };
+}
+
+function buildRows(columns) {
+  const names = Object.keys(columns).filter((c) => c !== "patient_id");
+  const n = columns[names[0]].length;
+  const base = [];
