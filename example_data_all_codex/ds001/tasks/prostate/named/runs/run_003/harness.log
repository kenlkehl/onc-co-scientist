+        if (h.encoding === 0) {
+          pageValues = decodePlainValues(dataPart, 0, md.type, nonNullCount).values;
+        } else if (h.encoding === 2 || h.encoding === 8) {
+          if (!dictionary) throw new Error(`Dictionary page missing for ${name}`);
+          pageValues = decodeDictionaryValues(dataPart, 0, nonNullCount).map((idx) => dictionary[idx]);
+        } else {
+          throw new Error(`Unsupported data page v2 encoding ${h.encoding} for ${name}`);
+        }
+        let vi = 0;
+        for (const level of levels) values.push(level === maxDef ? pageValues[vi++] : null);
+      } else {
+        throw new Error(`Unsupported page type ${pageHeader.type} for ${name}`);
+      }
+    }
+    if (values.length !== md.num_values) {
+      throw new Error(`Column ${name} length ${values.length} != ${md.num_values}`);
+    }
+    columns[name] = values;
