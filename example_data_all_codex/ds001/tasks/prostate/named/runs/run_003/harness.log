+    1: ["version", readI32],
+    2: ["schema", (reader) => readList(reader, readSchemaElement)],
+    3: ["num_rows", readI64],
+    4: ["row_groups", (reader) => readList(reader, readRowGroup)],
+    5: ["key_value_metadata", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
+    6: ["created_by", readString],
+    7: ["column_orders", (reader, type) => {
+      reader.skip(type);
+      return true;
+    }],
