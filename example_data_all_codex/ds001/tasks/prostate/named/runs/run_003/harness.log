+function parseParquet(path) {
+  const file = fs.readFileSync(path);
+  if (file.subarray(0, 4).toString() !== "PAR1") throw new Error("Not a Parquet file");
+  if (file.subarray(file.length - 4).toString() !== "PAR1") throw new Error("Bad Parquet footer");
