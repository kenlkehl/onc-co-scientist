+  const scale = n / (n - p);
+  const variance = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      let s = 0;
+      for (let a = 0; a < p; a++) {
+        for (let b = 0; b < p; b++) s += inv[i][a] * meat[a][b] * inv[b][j];
+      }
+      variance[i][j] = s * scale;
+    }
+  }
+  const se = variance.map((row, i) => Math.sqrt(Math.max(row[i], 1e-16)));
