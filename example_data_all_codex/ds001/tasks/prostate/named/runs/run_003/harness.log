import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome counts')
print(df['objective_response'].value_counts(dropna=False).to_string())
print('missing total', int(df.isna().sum().sum()))
# unique counts and means
summary=[]
for c in df.columns:
    s=df[c]
    summary.append((c, str(s.dtype), int(s.nunique()), float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, float(s.std()) if pd.api.types.is_numeric_dtype(s) else None, float(s.min()) if pd.api.types.is_numeric_dtype(s) else None, float(s.max()) if pd.api.types.is_numeric_dtype(s) else None))
print('\\nvar_summary')
for row in summary:
    print('\\t'.join(map(str,row)))
