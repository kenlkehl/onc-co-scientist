+  for (let i = 0; i < n; i++) {
+    const xi = Array(p);
+    xi[0] = 1;
+    for (let j = 0; j < terms.length; j++) xi[j + 1] = terms[j].fn(rows[i]);
+    const yi = y[i];
+    for (let j = 0; j < p; j++) {
+      xty[j] += xi[j] * yi;
+      for (let k = 0; k <= j; k++) xtx[j][k] += xi[j] * xi[k];
+    }
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = j + 1; k < p; k++) xtx[j][k] = xtx[k][j];
+    xtx[j][j] += 1e-8;
+  }
