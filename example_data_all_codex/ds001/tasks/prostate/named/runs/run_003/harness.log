+      for (let k = 0; k <= j; k++) xtx[j][k] += xi[j] * xi[k];
+    }
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = j + 1; k < p; k++) xtx[j][k] = xtx[k][j];
+    xtx[j][j] += 1e-8;
