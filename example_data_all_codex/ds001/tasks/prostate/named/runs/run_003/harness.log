+    const hess = Array.from({ length: p }, () => Array(p).fill(0));
+    for (let i = 0; i < n; i++) {
+      let eta = 0;
+      for (let j = 0; j < p; j++) eta += x[i][j] * beta[j];
+      const mu = eta >= 0 ? 1 / (1 + Math.exp(-eta)) : Math.exp(eta) / (1 + Math.exp(eta));
+      const w = Math.max(mu * (1 - mu), 1e-8);
+      const resid = y[i] - mu;
