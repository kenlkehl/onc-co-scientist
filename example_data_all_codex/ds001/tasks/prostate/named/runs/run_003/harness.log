+    "her2_amplification",
+    "met_exon14_skipping",
+    "ret_fusion",
+    "ros1_fusion",
+    "braf_v600e",
+  ].map((v) => term(v, (r, name = v) => r[name]));
+  const extraLabTerms = [
+    term("hemoglobin_z", (r) => r.hemoglobin_z),
+    term("log_alp_z", (r) => r.log_alp_z),
+    term("bmi_z", (r) => r.bmi_z),
+    term("sodium_z", (r) => r.sodium_z),
+  ];
