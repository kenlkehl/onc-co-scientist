+        literalLen = 1;
+        let n = 0;
+        for (let i = 0; i < bytes; i++) n |= input[ip++] << (8 * i);
+        literalLen += n;
+      }
+      input.copy(out, op, ip, ip + literalLen);
+      ip += literalLen;
+      op += literalLen;
+    } else if (kind === 1) {
