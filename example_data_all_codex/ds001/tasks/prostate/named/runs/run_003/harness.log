+  const variance = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      let s = 0;
+      for (let a = 0; a < p; a++) {
+        for (let b = 0; b < p; b++) s += inv[i][a] * meat[a][b] * inv[b][j];
