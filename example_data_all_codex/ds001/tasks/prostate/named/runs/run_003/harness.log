+  header.nextPos = r.pos;
+  return header;
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[ip++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let op = 0;
+  while (ip < input.length && op < len) {
+    const tag = input[ip++];
+    const kind = tag & 0x03;
+    if (kind === 0) {
+      let literalLen = tag >> 2;
+      if (literalLen < 60) {
+        literalLen += 1;
+      } else {
