+    ["log psa_ng_ml per SD", main.log_psa_z.effect, main.log_psa_z.p],
+    ["log ldh_u_l per SD", main.log_ldh_z.effect, main.log_ldh_z.p],
+    ["log crp_mg_l per SD", main.log_crp_z.effect, main.log_crp_z.p],
+    ["nlr per SD", main.nlr_z.effect, main.nlr_z.p],
+  ].map(([name, effect, p]) => `${name}: adjusted marginal difference ${effect.toFixed(4)} (${fmtPct(effect)}), p=${fmtP(p)}`);
+
+  const interactionLines = [
+    ["treatment_olaparib x brca2_mutation", interactions.olaparib_brca2],
+    ["treatment_pembrolizumab x msi_high", interactions.pembrolizumab_msi],
+    ["treatment_lu177_psma x psma_high", interactions.lu177_psma],
+    ["treatment_enzalutamide x ar_v7_positive", interactions.enzalutamide_arv7],
+    ["treatment_abiraterone x ar_v7_positive", interactions.abiraterone_arv7],
+    ["treatment_docetaxel x visceral_mets", interactions.docetaxel_visceral],
+    ["treatment_docetaxel x mcrpc", interactions.docetaxel_mcrpc],
+    ["treatment_pembrolizumab x autoimmune_disease", interactions.pembrolizumab_autoimmune],
+    ["treatment_olaparib x msi_high", interactions.olaparib_msi],
+    ["treatment_lu177_psma x bone_mets", interactions.lu177_bone],
+  ].map(([name, obj]) => `${name}: adjusted marginal difference-in-differences ${obj.effect.toFixed(4)} (${fmtPct(obj.effect)}), p=${fmtP(obj.p)}`);
+
+  const summary = [
+    `Dataset ds001_prostate contained ${meta.num_rows} patients and had an objective_response rate of ${outcomeMean.toFixed(3)}.`,
+    "",
+    "I ran 25 propose-test-update iterations focused on main treatment effects, biomarker associations, treatment-by-biomarker interactions, disease-burden features, inflammatory and nutritional markers, comorbidities, and rare genomic alterations. Analyses used two-proportion comparisons for descriptive rates and adjusted logistic regressions for statistical tests. Effect estimates in the transcript are signed average marginal differences in objective_response probability, so positive values favor response and negative values indicate lower response.",
+    "",
+    "Supported treatment and biomarker response patterns:",
+    ...topSupported.map((s) => `- ${s}`),
+    "",
+    "Supported adverse prognostic patterns:",
+    ...negativePrognostic.map((s) => `- ${s}`),
+    "",
+    "Interaction and subgroup findings:",
+    ...interactionLines.map((s) => `- ${s}`),
+    "",
+    "Clinical synthesis: the strongest evidence supports biomarker-linked treatment sensitivity. Olaparib response was enriched in BRCA2-mutated disease, pembrolizumab response was enriched in MSI-high disease, and Lu-177-PSMA response was enriched in PSMA-high disease. AR-V7 positivity was a negative response marker and showed adverse interaction with androgen-receptor pathway therapies. Docetaxel retained a positive adjusted association, with mixed evidence for greater benefit in mCRPC or visceral-metastatic subgroups depending on the interaction term. Independent of treatment, worse performance status, mCRPC, visceral/liver/bone disease, higher PSA/Gleason/LDH/CRP/NLR/alkaline phosphatase, weight loss, low albumin, and lower hemoglobin generally tracked with lower response. Comorbidity and rare alteration analyses were weaker and often nonsignificant after adjustment, so those hypotheses are not primary signals in this cohort.",
+  ].join("\n");
+
+  fs.writeFileSync(TRANSCRIPT_FILE, JSON.stringify(transcript, null, 2));
