+
+function main() {
+  const { meta, columns } = parseParquet(PARQUET_FILE);
+  const { rows } = buildRows(columns);
+  const y = columns.objective_response.map((v) => Number(v));
+  const outcomeMean = mean(y);
+
+  const treatments = [
+    "treatment_enzalutamide",
+    "treatment_abiraterone",
+    "treatment_docetaxel",
+    "treatment_olaparib",
+    "treatment_lu177_psma",
+    "treatment_pembrolizumab",
+  ];
+  const coreTerms = [
+    term("age10", (r) => r.age10),
+    term("ecog_ps", (r) => r.ecog_ps),
+    term("mcrpc", (r) => r.mcrpc),
+    term("visceral_mets", (r) => r.visceral_mets),
+    term("log_psa_z", (r) => r.log_psa_z),
+    term("gleason_score", (r) => r.gleason_score),
+    term("albumin_z", (r) => r.albumin_z),
+    term("log_ldh_z", (r) => r.log_ldh_z),
+    term("weight_loss_z", (r) => r.weight_loss_z),
+    term("log_crp_z", (r) => r.log_crp_z),
