+    "visceral_mets",
+    "liver_mets",
+    "bone_mets",
+    "pleural_effusion",
+    "diabetes_mellitus",
+    "chronic_kidney_disease",
+    "heart_failure",
+    "autoimmune_disease",
+    "her2_amplification",
+    "met_exon14_skipping",
