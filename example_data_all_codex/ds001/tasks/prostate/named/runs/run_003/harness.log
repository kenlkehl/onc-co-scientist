+
+function readBitPackedValues(buf, pos, valueCount, bitWidth) {
+  const out = [];
+  if (bitWidth === 0) {
+    for (let i = 0; i < valueCount; i++) out.push(0);
+    return { values: out, pos };
+  }
+  let bitPos = 0;
+  for (let i = 0; i < valueCount; i++) {
+    let v = 0;
+    for (let b = 0; b < bitWidth; b++) {
+      const absolute = bitPos + b;
+      const byte = buf[pos + (absolute >> 3)];
+      const bit = (byte >> (absolute & 7)) & 1;
+      v |= bit << b;
+    }
+    out.push(v);
+    bitPos += bitWidth;
+  }
+  return { values: out, pos: pos + Math.ceil((valueCount * bitWidth) / 8) };
+}
+
+function decodeRleBitPacked(buf, pos, end, bitWidth, expectedCount) {
+  const values = [];
+  let p = pos;
+  const widthBytes = Math.ceil(bitWidth / 8);
+  while (p < end && values.length < expectedCount) {
+    const h = readUnsignedVarint(buf, p);
+    p = h.pos;
+    if ((h.value & 1) === 0) {
+      const runLength = h.value >> 1;
+      let value = 0;
+      for (let i = 0; i < widthBytes; i++) value |= buf[p + i] << (8 * i);
+      p += widthBytes;
+      for (let i = 0; i < runLength && values.length < expectedCount; i++) values.push(value);
+    } else {
+      const groupCount = h.value >> 1;
+      const valueCount = groupCount * 8;
+      const decoded = readBitPackedValues(buf, p, valueCount, bitWidth);
+      p = decoded.pos;
+      for (const v of decoded.values) {
