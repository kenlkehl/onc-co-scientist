+const fs = require("fs");
+
+const PARQUET_FILE = "dataset.parquet";
+const TRANSCRIPT_FILE = "transcript.json";
+const SUMMARY_FILE = "analysis_summary.txt";
+
+const T = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+const TYPE_NAMES = {
+  0: "BOOLEAN",
+  1: "INT32",
+  2: "INT64",
+  3: "INT96",
+  4: "FLOAT",
+  5: "DOUBLE",
+  6: "BYTE_ARRAY",
+  7: "FIXED_LEN_BYTE_ARRAY",
+};
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+
+  byte() {
+    return this.buf[this.pos++];
+  }
+
+  varint() {
+    let shift = 0n;
+    let value = 0n;
+    while (true) {
+      const b = this.byte();
+      value |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return value;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  i32() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  i64() {
+    return Number(this.zigzag(this.varint()));
+  }
+
+  binaryBuffer() {
+    const len = Number(this.varint());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+
+  binary() {
+    return this.binaryBuffer().toString("utf8");
+  }
+
+  listBegin() {
+    const b = this.byte();
+    let size = b >> 4;
+    const etype = b & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, etype };
+  }
+
+  fieldBegin(lastFieldId) {
+    const b = this.byte();
+    const type = b & 0x0f;
+    if (type === T.STOP) return { type };
+    const delta = b >> 4;
+    const id = delta === 0 ? this.i32() : lastFieldId + delta;
+    return { type, id };
+  }
+
+  skip(type) {
+    switch (type) {
+      case T.TRUE:
+      case T.FALSE:
+        return;
+      case T.BYTE:
