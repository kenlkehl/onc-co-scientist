+function round(x, digits = 6) {
+  if (!Number.isFinite(x)) return x;
+  const m = 10 ** digits;
+  return Math.round(x * m) / m;
+}
+
+function term(name, fn) {
+  return { name, fn };
+}
+
+function fitOLS(y, rows, terms) {
+  const n = y.length;
+  const p = terms.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+
+  for (let i = 0; i < n; i++) {
+    const xi = Array(p);
+    xi[0] = 1;
+    for (let j = 0; j < terms.length; j++) xi[j + 1] = terms[j].fn(rows[i]);
+    const yi = y[i];
+    for (let j = 0; j < p; j++) {
+      xty[j] += xi[j] * yi;
+      for (let k = 0; k <= j; k++) xtx[j][k] += xi[j] * xi[k];
+    }
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = j + 1; k < p; k++) xtx[j][k] = xtx[k][j];
+    xtx[j][j] += 1e-8;
+  }
+
+  const solved = inverseAndSolve(xtx, xty);
+  const beta = solved.solution;
+  const inv = solved.inv;
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+
+  for (let i = 0; i < n; i++) {
+    const xi = Array(p);
+    xi[0] = 1;
+    for (let j = 0; j < terms.length; j++) xi[j + 1] = terms[j].fn(rows[i]);
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += xi[j] * beta[j];
+    const e2 = (y[i] - pred) ** 2;
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k <= j; k++) meat[j][k] += xi[j] * xi[k] * e2;
+    }
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = j + 1; k < p; k++) meat[j][k] = meat[k][j];
+  }
+
+  const scale = n / (n - p);
+  const variance = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      let s = 0;
+      for (let a = 0; a < p; a++) {
+        for (let b = 0; b < p; b++) s += inv[i][a] * meat[a][b] * inv[b][j];
+      }
+      variance[i][j] = s * scale;
+    }
