+    base[i].log_ldh_z = (transforms.log_ldh[i] - stats.log_ldh.mean) / stats.log_ldh.sd;
+    base[i].log_crp_z = (transforms.log_crp[i] - stats.log_crp.mean) / stats.log_crp.sd;
+    base[i].log_alp_z = (transforms.log_alp[i] - stats.log_alp.mean) / stats.log_alp.sd;
+    base[i].nlr_z = (base[i].nlr - stats.nlr.mean) / stats.nlr.sd;
+    base[i].hemoglobin_z = (base[i].hemoglobin_g_dl - stats.hemoglobin.mean) / stats.hemoglobin.sd;
+    base[i].albumin_z = (base[i].albumin_g_dl - stats.albumin.mean) / stats.albumin.sd;
+    base[i].weight_loss_z = (base[i].weight_loss_pct_6mo - stats.weight_loss.mean) / stats.weight_loss.sd;
+    base[i].bmi_z = (base[i].bmi - stats.bmi.mean) / stats.bmi.sd;
