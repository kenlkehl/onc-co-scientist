+    term("weight_loss_z", (r) => r.weight_loss_z),
+    term("log_crp_z", (r) => r.log_crp_z),
+    term("nlr_z", (r) => r.nlr_z),
+  ];
+  const treatmentTerms = treatments.map((v) => term(v, (r, name = v) => r[name]));
+  const adjustmentTerms = [...coreTerms, ...treatmentTerms];
