+    const xi = Array(p);
+    xi[0] = 1;
+    for (let j = 0; j < terms.length; j++) xi[j + 1] = terms[j].fn(rows[i]);
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += xi[j] * beta[j];
+    const e2 = (y[i] - pred) ** 2;
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k <= j; k++) meat[j][k] += xi[j] * xi[k] * e2;
+    }
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = j + 1; k < p; k++) meat[j][k] = meat[k][j];
+  }
+
+  const scale = n / (n - p);
+  const variance = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      let s = 0;
+      for (let a = 0; a < p; a++) {
+        for (let b = 0; b < p; b++) s += inv[i][a] * meat[a][b] * inv[b][j];
+      }
+      variance[i][j] = s * scale;
+    }
+  }
+  const se = variance.map((row, i) => Math.sqrt(Math.max(row[i], 1e-16)));
+  const z = beta.map((v, i) => v / se[i]);
+  const pvals = z.map(twoSidedNormalP);
+  return { beta, se, z, pvals, terms };
+}
+
+function buildRows(columns) {
+  const names = Object.keys(columns).filter((c) => c !== "patient_id");
+  const n = columns[names[0]].length;
+  const base = [];
+  for (let i = 0; i < n; i++) {
+    const row = {};
+    for (const name of names) row[name] = columns[name][i];
+    base.push(row);
+  }
+  const transforms = {
+    age10: base.map((r) => r.age_years / 10),
+    log_psa: base.map((r) => Math.log1p(r.psa_ng_ml)),
+    log_ldh: base.map((r) => Math.log1p(r.ldh_u_l)),
+    log_crp: base.map((r) => Math.log1p(r.crp_mg_l)),
+    log_alp: base.map((r) => Math.log1p(r.alkaline_phosphatase_u_l)),
+  };
+  const stats = {};
+  for (const [name, arr] of Object.entries(transforms)) stats[name] = { mean: mean(arr), sd: sd(arr) };
+  stats.nlr = { mean: mean(base.map((r) => r.nlr)), sd: sd(base.map((r) => r.nlr)) };
+  stats.hemoglobin = { mean: mean(base.map((r) => r.hemoglobin_g_dl)), sd: sd(base.map((r) => r.hemoglobin_g_dl)) };
+  stats.albumin = { mean: mean(base.map((r) => r.albumin_g_dl)), sd: sd(base.map((r) => r.albumin_g_dl)) };
+  stats.weight_loss = { mean: mean(base.map((r) => r.weight_loss_pct_6mo)), sd: sd(base.map((r) => r.weight_loss_pct_6mo)) };
+  stats.bmi = { mean: mean(base.map((r) => r.bmi)), sd: sd(base.map((r) => r.bmi)) };
+  stats.sodium = { mean: mean(base.map((r) => r.sodium_meq_l)), sd: sd(base.map((r) => r.sodium_meq_l)) };
+
+  for (let i = 0; i < n; i++) {
+    base[i].age10 = transforms.age10[i];
+    base[i].log_psa_z = (transforms.log_psa[i] - stats.log_psa.mean) / stats.log_psa.sd;
+    base[i].log_ldh_z = (transforms.log_ldh[i] - stats.log_ldh.mean) / stats.log_ldh.sd;
+    base[i].log_crp_z = (transforms.log_crp[i] - stats.log_crp.mean) / stats.log_crp.sd;
+    base[i].log_alp_z = (transforms.log_alp[i] - stats.log_alp.mean) / stats.log_alp.sd;
+    base[i].nlr_z = (base[i].nlr - stats.nlr.mean) / stats.nlr.sd;
+    base[i].hemoglobin_z = (base[i].hemoglobin_g_dl - stats.hemoglobin.mean) / stats.hemoglobin.sd;
+    base[i].albumin_z = (base[i].albumin_g_dl - stats.albumin.mean) / stats.albumin.sd;
+    base[i].weight_loss_z = (base[i].weight_loss_pct_6mo - stats.weight_loss.mean) / stats.weight_loss.sd;
+    base[i].bmi_z = (base[i].bmi - stats.bmi.mean) / stats.bmi.sd;
+    base[i].sodium_z = (base[i].sodium_meq_l - stats.sodium.mean) / stats.sodium.sd;
+  }
+  return { rows: base, stats };
+}
