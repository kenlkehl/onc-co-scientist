+function twoPropTest(y, group) {
+  let n1 = 0, x1 = 0, n0 = 0, x0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (group[i]) {
+      n1++;
+      x1 += y[i];
+    } else {
+      n0++;
+      x0 += y[i];
+    }
+  }
+  const p1 = x1 / n1;
+  const p0 = x0 / n0;
+  const pooled = (x1 + x0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
+  const z = (p1 - p0) / se;
+  return { n1, n0, p1, p0, effect: p1 - p0, z, p: twoSidedNormalP(z) };
