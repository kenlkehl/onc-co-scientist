+  fs.writeFileSync(TRANSCRIPT_FILE, JSON.stringify(transcript, null, 2));
+  fs.writeFileSync(SUMMARY_FILE, summary);
+  console.log(`Wrote ${TRANSCRIPT_FILE} and ${SUMMARY_FILE}`);
+  console.log(`Rows=${meta.num_rows}; objective_response=${outcomeMean.toFixed(4)}; iterations=${iterations.length}`);
