+
+function mean(arr) {
+  let s = 0;
+  for (const x of arr) s += x;
+  return s / arr.length;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const x of arr) {
+    const d = x - m;
+    ss += d * d;
+  }
+  return Math.sqrt(ss / (arr.length - 1));
