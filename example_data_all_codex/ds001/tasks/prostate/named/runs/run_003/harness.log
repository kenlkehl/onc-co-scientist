+  const solved = inverseAndSolve(xtx, xty);
+  const beta = solved.solution;
+  const inv = solved.inv;
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+
+  for (let i = 0; i < n; i++) {
+    const xi = Array(p);
+    xi[0] = 1;
+    for (let j = 0; j < terms.length; j++) xi[j + 1] = terms[j].fn(rows[i]);
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += xi[j] * beta[j];
+    const e2 = (y[i] - pred) ** 2;
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k <= j; k++) meat[j][k] += xi[j] * xi[k] * e2;
+    }
+  }
+  for (let j = 0; j < p; j++) {
+    for (let k = j + 1; k < p; k++) meat[j][k] = meat[k][j];
+  }
