+  const primitiveSchema = meta.schema.slice(1);
+  const columns = {};
+  const rowGroup = meta.row_groups[0];
+  for (let colIndex = 0; colIndex < rowGroup.columns.length; colIndex++) {
+    const chunk = rowGroup.columns[colIndex];
+    const md = chunk.meta_data;
+    const schema = primitiveSchema[colIndex];
