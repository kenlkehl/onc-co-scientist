+
+function averageMarginalBinary(model, rows, variable, onValue = 1, offValue = 0) {
+  let s = 0;
+  for (const row of rows) {
+    const a = { ...row, [variable]: onValue };
+    const b = { ...row, [variable]: offValue };
+    s += predict(model, a) - predict(model, b);
+  }
+  return s / rows.length;
+}
+
+function averageMarginalContinuous(model, rows, variable, delta) {
+  let s = 0;
+  for (const row of rows) {
+    const a = { ...row, [variable]: row[variable] + delta };
+    const b = { ...row, [variable]: row[variable] };
+    s += predict(model, a) - predict(model, b);
+  }
+  return s / rows.length;
+}
+
+function averageInteractionDiff(model, rows, treatment, marker) {
+  let s = 0;
+  for (const row of rows) {
+    const a = { ...row, [treatment]: 1, [marker]: 1 };
+    const b = { ...row, [treatment]: 0, [marker]: 1 };
+    const c = { ...row, [treatment]: 1, [marker]: 0 };
+    const d = { ...row, [treatment]: 0, [marker]: 0 };
+    s += (predict(model, a) - predict(model, b)) - (predict(model, c) - predict(model, d));
