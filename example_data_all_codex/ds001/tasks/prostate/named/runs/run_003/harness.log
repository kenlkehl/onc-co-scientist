+        const h = pageHeader.data_page_header;
+        let p = 0;
+        let levels;
+        if (maxDef > 0) {
+          const decoded = decodeLevelsV1(page, p, maxDef, h.num_values);
+          levels = decoded.levels;
+          p = decoded.pos;
+        } else {
+          levels = new Array(h.num_values).fill(maxDef);
+        }
+        const nonNullCount = levels.reduce((acc, v) => acc + (v === maxDef ? 1 : 0), 0);
+        let pageValues;
+        if (h.encoding === 0) {
+          pageValues = decodePlainValues(page, p, md.type, nonNullCount).values;
+        } else if (h.encoding === 2 || h.encoding === 8) {
+          if (!dictionary) throw new Error(`Dictionary page missing for ${name}`);
+          const indexes = decodeDictionaryValues(page, p, nonNullCount);
+          pageValues = indexes.map((idx) => dictionary[idx]);
+        } else {
+          throw new Error(`Unsupported data page encoding ${h.encoding} for ${name}`);
+        }
+        let vi = 0;
+        for (const level of levels) values.push(level === maxDef ? pageValues[vi++] : null);
+      } else if (pageHeader.type === 3) {
+        const h = pageHeader.data_page_header_v2;
+        let levelPart = compressed.subarray(0, h.repetition_levels_byte_length + h.definition_levels_byte_length);
+        let dataPart = compressed.subarray(h.repetition_levels_byte_length + h.definition_levels_byte_length);
+        if (h.is_compressed !== false && md.codec !== 0) dataPart = decompressPage(md.codec, dataPart);
+        let lp = 0;
+        lp += h.repetition_levels_byte_length;
+        const decodedLevels = decodeLevelsV2(levelPart, lp, h.definition_levels_byte_length, maxDef, h.num_values);
+        const levels = maxDef > 0 ? decodedLevels.levels : new Array(h.num_values).fill(maxDef);
+        const nonNullCount = levels.reduce((acc, v) => acc + (v === maxDef ? 1 : 0), 0);
+        let pageValues;
+        if (h.encoding === 0) {
+          pageValues = decodePlainValues(dataPart, 0, md.type, nonNullCount).values;
+        } else if (h.encoding === 2 || h.encoding === 8) {
