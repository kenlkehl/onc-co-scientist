+  ]);
+
+  const transcript = {
+    dataset_id: "ds001_prostate",
+    model_id: "gpt-5-codex",
+    harness_id: "codex-local-node-parquet@1.0",
+    max_iterations: 25,
+    iterations,
+  };
+
+  const topSupported = [
+    ["treatment_olaparib", main.treatment_olaparib.effect, main.treatment_olaparib.p],
+    ["treatment_lu177_psma", main.treatment_lu177_psma.effect, main.treatment_lu177_psma.p],
+    ["treatment_pembrolizumab", main.treatment_pembrolizumab.effect, main.treatment_pembrolizumab.p],
+    ["treatment_docetaxel", main.treatment_docetaxel.effect, main.treatment_docetaxel.p],
+    ["brca2_mutation", main.brca2_mutation.effect, main.brca2_mutation.p],
+    ["msi_high", main.msi_high.effect, main.msi_high.p],
