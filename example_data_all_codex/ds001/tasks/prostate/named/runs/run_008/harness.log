function invert(A){const m=A.length;const aug=A.map((row,i)=>row.concat(Array.from({length:m},(_,j)=>i===j?1:0)));for(let c=0;c<m;c++){let piv=c;for(let r=c+1;r<m;r++)if(Math.abs(aug[r][c])>Math.abs(aug[piv][c]))piv=r;if(Math.abs(aug[piv][c])<1e-12)throw Error('singular');[aug[c],aug[piv]]=[aug[piv],aug[c]];const pv=aug[c][c];for(let j=0;j<2*m;j++)aug[c][j]/=pv;for(let r=0;r<m;r++)if(r"'!==c){const f=aug[r][c];if(f!==0)for(let j=0;j<2*m;j++)aug[r][j]-=f*aug[c][j];}}return aug.map(row=>row.slice(m));}
function ols(terms, basePred=null){const idx=[];for(let i=0;i<n;i++)if(!basePred||basePred(i))idx.push(i);const k=terms.length+1,N=idx.length;let XTX=Array.from({length:k},()=>Array(k).fill(0)),XTy=Array(k).fill(0);function row(i){return [1,...terms.map(t=>t.f(i))];}for(const i of idx){const x=row(i);for(let a=0;a<k;a++){XTy[a]+=x[a]*y[i];for(let b=0;b<k;b++)XTX[a][b]+=x[a]*x[b];}}const inv=invert(XTX);const beta=Array(k).fill(0);for(let a=0;a<k;a++)for(let b=0;b<k;b++)beta[a]+=inv[a][b]*XTy[b];let meat=Array.from({length:k},()=>Array(k).fill(0));for(const i of idx){const x=row(i);let pred=0;for(let a=0;a<k;a++)pred+=beta[a]*x[a];const e=y[i]-pred;for(let a=0;a<k;a++)for(let b=0;b<k;b++)meat[a][b]+=x[a]*x[b]*e*e;}let cov=Array.from({length:k},()=>Array(k).fill(0));for(let a=0;a<k;a++)for(let b=0;b<k;b++)for(let c=0;c<k;c++)for(let d=0;d<k;d++)cov[a][b]+=inv[a][c]*meat[c][d]*inv[d][b];const scale=N/(N-k);for(let a=0;a<k;a++)for(let b=0;b<k;b++)cov[a][b]*=scale;return {N,beta,se:cov.map((r,i)=>Math.sqrt(Math.max(0,r[i]))),terms:['"'intercept',...terms.map(t=>t.name)]};}
const PSA75=quant('psa_ng_ml',.75), WL75=quant('weight_loss_pct_6mo',.75), CRP75=quant('crp_mg_l',.75), ALB25=quant('albumin_g_dl',.25);console.log('thresholds', {PSA75,WL75,CRP75,ALB25});
function logRD(label, r){console.log(label,'effect',r.effect.toFixed(6),'p',fmtp(r.p),'n1',r.n1,'p1',r.p1.toFixed(6),'n0',r.n0,'p0',r.p0.toFixed(6));}
