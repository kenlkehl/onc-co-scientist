function snappy(src){let i=0;function rv(){let shift=0,n=0;while(true){const b=src[i++];n|=(b&127)<<shift;if("'!(b&128))return n;shift+=7}}const len=rv();const out=Buffer.alloc(len);let o=0;while(i<src.length){const tag=src[i++],type=tag&3;if(type===0){let l=tag>>2;if(l<60)l+=1;else{const nb=l-59;l=0;for(let j=0;j<nb;j++)l|=src[i++]<<(8*j);l+=1;}src.copy(out,o,i,i+l);i+=l;o+=l;}else{let l,ofs;if(type===1){l=((tag>>2)&7)+4;ofs=((tag&0xe0)<<3)|src[i++];}else if(type===2){l=(tag>>2)+1;ofs=src[i]|(src[i+1]<<8);i+=2;}else{l=(tag>>2)+1;ofs=(src[i]|(src[i+1]<<8)|(src[i+2]<<16)|(src[i+3]<<24))>>>0;i+=4;}for(let j=0;j<l;j++)out[o+j]=out[o-ofs+j];o+=l;}}if(o!==len)throw Error('"'snappy length mismatch '+o+' '+len);return out;}
function makeParser(buf,start){let off=start;function rv(){let shift=0n,out=0n;while(true){const b=buf[off++];out|=BigInt(b&127)<<shift;if("'!(b&128))return out;shift+=7n}}const zz=n=>Number((n>>1n)''^(-(n&1n)));function ri(){const u=rv();return Number((u>>1n)''^(-(u&1n)))}function val(t){switch(t){case 1:return true;case 2:return false;case 3:return buf.readInt8(off++);case 4:case 5:return zz(rv());case 6:return ri();case 7:{const v=buf.readDoubleLE(off);off+=8;return v}case 8:{const l=Number(rv());const b=buf.subarray(off,off+l);off+=l;return b;}case 9:return list();case 12:return struct();default:throw Error('"'type '+t+' at '+off)}}function list(){const h=buf[off++];let n=h>>4;const et=h&15;if(n===15)n=Number(rv());const a=[];for(let i=0;i<n;i++)a.push(val(et));return a}function struct(){const o={};let last=0;while(true){const h=buf[off++];const t=h&15;if(t===0)break;const d=h>>4;const f=d?last+d:zz(rv());last=f;o[f]=val(t)}return o}return {struct,get off(){return off}}}
function readHeader(pos){const p=makeParser(file,pos);const h=p.struct();return {h,end:p.off};}
function decodePlain(buf,type,n){let o=0,a=[];for(let i=0;i<n;i++){if(type===5){a.push(buf.readDoubleLE(o));o+=8;}else if(type===2){a.push(Number(buf.readBigInt64LE(o)));o+=8;}else if(type===6){const l=buf.readUInt32LE(o);o+=4;a.push(buf.subarray(o,o+l).toString('utf8'));o+=l;}else throw Error('plain type '+type);}return a;}
function readVarAt(buf,o){let shift=0,n=0;while(true){const b=buf[o++];n|=(b&127)<<shift;if("'!(b&128))return [n,o];shift+=7}}
function readHybrid(buf,o,bitWidth,total){const vals=[];if(bitWidth===0){while(vals.length<total)vals.push(0);return {vals,off:o};}const byteWidth=Math.ceil(bitWidth/8);while(vals.length<total){let r=readVarAt(buf,o);let header=r[0];o=r[1];if((header&1)===0){const count=header>>1;let v=0;for(let b=0;b<byteWidth;b++)v|=buf[o++]<<(8*b);for(let i=0;i<count&&vals.length<total;i++)vals.push(v);}else{const groups=header>>1;const n=groups*8;let bitPos=0;for(let i=0;i<n&&vals.length<total;i++){let v=0;for(let b=0;b<bitWidth;b++){const byte=buf[o+Math.floor(bitPos/8)];const bit=(byte>>(bitPos%8))&1;v|=bit<<b;bitPos++;}vals.push(v);}o+=Math.ceil(n*bitWidth/8);}}return {vals,off:o};}
const footerLen=file.readUInt32LE(file.length-8), footerStart=file.length-8-footerLen;const meta=makeParser(file,footerStart).struct();const schema=meta[2], cols=meta[4][0][1];const names=schema.slice(1).map(s=>s[4].toString('"'utf8'));
function readColumn(idx){const md=cols[idx][3];const type=md[1], total=md[5];let pos=md[11]??md[9];let dict=null;if(md[11]"'!=null){let {h,end}=readHeader(pos);const comp=file.subarray(end,end+h[3]);const decomp=md[4]===1?snappy(comp):comp;dict=decodePlain(decomp,type,h[7][1]);pos=end+h[3];}else pos=md[9];const out=[];while(out.length<total){const {h,end}=readHeader(pos);const comp=file.subarray(end,end+h[3]);const d=md[4]===1?snappy(comp):comp;pos=end+h[3];if(h[1]!==0)continue;const n=h[5][1], enc=h[5][2];let o=0;const defLen=d.readUInt32LE(o);o+=4+defLen;if(enc===8||enc===2){const bw=d[o++];const rr=readHybrid(d,o,bw,n);for(const ix of rr.vals)out.push(dict[ix]);}else if(enc===0){out.push(...decodePlain(d.subarray(o),type,n));}else throw Error('"'encoding '+enc+' col '+names[idx]);}return out;}
const data={};for(let i=1;i<names.length;i++)data[names[i]]=readColumn(i);const y=data.objective_response;const n=y.length;
function erf(x){const sign=x<0?-1:1;x=Math.abs(x);const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911;const t=1/(1+p*x);const val=1-(((((a5*t+a4)*t+a3)*t+a2)*t+a1)*t*Math.exp(-x*x);return sign*val}function normCdf(z){return 0.5*(1+erf(z/Math.SQRT2))}function p2z(z){return z===Infinity?0:2*(1-normCdf(Math.abs(z)))}function fmtp(p){return p<1e-300?'0':p.toExponential(4)}
function prop(pred){let nn=0,s=0;for(let i=0;i<n;i++)if(pred(i)){nn++;s+=y[i];}return {n:nn,s,p:s/nn};}
function rd(pred, basePred=null){let n1=0,s1=0,n0=0,s0=0;for(let i=0;i<n;i++){if(basePred && "'!basePred(i))continue;if(pred(i)){n1++;s1+=y[i]}else{n0++;s0+=y[i]}}const p1=s1/n1,p0=s0/n0,eff=p1-p0,se=Math.sqrt(p1*(1-p1)/n1+p0*(1-p0)/n0);return {n1,s1,p1,n0,s0,p0,effect:eff,se,z:eff/se,p:p2z(eff/se)}}
