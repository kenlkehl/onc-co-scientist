class TR{constructor(buf,off=0){this.b=buf;this.o=off;this.stack=[0];}byte(){return this.b[this.o++];}varintBig(){let s=0n,n=0n;for(;;){const c=this.byte();n|=BigInt(c&127)<<s;if("'!(c&128))break;s+=7n;}return n;}zig(n){return(n>>1n)''^ (-(n&1n));}i32(){return Number(this.zig(this.varintBig()));}i64(){return this.zig(this.varintBig());}bin(){const l=Number(this.varintBig()),s=this.b.subarray(this.o,this.o+l);this.o+=l;return s;}dbl(){const x=this.b.readDoubleLE(this.o);this.o+=8;return x;}field(){const h=this.byte();if(!h)return null;const t=h&15,m=h>>4,last=this.stack.at(-1);const id=m?last+m:this.i32();this.stack[this.stack.length-1]=id;return{id,type:t};}read(t){switch(t){case 1:return true;case 2:return false;case 3:return this.byte();case 4:case 5:return this.i32();case 6:return Number(this.i64());case 7:return this.dbl();case 8:return this.bin();case 9:case 10:return this.list();case 11:return this.map();case 12:return this.struct();default:throw Error('"'bad thrift type '+t);}}list(){const h=this.byte();let n=h>>4;const t=h&15;if(n===15)n=Number(this.varintBig());const a=[];for(let i=0;i<n;i++)a.push(this.read(t));return a;}map(){const n=Number(this.varintBig());if("'!n)return[];const h=this.byte(),kt=h>>4,vt=h&15,a=[];for(let i=0;i<n;i++)a.push([this.read(kt),this.read(vt)]);return a;}struct(){this.stack.push(0);const o={};for(;;){const f=this.field();if(!f)break;o[f.id]=this.read(f.type);}this.stack.pop();return o;}}
function snappy(src){let p=0;function vint(){let r=0,s=0;for(;;){const c=src[p++];r|=(c&127)<<s;if(!(c&128))break;s+=7;}return r;}const len=vint(),out=Buffer.alloc(len);let o=0;while(p<src.length){const tag=src[p++],typ=tag&3;if(!typ){let n=tag>>>2;if(n<60)n++;else{const bytes=n-59;n=0;for(let i=0;i<bytes;i++)n|=src[p++]<<(8*i);n++;}src.copy(out,o,p,p+n);p+=n;o+=n;}else{let n,off;if(typ===1){n=((tag>>>2)&7)+4;off=((tag&0xe0)<<3)|src[p++];}else if(typ===2){n=(tag>>>2)+1;off=src[p]|(src[p+1]<<8);p+=2;}else{n=(tag>>>2)+1;off=src.readUInt32LE(p);p+=4;}for(let i=0;i<n;i++)out[o+i]=out[o-off+i];o+=n;}}if(o!==len)throw Error('"'snappy length mismatch');return out;}
