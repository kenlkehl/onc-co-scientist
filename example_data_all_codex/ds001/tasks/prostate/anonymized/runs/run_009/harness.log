const fs = require('fs');
const b = fs.readFileSync('dataset.parquet');

class ThriftReader {
  constructor(buf, off=0) { this.b = buf; this.o = off; this.stack = [0]; }
  byte() { return this.b[this.o++]; }
  varintBig() { let shift = 0n, n = 0n; while (true) { const c = this.byte(); n |= BigInt(c & 0x7f) << shift; if ("'!(c & 0x80)) break; shift += 7n; } return n; }
  zig(n) { return (n >> 1n) ''^ (-(n & 1n)); }
  i32() { return Number(this.zig(this.varintBig())); }
  i64() { return this.zig(this.varintBig()); }
  bin() { const len = Number(this.varintBig()); const s = this.b.subarray(this.o, this.o + len); this.o += len; return s; }
  dbl() { const x = this.b.readDoubleLE(this.o); this.o += 8; return x; }
  field() { const h = this.byte(); if (h === 0) return null; const type = h & 15; const mod = h >> 4; const last = this.stack[this.stack.length - 1]; const id = mod ? last + mod : this.i32(); this.stack[this.stack.length - 1] = id; return { id, type }; }
  readVal(type) { switch(type) { case 1: return true; case 2: return false; case 3: return this.byte(); case 4: case 5: return this.i32(); case 6: return Number(this.i64()); case 7: return this.dbl(); case 8: return this.bin(); case 9: case 10: return this.list(); case 11: return this.map(); case 12: return this.struct(); default: throw new Error(`bad thrift type ${type} at ${this.o}`); } }
  list() { const h = this.byte(); const elem = h & 15; let size = h >> 4; if (size === 15) size = Number(this.varintBig()); const a = []; for (let i = 0; i < size; i++) a.push(this.readVal(elem)); return a; }
  map() { const size = Number(this.varintBig()); if (!size) return []; const h = this.byte(); const kt = h >> 4, vt = h & 15; const a = []; for (let i = 0; i < size; i++) a.push([this.readVal(kt), this.readVal(vt)]); return a; }
  struct() { this.stack.push(0); const obj = {}; while (true) { const f = this.field(); if (!f) break; obj[f.id] = this.readVal(f.type); } this.stack.pop(); return obj; }
}

function snappyDecode(src) {
  let p = 0;
  function vint() { let r = 0, s = 0; while (true) { const c = src[p++]; r |= (c & 127) << s; if (!(c & 128)) break; s += 7; } return r; }
  const len = vint();
  const out = Buffer.alloc(len);
  let o = 0;
  while (p < src.length) {
    const tag = src[p++];
    const typ = tag & 3;
    if (typ === 0) {
      let n = tag >>> 2;
      if (n < 60) n += 1;
      else { const bytes = n - 59; n = 0; for (let i = 0; i < bytes; i++) n |= src[p++] << (8 * i); n += 1; }
      src.copy(out, o, p, p + n); p += n; o += n;
    } else {
      let n, off;
      if (typ === 1) { n = ((tag >>> 2) & 7) + 4; off = ((tag & 0xe0) << 3) | src[p++]; }
      else if (typ === 2) { n = (tag >>> 2) + 1; off = src[p] | (src[p+1] << 8); p += 2; }
      else { n = (tag >>> 2) + 1; off = src.readUInt32LE(p); p += 4; }
      for (let i = 0; i < n; i++) out[o + i] = out[o - off + i];
      o += n;
    }
  }
  if (o !== len) throw new Error(`snappy length mismatch ${o} != ${len}`);
  return out;
}

function readPlainDict(buf, type, n) {
  const vals = [];
  let o = 0;
  for (let i = 0; i < n; i++) {
    if (type === 2) { vals.push(Number(buf.readBigInt64LE(o))); o += 8; }
    else if (type === 5) { vals.push(buf.readDoubleLE(o)); o += 8; }
    else if (type === 6) { const len = buf.readUInt32LE(o); o += 4; vals.push(buf.subarray(o, o + len).toString()); o += len; }
    else throw new Error(`unsupported physical type ${type}`);
  }
  return vals;
}

function readVarint(buf, state) { let r = 0, s = 0; while (true) { const c = buf[state.o++]; r |= (c & 127) << s; if (!(c & 128)) break; s += 7; } return r; }
function decodeHybrid(buf, bitWidth, count) {
  const out = [];
  const st = { o: 0 };
  const byteWidth = Math.ceil(bitWidth / 8);
  while (out.length < count && st.o < buf.length) {
    const header = readVarint(buf, st);
    if ((header & 1) === 0) {
      const run = header >>> 1;
      let v = 0;
      for (let i = 0; i < byteWidth; i++) v |= (buf[st.o++] || 0) << (8 * i);
      for (let i = 0; i < run && out.length < count; i++) out.push(v);
    } else {
      const groups = header >>> 1;
      const total = groups * 8;
      let bitPos = 0;
      for (let i = 0; i < total && out.length < count; i++) {
        let v = 0;
        for (let bit = 0; bit < bitWidth; bit++) {
          const byte = buf[st.o + (bitPos >> 3)];
          const one = (byte >> (bitPos & 7)) & 1;
          v |= one << bit;
          bitPos++;
        }
        out.push(v);
      }
      st.o += Math.ceil((total * bitWidth) / 8);
    }
  }
  if (out.length !== count) throw new Error(`hybrid decoded ${out.length} != ${count}`);
  return out;
}

function readParquetSimple(path) {
  const file = fs.readFileSync(path);
  const footerLen = file.readUInt32LE(file.length - 8);
  const footer = file.subarray(file.length - 8 - footerLen, file.length - 8);
  const meta = new ThriftReader(footer).struct();
  const schema = meta[2];
  const columns = meta[4][0][1];
  const out = {};
  for (let ci = 0; ci < columns.length; ci++) {
    const md = columns[ci][3];
    const type = md[1];
    const name = md[3].map(x => x.toString()).join('"'.');
    if (name === 'patient_id') continue;
    let off = md[11] ?? md[9];
    const end = off + md[7];
    let dict = null;
    const values = [];
    while (off < end) {
      const tr = new ThriftReader(file, off);
      const header = tr.struct();
      const bodyStart = tr.o;
      const bodyCompressed = file.subarray(bodyStart, bodyStart + header[3]);
      const body = md[4] === 1 ? snappyDecode(bodyCompressed) : bodyCompressed;
      if (header[1] === 2) {
        const dh = header[7];
        dict = readPlainDict(body, type, dh[1]);
      } else if (header[1] === 0) {
        const dph = header[5] ?? header[4];
        const nvals = dph[1];
        const defLen = body.readUInt32LE(0);
        const valueStart = 4 + defLen;
        const bitWidth = body[valueStart];
        const idxBuf = body.subarray(valueStart + 1);
        const ids = decodeHybrid(idxBuf, bitWidth, nvals);
        for (const id of ids) values.push(dict[id]);
      }
      off = bodyStart + header[3];
    }
    if (values.length "'!== meta[3]) throw new Error(`${name} values ${values.length} != ${meta[3]}`);
    out[name] = values;
  }
  return { data: out, n: meta[3] };
}

function mean(a) { return a.reduce((s,x)=>s+x,0) / a.length; }
function uniqInfo(a) { const m = new Map(); for (const x of a) m.set(x, (m.get(x)||0)+1); return [...m.entries()].sort((u,v)=>v[1]-u[1]); }
function erf(x) { const sign = x < 0 ? -1 : 1; x = Math.abs(x); const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911; const t=1/(1+p*x); const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x); return sign*y; }
function normCdf(z) { return 0.5 * (1 + erf(z / Math.SQRT2)); }
function p2(z) { const p = 2 * (1 - normCdf(Math.abs(z))); return Math.max(0, Math.min(1, p)); }
function fmt(x, d=4) { if (!Number.isFinite(x)) return String(x); return Number(x.toFixed(d)); }

const { data, n } = readParquetSimple('"'dataset.parquet');
const y = data.objective_response;
const yMean = mean(y);
const cols = Object.keys(data).filter(c => c "'!== '"'objective_response');
const profiles = cols.map(c => {
  const a = data[c]; const u = uniqInfo(a); const vals = u.map(x=>x[0]);
  let mn = Infinity, mx = -Infinity, sum = 0, sumsq = 0;
  for (const v of a) { if (v < mn) mn = v; if (v > mx) mx = v; sum += v; sumsq += v*v; }
  const mu = sum/n; const sd = Math.sqrt(Math.max(0, sumsq/n - mu*mu));
  return { c, unique: u.length, top: u.slice(0,5), min: mn, max: mx, mean: mu, sd };
});

function binaryRiskDiff(c) {
  const x = data[c]; let n1=0,s1=0,n0=0,s0=0;
  for (let i=0;i<n;i++) { if (x[i] === 1) { n1++; s1 += y[i]; } else if (x[i] === 0) { n0++; s0 += y[i]; } }
  const p1=s1/n1, p0=s0/n0, diff=p1-p0, pPool=(s1+s0)/(n1+n0); const se=Math.sqrt(pPool*(1-pPool)*(1/n1+1/n0)); return {c,n1,n0,p1,p0,diff,z:diff/se,p:p2(diff/se)};
}
function thresholdRiskDiff(c, thr, high=true) {
  const x=data[c]; let n1=0,s1=0,n0=0,s0=0;
  for(let i=0;i<n;i++){ const g = high ? x[i] >= thr : x[i] <= thr; if(g){n1++;s1+=y[i];} else {n0++;s0+=y[i];} }
  const p1=s1/n1,p0=s0/n0,diff=p1-p0,pPool=(s1+s0)/(n1+n0); const se=Math.sqrt(pPool*(1-pPool)*(1/n1+1/n0)); return {c,thr,high,n1,n0,p1,p0,diff,z:diff/se,p:p2(diff/se)};
}
function median(arr){const s=[...arr].sort((a,b)=>a-b); return s[Math.floor(s.length/2)];}
function quantile(arr,q){const s=[...arr].sort((a,b)=>a-b); return s[Math.floor((s.length-1)*q)];}
function contSlope(c) {
  const x=data[c]; const prof=profiles.find(p=>p.c===c); const mu=prof.mean, sd=prof.sd; let sx2=0,sxy=0;
  for(let i=0;i<n;i++){const z=(x[i]-mu)/sd; sx2+=z*z; sxy+=z*(y[i]-yMean);} const b=sxy/sx2;
  let rss=0; for(let i=0;i<n;i++){const z=(x[i]-mu)/sd; const e=y[i]-(yMean+b*z); rss+=e*e;} const se=Math.sqrt((rss/(n-2))/sx2); return {c,b,se,z:b/se,p:p2(b/se)};
}
function subgroupBinary(c, subgroupCol, subgroupVal) {
  const x=data[c], g=data[subgroupCol]; let n1=0,s1=0,n0=0,s0=0;
  for(let i=0;i<n;i++){ if(g[i] "'!== subgroupVal) continue; if(x[i]===1){n1++;s1+=y[i];} else if(x[i]===0){n0++;s0+=y[i];} }
  const p1=s1/n1,p0=s0/n0,diff=p1-p0,pPool=(s1+s0)/(n1+n0),se=Math.sqrt(pPool*(1-pPool)*(1/n1+1/n0)); return {c,subgroupCol,subgroupVal,n1,n0,p1,p0,diff,p:p2(diff/se),z:diff/se};
}
function interaction2(a,bcol) {
  const xa=data[a], xb=data[bcol]; const cells={};
  for (const av of [0,1]) for (const bv of [0,1]) cells[`${av}${bv}`]={n:0,s:0};
  for(let i=0;i<n;i++){ const av=xa[i], bv=xb[i]; if((av===0||av===1)&&(bv===0||bv===1)){ const cell=cells[`${av}${bv}`]; cell.n++; cell.s+=y[i]; }}
  for (const k of Object.keys(cells)) cells[k].p = cells[k].s / cells[k].n;
  const did = cells['"'11'].p - cells['10'].p - cells['01'].p + cells['00'].p;
  const se = Math.sqrt(Object.values(cells).reduce((s,cell)=>s + cell.p*(1-cell.p)/(cell.n||1),0));
  return {a,b:bcol,cells,did,se,z:did/se,p:p2(did/se)};
}
function conditionalPairs(target, adjust) {
  const r1 = subgroupBinary(target, adjust, 1); const r0 = subgroupBinary(target, adjust, 0); return {target, adjust, r1, r0, diffOfDiff: r1.diff-r0.diff};
}

const binaryCols = profiles.filter(p => p.unique === 2 && p.min === 0 && p.max === 1).map(p=>p.c);
const contCols = profiles.filter(p => p.unique > 10).map(p=>p.c);
const binaryEffects = binaryCols.map(binaryRiskDiff).sort((a,b)=>Math.abs(b.diff)-Math.abs(a.diff));
const contEffects = contCols.map(contSlope).sort((a,b)=>Math.abs(b.b)-Math.abs(a.b));
const thresholdEffects = contCols.flatMap(c => {
  const arr=data[c]; return [thresholdRiskDiff(c, quantile(arr,0.75), true), thresholdRiskDiff(c, quantile(arr,0.25), false)];
}).sort((a,b)=>Math.abs(b.diff)-Math.abs(a.diff));
const interactions = [];
for (let i=0;i<binaryEffects.length;i++) for(let j=i+1;j<Math.min(binaryEffects.length,30);j++) {
  const a=binaryEffects[i].c, bc=binaryEffects[j].c;
  const res=interaction2(a,bc);
  if (Object.values(res.cells).every(cell=>cell.n>=200)) interactions.push(res);
}
interactions.sort((a,b)=>Math.abs(b.did)-Math.abs(a.did));

