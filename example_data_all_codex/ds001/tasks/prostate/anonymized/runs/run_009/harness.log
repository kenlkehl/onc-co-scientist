function p2(z){const p=2*(1-cdf(Math.abs(z)));return p===0?1e-300:Math.max(0,Math.min(1,p));}
function mean(a){let s=0;for(const x of a)s+=x;return s/a.length;}
function q(a,qq){const s=[...a].sort((x,y)=>x-y);return s[Math.floor((s.length-1)*qq)];}
function round(x,d=6){return Number(x.toFixed(d));}
function ptxt(p){return p<=1e-300?'<1e-300':(p<0.001?p.toExponential(2):p.toFixed(3));}
function pct(x){return (100*x).toFixed(1)+'%';}
function pp(x){const s=x>=0?'+':'';return s+(100*x).toFixed(1)+' percentage points';}

