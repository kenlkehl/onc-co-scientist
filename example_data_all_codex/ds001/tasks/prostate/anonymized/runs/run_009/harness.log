function rv(buf,st){let r=0,s=0;for(;;){const c=buf[st.o++];r|=(c&127)<<s;if("'!(c&128))break;s+=7;}return r;}
function hybrid(buf,bw,count){const out=[],st={o:0},bytes=Math.ceil(bw/8);while(out.length<count&&st.o<buf.length){const h=rv(buf,st);if((h&1)===0){const run=h>>>1;let v=0;for(let i=0;i<bytes;i++)v|=(buf[st.o++]||0)<<(8*i);for(let i=0;i<run&&out.length<count;i++)out.push(v);}else{const total=(h>>>1)*8;let bitPos=0;for(let i=0;i<total&&out.length<count;i++){let v=0;for(let bit=0;bit<bw;bit++){const one=(buf[st.o+(bitPos>>3)]>>(bitPos&7))&1;v|=one<<bit;bitPos++;}out.push(v);}st.o+=Math.ceil(total*bw/8);}}if(out.length!==count)throw Error('"'hybrid length mismatch');return out;}
function readData(path){const file=fs.readFileSync(path);const fl=file.readUInt32LE(file.length-8);const meta=new TR(file.subarray(file.length-8-fl,file.length-8)).struct();const cols=meta[4][0][1],data={};for(const col of cols){const md=col[3],type=md[1],name=md[3].map(x=>x.toString()).join('.');if(name==='patient_id')continue;let off=md[11]??md[9],end=off+md[7],dict=null,vals=[];while(off<end){const tr=new TR(file,off),h=tr.struct(),bodyStart=tr.o,body=md[4]===1?snappy(file.subarray(bodyStart,bodyStart+h[3])):file.subarray(bodyStart,bodyStart+h[3]);if(h[1]===2){dict=dictPlain(body,type,h[7][1]);}else if(h[1]===0){const dph=h[5]??h[4],cnt=dph[1],defLen=body.readUInt32LE(0),start=4+defLen,bw=body[start],ids=hybrid(body.subarray(start+1),bw,cnt);for(const id of ids)vals.push(dict[id]);}off=bodyStart+h[3];}if(vals.length"'!==meta[3])throw Error(name+'"' length '+vals.length);data[name]=vals;}return{data,n:meta[3]};}
function erf(x){const sign=x<0?-1:1;x=Math.abs(x);const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911,t=1/(1+p*x);const y=1-(((((a5*t+a4)*t+a3)*t+a2)*t+a1)*t*Math.exp(-x*x));return sign*y;}
