const iterations=[];
iterations.push(iteration(1,[hyp('h001','Patients with "'`feature_005` equal to 1 have higher mean `objective_response` than patients with `feature_005` equal to 0.'"'),hyp('h002','Patients with "'`feature_034` equal to 1 have lower mean `objective_response` than patients with `feature_034` equal to 0.'"')],[mk(['h001'],R.f005,"'`Response was ${pct(R.f005.p1)} for feature_005=1 versus ${pct(R.f005.p0)} for feature_005=0; risk difference ${pp(R.f005.effect)}, p=${ptxt(R.f005.p)}.`),mk(['"'h002'],R.f034,"'`Response was ${pct(R.f034.p1)} for feature_034=1 versus ${pct(R.f034.p0)} for feature_034=0; risk difference ${pp(R.f034.effect)}, p=${ptxt(R.f034.p)}.`)],'"'The two largest binary main effects pointed in opposite directions, motivating interaction tests between them.'));
