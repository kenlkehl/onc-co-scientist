function rd(name,pred){let n1=0,s1=0,n0=0,s0=0;for(let i=0;i<n;i++){if(pred(i)){n1++;s1+=y[i];}else{n0++;s0+=y[i];}}const p1=s1/n1,p0=s0/n0,effect=p1-p0,pooled=(s1+s0)/(n1+n0),se=Math.sqrt(pooled*(1-pooled)*(1/n1+1/n0));return{name,n1,n0,p1,p0,effect,p:p2(effect/se),z:effect/se};}
function bin(c){return rd(c,i=>data[c][i]===1);}
function thresh(c,thr,high=true){return rd("'`${c}${high?'"'>=':'<='}"'${thr}`,i=>high?data[c][i]>=thr:data[c][i]<=thr);}
function levelRD(c,lvlA,lvlB){let n1=0,s1=0,n0=0,s0=0;for(let i=0;i<n;i++){if(data[c][i]===lvlA){n1++;s1+=y[i];}else if(data[c][i]===lvlB){n0++;s0+=y[i];}}const p1=s1/n1,p0=s0/n0,effect=p1-p0,pooled=(s1+s0)/(n1+n0),se=Math.sqrt(pooled*(1-pooled)*(1/n1+1/n0));return{name:`${c} ${lvlA} vs ${lvlB}`,n1,n0,p1,p0,effect,p:p2(effect/se),z:effect/se};}
function did(name,a,b){const cells={};for(const av of [0,1])for(const bv of [0,1])cells[`${av}${bv}`]={n:0,s:0};for(let i=0;i<n;i++){const av=a(i)?1:0,bv=b(i)?1:0;const cell=cells[`${av}${bv}`];cell.n++;cell.s+=y[i];}for(const k of Object.keys(cells))cells[k].p=cells[k].s/cells[k].n;const effect=cells['"'11'].p-cells['10'].p-cells['01'].p+cells['00'].p;const se=Math.sqrt(Object.values(cells).reduce((s,c)=>s+c.p*(1-c.p)/c.n,0));return{name,cells,effect,p:p2(effect/se),z:effect/se};}
function stdCol(c){const a=data[c],mu=mean(a);let ss=0;for(const v of a)ss+=(v-mu)*(v-mu);const sd=Math.sqrt(ss/a.length);return {mu,sd,z:i=>(a[i]-mu)/sd};}
function invert(A){const n=A.length;const M=A.map((r,i)=>[...r,...Array.from({length:n},(_,j)=>i===j?1:0)]);for(let i=0;i<n;i++){let max=i;for(let r=i+1;r<n;r++)if(Math.abs(M[r][i])>Math.abs(M[max][i]))max=r;[M[i],M[max]]=[M[max],M[i]];const piv=M[i][i];for(let c=0;c<2*n;c++)M[i][c]/=piv;for(let r=0;r<n;r++){if(r===i)continue;const f=M[r][i];for(let c=0;c<2*n;c++)M[r][c]-=f*M[i][c];}}return M.map(r=>r.slice(n));}
function ols(terms){const k=terms.length+1,XtX=Array.from({length:k},()=>Array(k).fill(0)),Xty=Array(k).fill(0),xs=new Array(k);for(let i=0;i<n;i++){xs[0]=1;for(let j=1;j<k;j++)xs[j]=terms[j-1].fn(i);for(let a=0;a<k;a++){Xty[a]+=xs[a]*y[i];for(let b=0;b<k;b++)XtX[a][b]+=xs[a]*xs[b];}}const inv=invert(XtX),beta=inv.map(row=>row.reduce((s,v,j)=>s+v*Xty[j],0));const meat=Array.from({length:k},()=>Array(k).fill(0));for(let i=0;i<n;i++){xs[0]=1;let fit=beta[0];for(let j=1;j<k;j++){xs[j]=terms[j-1].fn(i);fit+=beta[j]*xs[j];}const e=y[i]-fit,e2=e*e;for(let a=0;a<k;a++)for(let b=0;b<k;b++)meat[a][b]+=e2*xs[a]*xs[b];}const tmp=Array.from({length:k},()=>Array(k).fill(0));for(let i=0;i<k;i++)for(let j=0;j<k;j++)for(let l=0;l<k;l++)tmp[i][j]+=inv[i][l]*meat[l][j];const V=Array.from({length:k},()=>Array(k).fill(0)),f=n/(n-k);for(let i=0;i<k;i++)for(let j=0;j<k;j++)for(let l=0;l<k;l++)V[i][j]+=tmp[i][l]*inv[l][j]*f;return Object.fromEntries(terms.map((t,idx)=>{const j=idx+1,se=Math.sqrt(V[j][j]),z=beta[j]/se;return [t.name,{term:t.name,beta:beta[j],se,z,p:p2(z)}];}));}

