function common(res, type='risk_difference'){return {effect_estimate:round(res.effect),p_value:res.p,significant:res.p<0.05,test:type,n_exposed:res.n1,n_reference:res.n0,exposed_response_rate:round(res.p1),reference_response_rate:round(res.p0)};}
function mk(ids,res,summary,type){return {hypothesis_ids:ids,result_summary:summary,p_value:res.p,effect_estimate:round(res.effect),significant:res.p<0.05,test:type||'two-proportion z test',n_exposed:res.n1,n_reference:res.n0,exposed_response_rate:res.p1,reference_response_rate:res.p0};}
