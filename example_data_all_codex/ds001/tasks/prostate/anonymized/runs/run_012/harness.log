summary=[]
for c in df.columns:
    s=df[c]
    vc=s.value_counts(dropna=False).sort_index()
    summary.append((c, str(s.dtype), int(s.nunique()), float(s.mean()) if np.issubdtype(s.dtype, np.number) else None, vc.head(10).to_dict()))
for row in summary:
    print(row)
