  foreach ($h in $iter.proposed_hypotheses) {
    if (-not $h.id) { $errors += "iteration $($iter.index) hypothesis missing id" }
    if (-not $h.text) { $errors += "iteration $($iter.index) hypothesis $($h.id) missing text" }
  }
  foreach ($a in $iter.analyses) {
    if (-not $a.hypothesis_ids -or $a.hypothesis_ids.Count -eq 0) { $errors += "iteration $($iter.index) analysis missing hypothesis_ids" }
    if (-not $a.result_summary) { $errors += "iteration $($iter.index) analysis missing result_summary" }
    if ($null -eq $a.effect_estimate) { $errors += "iteration $($iter.index) analysis missing effect_estimate" }
    if (($null -eq $a.p_value) -and ($null -eq $a.significant)) { $errors += "iteration $($iter.index) analysis missing p_value/significant" }
  }
}
if ($errors.Count) { $errors | ForEach-Object { Write-Output $_ }; exit 1 }
