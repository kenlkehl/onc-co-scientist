+    if (dph[2] === 8) {
+      const bitWidth = page[pagePos++];
+      const idxDecoded = decodeHybrid(page, pagePos, nonNull, bitWidth);
+      let idxPos = 0;
+      for (const d of defDecoded.values) {
+        if (d === 1) values.push(dictionary[idxDecoded.values[idxPos++]]);
+        else values.push(null);
+      }
+    } else if (dph[2] === 0) {
+      const plain = decodePlainValues(page.subarray(pagePos), parquetType, nonNull);
+      let idxPos = 0;
+      for (const d of defDecoded.values) {
+        if (d === 1) values.push(plain[idxPos++]);
+        else values.push(null);
+      }
+    } else {
+      throw new Error(`Unsupported data encoding ${dph[2]}`);
+    }
+    pos = payloadStart + pageHeader[3];
+  }
+  return values;
+}
+
+function readDataset() {
+  const fileBuf = fs.readFileSync(DATASET);
+  const meta = parseFooter(fileBuf);
+  const schema = meta[2];
+  const rowGroup = meta[4][0];
+  const columns = {};
+  const types = {};
+  for (let i = 1; i < schema.length; i++) {
+    const name = schema[i][4].toString("utf8");
+    const parquetType = schema[i][1];
+    types[name] = parquetType;
+    if (name === "patient_id") continue;
+    columns[name] = decodeColumn(fileBuf, rowGroup[1][i - 1], parquetType);
+  }
+  return { columns, types, n: meta[3] };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalTwoSided(z) {
+  const a = Math.abs(z);
+  if (!Number.isFinite(a)) return NORM_MIN_P;
+  if (a < 8) return Math.max(NORM_MIN_P, 2 * (1 - 0.5 * (1 + erf(a / Math.SQRT2))));
+  const tail = (Math.exp(-0.5 * a * a) / (a * Math.sqrt(2 * Math.PI))) * (1 - 1 / (a * a) + 3 / (a ** 4));
+  return Math.max(NORM_MIN_P, Math.min(1, 2 * tail));
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function summarizeFeature(x) {
+  const n = x.length;
+  let s = 0;
+  let ss = 0;
+  let min = Infinity;
+  let max = -Infinity;
+  const counts = new Map();
+  for (const v of x) {
+    s += v;
+    ss += v * v;
+    if (v < min) min = v;
+    if (v > max) max = v;
+    if (counts.size <= 200) counts.set(v, (counts.get(v) || 0) + 1);
+  }
+  const m = s / n;
+  const variance = Math.max(0, ss / n - m * m);
+  const uniqueValues = [...counts.keys()].sort((a, b) => a - b);
+  const allCounted = counts.size <= 200;
+  return {
+    mean: m,
+    sd: Math.sqrt(variance),
+    min,
+    max,
+    uniqueCount: allCounted ? counts.size : 201,
+    uniqueValues,
+    counts,
+    isBinary01: allCounted && counts.size === 2 && counts.has(0) && counts.has(1),
+  };
+}
+
+function univariateEffect(x, y, summary) {
+  const n = x.length;
+  const yMean = mean(y);
+  if (!Number.isFinite(summary.sd) || summary.sd <= 0 || summary.min === summary.max) {
+    return { effect: 0, p: 1, z: 0, method: "constant feature not tested" };
+  }
+  if (summary.isBinary01) {
+    let n1 = 0;
+    let y1 = 0;
+    let n0 = 0;
+    let y0 = 0;
+    for (let i = 0; i < n; i++) {
+      if (x[i] === 1) {
+        n1++;
+        y1 += y[i];
+      } else {
+        n0++;
+        y0 += y[i];
+      }
+    }
+    const p1 = y1 / n1;
+    const p0 = y0 / n0;
+    const effect = p1 - p0;
+    const se = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+    const z = effect / se;
+    return { effect, p: normalTwoSided(z), z, n1, n0, p1, p0, method: "two-proportion z-test" };
+  }
+  let sx = 0;
+  let sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0;
+  let sxy = 0;
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const betaRaw = sxy / sxx;
+  const alpha = my - betaRaw * mx;
+  for (let i = 0; i < n; i++) {
+    const e = y[i] - (alpha + betaRaw * x[i]);
+    sse += e * e;
+  }
+  const sd = Math.sqrt(sxx / n);
+  const effect = betaRaw * sd;
+  const seRaw = Math.sqrt((sse / (n - 2)) / sxx);
+  const se = seRaw * sd;
+  const z = effect / se;
+  return { effect, p: normalTwoSided(z), z, meanX: mx, sdX: sd, yMean, method: "linear probability regression per 1 SD" };
+}
+
+function transposeMultiply(X, y = null) {
+  const p = X[0].length;
+  if (y == null) {
+    const out = Array.from({ length: p }, () => Array(p).fill(0));
+    for (const row of X) {
+      for (let j = 0; j < p; j++) {
+        const rj = row[j];
+        for (let k = 0; k < p; k++) out[j][k] += rj * row[k];
+      }
+    }
+    return out;
+  }
+  const out = Array(p).fill(0);
+  for (let i = 0; i < X.length; i++) {
+    for (let j = 0; j < p; j++) out[j] += X[i][j] * y[i];
+  }
+  return out;
+}
+
+function inverse(A) {
+  const n = A.length;
+  const M = A.map((row, i) => [...row, ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))]);
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = M[r][i];
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= factor * M[i][c];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function matVec(A, v) {
+  return A.map((row) => row.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function olsRobust(X, y) {
+  const n = X.length;
+  const p = X[0].length;
+  const xtx = transposeMultiply(X);
+  const xtxInv = inverse(xtx);
+  const xty = transposeMultiply(X, y);
+  const beta = matVec(xtxInv, xty);
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < n; i++) {
+    let fit = 0;
+    for (let j = 0; j < p; j++) fit += X[i][j] * beta[j];
+    const e2 = (y[i] - fit) ** 2;
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) meat[j][k] += e2 * X[i][j] * X[i][k];
+    }
+  }
+  const tmp = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) tmp[i][j] += xtxInv[i][k] * meat[k][j];
+    }
+  }
+  const vcov = Array.from({ length: p }, () => Array(p).fill(0));
+  const scale = n / (n - p);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) vcov[i][j] += tmp[i][k] * xtxInv[k][j] * scale;
+    }
+  }
+  const se = vcov.map((row, i) => Math.sqrt(Math.max(0, row[i])));
+  const pvals = beta.map((b, i) => normalTwoSided(b / se[i]));
+  return { beta, se, p: pvals };
+}
+
+function transformColumn(x, summary) {
+  if (summary.isBinary01) return x.slice();
+  return x.map((v) => (v - summary.mean) / summary.sd);
+}
