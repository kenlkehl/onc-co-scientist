+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+    this.lastField = [];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarint() {
+    let shift = 0n;
+    let result = 0n;
+    for (;;) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  readI32() {
+    return this.zigzag(this.readVarint());
+  }
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readDouble() {
+    const out = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return out;
+  }
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type, id: 0 };
+    const delta = (b & 0xf0) >> 4;
+    const prev = this.lastField[this.lastField.length - 1] || 0;
+    const id = delta === 0 ? this.readI32() : prev + delta;
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+  readStruct() {
+    this.lastField.push(0);
+    const obj = {};
+    for (;;) {
+      const { type, id } = this.readFieldBegin();
+      if (type === 0) break;
+      obj[id] = this.readValue(type);
+    }
+    this.lastField.pop();
+    return obj;
+  }
+  readList() {
+    const b = this.readByte();
+    let size = (b & 0xf0) >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(this.readValue(elemType));
+    return arr;
+  }
+  readValue(type) {
+    if (type === 1) return true;
+    if (type === 2) return false;
+    if (type === 3 || type === 4 || type === 5) return this.readI32();
+    if (type === 6) return this.readI64();
+    if (type === 7) return this.readDouble();
+    if (type === 8) return this.readBinary();
+    if (type === 9 || type === 10) return this.readList();
+    if (type === 12) return this.readStruct();
+    throw new Error(`Unsupported compact thrift type ${type} at ${this.pos}`);
+  }
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let shift = 0;
+  let len = 0;
+  for (;;) {
+    const b = input[pos++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let n = tag >> 2;
+      if (n < 60) {
+        n += 1;
+      } else {
+        const bytes = n - 59;
+        n = 0;
+        for (let i = 0; i < bytes; i++) n |= input[pos++] << (8 * i);
+        n += 1;
+      }
+      input.copy(out, op, pos, pos + n);
+      pos += n;
+      op += n;
+    } else {
+      let n;
+      let off;
+      if (type === 1) {
+        n = ((tag >> 2) & 7) + 4;
+        off = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        n = (tag >> 2) + 1;
+        off = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        n = (tag >> 2) + 1;
+        off =
+          (input[pos] |
+            (input[pos + 1] << 8) |
+            (input[pos + 2] << 16) |
+            (input[pos + 3] << 24)) >>>
+          0;
+        pos += 4;
+      }
+      for (let i = 0; i < n; i++) out[op + i] = out[op - off + i];
+      op += n;
+    }
+  }
+  if (op !== len) throw new Error(`Snappy output length mismatch ${op} != ${len}`);
+  return out;
+}
+
+function readUnsignedVarint(buf, pos) {
+  let shift = 0;
+  let out = 0;
+  for (;;) {
+    const b = buf[pos++];
+    out |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: out, pos };
+}
+
+function readBitPackedValues(buf, pos, count, bitWidth) {
+  const values = [];
+  if (bitWidth === 0) {
+    for (let i = 0; i < count; i++) values.push(0);
+    return { values, pos };
+  }
+  let bitPos = pos * 8;
+  for (let i = 0; i < count; i++) {
+    let v = 0;
+    for (let b = 0; b < bitWidth; b++) {
+      const absolute = bitPos + b;
+      const bit = (buf[absolute >> 3] >> (absolute & 7)) & 1;
+      v |= bit << b;
+    }
+    values.push(v);
+    bitPos += bitWidth;
+  }
+  return { values, pos: Math.ceil(bitPos / 8) };
+}
+
+function decodeHybrid(buf, pos, count, bitWidth, endPos = buf.length) {
+  const out = [];
+  const bytesForValue = Math.ceil(bitWidth / 8);
+  while (out.length < count && pos < endPos) {
+    const header = readUnsignedVarint(buf, pos);
+    pos = header.pos;
+    if ((header.value & 1) === 0) {
+      const runLength = header.value >> 1;
+      let value = 0;
+      for (let i = 0; i < bytesForValue; i++) value |= buf[pos++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header.value >> 1;
+      const runCount = groups * 8;
+      const decoded = readBitPackedValues(buf, pos, runCount, bitWidth);
+      pos = decoded.pos;
+      for (const v of decoded.values) {
+        if (out.length >= count) break;
+        out.push(v);
+      }
+    }
+  }
+  if (out.length !== count) throw new Error(`Hybrid decode length ${out.length} != ${count}`);
+  return { values: out, pos };
+}
+
+function decodePlainValues(buf, parquetType, count) {
+  const out = [];
+  let pos = 0;
+  for (let i = 0; i < count; i++) {
+    if (parquetType === 5) {
+      out.push(buf.readDoubleLE(pos));
+      pos += 8;
+    } else if (parquetType === 2) {
+      out.push(Number(buf.readBigInt64LE(pos)));
+      pos += 8;
+    } else if (parquetType === 1) {
+      out.push(buf.readInt32LE(pos));
+      pos += 4;
+    } else if (parquetType === 6) {
+      const len = buf.readInt32LE(pos);
+      pos += 4;
+      out.push(buf.subarray(pos, pos + len).toString("utf8"));
+      pos += len;
+    } else {
+      throw new Error(`Unsupported parquet physical type ${parquetType}`);
+    }
+  }
+  return out;
+}
