+        off = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        n = (tag >> 2) + 1;
+        off = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        n = (tag >> 2) + 1;
+        off =
