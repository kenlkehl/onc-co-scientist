+function parseFooter(fileBuf) {
+  if (fileBuf.subarray(0, 4).toString("ascii") !== "PAR1") {
+    throw new Error("Missing Parquet magic at start");
+  }
+  if (fileBuf.subarray(fileBuf.length - 4).toString("ascii") !== "PAR1") {
