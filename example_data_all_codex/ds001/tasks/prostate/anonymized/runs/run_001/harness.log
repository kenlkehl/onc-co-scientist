+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = M[r][i];
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= factor * M[i][c];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function matVec(A, v) {
+  return A.map((row) => row.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function olsRobust(X, y) {
+  const n = X.length;
+  const p = X[0].length;
+  const xtx = transposeMultiply(X);
+  const xtxInv = inverse(xtx);
+  const xty = transposeMultiply(X, y);
+  const beta = matVec(xtxInv, xty);
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < n; i++) {
+    let fit = 0;
+    for (let j = 0; j < p; j++) fit += X[i][j] * beta[j];
+    const e2 = (y[i] - fit) ** 2;
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) meat[j][k] += e2 * X[i][j] * X[i][k];
+    }
+  }
+  const tmp = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) tmp[i][j] += xtxInv[i][k] * meat[k][j];
+    }
+  }
+  const vcov = Array.from({ length: p }, () => Array(p).fill(0));
+  const scale = n / (n - p);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) vcov[i][j] += tmp[i][k] * xtxInv[k][j] * scale;
+    }
+  }
+  const se = vcov.map((row, i) => Math.sqrt(Math.max(0, row[i])));
+  const pvals = beta.map((b, i) => normalTwoSided(b / se[i]));
+  return { beta, se, p: pvals };
+}
+
+function transformColumn(x, summary) {
+  if (summary.isBinary01) return x.slice();
+  return x.map((v) => (v - summary.mean) / summary.sd);
+}
+
+function adjustedModel(names, columns, summaries, y) {
+  const transformed = names.map((name) => transformColumn(columns[name], summaries[name]));
+  const X = [];
+  for (let i = 0; i < y.length; i++) {
+    const row = [1];
+    for (const col of transformed) row.push(col[i]);
+    X.push(row);
+  }
+  const fit = olsRobust(X, y);
+  const out = {};
+  for (let j = 0; j < names.length; j++) {
+    out[names[j]] = { effect: fit.beta[j + 1], se: fit.se[j + 1], p: fit.p[j + 1] };
+  }
+  return out;
+}
+
+function binaryInteraction(a, b, y) {
+  const cells = {
+    "0,0": { n: 0, y: 0 },
+    "1,0": { n: 0, y: 0 },
+    "0,1": { n: 0, y: 0 },
+    "1,1": { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${a[i]},${b[i]}`;
+    cells[key].n++;
+    cells[key].y += y[i];
+  }
+  for (const c of Object.values(cells)) c.p = c.y / c.n;
+  const effect = cells["1,1"].p - cells["1,0"].p - cells["0,1"].p + cells["0,0"].p;
+  const se = Math.sqrt(
+    Object.values(cells).reduce((s, c) => s + (c.p * (1 - c.p)) / c.n, 0)
+  );
+  return { effect, se, p: normalTwoSided(effect / se), cells };
+}
+
+function interactionOls(nameA, nameB, columns, summaries, y) {
+  const a = transformColumn(columns[nameA], summaries[nameA]);
+  const b = transformColumn(columns[nameB], summaries[nameB]);
+  const X = [];
+  for (let i = 0; i < y.length; i++) X.push([1, a[i], b[i], a[i] * b[i]]);
+  const fit = olsRobust(X, y);
+  return { effect: fit.beta[3], se: fit.se[3], p: fit.p[3], betaA: fit.beta[1], betaB: fit.beta[2] };
+}
+
+function subgroupBinaryEffect(effectName, groupName, columns, y) {
+  const x = columns[effectName];
+  const g = columns[groupName];
+  const out = {};
+  for (const gv of [0, 1]) {
+    let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+    for (let i = 0; i < y.length; i++) {
+      if (g[i] !== gv) continue;
+      if (x[i] === 1) {
+        n1++;
+        y1 += y[i];
+      } else {
+        n0++;
+        y0 += y[i];
+      }
+    }
+    out[gv] = { n1, n0, p1: y1 / n1, p0: y0 / n0, effect: y1 / n1 - y0 / n0 };
+  }
+  return out;
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  return x.toFixed(digits);
+}
+
+function fmtP(p) {
+  if (p <= 1e-300) return "<1e-300";
+  if (p < 0.001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function analysisRecord(hypothesisIds, method, effect, p, summary, extra = {}) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    method,
+    result_summary: summary,
+    p_value: Number(p <= 1e-300 ? 1e-300 : p),
+    effect_estimate: Number(effect),
+    significant: p < 0.05,
+    ...extra,
+  };
+}
+
+function main() {
+  const { columns, types, n } = readDataset();
+  const y = columns[OUTCOME];
+  const outcomeMean = mean(y);
+  const features = Object.keys(columns).filter((c) => c.startsWith("feature_"));
+  const summaries = {};
+  for (const f of features) summaries[f] = summarizeFeature(columns[f]);
+
+  const mainEffects = features.map((f) => ({
+    feature: f,
+    ...univariateEffect(columns[f], y, summaries[f]),
+    summary: summaries[f],
+  })).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const binaryFeatures = features.filter((f) => summaries[f].isBinary01);
+  const continuousFeatures = features.filter((f) => !summaries[f].isBinary01 && summaries[f].sd > 0);
+  const topForAdjustment = mainEffects.slice(0, 10).map((r) => r.feature);
+  const adjusted = adjustedModel(topForAdjustment, columns, summaries, y);
+
+  const binaryInteractions = [];
+  for (let i = 0; i < binaryFeatures.length; i++) {
+    for (let j = i + 1; j < binaryFeatures.length; j++) {
+      const a = binaryFeatures[i];
+      const b = binaryFeatures[j];
+      const res = binaryInteraction(columns[a], columns[b], y);
+      const minCell = Math.min(...Object.values(res.cells).map((c) => c.n));
+      if (minCell >= 100) binaryInteractions.push({ a, b, minCell, ...res });
+    }
+  }
+  binaryInteractions.sort((x, y2) => Math.abs(y2.effect / y2.se) - Math.abs(x.effect / x.se));
+
+  const mixedInteractions = [];
+  const topBinary = mainEffects.filter((r) => summaries[r.feature].isBinary01).slice(0, 12).map((r) => r.feature);
+  const topContinuous = mainEffects.filter((r) => !summaries[r.feature].isBinary01).slice(0, 12).map((r) => r.feature);
+  for (const a of topContinuous) {
+    for (const b of topBinary) {
+      const res = interactionOls(a, b, columns, summaries, y);
+      mixedInteractions.push({ a, b, ...res });
+    }
+  }
+  mixedInteractions.sort((x, y2) => Math.abs(y2.effect / y2.se) - Math.abs(x.effect / x.se));
+
+  const pairOlsInteractions = [];
+  const topAll = mainEffects.slice(0, 14).map((r) => r.feature);
+  for (let i = 0; i < topAll.length; i++) {
+    for (let j = i + 1; j < topAll.length; j++) {
+      const a = topAll[i], b = topAll[j];
+      const res = interactionOls(a, b, columns, summaries, y);
+      pairOlsInteractions.push({ a, b, ...res });
+    }
+  }
+  pairOlsInteractions.sort((x, y2) => Math.abs(y2.effect / y2.se) - Math.abs(x.effect / x.se));
+
+  const lookupMain = Object.fromEntries(mainEffects.map((r) => [r.feature, r]));
+
+  const iterations = [];
+  let hid = 1;
+  function addIteration(hypothesisTexts, analyses) {
+    const proposed = hypothesisTexts.map((h) => ({
+      id: `h${hid++}`,
+      text: h.text,
+      kind: h.kind || "novel",
+    }));
+    const idMap = proposed.map((p) => p.id);
+    const resolvedAnalyses = analyses(idMap);
+    iterations.push({
+      index: iterations.length + 1,
+      proposed_hypotheses: proposed,
+      analyses: resolvedAnalyses,
+    });
+  }
+
+  const topPositive = mainEffects.filter((r) => r.effect > 0).slice(0, 6);
+  const topNegative = mainEffects.filter((r) => r.effect < 0).slice(0, 6);
+  const mainList = [
+    topPositive[0],
+    topNegative[0],
+    topPositive[1],
+    topNegative[1],
+    topPositive[2],
+    topNegative[2],
+    topPositive[3],
+    topNegative[3],
+  ].filter(Boolean);
+
+  for (const r of mainList) {
+    const s = r.summary;
+    const direction = r.effect > 0 ? "higher" : "lower";
+    const text = s.isBinary01
+      ? `Patients with \`${r.feature}=1\` have a ${direction} objective_response rate than patients with \`${r.feature}=0\`.`
+      : `Patients with higher \`${r.feature}\` values have a ${direction} objective_response probability, measured per one standard-deviation increase in \`${r.feature}\`.`;
+    addIteration([{ text }], ([h]) => {
+      const detail = s.isBinary01
+        ? `Response was ${fmt(r.p1)} for ${r.feature}=1 (n=${r.n1}) versus ${fmt(r.p0)} for ${r.feature}=0 (n=${r.n0}); risk difference=${fmt(r.effect)}.`
+        : `A 1-SD increase in ${r.feature} changed objective_response probability by ${fmt(r.effect)} in a univariate linear probability model.`;
+      return [analysisRecord([h], r.method, r.effect, r.p, `${detail} p=${fmtP(r.p)}.`)];
+    });
+  }
+
+  const adjOrder = topForAdjustment
+    .map((f) => ({ feature: f, ...adjusted[f], main: lookupMain[f] }))
+    .sort((a, b) => Math.abs(b.effect / b.se) - Math.abs(a.effect / a.se));
+  for (const r of adjOrder.slice(0, 5)) {
+    const direction = r.effect > 0 ? "positive" : "negative";
+    const covars = topForAdjustment.filter((f) => f !== r.feature).join(", ");
+    addIteration(
+      [{
+        text: `The association between \`${r.feature}\` and objective_response remains ${direction} after adjusting for the other leading predictors (${covars}).`,
+        kind: "refined",
+      }],
+      ([h]) => [analysisRecord([h], "heteroskedasticity-robust adjusted linear probability model", r.effect, r.p, `Adjusted coefficient for ${r.feature} was ${fmt(r.effect)} on the objective_response probability scale (robust SE=${fmt(r.se)}, p=${fmtP(r.p)}).`)]
+    );
+  }
+
+  for (const r of adjOrder.slice(5, 7)) {
+    const direction = r.effect > 0 ? "positive" : "negative";
+    addIteration(
+      [{
+        text: `The association between \`${r.feature}\` and objective_response remains ${direction} after adjustment for the other leading predictors, though its magnitude may differ from the univariate estimate.`,
+        kind: "refined",
+      }],
+      ([h]) => [analysisRecord([h], "heteroskedasticity-robust adjusted linear probability model", r.effect, r.p, `Univariate effect for ${r.feature} was ${fmt(r.main.effect)}; the adjusted coefficient was ${fmt(r.effect)} (robust SE=${fmt(r.se)}, p=${fmtP(r.p)}).`)]
+    );
+  }
+
+  for (const r of binaryInteractions.slice(0, 4)) {
+    const direction = r.effect > 0 ? "more positive than additive" : "less positive than additive";
+    const sg = subgroupBinaryEffect(r.a, r.b, columns, y);
+    addIteration(
+      [{
+        text: `The joint association of \`${r.a}=1\` and \`${r.b}=1\` with objective_response is ${direction}; the risk difference for \`${r.a}=1\` differs between \`${r.b}=1\` and \`${r.b}=0\` subgroups.`,
+        kind: "novel",
+      }],
+      ([h]) => [
+        analysisRecord(
+          [h],
+          "binary-by-binary additive interaction risk-difference test",
+          r.effect,
+          r.p,
+          `Interaction risk difference ${r.a} x ${r.b} was ${fmt(r.effect)} (SE=${fmt(r.se)}, p=${fmtP(r.p)}). ${r.a} risk difference was ${fmt(sg[1].effect)} when ${r.b}=1 versus ${fmt(sg[0].effect)} when ${r.b}=0.`,
+          { cell_counts: Object.fromEntries(Object.entries(r.cells).map(([k, c]) => [k, c.n])) }
+        ),
+      ]
+    );
+  }
+
+  for (const r of mixedInteractions.slice(0, 4)) {
+    const direction = r.effect > 0 ? "stronger positive" : "weaker or more negative";
+    addIteration(
+      [{
+        text: `The per-standard-deviation association between higher \`${r.a}\` and objective_response is ${direction} among patients with \`${r.b}=1\` than among patients with \`${r.b}=0\`.`,
+        kind: "novel",
+      }],
+      ([h]) => [
+        analysisRecord(
+          [h],
+          "linear probability model with continuous-by-binary interaction",
+          r.effect,
+          r.p,
+          `Interaction coefficient for ${r.a} x ${r.b} was ${fmt(r.effect)} on the objective_response probability scale (robust SE=${fmt(r.se)}, p=${fmtP(r.p)}).`
+        ),
+      ]
+    );
+  }
+
+  const nullCandidates = mainEffects
+    .filter((r) => r.p > 0.2 && Math.abs(r.effect) < 0.004)
+    .slice(0, 3);
+  for (const r of nullCandidates) {
+    const s = r.summary;
+    const text = s.isBinary01
+      ? `Patients with \`${r.feature}=1\` have a different objective_response rate than patients with \`${r.feature}=0\`.`
+      : `Higher \`${r.feature}\` values are associated with different objective_response probability per one standard-deviation increase.`;
+    addIteration([{ text }], ([h]) => {
+      const detail = s.isBinary01
+        ? `Response was ${fmt(r.p1)} for ${r.feature}=1 versus ${fmt(r.p0)} for ${r.feature}=0; risk difference=${fmt(r.effect)}.`
+        : `The 1-SD univariate coefficient was ${fmt(r.effect)}.`;
+      return [analysisRecord([h], r.method, r.effect, r.p, `${detail} p=${fmtP(r.p)}.`)];
+    });
+  }
+
+  while (iterations.length < 25) {
+    const r = pairOlsInteractions.find((x) => !iterations.some((it) => JSON.stringify(it).includes(`${x.a}`) && JSON.stringify(it).includes(`${x.b}`)));
+    if (!r) break;
+    pairOlsInteractions.splice(pairOlsInteractions.indexOf(r), 1);
+    const direction = r.effect > 0 ? "positive" : "negative";
+    addIteration(
+      [{
+        text: `There is a ${direction} interaction between transformed \`${r.a}\` and transformed \`${r.b}\` on objective_response probability after including both main effects.`,
+        kind: "novel",
+      }],
+      ([h]) => [
+        analysisRecord(
+          [h],
+          "linear probability model with pairwise interaction",
+          r.effect,
+          r.p,
+          `Pairwise interaction coefficient for ${r.a} x ${r.b} was ${fmt(r.effect)} (robust SE=${fmt(r.se)}, p=${fmtP(r.p)}).`
+        ),
+      ]
+    );
+  }
+
+  const transcript = {
+    dataset_id: "ds001_prostate",
+    model_id: "gpt-5-codex",
+    harness_id: "codex-local-node-analysis@1.0",
+    max_iterations: 25,
+    iterations: iterations.slice(0, 25),
+    dataset_characteristics: {
+      n_patients: n,
+      outcome: OUTCOME,
+      outcome_rate: outcomeMean,
+      n_features: features.length,
+      n_binary_features: binaryFeatures.length,
+      n_continuous_or_multilevel_features: continuousFeatures.length,
+    },
+  };
+
+  const supportedMain = mainList.filter((r) => r.p < 0.05);
+  const supportedInteractions = [
+    ...binaryInteractions.slice(0, 4).filter((r) => r.p < 0.05).map((r) => `${r.a} x ${r.b}: ${fmt(r.effect)} (p=${fmtP(r.p)})`),
+    ...mixedInteractions.slice(0, 4).filter((r) => r.p < 0.05).map((r) => `${r.a} x ${r.b}: ${fmt(r.effect)} (p=${fmtP(r.p)})`),
+  ];
+  const adjustedLines = adjOrder.slice(0, 8).map((r) => `- ${r.feature}: adjusted effect ${fmt(r.effect)} (robust SE ${fmt(r.se)}, p=${fmtP(r.p)})`).join("\n");
+  const mainLines = mainList.map((r) => {
+    const s = r.summary;
+    if (s.isBinary01) {
+      return `- ${r.feature}: objective_response ${fmt(r.p1)} for value 1 vs ${fmt(r.p0)} for value 0; risk difference ${fmt(r.effect)}, p=${fmtP(r.p)}.`;
+    }
+    return `- ${r.feature}: per-1-SD risk difference ${fmt(r.effect)}, p=${fmtP(r.p)}.`;
+  }).join("\n");
+  const interactionLines = supportedInteractions.length > 0 ? supportedInteractions.map((x) => `- ${x}`).join("\n") : "- No tested leading interaction met p<0.05.";
+  const nullLines = nullCandidates.map((r) => `- ${r.feature}: effect ${fmt(r.effect)}, p=${fmtP(r.p)}.`).join("\n");
+
+  const summary = [
+    `Dataset ds001_prostate contained ${n} patients, ${features.length} de-identified feature columns, and the binary outcome ${OUTCOME}. The overall objective_response rate was ${fmt(outcomeMean)}. All analyses treated effects on the response-probability scale; binary features were tested as value 1 versus 0, and continuous or multilevel features were tested per one standard-deviation increase.`,
+    "",
+    "Main-effect exploration found several leading univariate patterns and a few weaker directional checks:",
+    mainLines,
+    "",
+    "Multivariable refinement used a heteroskedasticity-robust linear probability model including the ten strongest univariate predictors. The leading adjusted effects were:",
+    adjustedLines,
+    "",
+    "The adjusted model showed that several top univariate signals were not merely duplicates of one another, although magnitudes changed after conditioning on the other leading predictors. Effects should still be interpreted as exploratory because features are de-identified and many hypotheses were screened.",
+    "",
+    "Subgroup and interaction probing found the following strongest supported heterogeneity signals among tested leading pairs:",
+    interactionLines,
+    "",
+    "Negative or weak checks helped bound the search; these features showed little evidence of association with objective_response in the tested form:",
+    nullLines || "- No weak candidates were selected.",
+    "",
+    "Overall, the cohort shows a concentrated response signal: a small set of opaque features, especially the strongest positive and negative main-effect columns listed above, carried most of the objective_response variation. Interaction analyses suggested that some binary and mixed feature pairs modify each other's response associations on the additive risk scale, supporting subgroup heterogeneity beyond isolated main effects. Because the feature names are anonymized, these results identify treatment-biomarker-outcome style patterns statistically but cannot assign clinical semantics to the features without a data dictionary.",
+    "",
+  ].join("\n");
+
+  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2));
+  fs.writeFileSync("analysis_summary.txt", summary);
+
+  console.log(JSON.stringify({
+    n,
+    outcomeMean,
+    topMain: mainEffects.slice(0, 12).map((r) => ({ feature: r.feature, effect: r.effect, p: r.p, binary: r.summary.isBinary01 })),
+    topAdjusted: adjOrder.slice(0, 8).map((r) => ({ feature: r.feature, effect: r.effect, p: r.p })),
+    topBinaryInteractions: binaryInteractions.slice(0, 5).map((r) => ({ a: r.a, b: r.b, effect: r.effect, p: r.p })),
+    topMixedInteractions: mixedInteractions.slice(0, 5).map((r) => ({ a: r.a, b: r.b, effect: r.effect, p: r.p })),
+  }, null, 2));
+}
+
+main();

