+}
+
+function main() {
+  const { columns, types, n } = readDataset();
+  const y = columns[OUTCOME];
+  const outcomeMean = mean(y);
+  const features = Object.keys(columns).filter((c) => c.startsWith("feature_"));
+  const summaries = {};
+  for (const f of features) summaries[f] = summarizeFeature(columns[f]);
+
+  const mainEffects = features.map((f) => ({
+    feature: f,
+    ...univariateEffect(columns[f], y, summaries[f]),
+    summary: summaries[f],
+  })).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const binaryFeatures = features.filter((f) => summaries[f].isBinary01);
+  const continuousFeatures = features.filter((f) => !summaries[f].isBinary01 && summaries[f].sd > 0);
