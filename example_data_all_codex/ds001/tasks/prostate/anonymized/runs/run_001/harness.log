+  const topPositive = mainEffects.filter((r) => r.effect > 0).slice(0, 6);
+  const topNegative = mainEffects.filter((r) => r.effect < 0).slice(0, 6);
+  const mainList = [
+    topPositive[0],
+    topNegative[0],
+    topPositive[1],
+    topNegative[1],
+    topPositive[2],
+    topNegative[2],
+    topPositive[3],
+    topNegative[3],
+  ].filter(Boolean);
+
+  for (const r of mainList) {
+    const s = r.summary;
+    const direction = r.effect > 0 ? "higher" : "lower";
+    const text = s.isBinary01
+      ? `Patients with \`${r.feature}=1\` have a ${direction} objective_response rate than patients with \`${r.feature}=0\`.`
+      : `Patients with higher \`${r.feature}\` values have a ${direction} objective_response probability, measured per one standard-deviation increase in \`${r.feature}\`.`;
+    addIteration([{ text }], ([h]) => {
+      const detail = s.isBinary01
