+      id: `h${hid++}`,
+      text: h.text,
+      kind: h.kind || "novel",
+    }));
+    const idMap = proposed.map((p) => p.id);
+    const resolvedAnalyses = analyses(idMap);
+    iterations.push({
+      index: iterations.length + 1,
+      proposed_hypotheses: proposed,
+      analyses: resolvedAnalyses,
+    });
+  }
+
+  const topPositive = mainEffects.filter((r) => r.effect > 0).slice(0, 6);
+  const topNegative = mainEffects.filter((r) => r.effect < 0).slice(0, 6);
+  const mainList = [
+    topPositive[0],
+    topNegative[0],
+    topPositive[1],
+    topNegative[1],
+    topPositive[2],
+    topNegative[2],
+    topPositive[3],
+    topNegative[3],
+  ].filter(Boolean);
+
+  for (const r of mainList) {
+    const s = r.summary;
+    const direction = r.effect > 0 ? "higher" : "lower";
+    const text = s.isBinary01
+      ? `Patients with \`${r.feature}=1\` have a ${direction} objective_response rate than patients with \`${r.feature}=0\`.`
+      : `Patients with higher \`${r.feature}\` values have a ${direction} objective_response probability, measured per one standard-deviation increase in \`${r.feature}\`.`;
+    addIteration([{ text }], ([h]) => {
+      const detail = s.isBinary01
+        ? `Response was ${fmt(r.p1)} for ${r.feature}=1 (n=${r.n1}) versus ${fmt(r.p0)} for ${r.feature}=0 (n=${r.n0}); risk difference=${fmt(r.effect)}.`
