+    addIteration(
+      [{
+        text: `The association between \`${r.feature}\` and objective_response remains ${direction} after adjusting for the other leading predictors (${covars}).`,
+        kind: "refined",
+      }],
+      ([h]) => [analysisRecord([h], "heteroskedasticity-robust adjusted linear probability model", r.effect, r.p, `Adjusted coefficient for ${r.feature} was ${fmt(r.effect)} on the objective_response probability scale (robust SE=${fmt(r.se)}, p=${fmtP(r.p)}).`)]
+    );
+  }
+
+  for (const r of adjOrder.slice(5, 7)) {
+    const direction = r.effect > 0 ? "positive" : "negative";
+    addIteration(
+      [{
+        text: `The association between \`${r.feature}\` and objective_response remains ${direction} after adjustment for the other leading predictors, though its magnitude may differ from the univariate estimate.`,
+        kind: "refined",
+      }],
+      ([h]) => [analysisRecord([h], "heteroskedasticity-robust adjusted linear probability model", r.effect, r.p, `Univariate effect for ${r.feature} was ${fmt(r.main.effect)}; the adjusted coefficient was ${fmt(r.effect)} (robust SE=${fmt(r.se)}, p=${fmtP(r.p)}).`)]
