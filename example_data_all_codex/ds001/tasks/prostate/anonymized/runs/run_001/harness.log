+    let y1 = 0;
+    let n0 = 0;
+    let y0 = 0;
+    for (let i = 0; i < n; i++) {
+      if (x[i] === 1) {
+        n1++;
+        y1 += y[i];
+      } else {
+        n0++;
+        y0 += y[i];
+      }
+    }
+    const p1 = y1 / n1;
+    const p0 = y0 / n0;
+    const effect = p1 - p0;
+    const se = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+    const z = effect / se;
+    return { effect, p: normalTwoSided(z), z, n1, n0, p1, p0, method: "two-proportion z-test" };
+  }
+  let sx = 0;
+  let sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0;
+  let sxy = 0;
+  let sse = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const betaRaw = sxy / sxx;
+  const alpha = my - betaRaw * mx;
+  for (let i = 0; i < n; i++) {
+    const e = y[i] - (alpha + betaRaw * x[i]);
+    sse += e * e;
+  }
