+    hypothesis_ids: hypothesisIds,
+    method,
+    result_summary: summary,
+    p_value: Number(p <= 1e-300 ? 1e-300 : p),
+    effect_estimate: Number(effect),
+    significant: p < 0.05,
+    ...extra,
+  };
+}
