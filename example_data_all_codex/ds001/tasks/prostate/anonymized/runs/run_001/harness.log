+const fs = require("fs");
+
+const DATASET = "dataset.parquet";
+const OUTCOME = "objective_response";
+const NORM_MIN_P = 1e-300;
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+    this.lastField = [];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarint() {
+    let shift = 0n;
+    let result = 0n;
+    for (;;) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  zigzag(n) {
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  readI32() {
+    return this.zigzag(this.readVarint());
+  }
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readDouble() {
+    const out = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return out;
+  }
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type, id: 0 };
+    const delta = (b & 0xf0) >> 4;
+    const prev = this.lastField[this.lastField.length - 1] || 0;
+    const id = delta === 0 ? this.readI32() : prev + delta;
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+  readStruct() {
+    this.lastField.push(0);
+    const obj = {};
+    for (;;) {
+      const { type, id } = this.readFieldBegin();
+      if (type === 0) break;
+      obj[id] = this.readValue(type);
+    }
