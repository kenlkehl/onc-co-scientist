+  const adjusted = adjustedModel(topForAdjustment, columns, summaries, y);
+
+  const binaryInteractions = [];
+  for (let i = 0; i < binaryFeatures.length; i++) {
+    for (let j = i + 1; j < binaryFeatures.length; j++) {
+      const a = binaryFeatures[i];
+      const b = binaryFeatures[j];
+      const res = binaryInteraction(columns[a], columns[b], y);
+      const minCell = Math.min(...Object.values(res.cells).map((c) => c.n));
+      if (minCell >= 100) binaryInteractions.push({ a, b, minCell, ...res });
+    }
+  }
+  binaryInteractions.sort((x, y2) => Math.abs(y2.effect / y2.se) - Math.abs(x.effect / x.se));
+
+  const mixedInteractions = [];
+  const topBinary = mainEffects.filter((r) => summaries[r.feature].isBinary01).slice(0, 12).map((r) => r.feature);
+  const topContinuous = mainEffects.filter((r) => !summaries[r.feature].isBinary01).slice(0, 12).map((r) => r.feature);
+  for (const a of topContinuous) {
+    for (const b of topBinary) {
+      const res = interactionOls(a, b, columns, summaries, y);
+      mixedInteractions.push({ a, b, ...res });
+    }
+  }
+  mixedInteractions.sort((x, y2) => Math.abs(y2.effect / y2.se) - Math.abs(x.effect / x.se));
+
+  const pairOlsInteractions = [];
+  const topAll = mainEffects.slice(0, 14).map((r) => r.feature);
+  for (let i = 0; i < topAll.length; i++) {
+    for (let j = i + 1; j < topAll.length; j++) {
+      const a = topAll[i], b = topAll[j];
+      const res = interactionOls(a, b, columns, summaries, y);
+      pairOlsInteractions.push({ a, b, ...res });
+    }
+  }
+  pairOlsInteractions.sort((x, y2) => Math.abs(y2.effect / y2.se) - Math.abs(x.effect / x.se));
