+  if (fileBuf.subarray(fileBuf.length - 4).toString("ascii") !== "PAR1") {
+    throw new Error("Missing Parquet magic at end");
+  }
+  const footerLen = fileBuf.readUInt32LE(fileBuf.length - 8);
+  const footer = fileBuf.subarray(fileBuf.length - 8 - footerLen, fileBuf.length - 8);
+  return new CompactReader(footer).readStruct();
+}
+
+function decodeColumn(fileBuf, columnChunk, parquetType) {
+  const md = columnChunk[3];
+  const codec = md[4];
+  if (codec !== 1) throw new Error(`Only Snappy columns are handled; codec=${codec}`);
+  const dictionary = [];
+  let pos = md[11];
+  if (pos != null) {
+    const headerReader = new CompactReader(fileBuf, pos);
+    const pageHeader = headerReader.readStruct();
+    const payloadStart = headerReader.pos;
+    const compressed = fileBuf.subarray(payloadStart, payloadStart + pageHeader[3]);
+    const uncompressed = snappyUncompress(compressed);
+    if (pageHeader[1] !== 2) throw new Error("Expected dictionary page");
+    const dictHeader = pageHeader[7];
+    dictionary.push(...decodePlainValues(uncompressed, parquetType, dictHeader[1]));
+    pos = payloadStart + pageHeader[3];
+  }
+
+  pos = md[9];
+  const values = [];
+  const totalValues = md[5];
+  while (values.length < totalValues) {
+    const headerReader = new CompactReader(fileBuf, pos);
+    const pageHeader = headerReader.readStruct();
+    const payloadStart = headerReader.pos;
+    const compressed = fileBuf.subarray(payloadStart, payloadStart + pageHeader[3]);
+    const page = snappyUncompress(compressed);
+    if (pageHeader[1] !== 0) {
+      throw new Error(`Unexpected page type ${pageHeader[1]} in data stream`);
+    }
+    const dph = pageHeader[5];
+    const numValues = dph[1];
+    let pagePos = 0;
+    const defLen = page.readUInt32LE(pagePos);
+    pagePos += 4;
+    const defDecoded = decodeHybrid(page, pagePos, numValues, 1, pagePos + defLen);
+    pagePos += defLen;
+    let nonNull = 0;
+    for (const d of defDecoded.values) if (d === 1) nonNull++;
