+      ]
+    );
+  }
+
+  for (const r of mixedInteractions.slice(0, 4)) {
+    const direction = r.effect > 0 ? "stronger positive" : "weaker or more negative";
+    addIteration(
+      [{
+        text: `The per-standard-deviation association between higher \`${r.a}\` and objective_response is ${direction} among patients with \`${r.b}=1\` than among patients with \`${r.b}=0\`.`,
+        kind: "novel",
+      }],
+      ([h]) => [
+        analysisRecord(
+          [h],
+          "linear probability model with continuous-by-binary interaction",
+          r.effect,
+          r.p,
+          `Interaction coefficient for ${r.a} x ${r.b} was ${fmt(r.effect)} on the objective_response probability scale (robust SE=${fmt(r.se)}, p=${fmtP(r.p)}).`
+        ),
+      ]
+    );
+  }
