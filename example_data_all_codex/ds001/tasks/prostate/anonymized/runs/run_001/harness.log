+      for (let i = 0; i < bytesForValue; i++) value |= buf[pos++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header.value >> 1;
+      const runCount = groups * 8;
+      const decoded = readBitPackedValues(buf, pos, runCount, bitWidth);
+      pos = decoded.pos;
+      for (const v of decoded.values) {
+        if (out.length >= count) break;
+        out.push(v);
+      }
+    }
+  }
+  if (out.length !== count) throw new Error(`Hybrid decode length ${out.length} != ${count}`);
+  return { values: out, pos };
+}
+
+function decodePlainValues(buf, parquetType, count) {
+  const out = [];
+  let pos = 0;
+  for (let i = 0; i < count; i++) {
+    if (parquetType === 5) {
+      out.push(buf.readDoubleLE(pos));
+      pos += 8;
+    } else if (parquetType === 2) {
+      out.push(Number(buf.readBigInt64LE(pos)));
+      pos += 8;
+    } else if (parquetType === 1) {
+      out.push(buf.readInt32LE(pos));
+      pos += 4;
+    } else if (parquetType === 6) {
+      const len = buf.readInt32LE(pos);
+      pos += 4;
+      out.push(buf.subarray(pos, pos + len).toString("utf8"));
+      pos += len;
+    } else {
+      throw new Error(`Unsupported parquet physical type ${parquetType}`);
+    }
