+
+function transposeMultiply(X, y = null) {
+  const p = X[0].length;
+  if (y == null) {
+    const out = Array.from({ length: p }, () => Array(p).fill(0));
+    for (const row of X) {
+      for (let j = 0; j < p; j++) {
+        const rj = row[j];
+        for (let k = 0; k < p; k++) out[j][k] += rj * row[k];
+      }
+    }
+    return out;
+  }
+  const out = Array(p).fill(0);
+  for (let i = 0; i < X.length; i++) {
+    for (let j = 0; j < p; j++) out[j] += X[i][j] * y[i];
+  }
+  return out;
+}
+
+function inverse(A) {
+  const n = A.length;
+  const M = A.map((row, i) => [...row, ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))]);
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = M[r][i];
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= factor * M[i][c];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function matVec(A, v) {
+  return A.map((row) => row.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function olsRobust(X, y) {
+  const n = X.length;
+  const p = X[0].length;
+  const xtx = transposeMultiply(X);
+  const xtxInv = inverse(xtx);
+  const xty = transposeMultiply(X, y);
+  const beta = matVec(xtxInv, xty);
+  const meat = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < n; i++) {
+    let fit = 0;
+    for (let j = 0; j < p; j++) fit += X[i][j] * beta[j];
+    const e2 = (y[i] - fit) ** 2;
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) meat[j][k] += e2 * X[i][j] * X[i][k];
+    }
+  }
+  const tmp = Array.from({ length: p }, () => Array(p).fill(0));
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) tmp[i][j] += xtxInv[i][k] * meat[k][j];
+    }
+  }
+  const vcov = Array.from({ length: p }, () => Array(p).fill(0));
+  const scale = n / (n - p);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) {
+      for (let k = 0; k < p; k++) vcov[i][j] += tmp[i][k] * xtxInv[k][j] * scale;
+    }
+  }
+  const se = vcov.map((row, i) => Math.sqrt(Math.max(0, row[i])));
+  const pvals = beta.map((b, i) => normalTwoSided(b / se[i]));
+  return { beta, se, p: pvals };
+}
+
+function transformColumn(x, summary) {
+  if (summary.isBinary01) return x.slice();
+  return x.map((v) => (v - summary.mean) / summary.sd);
+}
+
+function adjustedModel(names, columns, summaries, y) {
+  const transformed = names.map((name) => transformColumn(columns[name], summaries[name]));
+  const X = [];
+  for (let i = 0; i < y.length; i++) {
+    const row = [1];
+    for (const col of transformed) row.push(col[i]);
+    X.push(row);
+  }
+  const fit = olsRobust(X, y);
+  const out = {};
+  for (let j = 0; j < names.length; j++) {
+    out[names[j]] = { effect: fit.beta[j + 1], se: fit.se[j + 1], p: fit.p[j + 1] };
+  }
+  return out;
+}
+
+function binaryInteraction(a, b, y) {
+  const cells = {
+    "0,0": { n: 0, y: 0 },
+    "1,0": { n: 0, y: 0 },
+    "0,1": { n: 0, y: 0 },
+    "1,1": { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${a[i]},${b[i]}`;
+    cells[key].n++;
+    cells[key].y += y[i];
+  }
+  for (const c of Object.values(cells)) c.p = c.y / c.n;
+  const effect = cells["1,1"].p - cells["1,0"].p - cells["0,1"].p + cells["0,0"].p;
+  const se = Math.sqrt(
+    Object.values(cells).reduce((s, c) => s + (c.p * (1 - c.p)) / c.n, 0)
+  );
+  return { effect, se, p: normalTwoSided(effect / se), cells };
+}
+
+function interactionOls(nameA, nameB, columns, summaries, y) {
+  const a = transformColumn(columns[nameA], summaries[nameA]);
+  const b = transformColumn(columns[nameB], summaries[nameB]);
+  const X = [];
+  for (let i = 0; i < y.length; i++) X.push([1, a[i], b[i], a[i] * b[i]]);
+  const fit = olsRobust(X, y);
+  return { effect: fit.beta[3], se: fit.se[3], p: fit.p[3], betaA: fit.beta[1], betaB: fit.beta[2] };
