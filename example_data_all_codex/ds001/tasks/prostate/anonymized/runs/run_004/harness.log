const fs = require('fs');
const probe = JSON.parse(fs.readFileSync('analysis_probe.json', 'utf8'));
const pf = p => (p === 0 ? 1e-300 : p);
const sig = p => pf(p) < 0.05;
const pct = x => "'`${(100*x).toFixed(1)}%`;
const pp = x => `${(100*x).toFixed(2)} percentage points`;
function main(feature, levelOrType) {
  const rows = probe.main.filter(m => m.feature === feature);
  if (levelOrType === '"'continuous_slope') return rows.find(m => m.type === 'continuous_slope');
  return rows.find(m => String(m.level) === String(levelOrType));
}
function inter(a, b) {
  const row = probe.interactions.find(x => x.a === a && x.b === b);
  if ("'!row) throw new Error(`missing interaction ${a} x ${b}`);
  return row;
}
function mainAnalysis(hid, m, detail) {
  const p = pf(m.p);
  const summary = detail || (m.type === '"'continuous_slope'
    ? "'`${m.feature} had a linear-probability slope of ${m.effect.toPrecision(4)} per 1-unit increase in the feature (two-sided z p=${p.toPrecision(3)}).`
    : `Response was ${pct(m.p1)} in ${m.feature}=${m.level} versus ${pct(m.p0)} in the comparison group; risk difference ${pp(m.effect)} (two-sided z p=${p.toPrecision(3)}).`);
  return {
    hypothesis_ids: [hid],
    code: m.type === '"'continuous_slope' ? 'Linear probability model: objective_response ~ feature' : 'Two-sample risk-difference z-test for objective_response proportions',
    result_summary: summary,
    p_value: p,
    effect_estimate: Number(m.effect.toPrecision(12)),
    significant: sig(m.p)
  };
}
function interactionAnalysis(hid, it, detail) {
  const c = it.cells;
  const effect0 = c['10'].p - c['00'].p;
  const effect1 = c['11'].p - c['01'].p;
  const p = pf(it.p);
  const summary = detail || "'`For ${it.adesc}, the risk difference was ${pp(effect0)} when ${it.bdesc} was absent and ${pp(effect1)} when ${it.bdesc} was present; difference-in-differences ${pp(it.effect)} (p=${p.toPrecision(3)}).`;
  return {
    hypothesis_ids: [hid],
    code: '"'Four-cell interaction test: (p11 - p01) - (p10 - p00), with normal-approximation SE from the four binomial proportions',
    result_summary: summary,
    p_value: p,
    effect_estimate: Number(it.effect.toPrecision(12)),
    significant: sig(it.p)
  };
}
const iterations = [];
function add(index, hypotheses, analyses, update) {
  iterations.push({ index, proposed_hypotheses: hypotheses, analyses, update });
}
