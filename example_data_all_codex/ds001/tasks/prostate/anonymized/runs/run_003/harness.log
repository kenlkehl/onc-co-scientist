"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome counts')
print(df['objective_response'].value_counts(dropna=False).to_string())
print('outcome mean', float(df['objective_response'].mean()))
features = [c for c in df.columns if c.startswith('feature_')]
summary=[]
for c in features:
    s=df[c]
    vals=s.value_counts().sort_index()
    nun=s.nunique()
    if nun <= 5:
        desc=';'.join(f'{k}:{v}' for k,v in vals.items())
    else:
        desc=f'min={s.min()}, max={s.max()}, mean={s.mean():.4g}, sd={s.std():.4g}, nunique={nun}'
    summary.append((c,str(s.dtype),nun,desc))
for row in summary:
    print('\\t'.join(map(str,row)))
