import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome counts')
print(df['objective_response'].value_counts(dropna=False).sort_index().to_string())
print('outcome mean', df['objective_response'].mean())
rows=[]
for c in df.columns:
    if c=='objective_response': continue
    s=df[c]
    vc=s.value_counts().sort_index()
    rows.append((c, str(s.dtype), int(s.nunique()), float(s.min()), float(s.max()), vc.head(10).to_dict()))
print('feature summaries')
for r in rows:
    print(r)
