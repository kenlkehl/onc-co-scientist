function snappy(input){let pos=0; function rv(){let res=0,sh=0;while(true){let by=input[pos++];res|=(by&0x7f)<<sh;if("'!(by&0x80))break;sh+=7;}return res>>>0;} const len=rv(); const out=Buffer.alloc(len); let op=0; while(pos<input.length){let tag=input[pos++],typ=tag&3;if(typ===0){let l=tag>>2;if(l<60)l++;else{let n=l-59;l=0;for(let i=0;i<n;i++)l|=input[pos++]<<(8*i);l++;}input.copy(out,op,pos,pos+l);pos+=l;op+=l;}else{let length,offset;if(typ===1){length=((tag>>2)&7)+4;offset=((tag&0xe0)<<3)|input[pos++];}else if(typ===2){length=(tag>>2)+1;offset=input[pos]|(input[pos+1]<<8);pos+=2;}else{length=(tag>>2)+1;offset=(input[pos]|(input[pos+1]<<8)|(input[pos+2]<<16)|(input[pos+3]<<24)>>>0);pos+=4;}for(let i=0;i<length;i++)out[op+i]=out[op-offset+i];op+=length;}} if(op!==len)throw Error('"'snappy op '+op+' len '+len); return out;}
