import pandas as pd
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print(df.dtypes.to_string())
print('outcome unique', df['objective_response'].value_counts(dropna=False).sort_index().to_dict())
print('first columns', df.columns.tolist()[:10])
print('all numeric?', all(pd.api.types.is_numeric_dtype(df[c]) for c in df.columns))
print('feature summary:')
features=[c for c in df.columns if c"'!='"'objective_response']
summary=[]
for c in features:
    s=df[c]
    summary.append((c, str(s.dtype), int(s.nunique()), float(s.mean()), float(s.std()), float(s.min()), float(s.max())))
for row in summary[:72]:
    print(row)
