const cols=load(), y=cols.objective_response, n=y.length; function erf(x){const s=x<0?-1:1;x=Math.abs(x);const a1=.254829592,a2=-.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=.3275911,t=1/(1+p*x);return s*(1-((((a5*t+a4)*t+a3)*t+a2)*t+a1)*t*Math.exp(-x*x));} function pz(z){return Math.max(2*(1-(.5*(1+erf(Math.abs(z)/Math.SQRT2)))),1e-300);} function rateWhere(pred){let nn=0,yy=0;for(let i=0;i<n;i++)if(pred(i)){nn++;yy+=y[i];}return{n:nn,rate:yy/nn,y:yy};} function rd(predA,predB){const A=rateWhere(predA),B=rateWhere(predB),eff=A.rate-B.rate,se=Math.sqrt(A.rate*(1-A.rate)/A.n+B.rate*(1-B.rate)/B.n),z=eff/se;return{A,B,eff,z,p:pz(z)};} function print(name,obj){console.log(name,JSON.stringify(obj));}
