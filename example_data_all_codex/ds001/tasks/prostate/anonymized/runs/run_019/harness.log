function makeReader(buf,start=0){let pos=start; const readByte=()=>buf[pos++]; const readVar=()=>{let sh=0,r=0n; while(true){let by=readByte(); r|=BigInt(by&0x7f)<<BigInt(sh); if("'!(by&0x80))break; sh+=7;} return r;}; const zz=n=>(n>>1n)''^(-(n&1n)); const readI=()=>Number(zz(readVar())); const readBin=()=>{let len=Number(readVar()); let s=buf.subarray(pos,pos+len); pos+=len; return s.toString('"'utf8');}; function readList(){let h=readByte(), size=h>>4, et=h&0xf; if(size===15) size=Number(readVar()); let arr=[]; for(let i=0;i<size;i++) arr.push(readVal(et)); return arr;} function readVal(t){if(t===1)return true;if(t===2)return false;if(t===3)return readByte();if(t===4||t===5||t===6)return readI();if(t===7){let v=buf.readDoubleLE(pos);pos+=8;return v;}if(t===8)return readBin();if(t===9||t===10)return readList();if(t===12)return readStruct();throw Error('t '+t+' p '+pos)} function readStruct(){let obj={},last=0;while(true){let h=readByte(),t=h&0xf;if(t===0)break;let d=h>>4,f=d?last+d:readI();last=f;obj[f]=readVal(t);}return obj;} return {readStruct,get pos(){return pos}};}
function snappy(input){let pos=0;function rv(){let res=0,sh=0;while(true){let by=input[pos++];res|=(by&0x7f)<<sh;if("'!(by&0x80))break;sh+=7;}return res>>>0;}const len=rv(),out=Buffer.alloc(len);let op=0;while(pos<input.length){let tag=input[pos++],typ=tag&3;if(typ===0){let l=tag>>2;if(l<60)l++;else{let n=l-59;l=0;for(let i=0;i<n;i++)l|=input[pos++]<<(8*i);l++;}input.copy(out,op,pos,pos+l);pos+=l;op+=l;}else{let length,offset;if(typ===1){length=((tag>>2)&7)+4;offset=((tag&0xe0)<<3)|input[pos++];}else if(typ===2){length=(tag>>2)+1;offset=input[pos]|(input[pos+1]<<8);pos+=2;}else{length=(tag>>2)+1;offset=(input[pos]|(input[pos+1]<<8)|(input[pos+2]<<16)|(input[pos+3]<<24)>>>0);pos+=4;}for(let i=0;i<length;i++)out[op+i]=out[op-offset+i];op+=length;}}return out;}
