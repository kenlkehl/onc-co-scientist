function page(offset){const r=makeReader(file,offset);const h=r.readStruct();const body=file.subarray(r.pos,r.pos+h[3]);return{h,body,next:r.pos+h[3]};}
function plainDecode(buf,type,n){let pos=0,arr=[];for(let i=0;i<n;i++){if(type===2){arr.push(Number(buf.readBigInt64LE(pos)));pos+=8;}else if(type===1){arr.push(buf.readInt32LE(pos));pos+=4;}else if(type===5){arr.push(buf.readDoubleLE(pos));pos+=8;}else if(type===6){let len=buf.readInt32LE(pos);pos+=4;arr.push(buf.subarray(pos,pos+len).toString('"'utf8'));pos+=len;}else throw Error('type '+type);}return arr;}
function bitWidth(max){let w=0;while((1<<w)<=max)w++;return w;} function readUVar(buf,st){let res=0,sh=0;while(st.pos<st.end){let by=buf[st.pos++];res|=(by&0x7f)<<sh;if("'!(by&0x80))break;sh+=7;}return res>>>0;} function readHybrid(buf,start,end,bw,count){let st={pos:start,end},vals=[];if(bw===0){while(vals.length<count)vals.push(0);return{vals,pos:st.pos};}while(vals.length<count&&st.pos<end){let header=readUVar(buf,st);if((header&1)===0){let run=header>>>1,bytes=Math.ceil(bw/8),v=0;for(let i=0;i<bytes;i++)v|=buf[st.pos++]<<(8*i);for(let i=0;i<run&&vals.length<count;i++)vals.push(v);}else{let groups=header>>>1,n=groups*8,bytes=Math.ceil(n*bw/8),dataStart=st.pos;for(let i=0;i<n&&vals.length<count;i++){let v=0;for(let j=0;j<bw;j++){let bit=i*bw+j;if((buf[dataStart+(bit>>3)]>>(bit&7))&1)v|=1<<j;}vals.push(v);}st.pos+=bytes;}}return{vals,pos:st.pos};}
function readColumn(ch,schemaElem){const cm=ch[3],type=cm[1],codec=cm[4],total=cm[5];let values=[],dict=null,off=cm[11]||cm[9];if(cm[11]!==undefined){let pg=page(cm[11]);let body=codec===1?snappy(pg.body):pg.body;dict=plainDecode(body,type,pg.h[7][1]);off=pg.next;}while(values.length<total){let pg=page(off),body=codec===1?snappy(pg.body):pg.body;if(pg.h[1]!==0){off=pg.next;continue;}let dh=pg.h[5],n=dh[1],enc=dh[2],pos=0,maxDef=(schemaElem[3]===1)?1:0,defs;if(maxDef){let len=body.readInt32LE(pos);pos+=4;defs=readHybrid(body,pos,pos+len,bitWidth(maxDef),n).vals;pos+=len;}else defs=Array(n).fill(0);let nonNull=defs.filter(d=>d===maxDef).length,vals=[];if(enc===8||enc===2){let bw=body[pos++];vals=readHybrid(body,pos,body.length,bw,nonNull).vals.map(i=>dict[i]);}else vals=plainDecode(body.subarray(pos),type,nonNull);let vi=0;for(let d of defs)values.push(d===maxDef?vals[vi++]:null);off=pg.next;}return values;}
