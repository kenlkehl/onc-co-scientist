function ana(ids, summary, r, method) { return { hypothesis_ids: ids, code: null, method, result_summary: summary, p_value: r.p, effect_estimate: r.effect, significant: r.p < 0.05 }; }
function anaManual(ids, summary, effect, p, method) { return { hypothesis_ids: ids, code: null, method, result_summary: summary, p_value: p, effect_estimate: effect, significant: p < 0.05 }; }
