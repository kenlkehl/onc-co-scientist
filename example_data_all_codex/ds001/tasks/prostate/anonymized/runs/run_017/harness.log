"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from scipy import stats

p='dataset.parquet'
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.value_counts())
print(df.dtypes.to_string())
y='objective_response'
print('outcome unique', df[y].value_counts().sort_index().to_dict(), 'mean', df[y].mean())
rows=[]
for c in df.columns:
    if c==y: continue
    s=df[c]
    nuniq=s.nunique(dropna=False)
    vals=s.value_counts().sort_index().head(10).to_dict()
    rows.append((c, str(s.dtype), nuniq, vals, float(s.mean()) if np.issubdtype(s.dtype, np.number) else None))
print('\\nfeature summary first 80')
for r in rows:
    print(r)

assoc=[]
for c in [c for c in df.columns if c"'!=y]:
    x=df[c]
    if x.nunique()==2 and set(x.unique()).issubset({0,1,False,True}):
        y1=df.loc[x==1,y]
        y0=df.loc[x==0,y]
        tab=pd.crosstab(x, df[y])
        chi2,pv,_,_=stats.chi2_contingency(tab, correction=False)
        assoc.append((c, len(y1), float(x.mean()), float(y1.mean()), float(y0.mean()), float(y1.mean()-y0.mean()), pv))
    else:
        # point-biserial / simple logistic not here
        r,pv=stats.pointbiserialr(df[y], x)
        assoc.append((c, None, float(x.mean()), None, None, float(r), pv))
assoc=sorted(assoc, key=lambda t:t[-1])
print('"'\\nTop univariate associations')
for a in assoc[:30]:
    print(a)
