    const f1 = binaryFeatures[i];
    const f2 = binaryFeatures[j];
    const res = interactionBinaryBinary(data[f1], data[f2], y);
    const minCell = Math.min(...Object.values(res.cells).map((c) => c.n));
    if (minCell >= 50) binaryInteractions.push({ f1, f2, minCell, ...res });
  }
}
binaryInteractions.sort((a, b) => a.p - b.p);

const topMainBinary = mainBinary.slice(0, 8).map((r) => r.feature);
const adjustedNames = ["intercept", ...topMainBinary];
const adjusted = ols(
  (i) => [1, ...topMainBinary.map((f) => data[f][i])],
