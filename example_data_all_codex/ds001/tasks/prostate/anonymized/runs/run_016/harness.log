@@ -0,0 +1,1500 @@
+const fs = require("fs");
+
+const DATASET_ID = "ds001_prostate";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-node-parquet-analysis@1.0";
+const MAX_ITERATIONS = 25;
+
+const buf = fs.readFileSync("dataset.parquet");
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buffer, start = 0) {
+    this.b = buffer;
+    this.p = start;
+    this.last = [];
+  }
+
+  u8() {
+    return this.b[this.p++];
+  }
+
+  bytes(n) {
+    const out = this.b.subarray(this.p, this.p + n);
+    this.p += n;
+    return out;
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const x = this.u8();
+      result |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzagNumber(u) {
+    return Number((u >> 1n) ^ (-(u & 1n)));
+  }
+
+  i32() {
+    return this.zigzagNumber(this.varint());
+  }
+
+  i64() {
+    return this.zigzagNumber(this.varint());
+  }
+
+  binary() {
+    const n = Number(this.varint());
+    return this.bytes(n);
+  }
+
+  str() {
+    return this.binary().toString("utf8");
+  }
+
+  listBegin() {
+    const h = this.u8();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+
+  fieldBegin() {
+    const h = this.u8();
+    const type = h & 0x0f;
+    if (type === CT.STOP) return { type, id: 0 };
+    const delta = h >> 4;
+    const prev = this.last[this.last.length - 1] || 0;
+    const id = delta === 0 ? this.zigzagNumber(this.varint()) : prev + delta;
+    this.last[this.last.length - 1] = id;
+    return { type, id };
+  }
+
+  struct(fn) {
+    this.last.push(0);
+    const out = fn();
+    this.last.pop();
+    return out;
+  }
+
+  skip(type) {
+    switch (type) {
+      case CT.STOP:
+      case CT.TRUE:
+      case CT.FALSE:
+        return;
+      case CT.BYTE:
+        this.u8();
+        return;
+      case CT.I16:
+      case CT.I32:
+        this.i32();
+        return;
+      case CT.I64:
+        this.i64();
+        return;
+      case CT.DOUBLE:
+        this.bytes(8);
+        return;
+      case CT.BINARY:
+        this.binary();
+        return;
+      case CT.LIST:
+      case CT.SET: {
+        const l = this.listBegin();
+        for (let i = 0; i < l.size; i++) this.skip(l.type);
+        return;
+      }
+      case CT.MAP: {
+        const n = Number(this.varint());
