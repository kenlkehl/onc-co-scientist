+function mean(a) {
+  let s = 0;
+  for (const v of a) s += v;
+  return s / a.length;
+}
+
+function variance(a, m = mean(a)) {
+  let s = 0;
+  for (const v of a) {
+    const d = v - m;
+    s += d * d;
+  }
+  return s / (a.length - 1);
+}
+
+function sd(a) {
+  return Math.sqrt(variance(a));
+}
+
+function minMaxUnique(a, maxTrack = 20) {
+  let min = Infinity;
+  let max = -Infinity;
+  const seen = new Set();
+  for (const v of a) {
+    if (v < min) min = v;
+    if (v > max) max = v;
+    if (seen.size <= maxTrack) seen.add(v);
+  }
