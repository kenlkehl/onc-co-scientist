+}
+
+function binaryFeatureTest(x, y) {
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (x[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p1 = y1 / n1;
+  const p0 = y0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+  const z = effect / se;
+  return { effect, p: twoSidedP(z), z, n1, n0, p1, p0 };
+}
+
+function continuousSlopeTest(x, y) {
+  const mx = mean(x);
+  const sx = sd(x);
+  const z = x.map((v) => (v - mx) / sx);
+  let sxx = 0, sxy = 0;
+  const my = mean(y);
+  for (let i = 0; i < y.length; i++) {
+    sxx += z[i] * z[i];
+    sxy += z[i] * (y[i] - my);
+  }
+  const beta = sxy / sxx;
+  let rss = 0;
+  for (let i = 0; i < y.length; i++) {
+    const e = y[i] - (my + beta * z[i]);
+    rss += e * e;
+  }
+  const se = Math.sqrt((rss / (y.length - 2)) / sxx);
+  const zstat = beta / se;
+  return { effect: beta, p: twoSidedP(zstat), z: zstat, mean: mx, sd: sx };
+}
+
+function subgroupBinaryTest(g, x, y, gValue) {
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (g[i] !== gValue) continue;
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (x[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p1 = y1 / n1;
+  const p0 = y0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+  return { effect, p: twoSidedP(effect / se), n1, n0, p1, p0 };
+}
+
+function interactionBinaryBinary(a, b, y) {
+  const cells = {
+    "00": { n: 0, y: 0 },
+    "01": { n: 0, y: 0 },
+    "10": { n: 0, y: 0 },
+    "11": { n: 0, y: 0 },
+  };
+  for (let i = 0; i < y.length; i++) {
+    const key = `${a[i] === 1 ? 1 : 0}${b[i] === 1 ? 1 : 0}`;
+    cells[key].n++;
+    cells[key].y += y[i];
+  }
+  const p00 = cells["00"].y / cells["00"].n;
+  const p01 = cells["01"].y / cells["01"].n;
+  const p10 = cells["10"].y / cells["10"].n;
+  const p11 = cells["11"].y / cells["11"].n;
+  const effect = p11 - p10 - p01 + p00;
+  const se = Math.sqrt(
+    (p11 * (1 - p11)) / cells["11"].n +
+      (p10 * (1 - p10)) / cells["10"].n +
+      (p01 * (1 - p01)) / cells["01"].n +
+      (p00 * (1 - p00)) / cells["00"].n,
+  );
+  return { effect, p: twoSidedP(effect / se), cells, rates: { p00, p01, p10, p11 } };
+}
+
+function transpose(m) {
+  return m[0].map((_, j) => m.map((row) => row[j]));
+}
+
+function matMul(A, B) {
+  const out = Array.from({ length: A.length }, () => new Array(B[0].length).fill(0));
+  for (let i = 0; i < A.length; i++) {
+    for (let k = 0; k < B.length; k++) {
+      const aik = A[i][k];
+      if (aik === 0) continue;
+      for (let j = 0; j < B[0].length; j++) out[i][j] += aik * B[k][j];
+    }
+  }
+  return out;
+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const M = A.map((row, i) => [
+    ...row,
+    ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0)),
+  ]);
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(M[r][col]) > Math.abs(M[pivot][col])) pivot = r;
+    }
+    if (Math.abs(M[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    [M[col], M[pivot]] = [M[pivot], M[col]];
+    const d = M[col][col];
+    for (let j = 0; j < 2 * n; j++) M[col][j] /= d;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = M[r][col];
+      for (let j = 0; j < 2 * n; j++) M[r][j] -= f * M[col][j];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function ols(design, y, names) {
+  const p = names.length;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  for (let i = 0; i < y.length; i++) {
+    const row = design(i);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
+  }
+
+  const meat = Array.from({ length: p }, () => new Array(p).fill(0));
+  for (let i = 0; i < y.length; i++) {
+    const row = design(i);
+    let fitted = 0;
+    for (let a = 0; a < p; a++) fitted += row[a] * beta[a];
+    const e2 = (y[i] - fitted) ** 2;
+    for (let a = 0; a < p; a++) {
+      for (let b = 0; b < p; b++) meat[a][b] += e2 * row[a] * row[b];
+    }
+  }
+  const robust = matMul(matMul(inv, meat), inv);
+  const scale = y.length / (y.length - p);
+  const rows = {};
+  for (let a = 0; a < p; a++) {
+    const se = Math.sqrt(Math.max(0, robust[a][a] * scale));
+    const z = beta[a] / se;
+    rows[names[a]] = { beta: beta[a], se, z, p: twoSidedP(z) };
+  }
+  return rows;
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) < 0.0001 && x !== 0) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function pText(p) {
+  if (p === 0) return "<1e-16";
+  if (p < 0.0001) return p.toExponential(3);
+  return p.toFixed(4);
+}
+
+function direction(effect, positiveWord = "higher", negativeWord = "lower") {
+  return effect >= 0 ? positiveWord : negativeWord;
+}
+
+function signWord(effect) {
+  return effect >= 0 ? "positive" : "negative";
+}
+
+function additivityDirection(effect) {
+  return effect >= 0 ? "higher than expected under additivity" : "lower than expected under additivity";
+}
+
+function hyp(id, text, kind = "novel") {
+  return { id, text, kind };
+}
+
+function analysis(ids, summary, p, effect, code = null) {
+  return {
+    hypothesis_ids: ids,
+    code,
+    result_summary: summary,
+    p_value: p,
+    effect_estimate: effect,
+    significant: p < 0.05,
+  };
+}
+
+const profiles = {};
+const binaryFeatures = [];
+const continuousFeatures = [];
+for (const f of featureNames) {
+  const mm = minMaxUnique(data[f]);
+  const m = mean(data[f]);
+  const s = sd(data[f]);
+  profiles[f] = { ...mm, mean: m, sd: s };
+  if (mm.uniqueAtMost === 2 && mm.min === 0 && mm.max === 1) binaryFeatures.push(f);
+  else continuousFeatures.push(f);
+}
+
+const mainBinary = binaryFeatures
+  .map((f) => ({ feature: f, ...binaryFeatureTest(data[f], y), prevalence: mean(data[f]) }))
+  .sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+const mainContinuous = continuousFeatures
+  .map((f) => ({ feature: f, ...continuousSlopeTest(data[f], y) }))
+  .filter((r) => Number.isFinite(r.effect) && Number.isFinite(r.p))
+  .sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+const binaryInteractions = [];
+for (let i = 0; i < binaryFeatures.length; i++) {
+  for (let j = i + 1; j < binaryFeatures.length; j++) {
+    const f1 = binaryFeatures[i];
+    const f2 = binaryFeatures[j];
+    const res = interactionBinaryBinary(data[f1], data[f2], y);
+    const minCell = Math.min(...Object.values(res.cells).map((c) => c.n));
+    if (minCell >= 50) binaryInteractions.push({ f1, f2, minCell, ...res });
+  }
+}
+binaryInteractions.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+const topMainBinary = mainBinary.slice(0, 8).map((r) => r.feature);
+const adjustedNames = ["intercept", ...topMainBinary];
+const adjusted = ols(
+  (i) => [1, ...topMainBinary.map((f) => data[f][i])],
+  y,
+  adjustedNames,
+);
+
+const interaction1 = binaryInteractions[0];
+const interaction2 = binaryInteractions.find(
+  (x) => ![interaction1.f1, interaction1.f2].includes(x.f1) && ![interaction1.f1, interaction1.f2].includes(x.f2),
+);
+const interaction3 = binaryInteractions.find(
+  (x) => x.p < 0.001 && Math.abs(x.effect) > 0.02 && x !== interaction1 && x !== interaction2,
+);
+
+const subgroupA = subgroupBinaryTest(data[interaction1.f2], data[interaction1.f1], y, 1);
+const subgroupB = subgroupBinaryTest(data[interaction1.f2], data[interaction1.f1], y, 0);
+
+const topCont = mainContinuous[0];
+const topContArray = data[topCont.feature];
+const topContMean = topCont.mean;
+const topContSd = topCont.sd;
+const zTopCont = topContArray.map((v) => (v - topContMean) / topContSd);
+const contBinaryInteractions = [];
+for (const b of binaryFeatures) {
+  const rows = ols(
+    (i) => [1, zTopCont[i], data[b][i], zTopCont[i] * data[b][i]],
+    y,
+    ["intercept", topCont.feature, b, `${topCont.feature}:${b}`],
+  );
+  const term = rows[`${topCont.feature}:${b}`];
+  contBinaryInteractions.push({ binary: b, effect: term.beta, p: term.p, rows });
+}
+contBinaryInteractions.sort((a, b) => a.p - b.p);
+const topContInteraction = contBinaryInteractions[0];
+
+const negativeBinary = mainBinary.filter((r) => r.effect < 0).slice(0, 3);
+const nullBinary = mainBinary
+  .filter((r) => r.p > 0.5 && r.prevalence > 0.1 && r.prevalence < 0.9)
+  .slice(0, 2);
+
+const topTwo = mainBinary.slice(0, 2);
+const topThree = mainBinary.slice(0, 3);
+
+const triple = ols(
+  (i) => [
+    1,
+    data[topThree[0].feature][i],
+    data[topThree[1].feature][i],
+    data[topThree[2].feature][i],
+    data[topThree[0].feature][i] * data[topThree[1].feature][i],
+    data[topThree[0].feature][i] * data[topThree[2].feature][i],
+    data[topThree[1].feature][i] * data[topThree[2].feature][i],
+    data[topThree[0].feature][i] * data[topThree[1].feature][i] * data[topThree[2].feature][i],
+  ],
+  y,
+  [
+    "intercept",
+    topThree[0].feature,
+    topThree[1].feature,
+    topThree[2].feature,
+    `${topThree[0].feature}:${topThree[1].feature}`,
+    `${topThree[0].feature}:${topThree[2].feature}`,
+    `${topThree[1].feature}:${topThree[2].feature}`,
+    `${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature}`,
+  ],
+);
+
+const iterations = [];
+
+iterations.push({
+  index: 1,
+  proposed_hypotheses: [
+    hyp(
+      "h1",
+      `Patients with ${topTwo[0].feature}=1 have a ${direction(topTwo[0].effect)} objective_response rate than patients with ${topTwo[0].feature}=0.`,
+    ),
+    hyp(
+      "h2",
+      `Patients with ${topTwo[1].feature}=1 have a ${direction(topTwo[1].effect)} objective_response rate than patients with ${topTwo[1].feature}=0.`,
+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h1"],
+      `${topTwo[0].feature}=1 response rate was ${fmt(topTwo[0].p1)} vs ${fmt(topTwo[0].p0)} for ${topTwo[0].feature}=0; risk difference ${fmt(topTwo[0].effect)} (two-proportion z-test p=${pText(topTwo[0].p)}).`,
+      topTwo[0].p,
+      topTwo[0].effect,
+    ),
+    analysis(
+      ["h2"],
+      `${topTwo[1].feature}=1 response rate was ${fmt(topTwo[1].p1)} vs ${fmt(topTwo[1].p0)} for ${topTwo[1].feature}=0; risk difference ${fmt(topTwo[1].effect)} (two-proportion z-test p=${pText(topTwo[1].p)}).`,
+      topTwo[1].p,
+      topTwo[1].effect,
+    ),
+  ],
+});
+
+iterations.push({
+  index: 2,
+  proposed_hypotheses: [
+    hyp(
+      "h3",
+      `After adjustment for the strongest binary features (${topMainBinary.join(", ")}), ${topTwo[0].feature}=1 remains associated with ${direction(adjusted[topTwo[0].feature].beta)} objective_response on the risk-difference scale.`,
+      "refined",
+    ),
+    hyp(
+      "h4",
+      `After adjustment for the strongest binary features (${topMainBinary.join(", ")}), ${topTwo[1].feature}=1 remains associated with ${direction(adjusted[topTwo[1].feature].beta)} objective_response on the risk-difference scale.`,
+      "refined",
+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h3"],
+      `Multivariable linear probability model coefficient for ${topTwo[0].feature} was ${fmt(adjusted[topTwo[0].feature].beta)} with robust p=${pText(adjusted[topTwo[0].feature].p)}.`,
+      adjusted[topTwo[0].feature].p,
+      adjusted[topTwo[0].feature].beta,
+    ),
+    analysis(
+      ["h4"],
+      `Multivariable linear probability model coefficient for ${topTwo[1].feature} was ${fmt(adjusted[topTwo[1].feature].beta)} with robust p=${pText(adjusted[topTwo[1].feature].p)}.`,
+      adjusted[topTwo[1].feature].p,
+      adjusted[topTwo[1].feature].beta,
+    ),
+  ],
+});
+
+iterations.push({
+  index: 3,
+  proposed_hypotheses: [
+    hyp(
+      "h5",
+      `Patients with ${topCont.feature} one standard deviation above the cohort mean have a ${direction(topCont.effect)} objective_response probability than otherwise similar patients with ${topCont.feature} at the mean.`,
+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h5"],
+      `${topCont.feature} had a one-SD linear probability slope of ${fmt(topCont.effect)} for objective_response (mean ${fmt(topCont.mean)}, SD ${fmt(topCont.sd)}, p=${pText(topCont.p)}).`,
+      topCont.p,
+      topCont.effect,
+    ),
+  ],
+});
+
+iterations.push({
+  index: 4,
+  proposed_hypotheses: [
+    hyp(
+      "h6",
+      `The joint presence of ${interaction1.f1}=1 and ${interaction1.f2}=1 has objective_response ${additivityDirection(interaction1.effect)} compared with the sum of their separate risk differences.`,
+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h6"],
+      `Additive interaction ${interaction1.f1} x ${interaction1.f2} was ${fmt(interaction1.effect)}; cell response rates p00=${fmt(interaction1.rates.p00)}, p10=${fmt(interaction1.rates.p10)}, p01=${fmt(interaction1.rates.p01)}, p11=${fmt(interaction1.rates.p11)} (p=${pText(interaction1.p)}).`,
+      interaction1.p,
+      interaction1.effect,
+    ),
+  ],
+});
+
+iterations.push({
+  index: 5,
+  proposed_hypotheses: [
+    hyp(
+      "h7",
+      `Within the ${interaction1.f2}=1 subgroup, ${interaction1.f1}=1 is associated with ${direction(subgroupA.effect)} objective_response than ${interaction1.f1}=0.`,
+      "refined",
+    ),
+    hyp(
+      "h8",
+      `Within the ${interaction1.f2}=0 subgroup, ${interaction1.f1}=1 is associated with ${direction(subgroupB.effect)} objective_response than ${interaction1.f1}=0.`,
+      "refined",
+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h7"],
+      `Among ${interaction1.f2}=1 patients, ${interaction1.f1}=1 response rate was ${fmt(subgroupA.p1)} vs ${fmt(subgroupA.p0)} for ${interaction1.f1}=0; risk difference ${fmt(subgroupA.effect)} (p=${pText(subgroupA.p)}).`,
+      subgroupA.p,
+      subgroupA.effect,
+    ),
+    analysis(
+      ["h8"],
+      `Among ${interaction1.f2}=0 patients, ${interaction1.f1}=1 response rate was ${fmt(subgroupB.p1)} vs ${fmt(subgroupB.p0)} for ${interaction1.f1}=0; risk difference ${fmt(subgroupB.effect)} (p=${pText(subgroupB.p)}).`,
+      subgroupB.p,
+      subgroupB.effect,
+    ),
+  ],
+});
+
+if (interaction2) {
+  iterations.push({
+    index: 6,
+    proposed_hypotheses: [
+      hyp(
+        "h9",
+        `The joint presence of ${interaction2.f1}=1 and ${interaction2.f2}=1 has objective_response ${additivityDirection(interaction2.effect)} compared with the sum of their separate risk differences.`,
+      ),
+    ],
+    analyses: [
+      analysis(
+        ["h9"],
+        `Additive interaction ${interaction2.f1} x ${interaction2.f2} was ${fmt(interaction2.effect)}; cell response rates p00=${fmt(interaction2.rates.p00)}, p10=${fmt(interaction2.rates.p10)}, p01=${fmt(interaction2.rates.p01)}, p11=${fmt(interaction2.rates.p11)} (p=${pText(interaction2.p)}).`,
+        interaction2.p,
+        interaction2.effect,
+      ),
+    ],
+  });
+}
+
+iterations.push({
+  index: 7,
+  proposed_hypotheses: negativeBinary.map((r, idx) =>
+    hyp(
+      `h${10 + idx}`,
+      `Patients with ${r.feature}=1 have a lower objective_response rate than patients with ${r.feature}=0.`,
+    ),
+  ),
+  analyses: negativeBinary.map((r, idx) =>
+    analysis(
+      [`h${10 + idx}`],
+      `${r.feature}=1 response rate was ${fmt(r.p1)} vs ${fmt(r.p0)} for ${r.feature}=0; risk difference ${fmt(r.effect)} (p=${pText(r.p)}).`,
+      r.p,
+      r.effect,
+    ),
+  ),
+});
+
+iterations.push({
+  index: 8,
+  proposed_hypotheses: [
+    hyp(
+      "h13",
+      `The one-SD ${topCont.feature} association with objective_response is ${direction(topContInteraction.effect, "more positive", "more negative")} when ${topContInteraction.binary}=1 than when ${topContInteraction.binary}=0.`,
+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h13"],
+      `Linear probability model interaction between standardized ${topCont.feature} and ${topContInteraction.binary} was ${fmt(topContInteraction.effect)} (robust p=${pText(topContInteraction.p)}).`,
+      topContInteraction.p,
+      topContInteraction.effect,
+    ),
+  ],
+});
+
+iterations.push({
+  index: 9,
+  proposed_hypotheses: [
+    hyp(
+      "h14",
+      `Among the strongest three binary features (${topThree.map((r) => r.feature).join(", ")}), the three-way departure from additivity in objective_response is ${signWord(triple[`${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature}`].beta)}.`,
+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h14"],
+      `The three-way linear probability interaction ${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature} was ${fmt(triple[`${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature}`].beta)} with robust p=${pText(triple[`${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature}`].p)}.`,
+      triple[`${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature}`].p,
+      triple[`${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature}`].beta,
+    ),
+  ],
+});
+
+iterations.push({
+  index: 10,
+  proposed_hypotheses: nullBinary.map((r, idx) =>
+      hyp(
+        `h${15 + idx}`,
+      `Patients with ${r.feature}=1 have a ${direction(r.effect)} objective_response rate than patients with ${r.feature}=0.`,
+    ),
+  ),
+  analyses: nullBinary.map((r, idx) =>
+    analysis(
+      [`h${15 + idx}`],
+      `${r.feature}=1 response rate was ${fmt(r.p1)} vs ${fmt(r.p0)} for ${r.feature}=0; risk difference ${fmt(r.effect)} (p=${pText(r.p)}), providing no evidence of association.`,
+      r.p,
+      r.effect,
+    ),
+  ),
+});
+
+if (interaction3) {
+  iterations.push({
+    index: 11,
+    proposed_hypotheses: [
+      hyp(
+        "h17",
+        `The pair ${interaction3.f1}=1 and ${interaction3.f2}=1 has objective_response ${additivityDirection(interaction3.effect)} compared with the sum of their separate risk differences.`,
+      ),
+    ],
+    analyses: [
+      analysis(
+        ["h17"],
+        `Additive interaction ${interaction3.f1} x ${interaction3.f2} was ${fmt(interaction3.effect)}; cell response rates p00=${fmt(interaction3.rates.p00)}, p10=${fmt(interaction3.rates.p10)}, p01=${fmt(interaction3.rates.p01)}, p11=${fmt(interaction3.rates.p11)} (p=${pText(interaction3.p)}).`,
+        interaction3.p,
+        interaction3.effect,
+      ),
+    ],
+  });
+}
+
+let nextIndex = iterations.length + 1;
+let nextHypNum = 18;
+for (const r of mainBinary.slice(2, 8)) {
+  iterations.push({
+    index: nextIndex++,
+    proposed_hypotheses: [
+      hyp(
+        `h${nextHypNum}`,
+        `Patients with ${r.feature}=1 have a ${direction(r.effect)} objective_response rate than patients with ${r.feature}=0.`,
+      ),
+    ],
+    analyses: [
+      analysis(
+        [`h${nextHypNum}`],
+        `${r.feature}=1 response rate was ${fmt(r.p1)} vs ${fmt(r.p0)} for ${r.feature}=0; risk difference ${fmt(r.effect)} (p=${pText(r.p)}).`,
+        r.p,
+        r.effect,
+      ),
+    ],
+  });
