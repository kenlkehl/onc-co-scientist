+  contBinaryInteractions.push({ binary: b, effect: term.beta, p: term.p, rows });
+}
+contBinaryInteractions.sort((a, b) => a.p - b.p);
+const topContInteraction = contBinaryInteractions[0];
+
+const negativeBinary = mainBinary.filter((r) => r.effect < 0).slice(0, 3);
+const nullBinary = mainBinary
+  .filter((r) => r.p > 0.5 && r.prevalence > 0.1 && r.prevalence < 0.9)
+  .slice(0, 2);
+
+const topTwo = mainBinary.slice(0, 2);
+const topThree = mainBinary.slice(0, 3);
+
+const triple = ols(
+  (i) => [
+    1,
+    data[topThree[0].feature][i],
+    data[topThree[1].feature][i],
+    data[topThree[2].feature][i],
+    data[topThree[0].feature][i] * data[topThree[1].feature][i],
