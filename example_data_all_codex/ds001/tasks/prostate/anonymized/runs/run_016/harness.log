+  const p01 = cells["01"].y / cells["01"].n;
+  const p10 = cells["10"].y / cells["10"].n;
+  const p11 = cells["11"].y / cells["11"].n;
+  const effect = p11 - p10 - p01 + p00;
+  const se = Math.sqrt(
