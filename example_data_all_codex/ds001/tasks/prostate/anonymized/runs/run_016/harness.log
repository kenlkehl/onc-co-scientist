+function binaryFeatureTest(x, y) {
+  let n1 = 0, y1 = 0, n0 = 0, y0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === 1) {
+      n1++;
+      y1 += y[i];
+    } else if (x[i] === 0) {
+      n0++;
+      y0 += y[i];
+    }
+  }
+  const p1 = y1 / n1;
+  const p0 = y0 / n0;
+  const effect = p1 - p0;
+  const se = Math.sqrt((p1 * (1 - p1)) / n1 + (p0 * (1 - p0)) / n0);
+  const z = effect / se;
+  return { effect, p: twoSidedP(z), z, n1, n0, p1, p0 };
+}
