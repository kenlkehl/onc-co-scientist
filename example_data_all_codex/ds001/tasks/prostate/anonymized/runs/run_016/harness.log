+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h6"],
+      `Additive interaction ${interaction1.f1} x ${interaction1.f2} was ${fmt(interaction1.effect)}; cell response rates p00=${fmt(interaction1.rates.p00)}, p10=${fmt(interaction1.rates.p10)}, p01=${fmt(interaction1.rates.p01)}, p11=${fmt(interaction1.rates.p11)} (p=${pText(interaction1.p)}).`,
+      interaction1.p,
+      interaction1.effect,
+    ),
+  ],
+});
+
+iterations.push({
+  index: 5,
+  proposed_hypotheses: [
+    hyp(
+      "h7",
+      `Within the ${interaction1.f2}=1 subgroup, ${interaction1.f1}=1 is associated with ${direction(subgroupA.effect)} objective_response than ${interaction1.f1}=0.`,
+      "refined",
+    ),
+    hyp(
+      "h8",
+      `Within the ${interaction1.f2}=0 subgroup, ${interaction1.f1}=1 is associated with ${direction(subgroupB.effect)} objective_response than ${interaction1.f1}=0.`,
+      "refined",
+    ),
+  ],
+  analyses: [
+    analysis(
+      ["h7"],
+      `Among ${interaction1.f2}=1 patients, ${interaction1.f1}=1 response rate was ${fmt(subgroupA.p1)} vs ${fmt(subgroupA.p0)} for ${interaction1.f1}=0; risk difference ${fmt(subgroupA.effect)} (p=${pText(subgroupA.p)}).`,
+      subgroupA.p,
