+    this.b = buffer;
+    this.p = start;
+    this.last = [];
+  }
+
+  u8() {
+    return this.b[this.p++];
+  }
+
+  bytes(n) {
+    const out = this.b.subarray(this.p, this.p + n);
+    this.p += n;
+    return out;
+  }
+
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const x = this.u8();
+      result |= BigInt(x & 0x7f) << shift;
+      if ((x & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzagNumber(u) {
+    return Number((u >> 1n) ^ (-(u & 1n)));
+  }
+
+  i32() {
+    return this.zigzagNumber(this.varint());
+  }
+
+  i64() {
+    return this.zigzagNumber(this.varint());
+  }
+
+  binary() {
+    const n = Number(this.varint());
+    return this.bytes(n);
+  }
+
+  str() {
+    return this.binary().toString("utf8");
+  }
+
+  listBegin() {
+    const h = this.u8();
+    let size = h >> 4;
+    const type = h & 0x0f;
+    if (size === 15) size = Number(this.varint());
+    return { size, type };
+  }
+
+  fieldBegin() {
+    const h = this.u8();
+    const type = h & 0x0f;
+    if (type === CT.STOP) return { type, id: 0 };
+    const delta = h >> 4;
+    const prev = this.last[this.last.length - 1] || 0;
+    const id = delta === 0 ? this.zigzagNumber(this.varint()) : prev + delta;
+    this.last[this.last.length - 1] = id;
+    return { type, id };
+  }
+
+  struct(fn) {
+    this.last.push(0);
+    const out = fn();
+    this.last.pop();
+    return out;
