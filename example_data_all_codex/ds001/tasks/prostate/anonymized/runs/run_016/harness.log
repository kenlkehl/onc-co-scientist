+        `${r.feature}=1 response rate was ${fmt(r.p1)} vs ${fmt(r.p0)} for ${r.feature}=0; risk difference ${fmt(r.effect)} (p=${pText(r.p)}).`,
+        r.p,
+        r.effect,
+      ),
+    ],
+  });
+  nextHypNum += 1;
+}
+
+for (const r of mainContinuous.slice(1, 5)) {
+  iterations.push({
+    index: nextIndex++,
+    proposed_hypotheses: [
+      hyp(
+        `h${nextHypNum}`,
+        `A one-standard-deviation higher value of ${r.feature} is associated with higher objective_response probability.`,
+      ),
+    ],
+    analyses: [
+      analysis(
+        [`h${nextHypNum}`],
+        `${r.feature} had a one-SD linear probability slope of ${fmt(r.effect)} for objective_response (mean ${fmt(r.mean)}, SD ${fmt(r.sd)}, p=${pText(r.p)}).`,
+        r.p,
+        r.effect,
+      ),
+    ],
+  });
+  nextHypNum += 1;
+}
+
+for (const ix of binaryInteractions.slice(3, 7)) {
+  iterations.push({
+    index: nextIndex++,
+    proposed_hypotheses: [
+      hyp(
+        `h${nextHypNum}`,
+        `The joint presence of ${ix.f1}=1 and ${ix.f2}=1 changes objective_response beyond the sum of the two individual associations.`,
+      ),
+    ],
+    analyses: [
+      analysis(
+        [`h${nextHypNum}`],
+        `Additive interaction ${ix.f1} x ${ix.f2} was ${fmt(ix.effect)}; cell response rates p00=${fmt(ix.rates.p00)}, p10=${fmt(ix.rates.p10)}, p01=${fmt(ix.rates.p01)}, p11=${fmt(ix.rates.p11)} (p=${pText(ix.p)}).`,
+        ix.p,
+        ix.effect,
+      ),
+    ],
+  });
+  nextHypNum += 1;
+}
+
+while (iterations.length > MAX_ITERATIONS) iterations.pop();
+for (let i = 0; i < iterations.length; i++) iterations[i].index = i + 1;
+
+const transcript = {
+  dataset_id: DATASET_ID,
+  model_id: MODEL_ID,
+  harness_id: HARNESS_ID,
+  max_iterations: MAX_ITERATIONS,
+  iterations,
+};
+
+fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2));
+
+const lines = [];
+lines.push(`Dataset ${DATASET_ID}: ${n} patients; objective_response mean ${fmt(yMean)}.`);
+lines.push(
+  `Decoded ${featureNames.length} feature columns from dataset.parquet: ${binaryFeatures.length} binary features and ${continuousFeatures.length} non-binary numeric features.`,
+);
+lines.push("");
+lines.push("Main effects.");
+for (const r of mainBinary.slice(0, 8)) {
+  lines.push(
+    `- ${r.feature}: response ${fmt(r.p1)} when 1 vs ${fmt(r.p0)} when 0; risk difference ${fmt(r.effect)}, p=${pText(r.p)}.`,
+  );
+}
+for (const r of mainContinuous.slice(0, 5)) {
+  lines.push(
+    `- ${r.feature}: one-SD slope ${fmt(r.effect)} on objective_response probability; p=${pText(r.p)}.`,
+  );
+}
+lines.push("");
+lines.push("Adjusted model.");
+lines.push(
+  `A linear probability model including ${topMainBinary.join(", ")} showed the two strongest binary signals remained positive: ${topTwo[0].feature} coefficient ${fmt(adjusted[topTwo[0].feature].beta)} (p=${pText(adjusted[topTwo[0].feature].p)}) and ${topTwo[1].feature} coefficient ${fmt(adjusted[topTwo[1].feature].beta)} (p=${pText(adjusted[topTwo[1].feature].p)}).`,
+);
+lines.push("");
+lines.push("Subgroup and interaction findings.");
+for (const ix of binaryInteractions.slice(0, 7)) {
+  lines.push(
+    `- ${ix.f1} x ${ix.f2}: additive interaction ${fmt(ix.effect)}, p=${pText(ix.p)}; rates p00=${fmt(ix.rates.p00)}, p10=${fmt(ix.rates.p10)}, p01=${fmt(ix.rates.p01)}, p11=${fmt(ix.rates.p11)}.`,
+  );
+}
+lines.push(
+  `The leading subgroup refinement showed ${interaction1.f1}'s risk difference was ${fmt(subgroupA.effect)} in ${interaction1.f2}=1 patients and ${fmt(subgroupB.effect)} in ${interaction1.f2}=0 patients.`,
+);
+lines.push(
+  `For continuous-binary heterogeneity, standardized ${topCont.feature} x ${topContInteraction.binary} had interaction ${fmt(topContInteraction.effect)}, p=${pText(topContInteraction.p)}.`,
+);
+lines.push(
+  `The three-way interaction among ${topThree.map((r) => r.feature).join(", ")} was ${fmt(triple[`${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature}`].beta)}, p=${pText(triple[`${topThree[0].feature}:${topThree[1].feature}:${topThree[2].feature}`].p)}.`,
+);
+lines.push("");
+lines.push("Negative and null checks.");
+for (const r of negativeBinary) {
+  lines.push(
+    `- ${r.feature}: lower response when 1; risk difference ${fmt(r.effect)}, p=${pText(r.p)}.`,
+  );
+}
+for (const r of nullBinary) {
+  lines.push(
+    `- ${r.feature}: near-null risk difference ${fmt(r.effect)}, p=${pText(r.p)}.`,
+  );
+}
+lines.push("");
+lines.push(
+  "Overall, the cohort contains multiple strong treatment-biomarker-style signals despite opaque feature labels: several binary features show large positive or negative response-rate differences, these signals remain after adjustment, and pairwise interaction scans identify clinically meaningful response heterogeneity where joint feature status departs from additivity. Null-control features with adequate prevalence showed no evidence of association, supporting that the strongest findings are not merely artifacts of sample size.",
+);
+
+fs.writeFileSync("analysis_summary.txt", `${lines.join("\n")}\n`);
+
+console.log(JSON.stringify({
+  rows: n,
+  outcome_mean: yMean,
+  binary_features: binaryFeatures.length,
+  continuous_features: continuousFeatures.length,
+  top_binary: mainBinary.slice(0, 5).map((r) => ({
+    feature: r.feature,
+    effect: r.effect,
+    p: r.p,
+    p1: r.p1,
+    p0: r.p0,
+  })),
+  top_continuous: mainContinuous.slice(0, 3).map((r) => ({
+    feature: r.feature,
+    effect: r.effect,
+    p: r.p,
+  })),
+  top_interactions: binaryInteractions.slice(0, 3).map((r) => ({
+    f1: r.f1,
