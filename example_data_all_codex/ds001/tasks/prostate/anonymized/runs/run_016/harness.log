+function continuousSlopeTest(x, y) {
+  const mx = mean(x);
+  const sx = sd(x);
+  const z = x.map((v) => (v - mx) / sx);
+  let sxx = 0, sxy = 0;
+  const my = mean(y);
+  for (let i = 0; i < y.length; i++) {
+    sxx += z[i] * z[i];
+    sxy += z[i] * (y[i] - my);
+  }
+  const beta = sxy / sxx;
+  let rss = 0;
+  for (let i = 0; i < y.length; i++) {
+    const e = y[i] - (my + beta * z[i]);
+    rss += e * e;
+  }
