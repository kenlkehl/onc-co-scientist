+}
+
+while (iterations.length > MAX_ITERATIONS) iterations.pop();
+for (let i = 0; i < iterations.length; i++) iterations[i].index = i + 1;
+
+const transcript = {
+  dataset_id: DATASET_ID,
+  model_id: MODEL_ID,
+  harness_id: HARNESS_ID,
+  max_iterations: MAX_ITERATIONS,
+  iterations,
+};
