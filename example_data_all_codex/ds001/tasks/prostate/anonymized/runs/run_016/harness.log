function fmt(x, digits = 4) {
  if (!Number.isFinite(x)) return String(x);
  if (Math.abs(x) < 0.0001 && x !== 0) return x.toExponential(3);
  return x.toFixed(digits);
}

function pText(p) {
  if (p === 0) return "<1e-16";
  if (p < 0.0001) return p.toExponential(3);
  return p.toFixed(4);
}

function hyp(id, text, kind = "novel") {
  return { id, text, kind };
}

function analysis(ids, summary, p, effect, code = null) {
  return {
    hypothesis_ids: ids,
    code,
    result_summary: summary,
    p_value: p,
    effect_estimate: effect,
    significant: p < 0.05,
  };
}

const profiles = {};
const binaryFeatures = [];
const continuousFeatures = [];
for (const f of featureNames) {
  const mm = minMaxUnique(data[f]);
  const m = mean(data[f]);
  const s = sd(data[f]);
  profiles[f] = { ...mm, mean: m, sd: s };
  if (mm.uniqueAtMost === 2 && mm.min === 0 && mm.max === 1) binaryFeatures.push(f);
  else continuousFeatures.push(f);
}

const mainBinary = binaryFeatures
