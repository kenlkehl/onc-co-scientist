+function invertMatrix(A) {
+  const n = A.length;
+  const M = A.map((row, i) => [
+    ...row,
+    ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0)),
+  ]);
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) {
+      if (Math.abs(M[r][col]) > Math.abs(M[pivot][col])) pivot = r;
+    }
+    if (Math.abs(M[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    [M[col], M[pivot]] = [M[pivot], M[col]];
+    const d = M[col][col];
+    for (let j = 0; j < 2 * n; j++) M[col][j] /= d;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const f = M[r][col];
+      for (let j = 0; j < 2 * n; j++) M[r][j] -= f * M[col][j];
+    }
+  }
+  return M.map((row) => row.slice(n));
+}
+
+function ols(design, y, names) {
+  const p = names.length;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  for (let i = 0; i < y.length; i++) {
+    const row = design(i);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let a = 0; a < p; a++) {
+    for (let b = 0; b < p; b++) beta[a] += inv[a][b] * xty[b];
+  }
+
+  const meat = Array.from({ length: p }, () => new Array(p).fill(0));
+  for (let i = 0; i < y.length; i++) {
+    const row = design(i);
+    let fitted = 0;
+    for (let a = 0; a < p; a++) fitted += row[a] * beta[a];
+    const e2 = (y[i] - fitted) ** 2;
+    for (let a = 0; a < p; a++) {
+      for (let b = 0; b < p; b++) meat[a][b] += e2 * row[a] * row[b];
+    }
+  }
+  const robust = matMul(matMul(inv, meat), inv);
+  const scale = y.length / (y.length - p);
+  const rows = {};
+  for (let a = 0; a < p; a++) {
+    const se = Math.sqrt(Math.max(0, robust[a][a] * scale));
+    const z = beta[a] / se;
+    rows[names[a]] = { beta: beta[a], se, z, p: twoSidedP(z) };
+  }
