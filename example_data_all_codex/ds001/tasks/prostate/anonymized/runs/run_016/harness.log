+function matMul(A, B) {
+  const out = Array.from({ length: A.length }, () => new Array(B[0].length).fill(0));
+  for (let i = 0; i < A.length; i++) {
+    for (let k = 0; k < B.length; k++) {
+      const aik = A[i][k];
+      if (aik === 0) continue;
+      for (let j = 0; j < B[0].length; j++) out[i][j] += aik * B[k][j];
+    }
+  }
+  return out;
