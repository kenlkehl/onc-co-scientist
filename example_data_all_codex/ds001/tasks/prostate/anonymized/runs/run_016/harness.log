+  const meat = Array.from({ length: p }, () => new Array(p).fill(0));
+  for (let i = 0; i < y.length; i++) {
+    const row = design(i);
+    let fitted = 0;
+    for (let a = 0; a < p; a++) fitted += row[a] * beta[a];
+    const e2 = (y[i] - fitted) ** 2;
+    for (let a = 0; a < p; a++) {
+      for (let b = 0; b < p; b++) meat[a][b] += e2 * row[a] * row[b];
+    }
+  }
