const buf=b.slice(b.length-8-footerLen, b.length-8);
let pos=0;
function readVarint(){ let shift=0, result=0n; while(true){ const byte=buf[pos++]; result |= BigInt(byte & 0x7f) << BigInt(shift); if((byte & 0x80)===0) break; shift+=7; } return result; }
function zigzag(n){ return (n >> 1n) "'^ (-(n & 1n)); }
function num(n){ const z=zigzag(n); return Number(z); }
function readI16(){return num(readVarint());}
function readI32(){return num(readVarint());}
function readI64(){ const z=zigzag(readVarint()); return Number(z); }
function readDouble(){ const v=buf.readDoubleLE(pos); pos+=8; return v; }
function readFloat(){ const v=buf.readFloatLE(pos); pos+=4; return v; }
function readBinary(){ const len=Number(readVarint()); const s=buf.slice(pos,pos+len); pos+=len; return s.toString('"'utf8'); }
function readList(){ const h=buf[pos++]; let size=h>>4; const et=h&0x0f; if(size===15) size=Number(readVarint()); const arr=[]; for(let i=0;i<size;i++) arr.push(readValue(et)); return arr; }
function readMap(){ const size=Number(readVarint()); if(size===0) return []; const h=buf[pos++]; const kt=h>>4, vt=h&0x0f; const arr=[]; for(let i=0;i<size;i++) arr.push([readValue(kt), readValue(vt)]); return arr; }
function readStruct(){ let last=0; const obj={}; while(true){ const h=buf[pos++]; const type=h&0x0f; if(type===0) break; const delta=h>>4; let fid; if(delta===0) fid=readI16(); else fid=last+delta; last=fid; obj[fid]=readValue(type); } return obj; }
function readValue(t){ switch(t){ case 1:return true; case 2:return false; case 3:return (buf[pos++]<<24)>>24; case 4:return readI16(); case 5:return readI32(); case 6:return readI64(); case 7:return readDouble(); case 8:return readBinary(); case 9:return readList(); case 10:return readList(); case 11:return readMap(); case 12:return readStruct(); case 13:return readFloat(); default: throw new Error('type '+t+' at '+pos); } }
