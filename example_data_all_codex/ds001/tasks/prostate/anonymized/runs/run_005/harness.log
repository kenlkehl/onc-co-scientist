function decodeHybrid(buf,start,bitWidth,count,end=null){const st={pos:start};const vals=[];const bytesFor=Math.ceil(bitWidth/8);while(vals.length<count && st.pos<(end??buf.length)){const header=readUnsignedVar(buf,st);if((header&1)===0){const run=header>>1;let v=0;for(let i=0;i<bytesFor;i++)v|=(buf[st.pos++]||0)<<(8*i);for(let i=0;i<run&&vals.length<count;i++)vals.push(v);}else{const groups=header>>1;const n=groups*8;let bitPos=st.pos*8;for(let i=0;i<n&&vals.length<count;i++){let v=0;for(let b=0;b<bitWidth;b++){const byte=buf[Math.floor(bitPos/8)];v|=((byte>>(bitPos%8))&1)<<b;bitPos++;}vals.push(v);}st.pos+=Math.ceil(n*bitWidth/8);}}return{vals,pos:st.pos};}
function decodeDataPage(page,type,dict){const ph=page.header;const dph=ph[5];if("'!dph)throw new Error('"'unsupported page header '+JSON.stringify(ph));const numValues=dph[1];const encoding=dph[2];let pos=0; // no repeated fields; def levels only, because schema fields are optional
const defLen=page.body.readInt32LE(pos);pos+=4;const def=decodeHybrid(page.body,pos,1,numValues,pos+defLen);pos+=defLen;const nonNull=def.vals.reduce((a,v)=>a+(v?1:0),0);let values=[];if(encoding===8||encoding===2){const bitWidth=page.body[pos++];const dec=decodeHybrid(page.body,pos,bitWidth,nonNull);values=dec.vals.map(i=>dict[i]);pos=dec.pos;}else if(encoding===0){values=readPlainDict(page.body.slice(pos),type,nonNull);}else throw new Error('encoding '+encoding);return values;}
function decodeColumn(chunk){const cm=chunk[3];const type=cm[1];const n=cm[5];const dictOff=cm[11];let dict=null;if(dictOff"'!=null){const dp=readPage(dictOff);const dh=dp.header[7];dict=readPlainDict(dp.body,type,dh[1]);}
let off=cm[9];const out=[];while(out.length<n){const pg=readPage(off);if(pg.header[1]===0){out.push(...decodeDataPage(pg,type,dict));}else if(pg.header[1]===2){/* dictionary page unexpectedly in stream */}else throw new Error('"'unsupported page type '+pg.header[1]);off=pg.next;if(off>file.length)throw new Error('ran past file');}
