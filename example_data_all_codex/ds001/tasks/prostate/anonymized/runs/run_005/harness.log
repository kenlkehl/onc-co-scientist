function pNorm(z){return Math.max(0,Math.min(1,2*(1-normCdf(Math.abs(z)))));}
function rdTest(ind,y){let n1=0,s1=0,n0=0,s0=0;for(let i=0;i<y.length;i++){if(ind[i]){n1++;s1+=y[i];}else{n0++;s0+=y[i];}}const p1=s1/n1,p0=s0/n0,rd=p1-p0;const se=Math.sqrt(p1*(1-p1)/n1+p0*(1-p0)/n0);const z=rd/se;return{n1,n0,p1,p0,effect:rd,se,z,p:pNorm(z)};}
function didTest(a,b,y){const cells={};for(const A of [0,1])for(const B of [0,1])cells["'`${A}${B}`]={n:0,s:0};for(let i=0;i<y.length;i++){const A=a[i]?1:0,B=b[i]?1:0;const c=cells[`${A}${B}`];c.n++;c.s+=y[i];}
for(const k in cells){cells[k].p=cells[k].s/cells[k].n;cells[k].v=cells[k].p*(1-cells[k].p)/cells[k].n;}
const effect=(cells['"'11'].p-cells['01'].p)-(cells['10'].p-cells['00'].p);const se=Math.sqrt(cells['11'].v+cells['01'].v+cells['10'].v+cells['00'].v);const z=effect/se;return{effect,se,z,p:pNorm(z),cells};}
function corrSlope(x,y){const n=x.length;let sx=0,sy=0,sxx=0,sxy=0;for(let i=0;i<n;i++){sx+=x[i];sy+=y[i];sxx+=x[i]*x[i];sxy+=x[i]*y[i];}const mx=sx/n,my=sy/n;const Sxx=sxx-n*mx*mx;const Sxy=sxy-n*mx*my;const beta=Sxy/Sxx;let rss=0;for(let i=0;i<n;i++){const e=y[i]-(my+beta*(x[i]-mx));rss+=e*e;}const se=Math.sqrt((rss/(n-2))/Sxx);const z=beta/se;return{effect:beta,se,z,p:pNorm(z),meanX:mx,meanY:my};}
const meta=parseFooter();const chunks=meta[4][0][1];const data={};const names=[];for(let ci=0;ci<chunks.length;ci++){const name=chunks[ci][3][3][0].toString();if(name==='patient_id')continue;const vals=decodeColumn(chunks[ci]);data[name]=vals;names.push(name);}const y=data['objective_response'];const features=names.filter(n=>n"'!=='"'objective_response');console.log('decoded', names.length, 'columns; outcome mean', y.reduce((a,b)=>a+b,0)/y.length);
const summaries=[];for(const f of features){const x=data[f];const counts=new Map();let sx=0,min=Infinity,max=-Infinity;for(const v of x){counts.set(v,(counts.get(v)||0)+1);if(typeof v==='number'){sx+=v;if(v<min)min=v;if(v>max)max=v;}}const uniq=[...counts.keys()].sort((a,b)=>a-b);summaries.push({f,nunique:uniq.length,min,max,mean:sx/x.length,counts:[...counts.entries()].sort((a,b)=>a[0]-b[0]).slice(0,12)});}console.log('summaries first', JSON.stringify(summaries.slice(0,10),null,2));
const main=[];const indicators=[];for(const s of summaries){const f=s.f,x=data[f],uniq=[...new Set(x)].sort((a,b)=>a-b);if(uniq.length<=1)continue;if(uniq.length===2){const hi=Math.max(...uniq),lo=Math.min(...uniq);const ind=x.map(v=>v===hi);const r=rdTest(ind,y);main.push({feature:f,type:'binary',level:hi,ref:lo,...r});indicators.push({name:"'`${f}=${hi}`,feature:f,kind:'"'binary',ind,desc:"'`${f} = ${hi}`,...r});}
else if(uniq.length<=8){for(const lev of uniq){const ind=x.map(v=>v===lev);const r=rdTest(ind,y);main.push({feature:f,type:'"'level',level:lev,ref:'other',...r});if(r.n1>=500&&r.n0>=500)indicators.push({name:"'`${f}=${lev}`,feature:f,kind:'"'level',ind,desc:"'`${f} = ${lev}`,...r});}
const lo=uniq[0],hi=uniq[uniq.length-1];const r=rdTest(x.map(v=>v===hi),y);const rlo=rdTest(x.map(v=>v===lo),y);}
else{const r=corrSlope(x,y);main.push({feature:f,type:'"'continuous_slope',level:'per_unit',...r});const sorted=[...x].sort((a,b)=>a-b);const med=sorted[Math.floor(sorted.length/2)];const ind=x.map(v=>v>=med);const rr=rdTest(ind,y);indicators.push({name:"'`${f}>=${med}`,feature:f,kind:'"'median',threshold:med,ind,desc:"'`${f} >= ${med}`,...rr});}}
main.sort((a,b)=>a.p-b.p);console.log('"'top main');for(const m of main.slice(0,40)){console.log(JSON.stringify({...m, ind:undefined}));}
