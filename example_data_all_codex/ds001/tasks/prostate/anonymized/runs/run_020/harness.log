+class TCompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+    this.lastField = [];
+    this.currentField = 0;
+  }
+  readByte() { return this.buf[this.pos++]; }
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  readZigZag() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  readI16Raw() {
+    const n = this.readZigZag();
+    return Number(n);
+  }
+  readI32() { return Number(this.readZigZag()); }
+  readI64() {
+    const n = this.readZigZag();
+    const asNum = Number(n);
+    return Number.isSafeInteger(asNum) ? asNum : n.toString();
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const s = this.buf.toString('utf8', this.pos, this.pos + len);
+    this.pos += len;
+    return s;
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) id = this.readI16Raw();
+    else id = this.currentField + delta;
+    this.currentField = id;
+    return { type, id };
+  }
+  readStruct(spec) {
+    this.lastField.push(this.currentField);
+    this.currentField = 0;
+    const out = {};
+    while (true) {
+      const f = this.readFieldBegin();
+      if (f.type === 0) break;
+      const fieldSpec = spec[f.id];
+      const name = fieldSpec ? fieldSpec.name : `field_${f.id}`;
+      const kind = fieldSpec ? fieldSpec.kind : null;
+      out[name] = this.readValue(f.type, kind);
+    }
+    this.currentField = this.lastField.pop();
+    return out;
+  }
+  readList(elemKind) {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(this.readValue(elemType, elemKind));
+    return arr;
+  }
+  readValue(type, kind) {
+    if (type === 1) return true;
+    if (type === 2) return false;
+    if (type === 3) return this.readByte();
+    if (type === 4) return this.readI16Raw();
+    if (type === 5) return this.readI32();
+    if (type === 6) return this.readI64();
+    if (type === 7) return this.readDouble();
+    if (type === 8) return this.readBinary();
+    if (type === 9) return this.readList(kind && kind.elem);
+    if (type === 12) return this.readStruct(kind && kind.spec ? kind.spec : {});
+    throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+  }
+}
