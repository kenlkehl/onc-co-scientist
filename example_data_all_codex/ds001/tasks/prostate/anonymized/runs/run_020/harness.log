+const fs = require('fs');
+
+class TCompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+    this.lastField = [];
+    this.currentField = 0;
+  }
+  readByte() { return this.buf[this.pos++]; }
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  readZigZag() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  readI16Raw() {
+    const n = this.readZigZag();
+    return Number(n);
+  }
+  readI32() { return Number(this.readZigZag()); }
+  readI64() {
+    const n = this.readZigZag();
+    const asNum = Number(n);
+    return Number.isSafeInteger(asNum) ? asNum : n.toString();
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const s = this.buf.toString('utf8', this.pos, this.pos + len);
+    this.pos += len;
+    return s;
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) id = this.readI16Raw();
+    else id = this.currentField + delta;
+    this.currentField = id;
+    return { type, id };
+  }
+  readStruct(spec) {
+    this.lastField.push(this.currentField);
+    this.currentField = 0;
+    const out = {};
+    while (true) {
+      const f = this.readFieldBegin();
+      if (f.type === 0) break;
+      const fieldSpec = spec[f.id];
+      const name = fieldSpec ? fieldSpec.name : `field_${f.id}`;
+      const kind = fieldSpec ? fieldSpec.kind : null;
+      out[name] = this.readValue(f.type, kind);
+    }
+    this.currentField = this.lastField.pop();
+    return out;
+  }
+  readList(elemKind) {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(this.readValue(elemType, elemKind));
+    return arr;
+  }
+  readValue(type, kind) {
+    if (type === 1) return true;
+    if (type === 2) return false;
+    if (type === 3) return this.readByte();
+    if (type === 4) return this.readI16Raw();
+    if (type === 5) return this.readI32();
+    if (type === 6) return this.readI64();
+    if (type === 7) return this.readDouble();
+    if (type === 8) return this.readBinary();
+    if (type === 9) return this.readList(kind && kind.elem);
+    if (type === 12) return this.readStruct(kind && kind.spec ? kind.spec : {});
+    throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+  }
+}
+
+const SchemaElement = {
+  1: { name: 'type', kind: null },
+  2: { name: 'type_length', kind: null },
+  3: { name: 'repetition_type', kind: null },
+  4: { name: 'name', kind: null },
+  5: { name: 'num_children', kind: null },
+  6: { name: 'converted_type', kind: null },
+  7: { name: 'scale', kind: null },
+  8: { name: 'precision', kind: null },
+  9: { name: 'field_id', kind: null },
+};
+const Statistics = {
+  1: { name: 'max', kind: null },
+  2: { name: 'min', kind: null },
+  3: { name: 'null_count', kind: null },
+  4: { name: 'distinct_count', kind: null },
+  5: { name: 'max_value', kind: null },
+  6: { name: 'min_value', kind: null },
+};
+const ColumnMetaData = {
+  1: { name: 'type', kind: null },
+  2: { name: 'encodings', kind: { elem: null } },
+  3: { name: 'path_in_schema', kind: { elem: null } },
+  4: { name: 'codec', kind: null },
+  5: { name: 'num_values', kind: null },
+  6: { name: 'total_uncompressed_size', kind: null },
+  7: { name: 'total_compressed_size', kind: null },
+  9: { name: 'data_page_offset', kind: null },
+  10: { name: 'index_page_offset', kind: null },
+  11: { name: 'dictionary_page_offset', kind: null },
+  12: { name: 'statistics', kind: { spec: Statistics } },
+};
+const ColumnChunk = {
+  1: { name: 'file_path', kind: null },
+  2: { name: 'file_offset', kind: null },
+  3: { name: 'meta_data', kind: { spec: ColumnMetaData } },
+};
+const RowGroup = {
+  1: { name: 'columns', kind: { elem: { spec: ColumnChunk } } },
+  2: { name: 'total_byte_size', kind: null },
+  3: { name: 'num_rows', kind: null },
+  6: { name: 'total_compressed_size', kind: null },
+};
+const FileMetaData = {
+  1: { name: 'version', kind: null },
+  2: { name: 'schema', kind: { elem: { spec: SchemaElement } } },
+  3: { name: 'num_rows', kind: null },
+  4: { name: 'row_groups', kind: { elem: { spec: RowGroup } } },
+  6: { name: 'created_by', kind: null },
+};
+
+const PageHeader = {
+  1: { name: 'type', kind: null },
+  2: { name: 'uncompressed_page_size', kind: null },
+  3: { name: 'compressed_page_size', kind: null },
+  5: { name: 'data_page_header', kind: { spec: {
+    1: { name: 'num_values', kind: null },
+    2: { name: 'encoding', kind: null },
+    3: { name: 'definition_level_encoding', kind: null },
+    4: { name: 'repetition_level_encoding', kind: null },
+  } } },
+  7: { name: 'dictionary_page_header', kind: { spec: {
+    1: { name: 'num_values', kind: null },
+    2: { name: 'encoding', kind: null },
+    3: { name: 'is_sorted', kind: null },
+  } } },
+  8: { name: 'data_page_header_v2', kind: { spec: {
+    1: { name: 'num_values', kind: null },
+    2: { name: 'num_nulls', kind: null },
+    3: { name: 'num_rows', kind: null },
+    4: { name: 'encoding', kind: null },
+    5: { name: 'definition_levels_byte_length', kind: null },
+    6: { name: 'repetition_levels_byte_length', kind: null },
+    7: { name: 'is_compressed', kind: null },
+  } } },
+};
+
+const file = fs.readFileSync('dataset.parquet');
+const magic = file.toString('ascii', 0, 4);
+const footerMagic = file.toString('ascii', file.length - 4);
+const footerLen = file.readUInt32LE(file.length - 8);
+const metaStart = file.length - 8 - footerLen;
+const reader = new TCompactReader(file, metaStart);
+const meta = reader.readStruct(FileMetaData);
+console.log({ magic, footerMagic, footerLen, metaStart, end: reader.pos });
+console.log('created_by', meta.created_by);
+console.log('rows', meta.num_rows, 'row_groups', meta.row_groups.length, 'schema_len', meta.schema.length);
+console.log('schema', meta.schema.slice(0, 10));
+const rg = meta.row_groups[0];
+console.log('row_group rows', rg.num_rows, 'columns', rg.columns.length, 'total_compressed_size', rg.total_compressed_size);
+for (let i = 0; i < Math.min(8, rg.columns.length); i++) {
+  const cm = rg.columns[i].meta_data;
+  console.log(i, cm.path_in_schema, 'type', cm.type, 'codec', cm.codec, 'enc', cm.encodings, 'num', cm.num_values, 'offs', {
+    dict: cm.dictionary_page_offset,
+    data: cm.data_page_offset,
+    comp: cm.total_compressed_size,
+    uncomp: cm.total_uncompressed_size
+  });
+}
+for (let i = 0; i < Math.min(3, rg.columns.length); i++) {
+  const cm = rg.columns[i].meta_data;
+  let pos = cm.dictionary_page_offset || cm.data_page_offset;
+  console.log('pages for', cm.path_in_schema[0]);
+  let values = 0;
+  for (let j = 0; j < 5 && values < cm.num_values; j++) {
+    const pr = new TCompactReader(file, pos);
+    const h = pr.readStruct(PageHeader);
+    console.log(' page', j, 'header', h, 'headerBytes', pr.pos - pos, 'payloadAt', pr.pos);
+    pos = pr.pos + h.compressed_page_size;
+    if (h.type === 0 && h.data_page_header) values += h.data_page_header.num_values;
+    if (h.type === 3 && h.data_page_header_v2) values += h.data_page_header_v2.num_values;
+  }
+}

