+    2: { name: 'encoding', kind: null },
+    3: { name: 'definition_level_encoding', kind: null },
+    4: { name: 'repetition_level_encoding', kind: null },
+  } } },
+  7: { name: 'dictionary_page_header', kind: { spec: {
