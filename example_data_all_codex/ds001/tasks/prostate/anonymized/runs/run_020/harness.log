+      dictionary = decodePlainValues(body, type, dh.num_values);
+    } else if (pageHeader.type === 0) {
+      const dh = pageHeader.data_page_header;
+      let bodyPos = 0;
+      let defLevels = null;
+      if (maxDef > 0) {
+        const d = decodeRleBitPacked(body, bodyPos, dh.num_values, defWidth);
+        defLevels = d.values;
+        bodyPos = d.pos;
+      }
+      let valueCount = dh.num_values;
+      if (defLevels) valueCount = defLevels.reduce((a, v) => a + (v === maxDef ? 1 : 0), 0);
+      let values;
+      if (dh.encoding === 8 || dh.encoding === 2) {
