+  if (!Number.isFinite(az)) return 1;
+  if (az > 8) {
+    const logP = Math.log(2) - 0.5 * az * az - Math.log(az) - 0.5 * Math.log(2 * Math.PI);
+    return logP < -745 ? 0 : Math.exp(logP);
+  }
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(az))));
+}
+
+function diffTest(indicator, y, subset = null) {
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (subset && !subset[i]) continue;
+    if (indicator[i]) { n1++; s1 += y[i]; }
+    else { n0++; s0 += y[i]; }
+  }
+  const p1 = s1 / n1;
+  const p0 = s0 / n0;
+  const diff = p1 - p0;
+  const pooled = (s1 + s0) / (n1 + n0);
+  const se = Math.sqrt(pooled * (1 - pooled) * (1 / n1 + 1 / n0));
+  const z = se > 0 ? diff / se : 0;
+  return { n1, n0, p1, p0, effect: diff, se, z, p: twoSidedPFromZ(z) };
+}
+
+function cellMeans(a, b, y) {
+  const cells = {};
+  for (const key of ['00', '01', '10', '11']) cells[key] = { n: 0, s: 0 };
+  for (let i = 0; i < y.length; i++) {
+    const key = (a[i] ? '1' : '0') + (b[i] ? '1' : '0');
+    cells[key].n++;
+    cells[key].s += y[i];
+  }
+  for (const key of Object.keys(cells)) {
+    cells[key].p = cells[key].s / cells[key].n;
+    cells[key].var = cells[key].p * (1 - cells[key].p) / cells[key].n;
+  }
+  return cells;
+}
+
+function interactionTest(a, b, y) {
+  const c = cellMeans(a, b, y);
+  const minN = Math.min(c['00'].n, c['01'].n, c['10'].n, c['11'].n);
+  const effect = c['11'].p - c['10'].p - c['01'].p + c['00'].p;
+  const se = Math.sqrt(c['11'].var + c['10'].var + c['01'].var + c['00'].var);
+  const z = se > 0 ? effect / se : 0;
+  return { cells: c, minN, effect, se, z, p: twoSidedPFromZ(z) };
+}
+
+function threeWayTest(a, b, c, y) {
+  const cells = {};
+  for (const key of ['000','001','010','011','100','101','110','111']) cells[key] = { n: 0, s: 0 };
+  for (let i = 0; i < y.length; i++) {
+    const key = (a[i] ? '1' : '0') + (b[i] ? '1' : '0') + (c[i] ? '1' : '0');
+    cells[key].n++;
+    cells[key].s += y[i];
+  }
+  for (const key of Object.keys(cells)) {
+    cells[key].p = cells[key].s / cells[key].n;
+    cells[key].var = cells[key].p * (1 - cells[key].p) / cells[key].n;
+  }
+  const weights = { '111': 1, '110': -1, '101': -1, '011': -1, '100': 1, '010': 1, '001': 1, '000': -1 };
+  let effect = 0, variance = 0, minN = Infinity;
+  for (const key of Object.keys(weights)) {
+    effect += weights[key] * cells[key].p;
+    variance += cells[key].var;
+    minN = Math.min(minN, cells[key].n);
+  }
+  const se = Math.sqrt(variance);
+  const z = se > 0 ? effect / se : 0;
+  return { cells, minN, effect, se, z, p: twoSidedPFromZ(z) };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => (i === j ? 1 : 0))));
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(m[r][col]) > Math.abs(m[pivot][col])) pivot = r;
+    if (Math.abs(m[pivot][col]) < 1e-12) throw new Error('Singular matrix');
+    [m[col], m[pivot]] = [m[pivot], m[col]];
+    const div = m[col][col];
+    for (let j = 0; j < 2 * n; j++) m[col][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = m[r][col];
+      for (let j = 0; j < 2 * n; j++) m[r][j] -= factor * m[col][j];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...predictors.map((pred) => pred.values[i] ? 1 : 0)];
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = 0; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let fitted = beta[0];
+    for (let j = 1; j < p; j++) fitted += beta[j] * (predictors[j - 1].values[i] ? 1 : 0);
+    const e = y[i] - fitted;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const terms = [];
+  for (let j = 1; j < p; j++) {
+    const se = Math.sqrt(sigma2 * inv[j][j]);
+    const z = beta[j] / se;
+    terms.push({ name: predictors[j - 1].name, effect: beta[j], se, z, p: twoSidedPFromZ(z) });
+  }
+  return { beta, terms };
+}
+
+function binaryPhi(a, b) {
+  let n11 = 0, n10 = 0, n01 = 0, n00 = 0;
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] && b[i]) n11++;
+    else if (a[i] && !b[i]) n10++;
+    else if (!a[i] && b[i]) n01++;
+    else n00++;
+  }
+  const denom = Math.sqrt((n11 + n10) * (n01 + n00) * (n11 + n01) * (n10 + n00));
+  return denom > 0 ? ((n11 * n00) - (n10 * n01)) / denom : 0;
+}
+
+function fmt(x, digits = 4) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 1000 || (Math.abs(x) > 0 && Math.abs(x) < 0.001)) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function cleanNumber(x) {
+  if (!Number.isFinite(x)) return null;
+  if (Object.is(x, -0)) return 0;
+  return Number(x.toPrecision(12));
+}
+
+function conditionText(summary) {
+  if (summary.kind === 'binary') return `\`${summary.name}\` equal to ${summary.highValue}`;
+  return `\`${summary.name}\` above its median (${fmt(summary.threshold, 3)})`;
+}
+
+function complementText(summary) {
+  if (summary.kind === 'binary') return `\`${summary.name}\` not equal to ${summary.highValue}`;
+  return `\`${summary.name}\` at or below its median (${fmt(summary.threshold, 3)})`;
+}
+
+function shortCondition(summary) {
+  if (summary.kind === 'binary') return `${summary.name}=${summary.highValue}`;
+  return `${summary.name}>median`;
+}
+
+function summarizeFeature(name, x, y) {
+  const uniques = uniqueSorted(x);
+  if (uniques.length < 2) return null;
+  const sorted = x.slice().sort((a, b) => a - b);
+  const median = quantileSorted(sorted, 0.5);
+  const isBinary = uniques.length === 2;
+  const highValue = isBinary ? uniques[1] : null;
+  const indicator = x.map((v) => isBinary ? v === highValue : v > median);
+  const test = diffTest(indicator, y);
+  return {
+    name,
+    uniqueCount: uniques.length,
+    min: sorted[0],
+    max: sorted[sorted.length - 1],
+    threshold: median,
+    kind: isBinary ? 'binary' : 'median',
+    highValue,
+    indicator,
+    test,
+  };
+}
+
+function main() {
+  const { columns, rowCount } = loadParquet('dataset.parquet');
+  const y = columns.objective_response;
+  const outcomeRate = mean(y);
+  const featureNames = Object.keys(columns).filter((c) => c !== 'objective_response');
+  const summaries = featureNames
+    .map((name) => summarizeFeature(name, columns[name], y))
+    .filter(Boolean);
+
+  const byP = summaries.slice().sort((a, b) => a.test.p - b.test.p);
+  const positives = byP.filter((s) => s.test.effect > 0);
+  const negatives = byP.filter((s) => s.test.effect < 0);
+  const mainChoices = [];
+  for (const s of positives.slice(0, 5)) mainChoices.push(s);
+  for (const s of negatives.slice(0, 5)) mainChoices.push(s);
+  mainChoices.sort((a, b) => a.test.p - b.test.p);
+
+  const interactionPool = byP.slice(0, 18);
+  const pairTests = [];
+  for (let i = 0; i < interactionPool.length; i++) {
+    for (let j = i + 1; j < interactionPool.length; j++) {
+      const a = interactionPool[i], b = interactionPool[j];
+      const test = interactionTest(a.indicator, b.indicator, y);
+      if (test.minN >= 100) pairTests.push({ a, b, test });
+    }
+  }
+  pairTests.sort((u, v) => u.test.p - v.test.p || Math.abs(v.test.effect) - Math.abs(u.test.effect));
+
+  const threeTests = [];
+  const threePool = byP.slice(0, 10);
+  for (let i = 0; i < threePool.length; i++) {
+    for (let j = i + 1; j < threePool.length; j++) {
+      for (let k = j + 1; k < threePool.length; k++) {
+        const a = threePool[i], b = threePool[j], c = threePool[k];
+        const test = threeWayTest(a.indicator, b.indicator, c.indicator, y);
+        if (test.minN >= 50) threeTests.push({ a, b, c, test });
+      }
+    }
+  }
+  threeTests.sort((u, v) => u.test.p - v.test.p || Math.abs(v.test.effect) - Math.abs(u.test.effect));
+
+  const adjustedSummaries = [];
+  for (const s of byP) {
+    if (adjustedSummaries.length >= 12) break;
+    let redundant = false;
+    for (const existing of adjustedSummaries) {
+      if (Math.abs(binaryPhi(s.indicator, existing.indicator)) > 0.98) {
+        redundant = true;
+        break;
+      }
+    }
+    if (!redundant) adjustedSummaries.push(s);
+  }
+  let adjustedPredictors = adjustedSummaries.map((s) => ({ name: s.name, values: s.indicator, summary: s }));
+  let adjusted;
+  while (adjustedPredictors.length > 1) {
+    try {
+      adjusted = ols(y, adjustedPredictors);
