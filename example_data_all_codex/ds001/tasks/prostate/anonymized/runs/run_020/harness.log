+      } else if (dh.encoding === 0) {
+        values = decodePlainDataValues(body, bodyPos, type, valueCount);
+      } else {
+        throw new Error(`Unsupported data encoding ${dh.encoding}`);
+      }
+      let valueIndex = 0;
+      for (let i = 0; i < dh.num_values; i++) {
+        if (!defLevels || defLevels[i] === maxDef) out[decodedCount++] = values[valueIndex++];
+        else out[decodedCount++] = NaN;
+      }
+    } else if (pageHeader.type === 3) {
+      throw new Error('DataPageV2 not implemented for this dataset');
+    }
+  }
+  if (decodedCount !== meta.num_values) {
+    throw new Error(`Decoded ${decodedCount} of ${meta.num_values} for ${meta.path_in_schema.join('.')}`);
