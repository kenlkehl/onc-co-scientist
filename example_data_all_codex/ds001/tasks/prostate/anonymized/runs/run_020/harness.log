+    this.currentField = 0;
+  }
+  readByte() { return this.buf[this.pos++]; }
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const b = this.readByte();
+      out |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return out;
+      shift += 7n;
+    }
+  }
+  readZigZag() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  readI16Raw() { return Number(this.readZigZag()); }
+  readI32() { return Number(this.readZigZag()); }
+  readI64() {
+    const n = this.readZigZag();
+    const v = Number(n);
+    return Number.isSafeInteger(v) ? v : n.toString();
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const start = this.pos;
+    this.pos += len;
+    return this.buf.toString('utf8', start, start + len);
+  }
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { id: 0, type: 0 };
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) id = this.readI16Raw();
+    else id = this.currentField + delta;
+    this.currentField = id;
+    return { id, type };
+  }
+  readStruct(spec = {}) {
+    this.stack.push(this.currentField);
+    this.currentField = 0;
+    const out = {};
+    while (true) {
+      const field = this.readFieldBegin();
+      if (field.type === 0) break;
+      const fieldSpec = spec[field.id];
+      const name = fieldSpec ? fieldSpec.name : `field_${field.id}`;
+      out[name] = this.readValue(field.type, fieldSpec ? fieldSpec.kind : null);
+    }
+    this.currentField = this.stack.pop();
+    return out;
+  }
+  readList(elemKind) {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(this.readValue(elemType, elemKind));
+    return arr;
+  }
+  readValue(type, kind) {
+    if (type === 1) return true;
