+
+function main() {
+  const { columns, rowCount } = loadParquet('dataset.parquet');
+  const y = columns.objective_response;
+  const outcomeRate = mean(y);
+  const featureNames = Object.keys(columns).filter((c) => c !== 'objective_response');
+  const summaries = featureNames
+    .map((name) => summarizeFeature(name, columns[name], y))
+    .filter(Boolean);
+
+  const byP = summaries.slice().sort((a, b) => a.test.p - b.test.p);
+  const positives = byP.filter((s) => s.test.effect > 0);
+  const negatives = byP.filter((s) => s.test.effect < 0);
+  const mainChoices = [];
+  for (const s of positives.slice(0, 5)) mainChoices.push(s);
+  for (const s of negatives.slice(0, 5)) mainChoices.push(s);
+  mainChoices.sort((a, b) => a.test.p - b.test.p);
+
+  const interactionPool = byP.slice(0, 18);
+  const pairTests = [];
+  for (let i = 0; i < interactionPool.length; i++) {
+    for (let j = i + 1; j < interactionPool.length; j++) {
+      const a = interactionPool[i], b = interactionPool[j];
+      const test = interactionTest(a.indicator, b.indicator, y);
+      if (test.minN >= 100) pairTests.push({ a, b, test });
+    }
+  }
+  pairTests.sort((u, v) => u.test.p - v.test.p || Math.abs(v.test.effect) - Math.abs(u.test.effect));
+
+  const threeTests = [];
+  const threePool = byP.slice(0, 10);
+  for (let i = 0; i < threePool.length; i++) {
+    for (let j = i + 1; j < threePool.length; j++) {
+      for (let k = j + 1; k < threePool.length; k++) {
+        const a = threePool[i], b = threePool[j], c = threePool[k];
+        const test = threeWayTest(a.indicator, b.indicator, c.indicator, y);
