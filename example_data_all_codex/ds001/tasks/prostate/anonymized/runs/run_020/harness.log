+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(m[r][col]) > Math.abs(m[pivot][col])) pivot = r;
+    if (Math.abs(m[pivot][col]) < 1e-12) throw new Error('Singular matrix');
+    [m[col], m[pivot]] = [m[pivot], m[col]];
+    const div = m[col][col];
+    for (let j = 0; j < 2 * n; j++) m[col][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = m[r][col];
+      for (let j = 0; j < 2 * n; j++) m[r][j] -= factor * m[col][j];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const n = y.length;
+  const p = predictors.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1, ...predictors.map((pred) => pred.values[i] ? 1 : 0)];
+    for (let j = 0; j < p; j++) {
+      xty[j] += row[j] * y[i];
+      for (let k = 0; k < p; k++) xtx[j][k] += row[j] * row[k];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let fitted = beta[0];
+    for (let j = 1; j < p; j++) fitted += beta[j] * (predictors[j - 1].values[i] ? 1 : 0);
+    const e = y[i] - fitted;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const terms = [];
+  for (let j = 1; j < p; j++) {
+    const se = Math.sqrt(sigma2 * inv[j][j]);
+    const z = beta[j] / se;
+    terms.push({ name: predictors[j - 1].name, effect: beta[j], se, z, p: twoSidedPFromZ(z) });
+  }
+  return { beta, terms };
+}
+
+function binaryPhi(a, b) {
+  let n11 = 0, n10 = 0, n01 = 0, n00 = 0;
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] && b[i]) n11++;
+    else if (a[i] && !b[i]) n10++;
+    else if (!a[i] && b[i]) n01++;
+    else n00++;
+  }
+  const denom = Math.sqrt((n11 + n10) * (n01 + n00) * (n11 + n01) * (n10 + n00));
+  return denom > 0 ? ((n11 * n00) - (n10 * n01)) / denom : 0;
