import pandas as pd
from pathlib import Path

p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome unique/counts')
print(df['objective_response'].value_counts(dropna=False).sort_index().to_string())
print('outcome mean', df['objective_response'].mean())
rows=[]
for c in df.columns:
    if c=='objective_response':
        continue
    s=df[c]
    vc=s.value_counts(dropna=False).sort_index()
    rows.append((c, str(s.dtype), s.nunique(dropna=False), float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, vc.head(10).to_dict()))
for r in rows[:80]:
    print(r)
