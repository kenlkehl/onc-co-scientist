import pandas as pd
import numpy as np
from scipy import stats

pd.set_option('display.max_rows', 200)
df = pd.read_parquet('dataset.parquet')
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome counts')
print(df['objective_response'].value_counts(dropna=False).sort_index().to_string())
print('outcome mean', df['objective_response'].mean())
print('feature summary')
rows=[]
for c in df.columns:
    if c == 'objective_response':
        continue
    vc = df[c].value_counts().sort_index()
    rows.append((c, str(df[c].dtype), df[c].nunique(), df[c].mean(), df[c].std(), vc.to_dict() if df[c].nunique()<=10 else 'many'))
for r in rows:
    print(r)

# univariate binary risk differences if applicable
results=[]
y=df['objective_response'].astype(float)
for c in [x for x in df.columns if x"'!='"'objective_response']:
    vals=sorted(df[c].unique())
    if set(vals).issubset({0,1,False,True}):
        x=df[c].astype(int)
        n1=x.sum(); n0=len(x)-n1
        p1=y[x==1].mean(); p0=y[x==0].mean(); rd=p1-p0
        tab=pd.crosstab(x, df['objective_response'])
        try:
            chi2,p,_,_=stats.chi2_contingency(tab)
        except Exception as e:
            p=np.nan
        results.append((c,n1,n0,p1,p0,rd,p))
    else:
        # test numeric slope with point biserial/logit? store correlation
        slope, intercept, r, p, se=stats.linregress(df[c], y)
        results.append((c, None, None, None, None, slope,p))
results_sorted=sorted(results, key=lambda t: abs(t[5]), reverse=True)
print('\\nTop by abs RD/slope')
for r in results_sorted[:30]: print(r)
print('\\nTop by p')
for r in sorted(results, key=lambda t: t[6])[:30]: print(r)
