+const fs = require("fs");
+
+const DATASET_PATH = "dataset.parquet";
+const OUTCOME = "pfs_months";
+const DATASET_ID = "ds001_nsclc";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-local-node-parquet@1.0";
+const MAX_ITERATIONS = 25;
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.b = buf;
+    this.pos = pos;
+    this.lastField = [];
+  }
+  readByte() {
+    return this.b[this.pos++];
+  }
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const byte = this.readByte();
+      result |= BigInt(byte & 0x7f) << BigInt(shift);
+      if ((byte & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  readZigZag() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ -(n & 1n);
+  }
+  readI32() {
+    return Number(this.readZigZag());
+  }
+  readI64() {
+    return Number(this.readZigZag());
+  }
+  readDouble() {
+    const v = this.b.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.b.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readString() {
+    return this.readBinary().toString("utf8");
+  }
+  readListHeader() {
+    const x = this.readByte();
+    let size = x >> 4;
+    const etype = x & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, etype };
+  }
+  readFieldBegin() {
+    const x = this.readByte();
+    const type = x & 0x0f;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = x >> 4;
+    const last = this.lastField[this.lastField.length - 1] || 0;
+    const id = delta === 0 ? Number(this.readZigZag()) : last + delta;
+    return { type, id };
+  }
+  readStruct(readFields) {
+    this.lastField.push(0);
+    const out = {};
+    while (true) {
+      const f = this.readFieldBegin();
+      if (f.type === 0) break;
+      this.lastField[this.lastField.length - 1] = f.id;
+      readFields(out, f, this);
+    }
+    this.lastField.pop();
+    return out;
+  }
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+        this.readI32();
+        return;
+      case 6:
+        this.readI64();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case 9:
+      case 10: {
+        const h = this.readListHeader();
+        for (let i = 0; i < h.size; i++) this.skip(h.etype);
+        return;
+      }
+      case 11: {
+        const size = Number(this.readVarint());
+        if (size === 0) return;
+        const kt = this.readByte();
+        const vt = this.readByte();
+        for (let i = 0; i < size; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12:
+        this.lastField.push(0);
+        while (true) {
+          const f = this.readFieldBegin();
+          if (f.type === 0) break;
+          this.lastField[this.lastField.length - 1] = f.id;
+          this.skip(f.type);
+        }
+        this.lastField.pop();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+    }
+  }
+}
+
+function readStatistics(r) {
+  return r.readStruct((o, f, rr) => {
+    switch (f.id) {
+      case 1:
+        o.max = rr.readBinary();
+        break;
+      case 2:
+        o.min = rr.readBinary();
+        break;
+      case 3:
+        o.null_count = rr.readI64();
+        break;
+      case 4:
+        o.distinct_count = rr.readI64();
+        break;
+      case 5:
+        o.max_value = rr.readBinary();
+        break;
+      case 6:
+        o.min_value = rr.readBinary();
+        break;
+      default:
+        rr.skip(f.type);
+    }
+  });
+}
+
+function readSchemaElement(r) {
+  return r.readStruct((o, f, rr) => {
+    switch (f.id) {
+      case 1:
+        o.type = rr.readI32();
+        break;
+      case 2:
+        o.type_length = rr.readI32();
+        break;
+      case 3:
+        o.repetition_type = rr.readI32();
+        break;
+      case 4:
+        o.name = rr.readString();
+        break;
+      case 5:
+        o.num_children = rr.readI32();
+        break;
+      case 6:
+        o.converted_type = rr.readI32();
+        break;
+      default:
+        rr.skip(f.type);
+    }
+  });
+}
+
+function readColumnMetaData(r) {
+  return r.readStruct((o, f, rr) => {
+    switch (f.id) {
+      case 1:
+        o.type = rr.readI32();
+        break;
+      case 2: {
+        const h = rr.readListHeader();
+        o.encodings = [];
+        for (let i = 0; i < h.size; i++) o.encodings.push(rr.readI32());
+        break;
+      }
+      case 3: {
+        const h = rr.readListHeader();
+        o.path_in_schema = [];
+        for (let i = 0; i < h.size; i++) o.path_in_schema.push(rr.readString());
+        break;
+      }
+      case 4:
+        o.codec = rr.readI32();
+        break;
+      case 5:
+        o.num_values = rr.readI64();
+        break;
+      case 6:
+        o.total_uncompressed_size = rr.readI64();
+        break;
+      case 7:
+        o.total_compressed_size = rr.readI64();
+        break;
+      case 9:
+        o.data_page_offset = rr.readI64();
+        break;
+      case 10:
+        o.index_page_offset = rr.readI64();
+        break;
+      case 11:
+        o.dictionary_page_offset = rr.readI64();
+        break;
+      case 12:
+        o.statistics = readStatistics(rr);
+        break;
+      default:
+        rr.skip(f.type);
+    }
+  });
+}
+
+function readColumnChunk(r) {
+  return r.readStruct((o, f, rr) => {
+    switch (f.id) {
+      case 1:
+        o.file_path = rr.readString();
+        break;
+      case 2:
+        o.file_offset = rr.readI64();
+        break;
+      case 3:
+        o.meta_data = readColumnMetaData(rr);
+        break;
+      case 4:
+        o.offset_index_offset = rr.readI64();
+        break;
+      case 5:
+        o.offset_index_length = rr.readI32();
+        break;
+      case 6:
+        o.column_index_offset = rr.readI64();
+        break;
+      case 7:
+        o.column_index_length = rr.readI32();
+        break;
+      default:
+        rr.skip(f.type);
+    }
+  });
+}
+
+function readRowGroup(r) {
+  return r.readStruct((o, f, rr) => {
+    switch (f.id) {
+      case 1: {
+        const h = rr.readListHeader();
+        o.columns = [];
+        for (let i = 0; i < h.size; i++) o.columns.push(readColumnChunk(rr));
+        break;
+      }
+      case 2:
+        o.total_byte_size = rr.readI64();
+        break;
+      case 3:
+        o.num_rows = rr.readI64();
+        break;
+      case 5:
+        o.total_compressed_size = rr.readI64();
+        break;
+      default:
+        rr.skip(f.type);
+    }
+  });
+}
+
+function readFileMetaData(buf) {
+  const r = new CompactReader(buf);
+  return r.readStruct((o, f, rr) => {
+    switch (f.id) {
+      case 1:
+        o.version = rr.readI32();
+        break;
+      case 2: {
+        const h = rr.readListHeader();
+        o.schema = [];
+        for (let i = 0; i < h.size; i++) o.schema.push(readSchemaElement(rr));
+        break;
+      }
+      case 3:
+        o.num_rows = rr.readI64();
+        break;
+      case 4: {
+        const h = rr.readListHeader();
+        o.row_groups = [];
+        for (let i = 0; i < h.size; i++) o.row_groups.push(readRowGroup(rr));
+        break;
+      }
+      case 6:
+        o.created_by = rr.readString();
+        break;
+      default:
+        rr.skip(f.type);
+    }
+  });
+}
+
+function readPageHeader(buf, offset) {
+  const r = new CompactReader(buf, offset);
+  const header = r.readStruct((o, f, rr) => {
+    switch (f.id) {
+      case 1:
+        o.type = rr.readI32();
+        break;
+      case 2:
+        o.uncompressed_page_size = rr.readI32();
+        break;
+      case 3:
+        o.compressed_page_size = rr.readI32();
+        break;
+      case 5:
+        o.data_page_header = rr.readStruct((oo, ff, rrr) => {
+          switch (ff.id) {
+            case 1:
