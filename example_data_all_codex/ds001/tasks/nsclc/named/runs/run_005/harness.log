+        break;
+      default:
+        rr.skip(f.type);
+    }
+  });
+}
+
+function readRowGroup(r) {
+  return r.readStruct((o, f, rr) => {
+    switch (f.id) {
+      case 1: {
+        const h = rr.readListHeader();
+        o.columns = [];
+        for (let i = 0; i < h.size; i++) o.columns.push(readColumnChunk(rr));
