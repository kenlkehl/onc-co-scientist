+function decodeHybrid(buf, offset, byteLength, bitWidth, maxValues) {
+  const out = [];
+  let pos = offset;
+  const end = byteLength == null ? buf.length : offset + byteLength;
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (pos < end && out.length < maxValues) {
+    let header = 0;
+    let shift = 0;
+    while (true) {
+      const c = buf[pos++];
+      header |= (c & 0x7f) << shift;
+      if ((c & 0x80) === 0) break;
+      shift += 7;
+    }
+    if ((header & 1) === 0) {
+      const count = header >> 1;
+      let value = 0;
+      for (let i = 0; i < valueBytes; i++) value |= buf[pos++] << (8 * i);
+      for (let i = 0; i < count && out.length < maxValues; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const count = groups * 8;
+      const bytes = Math.ceil((count * bitWidth) / 8);
+      const bitStart = pos * 8;
+      for (let i = 0; i < count && out.length < maxValues; i++) {
+        out.push(readPackedValue(buf, bitStart + i * bitWidth, bitWidth));
+      }
+      pos += bytes;
+    }
+  }
+  return { values: out, pos };
