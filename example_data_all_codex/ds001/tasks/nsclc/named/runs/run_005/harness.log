class CompactReader {
  constructor(buf, pos=0, end=buf.length){ this.b=buf; this.pos=pos; this.end=end; this.lastField=[]; this.boolValue=null; }
  readByte(){ return this.b[this.pos++]; }
  readVarint(){ let shift=0, result=0n; while(true){ const byte=this.readByte(); result |= BigInt(byte & 0x7f) << BigInt(shift); if((byte & 0x80)===0) break; shift += 7; } return result; }
  readZigZag(){ const n=this.readVarint(); return (n >> 1n) "'^ (-(n & 1n)); }
  readI32(){ return Number(this.readZigZag()); }
  readI64(){ return this.readZigZag(); }
  readDouble(){ const v=this.b.readDoubleLE(this.pos); this.pos += 8; return v; }
  readBinary(){ const l=Number(this.readVarint()); const s=this.b.subarray(this.pos,this.pos+l); this.pos+=l; return s; }
  readString(){ return this.readBinary().toString('"'utf8'); }
  readListHeader(){ const x=this.readByte(); let size=x>>4, etype=x&0x0f; if(size===15) size=Number(this.readVarint()); return {size, etype}; }
  readFieldBegin(){ const x=this.readByte(); const type=x&0x0f; if(type===0) return {type:0,id:0}; const delta=x>>4; let id; const last=this.lastField[this.lastField.length-1] || 0; if(delta===0){ id=Number(this.readZigZag()); } else { id=last+delta; } return {type,id}; }
  readStruct(readFields){ this.lastField.push(0); const out={}; while(true){ const f=this.readFieldBegin(); if(f.type===0) break; this.lastField[this.lastField.length-1]=f.id; readFields(out,f,this); } this.lastField.pop(); return out; }
  skip(type){ switch(type){
    case 1: case 2: return;
    case 3: this.pos += 1; return;
    case 4: this.readI32(); return;
    case 5: this.readI32(); return;
    case 6: this.readI64(); return;
    case 7: this.pos += 8; return;
    case 8: { const l=Number(this.readVarint()); this.pos+=l; return; }
    case 9: case 10: { const {size,etype}=this.readListHeader(); for(let i=0;i<size;i++) this.skip(etype); return; }
    case 11: { const size=Number(this.readVarint()); if(size===0) return; const kt=this.readByte(), vt=this.readByte(); for(let i=0;i<size;i++){this.skip(kt); this.skip(vt);} return; }
    case 12: { this.lastField.push(0); while(true){ const f=this.readFieldBegin(); if(f.type===0) break; this.lastField[this.lastField.length-1]=f.id; this.skip(f.type); } this.lastField.pop(); return; }
    default: throw new Error('skip unknown type '+type+' at '+this.pos);
  }}
}
function readSchemaElement(r){ return r.readStruct((o,f,r)=>{ switch(f.id){
  case 1: o.type=r.readI32(); break;
  case 2: o.type_length=r.readI32(); break;
  case 3: o.repetition_type=r.readI32(); break;
  case 4: o.name=r.readString(); break;
  case 5: o.num_children=r.readI32(); break;
  case 6: o.converted_type=r.readI32(); break;
