+}
+
+function buildSummary(r, iterations) {
+  const lines = [];
+  lines.push(`Dataset ${DATASET_ID}: ${r.n} NSCLC records; mean pfs_months ${round(r.pfsMean, 2)} (SD ${round(r.pfsSd, 2)}).`);
+  lines.push("");
+  lines.push("I ran 25 propose-test-refine iterations using linear models for pfs_months. Baseline-adjusted models controlled for age_years, sex_female, stage_iv, ecog_ps, has_brain_mets, albumin_g_dl, ldh_u_l, weight_loss_pct_6mo, crp_mg_l, nlr, smoking_status, and histology unless otherwise noted. P-values use large-sample normal approximations to the OLS coefficient tests.");
+  lines.push("");
+  lines.push("General disease-status effects were partly concentrated in a few variables. Higher albumin_g_dl was strongly favorable, while higher weight_loss_pct_6mo and ldh_u_l were adverse. Stage IV disease and brain metastases had large negative adjusted associations. In contrast, crp_mg_l, nlr, liver_mets, bone_mets, pleural_effusion, adrenal_mets, and most other metastatic-site flags were weak or not significant after adjustment.");
+  lines.push("");
+  lines.push("The clearest treatment-biomarker pattern was treatment_sotorasib by kras_g12c. The interaction was large and strongly positive in both focused and joint models. The other matched-treatment hypotheses were refuted: treatment_osimertinib by egfr_mutation, treatment_olaparib by brca2_mutation, and treatment_pembrolizumab by tmb_high were near zero and not significant.");
+  lines.push("");
+  lines.push("Immunotherapy-specific hypotheses were mostly unsupported. Pembrolizumab interactions with tmb_high, pdl1_tps, stk11_mutation, egfr_mutation, liver_mets, histology_squamous, and current smoking were all small and not significant. The main exception was a small negative treatment_pembrolizumab by kras_g12c interaction, about -0.053 months, which was statistically significant but much smaller than the sotorasib by KRAS G12C effect.");
+  lines.push("");
+  lines.push("Exploratory scans reinforced that most interaction signals were small. The top pembrolizumab scan terms were under 0.10 months in absolute value. The osimertinib scan did not identify egfr_mutation as a dominant interaction; the largest scanned osimertinib interactions were also small, with only pleural_effusion reaching nominal significance.");
+  lines.push("");
+  lines.push("Overall conclusion: the dominant supported signals are a large positive sotorasib benefit in kras_g12c patients and strong baseline prognostic effects from albumin, weight loss, LDH, stage IV disease, and brain metastases. Many plausible NSCLC treatment-biomarker hypotheses were directly tested and refuted in this dataset.");
+  lines.push("");
+  lines.push("Selected effect estimates:");
+  for (const item of [
+    ["sotorasib x kras_g12c", r.fitFullInteraction.soto_x_kras],
+    ["osimertinib x egfr_mutation", r.fitFullInteraction.osim_x_egfr],
+    ["olaparib x brca2_mutation", r.fitFullInteraction.olap_x_brca2],
+    ["pembrolizumab x tmb_high", r.fitFullInteraction.pembro_x_tmb_high],
+    ["pembrolizumab x stk11_mutation", r.fitFullInteraction.pembro_x_stk11],
+  ]) {
+    lines.push(`- ${item[0]}: ${round(item[1].beta, 3)} months, p=${formatP(item[1].p)}`);
+  }
+  return lines.join("\n") + "\n";
+}
+
+function printDiagnostics(r) {
+  console.log(`Loaded ${r.n} rows; PFS mean ${round(r.pfsMean, 3)}, SD ${round(r.pfsSd, 3)}`);
+  console.log("Top adjusted binary main effects:");
+  for (const x of r.mainRanked.slice(0, 12)) console.log(x.v, round(x.adj.beta, 3), formatP(x.adj.p));
+  console.log("Top adjusted continuous main effects:");
+  for (const x of r.contRanked.slice(0, 12)) console.log(x.v, `per ${x.scale}`, round(x.adj.beta, 3), formatP(x.adj.p));
+  console.log("Treatment-biomarker interactions:");
+  for (const x of r.interactions) console.log(`${x.t} x ${x.b}`, round(x.res.interaction.beta, 3), formatP(x.res.interaction.p));
+  console.log("PDL1-pembro interaction", round(r.pdl1Pemb.interaction.beta, 3), formatP(r.pdl1Pemb.interaction.p));
+  for (const [t, scan] of Object.entries(r.treatmentInteractionScans)) {
+    console.log(`Top ${t} interaction scan:`);
+    for (const x of scan.slice(0, 8)) console.log(" ", x.b, round(x.res.interaction.beta, 3), formatP(x.res.interaction.p));
+  }
+  console.log("Treatment main effects:");
+  for (const x of r.treatmentMain) console.log(" ", x.v, "prev", round(x.prev, 3), "adj", round(x.adj.beta, 3), formatP(x.adj.p));
+  console.log("Joint interaction model key terms:");
+  for (const k of ["osim_x_egfr", "soto_x_kras", "olap_x_brca2", "pembro_x_tmb_high", "pembro_x_stk11"]) {
+    console.log(" ", k, round(r.fitFullInteraction[k].beta, 3), formatP(r.fitFullInteraction[k].p));
+  }
+  console.log("Wrote transcript.json and analysis_summary.txt");
+}
+
+analyze();

