+      } else {
+        throw new Error(`Unsupported page type ${header.type} for ${name}`);
+      }
+      pos = bodyOffset + header.compressed_page_size;
+    }
+    if (values.length !== md.num_values) throw new Error(`${name}: decoded ${values.length}, expected ${md.num_values}`);
