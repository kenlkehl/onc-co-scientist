+    pembroSmoke,
+    treatmentMain,
+    egfrOsimMeans,
+    krasSotoMeans,
+    brcaOlapMeans,
+    tmbPembroMeans,
+    stkPembroMeans,
+    covariateOnly: covariateOnly.result,
+    pembroTmbStk,
+    fitFullInteraction: fitFullInteraction.result,
+  };
