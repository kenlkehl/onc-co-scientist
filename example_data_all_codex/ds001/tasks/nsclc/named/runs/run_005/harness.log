+function plainDecodeValues(buf, physicalType, count) {
+  const values = [];
+  let pos = 0;
+  for (let i = 0; i < count; i++) {
+    if (physicalType === 5) {
+      values.push(buf.readDoubleLE(pos));
+      pos += 8;
+    } else if (physicalType === 2) {
+      values.push(Number(buf.readBigInt64LE(pos)));
+      pos += 8;
+    } else if (physicalType === 1) {
+      values.push(buf.readInt32LE(pos));
+      pos += 4;
+    } else if (physicalType === 6) {
+      const len = buf.readInt32LE(pos);
+      pos += 4;
+      values.push(buf.subarray(pos, pos + len).toString("utf8"));
