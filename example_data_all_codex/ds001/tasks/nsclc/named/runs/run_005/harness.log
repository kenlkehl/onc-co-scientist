+
+function decodeDataPageV1(body, pageHeader, dict) {
+  const n = pageHeader.data_page_header.num_values;
+  let pos = 0;
+  const defLen = body.readInt32LE(pos);
+  pos += 4;
+  const def = decodeHybrid(body, pos, defLen, 1, n);
+  pos += defLen;
+  const definedCount = def.values.reduce((acc, x) => acc + (x > 0 ? 1 : 0), 0);
+  const indexBitWidth = body[pos++];
+  const indices = decodeHybrid(body, pos, body.length - pos, indexBitWidth, definedCount).values;
+  const out = [];
+  let k = 0;
+  for (let i = 0; i < n; i++) {
+    if (def.values[i] > 0) out.push(dict[indices[k++]]);
+    else out.push(null);
+  }
+  return out;
+}
+
+function loadParquet(path) {
+  const file = fs.readFileSync(path);
+  if (file.subarray(0, 4).toString("ascii") !== "PAR1" || file.subarray(file.length - 4).toString("ascii") !== "PAR1") {
+    throw new Error("Not a Parquet file");
+  }
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const footerStart = file.length - 8 - footerLen;
+  const meta = readFileMetaData(file.subarray(footerStart, file.length - 8));
+  if (meta.row_groups.length !== 1) throw new Error("Expected one row group");
+  const schemaByName = new Map();
+  for (const s of meta.schema.slice(1)) schemaByName.set(s.name, s);
+  const rg = meta.row_groups[0];
+  const columns = {};
+  for (const chunk of rg.columns) {
+    const md = chunk.meta_data;
+    const name = md.path_in_schema[0];
+    const start = md.dictionary_page_offset ?? md.data_page_offset;
+    const end = start + md.total_compressed_size;
+    let pos = start;
+    let dict = null;
+    const values = [];
+    while (pos < end && values.length < md.num_values) {
+      const { header, bodyOffset } = readPageHeader(file, pos);
+      const payload = file.subarray(bodyOffset, bodyOffset + header.compressed_page_size);
+      const body = decompress(md.codec, payload, header.uncompressed_page_size);
+      if (header.type === 2) {
+        dict = plainDecodeValues(body, md.type, header.dictionary_page_header.num_values);
+      } else if (header.type === 0) {
+        if (!dict) throw new Error(`Missing dictionary for ${name}`);
