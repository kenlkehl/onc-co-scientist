+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  return Math.max(0, Math.min(1, p));
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const aug = a.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    let best = Math.abs(aug[col][col]);
+    for (let r = col + 1; r < n; r++) {
+      const val = Math.abs(aug[r][col]);
+      if (val > best) {
+        best = val;
+        pivot = r;
+      }
+    }
+    if (best < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== col) [aug[pivot], aug[col]] = [aug[col], aug[pivot]];
+    const div = aug[col][col];
+    for (let c = 0; c < 2 * n; c++) aug[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = aug[r][col];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) aug[r][c] -= factor * aug[col][c];
+    }
+  }
+  return aug.map((row) => row.slice(n));
+}
+
+function ols(y, terms) {
+  const n = y.length;
+  const p = terms.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    for (let a = 0; a < p; a++) {
+      const xa = terms[a].values[i];
+      xty[a] += xa * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += xa * terms[b].values[i];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) xtx[b][a] = xtx[a][b];
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let fit = 0;
+    for (let j = 0; j < p; j++) fit += beta[j] * terms[j].values[i];
+    const e = y[i] - fit;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(row[i] * sigma2, 0)));
+  const result = {};
+  for (let i = 0; i < p; i++) {
+    const z = beta[i] / se[i];
+    result[terms[i].name] = { beta: beta[i], se: se[i], z, p: pFromZ(z) };
+  }
+  return { n, p, rss, sigma2, result };
+}
+
+function rank(arr) {
+  const idx = arr.map((v, i) => [v, i]).sort((a, b) => a[0] - b[0]);
+  const out = Array(arr.length);
+  let i = 0;
+  while (i < idx.length) {
+    let j = i + 1;
+    while (j < idx.length && idx[j][0] === idx[i][0]) j++;
+    const r = (i + j + 1) / 2;
+    for (let k = i; k < j; k++) out[idx[k][1]] = r;
+    i = j;
+  }
+  return out;
+}
+
+function spearman(x, y) {
+  const rx = rank(x);
+  const ry = rank(y);
+  const mx = mean(rx);
+  const my = mean(ry);
+  let num = 0;
+  let vx = 0;
+  let vy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = rx[i] - mx;
+    const dy = ry[i] - my;
+    num += dx * dy;
+    vx += dx * dx;
+    vy += dy * dy;
+  }
+  const rho = num / Math.sqrt(vx * vy);
+  const z = rho * Math.sqrt(x.length - 1);
+  return { rho, p: pFromZ(z) };
+}
+
+function formatP(p) {
+  if (p === 0) return "<1e-300";
+  if (p < 0.0001) return p.toExponential(2);
+  return p.toFixed(4);
+}
+
+function round(x, digits = 3) {
+  const m = 10 ** digits;
+  return Math.round(x * m) / m;
+}
+
+function term(name, values) {
+  return { name, values };
+}
+
+function zeros(n, value = 0) {
+  return Array(n).fill(value);
+}
+
+function product(a, b) {
+  const out = Array(a.length);
+  for (let i = 0; i < a.length; i++) out[i] = a[i] * b[i];
+  return out;
+}
+
+function centered(arr, scale = 1) {
+  const m = mean(arr);
+  return arr.map((v) => (v - m) / scale);
+}
+
+function indicatorEquals(arr, value) {
+  return arr.map((v) => (v === value ? 1 : 0));
+}
+
+function makeBaseTerms(c, includeSmokingHistology = true) {
+  const n = c[OUTCOME].length;
+  const terms = [term("Intercept", zeros(n, 1))];
+  terms.push(term("age_years_per10_centered", centered(c.age_years, 10)));
+  terms.push(term("sex_female", c.sex_female));
+  terms.push(term("stage_iv", c.stage_iv));
+  terms.push(term("ecog_ps", c.ecog_ps));
+  terms.push(term("has_brain_mets", c.has_brain_mets));
+  terms.push(term("albumin_g_dl_centered", centered(c.albumin_g_dl, 1)));
+  terms.push(term("ldh_u_l_per100_centered", centered(c.ldh_u_l, 100)));
+  terms.push(term("weight_loss_pct_6mo_per5_centered", centered(c.weight_loss_pct_6mo, 5)));
+  terms.push(term("crp_mg_l_per10_centered", centered(c.crp_mg_l, 10)));
+  terms.push(term("nlr_centered", centered(c.nlr, 1)));
+  if (includeSmokingHistology) {
+    terms.push(term("smoking_status_former", indicatorEquals(c.smoking_status, "former")));
+    terms.push(term("smoking_status_current", indicatorEquals(c.smoking_status, "current")));
+    terms.push(term("histology_squamous", indicatorEquals(c.histology, "squamous")));
+  }
+  return terms;
+}
+
+function baseTermName(variable) {
+  return {
+    age_years: "age_years_per10_centered",
+    sex_female: "sex_female",
+    stage_iv: "stage_iv",
+    ecog_ps: "ecog_ps",
+    has_brain_mets: "has_brain_mets",
+    albumin_g_dl: "albumin_g_dl_centered",
+    ldh_u_l: "ldh_u_l_per100_centered",
+    weight_loss_pct_6mo: "weight_loss_pct_6mo_per5_centered",
+    crp_mg_l: "crp_mg_l_per10_centered",
+    nlr: "nlr_centered",
+  }[variable] || null;
+}
+
+function adjustedMainEffect(c, variable, scale = 1) {
+  const baseName = baseTermName(variable);
+  if (baseName) {
+    return ols(c[OUTCOME], makeBaseTerms(c)).result[baseName];
+  }
+  const x = scale === 1 ? c[variable] : c[variable].map((v) => v / scale);
+  const res = ols(c[OUTCOME], makeBaseTerms(c).concat([term(variable, x)]));
+  return res.result[variable];
+}
+
+function treatmentBiomarkerInteraction(c, treatment, biomarker, label = null) {
+  const interName = `${treatment}_x_${biomarker}`;
+  const terms = makeBaseTerms(c).concat([term(treatment, c[treatment])]);
+  const baseName = baseTermName(biomarker);
+  if (!baseName) terms.push(term(biomarker, c[biomarker]));
+  terms.push(term(interName, product(c[treatment], c[biomarker])));
+  const res = ols(c[OUTCOME], terms);
+  return { interaction: res.result[interName], treatment: res.result[treatment], biomarker: res.result[baseName || biomarker], label: label || interName };
+}
+
+function interactionContinuous(c, treatment, variable, scale, name) {
+  const x = centered(c[variable], scale);
+  const interName = `${treatment}_x_${variable}_per${scale}`;
+  const terms = makeBaseTerms(c)
+    .concat([term(treatment, c[treatment]), term(`${variable}_scaled_centered`, x), term(interName, product(c[treatment], x))]);
+  const res = ols(c[OUTCOME], terms);
+  return { interaction: res.result[interName], treatment: res.result[treatment], variable: res.result[`${variable}_scaled_centered`], label: name || interName };
+}
+
+function subgroupMeans(c, treatment, subgroup) {
+  const y = c[OUTCOME];
+  const rows = {
+    s1t1: [],
+    s1t0: [],
+    s0t1: [],
+    s0t0: [],
+  };
+  for (let i = 0; i < y.length; i++) {
+    const s = c[subgroup][i] === 1 ? "s1" : "s0";
+    const t = c[treatment][i] === 1 ? "t1" : "t0";
+    rows[`${s}${t}`].push(i);
+  }
+  return Object.fromEntries(Object.entries(rows).map(([k, idx]) => [k, { n: idx.length, mean: mean(y, idx) }]));
+}
+
+function diffMeans(c, binaryVar) {
+  const y = c[OUTCOME];
+  const a = [];
+  const b = [];
+  for (let i = 0; i < y.length; i++) (c[binaryVar][i] === 1 ? a : b).push(i);
+  const ma = mean(y, a);
+  const mb = mean(y, b);
+  const va = variance(y, a);
+  const vb = variance(y, b);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const z = (ma - mb) / se;
+  return { effect: ma - mb, p: pFromZ(z), n1: a.length, n0: b.length, m1: ma, m0: mb };
+}
+
+function prevalence(c, variable) {
+  return mean(c[variable]);
+}
+
+function analyze() {
+  const { columns: c, n } = loadParquet(DATASET_PATH);
+  const y = c[OUTCOME];
+  const pfsMean = mean(y);
+  const pfsSd = Math.sqrt(variance(y));
+
+  const binaryMain = [
+    "stage_iv", "has_brain_mets", "egfr_mutation", "kras_g12c", "alk_fusion", "stk11_mutation", "brca2_mutation",
+    "tmb_high", "liver_mets", "bone_mets", "adrenal_mets", "pleural_effusion", "pericardial_effusion",
+    "contralateral_lung_mets", "her2_amplification", "met_exon14_skipping", "ret_fusion", "ros1_fusion",
+    "diabetes_mellitus", "hypertension", "copd", "chronic_kidney_disease", "heart_failure", "coronary_artery_disease",
+    "atrial_fibrillation", "autoimmune_disease", "prior_malignancy", "interstitial_lung_disease_history"
+  ];
+  const mainRanked = binaryMain.map((v) => ({ v, unadj: diffMeans(c, v), adj: adjustedMainEffect(c, v) }))
+    .sort((a, b) => Math.abs(b.adj.beta) - Math.abs(a.adj.beta));
+
+  const continuousMain = [
+    ["albumin_g_dl", 1], ["ldh_u_l", 100], ["weight_loss_pct_6mo", 5], ["crp_mg_l", 10], ["nlr", 1],
+    ["hemoglobin_g_dl", 1], ["alkaline_phosphatase_u_l", 100], ["ast_u_l", 10], ["alt_u_l", 10],
+    ["total_bilirubin_mg_dl", 1], ["creatinine_mg_dl", 1], ["sodium_meq_l", 5], ["bmi", 5], ["spo2_pct", 1],
+    ["cea_ng_ml", 10], ["ca_125_u_ml", 50]
+  ];
+  const contRanked = continuousMain.map(([v, scale]) => ({ v, scale, adj: adjustedMainEffect(c, v, scale), rho: spearman(c[v], y) }))
+    .sort((a, b) => Math.abs(b.adj.beta) - Math.abs(a.adj.beta));
+
+  const biomarkerTxPairs = [
+    ["treatment_osimertinib", "egfr_mutation"],
+    ["treatment_sotorasib", "kras_g12c"],
+    ["treatment_olaparib", "brca2_mutation"],
+    ["treatment_pembrolizumab", "tmb_high"],
+    ["treatment_pembrolizumab", "stk11_mutation"],
+    ["treatment_pembrolizumab", "egfr_mutation"],
+    ["treatment_pembrolizumab", "kras_g12c"],
+    ["treatment_pembrolizumab", "liver_mets"],
+    ["treatment_osimertinib", "has_brain_mets"],
+    ["treatment_sotorasib", "stk11_mutation"],
+    ["treatment_olaparib", "liver_mets"]
+  ];
+  const interactions = biomarkerTxPairs.map(([t, b]) => ({ t, b, res: treatmentBiomarkerInteraction(c, t, b), means: subgroupMeans(c, t, b) }));
+  const pdl1Pemb = interactionContinuous(c, "treatment_pembrolizumab", "pdl1_tps", 50, "pembrolizumab by PD-L1 TPS per 50 points");
+
+  const allBinaryForPembro = binaryMain.concat(["sex_female"]);
+  const pembroInteractionScan = allBinaryForPembro.map((b) => ({ b, res: treatmentBiomarkerInteraction(c, "treatment_pembrolizumab", b) }))
+    .sort((a, b) => Math.abs(b.res.interaction.beta) - Math.abs(a.res.interaction.beta));
+
+  const allBinaryForOsim = binaryMain.concat(["sex_female"]);
+  const osimInteractionScan = allBinaryForOsim.map((b) => ({ b, res: treatmentBiomarkerInteraction(c, "treatment_osimertinib", b) }))
+    .sort((a, b) => Math.abs(b.res.interaction.beta) - Math.abs(a.res.interaction.beta));
+
+  const scanVars = Array.from(new Set(binaryMain.concat(["sex_female"])));
+  const treatmentInteractionScans = {};
+  for (const t of ["treatment_pembrolizumab", "treatment_sotorasib", "treatment_olaparib", "treatment_osimertinib"]) {
+    treatmentInteractionScans[t] = scanVars.map((b) => ({ b, res: treatmentBiomarkerInteraction(c, t, b) }))
+      .sort((a, b) => Math.abs(b.res.interaction.beta) - Math.abs(a.res.interaction.beta));
+  }
+
+  const histSquamous = indicatorEquals(c.histology, "squamous");
+  const pembroHistName = "treatment_pembrolizumab_x_histology_squamous";
+  const pembroHist = ols(y, makeBaseTerms(c, false).concat([
+    term("treatment_pembrolizumab", c.treatment_pembrolizumab),
+    term("histology_squamous", histSquamous),
+    term(pembroHistName, product(c.treatment_pembrolizumab, histSquamous)),
+  ])).result[pembroHistName];
+
+  const smokeCurrent = indicatorEquals(c.smoking_status, "current");
+  const pembroSmokeName = "treatment_pembrolizumab_x_smoking_current";
+  const pembroSmoke = ols(y, makeBaseTerms(c, false).concat([
+    term("smoking_status_former", indicatorEquals(c.smoking_status, "former")),
+    term("smoking_status_current", smokeCurrent),
+    term("histology_squamous", histSquamous),
+    term("treatment_pembrolizumab", c.treatment_pembrolizumab),
+    term(pembroSmokeName, product(c.treatment_pembrolizumab, smokeCurrent)),
+  ])).result[pembroSmokeName];
+
+  const treatmentMain = ["treatment_pembrolizumab", "treatment_sotorasib", "treatment_olaparib", "treatment_osimertinib"]
+    .map((v) => ({ v, adj: adjustedMainEffect(c, v), unadj: diffMeans(c, v), prev: prevalence(c, v) }));
+
+  const egfrOsimMeans = subgroupMeans(c, "treatment_osimertinib", "egfr_mutation");
+  const krasSotoMeans = subgroupMeans(c, "treatment_sotorasib", "kras_g12c");
+  const brcaOlapMeans = subgroupMeans(c, "treatment_olaparib", "brca2_mutation");
+  const tmbPembroMeans = subgroupMeans(c, "treatment_pembrolizumab", "tmb_high");
+  const stkPembroMeans = subgroupMeans(c, "treatment_pembrolizumab", "stk11_mutation");
+
+  const covariateOnly = ols(y, makeBaseTerms(c).concat([
+    term("egfr_mutation", c.egfr_mutation),
+    term("kras_g12c", c.kras_g12c),
+    term("stk11_mutation", c.stk11_mutation),
+    term("tmb_high", c.tmb_high),
+    term("brca2_mutation", c.brca2_mutation),
+    term("treatment_pembrolizumab", c.treatment_pembrolizumab),
+    term("treatment_sotorasib", c.treatment_sotorasib),
+    term("treatment_olaparib", c.treatment_olaparib),
+    term("treatment_osimertinib", c.treatment_osimertinib),
+  ]));
+
+  const tripleName = "treatment_pembrolizumab_x_tmb_high_x_stk11_mutation";
+  const pembroTmbStk = ols(y, makeBaseTerms(c).concat([
+    term("treatment_pembrolizumab", c.treatment_pembrolizumab),
+    term("tmb_high", c.tmb_high),
+    term("stk11_mutation", c.stk11_mutation),
+    term("treatment_pembrolizumab_x_tmb_high", product(c.treatment_pembrolizumab, c.tmb_high)),
+    term("treatment_pembrolizumab_x_stk11_mutation", product(c.treatment_pembrolizumab, c.stk11_mutation)),
+    term("tmb_high_x_stk11_mutation", product(c.tmb_high, c.stk11_mutation)),
+    term(tripleName, product(product(c.treatment_pembrolizumab, c.tmb_high), c.stk11_mutation)),
+  ])).result[tripleName];
+
+  const fitFullInteraction = ols(y, makeBaseTerms(c).concat([
+    term("treatment_pembrolizumab", c.treatment_pembrolizumab),
+    term("tmb_high", c.tmb_high),
+    term("stk11_mutation", c.stk11_mutation),
+    term("egfr_mutation", c.egfr_mutation),
+    term("kras_g12c", c.kras_g12c),
+    term("brca2_mutation", c.brca2_mutation),
+    term("treatment_sotorasib", c.treatment_sotorasib),
+    term("treatment_olaparib", c.treatment_olaparib),
+    term("treatment_osimertinib", c.treatment_osimertinib),
+    term("pembro_x_tmb_high", product(c.treatment_pembrolizumab, c.tmb_high)),
+    term("pembro_x_stk11", product(c.treatment_pembrolizumab, c.stk11_mutation)),
+    term("soto_x_kras", product(c.treatment_sotorasib, c.kras_g12c)),
+    term("olap_x_brca2", product(c.treatment_olaparib, c.brca2_mutation)),
+    term("osim_x_egfr", product(c.treatment_osimertinib, c.egfr_mutation)),
+  ]));
+
+  const results = {
+    n,
+    pfsMean,
+    pfsSd,
+    mainRanked,
+    contRanked,
+    interactions,
+    pdl1Pemb,
+    pembroInteractionScan: pembroInteractionScan.slice(0, 10),
+    osimInteractionScan: osimInteractionScan.slice(0, 10),
+    treatmentInteractionScans,
+    pembroHist,
+    pembroSmoke,
+    treatmentMain,
+    egfrOsimMeans,
+    krasSotoMeans,
+    brcaOlapMeans,
+    tmbPembroMeans,
+    stkPembroMeans,
+    covariateOnly: covariateOnly.result,
+    pembroTmbStk,
+    fitFullInteraction: fitFullInteraction.result,
+  };
+
+  const iterations = buildTranscript(results);
+  const transcript = {
+    dataset_id: DATASET_ID,
+    model_id: MODEL_ID,
+    harness_id: HARNESS_ID,
+    max_iterations: MAX_ITERATIONS,
+    iterations,
+  };
+
+  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2) + "\n");
+  fs.writeFileSync("analysis_summary.txt", buildSummary(results, iterations));
+
+  printDiagnostics(results);
+}
+
+function analysisRecord(hypothesisIds, result, summary, code = null) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: summary,
+    p_value: result.p,
+    effect_estimate: result.beta ?? result.effect ?? result.rho,
+    significant: result.p < 0.05,
+  };
+}
+
+function hyp(id, text, kind = "novel") {
+  return { id, text, kind };
+}
+
+function buildTranscript(r) {
+  const out = [];
+  const getInt = (t, b) => r.interactions.find((x) => x.t === t && x.b === b).res.interaction;
+  const getMain = (v) => r.mainRanked.find((x) => x.v === v).adj;
+  const getCont = (v) => r.contRanked.find((x) => x.v === v).adj;
+  const getTx = (v) => r.treatmentMain.find((x) => x.v === v).adj;
+
+  out.push({
+    index: 1,
+    proposed_hypotheses: [
+      hyp("h1", "Higher inflammatory and tumor-burden markers `ldh_u_l`, `crp_mg_l`, `nlr`, and `weight_loss_pct_6mo` are associated with shorter mean `pfs_months`, while higher `albumin_g_dl` is associated with longer mean `pfs_months` after adjustment for baseline clinical factors."),
+    ],
+    analyses: [
+      analysisRecord(["h1"], getCont("ldh_u_l"), `Adjusted OLS estimated ${round(getCont("ldh_u_l").beta, 3)} months of PFS per 100 U/L higher ldh_u_l (p=${formatP(getCont("ldh_u_l").p)}).`),
+      analysisRecord(["h1"], getCont("crp_mg_l"), `Adjusted OLS estimated ${round(getCont("crp_mg_l").beta, 3)} months of PFS per 10 mg/L higher crp_mg_l (p=${formatP(getCont("crp_mg_l").p)}).`),
+      analysisRecord(["h1"], getCont("nlr"), `Adjusted OLS estimated ${round(getCont("nlr").beta, 3)} months of PFS per one-unit higher nlr (p=${formatP(getCont("nlr").p)}).`),
+      analysisRecord(["h1"], getCont("weight_loss_pct_6mo"), `Adjusted OLS estimated ${round(getCont("weight_loss_pct_6mo").beta, 3)} months of PFS per 5 percentage-point higher weight_loss_pct_6mo (p=${formatP(getCont("weight_loss_pct_6mo").p)}).`),
+      analysisRecord(["h1"], getCont("albumin_g_dl"), `Adjusted OLS estimated ${round(getCont("albumin_g_dl").beta, 3)} months of PFS per 1 g/dL higher albumin_g_dl (p=${formatP(getCont("albumin_g_dl").p)}).`),
+    ],
+  });
+
+  out.push({
+    index: 2,
+    proposed_hypotheses: [
+      hyp("h2", "Patients with `stage_iv`, `has_brain_mets`, `liver_mets`, or `bone_mets` have shorter mean `pfs_months` than patients without those metastatic burden features after adjustment."),
+    ],
+    analyses: [
