+const fs = require("fs");
+
+const DATASET_PATH = "dataset.parquet";
+const OUTCOME = "pfs_months";
+const DATASET_ID = "ds001_nsclc";
+const MODEL_ID = "gpt-5-codex";
+const HARNESS_ID = "codex-local-node-parquet@1.0";
+const MAX_ITERATIONS = 25;
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.b = buf;
+    this.pos = pos;
+    this.lastField = [];
+  }
+  readByte() {
+    return this.b[this.pos++];
+  }
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const byte = this.readByte();
+      result |= BigInt(byte & 0x7f) << BigInt(shift);
+      if ((byte & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  readZigZag() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ -(n & 1n);
+  }
+  readI32() {
+    return Number(this.readZigZag());
+  }
+  readI64() {
+    return Number(this.readZigZag());
+  }
+  readDouble() {
+    const v = this.b.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.b.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readString() {
+    return this.readBinary().toString("utf8");
+  }
+  readListHeader() {
+    const x = this.readByte();
+    let size = x >> 4;
+    const etype = x & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, etype };
+  }
+  readFieldBegin() {
+    const x = this.readByte();
+    const type = x & 0x0f;
+    if (type === 0) return { type: 0, id: 0 };
+    const delta = x >> 4;
+    const last = this.lastField[this.lastField.length - 1] || 0;
+    const id = delta === 0 ? Number(this.readZigZag()) : last + delta;
+    return { type, id };
+  }
+  readStruct(readFields) {
+    this.lastField.push(0);
+    const out = {};
+    while (true) {
+      const f = this.readFieldBegin();
+      if (f.type === 0) break;
+      this.lastField[this.lastField.length - 1] = f.id;
+      readFields(out, f, this);
+    }
+    this.lastField.pop();
+    return out;
+  }
+  skip(type) {
+    switch (type) {
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+        this.readI32();
+        return;
+      case 6:
+        this.readI64();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case 9:
+      case 10: {
+        const h = this.readListHeader();
+        for (let i = 0; i < h.size; i++) this.skip(h.etype);
+        return;
+      }
+      case 11: {
+        const size = Number(this.readVarint());
+        if (size === 0) return;
+        const kt = this.readByte();
+        const vt = this.readByte();
+        for (let i = 0; i < size; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12:
+        this.lastField.push(0);
+        while (true) {
+          const f = this.readFieldBegin();
+          if (f.type === 0) break;
+          this.lastField[this.lastField.length - 1] = f.id;
+          this.skip(f.type);
+        }
+        this.lastField.pop();
+        return;
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+    }
+  }
+}
