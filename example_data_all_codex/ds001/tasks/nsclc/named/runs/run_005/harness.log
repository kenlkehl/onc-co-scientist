+
+function snappyUncompress(input) {
+  let pos = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const c = input[pos++];
+    len |= (c & 0x7f) << shift;
+    if ((c & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let litLen = tag >> 2;
+      if (litLen < 60) {
+        litLen += 1;
+      } else {
+        const bytes = litLen - 59;
+        litLen = 0;
+        for (let i = 0; i < bytes; i++) litLen |= input[pos++] << (8 * i);
+        litLen += 1;
+      }
+      input.copy(out, op, pos, pos + litLen);
+      pos += litLen;
+      op += litLen;
+    } else {
+      let copyLen;
+      let offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < copyLen; i++) out[op + i] = out[op - offset + i];
+      op += copyLen;
+    }
+  }
