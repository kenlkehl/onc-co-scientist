assert(typeof t.harness_id==='string' && t.harness_id.length,'harness_id');
assert(t.max_iterations===25,'max_iterations');
assert(Array.isArray(t.iterations) && t.iterations.length===25,'iterations length');
let analyses=0, missing=[];
for(const it of t.iterations){
  assert(Number.isInteger(it.index) && it.index>=1,'iteration index');
  assert(Array.isArray(it.proposed_hypotheses) && it.proposed_hypotheses.length>0,"'`hypotheses ${it.index}`);
  for(const h of it.proposed_hypotheses){
    if(!(typeof h.id==='"'string' && typeof h.text==='string' && h.text.length>0)) missing.push("'`hypothesis ${it.index}`);
  }
  for(const a of (it.analyses||[])){
    analyses++;
    if(!Array.isArray(a.hypothesis_ids) || a.hypothesis_ids.length===0 || typeof a.result_summary!=='"'string') missing.push("'`analysis ${it.index}`);
    if(a.effect_estimate == null && a.p_value == null && a.significant == null) missing.push(`analysis stats ${it.index}`);
  }
}
assert(missing.length===0, missing.join('"'; '));
const s=fs.readFileSync('./analysis_summary.txt','utf8');
assert(s.length>1000,'summary length');
console.log("'`validated transcript.json: ${t.iterations.length} iterations, ${analyses} analyses`);
console.log(`validated analysis_summary.txt: ${s.length} chars`);
