+const a = require('./analyze_dataset.js');
+const { data } = a.readParquet();
+const y = data.pfs_months;
+const n = y.length;
+const arr = name => data[name];
+const z = name => a.zscore(data[name]);
+const c = name => a.center(data[name]);
+const bin = name => data[name].map(Number);
+const dummy = (name, value) => data[name].map(v => v === value ? 1 : 0);
+const scale = (values, s) => values.map(v => v * s);
+const add = (cols, name, values) => cols.concat([{ name, values }]);
+const core = [
+  { name: 'age_years', values: c('age_years') },
+  { name: 'sex_female', values: bin('sex_female') },
+  { name: 'stage_iv', values: bin('stage_iv') },
+  { name: 'has_brain_mets', values: bin('has_brain_mets') },
+  { name: 'ecog_ps', values: c('ecog_ps') },
+  { name: 'histology_squamous', values: dummy('histology', 'squamous') },
+  { name: 'smoking_current', values: dummy('smoking_status', 'current') },
+  { name: 'smoking_never', values: dummy('smoking_status', 'never') },
+];
+const severity = core.concat([
+  { name: 'albumin_g_dl', values: c('albumin_g_dl') },
+  { name: 'weight_loss_pct_6mo', values: c('weight_loss_pct_6mo') },
+  { name: 'ldh_per100', values: scale(c('ldh_u_l'), 0.01) },
+  { name: 'crp_mg_l', values: c('crp_mg_l') },
+  { name: 'nlr', values: c('nlr') },
+  { name: 'liver_mets', values: bin('liver_mets') },
+  { name: 'bone_mets', values: bin('bone_mets') },
+  { name: 'pleural_effusion', values: bin('pleural_effusion') },
+]);
+function term(model, name) {
+  return model.terms.find(t => t.name === name);
+}
+function print(name, model, terms) {
+  console.log('\n' + name);
+  for (const t of terms) {
+    const x = term(model, t);
+    console.log(`${t}\tbeta=${a.fmt(x.beta, 6)}\tse=${a.fmt(x.se, 6)}\tp=${a.ptxt(x.p)}`);
+  }
+}
+function olsPrint(name, cols, terms) {
+  const m = a.ols(y, cols);
+  print(name, m, terms);
+  return m;
+}
+// Adjusted prognostic main effects.
+olsPrint('core prognosis', severity, ['stage_iv','has_brain_mets','ecog_ps','albumin_g_dl','weight_loss_pct_6mo','ldh_per100','crp_mg_l','nlr','liver_mets','bone_mets','pleural_effusion','age_years','sex_female','histology_squamous','smoking_current','smoking_never']);
+
+const pembro = bin('treatment_pembrolizumab');
+const soto = bin('treatment_sotorasib');
+const olap = bin('treatment_olaparib');
+const osim = bin('treatment_osimertinib');
+const egfr = bin('egfr_mutation');
+const kras = bin('kras_g12c');
+const brca2 = bin('brca2_mutation');
+const stk11 = bin('stk11_mutation');
+const tmb = bin('tmb_high');
+const alk = bin('alk_fusion');
+const pdl1_10 = data.pdl1_tps.map(v => (v - a.mean(data.pdl1_tps)) / 0.1);
+
+olsPrint('pembro pdl1 interaction', severity.concat([
+  { name: 'pembrolizumab', values: pembro },
+  { name: 'pdl1_per10_centered', values: pdl1_10 },
+  { name: 'pembro_x_pdl1_per10', values: a.interactionArray(pembro, pdl1_10) },
+]), ['pembrolizumab','pdl1_per10_centered','pembro_x_pdl1_per10']);
+
+olsPrint('pembro tmb interaction', severity.concat([
+  { name: 'pembrolizumab', values: pembro },
+  { name: 'tmb_high', values: tmb },
+  { name: 'pembro_x_tmb_high', values: a.interactionArray(pembro, tmb) },
+]), ['pembrolizumab','tmb_high','pembro_x_tmb_high']);
+
+olsPrint('pembro driver resistance', severity.concat([
+  { name: 'pembrolizumab', values: pembro },
+  { name: 'egfr_mutation', values: egfr },
+  { name: 'alk_fusion', values: alk },
+  { name: 'pembro_x_egfr', values: a.interactionArray(pembro, egfr) },
+  { name: 'pembro_x_alk', values: a.interactionArray(pembro, alk) },
+]), ['pembrolizumab','egfr_mutation','alk_fusion','pembro_x_egfr','pembro_x_alk']);
+
+olsPrint('osimertinib egfr interaction', severity.concat([
+  { name: 'osimertinib', values: osim },
+  { name: 'egfr_mutation', values: egfr },
+  { name: 'osimertinib_x_egfr', values: a.interactionArray(osim, egfr) },
+]), ['osimertinib','egfr_mutation','osimertinib_x_egfr']);
+
+olsPrint('sotorasib kras interaction', severity.concat([
+  { name: 'sotorasib', values: soto },
+  { name: 'kras_g12c', values: kras },
+  { name: 'sotorasib_x_kras', values: a.interactionArray(soto, kras) },
+]), ['sotorasib','kras_g12c','sotorasib_x_kras']);
+
+olsPrint('sotorasib stk11 attenuation in kras', severity.concat([
+  { name: 'sotorasib', values: soto },
+  { name: 'kras_g12c', values: kras },
+  { name: 'stk11_mutation', values: stk11 },
+  { name: 'sotorasib_x_kras', values: a.interactionArray(soto, kras) },
+  { name: 'sotorasib_x_stk11', values: a.interactionArray(soto, stk11) },
+  { name: 'kras_x_stk11', values: a.interactionArray(kras, stk11) },
+  { name: 'sotorasib_x_kras_x_stk11', values: a.interactionArray(a.interactionArray(soto, kras), stk11) },
+]), ['sotorasib_x_kras','sotorasib_x_stk11','kras_x_stk11','sotorasib_x_kras_x_stk11']);
+
+olsPrint('olaparib brca2 interaction', severity.concat([
+  { name: 'olaparib', values: olap },
+  { name: 'brca2_mutation', values: brca2 },
+  { name: 'olaparib_x_brca2', values: a.interactionArray(olap, brca2) },
+]), ['olaparib','brca2_mutation','olaparib_x_brca2']);
+
+olsPrint('actionable fusions main effects', severity.concat([
+  { name: 'alk_fusion', values: alk },
+  { name: 'met_exon14_skipping', values: bin('met_exon14_skipping') },
+  { name: 'ret_fusion', values: bin('ret_fusion') },
+  { name: 'ros1_fusion', values: bin('ros1_fusion') },
+  { name: 'her2_amplification', values: bin('her2_amplification') },
+]), ['alk_fusion','met_exon14_skipping','ret_fusion','ros1_fusion','her2_amplification']);
+
+olsPrint('pembro autoimmune interaction', severity.concat([
+  { name: 'pembrolizumab', values: pembro },
+  { name: 'autoimmune_disease', values: bin('autoimmune_disease') },
+  { name: 'pembro_x_autoimmune', values: a.interactionArray(pembro, bin('autoimmune_disease')) },
+]), ['pembrolizumab','autoimmune_disease','pembro_x_autoimmune']);
+
+olsPrint('histology treatment interactions', severity.concat([
+  { name: 'pembrolizumab', values: pembro },
+  { name: 'sotorasib', values: soto },
+  { name: 'squamous', values: dummy('histology', 'squamous') },
+  { name: 'pembro_x_squamous', values: a.interactionArray(pembro, dummy('histology', 'squamous')) },
+  { name: 'sotorasib_x_squamous', values: a.interactionArray(soto, dummy('histology', 'squamous')) },
+]), ['pembrolizumab','sotorasib','squamous','pembro_x_squamous','sotorasib_x_squamous']);
+
+// Subgroup mean differences for interpretation.
+function subsetDiff(label, treat, pred) {
+  const yy = [], xx = [];
+  for (let i = 0; i < n; i++) if (pred(i)) { yy.push(y[i]); xx.push(treat[i]); }
+  const r = a.groupDiff(yy, xx, 1);
+  console.log(`${label}\tdiff=${a.fmt(r.effect, 6)}\tp=${a.ptxt(r.p)}\tm1=${a.fmt(r.m1)}\tm0=${a.fmt(r.m0)}\tn1=${r.n1}\tn0=${r.n0}`);
+}
+console.log('\nsubgroups');
+subsetDiff('osimertinib within EGFR+', osim, i => egfr[i] === 1);
