+
+function decodeDataPageV1(payload, header, schemaElem, parquetType, dictionary) {
+  let p = 0;
+  const n = header.num_values;
+  let present = n;
+  if (schemaElem.repetition_type === 1) {
+    const defLen = payload.readUInt32LE(p);
+    p += 4;
+    const defs = rleHybridDecode(payload, 1, n, p, p + defLen).values;
+    present = defs.reduce((a, v) => a + (v === 1 ? 1 : 0), 0);
+    p += defLen;
+  }
+  if (header.encoding === 8 || header.encoding === 2) {
+    const bw = payload[p++];
+    const indices = rleHybridDecode(payload, bw, present, p).values;
+    return indices.map(idx => dictionary[idx]);
+  }
