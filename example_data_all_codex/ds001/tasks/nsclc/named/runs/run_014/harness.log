+        bits -= bitW;
+      }
+      if (out.length >= expected) {
+        const consumedBits = (total * bitW + 7) >> 3;
+        const remainingValues = total - (out.length % 8 === 0 ? 8 : out.length % 8);
+        void remainingValues;
+        state.p = start + (state.p - start);
