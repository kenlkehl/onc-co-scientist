+
+function snappyUncompress(input) {
+  let ip = 0;
+  let shift = 0;
+  let expected = 0;
+  while (true) {
+    const b = input[ip++];
+    expected |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
