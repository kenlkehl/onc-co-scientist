+  for (let i = 0; i < a.length; i++) out[i] = a[i] * b[i];
+  return out;
+}
+
+function uniqueCounts(arr) {
+  const m = new Map();
+  for (const v of arr) m.set(v, (m.get(v) || 0) + 1);
+  return [...m.entries()].sort((a, b) => b[1] - a[1]);
+}
+
+function basicExploration(data) {
+  const y = data.pfs_months;
+  const cols = Object.keys(data).filter(c => c !== 'patient_id' && c !== 'pfs_months');
+  const binary = [];
+  const cont = [];
+  const cat = [];
+  for (const c of cols) {
+    const u = uniqueCounts(data[c]);
+    if (u.length <= 2 && typeof u[0][0] === 'number') binary.push(c);
+    else if (typeof u[0][0] === 'number') cont.push(c);
+    else cat.push(c);
+  }
+  const binStats = binary.map(c => ({ col: c, ...groupDiff(y, data[c], 1) })).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  const contStats = cont.map(c => ({ col: c, ...simpleSlope(y, data[c]) })).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  const catStats = [];
+  for (const c of cat) {
+    for (const [level] of uniqueCounts(data[c])) {
+      const x = data[c].map(v => v === level ? 1 : 0);
+      catStats.push({ col: c, level, ...groupDiff(y, x, 1) });
+    }
+  }
+  catStats.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  return { binary, cont, cat, binStats, contStats, catStats };
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 1000 || (Math.abs(x) < 0.001 && x !== 0)) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function ptxt(p) {
+  return p < 1e-250 ? '<1e-250' : fmt(p, 3);
+}
+
+function main() {
+  const { meta, data } = readParquet();
+  const y = data.pfs_months;
+  const exp = basicExploration(data);
+  console.log(`rows ${meta.num_rows}, columns ${Object.keys(data).length}`);
+  console.log('categorical uniques', JSON.stringify(Object.fromEntries(exp.cat.map(c => [c, uniqueCounts(data[c])]))));
+  console.log('top binary', exp.binStats.slice(0, 20).map(r => `${r.col}: diff=${fmt(r.effect)} p=${ptxt(r.p)} n1=${r.n1}`).join('\n'));
+  console.log('top continuous', exp.contStats.slice(0, 20).map(r => `${r.col}: slope=${fmt(r.effect)} p=${ptxt(r.p)}`).join('\n'));
+  console.log('top categorical', exp.catStats.slice(0, 10).map(r => `${r.col}=${r.level}: diff=${fmt(r.effect)} p=${ptxt(r.p)}`).join('\n'));
+}
+
+if (require.main === module) {
+  main();
+}
+
+module.exports = {
+  readParquet, mean, variance, groupDiff, simpleSlope, ols, zscore, center,
+  interactionArray, uniqueCounts, basicExploration, pFromZ, fmt, ptxt,
+};
