+function groupDiff(y, x, positiveValue = 1) {
+  let s1 = 0, s0 = 0, ss1 = 0, ss0 = 0, n1 = 0, n0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === positiveValue) {
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+      n1++;
+    } else {
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+      n0++;
+    }
+  }
+  const m1 = s1 / n1, m0 = s0 / n0;
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: pFromZ(z), z, m1, m0, n1, n0 };
+}
+
+function simpleSlope(y, x) {
+  const n = y.length;
+  let sx = 0, sy = 0;
+  for (let i = 0; i < n; i++) { sx += x[i]; sy += y[i]; }
+  const mx = sx / n, my = sy / n;
+  let sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx, dy = y[i] - my;
+    sxx += dx * dx;
+    sxy += dx * dy;
+    syy += dy * dy;
+  }
+  const b = sxy / sxx;
+  const a = my - b * mx;
+  const rss = syy - b * sxy;
+  const se = Math.sqrt((rss / (n - 2)) / sxx);
+  const z = b / se;
+  return { effect: b, p: pFromZ(z), z, intercept: a, meanX: mx, meanY: my };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error('singular matrix');
+    if (pivot !== i) [m[i], m[pivot]] = [m[pivot], m[i]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = m[r][i];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= factor * m[i][c];
+    }
+  }
+  return m.map(row => row.slice(n));
+}
+
+function ols(y, cols) {
+  const n = y.length;
+  const p = cols.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const c of cols) row.push(c.values[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < cols.length; j++) pred += beta[j + 1] * cols[j].values[i];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const terms = [{ name: '(Intercept)', beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]), p: null }];
+  terms[0].p = pFromZ(terms[0].beta / terms[0].se);
+  for (let j = 0; j < cols.length; j++) {
+    const se = Math.sqrt(sigma2 * inv[j + 1][j + 1]);
+    terms.push({ name: cols[j].name, beta: beta[j + 1], se, p: pFromZ(beta[j + 1] / se) });
+  }
+  return { terms, rss, sigma2, n, p };
+}
+
+function zscore(values) {
+  const m = mean(values);
+  const sd = Math.sqrt(variance(values));
+  return values.map(v => (v - m) / sd);
+}
+
+function center(values) {
+  const m = mean(values);
+  return values.map(v => v - m);
+}
+
+function interactionArray(a, b) {
+  const out = new Array(a.length);
+  for (let i = 0; i < a.length; i++) out[i] = a[i] * b[i];
+  return out;
+}
+
+function uniqueCounts(arr) {
+  const m = new Map();
+  for (const v of arr) m.set(v, (m.get(v) || 0) + 1);
+  return [...m.entries()].sort((a, b) => b[1] - a[1]);
+}
+
+function basicExploration(data) {
+  const y = data.pfs_months;
+  const cols = Object.keys(data).filter(c => c !== 'patient_id' && c !== 'pfs_months');
+  const binary = [];
+  const cont = [];
+  const cat = [];
+  for (const c of cols) {
+    const u = uniqueCounts(data[c]);
+    if (u.length <= 2 && typeof u[0][0] === 'number') binary.push(c);
+    else if (typeof u[0][0] === 'number') cont.push(c);
+    else cat.push(c);
+  }
+  const binStats = binary.map(c => ({ col: c, ...groupDiff(y, data[c], 1) })).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  const contStats = cont.map(c => ({ col: c, ...simpleSlope(y, data[c]) })).sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  const catStats = [];
+  for (const c of cat) {
+    for (const [level] of uniqueCounts(data[c])) {
+      const x = data[c].map(v => v === level ? 1 : 0);
+      catStats.push({ col: c, level, ...groupDiff(y, x, 1) });
+    }
+  }
+  catStats.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  return { binary, cont, cat, binStats, contStats, catStats };
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 1000 || (Math.abs(x) < 0.001 && x !== 0)) return x.toExponential(3);
+  return x.toFixed(digits);
+}
+
+function ptxt(p) {
+  return p < 1e-250 ? '<1e-250' : fmt(p, 3);
+}
+
+function main() {
+  const { meta, data } = readParquet();
+  const y = data.pfs_months;
+  const exp = basicExploration(data);
+  console.log(`rows ${meta.num_rows}, columns ${Object.keys(data).length}`);
+  console.log('categorical uniques', JSON.stringify(Object.fromEntries(exp.cat.map(c => [c, uniqueCounts(data[c])]))));
+  console.log('top binary', exp.binStats.slice(0, 20).map(r => `${r.col}: diff=${fmt(r.effect)} p=${ptxt(r.p)} n1=${r.n1}`).join('\n'));
+  console.log('top continuous', exp.contStats.slice(0, 20).map(r => `${r.col}: slope=${fmt(r.effect)} p=${ptxt(r.p)}`).join('\n'));
+  console.log('top categorical', exp.catStats.slice(0, 10).map(r => `${r.col}=${r.level}: diff=${fmt(r.effect)} p=${ptxt(r.p)}`).join('\n'));
+}
+
+if (require.main === module) {
+  main();
+}
+
+module.exports = {
+  readParquet, mean, variance, groupDiff, simpleSlope, ols, zscore, center,
+  interactionArray, uniqueCounts, basicExploration, pFromZ, fmt, ptxt,
+};
