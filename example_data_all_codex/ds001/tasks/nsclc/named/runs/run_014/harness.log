+
+function plainDecode(buf, parquetType, count) {
+  const values = [];
+  let p = 0;
+  for (let i = 0; i < count; i++) {
+    if (parquetType === 5) {
+      values.push(buf.readDoubleLE(p));
+      p += 8;
+    } else if (parquetType === 2) {
+      values.push(Number(buf.readBigInt64LE(p)));
+      p += 8;
+    } else if (parquetType === 1) {
+      values.push(buf.readInt32LE(p));
+      p += 4;
+    } else if (parquetType === 6) {
+      const len = buf.readInt32LE(p);
+      p += 4;
