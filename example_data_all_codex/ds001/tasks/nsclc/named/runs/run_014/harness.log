+      let bitBuffer = 0;
+      let bits = 0;
+      for (let i = 0; i < total && out.length < expected; i++) {
+        while (bits < bitW) {
+          bitBuffer |= buf[state.p++] << bits;
+          bits += 8;
+        }
+        out.push(bitBuffer & mask);
