+    const name = md.path_in_schema.join('.');
+    const schemaElem = schemaByName.get(name);
+    let offset = md.dictionary_page_offset ?? md.data_page_offset;
+    const endOffset = (md.dictionary_page_offset ?? md.data_page_offset) + md.total_compressed_size;
