+  { name: 'pembro_x_squamous', values: a.interactionArray(pembro, dummy('histology', 'squamous')) },
+  { name: 'sotorasib_x_squamous', values: a.interactionArray(soto, dummy('histology', 'squamous')) },
+]), ['pembrolizumab','sotorasib','histology_squamous','pembro_x_squamous','sotorasib_x_squamous']);
+
+// Subgroup mean differences for interpretation.
+function subsetDiff(label, treat, pred) {
+  const yy = [], xx = [];
+  for (let i = 0; i < n; i++) if (pred(i)) { yy.push(y[i]); xx.push(treat[i]); }
+  const r = a.groupDiff(yy, xx, 1);
+  console.log(`${label}\tdiff=${a.fmt(r.effect, 6)}\tp=${a.ptxt(r.p)}\tm1=${a.fmt(r.m1)}\tm0=${a.fmt(r.m0)}\tn1=${r.n1}\tn0=${r.n0}`);
+}
+console.log('\nsubgroups');
+subsetDiff('osimertinib within EGFR+', osim, i => egfr[i] === 1);
+subsetDiff('osimertinib within EGFR-', osim, i => egfr[i] === 0);
+subsetDiff('sotorasib within KRAS+', soto, i => kras[i] === 1);
