+class CompactReader {
+  constructor(buf) {
+    this.buf = buf;
+    this.pos = 0;
+    this.lastField = [];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
+  }
+  readZigZag() {
+    const n = this.readVarintBig();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readI64() {
+    const n = this.readVarintBig();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
+    const len = this.readVarint();
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readString() {
+    return this.readBinary().toString('utf8');
+  }
+  pushStruct() {
+    this.lastField.push(0);
+  }
+  popStruct() {
+    this.lastField.pop();
+  }
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type, id: 0 };
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) id = this.readZigZag();
+    else id = this.lastField[this.lastField.length - 1] + delta;
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = this.readVarint();
+    return { size, elemType };
+  }
+  skip(type) {
+    switch (type) {
+      case 0:
+        return;
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+        this.readZigZag();
+        return;
+      case 6:
+        this.readI64();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8:
+        this.readBinary();
+        return;
+      case 9:
+      case 10: {
