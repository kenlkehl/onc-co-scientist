+}
+
+function readDataPageHeader(r) {
+  return readStruct(r, {
+    1: { name: 'num_values', read: readI32 },
+    2: { name: 'encoding', read: readEnum },
+    3: { name: 'definition_level_encoding', read: readEnum },
+    4: { name: 'repetition_level_encoding', read: readEnum },
+    5: { name: 'statistics', read: readStats },
+  });
+}
+
+function readDictionaryPageHeader(r) {
+  return readStruct(r, {
+    1: { name: 'num_values', read: readI32 },
+    2: { name: 'encoding', read: readEnum },
+    3: { name: 'is_sorted', read: readBool },
+  });
+}
+
+function readDataPageHeaderV2(r) {
+  return readStruct(r, {
+    1: { name: 'num_values', read: readI32 },
+    2: { name: 'num_nulls', read: readI32 },
+    3: { name: 'num_rows', read: readI32 },
+    4: { name: 'encoding', read: readEnum },
+    5: { name: 'definition_levels_byte_length', read: readI32 },
+    6: { name: 'repetition_levels_byte_length', read: readI32 },
+    7: { name: 'is_compressed', read: readBool },
+    8: { name: 'statistics', read: readStats },
+  });
+}
+
+function readPageHeader(reader) {
+  const out = {};
+  reader.pushStruct();
+  while (true) {
+    const f = reader.readFieldBegin();
+    if (f.type === 0) break;
+    if (f.id === 1) out.type = readEnum(reader);
+    else if (f.id === 2) out.uncompressed_page_size = readI32(reader);
+    else if (f.id === 3) out.compressed_page_size = readI32(reader);
+    else if (f.id === 4 || f.id === 5) out.data_page_header = readDataPageHeader(reader);
+    else if (f.id === 6 || (f.id === 7 && out.type === 2)) out.dictionary_page_header = readDictionaryPageHeader(reader);
+    else if (f.id === 7 || f.id === 8) out.data_page_header_v2 = readDataPageHeaderV2(reader);
+    else reader.skip(f.type);
+  }
+  reader.popStruct();
+  return out;
+}
+
+function snappyUncompress(input) {
+  let ip = 0;
+  let shift = 0;
+  let expected = 0;
