+        if (size === 0) return;
+        const kt = this.readByte();
+        const vt = this.readByte();
+        for (let i = 0; i < size; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12:
+        this.pushStruct();
+        while (true) {
