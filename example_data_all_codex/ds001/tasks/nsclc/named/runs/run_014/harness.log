+class CompactReader {
+  constructor(buf) {
+    this.buf = buf;
+    this.pos = 0;
+    this.lastField = [];
+  }
+  readByte() {
+    if (this.pos >= this.buf.length) throw new Error('compact reader overflow');
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
