+const fs = require('fs');
+
+class CompactReader {
+  constructor(buf) {
+    this.buf = buf;
+    this.pos = 0;
+    this.lastField = [];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
+  }
+  readZigZag() {
+    const n = this.readVarintBig();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readI64() {
+    const n = this.readVarintBig();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
+    const len = this.readVarint();
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readString() {
+    return this.readBinary().toString('utf8');
+  }
+  pushStruct() {
+    this.lastField.push(0);
+  }
+  popStruct() {
+    this.lastField.pop();
+  }
+  readFieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type, id: 0 };
+    const delta = b >> 4;
+    let id;
+    if (delta === 0) id = this.readZigZag();
+    else id = this.lastField[this.lastField.length - 1] + delta;
+    this.lastField[this.lastField.length - 1] = id;
+    return { type, id };
+  }
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = this.readVarint();
+    return { size, elemType };
+  }
+  skip(type) {
+    switch (type) {
+      case 0:
+        return;
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.pos += 1;
+        return;
+      case 4:
+      case 5:
+        this.readZigZag();
+        return;
+      case 6:
+        this.readI64();
+        return;
+      case 7:
+        this.pos += 8;
+        return;
+      case 8:
+        this.readBinary();
+        return;
+      case 9:
+      case 10: {
+        const { size, elemType } = this.readListBegin();
+        for (let i = 0; i < size; i++) this.skip(elemType);
+        return;
+      }
+      case 11: {
+        const size = this.readVarint();
+        if (size === 0) return;
+        const kt = this.readByte();
+        const vt = this.readByte();
+        for (let i = 0; i < size; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12:
+        this.pushStruct();
+        while (true) {
+          const f = this.readFieldBegin();
+          if (f.type === 0) break;
+          this.skip(f.type);
+        }
+        this.popStruct();
+        return;
+      default:
+        throw new Error(`unknown compact type ${type} at ${this.pos}`);
+    }
+  }
+}
+
+function readStruct(reader, handlers) {
+  const out = {};
+  reader.pushStruct();
+  while (true) {
+    const f = reader.readFieldBegin();
+    if (f.type === 0) break;
+    const handler = handlers[f.id];
+    if (handler) out[handler.name] = handler.read(reader, f.type);
+    else reader.skip(f.type);
+  }
+  reader.popStruct();
+  return out;
+}
+
+const readI32 = r => r.readZigZag();
+const readI64 = r => r.readI64();
+const readString = r => r.readString();
+const readEnum = r => r.readZigZag();
+function readList(reader, elemReader) {
+  const { size } = reader.readListBegin();
+  const arr = [];
+  for (let i = 0; i < size; i++) arr.push(elemReader(reader));
+  return arr;
+}
+
+function readKeyValue(r) {
+  return readStruct(r, {
+    1: { name: 'key', read: readString },
+    2: { name: 'value', read: readString },
+  });
+}
+function readSchemaElement(r) {
+  return readStruct(r, {
+    1: { name: 'type', read: readEnum },
+    2: { name: 'type_length', read: readI32 },
+    3: { name: 'repetition_type', read: readEnum },
+    4: { name: 'name', read: readString },
+    5: { name: 'num_children', read: readI32 },
+    6: { name: 'converted_type', read: readEnum },
+    7: { name: 'scale', read: readI32 },
+    8: { name: 'precision', read: readI32 },
+    9: { name: 'field_id', read: readI32 },
+  });
+}
+function readStats(r) {
+  return readStruct(r, {
+    1: { name: 'max', read: rr => rr.readBinary() },
+    2: { name: 'min', read: rr => rr.readBinary() },
+    3: { name: 'null_count', read: readI64 },
+    4: { name: 'distinct_count', read: readI64 },
+    5: { name: 'max_value', read: rr => rr.readBinary() },
+    6: { name: 'min_value', read: rr => rr.readBinary() },
+  });
+}
+function readDataPageHeader(r) {
+  return readStruct(r, {
+    1: { name: 'num_values', read: readI32 },
+    2: { name: 'encoding', read: readEnum },
+    3: { name: 'definition_level_encoding', read: readEnum },
+    4: { name: 'repetition_level_encoding', read: readEnum },
+    5: { name: 'statistics', read: readStats },
+  });
+}
+function readDictionaryPageHeader(r) {
+  return readStruct(r, {
+    1: { name: 'num_values', read: readI32 },
+    2: { name: 'encoding', read: readEnum },
+    3: { name: 'is_sorted', read: (rr, type) => type === 1 ? true : type === 2 ? false : rr.readByte() !== 0 },
+  });
+}
+function readDataPageHeaderV2(r) {
+  return readStruct(r, {
+    1: { name: 'num_values', read: readI32 },
+    2: { name: 'num_nulls', read: readI32 },
+    3: { name: 'num_rows', read: readI32 },
+    4: { name: 'encoding', read: readEnum },
+    5: { name: 'definition_levels_byte_length', read: readI32 },
+    6: { name: 'repetition_levels_byte_length', read: readI32 },
+    7: { name: 'is_compressed', read: (rr, type) => type === 1 ? true : type === 2 ? false : rr.readByte() !== 0 },
+    8: { name: 'statistics', read: readStats },
+  });
+}
+function readPageHeader(r) {
+  return readStruct(r, {
+    1: { name: 'type', read: readEnum },
+    2: { name: 'uncompressed_page_size', read: readI32 },
+    3: { name: 'compressed_page_size', read: readI32 },
+    4: { name: 'data_page_header', read: readDataPageHeader },
+    6: { name: 'dictionary_page_header', read: readDictionaryPageHeader },
+    7: { name: 'data_page_header_v2', read: readDataPageHeaderV2 },
+    8: { name: 'crc', read: readI32 },
+  });
+}
+function readColumnMetaData(r) {
+  return readStruct(r, {
+    1: { name: 'type', read: readEnum },
+    2: { name: 'encodings', read: rr => readList(rr, readEnum) },
+    3: { name: 'path_in_schema', read: rr => readList(rr, readString) },
+    4: { name: 'codec', read: readEnum },
+    5: { name: 'num_values', read: readI64 },
+    6: { name: 'total_uncompressed_size', read: readI64 },
+    7: { name: 'total_compressed_size', read: readI64 },
+    8: { name: 'key_value_metadata', read: rr => readList(rr, readKeyValue) },
+    9: { name: 'data_page_offset', read: readI64 },
+    10: { name: 'index_page_offset', read: readI64 },
+    11: { name: 'dictionary_page_offset', read: readI64 },
+    12: { name: 'statistics', read: readStats },
+  });
+}
+function readColumnChunk(r) {
+  return readStruct(r, {
+    1: { name: 'file_path', read: readString },
+    2: { name: 'file_offset', read: readI64 },
+    3: { name: 'meta_data', read: readColumnMetaData },
+    4: { name: 'offset_index_offset', read: readI64 },
+    5: { name: 'offset_index_length', read: readI32 },
+    6: { name: 'column_index_offset', read: readI64 },
+    7: { name: 'column_index_length', read: readI32 },
+  });
+}
+function readRowGroup(r) {
+  return readStruct(r, {
+    1: { name: 'columns', read: rr => readList(rr, readColumnChunk) },
+    2: { name: 'total_byte_size', read: readI64 },
+    3: { name: 'num_rows', read: readI64 },
+    5: { name: 'file_offset', read: readI64 },
+    6: { name: 'total_compressed_size', read: readI64 },
+    7: { name: 'ordinal', read: readI64 },
+  });
+}
+function readFileMetaData(r) {
+  return readStruct(r, {
+    1: { name: 'version', read: readI32 },
+    2: { name: 'schema', read: rr => readList(rr, readSchemaElement) },
+    3: { name: 'num_rows', read: readI64 },
+    4: { name: 'row_groups', read: rr => readList(rr, readRowGroup) },
+    5: { name: 'key_value_metadata', read: rr => readList(rr, readKeyValue) },
+    6: { name: 'created_by', read: readString },
+  });
+}
+
+const file = fs.readFileSync('dataset.parquet');
+if (file.subarray(0, 4).toString() !== 'PAR1' || file.subarray(file.length - 4).toString() !== 'PAR1') {
+  throw new Error('not a parquet file');
+}
+const footerLen = file.readUInt32LE(file.length - 8);
+const footer = file.subarray(file.length - 8 - footerLen, file.length - 8);
+const meta = readFileMetaData(new CompactReader(footer));
+console.log(JSON.stringify({
+  version: meta.version,
+  num_rows: meta.num_rows,
+  created_by: meta.created_by,
+  schema: meta.schema,
+  row_groups: meta.row_groups.map(rg => ({
+    num_rows: rg.num_rows,
+    total_byte_size: rg.total_byte_size,
+    total_compressed_size: rg.total_compressed_size,
+    columns: rg.columns.map(c => ({
+      path: c.meta_data.path_in_schema.join('.'),
+      type: c.meta_data.type,
+      codec: c.meta_data.codec,
+      encodings: c.meta_data.encodings,
+      num_values: c.meta_data.num_values,
+      data_page_offset: c.meta_data.data_page_offset,
+      dictionary_page_offset: c.meta_data.dictionary_page_offset,
+      total_compressed_size: c.meta_data.total_compressed_size,
+      total_uncompressed_size: c.meta_data.total_uncompressed_size,
+    })),
+  })),
+}, null, 2));
+
+for (const colName of ['sex_female', 'smoking_status', 'age_years', 'pfs_months']) {
+  const col = meta.row_groups[0].columns.find(c => c.meta_data.path_in_schema.join('.') === colName);
+  console.error(`\nPAGES ${colName}`);
+  let off = col.meta_data.dictionary_page_offset ?? col.meta_data.data_page_offset;
+  let seen = 0;
+  for (let i = 0; i < 5 && off < col.meta_data.data_page_offset + col.meta_data.total_compressed_size; i++) {
+    const pr = new CompactReader(file.subarray(off));
+    const ph = readPageHeader(pr);
+    console.error(JSON.stringify({ offset: off, header_bytes: pr.pos, ph }, null, 2));
+    off += pr.pos + ph.compressed_page_size;
+    if (ph.data_page_header) seen += ph.data_page_header.num_values;
+    if (ph.data_page_header_v2) seen += ph.data_page_header_v2.num_values;
+    if (seen >= col.meta_data.num_values) break;
+  }
+}
