+function pFromZ(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  if (p === 0) return 1e-300;
+  return Math.max(p, 1e-300);
+}
+
+function groupDiff(y, x, positiveValue = 1) {
+  let s1 = 0, s0 = 0, ss1 = 0, ss0 = 0, n1 = 0, n0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === positiveValue) {
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+      n1++;
+    } else {
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+      n0++;
+    }
+  }
+  const m1 = s1 / n1, m0 = s0 / n0;
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: pFromZ(z), z, m1, m0, n1, n0 };
