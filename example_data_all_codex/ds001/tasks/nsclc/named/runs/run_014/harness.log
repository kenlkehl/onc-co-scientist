+const a = require('./analyze_dataset.js');
+const { data } = a.readParquet();
+const y = data.pfs_months;
+const bin = name => data[name].map(Number);
+const dummy = (name, value) => data[name].map(v => v === value ? 1 : 0);
+const center = name => a.center(data[name]);
+const scaleValues = (values, s) => values.map(v => v * s);
+const colsMeta = Object.keys(data).filter(c => c !== 'patient_id' && c !== 'pfs_months');
+const baseSpec = {
+  age_years: center('age_years'),
+  sex_female: bin('sex_female'),
+  stage_iv: bin('stage_iv'),
+  has_brain_mets: bin('has_brain_mets'),
+  ecog_ps: center('ecog_ps'),
+  histology_squamous: dummy('histology', 'squamous'),
+  smoking_current: dummy('smoking_status', 'current'),
+  smoking_never: dummy('smoking_status', 'never'),
+  albumin_g_dl: center('albumin_g_dl'),
+  weight_loss_pct_6mo: center('weight_loss_pct_6mo'),
+  ldh_per100: scaleValues(center('ldh_u_l'), 0.01),
+};
+function base(excludes = []) {
+  const ex = new Set(excludes);
+  return Object.entries(baseSpec).filter(([k]) => !ex.has(k)).map(([name, values]) => ({ name, values }));
+}
+function term(model, name) { return model.terms.find(t => t.name === name); }
+function uniqueCount(name) { return a.uniqueCounts(data[name]).length; }
+function numeric(name) { return typeof data[name][0] === 'number'; }
+const binaryVars = colsMeta.filter(c => numeric(c) && uniqueCount(c) <= 2);
+const contVars = colsMeta.filter(c => numeric(c) && uniqueCount(c) > 2);
+const treatmentVars = ['treatment_pembrolizumab','treatment_sotorasib','treatment_olaparib','treatment_osimertinib'];
+const biomarkerVars = binaryVars.filter(c => !treatmentVars.includes(c));
+
+const interactions = [];
+for (const tx of treatmentVars) {
+  for (const v of biomarkerVars) {
+    try {
+      const txv = bin(tx), vv = bin(v);
+      const intName = `${tx}_x_${v}`;
+      const m = a.ols(y, base().concat([
+        { name: tx, values: txv },
+        { name: v, values: vv },
+        { name: intName, values: a.interactionArray(txv, vv) },
+      ]));
+      const t = term(m, intName);
+      interactions.push({ tx, v, beta: t.beta, p: t.p, z: t.beta / t.se });
+    } catch (e) {}
+  }
+  for (const v of contVars) {
+    try {
+      const txv = bin(tx);
+      const vv = a.zscore(data[v]);
+      const intName = `${tx}_x_${v}_z`;
+      const m = a.ols(y, base().concat([
+        { name: tx, values: txv },
+        { name: `${v}_z`, values: vv },
+        { name: intName, values: a.interactionArray(txv, vv) },
+      ]));
+      const t = term(m, intName);
+      interactions.push({ tx, v: `${v}_z`, beta: t.beta, p: t.p, z: t.beta / t.se });
+    } catch (e) {}
+  }
+}
+interactions.sort((x, y2) => Math.abs(y2.z) - Math.abs(x.z));
+console.log('top treatment interactions');
+for (const r of interactions.slice(0, 40)) {
+  console.log(`${r.tx} x ${r.v}\tbeta=${a.fmt(r.beta,6)}\tz=${a.fmt(r.z,3)}\tp=${a.ptxt(r.p)}`);
+}
+
+const adjustedMain = [];
+for (const v of biomarkerVars.concat(contVars)) {
+  try {
+    const vv = uniqueCount(v) <= 2 ? bin(v) : a.zscore(data[v]);
+    const nm = uniqueCount(v) <= 2 ? v : `${v}_z`;
+    const m = a.ols(y, base().concat([{ name: nm, values: vv }]));
+    const t = term(m, nm);
+    adjustedMain.push({ v: nm, beta: t.beta, p: t.p, z: t.beta / t.se });
+  } catch (e) {}
+}
+adjustedMain.sort((x, y2) => Math.abs(y2.z) - Math.abs(x.z));
+console.log('\ntop adjusted main effects');
+for (const r of adjustedMain.slice(0, 60)) {
+  console.log(`${r.v}\tbeta=${a.fmt(r.beta,6)}\tz=${a.fmt(r.z,3)}\tp=${a.ptxt(r.p)}`);
+}
+
+// Pairwise binary interactions outside treatment, adjusted for the same core.
+const pairInts = [];
+for (let i = 0; i < biomarkerVars.length; i++) {
+  for (let j = i + 1; j < biomarkerVars.length; j++) {
+    const v1 = biomarkerVars[i], v2 = biomarkerVars[j];
+    try {
+      const a1 = bin(v1), a2 = bin(v2);
+      const intName = `${v1}_x_${v2}`;
+      const m = a.ols(y, base().concat([
+        { name: v1, values: a1 },
+        { name: v2, values: a2 },
+        { name: intName, values: a.interactionArray(a1, a2) },
+      ]));
+      const t = term(m, intName);
+      pairInts.push({ v1, v2, beta: t.beta, p: t.p, z: t.beta / t.se });
+    } catch (e) {}
+  }
+}
+pairInts.sort((x, y2) => Math.abs(y2.z) - Math.abs(x.z));
+console.log('\ntop binary-binary interactions');
+for (const r of pairInts.slice(0, 40)) {
+  console.log(`${r.v1} x ${r.v2}\tbeta=${a.fmt(r.beta,6)}\tz=${a.fmt(r.z,3)}\tp=${a.ptxt(r.p)}`);
+}

