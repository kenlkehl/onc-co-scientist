+  trm = term(mainModel, 'crp_per_10');
+  addIter(23, [h23], [rec([h23.id], trm.beta, trm.p, `Adjusted OLS estimated ${fmt(trm.beta)} PFS months per 10 mg/L higher crp_mg_l (SE ${fmt(trm.se)}, p=${fmt(trm.p)}).`, 'adjusted OLS: pfs_months ~ crp_mg_l/10 + treatments + biomarkers + clinical covariates')]);
