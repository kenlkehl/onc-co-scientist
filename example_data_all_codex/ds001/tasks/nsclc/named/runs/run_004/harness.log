+  if (Math.abs(x) > 0 && Math.abs(x) < 1e-4) return x.toExponential(2);
+  return x.toFixed(digits);
+}
+
+function pval(x) {
+  if (x === 0) return 0;
+  return Number(x.toPrecision(6));
+}
+
+function rec(hypothesis_ids, effect, p, summary, code) {
+  return {
+    hypothesis_ids,
+    code,
+    result_summary: summary,
+    p_value: pval(p),
+    effect_estimate: Number(effect.toFixed(6)),
+    significant: p < 0.05
+  };
+}
+
+function writeOutputs(transcript, summary) {
+  fs.writeFileSync('transcript.json', JSON.stringify(transcript, null, 2));
+  fs.writeFileSync('analysis_summary.txt', summary);
+}
+
+function main() {
+  const { data: df, n } = loadParquet('dataset.parquet');
+  if (process.env.DEBUG_COUNTS === '1') {
+    const cols = Object.keys(df);
+    for (const c of cols) {
+      const vals = df[c];
+      const uniq = new Map();
+      for (const v of vals) {
+        const key = String(v);
+        uniq.set(key, (uniq.get(key) || 0) + 1);
+      }
+      if (uniq.size <= 12) {
+        console.log(c, [...uniq.entries()].map(([k, v]) => `${k}:${v}`).join(', '));
+      } else {
+        console.log(c, 'unique', uniq.size, 'min', Math.min(...vals), 'max', Math.max(...vals));
+      }
+    }
+    const pairs = [
+      ['treatment_sotorasib', 'kras_g12c'],
+      ['treatment_osimertinib', 'egfr_mutation'],
+      ['treatment_olaparib', 'brca2_mutation']
+    ];
+    for (const [a, b] of pairs) {
+      let both = 0, onlyA = 0, onlyB = 0, neither = 0;
+      for (let i = 0; i < n; i++) {
+        if (df[a][i] && df[b][i]) both++;
+        else if (df[a][i]) onlyA++;
+        else if (df[b][i]) onlyB++;
+        else neither++;
+      }
+      console.log(`${a} vs ${b}: both=${both} onlyA=${onlyA} onlyB=${onlyB} neither=${neither}`);
+    }
+    return;
+  }
+  if (process.env.EXPLORE === '1') {
+    const skip = new Set(['patient_id', 'pfs_months']);
+    const cats = {
+      smoking_status: ['former', 'current'],
+      ecog_ps: [1, 2],
+      histology: ['squamous']
+    };
+    const specs = [];
+    for (const c of Object.keys(df)) {
+      if (skip.has(c)) continue;
+      if (cats[c]) {
+        for (const level of cats[c]) specs.push({ name: `${c}_${level}`, fn: i => df[c][i] === level ? 1 : 0 });
+        continue;
+      }
+      if (cats[c] === undefined && typeof df[c][0] === 'string') continue;
+      const vals = df[c].map(Number);
+      const unique = new Set(vals);
+      if (unique.size <= 1) continue;
+      if (unique.size === 2 && unique.has(0) && unique.has(1)) {
+        specs.push({ name: c, fn: i => +df[c][i] });
+      } else {
+        const m = mean(vals);
+        const sd = Math.sqrt(variance(vals));
+        specs.push({ name: `${c}_per_sd`, fn: i => (df[c][i] - m) / sd });
+      }
+    }
+    const { X, names } = buildMatrix(df, specs);
+    const model = { ...ols(df.pfs_months, X), names };
+    const rows = names.slice(1).map((name, k) => {
+      const i = k + 1;
+      return { name, beta: model.beta[i], se: model.se[i], p: model.p[i], t: model.t[i] };
+    }).sort((a, b) => Math.abs(b.t) - Math.abs(a.t));
+    console.log('Top adjusted main effects');
+    for (const r of rows.slice(0, 40)) console.log(r.name, fmt(r.beta), fmt(r.se), fmt(r.t), fmt(r.p));
+
+    const interactions = [];
+    const treatments = ['treatment_pembrolizumab', 'treatment_sotorasib', 'treatment_olaparib', 'treatment_osimertinib'];
+    const biomarkers = ['egfr_mutation', 'kras_g12c', 'alk_fusion', 'stk11_mutation', 'brca2_mutation', 'tmb_high', 'pdl1_tps'];
+    for (const tx of treatments) {
+      for (const bio of biomarkers) {
+        const bioSpec = bio === 'pdl1_tps'
+          ? { main: { name: 'pdl1_tps_per_0_5', fn: i => df.pdl1_tps[i] / 0.5 }, int: { name: `${tx}_x_pdl1_tps_per_0_5`, fn: i => (+df[tx][i]) * df.pdl1_tps[i] / 0.5 } }
+          : { main: { name: bio, fn: i => +df[bio][i] }, int: { name: `${tx}_x_${bio}`, fn: i => (+df[tx][i]) * (+df[bio][i]) } };
+        const m = adjustedModel(df, [
+          { name: tx, fn: i => +df[tx][i] },
+          bioSpec.main,
+          bioSpec.int
+        ]);
+        const r = term(m, bioSpec.int.name);
+        interactions.push({ name: bioSpec.int.name, beta: r.beta, se: r.se, p: r.p, t: r.t });
+      }
+    }
+    interactions.sort((a, b) => Math.abs(b.t) - Math.abs(a.t));
+    console.log('Top treatment-biomarker interactions');
+    for (const r of interactions) console.log(r.name, fmt(r.beta), fmt(r.se), fmt(r.t), fmt(r.p));
+    return;
+  }
+  const iterations = [];
+  const addIter = (index, hypotheses, analyses) => {
+    iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+  };
+
+  let h = 1;
+  const hyp = (text, kind = 'novel') => ({ id: `h${h++}`, text, kind });
+
