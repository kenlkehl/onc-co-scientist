+    let shift = 0;
+    let result = 0;
+    while (true) {
+      const b = input[ip++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return result;
+      shift += 7;
+    }
+  }
+  const totalLen = readVarint();
+  const out = Buffer.alloc(expectedSize || totalLen);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
