+function schemaColumns(meta) {
+  const schema = meta[2];
+  return schema.slice(1).map((s, i) => ({
+    index: i,
+    name: s[4],
+    type: s[1],
+    converted: s[6] ?? null,
+    logical: s[10] ?? null
