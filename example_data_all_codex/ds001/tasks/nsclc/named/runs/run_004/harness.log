+function readUnsignedVarint(br) {
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = br.u8();
+    result += (b & 0x7f) * Math.pow(2, shift);
+    if ((b & 0x80) === 0) return result;
+    shift += 7;
+  }
