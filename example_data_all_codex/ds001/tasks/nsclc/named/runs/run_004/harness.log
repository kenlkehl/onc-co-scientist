+function parseFileMetadata(fileBuf) {
+  if (fileBuf.subarray(0, 4).toString('ascii') !== 'PAR1') throw new Error('Not a parquet file');
+  const trailerMagic = fileBuf.subarray(fileBuf.length - 4).toString('ascii');
+  if (trailerMagic !== 'PAR1') throw new Error('Bad parquet trailer');
