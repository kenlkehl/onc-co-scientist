+    { name: 'treatment_sotorasib', fn: i => +df.treatment_sotorasib[i] },
+    { name: 'treatment_olaparib', fn: i => +df.treatment_olaparib[i] },
+    { name: 'treatment_osimertinib', fn: i => +df.treatment_osimertinib[i] },
+    { name: 'egfr_mutation', fn: i => +df.egfr_mutation[i] },
+    { name: 'kras_g12c', fn: i => +df.kras_g12c[i] },
