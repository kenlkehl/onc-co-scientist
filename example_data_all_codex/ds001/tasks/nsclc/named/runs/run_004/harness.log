+  const lines = [];
+  lines.push(`Dataset ${DATASET_ID}: ${n} NSCLC patient records with pfs_months as the continuous outcome. I ran ${iterations.length} propose-test-refine iterations using adjusted ordinary least-squares models and targeted subgroup mean comparisons. Adjusted models included demographics, stage, brain metastases, albumin, LDH, weight loss, CRP, NLR, ECOG performance status, histology, smoking, treatments, and key biomarkers unless otherwise noted.`);
