+function readUnsignedVarint(br) {
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = br.u8();
+    result += (b & 0x7f) * Math.pow(2, shift);
+    if ((b & 0x80) === 0) return result;
+    shift += 7;
+  }
+}
+
+function readBitPacked(br, count, bitWidth) {
+  if (bitWidth === 0) return Array(count).fill(0);
+  const vals = [];
+  let bitBuffer = 0;
+  let bits = 0;
+  const mask = (1 << bitWidth) - 1;
+  while (vals.length < count) {
+    if (bits < bitWidth) {
+      bitBuffer |= br.u8() << bits;
+      bits += 8;
+    } else {
+      vals.push(bitBuffer & mask);
+      bitBuffer >>= bitWidth;
+      bits -= bitWidth;
+    }
+  }
+  return vals;
+}
+
+function readRleBitPacked(br, count, bitWidth) {
+  const vals = [];
+  const bytesForWidth = Math.ceil(bitWidth / 8);
+  while (vals.length < count && br.pos < br.buf.length) {
+    const header = readUnsignedVarint(br);
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      let value = 0;
+      for (let i = 0; i < bytesForWidth; i++) value |= br.u8() << (8 * i);
+      for (let i = 0; i < runLen && vals.length < count; i++) vals.push(value);
+    } else {
+      const groups = header >> 1;
+      const runLen = groups * 8;
+      const packedByteCount = Math.ceil(runLen * bitWidth / 8);
+      const packed = new ByteReader(br.bytes(packedByteCount));
