+function maybeDecompress(codec, buf, expectedSize) {
+  if (codec === 0) return buf;
+  if (codec === 2) return zlib.inflateRawSync(buf);
+  if (codec === 1) return snappyUncompress(buf, expectedSize);
+  throw new Error(`Unsupported parquet compression codec ${codec}`);
