+  addIter(20, [h20], [rec([h20.id], trm.beta, trm.p, `Adjusted OLS estimated ${fmt(trm.beta)} PFS months for has_brain_mets-positive versus negative patients (SE ${fmt(trm.se)}, p=${fmt(trm.p)}).`, 'adjusted OLS: pfs_months ~ has_brain_mets + treatments + biomarkers + clinical covariates')]);
+
+  const h21 = hyp('Patients with `liver_mets` have shorter `pfs_months` than patients without `liver_mets`, independent of treatment, disease stage, and laboratory covariates.');
+  model = adjustedModel(df, [
+    { name: 'liver_mets', fn: i => +df.liver_mets[i] },
+    { name: 'bone_mets', fn: i => +df.bone_mets[i] },
+    { name: 'pleural_effusion', fn: i => +df.pleural_effusion[i] },
+    { name: 'treatment_pembrolizumab', fn: i => +df.treatment_pembrolizumab[i] },
+    { name: 'treatment_sotorasib', fn: i => +df.treatment_sotorasib[i] },
+    { name: 'treatment_olaparib', fn: i => +df.treatment_olaparib[i] },
+    { name: 'treatment_osimertinib', fn: i => +df.treatment_osimertinib[i] },
+    { name: 'egfr_mutation', fn: i => +df.egfr_mutation[i] },
+    { name: 'kras_g12c', fn: i => +df.kras_g12c[i] },
+    { name: 'stk11_mutation', fn: i => +df.stk11_mutation[i] },
+    { name: 'brca2_mutation', fn: i => +df.brca2_mutation[i] },
+    { name: 'tmb_high', fn: i => +df.tmb_high[i] },
+    { name: 'pdl1_tps_per_50', fn: i => df.pdl1_tps[i] / 50 }
+  ]);
+  trm = term(model, 'liver_mets');
