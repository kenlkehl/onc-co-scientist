+  const values = [];
+  while (pos < end && values.length < totalValues) {
+    const { header, next } = parsePageHeader(fileBuf, pos);
+    const pageType = header[1];
+    const uncompressed = header[2];
+    const compressed = header[3];
+    const compressedPayload = fileBuf.subarray(next, next + compressed);
+    const payload = maybeDecompress(codec, compressedPayload, uncompressed);
+    if (pageType === 2) {
