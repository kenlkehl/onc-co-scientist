+      case 5: return this.i32();
+      case 6: return this.i64();
+      case 7: return this.double();
+      case 8: return this.str();
+      case 9: return this.list();
+      case 12: return this.struct();
+      default:
+        throw new Error(`Unsupported compact thrift type ${type} at ${this.pos}`);
+    }
+  }
+  struct() {
+    const out = {};
+    let last = 0;
+    while (true) {
+      const hdr = this.byte();
+      const type = hdr & 0x0f;
+      if (type === 0) break;
+      const delta = hdr >> 4;
+      const field = delta === 0 ? this.i16() : last + delta;
+      last = field;
+      out[field] = this.value(type);
+    }
+    return out;
+  }
