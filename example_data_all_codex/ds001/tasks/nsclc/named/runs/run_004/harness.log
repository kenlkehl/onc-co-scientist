+  const h1 = hyp('Patients receiving `treatment_pembrolizumab` have longer mean `pfs_months` than patients not receiving `treatment_pembrolizumab`, after adjustment for demographics, stage, histology, smoking, ECOG performance status, metastatic burden, inflammatory/nutritional labs, other treatments, and key biomarkers.');
