+  const beta = matVec(XtXInv, Xty);
+  const n = y.length, p = beta.length;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += X[i][j] * beta[j];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const se = XtXInv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const t = beta.map((b, i) => b / se[i]);
+  const pvals = t.map(pFromT);
+  return { beta, se, t, p: pvals, rss, df: n - p };
