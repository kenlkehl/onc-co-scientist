+function decodeDictIndices(buf, count, dictSize) {
+  const br = new ByteReader(buf);
+  const bitWidth = br.u8();
+  return readRleBitPacked(br, count, bitWidth || bitWidthFor(dictSize - 1));
+}
+
+function decodeDataPage(type, encoding, payload, numValues, dictionary) {
+  const br = new ByteReader(payload);
+  const defLen = br.u32le();
+  br.bytes(defLen);
+  const valuesBuf = payload.subarray(br.pos);
+  if (encoding === 0) {
+    if (type === 0) return decodeBoolPlain(valuesBuf, numValues);
+    return decodePlain(type, valuesBuf, numValues);
+  }
+  if (encoding === 2 || encoding === 8) {
+    const idx = decodeDictIndices(valuesBuf, numValues, dictionary.length);
+    return idx.map(i => dictionary[i]);
+  }
+  throw new Error(`Unsupported data page encoding ${encoding}`);
+}
+
+function readColumn(fileBuf, columnChunk, schemaCol) {
+  const meta = columnChunk[3];
+  const type = meta[1];
+  const codec = meta[4];
+  const totalValues = meta[5];
+  let pos = meta[11] ?? meta[9];
+  const end = pos + meta[7];
+  let dictionary = null;
+  const values = [];
+  while (pos < end && values.length < totalValues) {
+    const { header, next } = parsePageHeader(fileBuf, pos);
+    const pageType = header[1];
+    const uncompressed = header[2];
+    const compressed = header[3];
+    const compressedPayload = fileBuf.subarray(next, next + compressed);
+    const payload = maybeDecompress(codec, compressedPayload, uncompressed);
+    if (pageType === 2) {
+      const dh = header[7];
+      const num = dh[1];
+      const enc = dh[2];
+      if (enc !== 0) throw new Error(`Unsupported dictionary encoding ${enc} for ${schemaCol.name}`);
+      dictionary = decodePlain(type, payload, num);
+    } else if (pageType === 0) {
+      const dph = header[5];
+      const num = dph[1];
+      const enc = dph[2];
+      values.push(...decodeDataPage(type, enc, payload, num, dictionary));
+    } else if (pageType === 3) {
+      throw new Error('DATA_PAGE_V2 is not implemented');
+    }
+    pos = next + compressed;
+  }
+  if (values.length !== totalValues) {
+    throw new Error(`Column ${schemaCol.name} decoded ${values.length} values, expected ${totalValues}`);
+  }
+  return values;
+}
+
+function loadParquet(path) {
+  const fileBuf = fs.readFileSync(path);
+  const meta = parseFileMetadata(fileBuf);
+  const cols = schemaColumns(meta);
+  const rowGroup = meta[4][0];
+  const chunks = rowGroup[1];
+  const out = {};
+  cols.forEach((col, i) => {
+    out[col.name] = readColumn(fileBuf, chunks[i], col);
+  });
+  return { data: out, n: meta[3], columns: cols.map(c => c.name) };
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function variance(arr) {
+  const m = mean(arr);
+  let s = 0;
+  for (const v of arr) {
+    const d = v - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromT(t) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(t)))));
+}
+
+function transpose(A) {
+  return A[0].map((_, i) => A.map(r => r[i]));
+}
+
+function matMul(A, B) {
+  const rows = A.length, inner = B.length, cols = B[0].length;
+  const out = Array.from({ length: rows }, () => Array(cols).fill(0));
+  for (let i = 0; i < rows; i++) {
+    for (let k = 0; k < inner; k++) {
+      const aik = A[i][k];
+      if (aik === 0) continue;
+      for (let j = 0; j < cols; j++) out[i][j] += aik * B[k][j];
+    }
+  }
+  return out;
+}
+
+function matVec(A, v) {
+  return A.map(r => r.reduce((s, x, i) => s + x * v[i], 0));
+}
+
+function inverse(A) {
+  const n = A.length;
+  const M = A.map((row, i) => row.concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[pivot][i])) pivot = r;
+    if (Math.abs(M[pivot][i]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== i) [M[i], M[pivot]] = [M[pivot], M[i]];
+    const div = M[i][i];
+    for (let j = 0; j < 2 * n; j++) M[i][j] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      if (f === 0) continue;
+      for (let j = 0; j < 2 * n; j++) M[r][j] -= f * M[i][j];
+    }
+  }
+  return M.map(row => row.slice(n));
+}
+
+function ols(y, X) {
+  const Xt = transpose(X);
+  const XtX = matMul(Xt, X);
+  const XtXInv = inverse(XtX);
+  const Xty = matVec(Xt, y);
+  const beta = matVec(XtXInv, Xty);
+  const n = y.length, p = beta.length;
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += X[i][j] * beta[j];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const se = XtXInv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const t = beta.map((b, i) => b / se[i]);
+  const pvals = t.map(pFromT);
+  return { beta, se, t, p: pvals, rss, df: n - p };
+}
+
+function buildMatrix(df, specs) {
+  const n = df.pfs_months.length;
+  const X = Array.from({ length: n }, () => [1]);
+  const names = ['Intercept'];
+  for (const spec of specs) {
+    names.push(spec.name);
+    for (let i = 0; i < n; i++) X[i].push(spec.fn(i));
+  }
+  return { X, names };
+}
+
+function adjustedModel(df, extraSpecs = []) {
+  const base = [
+    { name: 'age_years_per_10', fn: i => df.age_years[i] / 10 },
+    { name: 'sex_female', fn: i => +df.sex_female[i] },
+    { name: 'stage_iv', fn: i => +df.stage_iv[i] },
+    { name: 'has_brain_mets', fn: i => +df.has_brain_mets[i] },
+    { name: 'albumin_g_dl', fn: i => df.albumin_g_dl[i] },
+    { name: 'ldh_per_100', fn: i => df.ldh_u_l[i] / 100 },
+    { name: 'weight_loss_pct_6mo', fn: i => df.weight_loss_pct_6mo[i] },
+    { name: 'crp_per_10', fn: i => df.crp_mg_l[i] / 10 },
+    { name: 'nlr', fn: i => df.nlr[i] },
+    { name: 'ecog_1', fn: i => df.ecog_ps[i] === 1 ? 1 : 0 },
+    { name: 'ecog_2', fn: i => df.ecog_ps[i] === 2 ? 1 : 0 },
+    { name: 'ecog_3', fn: i => df.ecog_ps[i] === 3 ? 1 : 0 },
+    { name: 'histology_squamous', fn: i => df.histology[i] === 'squamous' ? 1 : 0 },
+    { name: 'histology_large_cell', fn: i => df.histology[i] === 'large_cell' ? 1 : 0 },
+    { name: 'smoking_former', fn: i => df.smoking_status[i] === 'former' ? 1 : 0 },
+    { name: 'smoking_current', fn: i => df.smoking_status[i] === 'current' ? 1 : 0 }
+  ];
+  const { X, names } = buildMatrix(df, base.concat(extraSpecs));
+  return { ...ols(df.pfs_months, X), names };
+}
+
+function idxByName(model, name) {
+  const idx = model.names.indexOf(name);
+  if (idx < 0) throw new Error(`Term not found: ${name}`);
+  return idx;
+}
+
+function term(model, name) {
+  const i = idxByName(model, name);
+  return { beta: model.beta[i], se: model.se[i], p: model.p[i], t: model.t[i] };
+}
+
+function groupMeanDiff(df, maskA, maskB) {
+  const a = [], b = [];
+  for (let i = 0; i < df.pfs_months.length; i++) {
+    if (maskA(i)) a.push(df.pfs_months[i]);
+    if (maskB(i)) b.push(df.pfs_months[i]);
+  }
+  const ma = mean(a), mb = mean(b);
+  const va = variance(a), vb = variance(b);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const t = (ma - mb) / se;
+  return { diff: ma - mb, p: pFromT(t), nA: a.length, nB: b.length, meanA: ma, meanB: mb };
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) > 0 && Math.abs(x) < 1e-4) return x.toExponential(2);
+  return x.toFixed(digits);
+}
+
+function pval(x) {
+  if (x === 0) return 0;
+  return Number(x.toPrecision(6));
+}
+
+function rec(hypothesis_ids, effect, p, summary, code) {
+  return {
+    hypothesis_ids,
+    code,
+    result_summary: summary,
+    p_value: pval(p),
+    effect_estimate: Number(effect.toFixed(6)),
+    significant: p < 0.05
+  };
+}
+
+function writeOutputs(transcript, summary) {
+  fs.writeFileSync('transcript.json', JSON.stringify(transcript, null, 2));
+  fs.writeFileSync('analysis_summary.txt', summary);
+}
