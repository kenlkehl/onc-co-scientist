+
+function bitWidthFor(maxValue) {
+  if (maxValue <= 0) return 0;
+  return Math.ceil(Math.log2(maxValue + 1));
+}
+
+function decodePlain(type, buf, count) {
+  const br = new ByteReader(buf);
+  const vals = [];
+  for (let i = 0; i < count; i++) {
+    if (type === 0) vals.push(!!br.u8());
+    else if (type === 1) vals.push(br.i32le());
+    else if (type === 2) vals.push(br.i64le());
+    else if (type === 3) vals.push(br.f32le());
+    else if (type === 4) vals.push(br.f64le());
+    else if (type === 6) {
+      const len = br.u32le();
+      vals.push(br.bytes(len).toString('utf8'));
