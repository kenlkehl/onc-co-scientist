+  addIter(22, [h22], [rec([h22.id], trm.beta, trm.p, `Adjusted OLS estimated ${fmt(trm.beta)} PFS months per 1 g/dL higher albumin_g_dl (SE ${fmt(trm.se)}, p=${fmt(trm.p)}).`, 'adjusted OLS: pfs_months ~ albumin_g_dl + treatments + biomarkers + clinical covariates')]);
