+  for (const spec of specs) {
+    names.push(spec.name);
+    for (let i = 0; i < n; i++) X[i].push(spec.fn(i));
+  }
+  return { X, names };
+}
+
+function adjustedModel(df, extraSpecs = []) {
+  const base = [
+    { name: 'age_years_per_10', fn: i => df.age_years[i] / 10 },
+    { name: 'sex_female', fn: i => +df.sex_female[i] },
+    { name: 'stage_iv', fn: i => +df.stage_iv[i] },
+    { name: 'has_brain_mets', fn: i => +df.has_brain_mets[i] },
+    { name: 'albumin_g_dl', fn: i => df.albumin_g_dl[i] },
+    { name: 'ldh_per_100', fn: i => df.ldh_u_l[i] / 100 },
+    { name: 'weight_loss_pct_6mo', fn: i => df.weight_loss_pct_6mo[i] },
+    { name: 'crp_per_10', fn: i => df.crp_mg_l[i] / 10 },
+    { name: 'nlr', fn: i => df.nlr[i] },
+    { name: 'ecog_1', fn: i => df.ecog_ps[i] === 1 ? 1 : 0 },
+    { name: 'ecog_2', fn: i => df.ecog_ps[i] === 2 ? 1 : 0 },
+    { name: 'histology_squamous', fn: i => df.histology[i] === 'squamous' ? 1 : 0 },
+    { name: 'smoking_former', fn: i => df.smoking_status[i] === 'former' ? 1 : 0 },
+    { name: 'smoking_current', fn: i => df.smoking_status[i] === 'current' ? 1 : 0 }
+  ];
+  const { X, names } = buildMatrix(df, base.concat(extraSpecs));
+  return { ...ols(df.pfs_months, X), names };
+}
+
+function idxByName(model, name) {
+  const idx = model.names.indexOf(name);
+  if (idx < 0) throw new Error(`Term not found: ${name}`);
+  return idx;
+}
+
+function term(model, name) {
+  const i = idxByName(model, name);
+  return { beta: model.beta[i], se: model.se[i], p: model.p[i], t: model.t[i] };
+}
+
+function groupMeanDiff(df, maskA, maskB) {
+  const a = [], b = [];
+  for (let i = 0; i < df.pfs_months.length; i++) {
+    if (maskA(i)) a.push(df.pfs_months[i]);
+    if (maskB(i)) b.push(df.pfs_months[i]);
+  }
+  const ma = mean(a), mb = mean(b);
+  const va = variance(a), vb = variance(b);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const t = (ma - mb) / se;
+  return { diff: ma - mb, p: pFromT(t), nA: a.length, nB: b.length, meanA: ma, meanB: mb };
+}
+
+function fmt(x, digits = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) > 0 && Math.abs(x) < 1e-4) return x.toExponential(2);
+  return x.toFixed(digits);
+}
+
+function pval(x) {
+  if (x === 0) return 0;
+  return Number(x.toPrecision(6));
+}
+
+function rec(hypothesis_ids, effect, p, summary, code) {
+  return {
+    hypothesis_ids,
+    code,
+    result_summary: summary,
+    p_value: pval(p),
+    effect_estimate: Number(effect.toFixed(6)),
+    significant: p < 0.05
+  };
+}
+
+function writeOutputs(transcript, summary) {
