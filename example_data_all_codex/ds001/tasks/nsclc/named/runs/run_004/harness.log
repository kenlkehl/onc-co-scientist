+function readColumn(fileBuf, columnChunk, schemaCol) {
+  const meta = columnChunk[3];
+  const type = meta[1];
+  const codec = meta[4];
+  const totalValues = meta[5];
+  let pos = meta[11] ?? meta[9];
+  const end = pos + meta[7];
