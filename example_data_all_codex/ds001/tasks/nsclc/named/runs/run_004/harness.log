+class CompactReader {
+  constructor(buf, pos = 0, end = buf.length) {
+    this.buf = buf;
+    this.pos = pos;
+    this.end = end;
+  }
+  byte() {
+    if (this.pos >= this.end) throw new Error('Unexpected EOF');
+    return this.buf[this.pos++];
+  }
+  varint() {
+    let shift = 0;
+    let result = 0;
+    while (true) {
+      const b = this.byte();
+      result += (b & 0x7f) * Math.pow(2, shift);
+      if ((b & 0x80) === 0) return result;
+      shift += 7;
+    }
+  }
+  zigzag() {
+    const n = this.varint();
+    return (n % 2 === 0) ? n / 2 : -(n + 1) / 2;
+  }
+  i16() { return this.zigzag(); }
+  i32() { return this.zigzag(); }
+  i64() { return this.zigzag(); }
+  binary() {
+    const len = this.varint();
+    const start = this.pos;
+    this.pos += len;
+    return this.buf.subarray(start, start + len);
+  }
+  str() {
+    return this.binary().toString('utf8');
+  }
+  double() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  list() {
+    const hdr = this.byte();
+    let size = hdr >> 4;
+    const type = hdr & 0x0f;
+    if (size === 15) size = this.varint();
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(this.value(type));
+    return arr;
+  }
+  value(type) {
+    switch (type) {
+      case 1: return true;
+      case 2: return false;
+      case 3: return this.byte();
+      case 4: return this.i16();
+      case 5: return this.i32();
+      case 6: return this.i64();
+      case 7: return this.double();
+      case 8: return this.str();
+      case 9: return this.list();
+      case 12: return this.struct();
+      default:
+        throw new Error(`Unsupported compact thrift type ${type} at ${this.pos}`);
+    }
+  }
+  struct() {
+    const out = {};
+    let last = 0;
+    while (true) {
+      const hdr = this.byte();
+      const type = hdr & 0x0f;
+      if (type === 0) break;
+      const delta = hdr >> 4;
+      const field = delta === 0 ? this.i16() : last + delta;
