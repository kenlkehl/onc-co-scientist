+function readBitPacked(br, count, bitWidth) {
+  if (bitWidth === 0) return Array(count).fill(0);
+  const vals = [];
+  let bitBuffer = 0;
+  let bits = 0;
+  const mask = (1 << bitWidth) - 1;
+  while (vals.length < count) {
+    if (bits < bitWidth) {
+      bitBuffer |= br.u8() << bits;
+      bits += 8;
+    } else {
+      vals.push(bitBuffer & mask);
+      bitBuffer >>= bitWidth;
+      bits -= bitWidth;
+    }
+  }
