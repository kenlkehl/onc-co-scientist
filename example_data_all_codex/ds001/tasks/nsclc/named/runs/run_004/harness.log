+  lines.push(`Pembrolizumab showed an independent positive association with PFS: the adjusted main effect was ${fmt(term(mainModel, 'treatment_pembrolizumab').beta)} months (p=${fmt(term(mainModel, 'treatment_pembrolizumab').p)}). PD-L1 was also favorable, with ${fmt(term(mainModel, 'pdl1_tps_per_50').beta)} months per 50-point increase (p=${fmt(term(mainModel, 'pdl1_tps_per_50').p)}). The pembrolizumab-by-PD-L1 interaction was positive (${fmt(iterations[2].analyses[0].effect_estimate)} months per 50 points, p=${fmt(iterations[2].analyses[0].p_value)}), and subgroup testing supported larger benefit in PD-L1-high disease: ${fmt(g4.diff)} months for pdl1_tps >= 50 versus ${fmt(g5.diff)} months for pdl1_tps < 1, both significant.`);
