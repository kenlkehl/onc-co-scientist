+
+function parseFileMetadata(fileBuf) {
+  if (fileBuf.subarray(0, 4).toString('ascii') !== 'PAR1') throw new Error('Not a parquet file');
+  const trailerMagic = fileBuf.subarray(fileBuf.length - 4).toString('ascii');
+  if (trailerMagic !== 'PAR1') throw new Error('Bad parquet trailer');
+  const metaLen = fileBuf.readUInt32LE(fileBuf.length - 8);
+  const start = fileBuf.length - 8 - metaLen;
+  return new CompactReader(fileBuf, start, start + metaLen).struct();
+}
+
+function schemaColumns(meta) {
+  const schema = meta[2];
+  return schema.slice(1).map((s, i) => ({
+    index: i,
+    name: s[4],
+    type: s[1],
+    converted: s[6] ?? null,
+    logical: s[10] ?? null
+  }));
+}
