+  lines.push("The strongest prognostic patterns were clinical rather than broad targeted-therapy effects: older age was associated with longer PFS, female sex with shorter PFS, and higher ECOG performance status, stage IV disease, brain metastases, weight loss, squamous histology, current smoking, low albumin, high LDH, and heart failure were adverse. Several plausible markers were refuted or weak in adjusted models, including liver metastases, bone metastases, CRP, NLR, hemoglobin, alkaline phosphatase, sodium, calcium, COPD, chronic kidney disease, interstitial lung disease history, most rare driver alterations, and the osimertinib and olaparib biomarker interactions.");
+  fs.writeFileSync("analysis_summary.txt", lines.join("\n"));
+
+  console.log(JSON.stringify({ rows: n, iterations: iterations.length, files: ["transcript.json", "analysis_summary.txt"] }, null, 2));
+}
