+    code: modelLabel,
+    result_summary: `${coef}: effect ${c.beta.toFixed(3)} months, SE ${c.se.toFixed(3)}, z ${c.z.toFixed(2)}, p=${formatP(c.p)}. ${extra}`.trim(),
+    p_value: c.p,
+    effect_estimate: Number(c.beta.toFixed(6)),
+    significant: c.p < 0.05,
+  });
+}
+
+function addDirectAnalysis(iter, ids, label, effect, p, summary) {
+  iter.analyses.push({
+    hypothesis_ids: ids,
+    code: label,
+    result_summary: summary,
+    p_value: p,
+    effect_estimate: Number(effect.toFixed(6)),
+    significant: p < 0.05,
+  });
+}
