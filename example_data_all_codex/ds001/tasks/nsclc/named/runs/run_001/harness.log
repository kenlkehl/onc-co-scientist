+function parseMetadata(buf) {
+  const metaLen = buf.readUInt32LE(buf.length - 8);
+  return new CompactReader(buf, buf.length - 8 - metaLen, buf.length - 8).readStruct(FileMeta);
+}
+
+function decodePlainValues(data, type, count) {
+  const out = [];
+  let pos = 0;
+  for (let i = 0; i < count; i++) {
+    if (type === 5) {
+      out.push(data.readDoubleLE(pos));
+      pos += 8;
+    } else if (type === 2) {
+      out.push(Number(data.readBigInt64LE(pos)));
+      pos += 8;
+    } else if (type === 1) {
+      out.push(data.readInt32LE(pos));
+      pos += 4;
+    } else if (type === 6) {
+      const len = data.readInt32LE(pos);
+      pos += 4;
+      out.push(data.slice(pos, pos + len).toString("utf8"));
+      pos += len;
+    } else {
+      throw new Error(`Unsupported plain type ${type}`);
+    }
+  }
+  return out;
