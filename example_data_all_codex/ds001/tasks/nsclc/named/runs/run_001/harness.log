+  let outPos = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let litLen = tag >> 2;
+      if (litLen < 60) {
+        litLen += 1;
+      } else {
