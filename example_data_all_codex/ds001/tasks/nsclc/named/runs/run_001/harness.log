+function bitWidth(n) {
+  let w = 0;
+  while ((1 << w) < n) w++;
+  return w;
+}
+
+function readHybrid(buf, width, count) {
+  const values = [];
+  let pos = 0;
+  function readVarintLocal() {
+    let shift = 0;
+    let result = 0;
+    while (true) {
+      const b = buf[pos++];
+      result |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  while (values.length < count && pos < buf.length) {
+    const header = readVarintLocal();
+    if ((header & 1) === 0) {
+      const runLen = header >> 1;
+      let v = 0;
+      const bytes = Math.ceil(width / 8);
+      for (let i = 0; i < bytes; i++) v |= buf[pos++] << (8 * i);
+      for (let i = 0; i < runLen && values.length < count; i++) values.push(v);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      let bitPos = 0;
+      const byteStart = pos;
+      for (let i = 0; i < total && values.length < count; i++) {
+        let v = 0;
+        for (let b = 0; b < width; b++) {
+          const abs = byteStart * 8 + bitPos++;
+          const bit = (buf[Math.floor(abs / 8)] >> (abs % 8)) & 1;
+          v |= bit << b;
+        }
+        values.push(v);
+      }
+      pos = byteStart + Math.ceil((total * width) / 8);
+    }
