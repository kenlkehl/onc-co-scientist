+class CompactReader {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.pos = offset;
+    this.end = end;
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
