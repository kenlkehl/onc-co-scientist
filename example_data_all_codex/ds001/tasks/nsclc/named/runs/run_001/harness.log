+  const type = md.type;
+  let pos = md.dictionary_page_offset || md.data_page_offset;
+  let dict = null;
+  const out = [];
+  while (out.length < md.num_values) {
+    const reader = new CompactReader(buf, pos);
+    const ph = reader.readStruct(PageHeader);
+    const headerEnd = reader.pos;
+    const comp = buf.slice(headerEnd, headerEnd + ph.compressed_page_size);
+    const page = md.codec === 1 ? snappyUncompress(comp) : comp;
+    pos = headerEnd + ph.compressed_page_size;
+    if (ph.type === 2) {
+      dict = decodePlainValues(page, type, ph.dictionary_page_header.num_values);
+      continue;
+    }
+    if (ph.type !== 0 && ph.type !== 3) throw new Error(`Unsupported page type ${ph.type}`);
+    if (!dict) throw new Error(`Missing dictionary for ${md.path_in_schema.join(".")}`);
+    const header = ph.data_page_header || ph.data_page_header_v2;
+    let valueData;
+    const n = header.num_values;
+    if (ph.type === 0) {
+      let p = 0;
+      const defLen = page.readUInt32LE(p);
+      p += 4 + defLen;
+      valueData = page.slice(p);
+    } else {
+      const defLen = header.definition_levels_byte_length || 0;
+      const repLen = header.repetition_levels_byte_length || 0;
+      valueData = page.slice(defLen + repLen);
+    }
+    const w = valueData[0];
+    const idx = readHybrid(valueData.slice(1), w, n);
+    for (const ix of idx) out.push(dict[ix]);
+  }
+  return out;
+}
+
+function readParquet(file) {
+  const buf = fs.readFileSync(file);
+  const meta = parseMetadata(buf);
+  const rg = meta.row_groups[0];
+  const data = {};
+  for (const chunk of rg.columns) {
+    const name = chunk.meta_data.path_in_schema.join(".");
+    data[name] = decodeColumn(buf, chunk);
+  }
+  return { meta, data };
+}
+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (!mask || mask(i)) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function count(mask, n) {
+  let c = 0;
+  for (let i = 0; i < n; i++) if (mask(i)) c++;
+  return c;
+}
+
+function erf(x) {
+  const sign = x >= 0 ? 1 : -1;
+  const ax = Math.abs(x);
+  const t = 1 / (1 + 0.3275911 * ax);
+  const y = 1 - (((((1.061405429 * t - 1.453152027) * t) + 1.421413741) * t - 0.284496736) * t + 0.254829592) * t * Math.exp(-ax * ax);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function pFromZ(z) {
+  const az = Math.abs(z);
+  if (az > 37) return 0;
+  return Math.max(0, 2 * (1 - normalCdf(az)));
+}
+
+function solveLinear(A, b) {
+  const n = A.length;
+  const M = A.map((row, i) => row.slice().concat([b[i]]));
+  for (let col = 0; col < n; col++) {
+    let pivot = col;
+    for (let r = col + 1; r < n; r++) if (Math.abs(M[r][col]) > Math.abs(M[pivot][col])) pivot = r;
+    if (Math.abs(M[pivot][col]) < 1e-12) throw new Error("Singular matrix");
+    [M[col], M[pivot]] = [M[pivot], M[col]];
+    const div = M[col][col];
+    for (let c = col; c <= n; c++) M[col][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === col) continue;
+      const factor = M[r][col];
+      for (let c = col; c <= n; c++) M[r][c] -= factor * M[col][c];
+    }
+  }
+  return M.map(row => row[n]);
+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const inv = [];
+  for (let j = 0; j < n; j++) {
+    const e = Array(n).fill(0);
+    e[j] = 1;
+    inv.push(solveLinear(A, e));
+  }
+  const out = Array.from({ length: n }, () => Array(n).fill(0));
+  for (let j = 0; j < n; j++) for (let i = 0; i < n; i++) out[i][j] = inv[j][i];
+  return out;
+}
+
+function ols(y, xFns, options = {}) {
+  const names = ["Intercept"].concat(xFns.map(x => x.name));
+  const p = names.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let n = 0;
+  let ySum = 0;
+  const rows = [];
+  for (let i = 0; i < y.length; i++) {
+    if (options.mask && !options.mask(i)) continue;
+    const row = [1];
+    let ok = true;
+    for (const fn of xFns) {
+      const v = fn.f(i);
+      if (!Number.isFinite(v)) ok = false;
+      row.push(v);
+    }
+    if (!ok || !Number.isFinite(y[i])) continue;
+    rows.push([row, y[i]]);
+    n++;
+    ySum += y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const beta = solveLinear(xtx, xty);
+  let sse = 0;
+  let tss = 0;
+  const yMean = ySum / n;
+  for (const [row, yi] of rows) {
+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += row[j] * beta[j];
+    const resid = yi - pred;
+    sse += resid * resid;
+    tss += (yi - yMean) * (yi - yMean);
+  }
+  const sigma2 = sse / (n - p);
+  const inv = invertMatrix(xtx);
+  const se = beta.map((_, j) => Math.sqrt(Math.max(0, sigma2 * inv[j][j])));
+  const coefs = {};
+  for (let j = 0; j < p; j++) {
+    const z = beta[j] / se[j];
+    coefs[names[j]] = { beta: beta[j], se: se[j], z, p: pFromZ(z) };
+  }
+  return { n, p, coefs, r2: 1 - sse / tss };
+}
+
+function fn(name, f) {
+  return { name, f };
+}
+
+function binary(data, name) {
+  return fn(name, i => Number(data[name][i]));
+}
+
+function continuous(data, name, scale = 1) {
+  return fn(name, i => Number(data[name][i]) / scale);
+}
+
+function eq(data, name, value, outName = `${name}_${value}`) {
+  return fn(outName, i => data[name][i] === value ? 1 : 0);
+}
+
+function interaction(name, a, b) {
+  return fn(name, i => a.f(i) * b.f(i));
+}
