+  addHyp(iter, "h1", "Patients receiving `treatment_pembrolizumab` have higher mean `pfs_months` than patients not receiving `treatment_pembrolizumab`.");
+  addHyp(iter, "h2", "Patients receiving `treatment_sotorasib` have higher mean `pfs_months` than patients not receiving `treatment_sotorasib`.");
+  addHyp(iter, "h3", "Patients receiving `treatment_olaparib` have higher mean `pfs_months` than patients not receiving `treatment_olaparib`.");
+  addHyp(iter, "h4", "Patients receiving `treatment_osimertinib` have higher mean `pfs_months` than patients not receiving `treatment_osimertinib`.");
