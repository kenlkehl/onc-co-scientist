+  const p = names.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let n = 0;
+  let ySum = 0;
+  const rows = [];
+  for (let i = 0; i < y.length; i++) {
+    if (options.mask && !options.mask(i)) continue;
+    const row = [1];
+    let ok = true;
+    for (const fn of xFns) {
+      const v = fn.f(i);
+      if (!Number.isFinite(v)) ok = false;
+      row.push(v);
+    }
+    if (!ok || !Number.isFinite(y[i])) continue;
+    rows.push([row, y[i]]);
+    n++;
+    ySum += y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
