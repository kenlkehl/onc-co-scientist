+        litLen = 1;
+        let extra = 0;
+        for (let i = 0; i < n; i++) extra |= input[pos++] << (8 * i);
+        litLen += extra;
+      }
+      input.copy(out, outPos, pos, pos + litLen);
+      pos += litLen;
+      outPos += litLen;
+    } else {
+      let copyLen, offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
