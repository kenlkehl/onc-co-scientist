+class CompactReader {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.pos = offset;
+    this.end = end;
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
