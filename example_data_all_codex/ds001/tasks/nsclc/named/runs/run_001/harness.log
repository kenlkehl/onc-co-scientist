class CompactReader {
  constructor(buf, offset=0, end=buf.length){this.buf=buf; this.pos=offset; this.end=end;}
  readByte(){return this.buf[this.pos++];}
  readVarint(){let shift=0, result=0n; while(true){const b=this.readByte(); result |= BigInt(b & 0x7f) << BigInt(shift); if((b&0x80)===0) break; shift += 7;} return result;}
  readZigZag(){const n=this.readVarint(); return Number((n >> 1n) "'^ (-(n & 1n)));}
  readZigZagBig(){const n=this.readVarint(); return (n >> 1n) ''^ (-(n & 1n));}
  readDouble(){const v=this.buf.readDoubleLE(this.pos); this.pos+=8; return v;}
  readBinary(){const len=Number(this.readVarint()); const s=this.buf.slice(this.pos, this.pos+len); this.pos+=len; return s;}
  skipType(t){
    if(t===1 || t===2) return; // bool payload in header
    if(t===3) {this.pos++; return;}
    if(t===4 || t===5) {this.readZigZag(); return;}
    if(t===6) {this.readZigZagBig(); return;}
    if(t===7) {this.pos+=8; return;}
    if(t===8) {this.readBinary(); return;}
    if(t===9 || t===10) {const h=this.readByte(); let size=h>>4; const et=h&0xf; if(size===15) size=Number(this.readVarint()); for(let i=0;i<size;i++) this.skipType(et); return;}
    if(t===11) {const size=Number(this.readVarint()); if(size===0) return; const kt=this.readByte()&0xf; const vt=this.readByte()&0xf; for(let i=0;i<size;i++){this.skipType(kt); this.skipType(vt);} return;}
    if(t===12) {this.readStruct({}); return;}
    throw new Error('"'skip unknown type '+t+' at '+this.pos);
  }
  readValue(t, spec){
    if(t===1) return true;
    if(t===2) return false;
    if(t===3) return this.readByte();
    if(t===4 || t===5) return this.readZigZag();
    if(t===6) {const x=this.readZigZagBig(); return (x<=BigInt(Number.MAX_SAFE_INTEGER)&&x>=BigInt(Number.MIN_SAFE_INTEGER)) ? Number(x) : x.toString();}
    if(t===7) return this.readDouble();
    if(t===8) return this.readBinary().toString('utf8');
    if(t===9 || t===10) {const h=this.readByte(); let size=h>>4; const et=h&0xf; if(size===15) size=Number(this.readVarint()); const arr=[]; const elemSpec=spec && spec.elem; for(let i=0;i<size;i++) arr.push(this.readValue(et, elemSpec)); return arr;}
