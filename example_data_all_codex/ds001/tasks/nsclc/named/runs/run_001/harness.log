+    let pred = 0;
+    for (let j = 0; j < p; j++) pred += row[j] * beta[j];
+    const resid = yi - pred;
+    sse += resid * resid;
+    tss += (yi - yMean) * (yi - yMean);
+  }
+  const sigma2 = sse / (n - p);
+  const inv = invertMatrix(xtx);
+  const se = beta.map((_, j) => Math.sqrt(Math.max(0, sigma2 * inv[j][j])));
+  const coefs = {};
+  for (let j = 0; j < p; j++) {
+    const z = beta[j] / se[j];
+    coefs[names[j]] = { beta: beta[j], se: se[j], z, p: pFromZ(z) };
+  }
+  return { n, p, coefs, r2: 1 - sse / tss };
