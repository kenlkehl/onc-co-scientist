+const fs = require("fs");
+
+const DATASET = "dataset.parquet";
+
+class CompactReader {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.pos = offset;
+    this.end = end;
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarint() {
+    let shift = 0;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << BigInt(shift);
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    return result;
+  }
+  readZigZag() {
+    const n = this.readVarint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  readZigZagBig() {
+    const n = this.readVarint();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return out;
+  }
+  readValue(type, spec = {}) {
+    if (type === 1) return true;
+    if (type === 2) return false;
+    if (type === 3) return this.readByte();
+    if (type === 4 || type === 5) return this.readZigZag();
+    if (type === 6) {
+      const v = this.readZigZagBig();
+      if (v <= BigInt(Number.MAX_SAFE_INTEGER) && v >= BigInt(Number.MIN_SAFE_INTEGER)) {
+        return Number(v);
+      }
+      return v.toString();
+    }
+    if (type === 7) return this.readDouble();
+    if (type === 8) return this.readBinary().toString("utf8");
+    if (type === 9 || type === 10) {
+      const h = this.readByte();
+      let size = h >> 4;
+      const elemType = h & 0x0f;
+      if (size === 15) size = Number(this.readVarint());
+      const arr = [];
+      for (let i = 0; i < size; i++) arr.push(this.readValue(elemType, spec.elem || {}));
+      return arr;
+    }
+    if (type === 11) {
+      const size = Number(this.readVarint());
+      const obj = {};
+      if (size === 0) return obj;
+      const types = this.readByte();
+      const keyType = types >> 4;
+      const valType = types & 0x0f;
+      for (let i = 0; i < size; i++) obj[this.readValue(keyType)] = this.readValue(valType);
+      return obj;
+    }
+    if (type === 12) return this.readStruct(spec);
+    throw new Error(`Unknown compact type ${type} at ${this.pos}`);
+  }
+  readStruct(spec = {}) {
+    const obj = {};
+    let lastField = 0;
+    while (true) {
+      const header = this.readByte();
+      if (header === 0) break;
+      const delta = header >> 4;
+      const type = header & 0x0f;
+      const fieldId = delta === 0 ? this.readZigZag() : lastField + delta;
+      lastField = fieldId;
+      const fieldSpec = spec[fieldId] || { name: String(fieldId) };
+      obj[fieldSpec.name] = this.readValue(type, fieldSpec);
+    }
+    return obj;
+  }
+}
