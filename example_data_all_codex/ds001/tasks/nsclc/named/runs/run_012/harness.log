"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs = require('fs');
const b = fs.readFileSync('dataset.parquet');
class TCompact { constructor(buf, pos=0){this.buf=buf;this.pos=pos;this.stack=[];this.lastField=0;} readByte(){return this.buf[this.pos++];} readVarint(){let shift=0,n=0;while(true){let x=this.readByte();n+=(x&0x7f)*Math.pow(2,shift);if((x&0x80)===0)break;shift+=7;}return n;} zigzag(n){return (n>>>1)"'^-(n&1);} readI16(){return this.zigzag(this.readVarint());} readI32(){return this.zigzag(this.readVarint());} readI64(){return this.zigzag(this.readVarint());} readBinary(){let len=this.readVarint();let s=this.buf.subarray(this.pos,this.pos+len);this.pos+=len;return s;} readString(){return this.readBinary().toString('"'utf8');} readFieldBegin(){let h=this.readByte();let type=h&15;if(type===0)return{type,id:0};let delta=h>>4;let id;if(delta===0)id=this.readI16();else id=this.lastField+delta;this.lastField=id;return{type,id};} readStruct(fn){this.stack.push(this.lastField);this.lastField=0;let out=fn();this.lastField=this.stack.pop();return out;} readListBegin(){let h=this.readByte();let size=h>>4,etype=h&15;if(size===15)size=this.readVarint();return{size,etype};} skip(type){switch(type){case 1:case 2:return;case 3:this.pos++;return;case 4:this.readI16();return;case 5:this.readI32();return;case 6:this.readI64();return;case 7:this.pos+=8;return;case 8:this.readBinary();return;case 9:case 10:{let l=this.readListBegin();for(let i=0;i<l.size;i++)this.skip(l.etype);return;}case 11:{let sz=this.readVarint();if(sz>0){let ktvt=this.readByte(),kt=(ktvt>>4)&15,vt=ktvt&15;for(let i=0;i<sz;i++){this.skip(kt);this.skip(vt);}}return;}case 12:this.readStruct(()=>{while(true){let f=this.readFieldBegin();if(f.type===0)break;this.skip(f.type);}});return;default:throw Error('skip '+type+' at '+this.pos);}}}
function readSchemaElement(t){return t.readStruct(()=>{let o={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 1:o.type=t.readI32();break;case 3:o.repetition_type=t.readI32();break;case 4:o.name=t.readString();break;case 5:o.num_children=t.readI32();break;case 6:o.converted_type=t.readI32();break;default:t.skip(f.type);}}return o;});}
function readColumnMeta(t){return t.readStruct(()=>{let o={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 1:o.type=t.readI32();break;case 2:{let l=t.readListBegin();o.encodings=[];for(let i=0;i<l.size;i++)o.encodings.push(t.readI32());break;}case 3:{let l=t.readListBegin();o.path_in_schema=[];for(let i=0;i<l.size;i++)o.path_in_schema.push(t.readString());break;}case 4:o.codec=t.readI32();break;case 5:o.num_values=t.readI64();break;case 6:o.total_uncompressed_size=t.readI64();break;case 7:o.total_compressed_size=t.readI64();break;case 9:o.data_page_offset=t.readI64();break;case 11:o.dictionary_page_offset=t.readI64();break;default:t.skip(f.type);}}return o;});}
function readColumnChunk(t){return t.readStruct(()=>{let o={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 3:o.meta_data=readColumnMeta(t);break;default:t.skip(f.type);}}return o;});}
function readRowGroup(t){return t.readStruct(()=>{let o={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 1:{let l=t.readListBegin();o.columns=[];for(let i=0;i<l.size;i++)o.columns.push(readColumnChunk(t));break;}case 3:o.num_rows=t.readI64();break;default:t.skip(f.type);}}return o;});}
function readFileMeta(t){return t.readStruct(()=>{let o={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 2:{let l=t.readListBegin();o.schema=[];for(let i=0;i<l.size;i++)o.schema.push(readSchemaElement(t));break;}case 3:o.num_rows=t.readI64();break;case 4:{let l=t.readListBegin();o.row_groups=[];for(let i=0;i<l.size;i++)o.row_groups.push(readRowGroup(t));break;}default:t.skip(f.type);}}return o;});}
function readPageHeaderAt(pos){let t=new TCompact(b,pos);let o=t.readStruct(()=>{let ph={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 1:ph.type=t.readI32();break;case 2:ph.uncompressed_page_size=t.readI32();break;case 3:ph.compressed_page_size=t.readI32();break;case 5:ph.data_page_header=readDataPageHeader(t);break;case 7:ph.dictionary_page_header=readDictPageHeader(t);break;case 8:ph.data_page_header_v2=readDataPageHeaderV2(t);break;default:t.skip(f.type);}}return ph;});o.headerLen=t.pos-pos;o.dataStart=t.pos;return o;}
function readDataPageHeader(t){return t.readStruct(()=>{let o={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 1:o.num_values=t.readI32();break;case 2:o.encoding=t.readI32();break;case 3:o.definition_level_encoding=t.readI32();break;case 4:o.repetition_level_encoding=t.readI32();break;default:t.skip(f.type);}}return o;});}
function readDictPageHeader(t){return t.readStruct(()=>{let o={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 1:o.num_values=t.readI32();break;case 2:o.encoding=t.readI32();break;case 3:o.is_sorted=f.type===1?true:f.type===2?false:(t.skip(f.type),undefined);break;default:t.skip(f.type);}}return o;});}
function readDataPageHeaderV2(t){return t.readStruct(()=>{let o={};while(true){let f=t.readFieldBegin();if(f.type===0)break;switch(f.id){case 1:o.num_values=t.readI32();break;case 2:o.num_nulls=t.readI32();break;case 3:o.num_rows=t.readI32();break;case 4:o.encoding=t.readI32();break;case 5:o.definition_levels_byte_length=t.readI32();break;case 6:o.repetition_levels_byte_length=t.readI32();break;case 7:o.is_compressed=f.type===1?true:f.type===2?false:(t.skip(f.type),undefined);break;default:t.skip(f.type);}}return o;});}
function snappyUncompress(input){let pos=0;function readVar(){let x=0,shift=0;while(true){let c=input[pos++];x|=(c&127)<<shift;if("'!(c&128))break;shift+=7;}return x;}let outLen=readVar();let out=Buffer.alloc(outLen);let op=0;while(pos<input.length){let tag=input[pos++],type=tag&3;if(type===0){let len=tag>>2;if(len<60){len+=1;}else{let n=len-59;len=0;for(let i=0;i<n;i++)len|=input[pos++]<<(8*i);len+=1;}input.copy(out,op,pos,pos+len);pos+=len;op+=len;}else{let len,offset;if(type===1){len=((tag>>2)&7)+4;offset=input[pos++]+((tag&0xE0)<<3);}else if(type===2){len=(tag>>2)+1;offset=input[pos]|(input[pos+1]<<8);pos+=2;}else{len=(tag>>2)+1;offset=(input[pos]|(input[pos+1]<<8)|(input[pos+2]<<16)|(input[pos+3]<<24))>>>0;pos+=4;}for(let i=0;i<len;i++){out[op]=out[op-offset];op++;}}}if(op!==outLen) throw Error('"'snappy len mismatch '+op+' '+outLen);return out;}
const footerLen=b.readUInt32LE(b.length-8);const footer=b.subarray(b.length-8-footerLen,b.length-8);const meta=readFileMeta(new TCompact(footer));const cols=meta.row_groups[0].columns.map((c,i)=>({i,name:meta.schema[i+1].name,type:c.meta_data.type,md:c.meta_data}));
for (const nm of ['sex_female','smoking_status','pfs_months','pdl1_tps','age_years']) {
 const c=cols.find(x=>x.name===nm); console.log('\\nCOL', nm, c.type, c.md);
 let pos=c.md.dictionary_page_offset ?? c.md.data_page_offset;
 for(let pg=0; pg<3 && pos < c.md.dictionary_page_offset + c.md.total_compressed_size; pg++){
  let ph=readPageHeaderAt(pos); console.log('page',pg,ph);
  let comp=b.subarray(ph.dataStart, ph.dataStart+ph.compressed_page_size);
  let dec=snappyUncompress(comp);
  console.log('dec len', dec.length, 'first bytes', Array.from(dec.subarray(0,40)));
  pos=ph.dataStart+ph.compressed_page_size;
 }
}
