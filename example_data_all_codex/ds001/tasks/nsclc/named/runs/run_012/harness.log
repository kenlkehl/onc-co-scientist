class TCompact { constructor(buf,pos=0){this.buf=buf;this.pos=pos;this.stack=[];this.lastField=0;} readByte(){return this.buf[this.pos++];} readVarint(){let shift=0,n=0;while(true){let x=this.readByte();n+=(x&0x7f)*Math.pow(2,shift);if((x&0x80)===0)break;shift+=7;}return n;} zigzag(n){return (n>>>1)"'^-(n&1);} readI16(){return this.zigzag(this.readVarint());} readI32(){return this.zigzag(this.readVarint());} readI64(){return this.zigzag(this.readVarint());} readBinary(){let len=this.readVarint();let s=this.buf.subarray(this.pos,this.pos+len);this.pos+=len;return s;} readString(){return this.readBinary().toString('"'utf8');} readFieldBegin(){let h=this.readByte();let type=h&15;if(type===0)return{type,id:0};let delta=h>>4;let id=delta?this.lastField+delta:this.readI16();this.lastField=id;return{type,id};} readStruct(fn){this.stack.push(this.lastField);this.lastField=0;let out=fn();this.lastField=this.stack.pop();return out;} readListBegin(){let h=this.readByte();let size=h>>4,etype=h&15;if(size===15)size=this.readVarint();return{size,etype};} skip(type){switch(type){case 1:case 2:return;case 3:this.pos++;return;case 4:this.readI16();return;case 5:this.readI32();return;case 6:this.readI64();return;case 7:this.pos+=8;return;case 8:this.readBinary();return;case 9:case 10:{let l=this.readListBegin();for(let i=0;i<l.size;i++)this.skip(l.etype);return;}case 11:{let sz=this.readVarint();if(sz>0){let ktvt=this.readByte(),kt=(ktvt>>4)&15,vt=ktvt&15;for(let i=0;i<sz;i++){this.skip(kt);this.skip(vt);}}return;}case 12:this.readStruct(()=>{while(true){let f=this.readFieldBegin();if(f.type===0)break;this.skip(f.type);}});return;default:throw Error('skip '+type+' at '+this.pos);}}}
