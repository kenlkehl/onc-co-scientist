import pandas as pd
import numpy as np
from scipy import stats

path = 'dataset.parquet'
df = pd.read_parquet(path)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('\\noutcome summary')
print(df['pfs_months'].describe().to_string())
print('\\nunique counts <=10')
for c in df.columns:
    if c == 'pfs_months':
        continue
    nun = df[c].nunique()
    if nun <= 10:
        vals = df[c].value_counts().sort_index().to_dict()
        print(c, nun, vals)
    else:
        print(c, nun, 'numeric?', pd.api.types.is_numeric_dtype(df[c]), 'mean', float(df[c].mean()) if pd.api.types.is_numeric_dtype(df[c]) else '')

# fast univariate associations: point-biserial/t-test for binary, OLS slope for continuous, ANOVA-like for categoricals
print('\\nTop univariate binary mean differences (1 - 0)')
rows=[]
for c in df.columns:
    if c=='pfs_months': continue
    if df[c].nunique()==2 and pd.api.types.is_numeric_dtype(df[c]):
        a=df.loc[df[c]==1,'pfs_months']; b=df.loc[df[c]==0,'pfs_months']
        if len(a)>1 and len(b)>1:
            t,p=stats.ttest_ind(a,b,equal_var=False)
            rows.append((c, a.mean()-b.mean(), p, len(a), a.mean(), b.mean()))
for r in sorted(rows, key=lambda x: abs(x[1]), reverse=True)[:30]:
    print(r)

print('\\nContinuous correlations/slope-ish')
rows=[]
for c in df.columns:
    if c=='pfs_months': continue
    if pd.api.types.is_numeric_dtype(df[c]) and df[c].nunique()>2:
        x=df[c].to_numpy(); y=df['pfs_months'].to_numpy()
        slope, intercept, r, p, se = stats.linregress(x,y)
        rows.append((c, slope, p, r, x.mean(), x.std()))
for r in sorted(rows, key=lambda x: abs(x[3]), reverse=True)[:30]:
    print(r)

print('\\nCategorical group means')
for c in df.columns:
    if c=='pfs_months': continue
    if not pd.api.types.is_numeric_dtype(df[c]) or (df[c].nunique()>2 and df[c].nunique()<=10):
        means=df.groupby(c)['pfs_months'].agg(['count','mean','std']).sort_values('mean')
        print('\\n',c)
        print(means.to_string())
