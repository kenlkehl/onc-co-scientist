+        values.push(value);
+        bitOffset += bitWidth;
+      }
+      state.position = end;
+    }
+  }
+  return { values, position: state.position };
+}
+
+function decodeColumn(buffer, columnChunk) {
+  const metadata = columnChunk[3];
+  const physicalType = PARQUET_TYPE[metadata[1]];
+  const path = metadata[3].join(".");
+  const codec = metadata[4];
+  const totalValues = Number(metadata[5]);
+  const dictionaryOffset = Number(metadata[11] ?? metadata[9]);
+  const dataPageOffset = Number(metadata[9]);
+  let position = dictionaryOffset;
+  let dictionary = null;
+  const values = [];
+  while (values.length < totalValues) {
+    const headerReader = new CompactReader(buffer, position);
+    const header = headerReader.readStruct();
+    const payloadStart = headerReader.position;
+    const compressedLength = Number(header[3]);
+    let page = buffer.slice(payloadStart, payloadStart + compressedLength);
+    if (codec === 1) page = snappyUncompress(page);
+    else if (codec !== 0) throw new Error(`Unsupported compression codec ${codec}`);
+    if (header[1] === 2) {
+      const dictionaryHeader = header[7];
+      const dictionaryCount = Number(dictionaryHeader[1]);
+      const encoding = dictionaryHeader[2];
+      if (encoding !== 0) throw new Error(`Unsupported dictionary encoding ${encoding}`);
+      dictionary = decodePlainDictionary(page, physicalType, dictionaryCount);
+    } else if (header[1] === 0) {
+      if (!dictionary) throw new Error(`Missing dictionary for ${path}`);
+      const dataHeader = header[5];
+      const valueCount = Number(dataHeader[1]);
+      const encoding = dataHeader[2];
+      if (encoding !== 8 && encoding !== 2) {
+        throw new Error(`Unsupported data encoding ${encoding} for ${path}`);
+      }
+      let pagePosition = 0;
+      const definitionLevelLength = page.readUInt32LE(pagePosition);
+      pagePosition += 4 + definitionLevelLength;
+      const bitWidth = page[pagePosition++];
+      const decoded = decodeRleBitPacked(page, bitWidth, valueCount, pagePosition);
+      for (let i = 0; i < valueCount; i += 1) values.push(dictionary[decoded.values[i]]);
+    } else {
+      throw new Error(`Unsupported page type ${header[1]} for ${path}`);
+    }
+    position = payloadStart + compressedLength;
+    if (position > dataPageOffset + Number(metadata[7]) + 1024) break;
+  }
+  if (values.length !== totalValues) {
+    throw new Error(`Decoded ${values.length}/${totalValues} values for ${path}`);
+  }
+  return values;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const abs = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * abs);
+  const y =
+    1 -
+    (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) *
+      t *
+      Math.exp(-abs * abs));
+  return sign * y;
+}
+
+function twoSidedNormalP(z) {
+  const abs = Math.abs(z);
+  if (!Number.isFinite(abs)) return 0;
+  const tail = 1 - normalCdf(abs);
+  return Math.max(0, Math.min(1, 2 * tail));
+}
+
+function mean(values, predicate = null) {
+  let total = 0;
+  let count = 0;
+  for (let i = 0; i < values.length; i += 1) {
+    if (!predicate || predicate(i)) {
+      total += values[i];
+      count += 1;
+    }
+  }
+  return total / count;
+}
+
+function countIf(n, predicate) {
+  let count = 0;
+  for (let i = 0; i < n; i += 1) if (predicate(i)) count += 1;
+  return count;
+}
+
+function welchDiff(y, group) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i += 1) {
+    if (group(i)) {
+      n1 += 1;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - (s1 * s1) / n1) / (n1 - 1);
+  const v0 = (ss0 - (s0 * s0) / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return {
+    effect: m1 - m0,
+    p: twoSidedNormalP(z),
+    z,
+    n1,
+    n0,
+    m1,
+    m0,
+    se,
+  };
+}
+
+function subgroupDiff(y, treated, subgroup) {
+  const inSub = welchDiff(y, (i) => treated(i) && subgroup(i));
+  const outSub = welchDiff(y, (i) => treated(i) && !subgroup(i));
+  return { inSub, outSub, contrast: inSub.effect - outSub.effect };
+}
+
+function invertMatrix(matrix) {
+  const n = matrix.length;
+  const augmented = matrix.map((row, i) => {
+    const identity = Array(n).fill(0);
+    identity[i] = 1;
+    return row.slice().concat(identity);
+  });
+  for (let col = 0; col < n; col += 1) {
+    let pivot = col;
+    for (let row = col + 1; row < n; row += 1) {
+      if (Math.abs(augmented[row][col]) > Math.abs(augmented[pivot][col])) {
+        pivot = row;
+      }
+    }
+    if (Math.abs(augmented[pivot][col]) < 1e-12) {
+      throw new Error("Singular matrix");
+    }
+    if (pivot !== col) {
+      const temp = augmented[pivot];
+      augmented[pivot] = augmented[col];
+      augmented[col] = temp;
+    }
+    const divisor = augmented[col][col];
+    for (let j = 0; j < 2 * n; j += 1) augmented[col][j] /= divisor;
+    for (let row = 0; row < n; row += 1) {
+      if (row === col) continue;
+      const factor = augmented[row][col];
+      for (let j = 0; j < 2 * n; j += 1) {
+        augmented[row][j] -= factor * augmented[col][j];
+      }
+    }
+  }
+  return augmented.map((row) => row.slice(n));
+}
+
+function ols(y, columns) {
+  const n = y.length;
+  const p = columns.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i += 1) {
+    const x = columns.map((column) => column.values[i]);
+    for (let a = 0; a < p; a += 1) {
+      xty[a] += x[a] * y[i];
+      for (let b = 0; b <= a; b += 1) xtx[a][b] += x[a] * x[b];
+    }
+  }
+  for (let a = 0; a < p; a += 1) {
+    for (let b = 0; b < a; b += 1) xtx[b][a] = xtx[a][b];
+  }
+  const xtxInv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i += 1) {
+    for (let j = 0; j < p; j += 1) beta[i] += xtxInv[i][j] * xty[j];
+  }
+  let rss = 0;
+  let tss = 0;
+  const yMean = mean(y);
+  for (let i = 0; i < n; i += 1) {
+    let fitted = 0;
+    for (let j = 0; j < p; j += 1) fitted += beta[j] * columns[j].values[i];
+    const residual = y[i] - fitted;
+    rss += residual * residual;
+    const centered = y[i] - yMean;
+    tss += centered * centered;
+  }
+  const sigma2 = rss / (n - p);
+  const terms = {};
+  for (let i = 0; i < p; i += 1) {
+    const se = Math.sqrt(sigma2 * xtxInv[i][i]);
+    const z = beta[i] / se;
+    terms[columns[i].name] = {
+      estimate: beta[i],
+      se,
+      z,
+      p: twoSidedNormalP(z),
+    };
+  }
+  return { terms, rss, r2: 1 - rss / tss, n, p };
+}
+
+function standardize(values) {
+  const mu = mean(values);
+  let ss = 0;
+  for (const value of values) ss += (value - mu) ** 2;
+  const sd = Math.sqrt(ss / (values.length - 1));
+  return values.map((value) => (value - mu) / sd);
+}
+
+function indicator(values, target) {
+  return values.map((value) => (value === target ? 1 : 0));
+}
+
+function interaction(a, b) {
+  return a.map((value, index) => value * b[index]);
+}
+
+function fmtNumber(value, digits = 3) {
+  if (!Number.isFinite(value)) return String(value);
+  if (Math.abs(value) >= 1000) return value.toFixed(0);
+  if (Math.abs(value) >= 100) return value.toFixed(1);
+  if (Math.abs(value) >= 10) return value.toFixed(2);
+  return value.toFixed(digits);
+}
+
+function fmtP(value) {
+  if (value === 0) return "<1e-300";
+  if (value < 1e-6) return value.toExponential(2);
+  return value.toPrecision(3);
+}
+
+function analysisRecord(hypothesisIds, label, result, code) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: label,
+    p_value: result.p,
+    effect_estimate: result.effect ?? result.estimate,
+    significant: result.p < 0.05,
+  };
+}
