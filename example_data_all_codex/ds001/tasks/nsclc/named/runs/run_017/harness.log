+        `Adjusted OLS coefficient for crp_mg_l_z was ${fmtNumber(baseModel.terms.crp_mg_l_z.estimate)} months per SD (p=${fmtP(baseModel.terms.crp_mg_l_z.p)}).`,
+        termResult(baseModel, "crp_mg_l_z"),
+        "OLS: pfs_months ~ standardized crp_mg_l + clinical covariates + biomarkers + treatments",
+      ),
+      analysisRecord(
