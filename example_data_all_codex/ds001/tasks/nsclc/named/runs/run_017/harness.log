+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - (s1 * s1) / n1) / (n1 - 1);
+  const v0 = (ss0 - (s0 * s0) / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return {
+    effect: m1 - m0,
+    p: twoSidedNormalP(z),
