+    ],
+    [
+      analysisRecord(
+        ["h9"],
+        `Adjusted interaction coefficient for treatment_pembrolizumab x pdl1_tps_z was ${fmtNumber(pembroPdl1Model.terms.pembro_x_pdl1_tps_z.estimate)} months per SD (p=${fmtP(pembroPdl1Model.terms.pembro_x_pdl1_tps_z.p)}). Unadjusted pembrolizumab contrast was ${fmtNumber(pembroHighPdl1.effect)} months in PD-L1 >=50 versus ${fmtNumber(pembroLowPdl1.effect)} months in PD-L1 <50.`,
+        termResult(pembroPdl1Model, "pembro_x_pdl1_tps_z"),
+        "OLS: pfs_months ~ covariates + treatment_pembrolizumab * standardized pdl1_tps",
+      ),
+    ],
+  );
+
+  addIteration(
+    6,
+    [
+      {
+        id: "h10",
+        text: "`treatment_pembrolizumab` has a larger positive association with `pfs_months` among patients with `tmb_high` equal to 1 than among patients with `tmb_high` equal to 0.",
+        kind: "refined",
+      },
+    ],
+    [
+      analysisRecord(
+        ["h10"],
+        `Adjusted interaction coefficient for treatment_pembrolizumab x tmb_high was ${fmtNumber(pembroTmbModel.terms.pembro_x_tmb_high.estimate)} months (p=${fmtP(pembroTmbModel.terms.pembro_x_tmb_high.p)}).`,
+        termResult(pembroTmbModel, "pembro_x_tmb_high"),
+        "OLS: pfs_months ~ covariates + treatment_pembrolizumab * tmb_high",
+      ),
+    ],
+  );
+
+  addIteration(
+    7,
+    [
+      {
+        id: "h11",
+        text: "`stk11_mutation` reduces benefit from `treatment_pembrolizumab`; the `treatment_pembrolizumab` by `stk11_mutation` interaction is negative for `pfs_months`.",
+        kind: "refined",
+      },
+    ],
+    [
+      analysisRecord(
+        ["h11"],
+        `Adjusted interaction coefficient for treatment_pembrolizumab x stk11_mutation was ${fmtNumber(pembroStk11Model.terms.pembro_x_stk11_mutation.estimate)} months (p=${fmtP(pembroStk11Model.terms.pembro_x_stk11_mutation.p)}).`,
+        termResult(pembroStk11Model, "pembro_x_stk11_mutation"),
+        "OLS: pfs_months ~ covariates + treatment_pembrolizumab * stk11_mutation",
+      ),
+    ],
+  );
+
+  addIteration(
+    8,
+    [
