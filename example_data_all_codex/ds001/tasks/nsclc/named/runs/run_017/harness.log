+    { name: "weight_loss_pct_6mo_z", values: z.weight_loss_pct_6mo },
+    { name: "crp_mg_l_z", values: z.crp_mg_l },
+    { name: "nlr_z", values: z.nlr },
+    { name: "smoking_former", values: indicator(data.smoking_status, "former") },
+    { name: "smoking_current", values: indicator(data.smoking_status, "current") },
+    { name: "histology_squamous", values: indicator(data.histology, "squamous") },
+    { name: "egfr_mutation", values: data.egfr_mutation },
+    { name: "kras_g12c", values: data.kras_g12c },
+    { name: "alk_fusion", values: data.alk_fusion },
+    { name: "stk11_mutation", values: data.stk11_mutation },
