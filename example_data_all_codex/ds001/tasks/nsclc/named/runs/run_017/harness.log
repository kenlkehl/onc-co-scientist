+  const osimertinibEgfrModel = adjustedModel([
+    { name: "osimertinib_x_egfr_mutation", values: interaction(data.treatment_osimertinib, data.egfr_mutation) },
+  ]);
+  const osimertinibBrainModel = adjustedModel([
+    { name: "osimertinib_x_has_brain_mets", values: interaction(data.treatment_osimertinib, data.has_brain_mets) },
+  ]);
+  const alkOsimertinibModel = adjustedModel([
+    { name: "osimertinib_x_alk_fusion", values: interaction(data.treatment_osimertinib, data.alk_fusion) },
+  ]);
+  const metModel = adjustedModel([
+    { name: "sotorasib_x_met_exon14_skipping", values: interaction(data.treatment_sotorasib, data.met_exon14_skipping) },
+    { name: "olaparib_x_her2_amplification", values: interaction(data.treatment_olaparib, data.her2_amplification) },
+    { name: "osimertinib_x_ros1_fusion", values: interaction(data.treatment_osimertinib, data.ros1_fusion) },
+  ]);
+
+  const pembroHighPdl1 = welchDiff(
+    y,
+    (i) => data.treatment_pembrolizumab[i] === 1 && data.pdl1_tps[i] >= 50,
+  );
