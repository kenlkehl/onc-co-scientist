+    y,
+    (i) => data.treatment_pembrolizumab[i] === 1 && data.pdl1_tps[i] < 50,
+  );
+  const sotoKrasSub = subgroupDiff(y, (i) => data.treatment_sotorasib[i] === 1, (i) => data.kras_g12c[i] === 1);
+  const olapBrcaSub = subgroupDiff(y, (i) => data.treatment_olaparib[i] === 1, (i) => data.brca2_mutation[i] === 1);
+  const osiEgfrSub = subgroupDiff(y, (i) => data.treatment_osimertinib[i] === 1, (i) => data.egfr_mutation[i] === 1);
+
+  const iterations = [];
+  function addIteration(index, hypotheses, analyses) {
+    iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+  }
+
+  addIteration(
+    1,
+    [
+      {
+        id: "h1",
+        text: "Patients with `stage_iv` equal to 1 have lower mean `pfs_months` than patients with `stage_iv` equal to 0.",
