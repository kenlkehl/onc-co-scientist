+const fs = require("fs");
+
+const PARQUET_TYPE = [
+  "BOOLEAN",
+  "INT32",
+  "INT64",
+  "INT96",
+  "FLOAT",
+  "DOUBLE",
+  "BYTE_ARRAY",
+  "FIXED_LEN_BYTE_ARRAY",
+];
+
+const COMPACT_TYPE = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buffer, position = 0) {
+    this.buffer = buffer;
+    this.position = position;
+  }
+
+  readByte() {
+    return this.buffer[this.position++];
+  }
+
+  readInt8() {
+    const value = this.buffer.readInt8(this.position);
+    this.position += 1;
+    return value;
+  }
+
+  readVarUInt() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const byte = this.readByte();
+      result |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  readZigZag() {
+    const raw = this.readVarUInt();
+    const decoded = (raw >> 1n) ^ (-(raw & 1n));
+    if (
+      decoded <= BigInt(Number.MAX_SAFE_INTEGER) &&
