+  readList() {
+    const header = this.readByte();
+    let size = header >> 4;
+    const elementType = header & 0x0f;
+    if (size === 15) size = Number(this.readVarUInt());
+    const values = [];
+    for (let index = 0; index < size; index += 1) {
+      values.push(this.readValue(elementType));
+    }
+    return values;
+  }
+
+  readMap() {
+    const size = Number(this.readVarUInt());
+    if (size === 0) return [];
+    const header = this.readByte();
+    const keyType = header >> 4;
+    const valueType = header & 0x0f;
+    const values = [];
+    for (let index = 0; index < size; index += 1) {
