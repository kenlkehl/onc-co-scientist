+const fs = require("fs");
+
+const PARQUET_TYPE = [
+  "BOOLEAN",
+  "INT32",
+  "INT64",
+  "INT96",
+  "FLOAT",
+  "DOUBLE",
+  "BYTE_ARRAY",
+  "FIXED_LEN_BYTE_ARRAY",
+];
+
+const COMPACT_TYPE = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buffer, position = 0) {
+    this.buffer = buffer;
+    this.position = position;
+  }
+
+  readByte() {
+    return this.buffer[this.position++];
+  }
+
+  readInt8() {
+    const value = this.buffer.readInt8(this.position);
+    this.position += 1;
+    return value;
+  }
+
+  readVarUInt() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const byte = this.readByte();
+      result |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  readZigZag() {
+    const raw = this.readVarUInt();
+    const decoded = (raw >> 1n) ^ (-(raw & 1n));
+    if (
+      decoded <= BigInt(Number.MAX_SAFE_INTEGER) &&
+      decoded >= BigInt(Number.MIN_SAFE_INTEGER)
+    ) {
+      return Number(decoded);
+    }
+    return decoded;
+  }
+
+  readDouble() {
+    const value = this.buffer.readDoubleLE(this.position);
+    this.position += 8;
+    return value;
+  }
+
+  readBinaryRaw() {
+    const length = Number(this.readVarUInt());
+    const value = this.buffer.slice(this.position, this.position + length);
+    this.position += length;
+    return value;
+  }
+
+  readBinary() {
+    return this.readBinaryRaw().toString("utf8");
+  }
+
+  readList() {
+    const header = this.readByte();
+    let size = header >> 4;
+    const elementType = header & 0x0f;
+    if (size === 15) size = Number(this.readVarUInt());
+    const values = [];
+    for (let index = 0; index < size; index += 1) {
+      values.push(this.readValue(elementType));
+    }
+    return values;
+  }
+
+  readMap() {
+    const size = Number(this.readVarUInt());
+    if (size === 0) return [];
+    const header = this.readByte();
+    const keyType = header >> 4;
+    const valueType = header & 0x0f;
+    const values = [];
+    for (let index = 0; index < size; index += 1) {
+      values.push([this.readValue(keyType), this.readValue(valueType)]);
+    }
+    return values;
+  }
+
+  readStruct() {
+    let lastFieldId = 0;
+    const value = {};
+    while (true) {
+      const header = this.readByte();
+      const type = header & 0x0f;
+      if (type === COMPACT_TYPE.STOP) break;
+      const modifier = header >> 4;
+      const fieldId =
+        modifier === 0 ? this.readZigZag() : lastFieldId + modifier;
+      lastFieldId = fieldId;
+      let fieldValue;
+      if (type === COMPACT_TYPE.TRUE) fieldValue = true;
+      else if (type === COMPACT_TYPE.FALSE) fieldValue = false;
+      else fieldValue = this.readValue(type);
+      value[fieldId] = fieldValue;
+    }
+    return value;
+  }
+
+  readValue(type) {
+    switch (type) {
+      case COMPACT_TYPE.TRUE:
+        return true;
+      case COMPACT_TYPE.FALSE:
+        return false;
+      case COMPACT_TYPE.BYTE:
+        return this.readInt8();
+      case COMPACT_TYPE.I16:
+      case COMPACT_TYPE.I32:
+      case COMPACT_TYPE.I64:
+        return this.readZigZag();
+      case COMPACT_TYPE.DOUBLE:
+        return this.readDouble();
+      case COMPACT_TYPE.BINARY:
+        return this.readBinary();
+      case COMPACT_TYPE.LIST:
+      case COMPACT_TYPE.SET:
+        return this.readList();
+      case COMPACT_TYPE.MAP:
+        return this.readMap();
+      case COMPACT_TYPE.STRUCT:
+        return this.readStruct();
+      default:
+        throw new Error(`Unknown compact type ${type}`);
+    }
+  }
+}
+
+function snappyUncompress(input) {
+  let position = 0;
+  let expectedLength = 0;
+  let shift = 0;
+  while (true) {
+    const byte = input[position++];
+    expectedLength |= (byte & 0x7f) << shift;
+    if ((byte & 0x80) === 0) break;
+    shift += 7;
+  }
+  const output = Buffer.alloc(expectedLength);
+  let outputPosition = 0;
+  while (position < input.length) {
+    const tag = input[position++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let length = tag >> 2;
+      if (length < 60) {
+        length += 1;
+      } else {
+        const byteLength = length - 59;
+        length = 0;
+        for (let i = 0; i < byteLength; i += 1) {
+          length |= input[position++] << (8 * i);
+        }
+        length += 1;
+      }
+      input.copy(output, outputPosition, position, position + length);
+      position += length;
+      outputPosition += length;
+    } else if (type === 1) {
+      const length = ((tag >> 2) & 0x07) + 4;
+      const offset = ((tag & 0xe0) << 3) | input[position++];
+      for (let i = 0; i < length; i += 1) {
+        output[outputPosition + i] = output[outputPosition - offset + i];
+      }
+      outputPosition += length;
+    } else if (type === 2) {
+      const length = (tag >> 2) + 1;
+      const offset = input[position] | (input[position + 1] << 8);
+      position += 2;
+      for (let i = 0; i < length; i += 1) {
+        output[outputPosition + i] = output[outputPosition - offset + i];
+      }
+      outputPosition += length;
+    } else {
+      const length = (tag >> 2) + 1;
+      const offset =
+        input[position] |
+        (input[position + 1] << 8) |
+        (input[position + 2] << 16) |
+        (input[position + 3] << 24);
+      position += 4;
+      for (let i = 0; i < length; i += 1) {
+        output[outputPosition + i] = output[outputPosition - offset + i];
+      }
+      outputPosition += length;
+    }
+  }
+  if (outputPosition !== expectedLength) {
+    throw new Error(`Snappy length mismatch: ${outputPosition}/${expectedLength}`);
+  }
+  return output;
+}
+
+function readFileMetadata(buffer) {
+  if (buffer.slice(0, 4).toString("ascii") !== "PAR1") {
+    throw new Error("Not a parquet file");
+  }
+  const footerMagic = buffer.slice(buffer.length - 4).toString("ascii");
+  if (footerMagic !== "PAR1") throw new Error("Bad parquet footer");
+  const metadataLength = buffer.readUInt32LE(buffer.length - 8);
+  const metadataStart = buffer.length - 8 - metadataLength;
+  return new CompactReader(buffer.slice(metadataStart, buffer.length - 8)).readStruct();
+}
+
+function decodePlainDictionary(page, type, count) {
+  const values = [];
+  let position = 0;
+  for (let i = 0; i < count; i += 1) {
+    if (type === "DOUBLE") {
+      values.push(page.readDoubleLE(position));
+      position += 8;
+    } else if (type === "INT64") {
+      values.push(Number(page.readBigInt64LE(position)));
+      position += 8;
+    } else if (type === "INT32") {
+      values.push(page.readInt32LE(position));
+      position += 4;
+    } else if (type === "BYTE_ARRAY") {
+      const length = page.readUInt32LE(position);
+      position += 4;
+      values.push(page.slice(position, position + length).toString("utf8"));
+      position += length;
+    } else {
+      throw new Error(`Unsupported dictionary type ${type}`);
+    }
+  }
+  return values;
+}
+
+function readHybridRunHeader(buffer, state) {
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const byte = buffer[state.position++];
+    result |= (byte & 0x7f) << shift;
+    if ((byte & 0x80) === 0) break;
+    shift += 7;
+  }
+  return result;
+}
+
+function decodeRleBitPacked(buffer, bitWidth, count, startPosition = 0) {
+  const state = { position: startPosition };
+  const values = [];
+  const bytesPerValue = Math.ceil(bitWidth / 8);
+  while (values.length < count && state.position < buffer.length) {
+    const header = readHybridRunHeader(buffer, state);
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < bytesPerValue; i += 1) {
+        value |= buffer[state.position++] << (8 * i);
+      }
+      const limit = Math.min(runLength, count - values.length);
+      for (let i = 0; i < limit; i += 1) values.push(value);
+    } else {
+      const groups = header >> 1;
+      const packedValueCount = groups * 8;
+      const packedByteCount = groups * bitWidth;
+      const end = state.position + packedByteCount;
+      let bitOffset = 0;
+      for (let i = 0; i < packedValueCount && values.length < count; i += 1) {
+        let value = 0;
+        for (let bit = 0; bit < bitWidth; bit += 1) {
+          const absoluteBit = bitOffset + bit;
+          const byte = buffer[state.position + (absoluteBit >> 3)];
+          const bitValue = (byte >> (absoluteBit & 7)) & 1;
+          value |= bitValue << bit;
+        }
+        values.push(value);
+        bitOffset += bitWidth;
+      }
+      state.position = end;
+    }
+  }
+  return { values, position: state.position };
+}
+
+function decodeColumn(buffer, columnChunk) {
+  const metadata = columnChunk[3];
+  const physicalType = PARQUET_TYPE[metadata[1]];
+  const path = metadata[3].join(".");
+  const codec = metadata[4];
+  const totalValues = Number(metadata[5]);
+  const dictionaryOffset = Number(metadata[11] ?? metadata[9]);
+  const dataPageOffset = Number(metadata[9]);
+  let position = dictionaryOffset;
+  let dictionary = null;
+  const values = [];
+  while (values.length < totalValues) {
+    const headerReader = new CompactReader(buffer, position);
+    const header = headerReader.readStruct();
+    const payloadStart = headerReader.position;
+    const compressedLength = Number(header[3]);
+    let page = buffer.slice(payloadStart, payloadStart + compressedLength);
+    if (codec === 1) page = snappyUncompress(page);
+    else if (codec !== 0) throw new Error(`Unsupported compression codec ${codec}`);
+    if (header[1] === 2) {
+      const dictionaryHeader = header[7];
+      const dictionaryCount = Number(dictionaryHeader[1]);
+      const encoding = dictionaryHeader[2];
+      if (encoding !== 0) throw new Error(`Unsupported dictionary encoding ${encoding}`);
+      dictionary = decodePlainDictionary(page, physicalType, dictionaryCount);
+    } else if (header[1] === 0) {
+      if (!dictionary) throw new Error(`Missing dictionary for ${path}`);
+      const dataHeader = header[5];
+      const valueCount = Number(dataHeader[1]);
+      const encoding = dataHeader[2];
+      if (encoding !== 8 && encoding !== 2) {
+        throw new Error(`Unsupported data encoding ${encoding} for ${path}`);
+      }
+      let pagePosition = 0;
+      const definitionLevelLength = page.readUInt32LE(pagePosition);
+      pagePosition += 4 + definitionLevelLength;
+      const bitWidth = page[pagePosition++];
+      const decoded = decodeRleBitPacked(page, bitWidth, valueCount, pagePosition);
+      for (let i = 0; i < valueCount; i += 1) values.push(dictionary[decoded.values[i]]);
+    } else {
+      throw new Error(`Unsupported page type ${header[1]} for ${path}`);
+    }
+    position = payloadStart + compressedLength;
+    if (position > dataPageOffset + Number(metadata[7]) + 1024) break;
+  }
+  if (values.length !== totalValues) {
+    throw new Error(`Decoded ${values.length}/${totalValues} values for ${path}`);
+  }
+  return values;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  const abs = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * abs);
+  const y =
+    1 -
+    (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) *
+      t *
+      Math.exp(-abs * abs));
+  return sign * y;
+}
+
+function twoSidedNormalP(z) {
+  const abs = Math.abs(z);
+  if (!Number.isFinite(abs)) return 0;
+  const tail = 1 - normalCdf(abs);
+  return Math.max(0, Math.min(1, 2 * tail));
+}
+
+function mean(values, predicate = null) {
+  let total = 0;
+  let count = 0;
+  for (let i = 0; i < values.length; i += 1) {
+    if (!predicate || predicate(i)) {
+      total += values[i];
+      count += 1;
+    }
+  }
+  return total / count;
+}
+
+function countIf(n, predicate) {
+  let count = 0;
+  for (let i = 0; i < n; i += 1) if (predicate(i)) count += 1;
+  return count;
+}
+
+function welchDiff(y, group) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  let ss1 = 0;
+  let ss0 = 0;
+  for (let i = 0; i < y.length; i += 1) {
+    if (group(i)) {
+      n1 += 1;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - (s1 * s1) / n1) / (n1 - 1);
+  const v0 = (ss0 - (s0 * s0) / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return {
+    effect: m1 - m0,
+    p: twoSidedNormalP(z),
+    z,
+    n1,
+    n0,
+    m1,
+    m0,
+    se,
+  };
+}
+
+function subgroupDiff(y, treated, subgroup) {
+  const inSub = welchDiff(y, (i) => treated(i) && subgroup(i));
+  const outSub = welchDiff(y, (i) => treated(i) && !subgroup(i));
+  return { inSub, outSub, contrast: inSub.effect - outSub.effect };
+}
+
+function invertMatrix(matrix) {
+  const n = matrix.length;
+  const augmented = matrix.map((row, i) => {
+    const identity = Array(n).fill(0);
+    identity[i] = 1;
+    return row.slice().concat(identity);
+  });
+  for (let col = 0; col < n; col += 1) {
+    let pivot = col;
+    for (let row = col + 1; row < n; row += 1) {
+      if (Math.abs(augmented[row][col]) > Math.abs(augmented[pivot][col])) {
+        pivot = row;
+      }
+    }
+    if (Math.abs(augmented[pivot][col]) < 1e-12) {
+      throw new Error("Singular matrix");
+    }
+    if (pivot !== col) {
+      const temp = augmented[pivot];
+      augmented[pivot] = augmented[col];
+      augmented[col] = temp;
+    }
+    const divisor = augmented[col][col];
+    for (let j = 0; j < 2 * n; j += 1) augmented[col][j] /= divisor;
+    for (let row = 0; row < n; row += 1) {
+      if (row === col) continue;
+      const factor = augmented[row][col];
+      for (let j = 0; j < 2 * n; j += 1) {
+        augmented[row][j] -= factor * augmented[col][j];
+      }
+    }
+  }
+  return augmented.map((row) => row.slice(n));
+}
+
+function ols(y, columns) {
+  const n = y.length;
+  const p = columns.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i += 1) {
+    const x = columns.map((column) => column.values[i]);
+    for (let a = 0; a < p; a += 1) {
+      xty[a] += x[a] * y[i];
+      for (let b = 0; b <= a; b += 1) xtx[a][b] += x[a] * x[b];
+    }
+  }
+  for (let a = 0; a < p; a += 1) {
+    for (let b = 0; b < a; b += 1) xtx[b][a] = xtx[a][b];
+  }
+  const xtxInv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i += 1) {
+    for (let j = 0; j < p; j += 1) beta[i] += xtxInv[i][j] * xty[j];
+  }
+  let rss = 0;
+  let tss = 0;
+  const yMean = mean(y);
+  for (let i = 0; i < n; i += 1) {
+    let fitted = 0;
+    for (let j = 0; j < p; j += 1) fitted += beta[j] * columns[j].values[i];
+    const residual = y[i] - fitted;
+    rss += residual * residual;
+    const centered = y[i] - yMean;
+    tss += centered * centered;
+  }
+  const sigma2 = rss / (n - p);
+  const terms = {};
+  for (let i = 0; i < p; i += 1) {
+    const se = Math.sqrt(sigma2 * xtxInv[i][i]);
+    const z = beta[i] / se;
+    terms[columns[i].name] = {
+      estimate: beta[i],
+      se,
+      z,
+      p: twoSidedNormalP(z),
+    };
+  }
+  return { terms, rss, r2: 1 - rss / tss, n, p };
+}
+
+function standardize(values) {
+  const mu = mean(values);
+  let ss = 0;
+  for (const value of values) ss += (value - mu) ** 2;
+  const sd = Math.sqrt(ss / (values.length - 1));
+  return values.map((value) => (value - mu) / sd);
+}
+
+function indicator(values, target) {
+  return values.map((value) => (value === target ? 1 : 0));
+}
+
+function interaction(a, b) {
+  return a.map((value, index) => value * b[index]);
+}
+
+function fmtNumber(value, digits = 3) {
+  if (!Number.isFinite(value)) return String(value);
+  if (Math.abs(value) >= 1000) return value.toFixed(0);
+  if (Math.abs(value) >= 100) return value.toFixed(1);
+  if (Math.abs(value) >= 10) return value.toFixed(2);
+  return value.toFixed(digits);
+}
+
+function fmtP(value) {
+  if (value === 0) return "<1e-300";
+  if (value < 1e-6) return value.toExponential(2);
+  return value.toPrecision(3);
+}
+
+function analysisRecord(hypothesisIds, label, result, code) {
+  return {
+    hypothesis_ids: hypothesisIds,
+    code,
+    result_summary: label,
+    p_value: result.p,
+    effect_estimate: result.effect ?? result.estimate,
+    significant: result.p < 0.05,
+  };
+}
+
+function main() {
