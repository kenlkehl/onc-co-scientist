+    { name: "creatinine_mg_dl_z", values: z.creatinine_mg_dl },
+    { name: "bun_mg_dl_z", values: z.bun_mg_dl },
+    { name: "sodium_meq_l_z", values: z.sodium_meq_l },
+    { name: "calcium_mg_dl_z", values: z.calcium_mg_dl },
+    { name: "spo2_pct_z", values: z.spo2_pct },
