+        ["h7"],
+        `Adjusted OLS coefficient for pdl1_tps_z was ${fmtNumber(baseModel.terms.pdl1_tps_z.estimate)} months per SD (p=${fmtP(baseModel.terms.pdl1_tps_z.p)}).`,
+        termResult(baseModel, "pdl1_tps_z"),
+        "OLS: pfs_months ~ standardized pdl1_tps + clinical covariates + biomarkers + treatments",
