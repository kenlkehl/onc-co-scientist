+function decodeRleBitPacked(buffer, bitWidth, count, startPosition = 0) {
+  const state = { position: startPosition };
+  const values = [];
+  const bytesPerValue = Math.ceil(bitWidth / 8);
+  while (values.length < count && state.position < buffer.length) {
+    const header = readHybridRunHeader(buffer, state);
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < bytesPerValue; i += 1) {
+        value |= buffer[state.position++] << (8 * i);
+      }
+      const limit = Math.min(runLength, count - values.length);
+      for (let i = 0; i < limit; i += 1) values.push(value);
+    } else {
+      const groups = header >> 1;
+      const packedValueCount = groups * 8;
+      const packedByteCount = groups * bitWidth;
+      const end = state.position + packedByteCount;
+      let bitOffset = 0;
+      for (let i = 0; i < packedValueCount && values.length < count; i += 1) {
+        let value = 0;
+        for (let bit = 0; bit < bitWidth; bit += 1) {
+          const absoluteBit = bitOffset + bit;
+          const byte = buffer[state.position + (absoluteBit >> 3)];
+          const bitValue = (byte >> (absoluteBit & 7)) & 1;
+          value |= bitValue << bit;
+        }
+        values.push(value);
+        bitOffset += bitWidth;
+      }
+      state.position = end;
