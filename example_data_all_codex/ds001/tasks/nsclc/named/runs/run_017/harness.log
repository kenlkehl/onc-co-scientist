+    const x = columns.map((column) => column.values[i]);
+    for (let a = 0; a < p; a += 1) {
+      xty[a] += x[a] * y[i];
+      for (let b = 0; b <= a; b += 1) xtx[a][b] += x[a] * x[b];
+    }
+  }
+  for (let a = 0; a < p; a += 1) {
