+    { name: "sotorasib_x_stk11_mutation", values: interaction(data.treatment_sotorasib, data.stk11_mutation) },
+  ]);
+  const olaparibBrcaModel = adjustedModel([
+    { name: "olaparib_x_brca2_mutation", values: interaction(data.treatment_olaparib, data.brca2_mutation) },
+  ]);
+  const osimertinibEgfrModel = adjustedModel([
+    { name: "osimertinib_x_egfr_mutation", values: interaction(data.treatment_osimertinib, data.egfr_mutation) },
+  ]);
+  const osimertinibBrainModel = adjustedModel([
+    { name: "osimertinib_x_has_brain_mets", values: interaction(data.treatment_osimertinib, data.has_brain_mets) },
+  ]);
+  const alkOsimertinibModel = adjustedModel([
+    { name: "osimertinib_x_alk_fusion", values: interaction(data.treatment_osimertinib, data.alk_fusion) },
+  ]);
+  const metModel = adjustedModel([
+    { name: "sotorasib_x_met_exon14_skipping", values: interaction(data.treatment_sotorasib, data.met_exon14_skipping) },
+    { name: "olaparib_x_her2_amplification", values: interaction(data.treatment_olaparib, data.her2_amplification) },
+    { name: "osimertinib_x_ros1_fusion", values: interaction(data.treatment_osimertinib, data.ros1_fusion) },
+  ]);
+
+  const pembroHighPdl1 = welchDiff(
+    y,
+    (i) => data.treatment_pembrolizumab[i] === 1 && data.pdl1_tps[i] >= 50,
+  );
+  const pembroLowPdl1 = welchDiff(
+    y,
+    (i) => data.treatment_pembrolizumab[i] === 1 && data.pdl1_tps[i] < 50,
+  );
+  const sotoKrasSub = subgroupDiff(y, (i) => data.treatment_sotorasib[i] === 1, (i) => data.kras_g12c[i] === 1);
+  const olapBrcaSub = subgroupDiff(y, (i) => data.treatment_olaparib[i] === 1, (i) => data.brca2_mutation[i] === 1);
+  const osiEgfrSub = subgroupDiff(y, (i) => data.treatment_osimertinib[i] === 1, (i) => data.egfr_mutation[i] === 1);
+
+  const iterations = [];
+  function addIteration(index, hypotheses, analyses) {
+    iterations.push({ index, proposed_hypotheses: hypotheses, analyses });
+  }
+
+  addIteration(
+    1,
+    [
+      {
+        id: "h1",
+        text: "Patients with `stage_iv` equal to 1 have lower mean `pfs_months` than patients with `stage_iv` equal to 0.",
+        kind: "novel",
+      },
+      {
+        id: "h2",
+        text: "Patients with `has_brain_mets` equal to 1 have lower mean `pfs_months` than patients with `has_brain_mets` equal to 0.",
