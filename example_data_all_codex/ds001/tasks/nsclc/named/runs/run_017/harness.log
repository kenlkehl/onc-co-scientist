+  ];
+  const broadMainModel = ols(y, allMainEffectColumns);
+
+  function termResult(model, termName) {
+    const term = model.terms[termName];
+    return { estimate: term.estimate, effect: term.estimate, p: term.p, se: term.se };
+  }
+
+  function adjustedModel(extraTerms) {
