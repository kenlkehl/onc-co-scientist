+
+  addIteration(
+    4,
+    [
+      {
+        id: "h7",
+        text: "Higher `pdl1_tps` is associated with higher `pfs_months` independent of treatment, with each 1-SD increase in `pdl1_tps` increasing PFS.",
+        kind: "novel",
+      },
+      {
+        id: "h8",
+        text: "Patients with `tmb_high` equal to 1 have higher `pfs_months` than patients with `tmb_high` equal to 0 independent of treatment.",
+        kind: "novel",
+      },
+    ],
+    [
+      analysisRecord(
+        ["h7"],
+        `Adjusted OLS coefficient for pdl1_tps_z was ${fmtNumber(baseModel.terms.pdl1_tps_z.estimate)} months per SD (p=${fmtP(baseModel.terms.pdl1_tps_z.p)}).`,
+        termResult(baseModel, "pdl1_tps_z"),
+        "OLS: pfs_months ~ standardized pdl1_tps + clinical covariates + biomarkers + treatments",
+      ),
+      analysisRecord(
+        ["h8"],
+        `Adjusted OLS coefficient for tmb_high was ${fmtNumber(baseModel.terms.tmb_high.estimate)} months (p=${fmtP(baseModel.terms.tmb_high.p)}).`,
+        termResult(baseModel, "tmb_high"),
+        "OLS: pfs_months ~ tmb_high + clinical covariates + biomarkers + treatments",
+      ),
+    ],
+  );
+
+  addIteration(
+    5,
+    [
+      {
+        id: "h9",
+        text: "`treatment_pembrolizumab` has a larger positive association with `pfs_months` as `pdl1_tps` increases; the `treatment_pembrolizumab` by 1-SD `pdl1_tps` interaction is positive.",
+        kind: "refined",
