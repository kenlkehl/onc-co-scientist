+      ),
+      analysisRecord(
+        ["h2"],
+        `Adjusted OLS coefficient for has_brain_mets was ${fmtNumber(baseModel.terms.has_brain_mets.estimate)} months (p=${fmtP(baseModel.terms.has_brain_mets.p)}), indicating shorter PFS in patients with brain metastases.`,
+        termResult(baseModel, "has_brain_mets"),
+        "OLS: pfs_months ~ has_brain_mets + age_years + sex_female + stage + ECOG + labs + biomarkers + treatments",
