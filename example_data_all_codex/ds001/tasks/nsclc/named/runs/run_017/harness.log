+const fs = require("fs");
+
+const PARQUET_TYPE = [
+  "BOOLEAN",
+  "INT32",
+  "INT64",
+  "INT96",
+  "FLOAT",
+  "DOUBLE",
+  "BYTE_ARRAY",
+  "FIXED_LEN_BYTE_ARRAY",
+];
+
+const COMPACT_TYPE = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buffer, position = 0) {
+    this.buffer = buffer;
+    this.position = position;
+  }
+
+  readByte() {
+    return this.buffer[this.position++];
+  }
+
+  readInt8() {
+    const value = this.buffer.readInt8(this.position);
+    this.position += 1;
+    return value;
+  }
+
+  readVarUInt() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const byte = this.readByte();
+      result |= BigInt(byte & 0x7f) << shift;
+      if ((byte & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  readZigZag() {
+    const raw = this.readVarUInt();
+    const decoded = (raw >> 1n) ^ (-(raw & 1n));
+    if (
+      decoded <= BigInt(Number.MAX_SAFE_INTEGER) &&
+      decoded >= BigInt(Number.MIN_SAFE_INTEGER)
+    ) {
+      return Number(decoded);
+    }
+    return decoded;
+  }
+
+  readDouble() {
+    const value = this.buffer.readDoubleLE(this.position);
+    this.position += 8;
+    return value;
+  }
+
+  readBinaryRaw() {
+    const length = Number(this.readVarUInt());
+    const value = this.buffer.slice(this.position, this.position + length);
+    this.position += length;
+    return value;
+  }
+
+  readBinary() {
+    return this.readBinaryRaw().toString("utf8");
+  }
+
+  readList() {
+    const header = this.readByte();
+    let size = header >> 4;
+    const elementType = header & 0x0f;
+    if (size === 15) size = Number(this.readVarUInt());
+    const values = [];
+    for (let index = 0; index < size; index += 1) {
+      values.push(this.readValue(elementType));
+    }
+    return values;
+  }
+
+  readMap() {
+    const size = Number(this.readVarUInt());
+    if (size === 0) return [];
+    const header = this.readByte();
+    const keyType = header >> 4;
+    const valueType = header & 0x0f;
+    const values = [];
+    for (let index = 0; index < size; index += 1) {
+      values.push([this.readValue(keyType), this.readValue(valueType)]);
+    }
+    return values;
+  }
+
+  readStruct() {
+    let lastFieldId = 0;
+    const value = {};
+    while (true) {
+      const header = this.readByte();
+      const type = header & 0x0f;
+      if (type === COMPACT_TYPE.STOP) break;
+      const modifier = header >> 4;
+      const fieldId =
+        modifier === 0 ? this.readZigZag() : lastFieldId + modifier;
+      lastFieldId = fieldId;
+      let fieldValue;
+      if (type === COMPACT_TYPE.TRUE) fieldValue = true;
+      else if (type === COMPACT_TYPE.FALSE) fieldValue = false;
+      else fieldValue = this.readValue(type);
+      value[fieldId] = fieldValue;
+    }
+    return value;
+  }
+
+  readValue(type) {
+    switch (type) {
+      case COMPACT_TYPE.TRUE:
+        return true;
+      case COMPACT_TYPE.FALSE:
+        return false;
+      case COMPACT_TYPE.BYTE:
+        return this.readInt8();
+      case COMPACT_TYPE.I16:
+      case COMPACT_TYPE.I32:
+      case COMPACT_TYPE.I64:
+        return this.readZigZag();
+      case COMPACT_TYPE.DOUBLE:
+        return this.readDouble();
+      case COMPACT_TYPE.BINARY:
+        return this.readBinary();
+      case COMPACT_TYPE.LIST:
+      case COMPACT_TYPE.SET:
+        return this.readList();
+      case COMPACT_TYPE.MAP:
+        return this.readMap();
+      case COMPACT_TYPE.STRUCT:
+        return this.readStruct();
+      default:
+        throw new Error(`Unknown compact type ${type}`);
+    }
+  }
+}
