+        ["h9"],
+        `Adjusted interaction coefficient for treatment_pembrolizumab x pdl1_tps_z was ${fmtNumber(pembroPdl1Model.terms.pembro_x_pdl1_tps_z.estimate)} months per SD (p=${fmtP(pembroPdl1Model.terms.pembro_x_pdl1_tps_z.p)}), so the PD-L1 gradient hypothesis was not supported.`,
+        termResult(pembroPdl1Model, "pembro_x_pdl1_tps_z"),
