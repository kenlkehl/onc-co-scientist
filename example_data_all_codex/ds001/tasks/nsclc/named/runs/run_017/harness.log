+      const dictionaryCount = Number(dictionaryHeader[1]);
+      const encoding = dictionaryHeader[2];
+      if (encoding !== 0) throw new Error(`Unsupported dictionary encoding ${encoding}`);
+      dictionary = decodePlainDictionary(page, physicalType, dictionaryCount);
