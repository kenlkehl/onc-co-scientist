+    { name: "osimertinib_x_egfr_mutation", values: interaction(data.treatment_osimertinib, data.egfr_mutation) },
+  ]);
+  const osimertinibBrainModel = adjustedModel([
+    { name: "osimertinib_x_has_brain_mets", values: interaction(data.treatment_osimertinib, data.has_brain_mets) },
+  ]);
