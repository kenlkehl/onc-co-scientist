+function snappyUncompress(input) {
+  let ip = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[ip++];
+    len |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let l = tag >> 2;
+      if (l < 60) {
+        l += 1;
+      } else {
+        const bytes = l - 59;
+        l = 0;
+        for (let i = 0; i < bytes; i++) l |= input[ip++] << (8 * i);
+        l += 1;
+      }
+      input.copy(out, op, ip, ip + l);
+      ip += l;
+      op += l;
+    } else {
+      let l;
+      let offset;
+      if (type === 1) {
+        l = ((tag >> 2) & 0x7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
