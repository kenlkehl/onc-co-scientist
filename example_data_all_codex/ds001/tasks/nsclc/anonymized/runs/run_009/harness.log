+const fs = require("fs");
+
+const parquetPath = "dataset.parquet";
+const buf = fs.readFileSync(parquetPath);
+
+const PT = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  INT96: 3,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+  FIXED_LEN_BYTE_ARRAY: 7,
+};
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buffer, offset = 0, limit = buffer.length) {
+    this.buf = buffer;
+    this.off = offset;
+    this.limit = limit;
+  }
+
+  readByte() {
+    return this.buf[this.off++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readI16() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI32() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.off);
+    this.off += 8;
+    return v;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const s = this.buf.subarray(this.off, this.off + len);
+    this.off += len;
+    return s;
+  }
+
+  readString() {
+    return this.readBinary().toString("utf8");
+  }
+
+  readListHeader() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const type = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, type };
+  }
+
+  skip(type) {
+    if (type === CT.STOP || type === CT.TRUE || type === CT.FALSE) return;
+    if (type === CT.BYTE) {
+      this.off += 1;
+      return;
+    }
+    if (type === CT.I16 || type === CT.I32) {
+      this.readI32();
+      return;
+    }
+    if (type === CT.I64) {
+      this.readI64();
+      return;
+    }
+    if (type === CT.DOUBLE) {
+      this.off += 8;
+      return;
+    }
+    if (type === CT.BINARY) {
+      this.readBinary();
+      return;
+    }
+    if (type === CT.LIST || type === CT.SET) {
+      const h = this.readListHeader();
+      for (let i = 0; i < h.size; i++) this.skip(h.type);
+      return;
+    }
+    if (type === CT.MAP) {
+      const n = Number(this.readVarint());
+      if (n > 0) {
+        const ktvt = this.readByte();
+        const kt = ktvt >> 4;
+        const vt = ktvt & 0x0f;
+        for (let i = 0; i < n; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+      }
+      return;
+    }
+    if (type === CT.STRUCT) {
+      let last = 0;
+      while (true) {
+        const hb = this.readByte();
+        if (hb === 0) break;
+        const delta = hb >> 4;
+        const t = hb & 0x0f;
