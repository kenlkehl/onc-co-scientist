+      off += 8;
+    } else if (physicalType === PT.FLOAT) {
+      out[i] = bytes.readFloatLE(off);
+      off += 4;
+    } else if (physicalType === PT.INT32) {
+      out[i] = bytes.readInt32LE(off);
+      off += 4;
+    } else if (physicalType === PT.INT64) {
