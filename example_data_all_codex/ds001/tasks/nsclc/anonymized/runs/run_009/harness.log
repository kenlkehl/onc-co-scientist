+  // Iterations 9-12: adjusted main effects.
+  for (const t of topMain.slice(0, 4)) {
+    const adjName = t.name;
+    const adj = adjustedByName[adjName];
+    if (!adj) continue;
+    const h = hyp(`After adjustment for the strongest observed main-effect covariates, \`${adjName}\` retains a ${adj.effect > 0 ? "positive" : "negative"} independent association with \`pfs_months\`.`, "refined");
