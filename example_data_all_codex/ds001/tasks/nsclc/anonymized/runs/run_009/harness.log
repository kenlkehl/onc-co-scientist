+class CompactReader {
+  constructor(buffer, offset = 0, limit = buffer.length) {
+    this.buf = buffer;
+    this.off = offset;
+    this.limit = limit;
+  }
+
+  readByte() {
+    return this.buf[this.off++];
+  }
+
+  readVarint() {
