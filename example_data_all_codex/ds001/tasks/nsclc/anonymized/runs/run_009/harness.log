+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === positiveValue) {
+      n1 += 1;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
