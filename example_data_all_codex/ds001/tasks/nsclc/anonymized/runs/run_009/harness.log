+const fs = require("fs");
+
+const parquetPath = "dataset.parquet";
+const buf = fs.readFileSync(parquetPath);
+
+const PT = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  INT96: 3,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+  FIXED_LEN_BYTE_ARRAY: 7,
+};
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buffer, offset = 0, limit = buffer.length) {
+    this.buf = buffer;
+    this.off = offset;
+    this.limit = limit;
+  }
+
+  readByte() {
+    return this.buf[this.off++];
+  }
+
+  readVarint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+
+  readI16() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI32() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.off);
+    this.off += 8;
+    return v;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const s = this.buf.subarray(this.off, this.off + len);
+    this.off += len;
+    return s;
+  }
+
+  readString() {
+    return this.readBinary().toString("utf8");
+  }
+
+  readListHeader() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const type = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { size, type };
+  }
+
+  skip(type) {
+    if (type === CT.STOP || type === CT.TRUE || type === CT.FALSE) return;
+    if (type === CT.BYTE) {
+      this.off += 1;
+      return;
+    }
+    if (type === CT.I16 || type === CT.I32) {
+      this.readI32();
+      return;
+    }
+    if (type === CT.I64) {
+      this.readI64();
+      return;
+    }
+    if (type === CT.DOUBLE) {
+      this.off += 8;
+      return;
+    }
+    if (type === CT.BINARY) {
+      this.readBinary();
+      return;
+    }
+    if (type === CT.LIST || type === CT.SET) {
+      const h = this.readListHeader();
+      for (let i = 0; i < h.size; i++) this.skip(h.type);
+      return;
+    }
+    if (type === CT.MAP) {
+      const n = Number(this.readVarint());
+      if (n > 0) {
+        const ktvt = this.readByte();
+        const kt = ktvt >> 4;
+        const vt = ktvt & 0x0f;
+        for (let i = 0; i < n; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+      }
+      return;
+    }
+    if (type === CT.STRUCT) {
+      let last = 0;
+      while (true) {
+        const hb = this.readByte();
+        if (hb === 0) break;
+        const delta = hb >> 4;
+        const t = hb & 0x0f;
+        const fid = delta ? last + delta : this.readI16();
+        last = fid;
+        this.skip(t);
+      }
+      return;
+    }
+    throw new Error(`Unknown compact type ${type} at ${this.off}`);
+  }
+
+  readStruct(reader) {
+    let last = 0;
+    const obj = {};
+    while (true) {
+      const hb = this.readByte();
+      if (hb === 0) break;
+      const delta = hb >> 4;
+      const type = hb & 0x0f;
+      const fid = delta ? last + delta : this.readI16();
+      last = fid;
+      reader(obj, fid, type);
+    }
+    return obj;
+  }
+
+  readStringList() {
+    const h = this.readListHeader();
+    const out = [];
+    for (let i = 0; i < h.size; i++) out.push(this.readString());
+    return out;
+  }
+
+  readI32List() {
+    const h = this.readListHeader();
+    const out = [];
+    for (let i = 0; i < h.size; i++) out.push(this.readI32());
+    return out;
+  }
+}
+
+function readSchemaElement(r) {
+  return r.readStruct((o, f, t) => {
+    if (f === 1) o.type = r.readI32();
+    else if (f === 2) o.type_length = r.readI32();
+    else if (f === 3) o.repetition_type = r.readI32();
+    else if (f === 4) o.name = r.readString();
+    else if (f === 5) o.num_children = r.readI32();
+    else if (f === 6) o.converted_type = r.readI32();
+    else if (f === 7) o.scale = r.readI32();
+    else if (f === 8) o.precision = r.readI32();
+    else if (f === 9) o.field_id = r.readI32();
+    else r.skip(t);
+  });
+}
+
+function readStats(r) {
+  return r.readStruct((o, f, t) => {
+    if (f === 1) o.max = r.readBinary();
+    else if (f === 2) o.min = r.readBinary();
+    else if (f === 3) o.null_count = Number(r.readI64());
+    else if (f === 4) o.distinct_count = Number(r.readI64());
+    else if (f === 5) o.max_value = r.readBinary();
+    else if (f === 6) o.min_value = r.readBinary();
+    else r.skip(t);
+  });
+}
+
+function readKV(r) {
+  return r.readStruct((o, f, t) => {
+    if (f === 1) o.key = r.readString();
+    else if (f === 2) o.value = r.readString();
+    else r.skip(t);
+  });
+}
+
+function readColumnMeta(r) {
+  return r.readStruct((o, f, t) => {
+    if (f === 1) o.type = r.readI32();
+    else if (f === 2) o.encodings = r.readI32List();
+    else if (f === 3) o.path_in_schema = r.readStringList();
+    else if (f === 4) o.codec = r.readI32();
+    else if (f === 5) o.num_values = Number(r.readI64());
+    else if (f === 6) o.total_uncompressed_size = Number(r.readI64());
+    else if (f === 7) o.total_compressed_size = Number(r.readI64());
+    else if (f === 8) {
+      const h = r.readListHeader();
+      o.key_value_metadata = [];
+      for (let i = 0; i < h.size; i++) o.key_value_metadata.push(readKV(r));
+    } else if (f === 9) o.data_page_offset = Number(r.readI64());
+    else if (f === 10) o.index_page_offset = Number(r.readI64());
+    else if (f === 11) o.dictionary_page_offset = Number(r.readI64());
+    else if (f === 12) o.statistics = readStats(r);
+    else r.skip(t);
+  });
+}
+
+function readColumnChunk(r) {
+  return r.readStruct((o, f, t) => {
+    if (f === 1) o.file_path = r.readString();
+    else if (f === 2) o.file_offset = Number(r.readI64());
+    else if (f === 3) o.meta_data = readColumnMeta(r);
+    else if (f === 4) o.offset_index_offset = Number(r.readI64());
+    else if (f === 5) o.offset_index_length = r.readI32();
+    else if (f === 6) o.column_index_offset = Number(r.readI64());
+    else if (f === 7) o.column_index_length = r.readI32();
+    else r.skip(t);
+  });
+}
+
+function readRowGroup(r) {
+  return r.readStruct((o, f, t) => {
+    if (f === 1) {
+      const h = r.readListHeader();
+      o.columns = [];
+      for (let i = 0; i < h.size; i++) o.columns.push(readColumnChunk(r));
+    } else if (f === 2) o.total_byte_size = Number(r.readI64());
+    else if (f === 3) o.num_rows = Number(r.readI64());
+    else if (f === 5) o.file_offset = Number(r.readI64());
+    else if (f === 6) o.total_compressed_size = Number(r.readI64());
+    else if (f === 7) o.ordinal = Number(r.readI16());
+    else r.skip(t);
+  });
+}
+
+function readFileMeta() {
+  const footerLen = buf.readInt32LE(buf.length - 8);
+  const footerStart = buf.length - 8 - footerLen;
+  const r = new CompactReader(buf.subarray(footerStart, buf.length - 8));
+  return r.readStruct((o, f, t) => {
+    if (f === 1) o.version = r.readI32();
+    else if (f === 2) {
+      const h = r.readListHeader();
+      o.schema = [];
+      for (let i = 0; i < h.size; i++) o.schema.push(readSchemaElement(r));
+    } else if (f === 3) o.num_rows = Number(r.readI64());
+    else if (f === 4) {
+      const h = r.readListHeader();
+      o.row_groups = [];
+      for (let i = 0; i < h.size; i++) o.row_groups.push(readRowGroup(r));
+    } else if (f === 5) {
+      const h = r.readListHeader();
+      o.key_value_metadata = [];
+      for (let i = 0; i < h.size; i++) o.key_value_metadata.push(readKV(r));
+    } else if (f === 6) o.created_by = r.readString();
+    else r.skip(t);
+  });
+}
+
+function readPageHeader(offset) {
+  const r = new CompactReader(buf, offset);
+  const header = r.readStruct((o, f, t) => {
+    if (f === 1) o.type = r.readI32();
+    else if (f === 2) o.uncompressed_page_size = r.readI32();
+    else if (f === 3) o.compressed_page_size = r.readI32();
+    else if (f === 4) o.crc = r.readI32();
+    else if (f === 5) {
+      o.data_page_header = r.readStruct((d, df, dt) => {
+        if (df === 1) d.num_values = r.readI32();
+        else if (df === 2) d.encoding = r.readI32();
+        else if (df === 3) d.definition_level_encoding = r.readI32();
+        else if (df === 4) d.repetition_level_encoding = r.readI32();
+        else if (df === 5) d.statistics = readStats(r);
+        else r.skip(dt);
+      });
+    } else if (f === 7) {
+      o.dictionary_page_header = r.readStruct((d, df, dt) => {
+        if (df === 1) d.num_values = r.readI32();
+        else if (df === 2) d.encoding = r.readI32();
+        else if (df === 3) d.is_sorted = dt === CT.TRUE ? true : dt === CT.FALSE ? false : Boolean(r.readByte());
+        else r.skip(dt);
+      });
+    } else if (f === 8) {
+      o.data_page_header_v2 = r.readStruct((d, df, dt) => {
+        if (df === 1) d.num_values = r.readI32();
+        else if (df === 2) d.num_nulls = r.readI32();
+        else if (df === 3) d.num_rows = r.readI32();
+        else if (df === 4) d.encoding = r.readI32();
