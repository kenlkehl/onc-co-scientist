+function slopeTest(x, y) {
+  const n = y.length;
+  let sx = 0, sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n, my = sy / n;
+  let sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx, dy = y[i] - my;
+    sxx += dx * dx;
+    sxy += dx * dy;
+    syy += dy * dy;
+  }
+  const beta = sxy / sxx;
+  const alpha = my - beta * mx;
+  const rss = syy - beta * sxy;
+  const sigma2 = rss / (n - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = beta / se;
+  const r = sxy / Math.sqrt(sxx * syy);
