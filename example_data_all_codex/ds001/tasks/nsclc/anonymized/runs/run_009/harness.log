+      for (let i = 0; i < byteWidth; i++) value |= bytes[state.off++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const totalValues = groups * 8;
+      let bitOffset = 0;
+      for (let i = 0; i < totalValues && out.length < count; i++) {
