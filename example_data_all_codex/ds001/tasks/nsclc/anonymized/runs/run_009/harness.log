+    const g = b[i] === 1 ? 1 : 0;
+    const st = stats[g];
+    st.n += 1;
+    st.sx += x[i];
+    st.sy += y[i];
+    st.sxxRaw += x[i] * x[i];
+    st.syyRaw += y[i] * y[i];
+    st.sxyRaw += x[i] * y[i];
