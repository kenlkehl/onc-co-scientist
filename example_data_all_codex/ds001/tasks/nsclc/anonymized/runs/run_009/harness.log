+  // Iterations 1-8: strongest main effects.
+  for (const t of topMain.slice(0, 8)) {
+    const d = describeMain(t);
+    const h = hyp(d.hypothesis);
+    addIteration([h], [
+      makeAnalysis(h.id, d.summary, t.effect, t.p, codeSnippet(d.code), {
