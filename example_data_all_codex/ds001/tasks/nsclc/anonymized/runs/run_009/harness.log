+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function variance(arr, m = mean(arr)) {
+  let s = 0;
+  for (const v of arr) {
+    const d = v - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(z) {
+  return 0.5 * (1 + erf(z / Math.SQRT2));
+}
+
+function twoSidedPFromZ(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  return Math.max(0, Math.min(1, p));
+}
+
+function groupDiffTest(x, y, positiveValue) {
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (x[i] === positiveValue) {
+      n1 += 1;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0 += 1;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - (s1 * s1) / n1) / (n1 - 1);
+  const v0 = (ss0 - (s0 * s0) / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: twoSidedPFromZ(z), n1, n0, m1, m0, se, z };
+}
+
+function slopeTest(x, y) {
+  const n = y.length;
+  let sx = 0, sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n, my = sy / n;
+  let sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx, dy = y[i] - my;
+    sxx += dx * dx;
+    sxy += dx * dy;
+    syy += dy * dy;
+  }
+  const beta = sxy / sxx;
+  const alpha = my - beta * mx;
+  const rss = syy - beta * sxy;
+  const sigma2 = rss / (n - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = beta / se;
+  const r = sxy / Math.sqrt(sxx * syy);
+  return { effect: beta, p: twoSidedPFromZ(z), n, meanX: mx, meanY: my, se, z, r, alpha };
+}
+
+function binaryInteractionTest(x1, x2, y) {
+  const n = [0, 0, 0, 0];
+  const s = [0, 0, 0, 0];
+  const ss = [0, 0, 0, 0];
+  for (let i = 0; i < y.length; i++) {
+    const idx = (x1[i] === 1 ? 2 : 0) + (x2[i] === 1 ? 1 : 0);
+    n[idx] += 1;
+    s[idx] += y[i];
+    ss[idx] += y[i] * y[i];
+  }
+  if (n.some(v => v < 3)) return null;
+  const m = s.map((v, i) => v / n[i]);
+  const v = ss.map((val, i) => (val - (s[i] * s[i]) / n[i]) / (n[i] - 1));
+  const effect = m[3] - m[2] - m[1] + m[0];
+  const se = Math.sqrt(v[3] / n[3] + v[2] / n[2] + v[1] / n[1] + v[0] / n[0]);
+  const z = effect / se;
+  return { effect, se, z, p: twoSidedPFromZ(z), n, means: m };
+}
+
+function numericBinaryInteractionTest(x, b, y) {
+  const stats = [
+    { n: 0, sx: 0, sy: 0, sxxRaw: 0, syyRaw: 0, sxyRaw: 0 },
+    { n: 0, sx: 0, sy: 0, sxxRaw: 0, syyRaw: 0, sxyRaw: 0 },
+  ];
+  for (let i = 0; i < y.length; i++) {
+    const g = b[i] === 1 ? 1 : 0;
+    const st = stats[g];
+    st.n += 1;
+    st.sx += x[i];
+    st.sy += y[i];
+    st.sxxRaw += x[i] * x[i];
+    st.syyRaw += y[i] * y[i];
+    st.sxyRaw += x[i] * y[i];
+  }
+  const slopes = stats.map(st => {
+    if (st.n < 3) return null;
+    const sxx = st.sxxRaw - (st.sx * st.sx) / st.n;
+    const syy = st.syyRaw - (st.sy * st.sy) / st.n;
+    const sxy = st.sxyRaw - (st.sx * st.sy) / st.n;
+    const beta = sxy / sxx;
+    const rss = syy - beta * sxy;
+    const sigma2 = rss / (st.n - 2);
+    const se = Math.sqrt(sigma2 / sxx);
+    return { beta, se, n: st.n };
+  });
+  if (!slopes[0] || !slopes[1]) return null;
+  const effect = slopes[1].beta - slopes[0].beta;
+  const se = Math.sqrt(slopes[0].se * slopes[0].se + slopes[1].se * slopes[1].se);
+  const z = effect / se;
+  return { effect, se, z, p: twoSidedPFromZ(z), slopes };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== i) [m[i], m[pivot]] = [m[pivot], m[i]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = m[r][i];
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= factor * m[i][c];
+    }
+  }
+  return m.map(row => row.slice(n));
+}
+
+function olsFromColumns(cols, y) {
+  const n = y.length;
+  const p = cols.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    yty += y[i] * y[i];
+    for (let j = 0; j < p; j++) {
+      const xj = cols[j][i];
+      xty[j] += xj * y[i];
+      for (let k = 0; k <= j; k++) xtx[j][k] += xj * cols[k][i];
+    }
+  }
+  for (let j = 0; j < p; j++) for (let k = j + 1; k < p; k++) xtx[j][k] = xtx[k][j];
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let j = 0; j < p; j++) for (let k = 0; k < p; k++) beta[j] += inv[j][k] * xty[k];
+  let bxty = 0;
+  for (let j = 0; j < p; j++) bxty += beta[j] * xty[j];
+  const rss = yty - bxty;
+  const sigma2 = rss / (n - p);
+  const se = beta.map((_, j) => Math.sqrt(Math.max(0, sigma2 * inv[j][j])));
+  const z = beta.map((b, j) => b / se[j]);
+  const pvals = z.map(twoSidedPFromZ);
+  return { beta, se, z, p: pvals, rss, sigma2, n, pCount: p };
