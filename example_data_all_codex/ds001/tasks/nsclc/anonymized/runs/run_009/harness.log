+    ),
+  ]);
+  narrative.push(`${iterations.length}. Interaction multiple-testing check: ${bestInter.a}:${bestInter.b} adjusted p=${fmtP(bonfInter)}.`);
+
+  // Iteration 24: subgroup confirmation of top main effect within strata of top interacting partner.
+  const partner = bestInter.a === bestMain.name ? bestInter.b : bestInter.a;
+  const focal = bestMain.name;
+  const h24 = hyp(`The main-effect direction for \`${focal}\` is consistent within strata of \`${partner}\`.`, "refined");
+  const subgroupAnalyses = [];
+  for (const level of [0, 1]) {
+    const idxY = [];
+    const idxX = [];
+    for (let i = 0; i < y.length; i++) {
+      if (columns[partner][i] === level) {
+        idxY.push(y[i]);
+        idxX.push(columns[focal][i]);
+      }
+    }
+    let res;
+    if (summaries[focal].numeric && summaries[focal].nUnique === 2) {
+      res = groupDiffTest(idxX, idxY, 1);
+    } else {
+      res = slopeTest(idxX, idxY);
+    }
+    subgroupAnalyses.push(
+      makeAnalysis(
+        h24.id,
+        `Within ${partner}=${level}, ${focal} effect was ${round(res.effect, 3)} months (n=${idxY.length}, p=${fmtP(res.p)}).`,
+        res.effect,
+        res.p,
+        `Stratified test of ${focal} within ${partner}=${level}`,
+        { test: "stratified_main_effect", variable: focal, stratum_variable: partner, stratum_value: level }
+      )
+    );
+  }
+  addIteration([h24], subgroupAnalyses);
+  narrative.push(`${iterations.length}. Stratified ${focal} by ${partner}: effects ${subgroupAnalyses.map(a => `${a.effect_estimate} months`).join(" and ")}.`);
+
+  // Iteration 25: composite high-risk score using top adverse main effects.
+  const adverse = topMain.filter(t => t.effect < 0).slice(0, 5);
+  const protective = topMain.filter(t => t.effect > 0).slice(0, 5);
+  const scoreFeatures = adverse.length >= 3 ? adverse.slice(0, 3) : topMain.slice(0, 3);
+  const score = Array(y.length).fill(0);
+  const scoreNames = [];
+  for (const t of scoreFeatures) {
+    scoreNames.push(t.name);
+    const vals = columns[t.name];
+    if (t.type === "binary") {
+      for (let i = 0; i < y.length; i++) score[i] += vals[i] === t.level ? 1 : 0;
+    } else if (t.type === "numeric") {
+      const m = mean(vals);
+      for (let i = 0; i < y.length; i++) score[i] += vals[i] > m ? 1 : 0;
+    } else {
+      for (let i = 0; i < y.length; i++) score[i] += vals[i] === t.level ? 1 : 0;
+    }
+  }
+  const scoreRes = slopeTest(score, y);
+  const h25 = hyp(`A simple count score composed of the top adverse features (${scoreNames.map(n => `\`${n}\``).join(", ")}) is negatively associated with \`pfs_months\`.`, "refined");
+  addIteration([h25], [
+    makeAnalysis(
+      h25.id,
+      `Each additional adverse-feature indicator in the ${scoreNames.join(", ")} score was associated with ${round(scoreRes.effect, 3)} months of pfs_months (p=${fmtP(scoreRes.p)}). Mean score=${round(mean(score), 3)}.`,
+      scoreRes.effect,
+      scoreRes.p,
+      `OLS: pfs_months ~ 1 + adverse_count_score(${scoreNames.join(", ")})`,
+      { test: "composite_score", variables: scoreNames }
+    ),
+  ]);
+  narrative.push(`${iterations.length}. Composite score ${scoreNames.join(", ")}: slope ${round(scoreRes.effect, 3)} months per indicator, p=${fmtP(scoreRes.p)}.`);
+
+  const transcript = {
+    dataset_id: "ds001_nsclc",
+    model_id: "gpt-5-codex",
+    harness_id: "codex-direct-parquet-js@1.0",
+    max_iterations: 25,
+    iterations,
+    dataset_profile: {
+      rows: meta.num_rows,
+      features: featureNames.length,
+      outcome: "pfs_months",
+      pfs_months_mean: round(yMean, 6),
+      pfs_months_sd: round(ySd, 6),
+      parquet_created_by: meta.created_by,
+    },
+    screened_tests: {
+      main_effect_tests: mainTests.length,
+      binary_binary_interactions: interactions.length,
+      numeric_binary_interactions: numBinInteractions.length,
+    },
+  };
+
+  const summaryLines = [];
+  summaryLines.push("Analysis summary for ds001_nsclc");
+  summaryLines.push("");
+  summaryLines.push(`Decoded 50,000 patient rows from dataset.parquet and analyzed pfs_months as the continuous outcome. Mean pfs_months was ${round(yMean, 3)} months (SD ${round(ySd, 3)}). I screened ${mainTests.length} univariable main-effect contrasts across 73 opaque features, then followed the strongest signals with adjusted OLS models, binary-binary interactions, numeric-by-binary interactions, subgroup checks, and multiple-testing corrections.`);
+  summaryLines.push("");
+  summaryLines.push("Main-effect findings:");
+  for (const t of topMain.slice(0, 8)) {
+    const d = describeMain(t);
+    summaryLines.push(`- ${d.summary}`);
+  }
+  summaryLines.push("");
+  summaryLines.push("Adjusted models:");
+  for (const t of topMain.slice(0, 4)) {
+    const adj = adjustedByName[t.name];
+    if (adj) summaryLines.push(`- ${t.name}: adjusted coefficient ${round(adj.effect, 3)} months, p=${fmtP(adj.p)}.`);
+  }
+  summaryLines.push("");
+  summaryLines.push("Interaction and subgroup findings:");
+  for (const it of topInteractions.slice(0, 6)) {
+    summaryLines.push(`- ${it.a} x ${it.b}: interaction coefficient ${round(it.effect, 3)} months, p=${fmtP(it.p)}.`);
+  }
+  for (const it of topNumBinInteractions.slice(0, 3)) {
+    summaryLines.push(`- Standardized ${it.a} x ${it.b}: interaction coefficient ${round(it.effect, 3)} months, p=${fmtP(it.p)}.`);
+  }
+  summaryLines.push(`- Strongest main effect Bonferroni check: ${bestMain.name} adjusted p=${fmtP(bonfMain)} over ${mainTests.length} main-effect tests.`);
+  summaryLines.push(`- Strongest binary-binary interaction Bonferroni check: ${bestInter.a} x ${bestInter.b} adjusted p=${fmtP(bonfInter)} over ${interactions.length} screened interactions.`);
+  summaryLines.push("");
+  summaryLines.push("Overall conclusion:");
+  const supported = iterations.flatMap(it => it.analyses).filter(a => a.significant).length;
+  const totalAnalyses = iterations.flatMap(it => it.analyses).length;
+  summaryLines.push(`The cohort contains several statistically strong treatment/biomarker-like feature associations with progression-free survival despite opaque feature labels. The largest supported univariable effects were carried by ${topMain.slice(0, 5).map(t => t.name).join(", ")}, and several remained independently associated after adjustment. Interaction testing suggested that the relationship between some feature pairs and pfs_months is not purely additive, especially ${bestInter.a} with ${bestInter.b}. Out of ${totalAnalyses} recorded analyses across 25 iterations, ${supported} were significant at p<0.05; results with very small p-values also survived conservative Bonferroni checks. Because the features are de-identified, these results should be interpreted as statistical treatment-biomarker-outcome patterns rather than named clinical mechanisms.`);
+
+  fs.writeFileSync("transcript.json", JSON.stringify(transcript, null, 2));
+  fs.writeFileSync("analysis_summary.txt", summaryLines.join("\n") + "\n");
+
+  console.log(JSON.stringify({
+    rows: meta.num_rows,
+    columns: Object.keys(columns).length,
+    yMean: round(yMean, 4),
+    ySd: round(ySd, 4),
+    topMain: topMain.slice(0, 10).map(t => ({ name: t.name, type: t.type, level: t.level, effect: round(t.effect, 4), p: fmtP(t.p), z: round(t.z, 2) })),
+    topInteractions: topInteractions.slice(0, 5).map(t => ({ a: t.a, b: t.b, effect: round(t.effect, 4), p: fmtP(t.p), z: round(t.z, 2) })),
+    iterations: iterations.length,
+  }, null, 2));
+}
+
+main();

