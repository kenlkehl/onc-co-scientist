+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    yty += y[i] * y[i];
+    for (let j = 0; j < p; j++) {
+      const xj = cols[j][i];
+      xty[j] += xj * y[i];
+      for (let k = 0; k <= j; k++) xtx[j][k] += xj * cols[k][i];
+    }
