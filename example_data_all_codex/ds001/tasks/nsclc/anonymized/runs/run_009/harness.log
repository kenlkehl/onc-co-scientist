+  readI16() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI32() {
+    return Number(this.zigzag(this.readVarint()));
+  }
+
+  readI64() {
+    return this.zigzag(this.readVarint());
+  }
+
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.off);
+    this.off += 8;
+    return v;
+  }
+
+  readBinary() {
+    const len = Number(this.readVarint());
+    const s = this.buf.subarray(this.off, this.off + len);
+    this.off += len;
+    return s;
+  }
+
+  readString() {
+    return this.readBinary().toString("utf8");
+  }
+
+  readListHeader() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const type = b & 0x0f;
