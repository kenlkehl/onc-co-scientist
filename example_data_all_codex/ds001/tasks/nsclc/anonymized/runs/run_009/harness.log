+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m1 = s1 / n1;
+  const m0 = s0 / n0;
+  const v1 = (ss1 - (s1 * s1) / n1) / (n1 - 1);
+  const v0 = (ss0 - (s0 * s0) / n0) / (n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: twoSidedPFromZ(z), n1, n0, m1, m0, se, z };
+}
+
+function slopeTest(x, y) {
+  const n = y.length;
+  let sx = 0, sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n, my = sy / n;
+  let sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx, dy = y[i] - my;
+    sxx += dx * dx;
+    sxy += dx * dy;
+    syy += dy * dy;
+  }
+  const beta = sxy / sxx;
+  const alpha = my - beta * mx;
+  const rss = syy - beta * sxy;
+  const sigma2 = rss / (n - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = beta / se;
+  const r = sxy / Math.sqrt(sxx * syy);
+  return { effect: beta, p: twoSidedPFromZ(z), n, meanX: mx, meanY: my, se, z, r, alpha };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => {
+    const out = row.slice();
+    for (let j = 0; j < n; j++) out.push(i === j ? 1 : 0);
+    return out;
+  });
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== i) [m[i], m[pivot]] = [m[pivot], m[i]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = m[r][i];
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= factor * m[i][c];
+    }
+  }
+  return m.map(row => row.slice(n));
+}
+
+function olsFromColumns(cols, y) {
+  const n = y.length;
+  const p = cols.length;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    yty += y[i] * y[i];
+    for (let j = 0; j < p; j++) {
+      const xj = cols[j][i];
+      xty[j] += xj * y[i];
+      for (let k = 0; k <= j; k++) xtx[j][k] += xj * cols[k][i];
+    }
+  }
+  for (let j = 0; j < p; j++) for (let k = j + 1; k < p; k++) xtx[j][k] = xtx[k][j];
+  const inv = invertMatrix(xtx);
+  const beta = Array(p).fill(0);
+  for (let j = 0; j < p; j++) for (let k = 0; k < p; k++) beta[j] += inv[j][k] * xty[k];
+  let bxty = 0;
+  for (let j = 0; j < p; j++) bxty += beta[j] * xty[j];
+  const rss = yty - bxty;
+  const sigma2 = rss / (n - p);
+  const se = beta.map((_, j) => Math.sqrt(Math.max(0, sigma2 * inv[j][j])));
+  const z = beta.map((b, j) => b / se[j]);
+  const pvals = z.map(twoSidedPFromZ);
+  return { beta, se, z, p: pvals, rss, sigma2, n, pCount: p };
+}
+
+function uniqueValues(arr) {
+  const counts = new Map();
+  for (const v of arr) counts.set(v, (counts.get(v) || 0) + 1);
+  return [...counts.entries()].sort((a, b) => b[1] - a[1]);
+}
+
+function isNumericArray(arr) {
+  return typeof arr[0] === "number";
+}
+
+function round(x, digits = 6) {
+  if (!Number.isFinite(x)) return x;
+  return Number(x.toFixed(digits));
+}
+
+function fmtP(p) {
+  if (p === 0) return "<1e-16";
+  if (p < 1e-4) return p.toExponential(2);
+  return p.toPrecision(3);
+}
+
+function bonf(p, m) {
+  return Math.min(1, p * m);
+}
+
+function codeSnippet(test) {
+  return test;
+}
+
+function makeAnalysis(hids, summary, effect, p, code, extra = {}) {
+  return {
+    hypothesis_ids: Array.isArray(hids) ? hids : [hids],
+    code,
+    result_summary: summary,
+    p_value: p === null ? null : round(p, 12),
+    effect_estimate: effect === null ? null : round(effect, 6),
+    significant: p === null ? null : p < 0.05,
+    ...extra,
+  };
+}
