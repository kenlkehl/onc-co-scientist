+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+};
+
+class CompactReader {
+  constructor(buffer, offset = 0, limit = buffer.length) {
+    this.buf = buffer;
+    this.off = offset;
+    this.limit = limit;
+  }
+
+  readByte() {
+    return this.buf[this.off++];
+  }
