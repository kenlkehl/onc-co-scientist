+  const strongFeatures = mainTests.slice(0, 20).map(t => t.name);
+  const binaryStrong = mainTests.filter(t => t.type === "binary").slice(0, 20).map(t => t.name);
+  const numericStrong = mainTests.filter(t => t.type === "numeric").slice(0, 20).map(t => t.name);
+
+  const interactions = [];
+  const candidateBinary = [...new Set([...binaryStrong, ...binary.slice(0, 40)])].slice(0, 40);
+  for (let a = 0; a < candidateBinary.length; a++) {
+    for (let b = a + 1; b < candidateBinary.length; b++) {
+      const n1 = candidateBinary[a], n2 = candidateBinary[b];
+      const x1 = columns[n1], x2 = columns[n2];
+      const fit = binaryInteractionTest(x1, x2, y);
+      if (fit) interactions.push({ a: n1, b: n2, effect: fit.effect, p: fit.p, z: fit.z, se: fit.se, means: fit.means, n: fit.n });
+    }
+  }
+  interactions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const numBinInteractions = [];
+  for (const n1 of numericStrong.slice(0, 10)) {
+    const xRaw = columns[n1];
+    const mx = mean(xRaw);
+    const sx = Math.sqrt(variance(xRaw, mx));
+    const x = xRaw.map(v => (v - mx) / sx);
+    for (const n2 of binaryStrong.slice(0, 15)) {
+      const b = columns[n2];
+      const fit = numericBinaryInteractionTest(x, b, y);
+      if (fit) numBinInteractions.push({ a: n1, b: n2, effect: fit.effect, p: fit.p, z: fit.z, se: fit.se, scaled: true, slopes: fit.slopes });
+    }
+  }
+  numBinInteractions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const topMain = mainTests.slice(0, 12);
+  const topInteractions = interactions.slice(0, 8);
+  const topNumBinInteractions = numBinInteractions.slice(0, 5);
+
+  // Build several focused multivariable models for important main effects.
+  const selectedBinary = [...new Set(mainTests.filter(t => t.type === "binary").slice(0, 10).map(t => t.name))];
+  const selectedNumeric = [...new Set(mainTests.filter(t => t.type === "numeric").slice(0, 8).map(t => t.name))];
+  const scaledNumeric = {};
+  for (const name of selectedNumeric) {
+    const arr = columns[name];
+    const m = mean(arr);
+    const sd = Math.sqrt(variance(arr, m));
+    scaledNumeric[name] = arr.map(v => (v - m) / sd);
+  }
+  const adjustmentCols = [
+    Array(y.length).fill(1),
+    ...selectedBinary.map(name => columns[name]),
+    ...selectedNumeric.map(name => scaledNumeric[name]),
+  ];
+  const adjustmentNames = ["Intercept", ...selectedBinary, ...selectedNumeric.map(name => `${name}_z`)];
+  const adjustedFit = olsFromColumns(adjustmentCols, y);
+  const adjustedByName = {};
+  for (let i = 1; i < adjustmentNames.length; i++) {
+    adjustedByName[adjustmentNames[i].replace("_z", "")] = {
+      effect: adjustedFit.beta[i],
+      p: adjustedFit.p[i],
+      z: adjustedFit.z[i],
+      se: adjustedFit.se[i],
+    };
+  }
+
+  const iterations = [];
+  const narrative = [];
+  let hid = 1;
+
+  function addIteration(hypotheses, analyses) {
+    iterations.push({
+      index: iterations.length + 1,
+      proposed_hypotheses: hypotheses,
+      analyses,
+    });
+  }
+
+  function hyp(text, kind = "novel") {
+    const h = { id: `h${hid++}`, text, kind };
+    return h;
+  }
+
+  function describeMain(t) {
+    if (t.type === "binary") {
+      return {
+        hypothesis: `Patients with \`${t.name}\` equal to ${t.level} have ${t.effect > 0 ? "higher" : "lower"} mean \`pfs_months\` than patients with the other value of \`${t.name}\`.`,
+        summary: `Mean pfs_months was ${round(t.m1, 3)} for ${t.name}=${t.level} (n=${t.n1}) vs ${round(t.m0, 3)} otherwise (n=${t.n0}); difference=${round(t.effect, 3)} months, p=${fmtP(t.p)}.`,
+        code: `Welch test: mean(pfs_months | ${t.name}=${t.level}) - mean(pfs_months | ${t.name}!=${t.level})`,
+      };
+    }
+    if (t.type === "numeric") {
+      return {
+        hypothesis: `Higher values of \`${t.name}\` are associated with ${t.effect > 0 ? "higher" : "lower"} \`pfs_months\` in a univariable linear regression.`,
+        summary: `Univariable slope for ${t.name} was ${round(t.effect, 4)} months per unit (r=${round(t.r, 4)}), p=${fmtP(t.p)}.`,
+        code: `OLS: pfs_months ~ 1 + ${t.name}`,
+      };
+    }
