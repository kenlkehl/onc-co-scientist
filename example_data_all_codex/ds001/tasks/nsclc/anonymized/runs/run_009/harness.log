+    const obj = {};
+    while (true) {
+      const hb = this.readByte();
+      if (hb === 0) break;
+      const delta = hb >> 4;
+      const type = hb & 0x0f;
+      const fid = delta ? last + delta : this.readI16();
+      last = fid;
