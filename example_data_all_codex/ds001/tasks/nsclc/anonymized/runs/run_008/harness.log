import pandas as pd
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('\\ndtypes')
print(df.dtypes.to_string())
print('\\noutcome summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
print('\\nfeature summaries')
rows=[]
for c in df.columns:
    if c=='pfs_months': continue
    s=df[c]
    rows.append((c, str(s.dtype), int(s.nunique()), float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, float(s.std()) if pd.api.types.is_numeric_dtype(s) else None, s.min(), s.max()))
for r in rows:
    print('\\t'.join(map(str,r)))
