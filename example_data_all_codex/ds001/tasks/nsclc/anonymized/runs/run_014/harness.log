+const fs = require("fs");
+
+const FILE = "dataset.parquet";
+const N = 50000;
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const b = this.buf[this.pos++];
+      out |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return out;
+      shift += 7n;
+    }
+  }
+  readInt() {
+    const n = this.readVarint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.buf.subarray(this.pos, this.pos + len).toString("utf8");
+    this.pos += len;
+    return out;
+  }
+  readList() {
+    const h = this.buf[this.pos++];
+    let n = h >> 4;
+    const t = h & 0x0f;
+    if (n === 15) n = Number(this.readVarint());
+    const out = [];
+    for (let i = 0; i < n; i++) out.push(this.readValue(t));
+    return out;
+  }
+  readStruct() {
+    let last = 0;
+    const out = {};
+    while (true) {
+      const h = this.buf[this.pos++];
+      const t = h & 0x0f;
+      if (t === 0) return out;
+      const d = h >> 4;
+      const id = d ? last + d : this.readInt();
+      last = id;
+      out[id] = t === 1 ? true : t === 2 ? false : this.readValue(t);
+    }
+  }
+  readValue(t) {
+    switch (t) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3: {
+        const v = this.buf.readInt8(this.pos);
+        this.pos += 1;
+        return v;
+      }
+      case 4:
+      case 5:
+      case 6:
+        return this.readInt();
+      case 7: {
+        const v = this.buf.readDoubleLE(this.pos);
+        this.pos += 8;
+        return v;
+      }
+      case 8:
+        return this.readBinary();
+      case 9:
+      case 10:
+        return this.readList();
+      case 12:
+        return this.readStruct();
+      default:
+        throw new Error(`Unsupported compact thrift type ${t} at ${this.pos}`);
+    }
+  }
+}
+
+function snappyUncompress(input) {
+  let p = 0;
+  let shift = 0;
+  let outLen = 0;
+  while (true) {
+    const b = input[p++];
+    outLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(outLen);
+  let o = 0;
+  while (p < input.length) {
+    const tag = input[p++];
+    const kind = tag & 3;
+    if (kind === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[p++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, o, p, p + len);
+      p += len;
+      o += len;
+    } else {
+      let len;
+      let offset;
+      if (kind === 1) {
+        len = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[p++];
+      } else if (kind === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[p] | (input[p + 1] << 8);
+        p += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset =
+          input[p] |
+          (input[p + 1] << 8) |
+          (input[p + 2] << 16) |
+          (input[p + 3] << 24);
+        p += 4;
+      }
+      for (let i = 0; i < len; i++) out[o] = out[o++ - offset];
+    }
+  }
+  if (o !== outLen) throw new Error(`Snappy length mismatch ${o} != ${outLen}`);
+  return out;
+}
+
+function decodeHybrid(buf, pos, bitWidth, nValues) {
+  const values = [];
+  while (values.length < nValues) {
+    let shift = 0;
+    let header = 0;
+    while (true) {
+      const b = buf[pos++];
+      header |= (b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7;
+    }
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      let v = 0;
+      const bytes = Math.ceil(bitWidth / 8);
+      for (let i = 0; i < bytes; i++) v |= buf[pos++] << (8 * i);
+      const take = Math.min(run, nValues - values.length);
+      for (let i = 0; i < take; i++) values.push(v);
+    } else {
+      const groups = header >> 1;
+      const total = groups * 8;
+      const byteLen = Math.ceil((total * bitWidth) / 8);
+      let bitPos = 0;
+      for (let i = 0; i < total; i++) {
+        let v = 0;
+        for (let b = 0; b < bitWidth; b++) {
+          const byte = buf[pos + (bitPos >> 3)];
+          v |= ((byte >> (bitPos & 7)) & 1) << b;
+          bitPos++;
+        }
+        if (values.length < nValues) values.push(v);
+      }
+      pos += byteLen;
+    }
+  }
+  return { values, pos };
+}
+
+function decodePlainDictionary(buf, parquetType, n) {
+  const out = [];
+  let p = 0;
+  for (let i = 0; i < n; i++) {
+    if (parquetType === 2) {
+      out.push(Number(buf.readBigInt64LE(p)));
+      p += 8;
+    } else if (parquetType === 5) {
+      out.push(buf.readDoubleLE(p));
+      p += 8;
+    } else if (parquetType === 6) {
+      const len = buf.readInt32LE(p);
+      p += 4;
+      out.push(buf.subarray(p, p + len).toString("utf8"));
+      p += len;
+    } else if (parquetType === 1) {
+      out.push(buf.readInt32LE(p));
+      p += 4;
+    } else {
+      throw new Error(`Unsupported Parquet type ${parquetType}`);
+    }
+  }
+  return out;
+}
+
+function readFooter(file) {
+  const footerLen = file.readUInt32LE(file.length - 8);
+  const start = file.length - 8 - footerLen;
+  const reader = new CompactReader(file.subarray(start, file.length - 8));
+  return reader.readStruct();
+}
+
+function readColumn(file, colMeta) {
+  const md = colMeta[3];
+  const parquetType = md[1];
+  let off = md[11] || md[9];
+  let dict = null;
+  const out = [];
+  while (out.length < md[5]) {
+    const reader = new CompactReader(file, off);
+    const header = reader.readStruct();
+    const bodyStart = reader.pos;
+    const body = snappyUncompress(file.subarray(bodyStart, bodyStart + header[3]));
+    off = bodyStart + header[3];
+    if (header[1] === 2) {
+      dict = decodePlainDictionary(body, parquetType, header[7][1]);
+      continue;
+    }
+    if (header[1] !== 0) throw new Error(`Unsupported page type ${header[1]}`);
+    const dph = header[5];
+    const n = dph[1];
+    const defBytes = body.readUInt32LE(0);
+    const defs = decodeHybrid(body, 4, 1, n);
+    const present = defs.values.filter((v) => v === 1).length;
+    if (present !== n) throw new Error("Unexpected null definition level");
+    let p = 4 + defBytes;
+    if (dph[2] === 8) {
+      const bitWidth = body[p++];
+      const decoded = decodeHybrid(body, p, bitWidth, present);
+      for (const idx of decoded.values) out.push(dict[idx]);
+    } else if (dph[2] === 0) {
+      const vals = decodePlainDictionary(body.subarray(p), parquetType, present);
+      out.push(...vals);
+    } else {
+      throw new Error(`Unsupported data encoding ${dph[2]}`);
+    }
+  }
+  return out;
+}
+
+function loadTable() {
+  const file = fs.readFileSync(FILE);
+  const footer = readFooter(file);
+  const columns = footer[4][0][1];
+  const table = {};
+  const schema = footer[2].slice(1).map((s) => s[4]);
+  columns.forEach((col, i) => {
+    const name = col[3][3][0];
+    if (name === "patient_id") return;
+    table[name] = readColumn(file, col);
+  });
+  return { table, schema: schema.filter((s) => s !== "patient_id") };
+}
+
+function mean(x) {
+  return x.reduce((a, b) => a + b, 0) / x.length;
+}
+
+function variance(x) {
+  const m = mean(x);
+  let s = 0;
+  for (const v of x) s += (v - m) * (v - m);
+  return s / (x.length - 1);
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erf(x / Math.SQRT2));
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y =
+    1 -
+    (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) *
+      t *
+      Math.exp(-x * x);
+  return sign * y;
+}
+
+function pFromZ(z) {
+  return Math.max(0, Math.min(1, 2 * (1 - normalCdf(Math.abs(z)))));
+}
+
+function regress(y, cols) {
+  const n = y.length;
+  const p = cols.length + 1;
+  const xtx = Array.from({ length: p }, () => Array(p).fill(0));
+  const xty = Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const c of cols) row.push(c[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invert(xtx);
+  const beta = inv.map((row) => row.reduce((s, v, j) => s + v * xty[j], 0));
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < cols.length; j++) pred += beta[j + 1] * cols[j][i];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const se = inv.map((row, i) => Math.sqrt(Math.max(0, sigma2 * row[i])));
+  const z = beta.map((b, i) => b / se[i]);
+  const pvals = z.map(pFromZ);
+  return { beta, se, pvals, rss, df: n - p };
+}
+
+function invert(a) {
+  const n = a.length;
+  const m = a.map((row, i) => [
+    ...row,
+    ...Array.from({ length: n }, (_, j) => (i === j ? 1 : 0)),
+  ]);
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error("Singular matrix");
+    if (pivot !== i) [m[pivot], m[i]] = [m[i], m[pivot]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = m[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= f * m[i][c];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function uniqueCounts(x) {
+  const map = new Map();
+  for (const v of x) map.set(v, (map.get(v) || 0) + 1);
+  return [...map.entries()].sort((a, b) => b[1] - a[1]);
+}
+
+function numericArray(x) {
+  return x.map((v) => Number(v));
+}
+
+function rankArray(x) {
+  const sorted = x.map((v, i) => [v, i]).sort((a, b) => a[0] - b[0]);
+  const ranks = Array(x.length);
+  for (let i = 0; i < sorted.length; ) {
+    let j = i + 1;
+    while (j < sorted.length && sorted[j][0] === sorted[i][0]) j++;
+    const r = (i + j + 1) / 2;
+    for (let k = i; k < j; k++) ranks[sorted[k][1]] = r;
+    i = j;
+  }
+  return ranks;
+}
+
+function subgroupDiff(y, g) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (g[i]) {
+      n1++;
+      s1 += y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+    }
+  }
+  return { n1, n0, mean1: s1 / n1, mean0: s0 / n0, diff: s1 / n1 - s0 / n0 };
+}
+
+function pearson(x, y) {
+  const mx = mean(x);
+  const my = mean(y);
+  let sxy = 0;
+  let sx = 0;
+  let sy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxy += dx * dy;
+    sx += dx * dx;
+    sy += dy * dy;
+  }
+  return sxy / Math.sqrt(sx * sy);
+}
+
+function quantile(x, q) {
+  const s = [...x].sort((a, b) => a - b);
+  const h = (s.length - 1) * q;
+  const lo = Math.floor(h);
+  const hi = Math.ceil(h);
+  return s[lo] + (s[hi] - s[lo]) * (h - lo);
+}
+
+function writeOutputs() {
+  const { table, schema } = loadTable();
+  const y = numericArray(table.pfs_months);
+  const features = schema.filter((c) => c !== "pfs_months");
+  const numeric = features.filter((c) => typeof table[c][0] === "number");
+  const strings = features.filter((c) => typeof table[c][0] === "string");
+  const profiles = {};
+  for (const c of features) profiles[c] = uniqueCounts(table[c]).slice(0, 8);
+
+  const yMean = mean(y);
+  const ySd = Math.sqrt(variance(y));
+  const main = [];
+  for (const c of numeric) {
+    const x = numericArray(table[c]);
+    const ux = uniqueCounts(x);
+    const res = regress(y, [x]);
+    main.push({
+      feature: c,
+      kind: ux.length <= 12 ? "discrete" : "continuous",
+      beta: res.beta[1],
+      se: res.se[1],
+      p: res.pvals[1],
+      unique: ux.length,
+      counts: ux.slice(0, 6),
+      mean: mean(x),
+      sd: Math.sqrt(variance(x)),
+      r: pearson(x, y),
+    });
+  }
+  for (const c of strings) {
+    const levels = uniqueCounts(table[c]);
+    if (levels.length === 2) {
+      const ref = levels[0][0];
+      const other = levels[1][0];
+      const x = table[c].map((v) => (v === other ? 1 : 0));
+      const res = regress(y, [x]);
+      main.push({
+        feature: c,
+        kind: "binary_string",
+        contrast: `${other} vs ${ref}`,
+        beta: res.beta[1],
+        se: res.se[1],
+        p: res.pvals[1],
+        unique: levels.length,
+        counts: levels,
+      });
+    } else {
+      for (const [lev] of levels) {
+        const x = table[c].map((v) => (v === lev ? 1 : 0));
+        const res = regress(y, [x]);
+        main.push({
+          feature: c,
+          kind: "categorical_indicator",
+          contrast: `${lev} vs all other ${c}`,
+          beta: res.beta[1],
+          se: res.se[1],
+          p: res.pvals[1],
+          unique: levels.length,
+          counts: levels,
+          level: lev,
+        });
+      }
+    }
+  }
+  main.sort((a, b) => Math.abs(b.beta / b.se) - Math.abs(a.beta / a.se));
+
+  const ranked = main.slice(0, 12).map((m) => m.feature);
+  const uniqueRanked = [...new Set(ranked)];
+  const multCols = uniqueRanked.map((c) => {
+    if (typeof table[c][0] === "number") return numericArray(table[c]);
+    const levels = uniqueCounts(table[c]);
+    return table[c].map((v) => (v === levels[levels.length - 1][0] ? 1 : 0));
+  });
+  const mult = regress(y, multCols);
+
+  const interactions = [];
+  const candidates = [...new Set(main.slice(0, 16).map((m) => m.feature))];
+  for (let a = 0; a < candidates.length; a++) {
+    for (let b = a + 1; b < candidates.length; b++) {
+      const ca = candidates[a];
+      const cb = candidates[b];
+      let xa = typeof table[ca][0] === "number" ? numericArray(table[ca]) : table[ca].map((v) => (v === uniqueCounts(table[ca]).at(-1)[0] ? 1 : 0));
+      let xb = typeof table[cb][0] === "number" ? numericArray(table[cb]) : table[cb].map((v) => (v === uniqueCounts(table[cb]).at(-1)[0] ? 1 : 0));
+      const ua = uniqueCounts(xa).length;
+      const ub = uniqueCounts(xb).length;
+      if (ua > 12) {
+        const mx = mean(xa);
+        const sx = Math.sqrt(variance(xa));
+        xa = xa.map((v) => (v - mx) / sx);
+      }
+      if (ub > 12) {
+        const mx = mean(xb);
+        const sx = Math.sqrt(variance(xb));
+        xb = xb.map((v) => (v - mx) / sx);
+      }
+      const xab = xa.map((v, i) => v * xb[i]);
+      try {
+        const res = regress(y, [xa, xb, xab]);
+        interactions.push({
+          a: ca,
+          b: cb,
+          beta: res.beta[3],
+          se: res.se[3],
+          p: res.pvals[3],
+          pMainA: res.pvals[1],
+          pMainB: res.pvals[2],
+        });
+      } catch (_) {}
+    }
+  }
+  interactions.sort((a, b) => Math.abs(b.beta / b.se) - Math.abs(a.beta / a.se));
+
+  const subgroups = [];
+  const disc = numeric.filter((c) => uniqueCounts(table[c]).length <= 8);
+  const contTop = numeric
+    .filter((c) => uniqueCounts(table[c]).length > 12)
+    .map((c) => ({ c, z: Math.abs(main.find((m) => m.feature === c)?.beta || 0) }))
+    .sort((a, b) => b.z - a.z)
+    .slice(0, 10)
+    .map((o) => o.c);
+  for (const c of disc) {
+    const x = numericArray(table[c]);
+    const ux = uniqueCounts(x).map((v) => v[0]);
+    if (ux.includes(0) && ux.includes(1)) {
+      const g = x.map((v) => v === 1);
+      const d = subgroupDiff(y, g);
+      const res = regress(y, [g.map(Number)]);
+      subgroups.push({ feature: c, group: "1 vs 0", ...d, beta: res.beta[1], p: res.pvals[1] });
+    }
+  }
+  for (const c of contTop) {
+    const x = numericArray(table[c]);
+    const q25 = quantile(x, 0.25);
+    const q75 = quantile(x, 0.75);
+    const g = x.map((v) => v >= q75);
+    const base = x.map((v) => v <= q25);
+    let n1 = 0, n0 = 0, s1 = 0, s0 = 0;
+    for (let i = 0; i < y.length; i++) {
+      if (g[i]) { n1++; s1 += y[i]; }
+      else if (base[i]) { n0++; s0 += y[i]; }
+    }
+    const highLow = y.map((_, i) => (g[i] ? 1 : base[i] ? 0 : NaN));
+    const yy = [], xx = [];
+    for (let i = 0; i < y.length; i++) if (!Number.isNaN(highLow[i])) { yy.push(y[i]); xx.push(highLow[i]); }
+    const res = regress(yy, [xx]);
+    subgroups.push({ feature: c, group: "top quartile vs bottom quartile", n1, n0, mean1: s1 / n1, mean0: s0 / n0, diff: s1 / n1 - s0 / n0, beta: res.beta[1], p: res.pvals[1], q25, q75 });
+  }
+  subgroups.sort((a, b) => Math.abs(b.beta) - Math.abs(a.beta));
+
+  const ranksY = rankArray(y);
+  const spearman = numeric
+    .filter((c) => uniqueCounts(table[c]).length > 12)
+    .map((c) => {
+      const rx = rankArray(numericArray(table[c]));
+      const r = pearson(rx, ranksY);
+      const z = r * Math.sqrt((N - 2) / Math.max(1e-12, 1 - r * r));
+      return { feature: c, rho: r, p: pFromZ(z) };
+    })
+    .sort((a, b) => Math.abs(b.rho) - Math.abs(a.rho));
+
+  const payload = {
+    yMean,
+    ySd,
+    profiles,
+    main,
+    uniqueRanked,
+    mult: uniqueRanked.map((feature, i) => ({
+      feature,
+      beta: mult.beta[i + 1],
+      se: mult.se[i + 1],
+      p: mult.pvals[i + 1],
+    })),
+    interactions,
+    subgroups,
+    spearman,
+    stringFeatures: strings.map((c) => ({ feature: c, counts: uniqueCounts(table[c]) })),
+  };
+  fs.writeFileSync("analysis_results.json", JSON.stringify(payload, null, 2));
+  console.log(JSON.stringify({
+    n: N,
+    outcome: { mean: yMean, sd: ySd },
+    top_main: main.slice(0, 15),
+    top_interactions: interactions.slice(0, 12),
+    top_subgroups: subgroups.slice(0, 12),
+    top_spearman: spearman.slice(0, 8),
+    strings: payload.stringFeatures,
+  }, null, 2));
+}
+
+writeOutputs();

diff --git a/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/nsclc/anonymized/analyze_dataset.js b/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/nsclc/anonymized/analyze_dataset.js
new file mode 100644
index 0000000000000000000000000000000000000000..eae48f1d03f579a600132f18279712f0d92997a4
--- /dev/null
+++ b/C:/Users/klkehl/are_llms_biased/data/ds001/tasks/nsclc/anonymized/analyze_dataset.js
@@ -0,0 +1,606 @@
+const fs = require("fs");
+
+const FILE = "dataset.parquet";
+const N = 50000;
+
+class CompactReader {
+  constructor(buf, pos = 0) {
+    this.buf = buf;
+    this.pos = pos;
+  }
+  readVarint() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const b = this.buf[this.pos++];
+      out |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) return out;
+      shift += 7n;
+    }
+  }
+  readInt() {
+    const n = this.readVarint();
+    return Number((n >> 1n) ^ (-(n & 1n)));
+  }
+  readBinary() {
+    const len = Number(this.readVarint());
+    const out = this.buf.subarray(this.pos, this.pos + len).toString("utf8");
+    this.pos += len;
+    return out;
+  }
+  readList() {
+    const h = this.buf[this.pos++];
+    let n = h >> 4;
+    const t = h & 0x0f;
+    if (n === 15) n = Number(this.readVarint());
+    const out = [];
+    for (let i = 0; i < n; i++) out.push(this.readValue(t));
+    return out;
+  }
+  readStruct() {
+    let last = 0;
+    const out = {};
+    while (true) {
+      const h = this.buf[this.pos++];
+      const t = h & 0x0f;
+      if (t === 0) return out;
+      const d = h >> 4;
+      const id = d ? last + d : this.readInt();
+      last = id;
+      out[id] = t === 1 ? true : t === 2 ? false : this.readValue(t);
+    }
+  }
+  readValue(t) {
+    switch (t) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3: {
+        const v = this.buf.readInt8(this.pos);
+        this.pos += 1;
+        return v;
+      }
+      case 4:
+      case 5:
+      case 6:
+        return this.readInt();
+      case 7: {
+        const v = this.buf.readDoubleLE(this.pos);
+        this.pos += 8;
+        return v;
+      }
+      case 8:
+        return this.readBinary();
+      case 9:
+      case 10:
+        return this.readList();
+      case 12:
+        return this.readStruct();
+      default:
+        throw new Error(`Unsupported compact thrift type ${t} at ${this.pos}`);
+    }
+  }
+}
+
+function snappyUncompress(input) {
+  let p = 0;
+  let shift = 0;
+  let outLen = 0;
+  while (true) {
+    const b = input[p++];
+    outLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(outLen);
+  let o = 0;
+  while (p < input.length) {
+    const tag = input[p++];
+    const kind = tag & 3;
