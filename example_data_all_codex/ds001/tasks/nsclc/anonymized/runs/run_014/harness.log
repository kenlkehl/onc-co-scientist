+}
+
+function pearson(x, y) {
+  const mx = mean(x);
+  const my = mean(y);
+  let sxy = 0;
+  let sx = 0;
+  let sy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxy += dx * dy;
+    sx += dx * dx;
+    sy += dy * dy;
+  }
+  return sxy / Math.sqrt(sx * sy);
+}
