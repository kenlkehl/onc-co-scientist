import pandas as pd
import numpy as np
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
rows=[]
for c in df.columns:
    if c=='pfs_months': continue
    s=df[c]
    nun=s.nunique(dropna=False)
    vals=s.value_counts().head(10).to_dict() if nun<=10 else None
    rows.append((c, str(s.dtype), nun, float(s.mean()) if np.issubdtype(s.dtype, np.number) else None, float(s.std()) if np.issubdtype(s.dtype, np.number) else None, vals))
for r in rows:
    print(r)
