+      analysis(["h31"], `Adjusted OLS estimated ${rnd(f073a.beta, 6)} months per 1-unit increase in feature_073 (${ptxt(f073a.p)}), not significant.`, f073a.beta, f073a.p),
+    ],
+    update: "Most secondary continuous variables had negligible effects compared with the leading features.",
+  },
