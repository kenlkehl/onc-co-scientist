+      feature: c,
+      kind: ux.length <= 12 ? "discrete" : "continuous",
+      beta: res.beta[1],
+      se: res.se[1],
+      p: res.pvals[1],
+      unique: ux.length,
+      counts: ux.slice(0, 6),
+      mean: mean(x),
+      sd: Math.sqrt(variance(x)),
+      r: pearson(x, y),
+    });
