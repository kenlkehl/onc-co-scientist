+const fs = require("fs");
+
+const r = JSON.parse(fs.readFileSync("analysis_results.json", "utf8"));
+
+const floorP = (p) => (p === 0 ? 1e-300 : p);
+const sig = (p) => floorP(p) < 0.05;
+const ptxt = (p) => (p === 0 || p <= 1e-300 ? "p<1e-300" : `p=${Number(p).toPrecision(3)}`);
+const rnd = (x, d = 3) => Number(x).toFixed(d);
+
+function main(feature, pred = () => true) {
+  const m = r.main.find((x) => x.feature === feature && pred(x));
+  if (!m) throw new Error(`missing main ${feature}`);
+  return m;
+}
+function sub(feature, pred = () => true) {
+  const s = r.subgroups.find((x) => x.feature === feature && pred(x));
+  if (!s) throw new Error(`missing subgroup ${feature}`);
+  return s;
