+      analysis(["h29"], `The feature_041-by-feature_056 interaction was +${rnd(ti("feature_041:feature_056_raw").beta, 5)} months per feature_041-by-feature_056 unit (${ptxt(ti("feature_041:feature_056_raw").p)}).`, ti("feature_041:feature_056_raw").beta, ti("feature_041:feature_056_raw").p),
