+    "feature_041",
+    "feature_036",
+    "feature_001",
+    "feature_042",
+    "feature_015=squamous",
+    "feature_025=current",
+    "feature_025=never",
+    "feature_004",
+    "feature_010",
+    "feature_056",
+    "feature_057",
+    "feature_009",
+    "feature_037",
+    "feature_028",
+    "feature_066",
+    "feature_051",
+    "feature_073",
