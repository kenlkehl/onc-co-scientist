+    ],
+    update: "`feature_037` also modified feature_009, so I checked whether feature_057 acted similarly.",
+  },
+  {
+    index: 19,
+    proposed_hypotheses: [
+      hyp("h25", "`feature_057=1` weakens the positive association between `feature_010=1` and `pfs_months`.", "refined"),
+    ],
+    analyses: [
+      analysis(["h25"], `The feature_010-by-feature_057 interaction was ${rnd(ti("feature_010:feature_057").beta)} months (${ptxt(ti("feature_010:feature_057").p)}). The feature_010=1/feature_057=1 cell averaged only 2.316 months.`, ti("feature_010:feature_057").beta, ti("feature_010:feature_057").p),
+    ],
+    update: "`feature_057` had little independent adjusted main effect but had clear interaction behavior.",
+  },
+  {
+    index: 20,
+    proposed_hypotheses: [
+      hyp("h26", "`feature_057=1` weakens or reverses the positive association between `feature_009=1` and `pfs_months`.", "refined"),
+    ],
+    analyses: [
+      analysis(["h26"], `The feature_057-by-feature_009 interaction was ${rnd(ti("feature_057:feature_009").beta)} months (${ptxt(ti("feature_057:feature_009").p)}). Feature_009=1 was favorable when feature_057=0 but not when feature_057=1.`, ti("feature_057:feature_009").beta, ti("feature_057:feature_009").p),
+    ],
+    update: "The interaction results suggested subgroup heterogeneity rather than one uniform feature_057 main effect.",
