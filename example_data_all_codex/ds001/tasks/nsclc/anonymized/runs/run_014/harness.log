+const floorP = (p) => (p === 0 ? 1e-300 : p);
+const sig = (p) => floorP(p) < 0.05;
+const ptxt = (p) => (p === 0 || p <= 1e-300 ? "p<1e-300" : `p=${Number(p).toPrecision(3)}`);
+const rnd = (x, d = 3) => Number(x).toFixed(d);
+
+function main(feature, pred = () => true) {
+  const m = r.main.find((x) => x.feature === feature && pred(x));
+  if (!m) throw new Error(`missing main ${feature}`);
+  return m;
+}
+function sub(feature, pred = () => true) {
+  const s = r.subgroups.find((x) => x.feature === feature && pred(x));
+  if (!s) throw new Error(`missing subgroup ${feature}`);
+  return s;
+}
+function adj(feature) {
+  const a = r.adjusted.find((x) => x.feature === feature);
+  if (!a) throw new Error(`missing adjusted ${feature}`);
+  return a;
+}
+function ti(key) {
+  const x = r.targetedInteractions[key];
+  if (!x) throw new Error(`missing interaction ${key}`);
+  return x;
+}
+function analysis(hypothesis_ids, result_summary, effect_estimate, p_value, extra = {}) {
+  return {
+    hypothesis_ids,
+    result_summary,
+    p_value: floorP(p_value),
+    effect_estimate,
+    significant: sig(p_value),
+    ...extra,
+  };
+}
+function hyp(id, text, kind = "novel") {
+  return { id, text, kind };
+}
