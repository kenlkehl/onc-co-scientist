+function snappyUncompress(input) {
+  let p = 0;
+  let shift = 0;
+  let outLen = 0;
+  while (true) {
+    const b = input[p++];
+    outLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(outLen);
+  let o = 0;
+  while (p < input.length) {
+    const tag = input[p++];
+    const kind = tag & 3;
+    if (kind === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[p++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, o, p, p + len);
+      p += len;
+      o += len;
+    } else {
+      let len;
+      let offset;
+      if (kind === 1) {
+        len = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[p++];
+      } else if (kind === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[p] | (input[p + 1] << 8);
+        p += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset =
