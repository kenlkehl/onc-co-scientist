"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
const fs = require('fs');
const buf = fs.readFileSync('dataset.parquet');
function u32le(pos){ return buf.readUInt32LE(pos); }
const len = buf.length;
console.log('len', len, 'magic start', buf.subarray(0,4).toString(), 'magic end', buf.subarray(len-4).toString());
const footerLen = u32le(len-8);
console.log('footerLen', footerLen, 'footerStart', len-8-footerLen);
const fbuf = buf.subarray(len-8-footerLen, len-8);
let pos=0;
const T={STOP:0,TRUE:1,FALSE:2,BYTE:3,I16:4,I32:5,I64:6,DOUBLE:7,BINARY:8,LIST:9,SET:10,MAP:11,STRUCT:12};
function readVarint(){ let shift=0, result=0n; while(true){ const b=fbuf[pos++]; result |= BigInt(b & 0x7f) << BigInt(shift); if((b & 0x80)===0) break; shift += 7; } return result; }
function zigzag(n){ return (n >> 1n) "'^ (-(n & 1n)); }
function toNum(n){ return Number(n); }
function readInt(){ return toNum(zigzag(readVarint())); }
function readBinary(){ const l=Number(readVarint()); const s=fbuf.subarray(pos,pos+l).toString('"'utf8'); pos+=l; return s; }
function skip(type){ readValue(type); }
function readList(){ const b=fbuf[pos++]; let size=b>>4; const etype=b&0x0f; if(size===15) size=Number(readVarint()); const arr=[]; for(let i=0;i<size;i++) arr.push(readValue(etype)); return arr; }
function readMap(){ const size=Number(readVarint()); if(size===0) return []; const b=fbuf[pos++]; const kt=b>>4, vt=b&0x0f; const arr=[]; for(let i=0;i<size;i++) arr.push([readValue(kt), readValue(vt)]); return arr; }
function readStruct(){ let last=0; const obj={}; while(true){ const h=fbuf[pos++]; const type=h&0x0f; if(type===0) break; const delta=h>>4; let fid; if(delta===0) fid=readInt(); else fid=last+delta; last=fid; if(type===T.TRUE) obj[fid]=true; else if(type===T.FALSE) obj[fid]=false; else obj[fid]=readValue(type); } return obj; }
function readValue(type){ switch(type){ case T.TRUE: return true; case T.FALSE: return false; case T.BYTE: {let v=fbuf.readInt8(pos); pos++; return v;} case T.I16: case T.I32: case T.I64: return readInt(); case T.DOUBLE: {let v=fbuf.readDoubleLE(pos); pos+=8; return v;} case T.BINARY: return readBinary(); case T.LIST: case T.SET: return readList(); case T.MAP: return readMap(); case T.STRUCT: return readStruct(); default: throw new Error('type '+type+' at '+pos); } }
const meta=readStruct();
console.log('parsed pos', pos, 'footer bytes', fbuf.length);
console.log('version', meta[1], 'num_rows', meta[3], 'created_by', meta[6]);
const schema=meta[2];
console.log('schema len', schema.length);
for(let i=0;i<schema.length;i++){ const e=schema[i]; console.log(i, {name:e[4], type:e[1], repetition:e[3], num_children:e[5], converted:e[6], logical:e[10]}); }
const rowgroups=meta[4];
console.log('rowgroups', rowgroups.length);
for(let r=0;r<rowgroups.length;r++){
