+  readValue(t) {
+    switch (t) {
+      case 1:
+        return true;
+      case 2:
+        return false;
+      case 3: {
+        const v = this.buf.readInt8(this.pos);
+        this.pos += 1;
+        return v;
+      }
+      case 4:
+      case 5:
+      case 6:
