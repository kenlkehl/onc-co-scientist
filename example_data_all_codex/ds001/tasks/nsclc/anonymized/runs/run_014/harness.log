+      analysis(["h20"], `Unadjusted feature_028=1 was ${rnd(f028.beta)} months lower (${ptxt(f028.p)}), but in the adjusted model the coefficient was ${rnd(adj("feature_028").beta, 4)} months (${ptxt(adj("feature_028").p)}), not significant.`, adj("feature_028").beta, adj("feature_028").p),
+    ],
+    update: "`feature_028` looked confounded, so I separated robust signals from interaction-driven patterns.",
+  },
+  {
+    index: 15,
+    proposed_hypotheses: [
+      hyp("h21", "`feature_066=1` is associated with longer `pfs_months` than `feature_066=0`, but this association is not independent of the major predictors."),
+    ],
+    analyses: [
+      analysis(["h21"], `Feature_066=1 was +${rnd(f066s.diff)} months higher in unadjusted subgroup means (${ptxt(f066s.p)}).`, f066s.diff, f066s.p),
+      analysis(["h21"], `After adjustment for the major predictors, feature_066 had coefficient ${rnd(adj("feature_066").beta, 4)} months (${ptxt(adj("feature_066").p)}), so the unadjusted association was not independent.`, adj("feature_066").beta, adj("feature_066").p),
+    ],
+    update: "`feature_066` was another apparent univariate signal that disappeared after adjustment.",
+  },
+  {
+    index: 16,
+    proposed_hypotheses: [
+      hyp("h22", "The combination `feature_010=1` and `feature_009=1` has supra-additively longer `pfs_months` beyond the separate main effects of `feature_010` and `feature_009`.", "refined"),
+    ],
+    analyses: [
+      analysis(["h22"], `The feature_010-by-feature_009 interaction was +${rnd(ti("feature_010:feature_009").beta)} months (${ptxt(ti("feature_010:feature_009").p)}). Cell means were 3.334 (0:0), 3.329 (0:1), 3.213 (1:0), and 5.766 (1:1).`, ti("feature_010:feature_009").beta, ti("feature_010:feature_009").p),
+    ],
+    update: "This was the strongest interaction, indicating a subgroup with much longer PFS when both markers were present.",
+  },
+  {
+    index: 17,
