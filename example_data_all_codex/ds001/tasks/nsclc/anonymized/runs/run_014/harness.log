+function subgroupDiff(y, g) {
+  let n1 = 0;
+  let n0 = 0;
+  let s1 = 0;
+  let s0 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (g[i]) {
+      n1++;
+      s1 += y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+    }
+  }
+  return { n1, n0, mean1: s1 / n1, mean0: s0 / n0, diff: s1 / n1 - s0 / n0 };
+}
+
+function pearson(x, y) {
+  const mx = mean(x);
+  const my = mean(y);
+  let sxy = 0;
+  let sx = 0;
+  let sy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    const dy = y[i] - my;
+    sxy += dx * dy;
+    sx += dx * dx;
+    sy += dy * dy;
+  }
+  return sxy / Math.sqrt(sx * sy);
