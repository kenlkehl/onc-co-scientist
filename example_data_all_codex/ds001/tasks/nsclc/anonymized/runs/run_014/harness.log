+      analysis(["h28"], `The feature_041-by-squamous interaction was ${rnd(ti("feature_041:feature_015_squamous_raw").beta, 5)} months per feature_041 unit (${ptxt(ti("feature_041:feature_015_squamous_raw").p)}).`, ti("feature_041:feature_015_squamous_raw").beta, ti("feature_041:feature_015_squamous_raw").p),
+      analysis(["h28"], `The feature_041-by-feature_042 interaction was ${rnd(ti("feature_041:feature_042_raw").beta, 5)} months per feature_041 unit (${ptxt(ti("feature_041:feature_042_raw").p)}).`, ti("feature_041:feature_042_raw").beta, ti("feature_041:feature_042_raw").p),
