+const fs = require("fs");
+
+const r = JSON.parse(fs.readFileSync("analysis_results.json", "utf8"));
+
+const floorP = (p) => (p === 0 ? 1e-300 : p);
+const sig = (p) => floorP(p) < 0.05;
+const ptxt = (p) => (p === 0 || p <= 1e-300 ? "p<1e-300" : `p=${Number(p).toPrecision(3)}`);
+const rnd = (x, d = 3) => Number(x).toFixed(d);
+
+function main(feature, pred = () => true) {
+  const m = r.main.find((x) => x.feature === feature && pred(x));
+  if (!m) throw new Error(`missing main ${feature}`);
+  return m;
+}
+function sub(feature, pred = () => true) {
+  const s = r.subgroups.find((x) => x.feature === feature && pred(x));
+  if (!s) throw new Error(`missing subgroup ${feature}`);
+  return s;
+}
+function adj(feature) {
+  const a = r.adjusted.find((x) => x.feature === feature);
+  if (!a) throw new Error(`missing adjusted ${feature}`);
+  return a;
+}
+function ti(key) {
+  const x = r.targetedInteractions[key];
+  if (!x) throw new Error(`missing interaction ${key}`);
+  return x;
+}
+function analysis(hypothesis_ids, result_summary, effect_estimate, p_value, extra = {}) {
+  return {
+    hypothesis_ids,
+    result_summary,
+    p_value: floorP(p_value),
+    effect_estimate,
+    significant: sig(p_value),
+    ...extra,
+  };
+}
+function hyp(id, text, kind = "novel") {
+  return { id, text, kind };
+}
+
+const f041 = main("feature_041");
+const f041q = sub("feature_041");
+const f036 = main("feature_036");
+const f001 = main("feature_001");
+const f042 = main("feature_042");
+const f015 = main("feature_015");
+const f025Current = main("feature_025", (m) => m.level === "current");
+const f025Never = main("feature_025", (m) => m.level === "never");
+const f004 = main("feature_004");
+const f004q = sub("feature_004");
+const f010 = main("feature_010");
+const f056 = main("feature_056");
+const f056q = sub("feature_056");
+const f057 = main("feature_057");
+const f009 = main("feature_009");
+const f037 = main("feature_037");
+const f028 = main("feature_028");
+const f066s = sub("feature_066");
+const f033s = sub("feature_033");
+const f029s = sub("feature_029");
+const f005s = sub("feature_005");
+const f051a = adj("feature_051");
+const f073a = adj("feature_073");
+
+const iterations = [
+  {
+    index: 1,
+    proposed_hypotheses: [
+      hyp("h1", "Higher `feature_041` is associated with longer `pfs_months`; each 1-unit increase in `feature_041` increases mean progression-free survival."),
+    ],
+    analyses: [
+      analysis(["h1"], `Univariate OLS gave a coefficient of +${rnd(f041.beta)} months per 1-unit increase in feature_041 (SE ${rnd(f041.se, 4)}, r=${rnd(f041.r)}; ${ptxt(f041.p)}).`, f041.beta, f041.p),
+    ],
+    update: "`feature_041` was the dominant continuous association, so the next iteration checked whether the effect was also visible as a clinically interpretable high-versus-low contrast.",
+  },
+  {
+    index: 2,
+    proposed_hypotheses: [
+      hyp("h2", "Patients in the top quartile of `feature_041` (>=71.8) have longer `pfs_months` than patients in the bottom quartile of `feature_041` (<=58.3).", "refined"),
+    ],
+    analyses: [
+      analysis(["h2"], `Top-quartile feature_041 patients had mean PFS ${rnd(f041q.mean1)} months versus ${rnd(f041q.mean0)} months in the bottom quartile, a +${rnd(f041q.diff)} month difference (${ptxt(f041q.p)}).`, f041q.diff, f041q.p),
+    ],
+    update: "The large high-versus-low separation supported prioritizing other large main effects.",
+  },
+  {
+    index: 3,
+    proposed_hypotheses: [
+      hyp("h3", "Higher ordinal values of `feature_036` are associated with shorter `pfs_months`, with level 2 lower than level 1 and level 1 lower than level 0."),
+    ],
+    analyses: [
+      analysis(["h3"], `Treating feature_036 as ordinal, OLS estimated -${rnd(Math.abs(f036.beta))} months per level (${ptxt(f036.p)}). Level means were 4.327 for 0, 3.185 for 1, and 2.152 for 2.`, f036.beta, f036.p),
+    ],
+    update: "`feature_036` showed a strong graded adverse pattern, motivating tests of other binary adverse markers.",
+  },
+  {
+    index: 4,
+    proposed_hypotheses: [
+      hyp("h4", "`feature_001=1` is associated with shorter `pfs_months` than `feature_001=0`."),
+    ],
+    analyses: [
+      analysis(["h4"], `Mean PFS was ${rnd(sub("feature_001").mean1)} months for feature_001=1 versus ${rnd(sub("feature_001").mean0)} months for feature_001=0, a ${rnd(f001.beta)} month difference (${ptxt(f001.p)}).`, f001.beta, f001.p),
+    ],
+    update: "`feature_001` was another strong adverse marker; I next checked another common binary marker.",
+  },
+  {
+    index: 5,
+    proposed_hypotheses: [
+      hyp("h5", "`feature_042=1` is associated with shorter `pfs_months` than `feature_042=0`."),
+    ],
+    analyses: [
+      analysis(["h5"], `Mean PFS was ${rnd(sub("feature_042").mean1)} months for feature_042=1 versus ${rnd(sub("feature_042").mean0)} months for feature_042=0, a ${rnd(f042.beta)} month difference (${ptxt(f042.p)}).`, f042.beta, f042.p),
+    ],
+    update: "The next iteration evaluated the named categorical tumor feature.",
+  },
+  {
+    index: 6,
+    proposed_hypotheses: [
+      hyp("h6", "`feature_015=squamous` is associated with shorter `pfs_months` than `feature_015=adenocarcinoma`."),
+    ],
+    analyses: [
+      analysis(["h6"], `Mean PFS was ${rnd(r.levelMeans.feature_015.find((x) => x.level === "squamous").mean)} months for squamous versus ${rnd(r.levelMeans.feature_015.find((x) => x.level === "adenocarcinoma").mean)} months for adenocarcinoma; the squamous contrast was ${rnd(f015.beta)} months (${ptxt(f015.p)}).`, f015.beta, f015.p),
+    ],
+    update: "`feature_015` behaved like an adverse histology-like subgroup, so the next step examined the other string-coded feature.",
+  },
+  {
+    index: 7,
+    proposed_hypotheses: [
+      hyp("h7", "`feature_025=current` is associated with shorter `pfs_months` than the other `feature_025` levels."),
+      hyp("h8", "`feature_025=never` is associated with longer `pfs_months` than the other `feature_025` levels."),
+    ],
