"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$files = Get-ChildItem -Path .'"\\runs -Filter transcript.json -Recurse | Sort-Object FullName
foreach ("'$f in $files) {
  try {
    $j = Get-Content -Raw -LiteralPath $f.FullName | ConvertFrom-Json
    $nIter = @($j.iterations).Count
    $nAnalyses = 0; foreach($it in $j.iterations){ $nAnalyses += @($it.analyses).Count }
    $sig = 0; foreach($it in $j.iterations){ foreach($a in @($it.analyses)){ if($a.significant -eq $true -or (($null -ne $a.p_value) -and ([double]$a.p_value -lt 0.05))){ $sig++ } } }
    $first = if($nIter -gt 0 -and @($j.iterations[0].proposed_hypotheses).Count -gt 0){ $j.iterations[0].proposed_hypotheses[0].text } else { '"'' }
    Write-Output \""'$($f.Directory.Name)`titer=$nIter`tanalyses=$nAnalyses`tsig=$sig`t$first"
  } catch { Write-Output "$($f.Directory.Name)`tERROR $($_.Exception.Message)" }
