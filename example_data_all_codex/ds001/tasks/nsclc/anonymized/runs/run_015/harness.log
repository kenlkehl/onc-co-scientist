let off=0;
const T={STOP:0,TRUE:1,FALSE:2,BYTE:3,I16:4,I32:5,I64:6,DOUBLE:7,BINARY:8,LIST:9,SET:10,MAP:11,STRUCT:12};
function readVarint(){ let shift=0, result=0n; while(true){ const byte=buf[off++]; result |= BigInt(byte & 0x7f) << BigInt(shift); if("'!(byte & 0x80)) break; shift+=7; } return result; }
function zig(n){ return (n >> 1n) ''^ (-(n & 1n)); }
function num(n){ const max=BigInt(Number.MAX_SAFE_INTEGER); const min=BigInt(Number.MIN_SAFE_INTEGER); return (n<=max && n>=min)?Number(n):n.toString(); }
function readI(){ return num(zig(readVarint())); }
function readList(){ const h=buf[off++]; let size=h>>4; const et=h&0x0f; if(size===15) size=Number(readVarint()); const arr=[]; for(let i=0;i<size;i++) arr.push(readValue(et)); return {listType:et, values:arr}; }
function readStruct(){ const fields=[]; let last=0; while(true){ const h=buf[off++]; const type=h&0x0f; if(type===0) break; const delta=h>>4; let id; if(delta) id=last+delta; else id=readI(); last=id; fields.push({id,type,value:readValue(type)}); } return fields; }
function readValue(type){ switch(type){ case T.TRUE: return true; case T.FALSE: return false; case T.BYTE: {let v=buf.readInt8(off); off++; return v;} case T.I16: case T.I32: case T.I64: return readI(); case T.DOUBLE: {let v=buf.readDoubleLE(off); off+=8; return v;} case T.BINARY: {let len=Number(readVarint()); let s=buf.slice(off,off+len); off+=len; return s.toString('"'utf8');} case T.LIST: case T.SET: return readList(); case T.STRUCT: return readStruct(); case T.MAP: { const size=Number(readVarint()); if(size===0) return []; const ht=buf[off++]; const kt=(ht>>4)&0xf, vt=ht&0xf; const arr=[]; for(let i=0;i<size;i++) arr.push([readValue(kt),readValue(vt)]); return arr;} default: throw new Error('unknown type '+type+' at '+off); }}
const root=readStruct();
