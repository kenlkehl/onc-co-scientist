"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import pandas as pd
import numpy as np
from scipy import stats
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('pfs desc')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
rows=[]
for c in df.columns:
    if c=='pfs_months': continue
    s=df[c]
    nun=s.nunique()
    rows.append((c, str(s.dtype), nun, float(s.mean()), float(s.std()), float(s.min()), float(s.max())))
print('feature summary first')
for row in rows[:80]:
    print('\\t'.join(map(str,row)))
# univariate linear regression simple slope/corr
from scipy.stats import linregress, pearsonr
res=[]
y=df['pfs_months'].to_numpy()
for c in [x for x in df.columns if x"'!='"'pfs_months']:
    x=df[c].to_numpy()
    lr=linregress(x,y)
    res.append((c, lr.slope, lr.pvalue, np.corrcoef(x,y)[0,1], df[c].mean()))
print('top abs univariate')
for r in sorted(res, key=lambda z: abs(z[1]), reverse=True)[:30]:
    print('\\t'.join([r[0], f'{r[1]:.6g}', f'{r[2]:.3g}', f'{r[3]:.5g}', f'{r[4]:.5g}']))
