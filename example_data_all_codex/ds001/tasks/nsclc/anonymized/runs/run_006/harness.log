import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.value_counts())
print(df.dtypes.to_string())
print('outcome desc')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
# unique counts and basic stats for features
rows=[]
for c in df.columns:
    if c=='pfs_months': continue
    s=df[c]
    rows.append((c, str(s.dtype), s.nunique(), float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, float(s.std()) if pd.api.types.is_numeric_dtype(s) else None, float(s.min()) if pd.api.types.is_numeric_dtype(s) else None, float(s.max()) if pd.api.types.is_numeric_dtype(s) else None))
print('feature summary head')
for r in rows[:80]: print(r)
