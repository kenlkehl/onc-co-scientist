import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('pfs summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
features=[c for c in df.columns if c"'!='"'pfs_months']
rows=[]
for c in features:
    s=df[c]
    nun=s.nunique()
    vals=s.value_counts().head(10).to_dict()
    rows.append((c, str(s.dtype), nun, float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, vals))
print('feature summaries')
for row in rows:
    print(row)
