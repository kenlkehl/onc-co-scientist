// stats utilities
function erfc(x){const z=Math.abs(x);const t=1/(1+0.5*z);const ans=t*Math.exp(-z*z-1.26551223+t*(1.00002368+t*(0.37409196+t*(0.09678418+t*(-0.18628806+t*(0.27886807+t*(-1.13520398+t*(1.48851587+t*(-0.82215223+t*0.17087277)))))))));return x>=0?ans:2-ans}
function pz(z){const p=erfc(Math.abs(z)/Math.SQRT2);return p===0?1e-300:p}
function mean(a){let s=0;for(const v of a)s+=v;return s/a.length}
function variance(a,m=mean(a)){let s=0;for(const v of a){const d=v-m;s+=d*d}return s/(a.length-1)}
function classify(name,a){if(name==='patient_id'||name==='pfs_months')return 'skip';const vals=[...new Set(a.map(String))];const num=typeof a[0]==='number';if(num&&vals.length===2&&vals.includes('0')&&vals.includes('1'))return 'binary';if(vals.length<=5)return 'categorical';return 'continuous'}
function binaryTest(x,y){let n0=0,n1=0,s0=0,s1=0,ss0=0,ss1=0;for(let i=0;i<y.length;i++){if(x[i]===1){n1++;s1+=y[i];ss1+=y[i]*y[i]}else{n0++;s0+=y[i];ss0+=y[i]*y[i]}}const m0=s0/n0,m1=s1/n1,v0=(ss0-s0*s0/n0)/(n0-1),v1=(ss1-s1*s1/n1)/(n1-1),diff=m1-m0,se=Math.sqrt(v0/n0+v1/n1),z=diff/se;return{effect:diff,p:pz(z),z,n0,n1,m0,m1}}
function contTest(x,y){const n=y.length,mx=mean(x),my=mean(y);let sxx=0,sxy=0;for(let i=0;i<n;i++){const dx=x[i]-mx;sxx+=dx*dx;sxy+=dx*(y[i]-my)}const slope=sxy/sxx;let rss=0;for(let i=0;i<n;i++){const r=y[i]-(my+slope*(x[i]-mx));rss+=r*r}const sig2=rss/(n-2),se=Math.sqrt(sig2/sxx),z=slope/se;return{effect:slope,p:pz(z),z,meanX:mx,sdX:Math.sqrt(sxx/(n-1)),stdEffect:slope*Math.sqrt(sxx/(n-1))}}
function catTests(x,y){const levels=[...new Set(x.map(String))].sort();const ref=levels[0];let groups={};for(const l of levels)groups[l]={n:0,s:0,ss:0};for(let i=0;i<y.length;i++){const g=groups[String(x[i])];g.n++;g.s+=y[i];g.ss+=y[i]*y[i]}for(const l of levels){const g=groups[l];g.mean=g.s/g.n;g.var=(g.ss-g.s*g.s/g.n)/(g.n-1)}let comps=[];for(const l of levels){if(l===ref)continue;const g=groups[l],r=groups[ref];const diff=g.mean-r.mean,se=Math.sqrt(g.var/g.n+r.var/r.n),z=diff/se;comps.push({level:l,ref,effect:diff,p:pz(z),z,n:g.n,nref:r.n,mean:g.mean,meanRef:r.mean})}comps.sort((a,b)=>Math.abs(b.z)-Math.abs(a.z));return{levels,ref,groups,top:comps[0],comps}}
function solve(A,b){const n=A.length;let M=A.map((r,i)=>r.concat([b[i]]));for(let k=0;k<n;k++){let piv=k;for(let i=k+1;i<n;i++)if(Math.abs(M[i][k])>Math.abs(M[piv][k]))piv=i;if(Math.abs(M[piv][k])<1e-12)throw Error('singular');[M[k],M[piv]]=[M[piv],M[k]];const div=M[k][k];for(let j=k;j<=n;j++)M[k][j]/=div;for(let i=0;i<n;i++)if(i"'!==k){const f=M[i][k];if(f!==0)for(let j=k;j<=n;j++)M[i][j]-=f*M[k][j]}}return M.map(r=>r[n])}
function invert(A){const n=A.length;let M=A.map((r,i)=>r.concat(Array.from({length:n},(_,j)=>i===j?1:0)));for(let k=0;k<n;k++){let piv=k;for(let i=k+1;i<n;i++)if(Math.abs(M[i][k])>Math.abs(M[piv][k]))piv=i;if(Math.abs(M[piv][k])<1e-10)throw Error('"'singular');[M[k],M[piv]]=[M[piv],M[k]];const div=M[k][k];for(let j=0;j<2*n;j++)M[k][j]/=div;for(let i=0;i<n;i++)if(i"'!==k){const f=M[i][k];if(f!==0)for(let j=k;j<2*n;j++)M[i][j]-=f*M[k][j]}}return M.map(r=>r.slice(n))}
function ols(cols,y){const n=y.length,p=cols.length;let XtX=Array.from({length:p},()=>Array(p).fill(0)),Xty=Array(p).fill(0),yty=0;for(let i=0;i<n;i++){yty+=y[i]*y[i];for(let a=0;a<p;a++){const va=cols[a][i];Xty[a]+=va*y[i];for(let c=0;c<=a;c++)XtX[a][c]+=va*cols[c][i]}}for(let a=0;a<p;a++)for(let c=0;c<a;c++)XtX[c][a]=XtX[a][c];const beta=solve(XtX,Xty);let sse=yty;for(let j=0;j<p;j++)sse-=beta[j]*Xty[j];const sigma2=sse/(n-p);const inv=invert(XtX);const se=beta.map((v,j)=>Math.sqrt(Math.max(0,sigma2*inv[j][j])));const pvals=beta.map((v,j)=>pz(v/se[j]));return{beta,se,p:pvals,sigma2,df:n-p}}
const df=load(), y=df.pfs_months, names=Object.keys(df).filter(n=>n!=='"'patient_id'&&n"'!=='"'pfs_months');console.log('loaded rows',y.length,'features',names.length,'pfs mean',mean(y),'sd',Math.sqrt(variance(y)));
let main=[];for(const n of names){const cls=classify(n,df[n]);let r;if(cls==='binary'){r=binaryTest(df[n],y);main.push({name:n,cls,effect:r.effect,p:r.p,z:r.z,detail:r})}else if(cls==='continuous'){r=contTest(df[n],y);main.push({name:n,cls,effect:r.effect,p:r.p,z:r.z,stdEffect:r.stdEffect,detail:r})}else if(cls==='categorical'){r=catTests(df[n],y);main.push({name:n,cls,effect:r.top.effect,p:r.top.p,z:r.top.z,detail:r})}}
console.log('\\nTop main by |z|');for(const r of [...main].sort((a,b)=>Math.abs(b.z)-Math.abs(a.z)).slice(0,25)){console.log(JSON.stringify({name:r.name,cls:r.cls,effect:r.effect,stdEffect:r.stdEffect,p:r.p,z:r.z,detail:r.cls==='binary'?{m1:r.detail.m1,m0:r.detail.m0,n1:r.detail.n1}:r.cls==='categorical'?r.detail.top:{meanX:r.detail.meanX,sdX:r.detail.sdX}}));}
console.log('\\nTop main by absolute natural effect (binary/cat)');for(const r of main.filter(r=>r.cls"'!=='"'continuous').sort((a,b)=>Math.abs(b.effect)-Math.abs(a.effect)).slice(0,25)){console.log(JSON.stringify({name:r.name,cls:r.cls,effect:r.effect,p:r.p,z:r.z,detail:r.cls==='binary'?{m1:r.detail.m1,m0:r.detail.m0,n1:r.detail.n1}:r.detail.top}));}
