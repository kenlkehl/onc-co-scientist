import pandas as pd
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('\\noutcome summary')
print(df['pfs_months'].describe(percentiles=[.01,.05,.1,.25,.5,.75,.9,.95,.99]).to_string())
features=[c for c in df.columns if c"'!='"'pfs_months']
summary=[]
for c in features:
    s=df[c]
    nun=s.nunique(dropna=False)
    vals=s.value_counts(normalize=True).head(5).to_dict() if nun<=10 else {}
    summary.append((c,str(s.dtype),nun,float(s.mean()),float(s.std()),float(s.min()),float(s.max()),vals))
print('\\nfeature summary first 80')
for row in summary:
    print(row)
