function plain(buf,type,n){let p=0,a=[];for(let i=0;i<n;i++){if(type===0){const by=buf[p+(i>>3)];a.push((by>>(i&7))&1)}else if(type===1){a.push(buf.readInt32LE(p));p+=4}else if(type===2){a.push(Number(buf.readBigInt64LE(p)));p+=8}else if(type===4){a.push(buf.readFloatLE(p));p+=4}else if(type===5){a.push(buf.readDoubleLE(p));p+=8}else if(type===6){const l=buf.readInt32LE(p);p+=4;a.push(buf.subarray(p,p+l).toString('"'utf8'));p+=l}else throw Error('plain type '+type)}return a}
