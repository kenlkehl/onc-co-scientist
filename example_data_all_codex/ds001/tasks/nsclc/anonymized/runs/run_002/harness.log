+  function adjustedInteraction(predA, predB, interName, interVec) {
+    const covars = [];
+    for (const p of topAdjustCovars) {
+      if (p.name.startsWith(predA + '=') || p.name === predA || p.name.startsWith(predB + '=') || p.name === predB) continue;
+      covars.push(p);
+    }
