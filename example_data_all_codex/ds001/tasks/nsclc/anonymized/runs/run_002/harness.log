+}
+function simpleRegression(x, y) {
+  const n = y.length;
+  let sx = 0, sy = 0, sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const xi = x[i], yi = y[i];
+    sx += xi; sy += yi; sxx += xi * xi; sxy += xi * yi; syy += yi * yi;
+  }
+  const mx = sx / n, my = sy / n;
+  const Sxx = sxx - n * mx * mx;
+  const Sxy = sxy - n * mx * my;
+  const Syy = syy - n * my * my;
