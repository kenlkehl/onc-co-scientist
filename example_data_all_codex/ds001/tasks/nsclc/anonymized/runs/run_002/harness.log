+  const summaries = Array.from(groups, ([level, arr]) => ({ level, n: arr.length, mean: mean(arr), var: variance(arr) }))
+    .sort((a, b) => a.mean - b.mean);
+  const lo = summaries[0], hi = summaries[summaries.length - 1];
+  const se = Math.sqrt(lo.var / lo.n + hi.var / hi.n);
+  const z = (hi.mean - lo.mean) / se;
+  return { low: lo, high: hi, effect: hi.mean - lo.mean, p: pFromZ(z), summaries };
+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const M = A.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let i = 0; i < n; i++) {
+    let piv = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[piv][i])) piv = r;
+    if (piv !== i) [M[i], M[piv]] = [M[piv], M[i]];
+    const div = M[i][i];
+    assert(Math.abs(div) > 1e-12, 'singular matrix');
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= f * M[i][c];
+    }
+  }
+  return M.map(row => row.slice(n));
+}
+function ols(y, predictors) {
+  const n = y.length, p = predictors.length + 1;
+  const XtX = Array.from({ length: p }, () => Array(p).fill(0));
+  const Xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const pred of predictors) row.push(pred.x[i]);
+    const yi = y[i];
+    yty += yi * yi;
+    for (let a = 0; a < p; a++) {
+      Xty[a] += row[a] * yi;
+      for (let b = 0; b <= a; b++) XtX[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) XtX[b][a] = XtX[a][b];
+  const inv = invertMatrix(XtX);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) beta[i] += inv[i][j] * Xty[j];
+  let bXy = 0;
+  for (let i = 0; i < p; i++) bXy += beta[i] * Xty[i];
+  const sse = Math.max(0, yty - bXy);
+  const sigma2 = sse / (n - p);
+  const terms = [{ name: 'intercept', beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]), p: pFromZ(beta[0] / Math.sqrt(sigma2 * inv[0][0])) }];
+  for (let i = 1; i < p; i++) {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    terms.push({ name: predictors[i - 1].name, beta: beta[i], se, p: pFromZ(beta[i] / se) });
+  }
+  return { terms, sse, sigma2, df: n - p };
+}
+function binaryInteraction(a, b, y) {
+  const x1 = a, x2 = b, inter = a.map((v, i) => v * b[i]);
+  const fit = ols(y, [{ name: 'a', x: x1 }, { name: 'b', x: x2 }, { name: 'interaction', x: inter }]);
+  const t = fit.terms.find(v => v.name === 'interaction');
+  const cells = {};
+  for (let av of [0, 1]) for (let bv of [0, 1]) cells[`${av}${bv}`] = [];
+  for (let i = 0; i < y.length; i++) cells[`${a[i]}${b[i]}`].push(y[i]);
+  const means = {};
+  for (const k of Object.keys(cells)) means[k] = { n: cells[k].length, mean: mean(cells[k]) };
+  return { beta: t.beta, p: t.p, means };
+}
+function slopeByBinary(cont, bin, y) {
+  const inter = cont.map((v, i) => v * bin[i]);
+  const fit = ols(y, [{ name: 'cont', x: cont }, { name: 'bin', x: bin }, { name: 'interaction', x: inter }]);
+  const t = fit.terms.find(v => v.name === 'interaction');
+  const slope0 = simpleRegression(cont.filter((_, i) => bin[i] === 0), y.filter((_, i) => bin[i] === 0));
+  const slope1 = simpleRegression(cont.filter((_, i) => bin[i] === 1), y.filter((_, i) => bin[i] === 1));
+  return { beta: t.beta, p: t.p, slope0: slope0.beta, slope1: slope1.beta, n0: bin.filter(v => v === 0).length, n1: bin.filter(v => v === 1).length };
+}
+function centeredProductInteraction(x, z, y) {
+  const mx = mean(x), mz = mean(z);
+  const xc = x.map(v => v - mx), zc = z.map(v => v - mz), inter = xc.map((v, i) => v * zc[i]);
+  const fit = ols(y, [{ name: 'x_centered', x: xc }, { name: 'z_centered', x: zc }, { name: 'interaction', x: inter }]);
+  const t = fit.terms.find(v => v.name === 'interaction');
+  return { beta: t.beta, p: t.p };
+}
+
+function fmt(x, d = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 100) return x.toFixed(1);
+  if (Math.abs(x) >= 10) return x.toFixed(2);
