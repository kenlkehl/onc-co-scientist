+function binaryInteraction(a, b, y) {
+  const x1 = a, x2 = b, inter = a.map((v, i) => v * b[i]);
+  const fit = ols(y, [{ name: 'a', x: x1 }, { name: 'b', x: x2 }, { name: 'interaction', x: inter }]);
+  const t = fit.terms.find(v => v.name === 'interaction');
+  const cells = {};
+  for (let av of [0, 1]) for (let bv of [0, 1]) cells[`${av}${bv}`] = [];
+  for (let i = 0; i < y.length; i++) cells[`${a[i]}${b[i]}`].push(y[i]);
+  const means = {};
+  for (const k of Object.keys(cells)) means[k] = { n: cells[k].length, mean: mean(cells[k]) };
+  return { beta: t.beta, p: t.p, means };
