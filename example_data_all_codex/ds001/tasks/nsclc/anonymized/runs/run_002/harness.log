+
+  const contInteractions = [];
+  for (let i = 0; i < topCont.length; i++) {
+    for (let j = i + 1; j < topCont.length; j++) {
+      const a = topCont[i], b = topCont[j];
+      const r = centeredProductInteraction(columns[a], columns[b], y);
+      contInteractions.push({ a, b, effect: r.beta, p: r.p, detail: r });
+    }
+  }
