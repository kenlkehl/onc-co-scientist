+    const counts = uniqueCounts(a);
+    const vals = Array.from(counts.keys());
+    const numeric = typeof vals[0] === 'number';
+    summaries[f] = {
+      name: f,
+      numeric,
+      physicalType: colInfo[f].physicalType,
+      unique: counts.size,
+      counts,
+      mean: numeric ? mean(a) : null,
+      sd: numeric ? Math.sqrt(variance(a)) : null,
+      min: numeric ? Math.min(...a) : null,
+      max: numeric ? Math.max(...a) : null,
