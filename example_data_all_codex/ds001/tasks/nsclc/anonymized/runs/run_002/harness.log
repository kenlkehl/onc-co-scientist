import pandas as pd
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print(df.shape)
print(df.dtypes.to_string())
print('\\nOutcome summary')
print(df['pfs_months'].describe().to_string())
print('\\nFeature summaries')
for c in df.columns:
    if c == 'pfs_months':
        continue
    s=df[c]
    nun=s.nunique()
    line=f\"{c}: dtype={s.dtype}, nunique={nun}, min={s.min()}, max={s.max()}, mean={s.mean():.6g}, sd={s.std():.6g}\"
    if nun <= 10:
        counts=s.value_counts().sort_index()
        line += \", counts=\" + \";\".join([f\"{k}:{v}\" for k,v in counts.items()])
    print(line)
