+  const n = y.length;
+  let sx = 0, sy = 0, sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const xi = x[i], yi = y[i];
+    sx += xi; sy += yi; sxx += xi * xi; sxy += xi * yi; syy += yi * yi;
+  }
+  const mx = sx / n, my = sy / n;
+  const Sxx = sxx - n * mx * mx;
+  const Sxy = sxy - n * mx * my;
+  const Syy = syy - n * my * my;
+  const beta = Sxy / Sxx;
+  const sse = Math.max(0, Syy - beta * Sxy);
+  const sigma2 = sse / (n - 2);
+  const se = Math.sqrt(sigma2 / Sxx);
+  const z = beta / se;
+  return { beta, se, z, p: pFromZ(z), meanX: mx, meanY: my };
+}
+function twoGroup(x, y, posValue = 1) {
+  const a = [], b = [];
+  for (let i = 0; i < x.length; i++) (x[i] === posValue ? a : b).push(y[i]);
+  const ma = mean(a), mb = mean(b), va = variance(a), vb = variance(b);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const z = (ma - mb) / se;
+  return { effect: ma - mb, p: pFromZ(z), mean1: ma, mean0: mb, n1: a.length, n0: b.length, z };
+}
+function groupDiff(cat, y) {
+  const groups = new Map();
+  for (let i = 0; i < cat.length; i++) {
+    const k = String(cat[i]);
+    if (!groups.has(k)) groups.set(k, []);
+    groups.get(k).push(y[i]);
+  }
+  const summaries = Array.from(groups, ([level, arr]) => ({ level, n: arr.length, mean: mean(arr), var: variance(arr) }))
+    .sort((a, b) => a.mean - b.mean);
+  const lo = summaries[0], hi = summaries[summaries.length - 1];
+  const se = Math.sqrt(lo.var / lo.n + hi.var / hi.n);
+  const z = (hi.mean - lo.mean) / se;
+  return { low: lo, high: hi, effect: hi.mean - lo.mean, p: pFromZ(z), summaries };
+}
+
+function invertMatrix(A) {
+  const n = A.length;
+  const M = A.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let i = 0; i < n; i++) {
+    let piv = i;
+    for (let r = i + 1; r < n; r++) if (Math.abs(M[r][i]) > Math.abs(M[piv][i])) piv = r;
+    if (piv !== i) [M[i], M[piv]] = [M[piv], M[i]];
+    const div = M[i][i];
+    assert(Math.abs(div) > 1e-12, 'singular matrix');
+    for (let c = 0; c < 2 * n; c++) M[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = M[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) M[r][c] -= f * M[i][c];
+    }
+  }
+  return M.map(row => row.slice(n));
+}
+function ols(y, predictors) {
+  const n = y.length, p = predictors.length + 1;
+  const XtX = Array.from({ length: p }, () => Array(p).fill(0));
+  const Xty = Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const pred of predictors) row.push(pred.x[i]);
+    const yi = y[i];
+    yty += yi * yi;
+    for (let a = 0; a < p; a++) {
+      Xty[a] += row[a] * yi;
+      for (let b = 0; b <= a; b++) XtX[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) for (let b = 0; b < a; b++) XtX[b][a] = XtX[a][b];
+  const inv = invertMatrix(XtX);
+  const beta = Array(p).fill(0);
+  for (let i = 0; i < p; i++) for (let j = 0; j < p; j++) beta[i] += inv[i][j] * Xty[j];
+  let bXy = 0;
+  for (let i = 0; i < p; i++) bXy += beta[i] * Xty[i];
+  const sse = Math.max(0, yty - bXy);
+  const sigma2 = sse / (n - p);
+  const terms = [{ name: 'intercept', beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]), p: pFromZ(beta[0] / Math.sqrt(sigma2 * inv[0][0])) }];
+  for (let i = 1; i < p; i++) {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    terms.push({ name: predictors[i - 1].name, beta: beta[i], se, p: pFromZ(beta[i] / se) });
+  }
+  return { terms, sse, sigma2, df: n - p };
+}
+function binaryInteraction(a, b, y) {
+  const x1 = a, x2 = b, inter = a.map((v, i) => v * b[i]);
+  const fit = ols(y, [{ name: 'a', x: x1 }, { name: 'b', x: x2 }, { name: 'interaction', x: inter }]);
+  const t = fit.terms.find(v => v.name === 'interaction');
+  const cells = {};
+  for (let av of [0, 1]) for (let bv of [0, 1]) cells[`${av}${bv}`] = [];
+  for (let i = 0; i < y.length; i++) cells[`${a[i]}${b[i]}`].push(y[i]);
+  const means = {};
+  for (const k of Object.keys(cells)) means[k] = { n: cells[k].length, mean: mean(cells[k]) };
+  return { beta: t.beta, p: t.p, means };
+}
+function slopeByBinary(cont, bin, y) {
+  const inter = cont.map((v, i) => v * bin[i]);
+  const fit = ols(y, [{ name: 'cont', x: cont }, { name: 'bin', x: bin }, { name: 'interaction', x: inter }]);
+  const t = fit.terms.find(v => v.name === 'interaction');
+  const slope0 = simpleRegression(cont.filter((_, i) => bin[i] === 0), y.filter((_, i) => bin[i] === 0));
+  const slope1 = simpleRegression(cont.filter((_, i) => bin[i] === 1), y.filter((_, i) => bin[i] === 1));
+  return { beta: t.beta, p: t.p, slope0: slope0.beta, slope1: slope1.beta, n0: bin.filter(v => v === 0).length, n1: bin.filter(v => v === 1).length };
+}
+function centeredProductInteraction(x, z, y) {
+  const mx = mean(x), mz = mean(z);
+  const xc = x.map(v => v - mx), zc = z.map(v => v - mz), inter = xc.map((v, i) => v * zc[i]);
+  const fit = ols(y, [{ name: 'x_centered', x: xc }, { name: 'z_centered', x: zc }, { name: 'interaction', x: inter }]);
+  const t = fit.terms.find(v => v.name === 'interaction');
+  return { beta: t.beta, p: t.p };
+}
+
+function fmt(x, d = 3) {
+  if (!Number.isFinite(x)) return String(x);
+  if (Math.abs(x) >= 100) return x.toFixed(1);
+  if (Math.abs(x) >= 10) return x.toFixed(2);
+  return x.toFixed(d);
+}
+function ptxt(p) { return p === 0 ? '<1e-15' : p.toExponential(2); }
+
+function analyze() {
+  const { meta, columns, colInfo } = readParquet();
+  const y = columns[YCOL];
+  const featureNames = Object.keys(columns).filter(c => c.startsWith('feature_'));
+  const summaries = {};
+  for (const f of featureNames) {
+    const a = columns[f];
+    const counts = uniqueCounts(a);
+    const vals = Array.from(counts.keys());
+    const numeric = typeof vals[0] === 'number';
+    summaries[f] = {
+      name: f,
+      numeric,
+      physicalType: colInfo[f].physicalType,
+      unique: counts.size,
+      counts,
+      mean: numeric ? mean(a) : null,
+      sd: numeric ? Math.sqrt(variance(a)) : null,
+      min: numeric ? Math.min(...a) : null,
+      max: numeric ? Math.max(...a) : null,
+    };
+  }
+
+  const main = [];
+  const binary = [];
+  const continuous = [];
+  const categorical = [];
+  for (const f of featureNames) {
+    const s = summaries[f], x = columns[f];
+    if (s.numeric && s.unique === 2 && s.counts.has(0) && s.counts.has(1)) {
+      binary.push(f);
+      const r = twoGroup(x, y, 1);
+      main.push({ feature: f, type: 'binary', effect: r.effect, p: r.p, detail: r });
+    } else if (s.numeric && s.unique > 10) {
+      continuous.push(f);
+      const r = simpleRegression(x, y);
+      main.push({ feature: f, type: 'continuous', effect: r.beta, p: r.p, detail: r });
+    } else {
+      categorical.push(f);
+      const r = groupDiff(x, y);
+      main.push({ feature: f, type: 'categorical', effect: r.effect, p: r.p, detail: r });
+    }
+  }
+  main.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+  const selectedMain = main.slice(0, 12);
+  function makePredictors(mainItems, suffix = '') {
+    const predictors = [];
+    for (const m of mainItems) {
+      const x = columns[m.feature];
+      if (m.type === 'categorical') {
+        const reference = m.detail.low.level;
+        for (const g of m.detail.summaries) {
+          if (g.level === reference) continue;
+          predictors.push({
+            name: `${m.feature}=${g.level}${suffix}`,
+            x: x.map(v => String(v) === g.level ? 1 : 0),
+            source: m,
+            reference,
+          });
+        }
+      } else {
+        predictors.push({ name: m.feature + suffix, x, source: m });
+      }
+    }
+    return predictors;
+  }
+  const adjustedPredictors = makePredictors(selectedMain);
+  const adjustedMap = {};
+  const adjusted = ols(y, adjustedPredictors);
+  for (const term of adjusted.terms.slice(1)) adjustedMap[term.name] = term;
+
+  const fullMainPredictors = makePredictors(main);
+  const fullAdjusted = ols(y, fullMainPredictors);
+
+  const topAdjustCovars = makePredictors(selectedMain.slice(0, 10));
+  function adjustedInteraction(predA, predB, interName, interVec) {
+    const covars = [];
+    for (const p of topAdjustCovars) {
+      if (p.name.startsWith(predA + '=') || p.name === predA || p.name.startsWith(predB + '=') || p.name === predB) continue;
+      covars.push(p);
+    }
+    const fit = ols(y, [...covars, { name: interName, x: interVec }]);
+    return fit.terms.find(t => t.name === interName);
+  }
+
+  const binInteractions = [];
+  for (let i = 0; i < binary.length; i++) {
+    for (let j = i + 1; j < binary.length; j++) {
+      const a = binary[i], b = binary[j];
+      const r = binaryInteraction(columns[a], columns[b], y);
+      const minCell = Math.min(...Object.values(r.means).map(v => v.n));
+      if (minCell >= 100) binInteractions.push({ a, b, effect: r.beta, p: r.p, detail: r });
+    }
+  }
+  binInteractions.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+  const contBinInteractions = [];
+  const topCont = continuous
+    .map(f => main.find(m => m.feature === f))
+    .sort((a, b) => a.p - b.p)
+    .slice(0, 12)
+    .map(m => m.feature);
+  for (const c of topCont) {
+    for (const b of binary) {
+      const r = slopeByBinary(columns[c], columns[b], y);
+      if (r.n0 >= 100 && r.n1 >= 100) contBinInteractions.push({ cont: c, bin: b, effect: r.beta, p: r.p, detail: r });
+    }
+  }
+  contBinInteractions.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+  const contInteractions = [];
+  for (let i = 0; i < topCont.length; i++) {
+    for (let j = i + 1; j < topCont.length; j++) {
+      const a = topCont[i], b = topCont[j];
+      const r = centeredProductInteraction(columns[a], columns[b], y);
+      contInteractions.push({ a, b, effect: r.beta, p: r.p, detail: r });
+    }
+  }
+  contInteractions.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+  console.log('rows', meta.num_rows, 'features', featureNames.length, 'outcome mean', fmt(mean(y)), 'sd', fmt(Math.sqrt(variance(y))));
+  console.log('binary', binary.length, 'continuous', continuous.length, 'categorical', categorical.length);
+  console.log('\nFeature summaries');
+  for (const f of featureNames) {
+    const s = summaries[f];
+    if (s.numeric && s.unique <= 8) {
+      const mrec = main.find(m => m.feature === f);
+      const gd = mrec.type === 'categorical' ? mrec.detail : null;
+      const extra = gd ? ' groups ' + gd.summaries.map(g => `${g.level}:${g.n}/mean=${fmt(g.mean)}`).join(',') : '';
+      console.log(f, 'unique', s.unique, 'counts', Array.from(s.counts.entries()).map(([k, v]) => `${k}:${v}`).join(','), extra, 'main_p', ptxt(mrec.p), 'effect', fmt(mrec.effect));
+    } else if (!s.numeric) {
+      const gd = main.find(m => m.feature === f).detail;
+      console.log(f, 'categorical', 'levels', gd.summaries.map(g => `${g.level}:${g.n}/mean=${fmt(g.mean)}`).join(','), 'main_p', ptxt(main.find(m => m.feature === f).p), 'effect', fmt(main.find(m => m.feature === f).effect));
+    } else {
+      console.log(f, 'unique', s.unique, 'mean', fmt(s.mean), 'sd', fmt(s.sd), 'min', fmt(s.min), 'max', fmt(s.max), 'main_p', ptxt(main.find(m => m.feature === f).p), 'beta', fmt(main.find(m => m.feature === f).effect));
+    }
+  }
+  console.log('\nTop main effects');
+  for (const m of main.slice(0, 25)) {
+    console.log(m.feature, m.type, 'effect', fmt(m.effect, 4), 'p', ptxt(m.p));
+  }
+  console.log('\nAdjusted selected main effects');
+  for (const t of adjusted.terms.slice(1)) console.log(t.name, 'beta', fmt(t.beta, 4), 'p', ptxt(t.p));
+  console.log('\nFull adjusted main effects, top 25 by p');
+  for (const t of fullAdjusted.terms.slice(1).sort((a, b) => a.p - b.p).slice(0, 25)) {
+    console.log(t.name, 'beta', fmt(t.beta, 4), 'p', ptxt(t.p));
+  }
+  console.log('\nTop binary interactions');
+  for (const r of binInteractions.slice(0, 25)) {
+    console.log(r.a, r.b, 'did', fmt(r.effect, 4), 'p', ptxt(r.p), 'cells', Object.entries(r.detail.means).map(([k, v]) => `${k}:${v.n}/${fmt(v.mean)}`).join(' '));
+  }
+  console.log('\nTop continuous-binary interactions');
+  for (const r of contBinInteractions.slice(0, 25)) {
+    console.log(r.cont, r.bin, 'slope_diff', fmt(r.effect, 4), 'p', ptxt(r.p), 's0', fmt(r.detail.slope0, 4), 's1', fmt(r.detail.slope1, 4));
+  }
+  console.log('\nTop continuous-continuous interactions');
+  for (const r of contInteractions.slice(0, 25)) {
+    console.log(r.a, r.b, 'interaction', fmt(r.effect, 5), 'p', ptxt(r.p));
+  }
+}
+
+analyze();
