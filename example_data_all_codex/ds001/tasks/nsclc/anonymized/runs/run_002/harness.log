+  return { values: vals, pos: p };
+}
+
+function readParquet() {
+  const buf = fs.readFileSync(DATASET);
+  assert(buf.slice(0, 4).toString() === 'PAR1', 'not parquet');
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const footer = buf.slice(buf.length - 8 - footerLen, buf.length - 8);
+  const meta = fileMeta(new Compact(footer));
+  const schemaByName = new Map();
+  for (const s of meta.schema.slice(1)) schemaByName.set(s.name, s);
+  const rg = meta.row_groups[0];
+  const columns = {};
+  const colInfo = {};
+  for (const chunk of rg.columns) {
+    const cm = chunk.meta_data;
+    const name = cm.path_in_schema[0];
+    if (name === 'patient_id') continue;
+    const schema = schemaByName.get(name);
+    const maxDefLevel = schema.repetition_type === 1 ? 1 : 0;
+    const start = cm.dictionary_page_offset ?? cm.data_page_offset;
+    const end = start + cm.total_compressed_size;
+    let off = start;
+    let dict = null;
+    const vals = [];
+    while (off < end && vals.length < cm.num_values) {
+      const ph = pageHeader(buf, off);
+      off += ph.header_size;
+      const comp = buf.slice(off, off + ph.compressed_page_size);
+      off += ph.compressed_page_size;
+      const page = cm.codec === 1 ? snappyUncompress(comp) : comp;
+      assert(page.length === ph.uncompressed_page_size, 'page size mismatch ' + name);
+      if (ph.type === 2) {
+        assert(ph.dictionary_page_header.encoding === 0, 'non-plain dictionary ' + name);
+        dict = readPlainValues(page, cm.type, ph.dictionary_page_header.num_values);
+      } else if (ph.type === 0) {
+        const dph = ph.data_page_header;
+        let p = 0;
+        if (maxDefLevel > 0) {
+          const defLen = page.readUInt32LE(p); p += 4;
+          const defs = decodeHybrid(page, p, bitWidth(maxDefLevel), dph.num_values, p + defLen).values;
+          p += defLen;
+          const nonNull = defs.filter(v => v === maxDefLevel).length;
+          if (dph.encoding === 8 || dph.encoding === 2) {
+            const width = page[p++];
+            const idx = decodeHybrid(page, p, width, nonNull).values;
+            let j = 0;
+            for (const d of defs) vals.push(d === maxDefLevel ? dict[idx[j++]] : null);
+          } else if (dph.encoding === 0) {
+            const plain = decodePlainFrom(page, cm.type, nonNull, p).values;
+            let j = 0;
+            for (const d of defs) vals.push(d === maxDefLevel ? plain[j++] : null);
+          } else {
+            throw new Error('unsupported data encoding ' + dph.encoding + ' for ' + name);
+          }
+        } else {
+          if (dph.encoding === 8 || dph.encoding === 2) {
+            const width = page[p++];
+            const idx = decodeHybrid(page, p, width, dph.num_values).values;
+            for (const id of idx) vals.push(dict[id]);
+          } else if (dph.encoding === 0) {
+            vals.push(...decodePlainFrom(page, cm.type, dph.num_values, p).values);
+          } else {
+            throw new Error('unsupported required encoding ' + dph.encoding + ' for ' + name);
+          }
+        }
+      } else if (ph.type === 3) {
+        throw new Error('DataPageV2 not implemented for ' + name);
+      }
+    }
+    assert(vals.length === meta.num_rows, 'value count mismatch ' + name + ' ' + vals.length);
+    columns[name] = vals;
+    colInfo[name] = { physicalType: cm.type, schema };
+  }
+  return { meta, columns, colInfo };
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592, a2 = -0.284496736, a3 = 1.421413741;
+  const a4 = -1.453152027, a5 = 1.061405429, p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+function normCdf(x) { return 0.5 * (1 + erf(x / Math.SQRT2)); }
+function pFromZ(z) {
+  const a = Math.abs(z);
+  if (!Number.isFinite(a)) return 1;
+  if (a > 8) return 0;
+  return Math.max(0, Math.min(1, 2 * (1 - normCdf(a))));
