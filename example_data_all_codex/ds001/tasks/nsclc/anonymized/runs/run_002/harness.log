+          const f=this.field();
+          if (!f) break;
+          this.skip(f.type);
+        }
+        this.pop();
+        return;
+      }
+      default: throw new Error('skip type '+type+' at '+this.pos);
+    }
+  }
+}
+
+function readStruct(cp, handlers) {
+  const out={};
+  cp.push();
+  while (true) {
+    const f=cp.field();
+    if (!f) break;
+    if (handlers[f.id]) handlers[f.id](cp, out, f.type);
+    else cp.skip(f.type);
+  }
+  cp.pop();
+  return out;
+}
