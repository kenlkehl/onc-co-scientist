+    for (let j = i + 1; j < binary.length; j++) {
+      const a = binary[i], b = binary[j];
+      const r = binaryInteraction(columns[a], columns[b], y);
+      const minCell = Math.min(...Object.values(r.means).map(v => v.n));
+      if (minCell >= 100) binInteractions.push({ a, b, effect: r.beta, p: r.p, detail: r });
+    }
+  }
+  binInteractions.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+  const contBinInteractions = [];
+  const topCont = continuous
+    .map(f => main.find(m => m.feature === f))
+    .sort((a, b) => a.p - b.p)
+    .slice(0, 12)
+    .map(m => m.feature);
