+const fs = require('fs');
+
+const buf = fs.readFileSync('dataset.parquet');
+function assert(cond, msg) { if (!cond) throw new Error(msg); }
+assert(buf.slice(0,4).toString() === 'PAR1', 'missing header magic');
+assert(buf.slice(buf.length-4).toString() === 'PAR1', 'missing footer magic');
+const footerLen = buf.readUInt32LE(buf.length - 8);
+const footer = buf.slice(buf.length - 8 - footerLen, buf.length - 8);
+console.log({fileSize: buf.length, footerLen});
+
+class Compact {
+  constructor(b) { this.b=b; this.pos=0; this.stack=[]; this.lastField=0; }
+  byte() { return this.b[this.pos++]; }
+  uvar() {
+    let x=0, s=0;
+    while (true) {
+      const c=this.byte();
+      x |= (c & 0x7f) << s;
+      if ((c & 0x80) === 0) return x >>> 0;
+      s += 7;
+    }
+  }
+  varintBig() {
+    let x=0n, s=0n;
+    while (true) {
+      const c=this.byte();
+      x |= BigInt(c & 0x7f) << s;
+      if ((c & 0x80) === 0) return x;
+      s += 7n;
+    }
+  }
+  zigzag32(n) { return (n >>> 1) ^ -(n & 1); }
+  zigzag64(n) { return (n >> 1n) ^ (-(n & 1n)); }
+  i32() { return this.zigzag32(this.uvar()); }
+  i64() { return Number(this.zigzag64(this.varintBig())); }
+  bin() { const n=this.uvar(); const s=this.b.slice(this.pos,this.pos+n); this.pos+=n; return s; }
+  push() { this.stack.push(this.lastField); this.lastField=0; }
+  pop() { this.lastField=this.stack.pop(); }
+  field() {
+    const h=this.byte();
+    if (h === 0) return null;
+    const type=h & 0x0f, delta=h >> 4;
+    let id;
+    if (delta === 0) id=this.i32(); else id=this.lastField + delta;
+    this.lastField=id;
+    return {id,type};
+  }
+  i16Raw() {
+    const lo=this.byte(), hi=this.byte();
+    let v=lo | (hi << 8);
+    if (v & 0x8000) v -= 0x10000;
+    return v;
+  }
+  listHeader() {
+    const h=this.byte();
+    let size=h >> 4, type=h & 0x0f;
+    if (size === 15) size=this.uvar();
+    return {size,type};
+  }
+  skip(type) {
+    switch(type) {
+      case 1: case 2: return;
+      case 3: this.byte(); return;
+      case 4: this.byte(); this.byte(); return;
+      case 5: this.i32(); return;
+      case 6: this.i64(); return;
+      case 7: this.b.readDoubleLE(this.pos); this.pos += 8; return;
+      case 8: this.bin(); return;
+      case 9: {
+        const {size,type: et}=this.listHeader();
+        for (let i=0;i<size;i++) this.skip(et);
+        return;
+      }
+      case 10: {
+        const {size,type: et}=this.listHeader();
+        for (let i=0;i<size;i++) this.skip(et);
+        return;
+      }
+      case 11: {
+        const n=this.uvar();
+        if (n === 0) return;
+        const kv=this.byte(), kt=kv >> 4, vt=kv & 0x0f;
+        for (let i=0;i<n;i++) { this.skip(kt); this.skip(vt); }
+        return;
+      }
+      case 12: {
+        this.push();
+        while (true) {
+          const f=this.field();
+          if (!f) break;
+          this.skip(f.type);
+        }
+        this.pop();
+        return;
+      }
+      default: throw new Error('skip type '+type+' at '+this.pos);
+    }
+  }
+}
+
+function readStruct(cp, handlers) {
+  const out={};
+  cp.push();
+  while (true) {
+    const f=cp.field();
+    if (!f) break;
+    if (handlers[f.id]) handlers[f.id](cp, out, f.type);
+    else cp.skip(f.type);
+  }
+  cp.pop();
+  return out;
+}
+function readList(cp, elemReader) {
+  const {size,type}=cp.listHeader();
+  const arr=[];
+  for (let i=0;i<size;i++) arr.push(elemReader(cp,type));
+  return arr;
+}
+const str = b => b.toString('utf8');
+function schemaElement(cp) {
+  return readStruct(cp, {
+    1:(c,o)=>o.type=c.i32(),
+    2:(c,o)=>o.type_length=c.i32(),
+    3:(c,o)=>o.repetition_type=c.i32(),
+    4:(c,o)=>o.name=str(c.bin()),
+    5:(c,o)=>o.num_children=c.i32(),
+    6:(c,o)=>o.converted_type=c.i32(),
+    7:(c,o)=>o.scale=c.i32(),
+    8:(c,o)=>o.precision=c.i32(),
+  });
+}
+function pageEncodingStats(cp) {
+  return readStruct(cp, {
+    1:(c,o)=>o.page_type=c.i32(),
+    2:(c,o)=>o.encoding=c.i32(),
+    3:(c,o)=>o.count=c.i32(),
+  });
+}
+function columnMeta(cp) {
+  return readStruct(cp, {
+    1:(c,o)=>o.type=c.i32(),
+    2:(c,o)=>o.encodings=readList(c,(cc)=>cc.i32()),
+    3:(c,o)=>o.path_in_schema=readList(c,(cc)=>str(cc.bin())),
+    4:(c,o)=>o.codec=c.i32(),
+    5:(c,o)=>o.num_values=c.i64(),
+    6:(c,o)=>o.total_uncompressed_size=c.i64(),
+    7:(c,o)=>o.total_compressed_size=c.i64(),
+    9:(c,o)=>o.data_page_offset=c.i64(),
+    10:(c,o)=>o.index_page_offset=c.i64(),
+    11:(c,o)=>o.dictionary_page_offset=c.i64(),
+    12:(c,o, t)=>{ o.statistics='present'; c.skip(t); },
+    13:(c,o)=>o.encoding_stats=readList(c,(cc)=>pageEncodingStats(cc)),
+  });
+}
+function columnChunk(cp) {
+  return readStruct(cp, {
+    1:(c,o)=>o.file_path=str(c.bin()),
+    2:(c,o)=>o.file_offset=c.i64(),
+    3:(c,o)=>o.meta_data=columnMeta(c),
+    4:(c,o)=>o.offset_index_offset=c.i64(),
+    5:(c,o)=>o.offset_index_length=c.i32(),
+    6:(c,o)=>o.column_index_offset=c.i64(),
+    7:(c,o)=>o.column_index_length=c.i32(),
+  });
+}
+function rowGroup(cp) {
+  return readStruct(cp, {
+    1:(c,o)=>o.columns=readList(c,(cc)=>columnChunk(cc)),
+    2:(c,o)=>o.total_byte_size=c.i64(),
+    3:(c,o)=>o.num_rows=c.i64(),
+  });
+}
+function keyValue(cp) {
+  return readStruct(cp, {
+    1:(c,o)=>o.key=str(c.bin()),
+    2:(c,o)=>o.value=str(c.bin()),
+  });
+}
+function fileMeta(cp) {
+  return readStruct(cp, {
+    1:(c,o)=>o.version=c.i32(),
+    2:(c,o)=>o.schema=readList(c,(cc)=>schemaElement(cc)),
+    3:(c,o)=>o.num_rows=c.i64(),
+    4:(c,o)=>o.row_groups=readList(c,(cc)=>rowGroup(cc)),
+    5:(c,o)=>o.key_value_metadata=readList(c,(cc)=>keyValue(cc)),
+    6:(c,o)=>o.created_by=str(c.bin()),
+  });
+}
+
