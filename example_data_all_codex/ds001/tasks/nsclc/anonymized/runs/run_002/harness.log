+
+  console.log('rows', meta.num_rows, 'features', featureNames.length, 'outcome mean', fmt(mean(y)), 'sd', fmt(Math.sqrt(variance(y))));
+  console.log('binary', binary.length, 'continuous', continuous.length, 'categorical', categorical.length);
+  console.log('\nFeature summaries');
+  for (const f of featureNames) {
+    const s = summaries[f];
+    if (s.numeric && s.unique <= 8) {
+      console.log(f, 'unique', s.unique, 'counts', Array.from(s.counts.entries()).map(([k, v]) => `${k}:${v}`).join(','), 'main_p', ptxt(main.find(m => m.feature === f).p), 'effect', fmt(main.find(m => m.feature === f).effect));
+    } else if (!s.numeric) {
+      console.log(f, 'categorical', 'levels', Array.from(s.counts.entries()).map(([k, v]) => `${k}:${v}`).join(','), 'main_p', ptxt(main.find(m => m.feature === f).p), 'effect', fmt(main.find(m => m.feature === f).effect));
+    } else {
+      console.log(f, 'unique', s.unique, 'mean', fmt(s.mean), 'sd', fmt(s.sd), 'min', fmt(s.min), 'max', fmt(s.max), 'main_p', ptxt(main.find(m => m.feature === f).p), 'beta', fmt(main.find(m => m.feature === f).effect));
