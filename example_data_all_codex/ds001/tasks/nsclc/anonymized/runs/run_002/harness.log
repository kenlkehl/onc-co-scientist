+
+  const contBinInteractions = [];
+  const topCont = continuous
+    .map(f => main.find(m => m.feature === f))
+    .sort((a, b) => a.p - b.p)
+    .slice(0, 12)
+    .map(m => m.feature);
+  for (const c of topCont) {
+    for (const b of binary) {
+      const r = slopeByBinary(columns[c], columns[b], y);
+      if (r.n0 >= 100 && r.n1 >= 100) contBinInteractions.push({ cont: c, bin: b, effect: r.beta, p: r.p, detail: r });
+    }
+  }
+  contBinInteractions.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+  const contInteractions = [];
