+    }
+  }
+  main.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+  const selectedMain = main.slice(0, 12);
+  function makePredictors(mainItems, suffix = '') {
+    const predictors = [];
+    for (const m of mainItems) {
+      const x = columns[m.feature];
+      if (m.type === 'categorical') {
+        const reference = m.detail.low.level;
+        for (const g of m.detail.summaries) {
+          if (g.level === reference) continue;
+          predictors.push({
+            name: `${m.feature}=${g.level}${suffix}`,
+            x: x.map(v => String(v) === g.level ? 1 : 0),
