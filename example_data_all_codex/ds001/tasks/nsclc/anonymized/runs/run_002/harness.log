+    }
+  }
+  binInteractions.sort((a, b) => a.p - b.p || Math.abs(b.effect) - Math.abs(a.effect));
+
+  const contBinInteractions = [];
+  const topCont = continuous
+    .map(f => main.find(m => m.feature === f))
