+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.alloc(len);
+  let op = 0;
+  while (ip < input.length) {
+    const tag = input[ip++];
+    const type = tag & 3;
+    if (type === 0) {
+      let litLen = tag >> 2;
+      if (litLen < 60) {
+        litLen += 1;
+      } else {
+        const n = litLen - 59;
+        litLen = 1;
+        for (let i = 0; i < n; i++) litLen += input[ip++] << (8 * i);
+      }
+      input.copy(out, op, ip, ip + litLen);
+      ip += litLen; op += litLen;
+    } else {
+      let copyLen, offset;
+      if (type === 1) {
+        copyLen = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[ip++];
+      } else if (type === 2) {
+        copyLen = (tag >> 2) + 1;
+        offset = input[ip] | (input[ip + 1] << 8);
+        ip += 2;
+      } else {
+        copyLen = (tag >> 2) + 1;
+        offset = input.readUInt32LE(ip);
+        ip += 4;
+      }
+      for (let i = 0; i < copyLen; i++) out[op + i] = out[op - offset + i];
