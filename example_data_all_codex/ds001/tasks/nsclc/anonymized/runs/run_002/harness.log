+      const mrec = main.find(m => m.feature === f);
+      const gd = mrec.type === 'categorical' ? mrec.detail : null;
+      const extra = gd ? ' groups ' + gd.summaries.map(g => `${g.level}:${g.n}/mean=${fmt(g.mean)}`).join(',') : '';
+      console.log(f, 'unique', s.unique, 'counts', Array.from(s.counts.entries()).map(([k, v]) => `${k}:${v}`).join(','), extra, 'main_p', ptxt(mrec.p), 'effect', fmt(mrec.effect));
+    } else if (!s.numeric) {
+      const gd = main.find(m => m.feature === f).detail;
+      console.log(f, 'categorical', 'levels', gd.summaries.map(g => `${g.level}:${g.n}/mean=${fmt(g.mean)}`).join(','), 'main_p', ptxt(main.find(m => m.feature === f).p), 'effect', fmt(main.find(m => m.feature === f).effect));
+    } else {
+      console.log(f, 'unique', s.unique, 'mean', fmt(s.mean), 'sd', fmt(s.sd), 'min', fmt(s.min), 'max', fmt(s.max), 'main_p', ptxt(main.find(m => m.feature === f).p), 'beta', fmt(main.find(m => m.feature === f).effect));
+    }
+  }
+  console.log('\nTop main effects');
+  for (const m of main.slice(0, 25)) {
+    console.log(m.feature, m.type, 'effect', fmt(m.effect, 4), 'p', ptxt(m.p));
+  }
