+  for (const v of a) m.set(v, (m.get(v) || 0) + 1);
+  return m;
+}
+function simpleRegression(x, y) {
+  const n = y.length;
+  let sx = 0, sy = 0, sxx = 0, sxy = 0, syy = 0;
+  for (let i = 0; i < n; i++) {
+    const xi = x[i], yi = y[i];
+    sx += xi; sy += yi; sxx += xi * xi; sxy += xi * yi; syy += yi * yi;
+  }
+  const mx = sx / n, my = sy / n;
+  const Sxx = sxx - n * mx * mx;
+  const Sxy = sxy - n * mx * my;
+  const Syy = syy - n * my * my;
+  const beta = Sxy / Sxx;
+  const sse = Math.max(0, Syy - beta * Sxy);
+  const sigma2 = sse / (n - 2);
+  const se = Math.sqrt(sigma2 / Sxx);
+  const z = beta / se;
+  return { beta, se, z, p: pFromZ(z), meanX: mx, meanY: my };
+}
+function twoGroup(x, y, posValue = 1) {
+  const a = [], b = [];
+  for (let i = 0; i < x.length; i++) (x[i] === posValue ? a : b).push(y[i]);
+  const ma = mean(a), mb = mean(b), va = variance(a), vb = variance(b);
+  const se = Math.sqrt(va / a.length + vb / b.length);
+  const z = (ma - mb) / se;
+  return { effect: ma - mb, p: pFromZ(z), mean1: ma, mean0: mb, n1: a.length, n0: b.length, z };
