+    } else if (physicalType === 5) {
+      vals.push(buf.readDoubleLE(p)); p += 8;
+    } else if (physicalType === 6) {
+      const n = buf.readUInt32LE(p); p += 4;
+      vals.push(buf.slice(p, p + n).toString('utf8')); p += n;
