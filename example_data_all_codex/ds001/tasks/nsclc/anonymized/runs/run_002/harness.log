+  }
+  console.log('\nTop binary interactions');
+  for (const r of binInteractions.slice(0, 25)) {
+    console.log(r.a, r.b, 'did', fmt(r.effect, 4), 'p', ptxt(r.p), 'cells', Object.entries(r.detail.means).map(([k, v]) => `${k}:${v.n}/${fmt(v.mean)}`).join(' '));
+  }
+  console.log('\nTop continuous-binary interactions');
