+      x |= (c & 0x7f) << s;
+      if ((c & 0x80) === 0) return x >>> 0;
+      s += 7;
+    }
+  }
+  varintBig() {
+    let x=0n, s=0n;
+    while (true) {
+      const c=this.byte();
+      x |= BigInt(c & 0x7f) << s;
+      if ((c & 0x80) === 0) return x;
+      s += 7n;
+    }
+  }
