+  const featureNames = Object.keys(columns).filter(c => c.startsWith('feature_'));
+  const summaries = {};
+  for (const f of featureNames) {
+    const a = columns[f];
+    const counts = uniqueCounts(a);
+    const vals = Array.from(counts.keys());
