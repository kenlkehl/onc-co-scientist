+function centeredProductInteraction(x, z, y) {
+  const mx = mean(x), mz = mean(z);
+  const xc = x.map(v => v - mx), zc = z.map(v => v - mz), inter = xc.map((v, i) => v * zc[i]);
+  const fit = ols(y, [{ name: 'x_centered', x: xc }, { name: 'z_centered', x: zc }, { name: 'interaction', x: inter }]);
