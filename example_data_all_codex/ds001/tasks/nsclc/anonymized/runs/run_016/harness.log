+
+function uniqueValues(arr) {
+  const m = new Map();
+  for (const x of arr) m.set(x, (m.get(x) || 0) + 1);
+  return [...m.entries()].sort((a, b) => {
+    if (typeof a[0] === "number" && typeof b[0] === "number") return a[0] - b[0];
+    return String(a[0]).localeCompare(String(b[0]));
+  });
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalTwoSided(z) {
+  const az = Math.abs(z);
+  if (!isFinite(az)) return 1;
+  const p = 2 * (1 - (0.5 * (1 + erf(az / Math.SQRT2))));
+  return Math.max(0, Math.min(1, p));
+}
+
+function groupStats(x, y) {
+  const groups = new Map();
+  for (let i = 0; i < x.length; i++) {
+    const key = x[i];
+    let g = groups.get(key);
+    if (!g) {
+      g = { n: 0, sum: 0, sumSq: 0 };
+      groups.set(key, g);
+    }
+    g.n++;
+    g.sum += y[i];
+    g.sumSq += y[i] * y[i];
+  }
+  const out = {};
+  for (const [k, g] of groups.entries()) {
+    out[k] = {
+      n: g.n,
+      mean: g.sum / g.n,
+      variance: g.n > 1 ? (g.sumSq - (g.sum * g.sum) / g.n) / (g.n - 1) : 0,
+    };
+  }
+  return out;
+}
+
+function twoGroupDiff(x, y, high = 1, low = 0) {
+  const gs = groupStats(x, y);
+  const a = gs[high];
+  const b = gs[low];
+  if (!a || !b) return null;
+  const diff = a.mean - b.mean;
+  const se = Math.sqrt(a.variance / a.n + b.variance / b.n);
+  const z = diff / se;
+  return { diff, p: normalTwoSided(z), z, high: a, low: b };
+}
+
+function simpleSlope(x, y, scale = 1) {
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < x.length; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    rss += e * e;
+  }
+  const sigma2 = rss / (x.length - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = slope / se;
+  return { slope, effect: slope * scale, p: normalTwoSided(z), z };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    assert(Math.abs(m[pivot][i]) > 1e-10, "singular matrix");
+    if (pivot !== i) {
+      const tmp = m[i];
+      m[i] = m[pivot];
+      m[pivot] = tmp;
+    }
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = m[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= f * m[i][c];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function ols(y, columns) {
+  const n = y.length;
+  const p = columns.length + 1;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const c of columns) row.push(c.data[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < columns.length; j++) pred += beta[j + 1] * columns[j].data[i];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const coef = [{ name: "intercept", beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]) }];
+  for (let j = 0; j < columns.length; j++) {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[j + 1][j + 1]));
+    const z = beta[j + 1] / se;
+    coef.push({ name: columns[j].name, beta: beta[j + 1], se, z, p: normalTwoSided(z) });
+  }
+  const yMean = mean(y);
+  let tss = 0;
+  for (const yy of y) tss += (yy - yMean) * (yy - yMean);
+  return { coef, rss, r2: 1 - rss / tss, sigma2 };
