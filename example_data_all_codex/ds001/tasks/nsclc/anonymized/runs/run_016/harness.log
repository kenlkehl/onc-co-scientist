+
+function buildDesign(df, profiles, omitNames = new Set()) {
+  const columns = [];
+  for (const p of profiles) {
+    if (omitNames.has(p.name)) continue;
+    const arr = df[p.name];
+    if (p.role === "continuous") {
+      columns.push({ name: p.name, data: arr });
+    } else if (p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1) {
+      columns.push({ name: p.name, data: arr });
+    } else {
+      const ref = p.values[0][0];
+      for (let i = 1; i < p.values.length; i++) {
+        const lvl = p.values[i][0];
+        columns.push({ name: `${p.name}=${lvl}`, data: arr.map((v) => v === lvl ? 1 : 0) });
+      }
+    }
+  }
+  return columns;
+}
+
+function adjustedEffectFor(df, profiles, targetName) {
+  const omit = new Set([targetName]);
+  const base = buildDesign(df, profiles, omit);
+  const targetProfile = profiles.find((p) => p.name === targetName);
+  const arr = df[targetName];
+  const targets = [];
+  if (targetProfile.role === "continuous") {
+    targets.push({ name: targetName, data: arr });
+  } else if (targetProfile.nunique === 2 && targetProfile.values[0][0] === 0 && targetProfile.values[1][0] === 1) {
+    targets.push({ name: targetName, data: arr });
+  } else {
+    const ref = targetProfile.values[0][0];
+    for (let i = 1; i < targetProfile.values.length; i++) {
+      const lvl = targetProfile.values[i][0];
+      targets.push({ name: `${targetName}=${lvl}`, data: arr.map((v) => v === lvl ? 1 : 0), level: lvl, reference: ref });
+    }
+  }
+  const fit = ols(df[OUTCOME], base.concat(targets));
+  const result = {};
+  for (const t of targets) {
+    const c = fit.coef.find((x) => x.name === t.name);
+    result[t.name] = { ...c, level: t.level, reference: t.reference, r2: fit.r2 };
+  }
+  return result;
+}
+
+function interactionBinary(df, profiles, aName, bName, adjustNames = []) {
+  const y = df[OUTCOME];
+  const a = df[aName];
+  const b = df[bName];
+  const columns = [
+    { name: aName, data: a },
+    { name: bName, data: b },
+    { name: `${aName}:${bName}`, data: a.map((v, i) => v * b[i]) },
+  ];
+  for (const n of adjustNames) {
+    if (n === aName || n === bName) continue;
+    const p = profiles.find((x) => x.name === n);
+    if (!p) continue;
+    if (p.role === "continuous") columns.push({ name: n, data: df[n] });
+    else if (p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1) columns.push({ name: n, data: df[n] });
+  }
+  const fit = ols(y, columns);
+  const c = fit.coef.find((x) => x.name === `${aName}:${bName}`);
+  return { ...c, r2: fit.r2 };
+}
+
+function interactionContinuousBinary(df, profiles, contName, binName, adjustNames = []) {
+  const y = df[OUTCOME];
+  const x = df[contName];
+  const b = df[binName];
+  const xMean = mean(x);
+  const centered = x.map((v) => v - xMean);
+  const columns = [
+    { name: `${contName}_centered`, data: centered },
+    { name: binName, data: b },
+    { name: `${contName}:${binName}`, data: centered.map((v, i) => v * b[i]) },
+  ];
+  for (const n of adjustNames) {
+    if (n === contName || n === binName) continue;
+    const p = profiles.find((x) => x.name === n);
+    if (!p) continue;
+    if (p.role === "continuous") columns.push({ name: n, data: df[n] });
+    else if (p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1) columns.push({ name: n, data: df[n] });
+  }
+  const fit = ols(y, columns);
+  const c = fit.coef.find((x) => x.name === `${contName}:${binName}`);
+  return { ...c, r2: fit.r2 };
+}
+
+function fmt(x, d = 3) {
+  if (x === null || x === undefined) return "NA";
+  if (Math.abs(x) < 0.001 && x !== 0) return x.toExponential(2);
+  return Number(x).toFixed(d);
+}
+
+function addAnalysis(hids, code, summary, effect, p) {
+  return {
+    hypothesis_ids: Array.isArray(hids) ? hids : [hids],
+    code,
+    result_summary: summary,
+    p_value: p,
+    effect_estimate: effect,
+    significant: p < 0.05,
+  };
+}
+
+function pText(p) {
+  return p === 0 ? "p<1e-300" : `p=${fmt(p, 3)}`;
+}
+
+function main() {
+  const { df, metadata, schemaByName } = loadDataset();
+  const y = df[OUTCOME];
+  const profiles = profileColumns(df, schemaByName);
+  const featureNames = profiles.map((p) => p.name);
+
+  const yMean = mean(y);
+  const ySd = Math.sqrt(variance(y, yMean));
+  const sortedY = y.slice().sort((a, b) => a - b);
+  const binaryProfiles = profiles.filter((p) => p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1);
+  const continuousProfiles = profiles.filter((p) => p.role === "continuous");
+  const multiProfiles = profiles.filter((p) => p.role === "categorical" && !(p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1));
+
+  const univBinary = binaryProfiles.map((p) => ({ name: p.name, ...p.univariate, prevalence: p.values[1][1] / y.length }))
+    .filter((r) => r && isFinite(r.diff))
+    .sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  const univContinuous = continuousProfiles.map((p) => ({ name: p.name, scale: p.effect_scale, sd: p.sd, min: p.min, max: p.max, ...p.univariate }))
+    .sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  const multiEffects = [];
+  for (const p of multiProfiles) {
+    if (!p.level_effects) continue;
+    for (const e of p.level_effects) multiEffects.push({ name: p.name, ...e });
+  }
+  multiEffects.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const selectedForAdjustment = [
+    "feature_041",
+    "feature_050",
+    ...univBinary.slice(0, 8).map((x) => x.name),
+    ...univContinuous.slice(0, 10).map((x) => x.name),
+    ...multiProfiles.map((x) => x.name),
+  ];
+  const adjusted = {};
+  for (const n of new Set(selectedForAdjustment)) adjusted[n] = adjustedEffectFor(df, profiles, n);
+
+  const candidateBinary = univBinary.slice(0, 12).map((x) => x.name);
+  const adjustCore = [...new Set([...univBinary.slice(0, 5).map((x) => x.name), ...univContinuous.slice(0, 3).map((x) => x.name)])];
+  const binaryInteractions = [];
+  for (let i = 0; i < candidateBinary.length; i++) {
+    for (let j = i + 1; j < candidateBinary.length; j++) {
+      const a = candidateBinary[i];
+      const b = candidateBinary[j];
+      const r = interactionBinary(df, profiles, a, b, adjustCore);
+      binaryInteractions.push({ a, b, ...r });
+    }
+  }
+  binaryInteractions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const cbInteractions = [];
+  for (const c of univContinuous.slice(0, 5).map((x) => x.name)) {
+    for (const b of candidateBinary.slice(0, 10)) {
