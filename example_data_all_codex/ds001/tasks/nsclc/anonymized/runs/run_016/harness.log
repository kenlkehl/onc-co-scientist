+    const s = this.buf.slice(this.pos, this.pos + len);
+    this.pos += len;
+    return s.toString("utf8");
+  }
+  fieldBegin() {
+    const b = this.readByte();
+    const type = b & 0x0f;
+    if (type === 0) return { type: 0 };
+    const delta = b >> 4;
+    const last = this.last[this.last.length - 1] || 0;
+    const id = delta === 0 ? this.readI32() : last + delta;
+    this.last[this.last.length - 1] = id;
+    return { type, id };
+  }
+  structBegin() {
+    this.last.push(0);
+  }
+  structEnd() {
+    this.last.pop();
+  }
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const etype = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { etype, size };
+  }
+  skip(type) {
