+    const key = x[i];
+    let g = groups.get(key);
+    if (!g) {
+      g = { n: 0, sum: 0, sumSq: 0 };
+      groups.set(key, g);
+    }
+    g.n++;
+    g.sum += y[i];
+    g.sumSq += y[i] * y[i];
