+
+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let res = 0;
+  while (true) {
+    const b = buf[state.pos++];
+    res += (b & 0x7f) * (2 ** shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return res;
