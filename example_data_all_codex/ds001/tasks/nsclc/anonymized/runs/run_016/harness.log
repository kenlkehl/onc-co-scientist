+function interactionContinuousBinary(df, profiles, contName, binName, adjustNames = []) {
+  const y = df[OUTCOME];
+  const x = df[contName];
+  const b = df[binName];
+  const xMean = mean(x);
+  const centered = x.map((v) => v - xMean);
+  const columns = [
+    { name: `${contName}_centered`, data: centered },
+    { name: binName, data: b },
+    { name: `${contName}:${binName}`, data: centered.map((v, i) => v * b[i]) },
+  ];
+  for (const n of adjustNames) {
+    if (n === contName || n === binName) continue;
+    const p = profiles.find((x) => x.name === n);
+    if (!p) continue;
+    if (p.role === "continuous") columns.push({ name: n, data: df[n] });
+    else if (p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1) columns.push({ name: n, data: df[n] });
+  }
+  const fit = ols(y, columns);
+  const c = fit.coef.find((x) => x.name === `${contName}:${binName}`);
+  return { ...c, r2: fit.r2 };
