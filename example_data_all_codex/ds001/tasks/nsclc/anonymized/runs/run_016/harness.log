+    if (isNumber && values.length > 12 && type === 5) role = "continuous";
+    if (isNumber && values.length > 20) role = "continuous";
+    const prof = { name, parquet_type: type, role, nunique: values.length, values: values.slice(0, 20) };
+    if (role === "continuous") {
+      const sorted = arr.slice().sort((a, b) => a - b);
+      prof.min = sorted[0];
+      prof.max = sorted[sorted.length - 1];
+      prof.mean = mean(arr);
+      prof.sd = Math.sqrt(variance(arr, prof.mean));
+      prof.q25 = sorted[Math.floor(0.25 * (sorted.length - 1))];
+      prof.q50 = sorted[Math.floor(0.50 * (sorted.length - 1))];
+      prof.q75 = sorted[Math.floor(0.75 * (sorted.length - 1))];
