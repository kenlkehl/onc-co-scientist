+    iter(11 + k, hs, [
+      addAnalysis(hs[0].id, `OLS: pfs_months ~ ${r.name}`, `A one-SD increase in ${r.name} was associated with ${fmt(r.effect)} months difference in pfs_months (${pText(r.p)}).`, r.effect, r.p),
