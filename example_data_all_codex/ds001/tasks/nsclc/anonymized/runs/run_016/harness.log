+
+function loadDataset() {
+  const buf = fs.readFileSync(DATASET);
+  const metadata = readMetadata(buf);
+  const schema = metadata.schema.slice(1);
+  const schemaByName = {};
+  for (const s of schema) schemaByName[s.name] = s;
+  assert(metadata.row_groups.length === 1, "script expects one row group");
+  const rowGroup = metadata.row_groups[0];
+  const df = {};
+  for (const col of rowGroup.columns) {
+    const name = col.meta_data.path_in_schema[0];
+    df[name] = readColumn(buf, col.meta_data, schemaByName);
+  }
+  return { df, metadata, schemaByName };
