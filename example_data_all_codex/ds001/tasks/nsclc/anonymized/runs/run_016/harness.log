+
+function readPageHeaderAt(buf, offset) {
+  const r = new CompactReader(buf.slice(offset));
+  const header = readStruct(r, {
+    1: { name: "type", read: (r) => r.readI32() },
+    2: { name: "uncompressed_page_size", read: (r) => r.readI32() },
+    3: { name: "compressed_page_size", read: (r) => r.readI32() },
+    4: { name: "crc", read: (r) => r.readI32() },
+    5: { name: "data_page_header", read: (r) => readDataPageHeader(r) },
+    7: { name: "dictionary_page_header", read: (r) => readDictionaryPageHeader(r) },
+    8: { name: "data_page_header_v2", read: (r) => readDataPageHeaderV2(r) },
+  });
