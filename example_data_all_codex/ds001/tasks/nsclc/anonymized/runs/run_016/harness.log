+  while (out.length < count && state.pos < buf.length) {
+    const header = readVarintFrom(buf, state);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const value = readUnsignedLE(buf, state.pos, bytesPerValue);
+      state.pos += bytesPerValue;
+      for (let i = 0; i < run && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const totalValues = groups * 8;
+      let bitBuffer = 0;
+      let bitsInBuffer = 0;
+      for (let i = 0; i < totalValues; i++) {
+        while (bitsInBuffer < width) {
