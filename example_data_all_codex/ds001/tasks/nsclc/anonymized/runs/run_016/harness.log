+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 1;
+        let raw = 0;
+        for (let i = 0; i < bytes; i++) raw |= input[pos++] << (8 * i);
+        len += raw;
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
