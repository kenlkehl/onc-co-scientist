+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return res;
+}
+
+function decodeHybrid(buf, width, count) {
+  if (width === 0) return new Array(count).fill(0);
+  const out = [];
+  const state = { pos: 0 };
+  const bytesPerValue = Math.ceil(width / 8);
+  while (out.length < count && state.pos < buf.length) {
+    const header = readVarintFrom(buf, state);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const value = readUnsignedLE(buf, state.pos, bytesPerValue);
+      state.pos += bytesPerValue;
+      for (let i = 0; i < run && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const totalValues = groups * 8;
+      let bitBuffer = 0;
+      let bitsInBuffer = 0;
+      for (let i = 0; i < totalValues; i++) {
+        while (bitsInBuffer < width) {
+          bitBuffer |= buf[state.pos++] << bitsInBuffer;
+          bitsInBuffer += 8;
+        }
+        const mask = width === 32 ? 0xffffffff : (2 ** width) - 1;
+        const value = bitBuffer & mask;
+        bitBuffer = Math.floor(bitBuffer / (2 ** width));
+        bitsInBuffer -= width;
+        if (out.length < count) out.push(value);
+      }
+    }
+  }
+  assert(out.length === count, "hybrid decode count mismatch");
+  return out;
+}
+
+function decodePlain(type, data, n) {
+  const out = new Array(n);
+  let pos = 0;
+  if (type === 5) {
+    for (let i = 0; i < n; i++) {
+      out[i] = data.readDoubleLE(pos);
+      pos += 8;
+    }
+  } else if (type === 2) {
+    for (let i = 0; i < n; i++) {
+      out[i] = Number(data.readBigInt64LE(pos));
+      pos += 8;
+    }
+  } else if (type === 6) {
+    for (let i = 0; i < n; i++) {
+      const len = data.readInt32LE(pos);
+      pos += 4;
+      out[i] = data.slice(pos, pos + len).toString("utf8");
+      pos += len;
+    }
+  } else {
+    throw new Error("unsupported plain type " + type);
+  }
+  return out;
+}
+
+function readMetadata(buf) {
+  assert(buf.slice(0, 4).toString() === "PAR1", "bad parquet start magic");
+  assert(buf.slice(buf.length - 4).toString() === "PAR1", "bad parquet end magic");
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const metaStart = buf.length - 8 - footerLen;
+  return readFileMetaData(new CompactReader(buf.slice(metaStart, metaStart + footerLen)));
+}
+
+function decompressPage(codec, compressed) {
+  if (codec === 0) return compressed;
+  if (codec === 1) return snappyUncompress(compressed);
+  throw new Error("unsupported compression codec " + codec);
+}
+
+function readColumn(buf, meta, schemaByName) {
+  const type = meta.type;
+  let dictionary = null;
+  if (meta.dictionary_page_offset !== undefined) {
+    const h = readPageHeaderAt(buf, meta.dictionary_page_offset);
+    assert(h.type === 2, "expected dictionary page");
+    const start = meta.dictionary_page_offset + h.header_size;
+    const compressed = buf.slice(start, start + h.compressed_page_size);
+    const data = decompressPage(meta.codec, compressed);
+    dictionary = decodePlain(type, data, h.dictionary_page_header.num_values);
+  }
+  const values = [];
+  let offset = meta.data_page_offset;
+  while (values.length < meta.num_values) {
+    const h = readPageHeaderAt(buf, offset);
+    const start = offset + h.header_size;
+    const compressed = buf.slice(start, start + h.compressed_page_size);
+    let data = decompressPage(meta.codec, compressed);
+    if (h.type === 0) {
+      const dph = h.data_page_header;
+      let pos = 0;
+      const schema = schemaByName[meta.path_in_schema[0]];
+      const maxDefLevel = schema && schema.repetition_type === 1 ? 1 : 0;
+      if (maxDefLevel > 0) {
+        const defLen = data.readUInt32LE(pos);
+        pos += 4 + defLen;
+      }
+      const valueData = data.slice(pos);
+      if (dph.encoding === 8 || dph.encoding === 2) {
+        assert(dictionary, "dictionary data page without dictionary");
+        const width = valueData[0];
+        const idx = decodeHybrid(valueData.slice(1), width, dph.num_values);
+        for (const j of idx) values.push(dictionary[j]);
+      } else if (dph.encoding === 0) {
+        const plain = decodePlain(type, valueData, dph.num_values);
+        for (const v of plain) values.push(v);
+      } else {
+        throw new Error("unsupported data page encoding " + dph.encoding);
+      }
+    } else if (h.type === 3) {
+      const dph = h.data_page_header_v2;
+      let pos = dph.repetition_levels_byte_length + dph.definition_levels_byte_length;
+      const valueData = data.slice(pos);
+      const nonNull = dph.num_values - dph.num_nulls;
+      if (dph.encoding === 8 || dph.encoding === 2) {
+        assert(dictionary, "dictionary data page without dictionary");
+        const width = valueData[0];
+        const idx = decodeHybrid(valueData.slice(1), width, nonNull);
+        for (const j of idx) values.push(dictionary[j]);
+      } else if (dph.encoding === 0) {
+        const plain = decodePlain(type, valueData, nonNull);
+        for (const v of plain) values.push(v);
+      } else {
+        throw new Error("unsupported data page v2 encoding " + dph.encoding);
+      }
+    } else {
+      throw new Error("unexpected page type " + h.type);
+    }
+    offset = start + h.compressed_page_size;
+  }
+  assert(values.length === meta.num_values, "column value count mismatch for " + meta.path_in_schema[0]);
+  return values;
+}
+
+function loadDataset() {
+  const buf = fs.readFileSync(DATASET);
+  const metadata = readMetadata(buf);
+  const schema = metadata.schema.slice(1);
+  const schemaByName = {};
+  for (const s of schema) schemaByName[s.name] = s;
+  assert(metadata.row_groups.length === 1, "script expects one row group");
+  const rowGroup = metadata.row_groups[0];
+  const df = {};
+  for (const col of rowGroup.columns) {
+    const name = col.meta_data.path_in_schema[0];
+    df[name] = readColumn(buf, col.meta_data, schemaByName);
+  }
+  return { df, metadata, schemaByName };
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const x of arr) s += x;
+  return s / arr.length;
+}
+
+function variance(arr, m = mean(arr)) {
+  let s = 0;
+  for (const x of arr) {
+    const d = x - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
+}
+
+function uniqueValues(arr) {
+  const m = new Map();
+  for (const x of arr) m.set(x, (m.get(x) || 0) + 1);
+  return [...m.entries()].sort((a, b) => {
+    if (typeof a[0] === "number" && typeof b[0] === "number") return a[0] - b[0];
+    return String(a[0]).localeCompare(String(b[0]));
+  });
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalTwoSided(z) {
+  const az = Math.abs(z);
+  if (!isFinite(az)) return 1;
+  const p = 2 * (1 - (0.5 * (1 + erf(az / Math.SQRT2))));
+  return Math.max(0, Math.min(1, p));
+}
+
+function groupStats(x, y) {
+  const groups = new Map();
+  for (let i = 0; i < x.length; i++) {
+    const key = x[i];
+    let g = groups.get(key);
+    if (!g) {
+      g = { n: 0, sum: 0, sumSq: 0 };
+      groups.set(key, g);
+    }
+    g.n++;
+    g.sum += y[i];
+    g.sumSq += y[i] * y[i];
+  }
+  const out = {};
+  for (const [k, g] of groups.entries()) {
+    out[k] = {
+      n: g.n,
+      mean: g.sum / g.n,
+      variance: g.n > 1 ? (g.sumSq - (g.sum * g.sum) / g.n) / (g.n - 1) : 0,
+    };
+  }
+  return out;
+}
+
+function twoGroupDiff(x, y, high = 1, low = 0) {
+  const gs = groupStats(x, y);
+  const a = gs[high];
+  const b = gs[low];
+  if (!a || !b) return null;
+  const diff = a.mean - b.mean;
+  const se = Math.sqrt(a.variance / a.n + b.variance / b.n);
+  const z = diff / se;
+  return { diff, p: normalTwoSided(z), z, high: a, low: b };
+}
+
+function simpleSlope(x, y, scale = 1) {
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < x.length; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    rss += e * e;
+  }
+  const sigma2 = rss / (x.length - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = slope / se;
+  return { slope, effect: slope * scale, p: normalTwoSided(z), z };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    assert(Math.abs(m[pivot][i]) > 1e-10, "singular matrix");
+    if (pivot !== i) {
+      const tmp = m[i];
+      m[i] = m[pivot];
+      m[pivot] = tmp;
+    }
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = m[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= f * m[i][c];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function ols(y, columns) {
+  const n = y.length;
+  const p = columns.length + 1;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const c of columns) row.push(c.data[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < columns.length; j++) pred += beta[j + 1] * columns[j].data[i];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const coef = [{ name: "intercept", beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]) }];
+  for (let j = 0; j < columns.length; j++) {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[j + 1][j + 1]));
+    const z = beta[j + 1] / se;
+    coef.push({ name: columns[j].name, beta: beta[j + 1], se, z, p: normalTwoSided(z) });
+  }
+  const yMean = mean(y);
+  let tss = 0;
+  for (const yy of y) tss += (yy - yMean) * (yy - yMean);
+  return { coef, rss, r2: 1 - rss / tss, sigma2 };
+}
+
+function profileColumns(df, schemaByName) {
+  const y = df[OUTCOME];
+  const cols = Object.keys(df).filter((c) => c !== "patient_id" && c !== OUTCOME);
+  return cols.map((name) => {
+    const arr = df[name];
+    const values = uniqueValues(arr);
+    const type = schemaByName[name].type;
+    const isNumber = typeof arr[0] === "number";
+    let role = "categorical";
+    if (isNumber && values.length > 12 && type === 5) role = "continuous";
+    if (isNumber && values.length > 20) role = "continuous";
+    const prof = { name, parquet_type: type, role, nunique: values.length, values: values.slice(0, 20) };
+    if (role === "continuous") {
+      const sorted = arr.slice().sort((a, b) => a - b);
+      prof.min = sorted[0];
+      prof.max = sorted[sorted.length - 1];
+      prof.mean = mean(arr);
+      prof.sd = Math.sqrt(variance(arr, prof.mean));
+      prof.q25 = sorted[Math.floor(0.25 * (sorted.length - 1))];
+      prof.q50 = sorted[Math.floor(0.50 * (sorted.length - 1))];
+      prof.q75 = sorted[Math.floor(0.75 * (sorted.length - 1))];
+      const scale = name === "feature_041" ? 10 : prof.sd;
+      prof.univariate = simpleSlope(arr, y, scale);
+      prof.effect_scale = scale;
+    } else {
+      prof.group_stats = groupStats(arr, y);
+      if (values.length === 2 && values[0][0] === 0 && values[1][0] === 1) {
+        prof.univariate = twoGroupDiff(arr, y, 1, 0);
+      } else {
+        const ref = values[0][0];
+        prof.reference = ref;
+        prof.level_effects = [];
+        for (let i = 1; i < values.length; i++) {
+          const lvl = values[i][0];
+          const bin = arr.map((v) => v === lvl ? 1 : (v === ref ? 0 : null));
+          const yy = [];
+          const xx = [];
+          for (let j = 0; j < bin.length; j++) {
+            if (bin[j] !== null) {
+              xx.push(bin[j]);
+              yy.push(y[j]);
+            }
+          }
+          const res = twoGroupDiff(xx, yy, 1, 0);
+          if (res) prof.level_effects.push({ level: lvl, reference: ref, ...res });
+        }
+      }
+    }
+    return prof;
+  });
+}
+
+function buildDesign(df, profiles, omitNames = new Set()) {
+  const columns = [];
+  for (const p of profiles) {
+    if (omitNames.has(p.name)) continue;
+    const arr = df[p.name];
+    if (p.role === "continuous") {
+      columns.push({ name: p.name, data: arr });
+    } else if (p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1) {
+      columns.push({ name: p.name, data: arr });
+    } else {
+      const ref = p.values[0][0];
+      for (let i = 1; i < p.values.length; i++) {
+        const lvl = p.values[i][0];
+        columns.push({ name: `${p.name}=${lvl}`, data: arr.map((v) => v === lvl ? 1 : 0) });
+      }
+    }
+  }
+  return columns;
+}
+
+function adjustedEffectFor(df, profiles, targetName) {
+  const omit = new Set([targetName]);
+  const base = buildDesign(df, profiles, omit);
+  const targetProfile = profiles.find((p) => p.name === targetName);
+  const arr = df[targetName];
+  const targets = [];
+  if (targetProfile.role === "continuous") {
+    targets.push({ name: targetName, data: arr });
+  } else if (targetProfile.nunique === 2 && targetProfile.values[0][0] === 0 && targetProfile.values[1][0] === 1) {
+    targets.push({ name: targetName, data: arr });
+  } else {
+    const ref = targetProfile.values[0][0];
+    for (let i = 1; i < targetProfile.values.length; i++) {
+      const lvl = targetProfile.values[i][0];
+      targets.push({ name: `${targetName}=${lvl}`, data: arr.map((v) => v === lvl ? 1 : 0), level: lvl, reference: ref });
+    }
+  }
+  const fit = ols(df[OUTCOME], base.concat(targets));
+  const result = {};
+  for (const t of targets) {
+    const c = fit.coef.find((x) => x.name === t.name);
+    result[t.name] = { ...c, level: t.level, reference: t.reference, r2: fit.r2 };
+  }
+  return result;
+}
+
+function interactionBinary(df, profiles, aName, bName, adjustNames = []) {
+  const y = df[OUTCOME];
+  const a = df[aName];
+  const b = df[bName];
+  const columns = [
+    { name: aName, data: a },
+    { name: bName, data: b },
+    { name: `${aName}:${bName}`, data: a.map((v, i) => v * b[i]) },
+  ];
+  for (const n of adjustNames) {
+    if (n === aName || n === bName) continue;
+    const p = profiles.find((x) => x.name === n);
+    if (!p) continue;
+    if (p.role === "continuous") columns.push({ name: n, data: df[n] });
+    else if (p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1) columns.push({ name: n, data: df[n] });
+  }
+  const fit = ols(y, columns);
+  const c = fit.coef.find((x) => x.name === `${aName}:${bName}`);
+  return { ...c, r2: fit.r2 };
+}
+
+function interactionContinuousBinary(df, profiles, contName, binName, adjustNames = []) {
+  const y = df[OUTCOME];
+  const x = df[contName];
+  const b = df[binName];
+  const xMean = mean(x);
+  const centered = x.map((v) => v - xMean);
+  const columns = [
+    { name: `${contName}_centered`, data: centered },
+    { name: binName, data: b },
+    { name: `${contName}:${binName}`, data: centered.map((v, i) => v * b[i]) },
+  ];
+  for (const n of adjustNames) {
+    if (n === contName || n === binName) continue;
+    const p = profiles.find((x) => x.name === n);
+    if (!p) continue;
+    if (p.role === "continuous") columns.push({ name: n, data: df[n] });
+    else if (p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1) columns.push({ name: n, data: df[n] });
+  }
+  const fit = ols(y, columns);
+  const c = fit.coef.find((x) => x.name === `${contName}:${binName}`);
+  return { ...c, r2: fit.r2 };
+}
+
+function fmt(x, d = 3) {
+  if (x === null || x === undefined) return "NA";
+  if (Math.abs(x) < 0.001 && x !== 0) return x.toExponential(2);
+  return Number(x).toFixed(d);
+}
+
+function addAnalysis(hids, code, summary, effect, p) {
+  return {
+    hypothesis_ids: Array.isArray(hids) ? hids : [hids],
+    code,
+    result_summary: summary,
+    p_value: p,
+    effect_estimate: effect,
+    significant: p < 0.05,
+  };
+}
+
+function pText(p) {
+  return p === 0 ? "p<1e-300" : `p=${fmt(p, 3)}`;
+}
+
+function main() {
+  const { df, metadata, schemaByName } = loadDataset();
+  const y = df[OUTCOME];
+  const profiles = profileColumns(df, schemaByName);
+  const featureNames = profiles.map((p) => p.name);
+
+  const yMean = mean(y);
+  const ySd = Math.sqrt(variance(y, yMean));
+  const sortedY = y.slice().sort((a, b) => a - b);
+  const binaryProfiles = profiles.filter((p) => p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1);
+  const continuousProfiles = profiles.filter((p) => p.role === "continuous");
+  const multiProfiles = profiles.filter((p) => p.role === "categorical" && !(p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1));
+
+  const univBinary = binaryProfiles.map((p) => ({ name: p.name, ...p.univariate, prevalence: p.values[1][1] / y.length }))
+    .filter((r) => r && isFinite(r.diff))
+    .sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  const univContinuous = continuousProfiles.map((p) => ({ name: p.name, scale: p.effect_scale, sd: p.sd, min: p.min, max: p.max, ...p.univariate }))
+    .sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+  const multiEffects = [];
+  for (const p of multiProfiles) {
+    if (!p.level_effects) continue;
+    for (const e of p.level_effects) multiEffects.push({ name: p.name, ...e });
+  }
+  multiEffects.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const selectedForAdjustment = [
+    "feature_041",
+    "feature_050",
+    ...univBinary.slice(0, 8).map((x) => x.name),
+    ...univContinuous.slice(0, 10).map((x) => x.name),
+    ...multiProfiles.map((x) => x.name),
+  ];
+  const adjusted = {};
+  for (const n of new Set(selectedForAdjustment)) adjusted[n] = adjustedEffectFor(df, profiles, n);
+
+  const candidateBinary = univBinary.slice(0, 12).map((x) => x.name);
+  const adjustCore = [...new Set([...univBinary.slice(0, 5).map((x) => x.name), ...univContinuous.slice(0, 3).map((x) => x.name)])];
+  const binaryInteractions = [];
+  for (let i = 0; i < candidateBinary.length; i++) {
+    for (let j = i + 1; j < candidateBinary.length; j++) {
+      const a = candidateBinary[i];
+      const b = candidateBinary[j];
+      const r = interactionBinary(df, profiles, a, b, adjustCore);
+      binaryInteractions.push({ a, b, ...r });
+    }
+  }
+  binaryInteractions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+
+  const cbInteractions = [];
+  for (const c of univContinuous.slice(0, 5).map((x) => x.name)) {
+    for (const b of candidateBinary.slice(0, 10)) {
+      const r = interactionContinuousBinary(df, profiles, c, b, adjustCore);
+      cbInteractions.push({ cont: c, bin: b, ...r });
+    }
+  }
+  cbInteractions.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
