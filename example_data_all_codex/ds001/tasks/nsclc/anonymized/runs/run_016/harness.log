+function readColumn(buf, meta, schemaByName) {
+  const type = meta.type;
+  let dictionary = null;
+  if (meta.dictionary_page_offset !== undefined) {
+    const h = readPageHeaderAt(buf, meta.dictionary_page_offset);
+    assert(h.type === 2, "expected dictionary page");
+    const start = meta.dictionary_page_offset + h.header_size;
+    const compressed = buf.slice(start, start + h.compressed_page_size);
+    const data = decompressPage(meta.codec, compressed);
+    dictionary = decodePlain(type, data, h.dictionary_page_header.num_values);
+  }
+  const values = [];
+  let offset = meta.data_page_offset;
+  while (values.length < meta.num_values) {
+    const h = readPageHeaderAt(buf, offset);
+    const start = offset + h.header_size;
+    const compressed = buf.slice(start, start + h.compressed_page_size);
+    let data = decompressPage(meta.codec, compressed);
+    if (h.type === 0) {
+      const dph = h.data_page_header;
+      let pos = 0;
+      const schema = schemaByName[meta.path_in_schema[0]];
+      const maxDefLevel = schema && schema.repetition_type === 1 ? 1 : 0;
+      if (maxDefLevel > 0) {
+        const defLen = data.readUInt32LE(pos);
+        pos += 4 + defLen;
+      }
+      const valueData = data.slice(pos);
+      if (dph.encoding === 8 || dph.encoding === 2) {
+        assert(dictionary, "dictionary data page without dictionary");
+        const width = valueData[0];
+        const idx = decodeHybrid(valueData.slice(1), width, dph.num_values);
+        for (const j of idx) values.push(dictionary[j]);
+      } else if (dph.encoding === 0) {
+        const plain = decodePlain(type, valueData, dph.num_values);
+        for (const v of plain) values.push(v);
+      } else {
+        throw new Error("unsupported data page encoding " + dph.encoding);
+      }
+    } else if (h.type === 3) {
+      const dph = h.data_page_header_v2;
+      let pos = dph.repetition_levels_byte_length + dph.definition_levels_byte_length;
+      const valueData = data.slice(pos);
+      const nonNull = dph.num_values - dph.num_nulls;
+      if (dph.encoding === 8 || dph.encoding === 2) {
+        assert(dictionary, "dictionary data page without dictionary");
+        const width = valueData[0];
+        const idx = decodeHybrid(valueData.slice(1), width, nonNull);
+        for (const j of idx) values.push(dictionary[j]);
+      } else if (dph.encoding === 0) {
+        const plain = decodePlain(type, valueData, nonNull);
+        for (const v of plain) values.push(v);
+      } else {
+        throw new Error("unsupported data page v2 encoding " + dph.encoding);
+      }
+    } else {
+      throw new Error("unexpected page type " + h.type);
+    }
+    offset = start + h.compressed_page_size;
+  }
