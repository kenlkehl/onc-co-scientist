+  const a = gs[high];
+  const b = gs[low];
+  if (!a || !b) return null;
+  const diff = a.mean - b.mean;
+  const se = Math.sqrt(a.variance / a.n + b.variance / b.n);
+  const z = diff / se;
+  return { diff, p: normalTwoSided(z), z, high: a, low: b };
+}
+
+function simpleSlope(x, y, scale = 1) {
+  const mx = mean(x);
+  const my = mean(y);
+  let sxx = 0;
+  let sxy = 0;
+  for (let i = 0; i < x.length; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  let rss = 0;
+  for (let i = 0; i < x.length; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    rss += e * e;
+  }
+  const sigma2 = rss / (x.length - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = slope / se;
+  return { slope, effect: slope * scale, p: normalTwoSided(z), z };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    assert(Math.abs(m[pivot][i]) > 1e-10, "singular matrix");
+    if (pivot !== i) {
+      const tmp = m[i];
+      m[i] = m[pivot];
+      m[pivot] = tmp;
+    }
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = m[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= f * m[i][c];
+    }
+  }
+  return m.map((row) => row.slice(n));
+}
+
+function ols(y, columns) {
+  const n = y.length;
+  const p = columns.length + 1;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const c of columns) row.push(c.data[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < columns.length; j++) pred += beta[j + 1] * columns[j].data[i];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const coef = [{ name: "intercept", beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]) }];
+  for (let j = 0; j < columns.length; j++) {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[j + 1][j + 1]));
+    const z = beta[j + 1] / se;
+    coef.push({ name: columns[j].name, beta: beta[j + 1], se, z, p: normalTwoSided(z) });
+  }
+  const yMean = mean(y);
+  let tss = 0;
+  for (const yy of y) tss += (yy - yMean) * (yy - yMean);
+  return { coef, rss, r2: 1 - rss / tss, sigma2 };
+}
+
+function profileColumns(df, schemaByName) {
+  const y = df[OUTCOME];
+  const cols = Object.keys(df).filter((c) => c !== "patient_id" && c !== OUTCOME);
+  return cols.map((name) => {
+    const arr = df[name];
+    const values = uniqueValues(arr);
+    const type = schemaByName[name].type;
+    const isNumber = typeof arr[0] === "number";
+    let role = "categorical";
+    if (isNumber && values.length > 12 && type === 5) role = "continuous";
+    if (isNumber && values.length > 20) role = "continuous";
+    const prof = { name, parquet_type: type, role, nunique: values.length, values: values.slice(0, 20) };
+    if (role === "continuous") {
+      const sorted = arr.slice().sort((a, b) => a - b);
+      prof.min = sorted[0];
+      prof.max = sorted[sorted.length - 1];
+      prof.mean = mean(arr);
+      prof.sd = Math.sqrt(variance(arr, prof.mean));
+      prof.q25 = sorted[Math.floor(0.25 * (sorted.length - 1))];
+      prof.q50 = sorted[Math.floor(0.50 * (sorted.length - 1))];
+      prof.q75 = sorted[Math.floor(0.75 * (sorted.length - 1))];
