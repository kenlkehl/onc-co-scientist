+function readMetadata(buf) {
+  assert(buf.slice(0, 4).toString() === "PAR1", "bad parquet start magic");
+  assert(buf.slice(buf.length - 4).toString() === "PAR1", "bad parquet end magic");
+  const footerLen = buf.readUInt32LE(buf.length - 8);
+  const metaStart = buf.length - 8 - footerLen;
+  return readFileMetaData(new CompactReader(buf.slice(metaStart, metaStart + footerLen)));
