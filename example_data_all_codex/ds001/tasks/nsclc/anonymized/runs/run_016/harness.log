+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => {
+    const r = row.slice();
+    for (let j = 0; j < n; j++) r.push(i === j ? 1 : 0);
+    return r;
+  });
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    assert(Math.abs(m[pivot][i]) > 1e-10, "singular matrix");
+    if (pivot !== i) {
+      const tmp = m[i];
+      m[i] = m[pivot];
+      m[pivot] = tmp;
+    }
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const f = m[r][i];
+      if (f === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= f * m[i][c];
