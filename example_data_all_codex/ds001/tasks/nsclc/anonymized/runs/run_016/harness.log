+      } else {
+        const ref = values[0][0];
+        prof.reference = ref;
+        prof.level_effects = [];
+        for (let i = 1; i < values.length; i++) {
+          const lvl = values[i][0];
+          const bin = arr.map((v) => v === lvl ? 1 : (v === ref ? 0 : null));
+          const yy = [];
+          const xx = [];
+          for (let j = 0; j < bin.length; j++) {
+            if (bin[j] !== null) {
+              xx.push(bin[j]);
+              yy.push(y[j]);
+            }
+          }
+          const res = twoGroupDiff(xx, yy, 1, 0);
