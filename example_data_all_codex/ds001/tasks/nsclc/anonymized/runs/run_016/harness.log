+  const candidateBinary = univBinary.slice(0, 12).map((x) => x.name);
+  const adjustCore = [...new Set([...univBinary.slice(0, 5).map((x) => x.name), ...univContinuous.slice(0, 3).map((x) => x.name)])];
+  const binaryInteractions = [];
+  for (let i = 0; i < candidateBinary.length; i++) {
+    for (let j = i + 1; j < candidateBinary.length; j++) {
+      const a = candidateBinary[i];
+      const b = candidateBinary[j];
