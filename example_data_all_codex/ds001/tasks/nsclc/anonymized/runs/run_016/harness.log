+    const id = delta === 0 ? this.readI32() : last + delta;
+    this.last[this.last.length - 1] = id;
+    return { type, id };
+  }
+  structBegin() {
+    this.last.push(0);
+  }
+  structEnd() {
+    this.last.pop();
+  }
+  readListBegin() {
+    const b = this.readByte();
+    let size = b >> 4;
+    const etype = b & 0x0f;
+    if (size === 15) size = Number(this.readVarint());
+    return { etype, size };
+  }
+  skip(type) {
+    switch (type) {
+      case 0: return;
+      case 1:
+      case 2: return;
+      case 3: this.pos += 1; return;
+      case 4:
+      case 5: this.readI32(); return;
+      case 6: this.readI64(); return;
+      case 7: this.pos += 8; return;
+      case 8: {
+        const len = Number(this.readVarint());
+        this.pos += len;
+        return;
+      }
+      case 9:
+      case 10: {
+        const l = this.readListBegin();
+        for (let i = 0; i < l.size; i++) this.skip(l.etype);
+        return;
+      }
+      case 11: {
+        const size = Number(this.readVarint());
+        if (size === 0) return;
+        const tb = this.readByte();
+        const kt = tb >> 4;
+        const vt = tb & 0x0f;
+        for (let i = 0; i < size; i++) {
+          this.skip(kt);
+          this.skip(vt);
+        }
+        return;
+      }
+      case 12: {
+        this.structBegin();
+        while (true) {
+          const f = this.fieldBegin();
+          if (f.type === 0) break;
+          this.skip(f.type);
+        }
+        this.structEnd();
+        return;
+      }
+      default:
+        throw new Error("unknown thrift compact type " + type);
+    }
+  }
