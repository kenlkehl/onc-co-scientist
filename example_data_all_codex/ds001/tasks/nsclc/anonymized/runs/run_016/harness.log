+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  for (let i = 0; i < n; i++) {
+    const row = [1];
+    for (const c of columns) row.push(c.data[i]);
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b < p; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let rss = 0;
+  for (let i = 0; i < n; i++) {
+    let pred = beta[0];
+    for (let j = 0; j < columns.length; j++) pred += beta[j + 1] * columns[j].data[i];
+    const e = y[i] - pred;
+    rss += e * e;
+  }
+  const sigma2 = rss / (n - p);
+  const coef = [{ name: "intercept", beta: beta[0], se: Math.sqrt(sigma2 * inv[0][0]) }];
+  for (let j = 0; j < columns.length; j++) {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[j + 1][j + 1]));
+    const z = beta[j + 1] / se;
+    coef.push({ name: columns[j].name, beta: beta[j + 1], se, z, p: normalTwoSided(z) });
+  }
+  const yMean = mean(y);
+  let tss = 0;
+  for (const yy of y) tss += (yy - yMean) * (yy - yMean);
+  return { coef, rss, r2: 1 - rss / tss, sigma2 };
