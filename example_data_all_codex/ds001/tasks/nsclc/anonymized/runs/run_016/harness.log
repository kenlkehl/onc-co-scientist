+class CompactReader {
+  constructor(buf) {
+    this.buf = buf;
+    this.pos = 0;
+    this.last = [];
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarint() {
+    let shift = 0n;
+    let res = 0n;
+    while (true) {
+      const b = this.readByte();
+      res |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return res;
+  }
+  zig(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  readI32() {
+    return Number(this.zig(this.readVarint()));
+  }
+  readI64() {
+    return this.zig(this.readVarint());
+  }
+  readDouble() {
+    const v = this.buf.readDoubleLE(this.pos);
+    this.pos += 8;
+    return v;
+  }
+  readBinary() {
