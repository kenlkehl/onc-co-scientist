+  const selectedForAdjustment = [
+    "feature_041",
+    "feature_050",
+    ...univBinary.slice(0, 8).map((x) => x.name),
+    ...univContinuous.slice(0, 10).map((x) => x.name),
+    ...multiProfiles.map((x) => x.name),
