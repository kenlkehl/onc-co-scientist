+
+function snappyUncompress(input) {
+  let pos = 0;
+  let shift = 0;
+  let outLen = 0;
+  while (true) {
+    const b = input[pos++];
+    outLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(outLen);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 1;
+        let raw = 0;
+        for (let i = 0; i < bytes; i++) raw |= input[pos++] << (8 * i);
+        len += raw;
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = (input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24)) >>> 0;
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) {
+        out[op] = out[op - offset];
+        op++;
+      }
+    }
+  }
+  assert(op === outLen, "snappy size mismatch");
+  return out;
+}
+
+function bitWidth(n) {
+  let w = 0;
+  while (n > 0) {
+    w++;
+    n >>= 1;
+  }
+  return w;
+}
+
+function readUnsignedLE(buf, pos, bytes) {
+  let v = 0;
+  for (let i = 0; i < bytes; i++) v += buf[pos + i] * (2 ** (8 * i));
+  return v;
+}
+
+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let res = 0;
+  while (true) {
+    const b = buf[state.pos++];
+    res += (b & 0x7f) * (2 ** shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return res;
