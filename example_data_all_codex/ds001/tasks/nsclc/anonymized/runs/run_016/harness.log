+}
+
+function bitWidth(n) {
+  let w = 0;
+  while (n > 0) {
+    w++;
+    n >>= 1;
+  }
+  return w;
+}
+
+function readUnsignedLE(buf, pos, bytes) {
+  let v = 0;
+  for (let i = 0; i < bytes; i++) v += buf[pos + i] * (2 ** (8 * i));
+  return v;
+}
+
+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let res = 0;
+  while (true) {
+    const b = buf[state.pos++];
+    res += (b & 0x7f) * (2 ** shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return res;
