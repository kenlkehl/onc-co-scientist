+function interactionBinary(df, profiles, aName, bName, adjustNames = []) {
+  const y = df[OUTCOME];
+  const a = df[aName];
+  const b = df[bName];
+  const columns = [
+    { name: aName, data: a },
+    { name: bName, data: b },
