+    5: { name: "data_page_header", read: (r) => readDataPageHeader(r) },
+    7: { name: "dictionary_page_header", read: (r) => readDictionaryPageHeader(r) },
+    8: { name: "data_page_header_v2", read: (r) => readDataPageHeaderV2(r) },
+  });
+  header.header_size = r.pos;
+  return header;
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let shift = 0;
+  let outLen = 0;
+  while (true) {
+    const b = input[pos++];
+    outLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(outLen);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 1;
+        let raw = 0;
+        for (let i = 0; i < bytes; i++) raw |= input[pos++] << (8 * i);
+        len += raw;
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = (input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24)) >>> 0;
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) {
+        out[op] = out[op - offset];
+        op++;
+      }
+    }
+  }
+  assert(op === outLen, "snappy size mismatch");
+  return out;
+}
+
+function bitWidth(n) {
+  let w = 0;
+  while (n > 0) {
+    w++;
+    n >>= 1;
+  }
+  return w;
+}
+
+function readUnsignedLE(buf, pos, bytes) {
+  let v = 0;
+  for (let i = 0; i < bytes; i++) v += buf[pos + i] * (2 ** (8 * i));
+  return v;
+}
+
+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let res = 0;
+  while (true) {
+    const b = buf[state.pos++];
+    res += (b & 0x7f) * (2 ** shift);
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return res;
+}
+
+function decodeHybrid(buf, width, count) {
+  if (width === 0) return new Array(count).fill(0);
+  const out = [];
+  const state = { pos: 0 };
+  const bytesPerValue = Math.ceil(width / 8);
+  while (out.length < count && state.pos < buf.length) {
+    const header = readVarintFrom(buf, state);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      const value = readUnsignedLE(buf, state.pos, bytesPerValue);
+      state.pos += bytesPerValue;
+      for (let i = 0; i < run && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const totalValues = groups * 8;
+      let bitBuffer = 0;
+      let bitsInBuffer = 0;
+      for (let i = 0; i < totalValues; i++) {
+        while (bitsInBuffer < width) {
+          bitBuffer |= buf[state.pos++] << bitsInBuffer;
+          bitsInBuffer += 8;
+        }
+        const mask = width === 32 ? 0xffffffff : (2 ** width) - 1;
+        const value = bitBuffer & mask;
+        bitBuffer = Math.floor(bitBuffer / (2 ** width));
+        bitsInBuffer -= width;
+        if (out.length < count) out.push(value);
+      }
+    }
+  }
+  assert(out.length === count, "hybrid decode count mismatch");
+  return out;
+}
+
+function decodePlain(type, data, n) {
+  const out = new Array(n);
+  let pos = 0;
+  if (type === 5) {
+    for (let i = 0; i < n; i++) {
+      out[i] = data.readDoubleLE(pos);
+      pos += 8;
+    }
+  } else if (type === 2) {
+    for (let i = 0; i < n; i++) {
+      out[i] = Number(data.readBigInt64LE(pos));
+      pos += 8;
+    }
+  } else if (type === 6) {
+    for (let i = 0; i < n; i++) {
+      const len = data.readInt32LE(pos);
+      pos += 4;
+      out[i] = data.slice(pos, pos + len).toString("utf8");
+      pos += len;
+    }
+  } else {
+    throw new Error("unsupported plain type " + type);
+  }
