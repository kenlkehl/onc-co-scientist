+      prof.univariate = simpleSlope(arr, y, scale);
+      prof.effect_scale = scale;
+    } else {
+      prof.group_stats = groupStats(arr, y);
+      if (values.length === 2 && values[0][0] === 0 && values[1][0] === 1) {
+        prof.univariate = twoGroupDiff(arr, y, 1, 0);
+      } else {
+        const ref = values[0][0];
+        prof.reference = ref;
+        prof.level_effects = [];
+        for (let i = 1; i < values.length; i++) {
+          const lvl = values[i][0];
+          const bin = arr.map((v) => v === lvl ? 1 : (v === ref ? 0 : null));
+          const yy = [];
+          const xx = [];
+          for (let j = 0; j < bin.length; j++) {
+            if (bin[j] !== null) {
+              xx.push(bin[j]);
+              yy.push(y[j]);
+            }
+          }
+          const res = twoGroupDiff(xx, yy, 1, 0);
+          if (res) prof.level_effects.push({ level: lvl, reference: ref, ...res });
+        }
