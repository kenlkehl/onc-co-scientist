+
+function mean(arr) {
+  let s = 0;
+  for (const x of arr) s += x;
+  return s / arr.length;
+}
+
+function variance(arr, m = mean(arr)) {
+  let s = 0;
+  for (const x of arr) {
+    const d = x - m;
+    s += d * d;
+  }
+  return s / (arr.length - 1);
