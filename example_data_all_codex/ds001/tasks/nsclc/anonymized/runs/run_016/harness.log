+    4: { name: "name", read: (r) => r.readBinary() },
+    5: { name: "num_children", read: (r) => r.readI32() },
+    6: { name: "converted_type", read: (r) => r.readI32() },
+    10: { name: "logicalType", read: (r, t) => { r.skip(t); return true; } },
+  });
+}
+
+function readStatistics(r) {
+  return readStruct(r, {
+    3: { name: "null_count", read: (r) => Number(r.readI64()) },
+    4: { name: "distinct_count", read: (r) => Number(r.readI64()) },
+    7: { name: "is_max_value_exact", read: (r, t) => t === 1 },
+    8: { name: "is_min_value_exact", read: (r, t) => t === 1 },
+  });
+}
+
+function readColumnMetaData(r) {
+  return readStruct(r, {
+    1: { name: "type", read: (r) => r.readI32() },
+    2: {
+      name: "encodings",
+      read: (r) => {
+        const l = r.readListBegin();
+        const a = [];
+        for (let i = 0; i < l.size; i++) a.push(r.readI32());
+        return a;
+      },
+    },
+    3: {
+      name: "path_in_schema",
+      read: (r) => {
+        const l = r.readListBegin();
+        const a = [];
+        for (let i = 0; i < l.size; i++) a.push(r.readBinary());
+        return a;
+      },
+    },
+    4: { name: "codec", read: (r) => r.readI32() },
+    5: { name: "num_values", read: (r) => Number(r.readI64()) },
+    6: { name: "total_uncompressed_size", read: (r) => Number(r.readI64()) },
+    7: { name: "total_compressed_size", read: (r) => Number(r.readI64()) },
+    9: { name: "data_page_offset", read: (r) => Number(r.readI64()) },
+    10: { name: "index_page_offset", read: (r) => Number(r.readI64()) },
+    11: { name: "dictionary_page_offset", read: (r) => Number(r.readI64()) },
+    12: { name: "statistics", read: (r) => readStatistics(r) },
+  });
+}
+
+function readColumnChunk(r) {
+  return readStruct(r, {
+    1: { name: "file_path", read: (r) => r.readBinary() },
+    2: { name: "file_offset", read: (r) => Number(r.readI64()) },
+    3: { name: "meta_data", read: (r) => readColumnMetaData(r) },
+    4: { name: "offset_index_offset", read: (r) => Number(r.readI64()) },
+    5: { name: "offset_index_length", read: (r) => r.readI32() },
+    6: { name: "column_index_offset", read: (r) => Number(r.readI64()) },
+    7: { name: "column_index_length", read: (r) => r.readI32() },
+  });
+}
+
+function readRowGroup(r) {
+  return readStruct(r, {
+    1: {
+      name: "columns",
+      read: (r) => {
+        const l = r.readListBegin();
+        const a = [];
+        for (let i = 0; i < l.size; i++) a.push(readColumnChunk(r));
+        return a;
+      },
+    },
+    2: { name: "total_byte_size", read: (r) => Number(r.readI64()) },
+    3: { name: "num_rows", read: (r) => Number(r.readI64()) },
+    6: { name: "total_compressed_size", read: (r) => Number(r.readI64()) },
+  });
+}
+
+function readFileMetaData(r) {
+  return readStruct(r, {
+    1: { name: "version", read: (r) => r.readI32() },
+    2: {
+      name: "schema",
+      read: (r) => {
+        const l = r.readListBegin();
+        const a = [];
+        for (let i = 0; i < l.size; i++) a.push(readSchemaElement(r));
+        return a;
+      },
+    },
+    3: { name: "num_rows", read: (r) => Number(r.readI64()) },
+    4: {
+      name: "row_groups",
+      read: (r) => {
+        const l = r.readListBegin();
+        const a = [];
+        for (let i = 0; i < l.size; i++) a.push(readRowGroup(r));
+        return a;
+      },
+    },
+    5: { name: "key_value_metadata", read: (r, t) => { r.skip(t); return true; } },
+    6: { name: "created_by", read: (r) => r.readBinary() },
+  });
+}
+
+function readDictionaryPageHeader(r) {
+  return readStruct(r, {
+    1: { name: "num_values", read: (r) => r.readI32() },
+    2: { name: "encoding", read: (r) => r.readI32() },
+    3: { name: "is_sorted", read: (r, t) => t === 1 },
+  });
+}
+
+function readDataPageHeader(r) {
+  return readStruct(r, {
+    1: { name: "num_values", read: (r) => r.readI32() },
+    2: { name: "encoding", read: (r) => r.readI32() },
+    3: { name: "definition_level_encoding", read: (r) => r.readI32() },
+    4: { name: "repetition_level_encoding", read: (r) => r.readI32() },
+    5: { name: "statistics", read: (r) => readStatistics(r) },
+  });
+}
+
+function readDataPageHeaderV2(r) {
+  return readStruct(r, {
+    1: { name: "num_values", read: (r) => r.readI32() },
+    2: { name: "num_nulls", read: (r) => r.readI32() },
+    3: { name: "num_rows", read: (r) => r.readI32() },
+    4: { name: "encoding", read: (r) => r.readI32() },
+    5: { name: "definition_levels_byte_length", read: (r) => r.readI32() },
+    6: { name: "repetition_levels_byte_length", read: (r) => r.readI32() },
+    7: { name: "is_compressed", read: (r, t) => t === 1 },
+    8: { name: "statistics", read: (r) => readStatistics(r) },
+  });
