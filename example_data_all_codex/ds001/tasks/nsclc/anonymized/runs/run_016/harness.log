+
+function buildDesign(df, profiles, omitNames = new Set()) {
+  const columns = [];
+  for (const p of profiles) {
+    if (omitNames.has(p.name)) continue;
+    const arr = df[p.name];
+    if (p.role === "continuous") {
+      columns.push({ name: p.name, data: arr });
+    } else if (p.nunique === 2 && p.values[0][0] === 0 && p.values[1][0] === 1) {
+      columns.push({ name: p.name, data: arr });
+    } else {
+      const ref = p.values[0][0];
+      for (let i = 1; i < p.values.length; i++) {
+        const lvl = p.values[i][0];
+        columns.push({ name: `${p.name}=${lvl}`, data: arr.map((v) => v === lvl ? 1 : 0) });
+      }
+    }
+  }
+  return columns;
+}
+
+function adjustedEffectFor(df, profiles, targetName) {
+  const omit = new Set([targetName]);
+  const base = buildDesign(df, profiles, omit);
+  const targetProfile = profiles.find((p) => p.name === targetName);
+  const arr = df[targetName];
+  const targets = [];
+  if (targetProfile.role === "continuous") {
+    targets.push({ name: targetName, data: arr });
+  } else if (targetProfile.nunique === 2 && targetProfile.values[0][0] === 0 && targetProfile.values[1][0] === 1) {
+    targets.push({ name: targetName, data: arr });
+  } else {
+    const ref = targetProfile.values[0][0];
+    for (let i = 1; i < targetProfile.values.length; i++) {
+      const lvl = targetProfile.values[i][0];
+      targets.push({ name: `${targetName}=${lvl}`, data: arr.map((v) => v === lvl ? 1 : 0), level: lvl, reference: ref });
+    }
+  }
+  const fit = ols(df[OUTCOME], base.concat(targets));
+  const result = {};
+  for (const t of targets) {
+    const c = fit.coef.find((x) => x.name === t.name);
+    result[t.name] = { ...c, level: t.level, reference: t.reference, r2: fit.r2 };
+  }
+  return result;
