+const CT_STOP = 0;
+const CT_TRUE = 1;
+const CT_FALSE = 2;
+const CT_BYTE = 3;
+const CT_I16 = 4;
+const CT_I32 = 5;
+const CT_I64 = 6;
+const CT_DOUBLE = 7;
+const CT_BINARY = 8;
+const CT_LIST = 9;
+const CT_SET = 10;
+const CT_MAP = 11;
+const CT_STRUCT = 12;
