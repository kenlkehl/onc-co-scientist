+const fs = require('fs');
+
+const buf = fs.readFileSync('dataset.parquet');
+const footerLen = buf.readUInt32LE(buf.length - 8);
+const footer = buf.subarray(buf.length - 8 - footerLen, buf.length - 8);
+
+const CT_STOP = 0;
+const CT_TRUE = 1;
+const CT_FALSE = 2;
+const CT_BYTE = 3;
+const CT_I16 = 4;
+const CT_I32 = 5;
+const CT_I64 = 6;
+const CT_DOUBLE = 7;
+const CT_BINARY = 8;
+const CT_LIST = 9;
+const CT_SET = 10;
+const CT_MAP = 11;
+const CT_STRUCT = 12;
+
+class CompactReader {
+  constructor(buffer) {
+    this.buf = buffer;
+    this.pos = 0;
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
+  }
+  readZigZag() {
+    const n = this.readVarintBig();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readBinary() {
+    const len = this.readVarint();
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out.toString('utf8');
+  }
+  readList(elemReader) {
+    const header = this.readByte();
+    let size = header >> 4;
+    const type = header & 0x0f;
+    if (size === 15) size = this.readVarint();
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(elemReader(type));
+    return arr;
+  }
+  readValue(type) {
+    switch (type) {
+      case CT_TRUE: return true;
+      case CT_FALSE: return false;
+      case CT_BYTE: return this.readByte();
+      case CT_I16:
+      case CT_I32:
+      case CT_I64: return this.readZigZag();
+      case CT_DOUBLE: {
+        const v = this.buf.readDoubleLE(this.pos);
+        this.pos += 8;
+        return v;
+      }
+      case CT_BINARY: return this.readBinary();
+      case CT_LIST:
+      case CT_SET: return this.readList(t => this.readValue(t));
+      case CT_STRUCT: return this.readStruct();
+      case CT_MAP: {
+        const size = this.readVarint();
+        if (size === 0) return [];
+        const types = this.readByte();
+        const kt = types >> 4;
+        const vt = types & 0x0f;
+        const arr = [];
+        for (let i = 0; i < size; i++) arr.push([this.readValue(kt), this.readValue(vt)]);
+        return arr;
+      }
+      default: throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+    }
+  }
+  readStruct() {
+    const obj = {};
+    let lastField = 0;
+    while (true) {
+      const b = this.readByte();
+      const type = b & 0x0f;
+      if (type === CT_STOP) break;
+      const delta = b >> 4;
+      let fieldId;
+      if (delta === 0) fieldId = this.readZigZag();
+      else fieldId = lastField + delta;
+      lastField = fieldId;
+      obj[fieldId] = this.readValue(type);
+    }
+    return obj;
+  }
+}
+
+const meta = new CompactReader(footer).readStruct();
+const schema = meta[2];
+const rowGroups = meta[4];
+function pageHeadersFor(col, limit = 3) {
+  const out = [];
+  let pos = col.dictPageOffset || col.dataPageOffset;
+  const end = (col.dictPageOffset || col.dataPageOffset) + col.totalCompressed;
+  while (pos < end && out.length < limit) {
+    const r = new CompactReader(buf.subarray(pos));
+    const h = r.readStruct();
+    out.push({
+      offset: pos,
+      headerBytes: r.pos,
+      type: h[1],
+      uncompressed: h[2],
+      compressed: h[3],
+      dataHeader: h[5] || null,
+      dictHeader: h[7] || null,
+      dataV2Header: h[8] || null
+    });
+    pos += r.pos + h[3];
+  }
+  return out;
+}
+const columns = rowGroups[0][1].map(cc => ({
+  path: cc[3][3],
+  type: cc[3][1],
+  encodings: cc[3][2],
+  codec: cc[3][4],
+  numValues: cc[3][5],
+  totalUncompressed: cc[3][6],
+  totalCompressed: cc[3][7],
+  dataPageOffset: cc[3][9],
+  dictPageOffset: cc[3][11]
+}));
+console.log(JSON.stringify({
+  version: meta[1],
+  numRows: meta[3],
+  createdBy: meta[6],
+  schema: schema.map(s => ({
+    name: s[4],
+    type: s[1],
+    repetition: s[3],
+    numChildren: s[5],
+    converted: s[6],
+    logical: s[10] ? true : false
+  })),
+  rowGroups: rowGroups.map(rg => ({
+    numRows: rg[3],
+    columns
+  })),
+  samplePageHeaders: Object.fromEntries([
+    columns[0],
+    columns[1],
+    columns[13],
+    columns[14],
+    columns[columns.length - 1]
+  ].map(c => [c.path[0], pageHeadersFor(c)]))
+}, null, 2));

