+  addIteration(12, [
+    h('h12a', 'After adjustment for the leading main-effect features, `feature_025=current` remains independently associated with lower `pfs_months`.', 'refined'),
+    h('h12b', 'After adjustment for the leading main-effect features, `feature_025=never` remains independently associated with higher `pfs_months`.', 'refined'),
+    h('h12c', 'After adjustment for the leading main-effect features, `feature_066=1` remains independently associated with higher `pfs_months`.', 'refined'),
+  ], [adjAnalysis('feature_025=current', 'h12a'), adjAnalysis('feature_025=never', 'h12b'), adjAnalysis('feature_066', 'h12c')]);
+
