+class CompactReader {
+  constructor(buffer) {
+    this.buf = buffer;
+    this.pos = 0;
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
+  }
+  readZigZag() {
+    const n = this.readVarintBig();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readBinary() {
