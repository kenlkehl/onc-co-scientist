+
+function linearSlope(y, x) {
+  const n = y.length;
+  let sx = 0, sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0, sxy = 0, sse = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  for (let i = 0; i < n; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    sse += e * e;
+  }
+  const sigma2 = sse / (n - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = slope / se;
+  return { slope, intercept, se, z, p: twoSidedNormalP(z), meanX: mx, sdX: Math.sqrt(sxx / (n - 1)) };
