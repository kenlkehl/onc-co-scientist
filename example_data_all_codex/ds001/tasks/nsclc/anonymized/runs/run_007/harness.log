+
+function summarizeColumn(arr) {
+  const n = arr.length;
+  const counts = new Map();
+  let numeric = true;
+  let min = Infinity;
+  let max = -Infinity;
+  let sum = 0;
+  for (const v of arr) {
+    counts.set(v, (counts.get(v) || 0) + 1);
+    if (typeof v !== 'number') numeric = false;
+    else {
+      if (v < min) min = v;
+      if (v > max) max = v;
+      sum += v;
+    }
+  }
