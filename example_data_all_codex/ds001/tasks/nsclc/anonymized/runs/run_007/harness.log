+      const fit = ols(y, [
+        { name: ct.feature, x: xCentered },
+        { name: bin.label, x: bx },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        binary: bin,
+        continuous: ct,
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+      });
+    }
+  }
