+
+function xtxFromColumns(cols, y) {
+  const n = y.length;
+  const p = cols.length;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = cols.map(c => c[i]);
+    yty += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = a + 1; b < p; b++) xtx[a][b] = xtx[b][a];
+  }
+  return { xtx, xty, yty, n, p };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => row.slice().concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== i) [m[i], m[pivot]] = [m[pivot], m[i]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = m[r][i];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= factor * m[i][c];
+    }
+  }
+  return m.map(row => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const names = ['intercept'].concat(predictors.map(p => p.name));
+  const cols = [new Array(y.length).fill(1)].concat(predictors.map(p => p.x));
+  const { xtx, xty, yty, n, p } = xtxFromColumns(cols, y);
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let bxty = 0;
+  for (let i = 0; i < p; i++) bxty += beta[i] * xty[i];
+  const sse = Math.max(0, yty - bxty);
+  const sigma2 = sse / (n - p);
+  const coefficients = names.map((name, i) => {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    const z = beta[i] / se;
+    return { name, beta: beta[i], se, z, p: twoSidedNormalP(z) };
+  });
+  return { coefficients, sse, sigma2, df: n - p };
+}
+
+function centered(arr) {
+  const m = mean(arr);
+  return arr.map(v => v - m);
+}
+
+function sdValue(arr) {
+  return sd(arr);
+}
+
+function preparePredictorForTest(test, data) {
+  if (test.kind === 'continuous') {
+    return { name: test.feature, x: data[test.feature].slice(), descriptor: test.feature, kind: 'continuous' };
+  }
+  const level = test.level;
+  return {
+    name: test.variable,
+    x: data[test.feature].map(v => v === level ? 1 : 0),
+    descriptor: test.variable,
+    kind: test.kind,
+  };
+}
+
+function screenBinaryInteractions(data, dummies) {
+  const y = data.pfs_months;
+  const candidates = dummies.filter(d => {
+    const n1 = d.x.reduce((a, b) => a + (b ? 1 : 0), 0);
+    return n1 >= 1000 && n1 <= y.length - 1000;
+  });
+  const out = [];
+  for (let i = 0; i < candidates.length; i++) {
+    for (let j = i + 1; j < candidates.length; j++) {
+      if (candidates[i].feature === candidates[j].feature) continue;
+      const a = candidates[i].x;
+      const b = candidates[j].x;
+      let n00 = 0, n01 = 0, n10 = 0, n11 = 0;
+      for (let k = 0; k < y.length; k++) {
+        if (a[k] && b[k]) n11++;
+        else if (a[k]) n10++;
+        else if (b[k]) n01++;
+        else n00++;
+      }
+      if (Math.min(n00, n01, n10, n11) < 250) continue;
+      const interaction = a.map((v, k) => (v && b[k]) ? 1 : 0);
+      const fit = ols(y, [
+        { name: candidates[i].label, x: a.map(Number) },
+        { name: candidates[j].label, x: b.map(Number) },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        a: candidates[i],
+        b: candidates[j],
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+        n00,
+        n01,
+        n10,
+        n11,
+      });
+    }
+  }
+  out.sort((x, y2) => x.p - y2.p);
+  return out;
+}
+
+function screenBinaryContinuousInteractions(data, dummies, continuousTests) {
+  const y = data.pfs_months;
+  const binaries = dummies.filter(d => {
+    const n1 = d.x.reduce((a, b) => a + (b ? 1 : 0), 0);
+    return n1 >= 1000 && n1 <= y.length - 1000;
+  });
+  const continuous = continuousTests
+    .filter(t => t.kind === 'continuous')
+    .sort((a, b) => a.p - b.p)
+    .slice(0, 20);
+  const out = [];
+  for (const bin of binaries) {
+    const bx = bin.x.map(Number);
+    for (const ct of continuous) {
+      if (bin.feature === ct.feature) continue;
+      const x = data[ct.feature];
+      const xCentered = centered(x);
+      const interaction = xCentered.map((v, i) => v * bx[i]);
+      const fit = ols(y, [
+        { name: ct.feature, x: xCentered },
+        { name: bin.label, x: bx },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        binary: bin,
+        continuous: ct,
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+      });
+    }
+  }
+  out.sort((a, b) => a.p - b.p);
+  return out;
+}
+
+function selectedAdjustedModel(data, screen) {
+  const selected = [
+    'feature_041',
+    'feature_037',
+    'feature_025=current',
+    'feature_025=never',
+    'feature_036=0',
+    'feature_036=2',
+    'feature_015',
+    'feature_001',
+    'feature_042',
+    'feature_010',
+    'feature_057',
+    'feature_028',
+    'feature_056',
+    'feature_004',
+    'feature_009',
+    'feature_066',
+    'feature_051',
+  ];
+  const testsByVariable = new Map(screen.tests.map(t => [t.variable, t]));
+  const predictors = [];
+  for (const key of selected) {
+    if (key === 'feature_036=0' || key === 'feature_036=2') {
+      const level = Number(key.split('=')[1]);
+      predictors.push({ name: key, x: data.feature_036.map(v => v === level ? 1 : 0) });
+    } else {
+      const t = testsByVariable.get(key);
+      predictors.push(preparePredictorForTest(t, data));
+    }
+  }
+  return ols(data.pfs_months, predictors);
+}
+
+function interactionFit(data, aLabel, bLabel) {
+  const screen = univariableScreen(data);
+  const dummyByLabel = new Map(screen.dummies.map(d => [d.label, d]));
+  const a = dummyByLabel.get(aLabel);
+  const b = dummyByLabel.get(bLabel);
+  const ax = a.x.map(Number);
+  const bx = b.x.map(Number);
+  const ix = ax.map((v, i) => v * bx[i]);
+  const fit = ols(data.pfs_months, [
+    { name: aLabel, x: ax },
+    { name: bLabel, x: bx },
+    { name: `${aLabel} x ${bLabel}`, x: ix },
+  ]);
+  return fit.coefficients.find(c => c.name === `${aLabel} x ${bLabel}`);
+}
+
+function summarizeColumn(arr) {
+  const n = arr.length;
+  const counts = new Map();
+  let numeric = true;
+  let min = Infinity;
+  let max = -Infinity;
+  let sum = 0;
+  for (const v of arr) {
+    counts.set(v, (counts.get(v) || 0) + 1);
+    if (typeof v !== 'number') numeric = false;
+    else {
+      if (v < min) min = v;
+      if (v > max) max = v;
+      sum += v;
+    }
+  }
+  const entries = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
+  return {
+    n,
+    unique: counts.size,
+    numeric,
+    mean: numeric ? sum / n : null,
+    min: numeric ? min : null,
+    max: numeric ? max : null,
+    top: entries.slice(0, 6),
+  };
+}
+
+function loadDataset() {
+  const buffer = fs.readFileSync('dataset.parquet');
+  const meta = readFooter(buffer);
+  const schema = parseSchema(meta);
+  const cols = parseColumns(meta);
+  const data = {};
+  for (let i = 0; i < cols.length; i++) {
+    data[cols[i].name] = decodeColumn(buffer, cols[i], schema[i]);
+  }
+  return { data, schema, cols, numRows: meta[3] };
+}
+
+if (require.main === module) {
+  const { data } = loadDataset();
+  const summaries = {};
+  for (const name of Object.keys(data)) summaries[name] = summarizeColumn(data[name]);
+  const screen = univariableScreen(data);
+  const binaryInteractions = screenBinaryInteractions(data, screen.dummies);
+  const binaryContinuousInteractions = screenBinaryContinuousInteractions(data, screen.dummies, screen.tests);
+  console.log(JSON.stringify({
+    shape: [data[Object.keys(data)[0]].length, Object.keys(data).length],
+    outcome: summaries.pfs_months,
+    firstFeatureSummaries: Object.fromEntries(Object.keys(summaries).filter(x => x.startsWith('feature_')).slice(0, 12).map(k => [k, summaries[k]])),
+    topMainEffects: screen.tests.slice(0, 25),
+    topBinaryInteractions: binaryInteractions.slice(0, 15).map(x => ({
+      a: x.a.label,
+      b: x.b.label,
+      effect: x.effect,
+      p: x.p,
+      z: x.z,
+      cells: [x.n00, x.n01, x.n10, x.n11],
+    })),
+    topBinaryContinuousInteractions: binaryContinuousInteractions.slice(0, 15).map(x => ({
+      binary: x.binary.label,
+      continuous: x.continuous.feature,
+      effect: x.effect,
+      p: x.p,
+      z: x.z,
+    })),
+  }, null, 2));
+}
