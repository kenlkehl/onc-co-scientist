+  const screen = univariableScreen(data);
+  const tests = new Map(screen.tests.map(t => [t.variable, t]));
+  const binaryInteractions = screenBinaryInteractions(data, screen.dummies);
+  const binaryContinuousInteractions = screenBinaryContinuousInteractions(data, screen.dummies, screen.tests);
+  const adjusted = selectedAdjustedModel(data, screen);
+  const adjustedMap = new Map(adjusted.coefficients.map(c => [c.name, c]));
+  const findBI = (a, b) => binaryInteractions.find(x =>
+    (x.a.label === a && x.b.label === b) || (x.a.label === b && x.b.label === a));
+  const findBC = (binary, continuous) => binaryContinuousInteractions.find(x =>
+    x.binary.label === binary && x.continuous.feature === continuous);
+
+  const iterations = [];
+  const addIteration = (index, hypotheses, analyses) => {
+    iterations.push({
+      index,
+      proposed_hypotheses: hypotheses,
+      analyses,
+    });
+  };
+  const h = (id, text, kind = 'novel') => ({ id, text, kind });
+  const a = (hypothesisIds, result, effect, p, method, extra = {}) => ({
+    hypothesis_ids: Array.isArray(hypothesisIds) ? hypothesisIds : [hypothesisIds],
+    result_summary: result,
+    p_value: safeP(p),
+    effect_estimate: effect,
+    significant: significant(p),
+    method,
+    ...extra,
+  });
+  const mainAnalysis = (varName, hid, methodLabel) => {
+    const t = tests.get(varName);
+    return a(
+      hid,
+      `${varName}: effect ${round(t.effect, 4)} months (${t.contrast}; ${pText(t.p)}).`,
+      t.effect,
+      t.p,
+      methodLabel || (t.kind === 'continuous' ? 'Univariable OLS slope for pfs_months on the feature.' : 'Two-group mean comparison on pfs_months.'),
+      t
+    );
+  };
+  const adjAnalysis = (name, hid) => {
+    const c = adjustedMap.get(name);
+    return a(
+      hid,
+      `${name}: adjusted coefficient ${round(c.beta, 4)} months (SE ${round(c.se, 4)}; ${pText(c.p)}).`,
+      c.beta,
+      c.p,
+      'Multivariable OLS including feature_041, feature_037, feature_025 indicators, feature_036 indicators, feature_015, feature_001, feature_042, feature_010, feature_057, feature_028, feature_056, feature_004, feature_009, feature_066, and feature_051.',
+      { standard_error: c.se, z_statistic: c.z }
+    );
+  };
+  const biAnalysis = (labelA, labelB, hid) => {
+    const r = findBI(labelA, labelB);
