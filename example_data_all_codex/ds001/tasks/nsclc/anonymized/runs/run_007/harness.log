+function snappyUncompress(input) {
+  let pos = 0;
+  let resultLen = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[pos++];
+    resultLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(resultLen);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[pos++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    }
+  }
+  if (op !== resultLen) throw new Error(`Snappy length mismatch ${op} != ${resultLen}`);
+  return out;
+}
+
+function readFooter(buffer) {
+  const footerLen = buffer.readUInt32LE(buffer.length - 8);
+  const footer = buffer.subarray(buffer.length - 8 - footerLen, buffer.length - 8);
+  return new CompactReader(footer).readStruct();
+}
+
+function parseSchema(meta) {
+  const schema = meta[2];
+  return schema.slice(1).map(s => ({
+    name: s[4],
+    type: s[1],
+    repetition: s[3],
+  }));
+}
+
+function parseColumns(meta) {
+  const rg = meta[4][0];
+  return rg[1].map(cc => {
+    const md = cc[3];
+    return {
+      name: md[3][0],
+      type: md[1],
+      encodings: md[2],
+      codec: md[4],
+      numValues: md[5],
+      totalCompressed: md[7],
+      dataPageOffset: md[9],
+      dictPageOffset: md[11],
+    };
+  });
+}
+
+function decodePlainValues(data, type, n) {
+  const out = new Array(n);
+  let pos = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === PARQUET_TYPES.DOUBLE) {
+      out[i] = data.readDoubleLE(pos);
+      pos += 8;
+    } else if (type === PARQUET_TYPES.FLOAT) {
+      out[i] = data.readFloatLE(pos);
+      pos += 4;
+    } else if (type === PARQUET_TYPES.INT64) {
+      out[i] = Number(data.readBigInt64LE(pos));
+      pos += 8;
+    } else if (type === PARQUET_TYPES.INT32) {
+      out[i] = data.readInt32LE(pos);
+      pos += 4;
+    } else if (type === PARQUET_TYPES.BYTE_ARRAY) {
+      const len = data.readInt32LE(pos);
+      pos += 4;
+      out[i] = data.subarray(pos, pos + len).toString('utf8');
+      pos += len;
+    } else {
+      throw new Error(`Unsupported plain type ${type}`);
+    }
+  }
+  return out;
+}
+
+function readUnsignedVarintAt(data, start) {
+  let pos = start;
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = data[pos++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: result, pos };
+}
+
+function readLittleBits(data, bitPos, bitWidth) {
+  let v = 0;
+  for (let b = 0; b < bitWidth; b++) {
+    const absolute = bitPos + b;
+    const bit = (data[absolute >> 3] >> (absolute & 7)) & 1;
+    v |= bit << b;
+  }
+  return v;
+}
+
+function decodeRleBitpacked(data, pos, count, bitWidth) {
+  if (bitWidth === 0) return { values: new Array(count).fill(0), pos };
+  const values = [];
+  while (values.length < count) {
+    const header = readUnsignedVarintAt(data, pos);
+    pos = header.pos;
+    if ((header.value & 1) === 0) {
+      const runLen = header.value >> 1;
+      const byteWidth = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < byteWidth; i++) value |= data[pos++] << (8 * i);
+      const take = Math.min(runLen, count - values.length);
+      for (let i = 0; i < take; i++) values.push(value);
+    } else {
+      const groups = header.value >> 1;
+      const runValues = groups * 8;
+      const byteLen = Math.ceil(runValues * bitWidth / 8);
+      const bitStart = pos * 8;
+      const take = Math.min(runValues, count - values.length);
+      for (let i = 0; i < take; i++) values.push(readLittleBits(data, bitStart + i * bitWidth, bitWidth));
+      pos += byteLen;
+    }
+  }
+  return { values, pos };
+}
+
+function readPageHeader(buffer, offset) {
+  const reader = new CompactReader(buffer.subarray(offset));
+  const header = reader.readStruct();
+  return { header, headerBytes: reader.pos };
+}
+
+function decodeColumn(buffer, col, schemaEntry) {
+  let dictionary = null;
+  const values = [];
+  let pos = col.dictPageOffset || col.dataPageOffset;
+  const end = (col.dictPageOffset || col.dataPageOffset) + col.totalCompressed;
+  while (pos < end && values.length < col.numValues) {
+    const { header, headerBytes } = readPageHeader(buffer, pos);
+    pos += headerBytes;
+    const compressed = buffer.subarray(pos, pos + header[3]);
+    pos += header[3];
+    const page = col.codec === 1 ? snappyUncompress(compressed) : compressed;
+    if (header[1] === 2) {
+      const dictHeader = header[7];
+      dictionary = decodePlainValues(page, col.type, dictHeader[1]);
+    } else if (header[1] === 0) {
+      const dataHeader = header[5];
+      const n = dataHeader[1];
+      let p = 0;
+      // All primitive columns are top-level optional fields: max repetition level is
+      // zero, max definition level is one. The dataset has no nulls, but decoding
+      // definition levels keeps page offsets aligned.
+      let defs;
+      if (schemaEntry.repetition === 1) {
+        const defByteLen = page.readInt32LE(p);
+        p += 4;
+        defs = decodeRleBitpacked(page.subarray(p, p + defByteLen), 0, n, 1);
+        p += defByteLen;
+      } else {
+        defs = decodeRleBitpacked(page, p, n, 0);
+        p = defs.pos;
+      }
+      const nonNull = defs.values.reduce((acc, v) => acc + (v > 0 ? 1 : 0), 0);
+      if (dataHeader[2] === 8 || dataHeader[2] === 2) {
+        const bitWidth = page[p++];
+        const decoded = decodeRleBitpacked(page, p, nonNull, bitWidth);
+        p = decoded.pos;
+        let j = 0;
+        for (let i = 0; i < n; i++) {
+          if (defs.values[i] > 0) values.push(dictionary[decoded.values[j++]]);
+          else values.push(null);
+        }
+      } else if (dataHeader[2] === 0) {
+        const plain = decodePlainValues(page.subarray(p), col.type, nonNull);
+        let j = 0;
+        for (let i = 0; i < n; i++) {
+          if (defs.values[i] > 0) values.push(plain[j++]);
+          else values.push(null);
+        }
+      } else {
+        throw new Error(`Unsupported data encoding ${dataHeader[2]} for ${col.name}`);
+      }
+    } else {
+      throw new Error(`Unsupported page type ${header[1]} for ${col.name}`);
+    }
+  }
+  if (values.length !== col.numValues) throw new Error(`Column ${col.name} decoded ${values.length}/${col.numValues}`);
+  return values;
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const v of arr) {
+    const d = v - m;
+    ss += d * d;
+  }
+  return Math.sqrt(ss / (arr.length - 1));
+}
+
+function summarizeColumn(arr) {
+  const n = arr.length;
+  const counts = new Map();
+  let numeric = true;
+  let min = Infinity;
+  let max = -Infinity;
+  let sum = 0;
+  for (const v of arr) {
+    counts.set(v, (counts.get(v) || 0) + 1);
+    if (typeof v !== 'number') numeric = false;
+    else {
+      if (v < min) min = v;
+      if (v > max) max = v;
+      sum += v;
+    }
+  }
+  const entries = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
+  return {
+    n,
+    unique: counts.size,
+    numeric,
+    mean: numeric ? sum / n : null,
+    min: numeric ? min : null,
+    max: numeric ? max : null,
+    top: entries.slice(0, 6),
+  };
+}
+
+function loadDataset() {
+  const buffer = fs.readFileSync('dataset.parquet');
+  const meta = readFooter(buffer);
+  const schema = parseSchema(meta);
+  const cols = parseColumns(meta);
+  const data = {};
+  for (let i = 0; i < cols.length; i++) {
+    data[cols[i].name] = decodeColumn(buffer, cols[i], schema[i]);
+  }
+  return { data, schema, cols, numRows: meta[3] };
+}
+
+if (require.main === module) {
+  const { data } = loadDataset();
+  const summaries = {};
+  for (const name of Object.keys(data)) summaries[name] = summarizeColumn(data[name]);
+  console.log(JSON.stringify({
+    shape: [data[Object.keys(data)[0]].length, Object.keys(data).length],
+    outcome: summaries.pfs_months,
+    firstFeatureSummaries: Object.fromEntries(Object.keys(summaries).filter(x => x.startsWith('feature_')).slice(0, 12).map(k => [k, summaries[k]])),
+  }, null, 2));
+}
