+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const v of arr) {
+    const d = v - m;
+    ss += d * d;
+  }
+  return Math.sqrt(ss / (arr.length - 1));
+}
+
+function summarizeColumn(arr) {
+  const n = arr.length;
+  const counts = new Map();
+  let numeric = true;
+  let min = Infinity;
+  let max = -Infinity;
+  let sum = 0;
+  for (const v of arr) {
+    counts.set(v, (counts.get(v) || 0) + 1);
+    if (typeof v !== 'number') numeric = false;
+    else {
+      if (v < min) min = v;
+      if (v > max) max = v;
+      sum += v;
+    }
+  }
+  const entries = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
+  return {
+    n,
+    unique: counts.size,
+    numeric,
