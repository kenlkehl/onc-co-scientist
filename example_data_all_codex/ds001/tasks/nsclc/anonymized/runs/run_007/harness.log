import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('outcome describe')
print(df['pfs_months'].describe().to_string())
rows=[]
for c in df.columns:
    if c=='pfs_months': continue
    s=df[c]
    vc=s.value_counts(dropna=False).sort_index()
    vals=list(vc.index[:10])
    rows.append((c, str(s.dtype), s.nunique(), float(s.mean()) if np.issubdtype(s.dtype, np.number) else None, float(s.std()) if np.issubdtype(s.dtype, np.number) else None, vals, list(vc.values[:10])))
for r in rows:
    print('\\t'.join(map(str,r)))
