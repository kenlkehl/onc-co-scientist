+const fs = require('fs');
+
+const PARQUET_TYPES = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+};
+
+const CT_STOP = 0;
+const CT_TRUE = 1;
+const CT_FALSE = 2;
+const CT_BYTE = 3;
+const CT_I16 = 4;
+const CT_I32 = 5;
+const CT_I64 = 6;
+const CT_DOUBLE = 7;
+const CT_BINARY = 8;
+const CT_LIST = 9;
+const CT_SET = 10;
+const CT_MAP = 11;
+const CT_STRUCT = 12;
+
+class CompactReader {
+  constructor(buffer) {
+    this.buf = buffer;
+    this.pos = 0;
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
+  }
+  readZigZag() {
+    const n = this.readVarintBig();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readBinary() {
+    const len = this.readVarint();
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out.toString('utf8');
+  }
+  readList(elemReader) {
+    const header = this.readByte();
+    let size = header >> 4;
+    const type = header & 0x0f;
+    if (size === 15) size = this.readVarint();
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(elemReader(type));
+    return arr;
+  }
+  readValue(type) {
+    switch (type) {
+      case CT_TRUE: return true;
+      case CT_FALSE: return false;
+      case CT_BYTE: return this.readByte();
+      case CT_I16:
+      case CT_I32:
+      case CT_I64: return this.readZigZag();
+      case CT_DOUBLE: {
+        const v = this.buf.readDoubleLE(this.pos);
+        this.pos += 8;
+        return v;
+      }
+      case CT_BINARY: return this.readBinary();
+      case CT_LIST:
+      case CT_SET: return this.readList(t => this.readValue(t));
+      case CT_STRUCT: return this.readStruct();
+      case CT_MAP: {
+        const size = this.readVarint();
+        if (size === 0) return [];
+        const types = this.readByte();
+        const kt = types >> 4;
+        const vt = types & 0x0f;
+        const arr = [];
+        for (let i = 0; i < size; i++) arr.push([this.readValue(kt), this.readValue(vt)]);
+        return arr;
+      }
+      default:
+        throw new Error(`Unsupported compact type ${type} at ${this.pos}`);
+    }
+  }
+  readStruct() {
+    const obj = {};
+    let lastField = 0;
+    while (true) {
+      const b = this.readByte();
+      const type = b & 0x0f;
+      if (type === CT_STOP) break;
+      const delta = b >> 4;
+      let fieldId;
+      if (delta === 0) fieldId = this.readZigZag();
+      else fieldId = lastField + delta;
+      lastField = fieldId;
+      obj[fieldId] = this.readValue(type);
+    }
+    return obj;
+  }
+}
+
+function snappyUncompress(input) {
+  let pos = 0;
+  let resultLen = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[pos++];
+    resultLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(resultLen);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[pos++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
+      let len;
+      let offset;
+      if (type === 1) {
+        len = ((tag >> 2) & 0x07) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        len = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < len; i++) out[op + i] = out[op - offset + i];
+      op += len;
+    }
+  }
+  if (op !== resultLen) throw new Error(`Snappy length mismatch ${op} != ${resultLen}`);
+  return out;
+}
+
+function readFooter(buffer) {
+  const footerLen = buffer.readUInt32LE(buffer.length - 8);
+  const footer = buffer.subarray(buffer.length - 8 - footerLen, buffer.length - 8);
+  return new CompactReader(footer).readStruct();
+}
+
+function parseSchema(meta) {
+  const schema = meta[2];
+  return schema.slice(1).map(s => ({
+    name: s[4],
+    type: s[1],
+    repetition: s[3],
+  }));
+}
+
+function parseColumns(meta) {
+  const rg = meta[4][0];
+  return rg[1].map(cc => {
+    const md = cc[3];
+    return {
+      name: md[3][0],
+      type: md[1],
+      encodings: md[2],
+      codec: md[4],
+      numValues: md[5],
+      totalCompressed: md[7],
+      dataPageOffset: md[9],
+      dictPageOffset: md[11],
+    };
+  });
+}
+
+function decodePlainValues(data, type, n) {
+  const out = new Array(n);
+  let pos = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === PARQUET_TYPES.DOUBLE) {
+      out[i] = data.readDoubleLE(pos);
+      pos += 8;
+    } else if (type === PARQUET_TYPES.FLOAT) {
+      out[i] = data.readFloatLE(pos);
+      pos += 4;
+    } else if (type === PARQUET_TYPES.INT64) {
+      out[i] = Number(data.readBigInt64LE(pos));
+      pos += 8;
+    } else if (type === PARQUET_TYPES.INT32) {
+      out[i] = data.readInt32LE(pos);
+      pos += 4;
+    } else if (type === PARQUET_TYPES.BYTE_ARRAY) {
+      const len = data.readInt32LE(pos);
+      pos += 4;
+      out[i] = data.subarray(pos, pos + len).toString('utf8');
+      pos += len;
+    } else {
+      throw new Error(`Unsupported plain type ${type}`);
+    }
+  }
+  return out;
+}
+
+function readUnsignedVarintAt(data, start) {
+  let pos = start;
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = data[pos++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: result, pos };
+}
+
+function readLittleBits(data, bitPos, bitWidth) {
+  let v = 0;
+  for (let b = 0; b < bitWidth; b++) {
+    const absolute = bitPos + b;
+    const bit = (data[absolute >> 3] >> (absolute & 7)) & 1;
+    v |= bit << b;
+  }
+  return v;
+}
+
+function decodeRleBitpacked(data, pos, count, bitWidth) {
+  if (bitWidth === 0) return { values: new Array(count).fill(0), pos };
+  const values = [];
+  while (values.length < count) {
+    const header = readUnsignedVarintAt(data, pos);
+    pos = header.pos;
+    if ((header.value & 1) === 0) {
+      const runLen = header.value >> 1;
+      const byteWidth = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < byteWidth; i++) value |= data[pos++] << (8 * i);
+      const take = Math.min(runLen, count - values.length);
+      for (let i = 0; i < take; i++) values.push(value);
+    } else {
+      const groups = header.value >> 1;
+      const runValues = groups * 8;
+      const byteLen = Math.ceil(runValues * bitWidth / 8);
+      const bitStart = pos * 8;
+      const take = Math.min(runValues, count - values.length);
+      for (let i = 0; i < take; i++) values.push(readLittleBits(data, bitStart + i * bitWidth, bitWidth));
+      pos += byteLen;
+    }
+  }
+  return { values, pos };
+}
+
+function readPageHeader(buffer, offset) {
+  const reader = new CompactReader(buffer.subarray(offset));
+  const header = reader.readStruct();
+  return { header, headerBytes: reader.pos };
+}
+
+function decodeColumn(buffer, col, schemaEntry) {
+  let dictionary = null;
+  const values = [];
+  let pos = col.dictPageOffset || col.dataPageOffset;
+  const end = (col.dictPageOffset || col.dataPageOffset) + col.totalCompressed;
+  while (pos < end && values.length < col.numValues) {
+    const { header, headerBytes } = readPageHeader(buffer, pos);
+    pos += headerBytes;
+    const compressed = buffer.subarray(pos, pos + header[3]);
+    pos += header[3];
+    const page = col.codec === 1 ? snappyUncompress(compressed) : compressed;
+    if (header[1] === 2) {
+      const dictHeader = header[7];
+      dictionary = decodePlainValues(page, col.type, dictHeader[1]);
+    } else if (header[1] === 0) {
+      const dataHeader = header[5];
+      const n = dataHeader[1];
+      let p = 0;
+      // All primitive columns are top-level optional fields: max repetition level is
+      // zero, max definition level is one. The dataset has no nulls, but decoding
+      // definition levels keeps page offsets aligned.
+      let defs;
+      if (schemaEntry.repetition === 1) {
+        const defByteLen = page.readInt32LE(p);
+        p += 4;
+        defs = decodeRleBitpacked(page.subarray(p, p + defByteLen), 0, n, 1);
+        p += defByteLen;
+      } else {
+        defs = decodeRleBitpacked(page, p, n, 0);
+        p = defs.pos;
+      }
+      const nonNull = defs.values.reduce((acc, v) => acc + (v > 0 ? 1 : 0), 0);
+      if (dataHeader[2] === 8 || dataHeader[2] === 2) {
+        const bitWidth = page[p++];
+        const decoded = decodeRleBitpacked(page, p, nonNull, bitWidth);
+        p = decoded.pos;
+        let j = 0;
+        for (let i = 0; i < n; i++) {
+          if (defs.values[i] > 0) values.push(dictionary[decoded.values[j++]]);
+          else values.push(null);
+        }
+      } else if (dataHeader[2] === 0) {
+        const plain = decodePlainValues(page.subarray(p), col.type, nonNull);
+        let j = 0;
+        for (let i = 0; i < n; i++) {
+          if (defs.values[i] > 0) values.push(plain[j++]);
+          else values.push(null);
+        }
+      } else {
+        throw new Error(`Unsupported data encoding ${dataHeader[2]} for ${col.name}`);
+      }
+    } else {
+      throw new Error(`Unsupported page type ${header[1]} for ${col.name}`);
+    }
+  }
+  if (values.length !== col.numValues) throw new Error(`Column ${col.name} decoded ${values.length}/${col.numValues}`);
+  return values;
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const v of arr) {
+    const d = v - m;
+    ss += d * d;
+  }
+  return Math.sqrt(ss / (arr.length - 1));
+}
+
+function erfApprox(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erfApprox(x / Math.SQRT2));
+}
+
+function twoSidedNormalP(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  return Math.max(0, Math.min(1, p));
+}
+
+function groupStats(y, g) {
+  let n0 = 0, n1 = 0, s0 = 0, s1 = 0, ss0 = 0, ss1 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (g[i]) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m0 = s0 / n0;
+  const m1 = s1 / n1;
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const se = Math.sqrt(v0 / n0 + v1 / n1);
+  const effect = m1 - m0;
+  const z = effect / se;
+  return { n0, n1, mean0: m0, mean1: m1, effect, se, z, p: twoSidedNormalP(z) };
+}
+
+function linearSlope(y, x) {
+  const n = y.length;
+  let sx = 0, sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0, sxy = 0, sse = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  for (let i = 0; i < n; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    sse += e * e;
+  }
+  const sigma2 = sse / (n - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = slope / se;
+  return { slope, intercept, se, z, p: twoSidedNormalP(z), meanX: mx, sdX: Math.sqrt(sxx / (n - 1)) };
+}
+
+function makeFeatureInfo(data) {
+  const out = [];
+  for (const name of Object.keys(data)) {
+    if (!name.startsWith('feature_')) continue;
+    const arr = data[name];
+    const counts = new Map();
+    let numeric = true;
+    for (const v of arr) {
+      counts.set(v, (counts.get(v) || 0) + 1);
+      if (typeof v !== 'number') numeric = false;
+    }
+    const values = Array.from(counts.keys());
+    const sortedCounts = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
+    let kind;
+    if (numeric && counts.size > 10) kind = 'continuous';
+    else if (counts.size === 2) kind = 'binary';
+    else kind = 'categorical';
+    out.push({ name, arr, numeric, values, counts, sortedCounts, kind });
+  }
+  return out;
+}
+
+function univariableScreen(data) {
+  const y = data.pfs_months;
+  const infos = makeFeatureInfo(data);
+  const tests = [];
+  const dummies = [];
+  for (const info of infos) {
+    if (info.kind === 'continuous') {
+      const r = linearSlope(y, info.arr);
+      tests.push({
+        feature: info.name,
+        variable: info.name,
+        kind: 'continuous',
+        contrast: 'per 1-unit increase',
+        effect: r.slope,
+        p: r.p,
+        z: r.z,
+        meanX: r.meanX,
+        sdX: r.sdX,
+        n: y.length,
+      });
+    } else if (info.kind === 'binary') {
+      const vals = info.values.slice().sort();
+      const high = vals[1];
+      const low = vals[0];
+      const g = info.arr.map(v => v === high);
+      const r = groupStats(y, g);
+      tests.push({
+        feature: info.name,
+        variable: info.name,
+        kind: 'binary',
+        contrast: `${high} vs ${low}`,
+        level: high,
+        reference: low,
+        effect: r.effect,
+        p: r.p,
+        z: r.z,
+        n0: r.n0,
+        n1: r.n1,
+        mean0: r.mean0,
+        mean1: r.mean1,
+      });
+      dummies.push({ feature: info.name, label: `${info.name}=${high}`, x: g.map(Boolean), level: high, reference: low, kind: 'binary' });
+    } else {
+      const reference = info.sortedCounts[0][0];
+      for (const [level, count] of info.sortedCounts) {
+        if (level === reference) continue;
+        if (count < 100) continue;
+        const g = info.arr.map(v => v === level);
+        const r = groupStats(y, g);
+        tests.push({
+          feature: info.name,
+          variable: `${info.name}=${level}`,
+          kind: 'categorical',
+          contrast: `${level} vs all other values`,
+          level,
+          reference: 'all other values',
+          effect: r.effect,
+          p: r.p,
+          z: r.z,
+          n0: r.n0,
+          n1: r.n1,
+          mean0: r.mean0,
+          mean1: r.mean1,
+        });
+        dummies.push({ feature: info.name, label: `${info.name}=${level}`, x: g.map(Boolean), level, reference: 'all other values', kind: 'categorical' });
+      }
+    }
+  }
+  tests.sort((a, b) => a.p - b.p);
+  return { tests, dummies, infos };
+}
+
+function xtxFromColumns(cols, y) {
+  const n = y.length;
+  const p = cols.length;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = cols.map(c => c[i]);
+    yty += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = a + 1; b < p; b++) xtx[a][b] = xtx[b][a];
+  }
+  return { xtx, xty, yty, n, p };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => row.slice().concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== i) [m[i], m[pivot]] = [m[pivot], m[i]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = m[r][i];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= factor * m[i][c];
+    }
+  }
+  return m.map(row => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const names = ['intercept'].concat(predictors.map(p => p.name));
+  const cols = [new Array(y.length).fill(1)].concat(predictors.map(p => p.x));
+  const { xtx, xty, yty, n, p } = xtxFromColumns(cols, y);
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let bxty = 0;
+  for (let i = 0; i < p; i++) bxty += beta[i] * xty[i];
+  const sse = Math.max(0, yty - bxty);
+  const sigma2 = sse / (n - p);
+  const coefficients = names.map((name, i) => {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    const z = beta[i] / se;
+    return { name, beta: beta[i], se, z, p: twoSidedNormalP(z) };
+  });
+  return { coefficients, sse, sigma2, df: n - p };
+}
+
+function centered(arr) {
+  const m = mean(arr);
+  return arr.map(v => v - m);
+}
+
+function sdValue(arr) {
+  return sd(arr);
+}
+
+function preparePredictorForTest(test, data) {
+  if (test.kind === 'continuous') {
+    return { name: test.feature, x: data[test.feature].slice(), descriptor: test.feature, kind: 'continuous' };
+  }
+  const level = test.level;
+  return {
+    name: test.variable,
+    x: data[test.feature].map(v => v === level ? 1 : 0),
+    descriptor: test.variable,
+    kind: test.kind,
+  };
+}
+
+function screenBinaryInteractions(data, dummies) {
+  const y = data.pfs_months;
+  const candidates = dummies.filter(d => {
+    const n1 = d.x.reduce((a, b) => a + (b ? 1 : 0), 0);
+    return n1 >= 1000 && n1 <= y.length - 1000;
+  });
+  const out = [];
+  for (let i = 0; i < candidates.length; i++) {
+    for (let j = i + 1; j < candidates.length; j++) {
+      if (candidates[i].feature === candidates[j].feature) continue;
+      const a = candidates[i].x;
+      const b = candidates[j].x;
+      let n00 = 0, n01 = 0, n10 = 0, n11 = 0;
+      for (let k = 0; k < y.length; k++) {
+        if (a[k] && b[k]) n11++;
+        else if (a[k]) n10++;
+        else if (b[k]) n01++;
+        else n00++;
+      }
+      if (Math.min(n00, n01, n10, n11) < 250) continue;
+      const interaction = a.map((v, k) => (v && b[k]) ? 1 : 0);
+      const fit = ols(y, [
+        { name: candidates[i].label, x: a.map(Number) },
+        { name: candidates[j].label, x: b.map(Number) },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        a: candidates[i],
+        b: candidates[j],
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+        n00,
+        n01,
+        n10,
+        n11,
+      });
+    }
+  }
+  out.sort((x, y2) => x.p - y2.p);
+  return out;
+}
+
+function screenBinaryContinuousInteractions(data, dummies, continuousTests) {
+  const y = data.pfs_months;
+  const binaries = dummies.filter(d => {
+    const n1 = d.x.reduce((a, b) => a + (b ? 1 : 0), 0);
+    return n1 >= 1000 && n1 <= y.length - 1000;
+  });
+  const continuous = continuousTests
+    .filter(t => t.kind === 'continuous')
+    .sort((a, b) => a.p - b.p)
+    .slice(0, 20);
+  const out = [];
+  for (const bin of binaries) {
+    const bx = bin.x.map(Number);
+    for (const ct of continuous) {
+      if (bin.feature === ct.feature) continue;
+      const x = data[ct.feature];
+      const xCentered = centered(x);
+      const interaction = xCentered.map((v, i) => v * bx[i]);
+      const fit = ols(y, [
+        { name: ct.feature, x: xCentered },
+        { name: bin.label, x: bx },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        binary: bin,
+        continuous: ct,
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+      });
+    }
+  }
+  out.sort((a, b) => a.p - b.p);
+  return out;
+}
+
+function summarizeColumn(arr) {
+  const n = arr.length;
+  const counts = new Map();
+  let numeric = true;
+  let min = Infinity;
+  let max = -Infinity;
+  let sum = 0;
+  for (const v of arr) {
+    counts.set(v, (counts.get(v) || 0) + 1);
+    if (typeof v !== 'number') numeric = false;
+    else {
+      if (v < min) min = v;
+      if (v > max) max = v;
+      sum += v;
+    }
+  }
+  const entries = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
+  return {
+    n,
+    unique: counts.size,
+    numeric,
+    mean: numeric ? sum / n : null,
+    min: numeric ? min : null,
+    max: numeric ? max : null,
+    top: entries.slice(0, 6),
+  };
+}
+
+function loadDataset() {
+  const buffer = fs.readFileSync('dataset.parquet');
+  const meta = readFooter(buffer);
+  const schema = parseSchema(meta);
+  const cols = parseColumns(meta);
+  const data = {};
+  for (let i = 0; i < cols.length; i++) {
+    data[cols[i].name] = decodeColumn(buffer, cols[i], schema[i]);
+  }
+  return { data, schema, cols, numRows: meta[3] };
+}
+
+if (require.main === module) {
+  const { data } = loadDataset();
+  const summaries = {};
+  for (const name of Object.keys(data)) summaries[name] = summarizeColumn(data[name]);
+  console.log(JSON.stringify({
+    shape: [data[Object.keys(data)[0]].length, Object.keys(data).length],
+    outcome: summaries.pfs_months,
+    firstFeatureSummaries: Object.fromEntries(Object.keys(summaries).filter(x => x.startsWith('feature_')).slice(0, 12).map(k => [k, summaries[k]])),
+  }, null, 2));
+}
