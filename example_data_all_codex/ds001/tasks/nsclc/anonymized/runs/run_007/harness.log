+
+function summarizeColumn(arr) {
+  const n = arr.length;
+  const counts = new Map();
+  let numeric = true;
+  let min = Infinity;
+  let max = -Infinity;
+  let sum = 0;
+  for (const v of arr) {
+    counts.set(v, (counts.get(v) || 0) + 1);
+    if (typeof v !== 'number') numeric = false;
+    else {
+      if (v < min) min = v;
+      if (v > max) max = v;
+      sum += v;
+    }
+  }
+  const entries = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
+  return {
+    n,
+    unique: counts.size,
+    numeric,
+    mean: numeric ? sum / n : null,
+    min: numeric ? min : null,
+    max: numeric ? max : null,
+    top: entries.slice(0, 6),
+  };
+}
+
+function loadDataset() {
+  const buffer = fs.readFileSync('dataset.parquet');
+  const meta = readFooter(buffer);
+  const schema = parseSchema(meta);
+  const cols = parseColumns(meta);
+  const data = {};
+  for (let i = 0; i < cols.length; i++) {
+    data[cols[i].name] = decodeColumn(buffer, cols[i], schema[i]);
+  }
+  return { data, schema, cols, numRows: meta[3] };
+}
+
+if (require.main === module) {
+  const { data } = loadDataset();
+  const { transcript, summary } = buildArtifacts(data);
+  fs.writeFileSync('transcript.json', JSON.stringify(transcript, null, 2) + '\n');
+  fs.writeFileSync('analysis_summary.txt', summary);
+  console.log('wrote transcript.json and analysis_summary.txt');
