+function snappyUncompress(input) {
+  let pos = 0;
+  let resultLen = 0;
+  let shift = 0;
+  while (true) {
+    const b = input[pos++];
+    resultLen |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(resultLen);
+  let op = 0;
+  while (pos < input.length) {
+    const tag = input[pos++];
+    const type = tag & 0x03;
+    if (type === 0) {
+      let len = tag >> 2;
+      if (len < 60) {
+        len += 1;
+      } else {
+        const bytes = len - 59;
+        len = 0;
+        for (let i = 0; i < bytes; i++) len |= input[pos++] << (8 * i);
+        len += 1;
+      }
+      input.copy(out, op, pos, pos + len);
+      pos += len;
+      op += len;
+    } else {
