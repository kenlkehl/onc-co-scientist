+      hid,
+      `${labelA} x ${labelB}: interaction coefficient ${round(r.effect, 4)} months (${pText(r.p)}); cells n00=${r.n00}, n01=${r.n01}, n10=${r.n10}, n11=${r.n11}.`,
+      r.effect,
+      r.p,
+      'OLS interaction model pfs_months ~ indicator A + indicator B + A:B.',
+      { z_statistic: r.z, cell_counts: { n00: r.n00, n01: r.n01, n10: r.n10, n11: r.n11 } }
+    );
+  };
+  const bcAnalysis = (binary, continuous, hid) => {
+    const r = findBC(binary, continuous);
+    return a(
+      hid,
+      `${binary} x centered ${continuous}: interaction coefficient ${round(r.effect, 4)} months per 1-unit ${continuous} (${pText(r.p)}).`,
+      r.effect,
+      r.p,
+      'OLS interaction model pfs_months ~ centered continuous feature + binary indicator + continuous:indicator.',
+      { z_statistic: r.z }
+    );
+  };
+
+  addIteration(1, [
+    h('h1', 'Higher `feature_041` values are associated with higher `pfs_months`; each 1-unit increase in `feature_041` increases mean progression-free survival.'),
+  ], [mainAnalysis('feature_041', 'h1')]);
+
+  addIteration(2, [
+    h('h2a', '`feature_036=0` patients have higher mean `pfs_months` than patients with `feature_036` not equal to 0.'),
+    h('h2b', '`feature_036=2` patients have lower mean `pfs_months` than patients with `feature_036` not equal to 2.'),
+  ], [mainAnalysis('feature_036=0', 'h2a'), mainAnalysis('feature_036=2', 'h2b')]);
