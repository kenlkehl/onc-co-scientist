+      const byteWidth = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < byteWidth; i++) value |= data[pos++] << (8 * i);
+      const take = Math.min(runLen, count - values.length);
+      for (let i = 0; i < take; i++) values.push(value);
+    } else {
+      const groups = header.value >> 1;
+      const runValues = groups * 8;
+      const byteLen = Math.ceil(runValues * bitWidth / 8);
+      const bitStart = pos * 8;
+      const take = Math.min(runValues, count - values.length);
+      for (let i = 0; i < take; i++) values.push(readLittleBits(data, bitStart + i * bitWidth, bitWidth));
+      pos += byteLen;
+    }
+  }
+  return { values, pos };
+}
+
+function readPageHeader(buffer, offset) {
+  const reader = new CompactReader(buffer.subarray(offset));
+  const header = reader.readStruct();
+  return { header, headerBytes: reader.pos };
+}
+
+function decodeColumn(buffer, col, schemaEntry) {
+  let dictionary = null;
+  const values = [];
+  let pos = col.dictPageOffset || col.dataPageOffset;
+  const end = (col.dictPageOffset || col.dataPageOffset) + col.totalCompressed;
+  while (pos < end && values.length < col.numValues) {
+    const { header, headerBytes } = readPageHeader(buffer, pos);
+    pos += headerBytes;
+    const compressed = buffer.subarray(pos, pos + header[3]);
+    pos += header[3];
+    const page = col.codec === 1 ? snappyUncompress(compressed) : compressed;
+    if (header[1] === 2) {
+      const dictHeader = header[7];
+      dictionary = decodePlainValues(page, col.type, dictHeader[1]);
+    } else if (header[1] === 0) {
+      const dataHeader = header[5];
+      const n = dataHeader[1];
+      let p = 0;
+      // All primitive columns are top-level optional fields: max repetition level is
+      // zero, max definition level is one. The dataset has no nulls, but decoding
+      // definition levels keeps page offsets aligned.
+      let defs;
+      if (schemaEntry.repetition === 1) {
+        const defByteLen = page.readInt32LE(p);
+        p += 4;
+        defs = decodeRleBitpacked(page.subarray(p, p + defByteLen), 0, n, 1);
+        p += defByteLen;
+      } else {
+        defs = decodeRleBitpacked(page, p, n, 0);
+        p = defs.pos;
+      }
+      const nonNull = defs.values.reduce((acc, v) => acc + (v > 0 ? 1 : 0), 0);
+      if (dataHeader[2] === 8 || dataHeader[2] === 2) {
+        const bitWidth = page[p++];
+        const decoded = decodeRleBitpacked(page, p, nonNull, bitWidth);
+        p = decoded.pos;
+        let j = 0;
+        for (let i = 0; i < n; i++) {
+          if (defs.values[i] > 0) values.push(dictionary[decoded.values[j++]]);
+          else values.push(null);
+        }
+      } else if (dataHeader[2] === 0) {
+        const plain = decodePlainValues(page.subarray(p), col.type, nonNull);
+        let j = 0;
+        for (let i = 0; i < n; i++) {
+          if (defs.values[i] > 0) values.push(plain[j++]);
+          else values.push(null);
+        }
+      } else {
+        throw new Error(`Unsupported data encoding ${dataHeader[2]} for ${col.name}`);
+      }
+    } else {
+      throw new Error(`Unsupported page type ${header[1]} for ${col.name}`);
+    }
+  }
+  if (values.length !== col.numValues) throw new Error(`Column ${col.name} decoded ${values.length}/${col.numValues}`);
+  return values;
+}
+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const v of arr) {
+    const d = v - m;
+    ss += d * d;
+  }
+  return Math.sqrt(ss / (arr.length - 1));
+}
+
+function erfApprox(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalCdf(x) {
+  return 0.5 * (1 + erfApprox(x / Math.SQRT2));
+}
+
+function twoSidedNormalP(z) {
+  const p = 2 * (1 - normalCdf(Math.abs(z)));
+  return Math.max(0, Math.min(1, p));
+}
+
+function groupStats(y, g) {
+  let n0 = 0, n1 = 0, s0 = 0, s1 = 0, ss0 = 0, ss1 = 0;
+  for (let i = 0; i < y.length; i++) {
+    if (g[i]) {
+      n1++;
+      s1 += y[i];
+      ss1 += y[i] * y[i];
+    } else {
+      n0++;
+      s0 += y[i];
+      ss0 += y[i] * y[i];
+    }
+  }
+  const m0 = s0 / n0;
+  const m1 = s1 / n1;
+  const v0 = (ss0 - s0 * s0 / n0) / (n0 - 1);
+  const v1 = (ss1 - s1 * s1 / n1) / (n1 - 1);
+  const se = Math.sqrt(v0 / n0 + v1 / n1);
+  const effect = m1 - m0;
+  const z = effect / se;
+  return { n0, n1, mean0: m0, mean1: m1, effect, se, z, p: twoSidedNormalP(z) };
+}
+
+function linearSlope(y, x) {
+  const n = y.length;
+  let sx = 0, sy = 0;
+  for (let i = 0; i < n; i++) {
+    sx += x[i];
+    sy += y[i];
+  }
+  const mx = sx / n;
+  const my = sy / n;
+  let sxx = 0, sxy = 0, sse = 0;
+  for (let i = 0; i < n; i++) {
+    const dx = x[i] - mx;
+    sxx += dx * dx;
+    sxy += dx * (y[i] - my);
+  }
+  const slope = sxy / sxx;
+  const intercept = my - slope * mx;
+  for (let i = 0; i < n; i++) {
+    const e = y[i] - intercept - slope * x[i];
+    sse += e * e;
+  }
+  const sigma2 = sse / (n - 2);
+  const se = Math.sqrt(sigma2 / sxx);
+  const z = slope / se;
+  return { slope, intercept, se, z, p: twoSidedNormalP(z), meanX: mx, sdX: Math.sqrt(sxx / (n - 1)) };
+}
+
+function makeFeatureInfo(data) {
+  const out = [];
+  for (const name of Object.keys(data)) {
+    if (!name.startsWith('feature_')) continue;
+    const arr = data[name];
+    const counts = new Map();
+    let numeric = true;
+    for (const v of arr) {
+      counts.set(v, (counts.get(v) || 0) + 1);
+      if (typeof v !== 'number') numeric = false;
+    }
+    const values = Array.from(counts.keys());
+    const sortedCounts = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
+    let kind;
+    if (numeric && counts.size > 10) kind = 'continuous';
+    else if (counts.size === 2) kind = 'binary';
+    else kind = 'categorical';
+    out.push({ name, arr, numeric, values, counts, sortedCounts, kind });
+  }
+  return out;
+}
+
+function univariableScreen(data) {
+  const y = data.pfs_months;
+  const infos = makeFeatureInfo(data);
+  const tests = [];
+  const dummies = [];
+  for (const info of infos) {
+    if (info.kind === 'continuous') {
+      const r = linearSlope(y, info.arr);
+      tests.push({
+        feature: info.name,
+        variable: info.name,
+        kind: 'continuous',
+        contrast: 'per 1-unit increase',
+        effect: r.slope,
+        p: r.p,
+        z: r.z,
+        meanX: r.meanX,
+        sdX: r.sdX,
+        n: y.length,
+      });
+    } else if (info.kind === 'binary') {
+      const vals = info.values.slice().sort();
+      const high = vals[1];
+      const low = vals[0];
+      const g = info.arr.map(v => v === high);
+      const r = groupStats(y, g);
+      tests.push({
+        feature: info.name,
+        variable: info.name,
+        kind: 'binary',
+        contrast: `${high} vs ${low}`,
+        level: high,
+        reference: low,
+        effect: r.effect,
+        p: r.p,
+        z: r.z,
+        n0: r.n0,
+        n1: r.n1,
+        mean0: r.mean0,
+        mean1: r.mean1,
+      });
+      dummies.push({ feature: info.name, label: `${info.name}=${high}`, x: g.map(Boolean), level: high, reference: low, kind: 'binary' });
+    } else {
+      const reference = info.sortedCounts[0][0];
+      for (const [level, count] of info.sortedCounts) {
+        if (level === reference) continue;
+        if (count < 100) continue;
+        const g = info.arr.map(v => v === level);
+        const r = groupStats(y, g);
+        tests.push({
+          feature: info.name,
+          variable: `${info.name}=${level}`,
+          kind: 'categorical',
+          contrast: `${level} vs all other values`,
+          level,
+          reference: 'all other values',
+          effect: r.effect,
+          p: r.p,
+          z: r.z,
+          n0: r.n0,
+          n1: r.n1,
+          mean0: r.mean0,
+          mean1: r.mean1,
+        });
+        dummies.push({ feature: info.name, label: `${info.name}=${level}`, x: g.map(Boolean), level, reference: 'all other values', kind: 'categorical' });
+      }
+    }
+  }
+  tests.sort((a, b) => a.p - b.p);
+  return { tests, dummies, infos };
+}
+
+function xtxFromColumns(cols, y) {
+  const n = y.length;
+  const p = cols.length;
+  const xtx = Array.from({ length: p }, () => new Array(p).fill(0));
+  const xty = new Array(p).fill(0);
+  let yty = 0;
+  for (let i = 0; i < n; i++) {
+    const row = cols.map(c => c[i]);
+    yty += y[i] * y[i];
+    for (let a = 0; a < p; a++) {
+      xty[a] += row[a] * y[i];
+      for (let b = 0; b <= a; b++) xtx[a][b] += row[a] * row[b];
+    }
+  }
+  for (let a = 0; a < p; a++) {
+    for (let b = a + 1; b < p; b++) xtx[a][b] = xtx[b][a];
+  }
+  return { xtx, xty, yty, n, p };
+}
+
+function invertMatrix(a) {
+  const n = a.length;
+  const m = a.map((row, i) => row.slice().concat(Array.from({ length: n }, (_, j) => i === j ? 1 : 0)));
+  for (let i = 0; i < n; i++) {
+    let pivot = i;
+    for (let r = i + 1; r < n; r++) {
+      if (Math.abs(m[r][i]) > Math.abs(m[pivot][i])) pivot = r;
+    }
+    if (Math.abs(m[pivot][i]) < 1e-12) throw new Error('Singular matrix');
+    if (pivot !== i) [m[i], m[pivot]] = [m[pivot], m[i]];
+    const div = m[i][i];
+    for (let c = 0; c < 2 * n; c++) m[i][c] /= div;
+    for (let r = 0; r < n; r++) {
+      if (r === i) continue;
+      const factor = m[r][i];
+      if (factor === 0) continue;
+      for (let c = 0; c < 2 * n; c++) m[r][c] -= factor * m[i][c];
+    }
+  }
+  return m.map(row => row.slice(n));
+}
+
+function ols(y, predictors) {
+  const names = ['intercept'].concat(predictors.map(p => p.name));
+  const cols = [new Array(y.length).fill(1)].concat(predictors.map(p => p.x));
+  const { xtx, xty, yty, n, p } = xtxFromColumns(cols, y);
+  const inv = invertMatrix(xtx);
+  const beta = new Array(p).fill(0);
+  for (let i = 0; i < p; i++) {
+    for (let j = 0; j < p; j++) beta[i] += inv[i][j] * xty[j];
+  }
+  let bxty = 0;
+  for (let i = 0; i < p; i++) bxty += beta[i] * xty[i];
+  const sse = Math.max(0, yty - bxty);
+  const sigma2 = sse / (n - p);
+  const coefficients = names.map((name, i) => {
+    const se = Math.sqrt(Math.max(0, sigma2 * inv[i][i]));
+    const z = beta[i] / se;
+    return { name, beta: beta[i], se, z, p: twoSidedNormalP(z) };
+  });
+  return { coefficients, sse, sigma2, df: n - p };
+}
+
+function centered(arr) {
+  const m = mean(arr);
+  return arr.map(v => v - m);
+}
+
+function sdValue(arr) {
+  return sd(arr);
+}
+
+function preparePredictorForTest(test, data) {
+  if (test.kind === 'continuous') {
+    return { name: test.feature, x: data[test.feature].slice(), descriptor: test.feature, kind: 'continuous' };
+  }
+  const level = test.level;
+  return {
+    name: test.variable,
+    x: data[test.feature].map(v => v === level ? 1 : 0),
+    descriptor: test.variable,
+    kind: test.kind,
+  };
+}
+
+function screenBinaryInteractions(data, dummies) {
+  const y = data.pfs_months;
+  const candidates = dummies.filter(d => {
+    const n1 = d.x.reduce((a, b) => a + (b ? 1 : 0), 0);
+    return n1 >= 1000 && n1 <= y.length - 1000;
+  });
+  const out = [];
+  for (let i = 0; i < candidates.length; i++) {
+    for (let j = i + 1; j < candidates.length; j++) {
+      if (candidates[i].feature === candidates[j].feature) continue;
+      const a = candidates[i].x;
+      const b = candidates[j].x;
+      let n00 = 0, n01 = 0, n10 = 0, n11 = 0;
+      for (let k = 0; k < y.length; k++) {
+        if (a[k] && b[k]) n11++;
+        else if (a[k]) n10++;
+        else if (b[k]) n01++;
+        else n00++;
+      }
+      if (Math.min(n00, n01, n10, n11) < 250) continue;
+      const interaction = a.map((v, k) => (v && b[k]) ? 1 : 0);
+      const fit = ols(y, [
+        { name: candidates[i].label, x: a.map(Number) },
+        { name: candidates[j].label, x: b.map(Number) },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        a: candidates[i],
+        b: candidates[j],
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+        n00,
+        n01,
+        n10,
+        n11,
+      });
+    }
+  }
+  out.sort((x, y2) => x.p - y2.p);
+  return out;
+}
+
+function screenBinaryContinuousInteractions(data, dummies, continuousTests) {
+  const y = data.pfs_months;
+  const binaries = dummies.filter(d => {
+    const n1 = d.x.reduce((a, b) => a + (b ? 1 : 0), 0);
+    return n1 >= 1000 && n1 <= y.length - 1000;
+  });
+  const continuous = continuousTests
+    .filter(t => t.kind === 'continuous')
+    .sort((a, b) => a.p - b.p)
+    .slice(0, 20);
+  const out = [];
+  for (const bin of binaries) {
+    const bx = bin.x.map(Number);
+    for (const ct of continuous) {
+      if (bin.feature === ct.feature) continue;
+      const x = data[ct.feature];
+      const xCentered = centered(x);
+      const interaction = xCentered.map((v, i) => v * bx[i]);
+      const fit = ols(y, [
+        { name: ct.feature, x: xCentered },
+        { name: bin.label, x: bx },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        binary: bin,
+        continuous: ct,
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+      });
+    }
+  }
+  out.sort((a, b) => a.p - b.p);
+  return out;
+}
+
+function selectedAdjustedModel(data, screen) {
+  const selected = [
+    'feature_041',
+    'feature_037',
+    'feature_025=current',
+    'feature_025=never',
+    'feature_036=0',
+    'feature_036=2',
+    'feature_015',
+    'feature_001',
+    'feature_042',
+    'feature_010',
+    'feature_057',
+    'feature_028',
+    'feature_056',
+    'feature_004',
+    'feature_009',
+    'feature_066',
+    'feature_051',
+  ];
+  const testsByVariable = new Map(screen.tests.map(t => [t.variable, t]));
+  const predictors = [];
+  for (const key of selected) {
+    if (key === 'feature_036=0' || key === 'feature_036=2') {
+      const level = Number(key.split('=')[1]);
+      predictors.push({ name: key, x: data.feature_036.map(v => v === level ? 1 : 0) });
+    } else {
+      const t = testsByVariable.get(key);
+      predictors.push(preparePredictorForTest(t, data));
+    }
+  }
+  return ols(data.pfs_months, predictors);
+}
+
+function interactionFit(data, aLabel, bLabel) {
+  const screen = univariableScreen(data);
+  const dummyByLabel = new Map(screen.dummies.map(d => [d.label, d]));
+  const a = dummyByLabel.get(aLabel);
+  const b = dummyByLabel.get(bLabel);
+  const ax = a.x.map(Number);
+  const bx = b.x.map(Number);
+  const ix = ax.map((v, i) => v * bx[i]);
+  const fit = ols(data.pfs_months, [
+    { name: aLabel, x: ax },
+    { name: bLabel, x: bx },
+    { name: `${aLabel} x ${bLabel}`, x: ix },
+  ]);
+  return fit.coefficients.find(c => c.name === `${aLabel} x ${bLabel}`);
+}
+
+function safeP(p) {
+  if (p === 0) return 1e-300;
+  return p;
+}
+
+function pText(p) {
+  return p === 0 || p <= 1e-300 ? 'p<1e-300' : `p=${p.toPrecision(4)}`;
+}
+
+function significant(p) {
+  return p < 0.05;
+}
+
+function round(x, digits = 4) {
+  const m = 10 ** digits;
+  return Math.round(x * m) / m;
+}
+
+function buildArtifacts(data) {
