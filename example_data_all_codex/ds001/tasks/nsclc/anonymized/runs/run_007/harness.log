+
+function readLittleBits(data, bitPos, bitWidth) {
+  let v = 0;
+  for (let b = 0; b < bitWidth; b++) {
+    const absolute = bitPos + b;
+    const bit = (data[absolute >> 3] >> (absolute & 7)) & 1;
+    v |= bit << b;
+  }
+  return v;
+}
+
+function decodeRleBitpacked(data, pos, count, bitWidth) {
+  if (bitWidth === 0) return { values: new Array(count).fill(0), pos };
+  const values = [];
+  while (values.length < count) {
+    const header = readUnsignedVarintAt(data, pos);
+    pos = header.pos;
+    if ((header.value & 1) === 0) {
+      const runLen = header.value >> 1;
+      const byteWidth = Math.ceil(bitWidth / 8);
+      let value = 0;
+      for (let i = 0; i < byteWidth; i++) value |= data[pos++] << (8 * i);
+      const take = Math.min(runLen, count - values.length);
+      for (let i = 0; i < take; i++) values.push(value);
+    } else {
+      const groups = header.value >> 1;
+      const runValues = groups * 8;
+      const byteLen = Math.ceil(runValues * bitWidth / 8);
+      const bitStart = pos * 8;
+      const take = Math.min(runValues, count - values.length);
+      for (let i = 0; i < take; i++) values.push(readLittleBits(data, bitStart + i * bitWidth, bitWidth));
+      pos += byteLen;
+    }
