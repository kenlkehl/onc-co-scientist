+    }
+    const values = Array.from(counts.keys());
+    const sortedCounts = Array.from(counts.entries()).sort((a, b) => b[1] - a[1]);
+    let kind;
+    if (numeric && counts.size > 10) kind = 'continuous';
+    else if (counts.size === 2) kind = 'binary';
+    else kind = 'categorical';
+    out.push({ name, arr, numeric, values, counts, sortedCounts, kind });
+  }
+  return out;
+}
+
+function univariableScreen(data) {
+  const y = data.pfs_months;
+  const infos = makeFeatureInfo(data);
+  const tests = [];
+  const dummies = [];
+  for (const info of infos) {
+    if (info.kind === 'continuous') {
+      const r = linearSlope(y, info.arr);
+      tests.push({
+        feature: info.name,
+        variable: info.name,
+        kind: 'continuous',
+        contrast: 'per 1-unit increase',
+        effect: r.slope,
+        p: r.p,
+        z: r.z,
+        meanX: r.meanX,
+        sdX: r.sdX,
+        n: y.length,
+      });
+    } else if (info.kind === 'binary') {
+      const vals = info.values.slice().sort();
+      const high = vals[1];
+      const low = vals[0];
+      const g = info.arr.map(v => v === high);
+      const r = groupStats(y, g);
+      tests.push({
+        feature: info.name,
+        variable: info.name,
+        kind: 'binary',
+        contrast: `${high} vs ${low}`,
+        level: high,
+        reference: low,
+        effect: r.effect,
+        p: r.p,
+        z: r.z,
+        n0: r.n0,
+        n1: r.n1,
+        mean0: r.mean0,
+        mean1: r.mean1,
+      });
+      dummies.push({ feature: info.name, label: `${info.name}=${high}`, x: g.map(Boolean), level: high, reference: low, kind: 'binary' });
+    } else {
+      const reference = info.sortedCounts[0][0];
+      for (const [level, count] of info.sortedCounts) {
+        if (level === reference) continue;
+        if (count < 100) continue;
+        const g = info.arr.map(v => v === level);
+        const r = groupStats(y, g);
+        tests.push({
+          feature: info.name,
+          variable: `${info.name}=${level}`,
+          kind: 'categorical',
+          contrast: `${level} vs all other values`,
+          level,
+          reference: 'all other values',
+          effect: r.effect,
+          p: r.p,
+          z: r.z,
+          n0: r.n0,
+          n1: r.n1,
+          mean0: r.mean0,
+          mean1: r.mean1,
