+function preparePredictorForTest(test, data) {
+  if (test.kind === 'continuous') {
+    return { name: test.feature, x: data[test.feature].slice(), descriptor: test.feature, kind: 'continuous' };
+  }
+  const level = test.level;
+  return {
+    name: test.variable,
+    x: data[test.feature].map(v => v === level ? 1 : 0),
+    descriptor: test.variable,
+    kind: test.kind,
+  };
+}
+
+function screenBinaryInteractions(data, dummies) {
+  const y = data.pfs_months;
+  const candidates = dummies.filter(d => {
+    const n1 = d.x.reduce((a, b) => a + (b ? 1 : 0), 0);
+    return n1 >= 1000 && n1 <= y.length - 1000;
+  });
+  const out = [];
+  for (let i = 0; i < candidates.length; i++) {
+    for (let j = i + 1; j < candidates.length; j++) {
+      if (candidates[i].feature === candidates[j].feature) continue;
+      const a = candidates[i].x;
+      const b = candidates[j].x;
+      let n00 = 0, n01 = 0, n10 = 0, n11 = 0;
+      for (let k = 0; k < y.length; k++) {
+        if (a[k] && b[k]) n11++;
+        else if (a[k]) n10++;
+        else if (b[k]) n01++;
+        else n00++;
+      }
+      if (Math.min(n00, n01, n10, n11) < 250) continue;
+      const interaction = a.map((v, k) => (v && b[k]) ? 1 : 0);
+      const fit = ols(y, [
+        { name: candidates[i].label, x: a.map(Number) },
+        { name: candidates[j].label, x: b.map(Number) },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        a: candidates[i],
+        b: candidates[j],
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+        n00,
+        n01,
+        n10,
+        n11,
+      });
+    }
+  }
+  out.sort((x, y2) => x.p - y2.p);
+  return out;
+}
+
+function screenBinaryContinuousInteractions(data, dummies, continuousTests) {
+  const y = data.pfs_months;
+  const binaries = dummies.filter(d => {
+    const n1 = d.x.reduce((a, b) => a + (b ? 1 : 0), 0);
+    return n1 >= 1000 && n1 <= y.length - 1000;
+  });
+  const continuous = continuousTests
+    .filter(t => t.kind === 'continuous')
+    .sort((a, b) => a.p - b.p)
+    .slice(0, 20);
+  const out = [];
+  for (const bin of binaries) {
+    const bx = bin.x.map(Number);
+    for (const ct of continuous) {
+      if (bin.feature === ct.feature) continue;
+      const x = data[ct.feature];
+      const xCentered = centered(x);
+      const interaction = xCentered.map((v, i) => v * bx[i]);
+      const fit = ols(y, [
+        { name: ct.feature, x: xCentered },
+        { name: bin.label, x: bx },
+        { name: 'interaction', x: interaction },
+      ]);
+      const coef = fit.coefficients.find(c => c.name === 'interaction');
+      out.push({
+        binary: bin,
+        continuous: ct,
+        effect: coef.beta,
+        p: coef.p,
+        z: coef.z,
+      });
+    }
+  }
+  out.sort((a, b) => a.p - b.p);
+  return out;
+}
