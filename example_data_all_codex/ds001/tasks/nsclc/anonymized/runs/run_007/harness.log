+const fs = require('fs');
+
+const PARQUET_TYPES = {
+  BOOLEAN: 0,
+  INT32: 1,
+  INT64: 2,
+  FLOAT: 4,
+  DOUBLE: 5,
+  BYTE_ARRAY: 6,
+};
+
+const CT_STOP = 0;
+const CT_TRUE = 1;
+const CT_FALSE = 2;
+const CT_BYTE = 3;
+const CT_I16 = 4;
+const CT_I32 = 5;
+const CT_I64 = 6;
+const CT_DOUBLE = 7;
+const CT_BINARY = 8;
+const CT_LIST = 9;
+const CT_SET = 10;
+const CT_MAP = 11;
+const CT_STRUCT = 12;
+
+class CompactReader {
+  constructor(buffer) {
+    this.buf = buffer;
+    this.pos = 0;
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
+  }
+  readZigZag() {
+    const n = this.readVarintBig();
+    const v = (n >> 1n) ^ (-(n & 1n));
+    return Number(v);
+  }
+  readBinary() {
+    const len = this.readVarint();
+    const out = this.buf.subarray(this.pos, this.pos + len);
+    this.pos += len;
+    return out.toString('utf8');
+  }
+  readList(elemReader) {
+    const header = this.readByte();
+    let size = header >> 4;
+    const type = header & 0x0f;
+    if (size === 15) size = this.readVarint();
+    const arr = [];
+    for (let i = 0; i < size; i++) arr.push(elemReader(type));
+    return arr;
+  }
+  readValue(type) {
+    switch (type) {
+      case CT_TRUE: return true;
+      case CT_FALSE: return false;
+      case CT_BYTE: return this.readByte();
+      case CT_I16:
+      case CT_I32:
+      case CT_I64: return this.readZigZag();
+      case CT_DOUBLE: {
+        const v = this.buf.readDoubleLE(this.pos);
+        this.pos += 8;
+        return v;
+      }
+      case CT_BINARY: return this.readBinary();
+      case CT_LIST:
+      case CT_SET: return this.readList(t => this.readValue(t));
+      case CT_STRUCT: return this.readStruct();
+      case CT_MAP: {
+        const size = this.readVarint();
+        if (size === 0) return [];
+        const types = this.readByte();
+        const kt = types >> 4;
+        const vt = types & 0x0f;
