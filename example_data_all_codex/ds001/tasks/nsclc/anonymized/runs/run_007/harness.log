+  const tests = [];
+  const dummies = [];
+  for (const info of infos) {
+    if (info.kind === 'continuous') {
+      const r = linearSlope(y, info.arr);
+      tests.push({
+        feature: info.name,
+        variable: info.name,
+        kind: 'continuous',
+        contrast: 'per 1-unit increase',
+        effect: r.slope,
+        p: r.p,
+        z: r.z,
+        meanX: r.meanX,
+        sdX: r.sdX,
+        n: y.length,
+      });
+    } else if (info.kind === 'binary') {
+      const vals = info.values.slice().sort();
+      const high = vals[1];
+      const low = vals[0];
+      const g = info.arr.map(v => v === high);
+      const r = groupStats(y, g);
+      tests.push({
+        feature: info.name,
+        variable: info.name,
+        kind: 'binary',
+        contrast: `${high} vs ${low}`,
+        level: high,
+        reference: low,
+        effect: r.effect,
+        p: r.p,
+        z: r.z,
+        n0: r.n0,
+        n1: r.n1,
+        mean0: r.mean0,
+        mean1: r.mean1,
