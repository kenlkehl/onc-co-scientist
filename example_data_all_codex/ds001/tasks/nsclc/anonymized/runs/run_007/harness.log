+const fs = require('fs');
+
+const buf = fs.readFileSync('dataset.parquet');
+const footerLen = buf.readUInt32LE(buf.length - 8);
+const footer = buf.subarray(buf.length - 8 - footerLen, buf.length - 8);
+
+const CT_STOP = 0;
+const CT_TRUE = 1;
+const CT_FALSE = 2;
+const CT_BYTE = 3;
+const CT_I16 = 4;
+const CT_I32 = 5;
+const CT_I64 = 6;
+const CT_DOUBLE = 7;
+const CT_BINARY = 8;
+const CT_LIST = 9;
+const CT_SET = 10;
+const CT_MAP = 11;
+const CT_STRUCT = 12;
+
+class CompactReader {
+  constructor(buffer) {
+    this.buf = buffer;
+    this.pos = 0;
+  }
+  readByte() {
+    return this.buf[this.pos++];
+  }
+  readVarintBig() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.readByte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  readVarint() {
+    return Number(this.readVarintBig());
