+        }
+      } else if (dataHeader[2] === 0) {
+        const plain = decodePlainValues(page.subarray(p), col.type, nonNull);
+        let j = 0;
+        for (let i = 0; i < n; i++) {
+          if (defs.values[i] > 0) values.push(plain[j++]);
+          else values.push(null);
+        }
