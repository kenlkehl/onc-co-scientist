+  addIteration(2, [
+    h('h2a', '`feature_036=0` patients have higher mean `pfs_months` than patients with `feature_036` not equal to 0.'),
+    h('h2b', '`feature_036=2` patients have lower mean `pfs_months` than patients with `feature_036` not equal to 2.'),
+  ], [mainAnalysis('feature_036=0', 'h2a'), mainAnalysis('feature_036=2', 'h2b')]);
+
+  addIteration(3, [
+    h('h3', '`feature_001=1` patients have lower mean `pfs_months` than `feature_001=0` patients.'),
+  ], [mainAnalysis('feature_001', 'h3')]);
+
+  addIteration(4, [
+    h('h4', '`feature_015=squamous` patients have lower mean `pfs_months` than `feature_015=adenocarcinoma` patients.'),
+  ], [mainAnalysis('feature_015', 'h4')]);
+
+  addIteration(5, [
+    h('h5a', '`feature_025=current` patients have lower mean `pfs_months` than patients with other `feature_025` values.'),
+    h('h5b', '`feature_025=never` patients have higher mean `pfs_months` than patients with other `feature_025` values.'),
+  ], [mainAnalysis('feature_025=current', 'h5a'), mainAnalysis('feature_025=never', 'h5b')]);
+
+  addIteration(6, [
+    h('h6a', '`feature_042=1` patients have lower mean `pfs_months` than `feature_042=0` patients.'),
+    h('h6b', '`feature_010=1` patients have higher mean `pfs_months` than `feature_010=0` patients.'),
+  ], [mainAnalysis('feature_042', 'h6a'), mainAnalysis('feature_010', 'h6b')]);
+
+  addIteration(7, [
+    h('h7a', '`feature_057=1` patients have lower mean `pfs_months` than `feature_057=0` patients.'),
+    h('h7b', '`feature_028=1` patients have lower mean `pfs_months` than `feature_028=0` patients.'),
+  ], [mainAnalysis('feature_057', 'h7a'), mainAnalysis('feature_028', 'h7b')]);
+
+  addIteration(8, [
+    h('h8a', 'Higher `feature_056` values are associated with higher `pfs_months`.'),
+    h('h8b', 'Higher `feature_004` values are associated with lower `pfs_months`.'),
+  ], [mainAnalysis('feature_056', 'h8a'), mainAnalysis('feature_004', 'h8b')]);
+
+  addIteration(9, [
+    h('h9a', '`feature_009=1` patients have higher mean `pfs_months` than `feature_009=0` patients.'),
+    h('h9b', '`feature_066=1` patients have higher mean `pfs_months` than `feature_066=0` patients.'),
