+
+function mean(arr) {
+  let s = 0;
+  for (const v of arr) s += v;
+  return s / arr.length;
+}
+
+function sd(arr) {
+  const m = mean(arr);
+  let ss = 0;
+  for (const v of arr) {
+    const d = v - m;
+    ss += d * d;
+  }
+  return Math.sqrt(ss / (arr.length - 1));
+}
+
+function erfApprox(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
