+      for (let i = 0; i < byteWidth; i++) value |= data[pos++] << (8 * i);
+      const take = Math.min(runLen, count - values.length);
+      for (let i = 0; i < take; i++) values.push(value);
+    } else {
+      const groups = header.value >> 1;
+      const runValues = groups * 8;
