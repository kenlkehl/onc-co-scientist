+    const t = tests.get(varName);
+    return a(
+      hid,
+      `${varName}: effect ${round(t.effect, 4)} months (${t.contrast}; ${pText(t.p)}).`,
+      t.effect,
+      t.p,
+      methodLabel || (t.kind === 'continuous' ? 'Univariable OLS slope for pfs_months on the feature.' : 'Two-group mean comparison on pfs_months.'),
+      t
+    );
+  };
