+
+function readUnsignedVarintAt(data, start) {
+  let pos = start;
+  let shift = 0;
+  let result = 0;
+  while (true) {
+    const b = data[pos++];
+    result |= (b & 0x7f) << shift;
+    if ((b & 0x80) === 0) break;
+    shift += 7;
+  }
+  return { value: result, pos };
