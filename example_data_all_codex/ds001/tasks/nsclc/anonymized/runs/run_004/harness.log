import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
print('pfs describe')
print(df['pfs_months'].describe().to_string())
print('missing', int(df.isna().sum().sum()))
summary=[]
for c in df.columns:
    if c=='pfs_months':
        continue
    s=df[c]
    nun=s.nunique(dropna=False)
    vals=s.value_counts(dropna=False).head(10).to_dict()
    summary.append((c,str(s.dtype),nun, float(s.mean()) if pd.api.types.is_numeric_dtype(s) else None, vals))
for row in summary:
    print(row)
