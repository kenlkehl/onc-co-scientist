 return out.slice(0,n); }
function erf(x){ const sign=x<0?-1:1; x=Math.abs(x); const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911; const t=1/(1+p*x); const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x); return sign*y; }
function norm2p(z){ const p=1-erf(Math.abs(z)/Math.SQRT2); return Math.max(p, Number.MIN_VALUE); }
function statsForMask(y, mask){ let n1=0,n0=0,s1=0,s0=0,ss1=0,ss0=0; for(let i=0;i<y.length;i++){ const v=y[i]; if(mask[i]){n1++;s1+=v;ss1+=v*v;} else {n0++;s0+=v;ss0+=v*v;} } if(n1<20 || n0<20) return null; const m1=s1/n1,m0=s0/n0; const v1=Math.max(0,(ss1-s1*s1/n1)/(n1-1)); const v0=Math.max(0,(ss0-s0*s0/n0)/(n0-1)); const se=Math.sqrt(v1/n1+v0/n0); const z=se>0?(m1-m0)/se:0; return {n1,n0,m1,m0,effect:m1-m0,z,p:norm2p(z)}; }
function corrSlope(y,x){ const n=y.length; let sx=0,sy=0,sxx=0,syy=0,sxy=0; for(let i=0;i<n;i++){const xi=x[i], yi=y[i]; sx+=xi; sy+=yi; sxx+=xi*xi; syy+=yi*yi; sxy+=xi*yi;} const mx=sx/n,my=sy/n; const Sxx=sxx-sx*sx/n, Syy=syy-sy*sy/n, Sxy=sxy-sx*sy/n; const slope=Sxy/Sxx; const r=Sxy/Math.sqrt(Sxx*Syy); const z=Math.abs(r)*Math.sqrt((n-2)/Math.max(1e-300,1-r*r)); return {effect:slope,r,p:norm2p(z),meanX:mx,meanY:my}; }
function quantile(arr,q){ const a=[...arr].sort((a,b)=>a-b); const idx=(a.length-1)*q; const lo=Math.floor(idx), hi=Math.ceil(idx); if(lo===hi)return a[lo]; return a[lo]*(hi-idx)+a[hi]*(idx-lo); }
