import pandas as pd
from pathlib import Path
p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
print('dtypes')
print(df.dtypes.to_string())
feature_cols = [c for c in df.columns if c.startswith('feature_')]
outcome_cols = [c for c in df.columns if c.startswith('dependency_')]
print('features', len(feature_cols), 'outcomes', len(outcome_cols))
print('\\nfeature profile:')
for c in feature_cols:
    s=df[c]
    nun=s.nunique(dropna=False)
    vals=s.value_counts(dropna=False).head(8)
    print(c, 'dtype=', s.dtype, 'nunique=', nun, 'mean=', getattr(s,'mean',lambda:None)() if pd.api.types.is_numeric_dtype(s) else 'NA')
    print(vals.to_string())
print('\\noutcome describe:')
print(df[outcome_cols].describe().T.to_string())
