for(const yname of outs){ const y=data[yname]; let main=[]; for(const pred of predicates){ const st=statsForMask(y,pred.mask); if(st) main.push({pred:pred.name,...st}); } main.sort((a,b)=>a.effect-b.effect); console.log('\\nOUTCOME',yname,'mean', (y.reduce((a,b)=>a+b,0)/y.length).toFixed(4)); console.log('Top negative main/subgroup predicates'); for(const r of main.slice(0,8)) console.log(r.pred,'n',r.n1,'eff',r.effect.toFixed(4),'means',r.m1.toFixed(4),r.m0.toFixed(4),'p',r.p.toExponential(2)); console.log('Top positive predicates'); for(const r of main.slice(-5).reverse()) console.log(r.pred,'n',r.n1,'eff',r.effect.toFixed(4),'means',r.m1.toFixed(4),r.m0.toFixed(4),'p',r.p.toExponential(2));
 let pairs=[]; for(let i=0;i<predicates.length;i++){ for(let j=i+1;j<predicates.length;j++){ const a=predicates[i], b=predicates[j]; if(a.f===b.f) continue; const mask=new Array(y.length); let n=0; for(let k=0;k<y.length;k++){ const m=a.mask[k]&&b.mask[k]; mask[k]=m; if(m)n++; } if(n<250||n>25000) continue; const st=statsForMask(y,mask); if("'!st) continue; pairs.push({pred:a.name+'"' & '+b.name,...st}); } } pairs.sort((a,b)=>a.effect-b.effect); console.log('Top negative pair subgroups'); for(const r of pairs.slice(0,8)) console.log(r.pred,'n',r.n1,'eff',r.effect.toFixed(4),'means',r.m1.toFixed(4),r.m0.toFixed(4),'p',r.p.toExponential(2)); }
