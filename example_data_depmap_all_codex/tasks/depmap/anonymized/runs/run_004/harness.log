for(let i=1;i<schema.length;i++){ const name=schema[i]; if(name.startsWith('feature_')||name.startsWith('dependency_')) data[name]=decodeColumn(cols[i][3]); }
const features=Object.keys(data).filter(c=>c.startsWith('feature_')); const outs=Object.keys(data).filter(c=>c.startsWith('dependency_'));
const predicates=[];
for(const f of features){ const arr=data[f]; const vals=[...new Set(arr)]; if(typeof arr[0]==='string' || vals.length<=12){ for(const v of vals){ const mask=arr.map(x=>x===v); const n=mask.reduce((a,b)=>a+(b?1:0),0); if(n>=250 && n<=49750) predicates.push({name:f+'='+v, f, val:v, mask, n}); } } else { const q25=quantile(arr,.25), q75=quantile(arr,.75); predicates.push({name:f+'>='+q75.toFixed(3), f, op:'>=q75', val:q75, mask:arr.map(x=>x>=q75), n:arr.filter(x=>x>=q75).length}); predicates.push({name:f+'<='+q25.toFixed(3), f, op:'<=q25', val:q25, mask:arr.map(x=>x<=q25), n:arr.filter(x=>x<=q25).length}); }
}
