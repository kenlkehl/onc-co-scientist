print('dataset_id', tr['dataset_id'])
print('max_iterations', tr['max_iterations'])
print('iterations', len(tr['iterations']))
print('hypotheses', sum(len(i.get('proposed_hypotheses', [])) for i in tr['iterations']))
print('analyses', sum(len(i.get('analyses', [])) for i in tr['iterations']))
missing=[]
for it in tr['iterations']:
    for idx,a in enumerate(it.get('analyses', []), start=1):
        for key in ['hypothesis_ids','result_summary','effect_estimate']:
            if key not in a or a[key] in ([], None):
                missing.append((it['index'], idx, key))
        if 'p_value' not in a and 'significant' not in a:
            missing.append((it['index'], idx, 'p_value_or_significant'))
print('missing_required_analysis_fields', missing)
