import pandas as pd, numpy as np
import statsmodels.api as sm
from scipy import stats

df=pd.read_parquet('dataset.parquet')
y=df['dependency_KIF18A']
q02875=df.feature_028.quantile(.75); q02890=df.feature_028.quantile(.90)
q01775=df.feature_017.quantile(.75); q01790=df.feature_017.quantile(.90)
conds={
'colorectal': df.feature_011.eq('colorectal'),
'feature_028_high75': df.feature_028.ge(q02875),
'feature_028_high90': df.feature_028.ge(q02890),
'feature_035_1': df.feature_035.eq(1),
'feature_020_0': df.feature_020.eq(0),
'feature_020_1': df.feature_020.eq(1),
'feature_017_high75': df.feature_017.ge(q01775),
'feature_017_high90': df.feature_017.ge(q01790),
}

def test(mask):
    a=y[mask]; b=y[~mask]
    p=stats.ttest_ind(a,b,equal_var=False).pvalue
    return int(mask.sum()), float(a.mean()), float(b.mean()), float(a.mean()-b.mean()), float(p)

rules=[
['colorectal'],
['feature_028_high90'],
['feature_035_1'],
['colorectal','feature_028_high90'],
['colorectal','feature_028_high75'],
['colorectal','feature_035_1'],
['colorectal','feature_020_0'],
['colorectal','feature_020_1'],
['colorectal','feature_035_1','feature_020_0'],
['colorectal','feature_035_1','feature_020_1'],
['colorectal','feature_028_high90','feature_035_1'],
['colorectal','feature_028_high90','feature_020_0'],
['colorectal','feature_028_high90','feature_035_1','feature_020_0'],
['colorectal','feature_028_high75','feature_035_1','feature_020_0'],
['colorectal','feature_028_high90','feature_035_1','feature_020_1'],
['colorectal','feature_017_high90'],
['colorectal','feature_028_high90','feature_017_high90'],
]
for r in rules:
    m=np.ones(len(df),bool)
    for k in r: m &= conds[k].to_numpy()
    print(' AND '.join(r), test(m))

# 2x2 means in colorectal for f035 and f020, and f028 high90
col=conds['colorectal']
print('\\nWithin colorectal 2x2 f035/f020')
for f035 in [0,1]:
  for f020 in [0,1]:
    m=col & df.feature_035.eq(f035) & df.feature_020.eq(f020)
    print(f'f035={f035} f020={f020}', int(m.sum()), float(y[m].mean()))
print('\\nWithin colorectal x f035 x f028 high90')
for f035 in [0,1]:
  for high in [0,1]:
    m=col & df.feature_035.eq(f035) & (df.feature_028.ge(q02890) if high else df.feature_028.lt(q02890))
    print(f'f035={f035} f028_high90={high}', int(m.sum()), float(y[m].mean()))
print('\\nWithin colorectal x f020 x f028 high90')
for f020 in [0,1]:
  for high in [0,1]:
    m=col & df.feature_020.eq(f020) & (df.feature_028.ge(q02890) if high else df.feature_028.lt(q02890))
    print(f'f020={f020} f028_high90={high}', int(m.sum()), float(y[m].mean()))

# OLS with interactions: y ~ C + f035 + f020 + C:f035 + C:f020, maybe outside model
C=col.astype(float).to_numpy(); F35=df.feature_035.astype(float).to_numpy(); F20=df.feature_020.astype(float).to_numpy(); H90=df.feature_028.ge(q02890).astype(float).to_numpy(); H75=df.feature_028.ge(q02875).astype(float).to_numpy()
for name,H in [('H90',H90),('H75',H75)]:
    X=sm.add_constant(np.column_stack([C,F35,F20,H,C*F35,C*F20,C*H,F35*H,C*F35*H]))
    fit=sm.OLS(y,X).fit()
    print('\\nOLS interaction', name)
    labels=['const','C','F35','F20','H','C:F35','C:F20','C:H','F35:H','C:F35:H']
    for lab,coef,p in zip(labels,fit.params,fit.pvalues):
        print(lab, float(coef), float(p))
