]

# Iteration 5: systematic one- and two-predicate dependency heterogeneity screen.
def build_predicates():
    preds = []
    for c in cat:
        vals = sorted(df[c].astype(str).unique())
        for val in vals:
            m = df[c].astype(str).eq(val).to_numpy()
            n = int(m.sum())
            if 200 <= n <= len(df) - 200:
                preds.append({'name': f'{c} == {val}', 'feature': c, 'mask': m, 'n': n})
    for c in bin_cols:
        for val in [1, 0]:
            m = df[c].eq(val).to_numpy()
            n = int(m.sum())
            if 200 <= n <= len(df) - 200:
                preds.append({'name': f'{c} == {val}', 'feature': c, 'mask': m, 'n': n})
    for c in cont:
        vals = df[c]
        for prob, op in [(0.10, '<='), (0.25, '<='), (0.75, '>='), (0.90, '>=')]:
            thr = float(vals.quantile(prob))
            if op == '<=':
                m = vals.le(thr).to_numpy()
                name = f'{c} <= q{int(prob*100)} ({thr:.3g})'
            else:
                m = vals.ge(thr).to_numpy()
                name = f'{c} >= q{int(prob*100)} ({thr:.3g})'
            n = int(m.sum())
            if 200 <= n <= len(df) - 200:
                preds.append({'name': name, 'feature': c, 'mask': m, 'n': n})
    return preds

preds = build_predicates()

def bh_qvalues(pvals):
    pvals = np.asarray(pvals, dtype=float)
    n = len(pvals)
    order = np.argsort(pvals)
    ranks = np.empty(n, dtype=int)
    ranks[order] = np.arange(1, n + 1)
    raw = pvals * n / ranks
    qvals = np.empty(n, dtype=float)
    running = 1.0
    for idx in order[::-1]:
        running = min(running, raw[idx])
        qvals[idx] = running
    return np.minimum(qvals, 1.0)

screen_results = {}
for ycol in outcomes:
    y = df[ycol].to_numpy()
    rows = []
    # Include one-predicate and two-predicate rules; min subgroup n = 300 for two-predicate rules.
    for pr in preds:
        m = pr['mask']
