        f'Within feature_011 == colorectal and feature_035 == 1, feature_020 == 1 had mean dependency_KIF18A {r17[\"mean_a\"]:.6g} in {r17[\"n_a\"]} lines vs {r17[\"mean_b\"]:.6g} for feature_020 == 0 in {r17[\"n_b\"]} lines; positive difference {r17[\"effect\"]:.6g} indicates suppression of the negative dependency (Welch p={ptxt(r17[\"p\"])}).',
        r17['effect'],
        r17['p'],
        code='Welch t-test within feature_011 == colorectal and feature_035 == 1: feature_020 == 1 vs feature_020 == 0',
        **{k: v for k, v in r17.items() if k not in {'effect', 'p'}},
