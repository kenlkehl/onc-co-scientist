        for j in range(i + 1, len(preds)):
            if preds[i]['feature'] == preds[j]['feature']:
                continue
            m = mi & preds[j]['mask']
            n = int(m.sum())
            if n < 300 or n > len(df) - 300:
                continue
            a = y[m]
            b = y[~m]
            p = fnum(stats.ttest_ind(a, b, equal_var=False).pvalue)
            rows.append({
                'rule': preds[i]['name'] + ' AND ' + preds[j]['name'],
                'features': (preds[i]['feature'], preds[j]['feature']),
                'n': n,
                'mean_group': fnum(a.mean()),
                'mean_complement': fnum(b.mean()),
                'effect': fnum(a.mean() - b.mean()),
                'p': p,
                'n_predicates': 2,
            })
    s = pd.DataFrame(rows)
    s['q'] = bh_qvalues(s['p'].fillna(1.0).to_numpy())
    s = s.sort_values(['effect', 'q'], ascending=[True, True]).reset_index(drop=True)
    screen_results[ycol] = s

iter5_h = []
iter5_a = []
hid_num = 20
for ycol in outcomes:
    top = screen_results[ycol].iloc[0]
    hid = f'h{hid_num}'
    iter5_h.append(hyp(hid, f'In a systematic one- and two-predicate heterogeneity screen, cell lines matching the top rule {top[\"rule\"]} have more negative {ycol} scores than the complement.', 'refined'))
    iter5_a.append(analysis(
        [hid],
        f'Systematic screen over {len(preds)} primitive predicates and {len(screen_results[ycol])} eligible one-/two-predicate rules for {ycol} selected {top[\"rule\"]}: mean {top[\"mean_group\"]:.6g} in {int(top[\"n\"])} lines vs {top[\"mean_complement\"]:.6g} in the complement; effect {top[\"effect\"]:.6g}, raw p={ptxt(top[\"p\"])}, BH q={ptxt(top[\"q\"])}.',
        top['effect'],
        top['p'],
        code='Enumerate categorical levels, binary values, and continuous quantile predicates; test eligible one- and two-predicate subgroups with Welch tests; BH-adjust within outcome.',
        significant=bool(top['q'] < 0.05),
        adjusted_p_value=fnum(top['q']),
        selected_rule=top['rule'],
        n_group=int(top['n']),
        mean_group=fnum(top['mean_group']),
        mean_complement=fnum(top['mean_complement']),
        screen_rank=1,
        number_of_rules_tested=int(len(screen_results[ycol])),
    ))
    hid_num += 1

# Iteration 6: refined weaker/common subgroup tests.
iter6_h = [
    hyp('h30', f'Cell lines with feature_016 >= {q[(\"feature_016\", .90)]:.3f} and feature_026 >= {q[(\"feature_026\", .90)]:.3f} have more negative dependency_TMED10 scores than all other cell lines.', 'refined'),
    hyp('h31', f'Cell lines with feature_016 >= {q[(\"feature_016\", .90)]:.3f} and feature_023 >= {q[(\"feature_023\", .90)]:.3f} have more negative dependency_DHX9 scores than all other cell lines.', 'refined'),
    hyp('h32', f'Cell lines with feature_016 >= {q[(\"feature_016\", .90)]:.3f} and feature_015 <= {q[(\"feature_015\", .10)]:.3f} have more negative dependency_POLR2A scores than all other cell lines.', 'refined'),
    hyp('h33', f'Cell lines with feature_003 >= {q[(\"feature_003\", .90)]:.3f} and feature_018 == 1 have more negative dependency_RPL11 scores than all other cell lines.', 'refined'),
