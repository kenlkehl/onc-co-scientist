import json
import math
from pathlib import Path

import numpy as np
import pandas as pd
import statsmodels.api as sm
from scipy import stats

base = Path('.')
df = pd.read_parquet(base / 'dataset.parquet')
features = [c for c in df.columns if c.startswith('feature_')]
outcomes = [c for c in df.columns if c.startswith('dependency_')]
cat = [c for c in features if df[c].dtype == 'object' or c == 'feature_001']
bin_cols = [c for c in features if pd.api.types.is_integer_dtype(df[c]) and df[c].nunique() == 2]
cont = [c for c in features if c not in cat + bin_cols]

# Common additive design: continuous features are standardized; binary and dummy-coded categorical
# columns stay on their natural 0/1 scale.
X_add = pd.concat(
    [
        (df[cont] - df[cont].mean()) / df[cont].std(ddof=0),
        df[bin_cols].astype(float),
        pd.get_dummies(df[cat].astype(str), prefix=cat, drop_first=True, dtype=float),
    ],
    axis=1,
)
X_add_const = sm.add_constant(X_add)
fits = {y: sm.OLS(df[y], X_add_const).fit() for y in outcomes}

q = {
    ('feature_028', .90): float(df['feature_028'].quantile(.90)),
    ('feature_028', .75): float(df['feature_028'].quantile(.75)),
    ('feature_016', .90): float(df['feature_016'].quantile(.90)),
    ('feature_016', .75): float(df['feature_016'].quantile(.75)),
    ('feature_023', .90): float(df['feature_023'].quantile(.90)),
    ('feature_023', .75): float(df['feature_023'].quantile(.75)),
    ('feature_003', .90): float(df['feature_003'].quantile(.90)),
    ('feature_015', .10): float(df['feature_015'].quantile(.10)),
    ('feature_026', .90): float(df['feature_026'].quantile(.90)),
}


def fnum(x):
    x = float(x)
    if math.isnan(x):
        return None
    if math.isinf(x):
        return 0.0 if x < 0 else 1e308
    return x


def ptxt(p):
    p = fnum(p)
    if p is None:
        return 'NA'
    if p == 0.0:
        return '<1e-300'
    if p < 1e-4:
        return f'{p:.2e}'
    return f'{p:.4f}'


def analysis(hids, summary, effect, p=None, code=None, significant=None, **extra):
    if significant is None and p is not None:
        significant = bool(fnum(p) < 0.05)
    rec = {
        'hypothesis_ids': hids,
        'code': code,
        'result_summary': summary,
        'p_value': fnum(p) if p is not None else None,
        'effect_estimate': fnum(effect) if effect is not None else None,
        'significant': significant,
    }
    rec.update(extra)
    return rec


def add_iter(index, hyps, analyses, update):
    return {
        'index': index,
        'proposed_hypotheses': hyps,
        'analyses': analyses,
        'update': update,
    }


def hyp(hid, text, kind='novel'):
    return {'id': hid, 'text': text, 'kind': kind}


def ols_summary(y, term, label):
    fit = fits[y]
    coef = fnum(fit.params[term])
    p = fnum(fit.pvalues[term])
    return analysis(
        [label],
        f'Additive OLS for {y} gave coefficient {coef:.6g} for {term} after adjustment for the other local features (p={ptxt(p)}). Negative values mean stronger dependency.',
        coef,
        p,
        code=f'OLS({y} ~ all local cell-line features); report coefficient for {term}',
        r_squared=fnum(fit.rsquared),
    )


def welch_mask(ycol, mask):
    mask = pd.Series(mask, index=df.index).astype(bool)
    a = df.loc[mask, ycol]
    b = df.loc[~mask, ycol]
    p = stats.ttest_ind(a, b, equal_var=False).pvalue
    return {
        'n_group': int(mask.sum()),
        'n_complement': int((~mask).sum()),
        'mean_group': fnum(a.mean()),
        'mean_complement': fnum(b.mean()),
        'effect': fnum(a.mean() - b.mean()),
        'p': fnum(p),
    }


def welch_two(ycol, mask_a, mask_b):
    mask_a = pd.Series(mask_a, index=df.index).astype(bool)
    mask_b = pd.Series(mask_b, index=df.index).astype(bool)
    a = df.loc[mask_a, ycol]
    b = df.loc[mask_b, ycol]
    p = stats.ttest_ind(a, b, equal_var=False).pvalue
    return {
        'n_a': int(mask_a.sum()),
        'n_b': int(mask_b.sum()),
        'mean_a': fnum(a.mean()),
        'mean_b': fnum(b.mean()),
        'effect': fnum(a.mean() - b.mean()),
        'p': fnum(p),
    }


def inter(ycol, driver, modifier):
    y = df[ycol].to_numpy()
    g = pd.Series(driver, index=df.index).astype(bool).to_numpy()
    h = pd.Series(modifier, index=df.index).astype(bool).to_numpy()
    G = g.astype(float)
    H = h.astype(float)
    fit = sm.OLS(y, sm.add_constant(np.column_stack([G, H, G * H]))).fit()
    e_h = fnum(y[g & h].mean() - y[(~g) & h].mean())
    e_not = fnum(y[g & (~h)].mean() - y[(~g) & (~h)].mean())
    return {
        'coef': fnum(fit.params[3]),
        'p': fnum(fit.pvalues[3]),
        'driver_effect_in_modifier': e_h,
        'driver_effect_outside_modifier': e_not,
        'n_driver_and_modifier': int((g & h).sum()),
        'n_not_driver_and_modifier': int(((~g) & h).sum()),
        'n_driver_not_modifier': int((g & (~h)).sum()),
        'n_neither': int(((~g) & (~h)).sum()),
    }


def interaction_analysis(hid, ycol, driver, modifier, driver_txt, modifier_txt):
    r = inter(ycol, driver, modifier)
    return analysis(
        [hid],
        f'OLS interaction for {driver_txt} by {modifier_txt} on {ycol}: interaction coefficient {r[\"coef\"]:.6g}; driver effect was {r[\"driver_effect_in_modifier\"]:.6g} within the modifier and {r[\"driver_effect_outside_modifier\"]:.6g} outside it (p={ptxt(r[\"p\"])}).',
        r['coef'],
        r['p'],
        code=f'OLS({ycol} ~ driver + modifier + driver:modifier)',
        **r,
    )


def subgroup_analysis(hid, ycol, mask, rule_txt):
    r = welch_mask(ycol, mask)
    return analysis(
        [hid],
        f'{rule_txt}: mean {ycol} was {r[\"mean_group\"]:.6g} in {r[\"n_group\"]} matching lines vs {r[\"mean_complement\"]:.6g} in the complement; difference {r[\"effect\"]:.6g} (Welch p={ptxt(r[\"p\"])}).',
        r['effect'],
        r['p'],
        code=f'Welch t-test comparing {rule_txt} against the complement for {ycol}',
        **{k: v for k, v in r.items() if k not in {'effect', 'p'}},
    )

# Iteration 1: strong binary drivers.
iter1_h = [
    hyp('h1', 'Cell lines with feature_009 == 1 have more negative dependency_BRAF scores than cell lines with feature_009 == 0, after adjusting for the other local cell-line features.'),
    hyp('h2', 'Cell lines with feature_022 == 1 have more negative dependency_EGFR scores than cell lines with feature_022 == 0, after adjusting for the other local cell-line features.'),
    hyp('h3', 'Cell lines with feature_024 == 1 have more negative dependency_ERBB2 scores than cell lines with feature_024 == 0, after adjusting for the other local cell-line features.'),
    hyp('h4', 'Cell lines with feature_014 == 1 have more negative dependency_KRAS scores than cell lines with feature_014 == 0, after adjusting for the other local cell-line features.'),
    hyp('h5', 'Cell lines with feature_027 == 1 have more negative dependency_RIT1 scores than cell lines with feature_027 == 0, after adjusting for the other local cell-line features.'),
]
iter1_a = [
    ols_summary('dependency_BRAF', 'feature_009', 'h1'),
    ols_summary('dependency_EGFR', 'feature_022', 'h2'),
    ols_summary('dependency_ERBB2', 'feature_024', 'h3'),
    ols_summary('dependency_KRAS', 'feature_014', 'h4'),
    ols_summary('dependency_RIT1', 'feature_027', 'h5'),
]

# Iteration 2: broader continuous/common-dependency signals.
iter2_h = [
    hyp('h6', 'Cell lines with feature_011 == colorectal have more negative dependency_KIF18A scores than non-colorectal lines, after adjusting for the other local cell-line features.', 'refined'),
    hyp('h7', 'Higher feature_016 is associated with more negative dependency_POLR2A scores, with a negative effect per one-standard-deviation increase after adjustment for other local features.', 'novel'),
    hyp('h8', 'Higher feature_003 is associated with more negative dependency_RPL11 scores, with a negative effect per one-standard-deviation increase after adjustment for other local features.', 'novel'),
    hyp('h9', 'Higher feature_023 is associated with more negative dependency_DHX9 scores, with a negative effect per one-standard-deviation increase after adjustment for other local features.', 'novel'),
    hyp('h10', 'Higher feature_016 is associated with more negative dependency_TMED10 scores, with a negative effect per one-standard-deviation increase after adjustment for other local features.', 'novel'),
]
iter2_a = [
    ols_summary('dependency_KIF18A', 'feature_011_colorectal', 'h6'),
    ols_summary('dependency_POLR2A', 'feature_016', 'h7'),
    ols_summary('dependency_RPL11', 'feature_003', 'h8'),
    ols_summary('dependency_DHX9', 'feature_023', 'h9'),
    ols_summary('dependency_TMED10', 'feature_016', 'h10'),
]

# Iteration 3: targeted effect-modification checks.
iter3_h = [
    hyp('h11', 'The negative dependency_BRAF effect of feature_009 == 1 is stronger in feature_011 == skin cell lines than in non-skin cell lines, so the feature_009-by-skin interaction is negative.', 'refined'),
    hyp('h12', f'The negative dependency_EGFR effect of feature_022 == 1 is stronger when feature_023 >= {q[(\"feature_023\", .75)]:.3f} than when feature_023 is lower, so the feature_022-by-high-feature_023 interaction is negative.', 'refined'),
    hyp('h13', 'The negative dependency_ERBB2 effect of feature_024 == 1 is stronger in feature_010 == her2_enriched cell lines than in other feature_010 subgroups, so the feature_024-by-her2_enriched interaction is negative.', 'refined'),
    hyp('h14', 'The negative dependency_KRAS effect of feature_014 == 1 is stronger in feature_011 == pancreatic cell lines than in non-pancreatic lines, so the feature_014-by-pancreatic interaction is negative.', 'refined'),
    hyp('h15', 'The negative dependency_RIT1 effect of feature_027 == 1 is stronger in feature_011 == brain cell lines than in non-brain lines, so the feature_027-by-brain interaction is negative.', 'refined'),
]
iter3_a = [
    interaction_analysis('h11', 'dependency_BRAF', df['feature_009'].eq(1), df['feature_011'].eq('skin'), 'feature_009 == 1', 'feature_011 == skin'),
    interaction_analysis('h12', 'dependency_EGFR', df['feature_022'].eq(1), df['feature_023'].ge(q[('feature_023', .75)]), 'feature_022 == 1', f'feature_023 >= {q[(\"feature_023\", .75)]:.3f}'),
    interaction_analysis('h13', 'dependency_ERBB2', df['feature_024'].eq(1), df['feature_010'].eq('her2_enriched'), 'feature_024 == 1', 'feature_010 == her2_enriched'),
    interaction_analysis('h14', 'dependency_KRAS', df['feature_014'].eq(1), df['feature_011'].eq('pancreatic'), 'feature_014 == 1', 'feature_011 == pancreatic'),
    interaction_analysis('h15', 'dependency_RIT1', df['feature_027'].eq(1), df['feature_011'].eq('brain'), 'feature_027 == 1', 'feature_011 == brain'),
]

# Iteration 4: KIF18A complete subgroup and suppressor.
col = df['feature_011'].eq('colorectal')
f35 = df['feature_035'].eq(1)
f20_0 = df['feature_020'].eq(0)
f20_1 = df['feature_020'].eq(1)
f28_hi90 = df['feature_028'].ge(q[('feature_028', .90)])
iter4_h = [
    hyp('h16', 'Cell lines with feature_011 == colorectal, feature_035 == 1, and feature_020 == 0 have markedly more negative dependency_KIF18A scores than all other cell lines.', 'refined'),
    hyp('h17', 'Within feature_011 == colorectal and feature_035 == 1 cell lines, feature_020 == 1 suppresses KIF18A dependency, giving less negative dependency_KIF18A scores than feature_020 == 0.', 'refined'),
    hyp('h18', f'Within the colorectal feature_035 KIF18A subgroup, feature_028 >= {q[(\"feature_028\", .90)]:.3f} further increases dependency_KIF18A, giving a negative colorectal-by-feature_035-by-high-feature_028 interaction.', 'refined'),
    hyp('h19', f'Cell lines satisfying feature_011 == colorectal, feature_035 == 1, feature_020 == 0, and feature_028 >= {q[(\"feature_028\", .90)]:.3f} have the most negative dependency_KIF18A scores relative to all other cell lines.', 'refined'),
]
# h17 is a within-subgroup contrast, not vs complement.
r17 = welch_two('dependency_KIF18A', col & f35 & f20_1, col & f35 & f20_0)
# Three-way interaction C:F35:H90 in a model with lower-order terms and feature_020.
C = col.astype(float).to_numpy()
F35 = f35.astype(float).to_numpy()
F20 = df['feature_020'].astype(float).to_numpy()
H90 = f28_hi90.astype(float).to_numpy()
X_kif = sm.add_constant(np.column_stack([C, F35, F20, H90, C * F35, C * F20, C * H90, F35 * H90, C * F35 * H90]))
fit_kif = sm.OLS(df['dependency_KIF18A'], X_kif).fit()
coef_3way = fnum(fit_kif.params[9])
p_3way = fnum(fit_kif.pvalues[9])
iter4_a = [
    subgroup_analysis('h16', 'dependency_KIF18A', col & f35 & f20_0, 'feature_011 == colorectal AND feature_035 == 1 AND feature_020 == 0'),
    analysis(
