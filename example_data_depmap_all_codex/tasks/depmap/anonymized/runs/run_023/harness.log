/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
import statsmodels.api as sm
from scipy import stats

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
# classify
cat=[c for c in features if df[c].dtype=='object' or c=='feature_001']
bin_cols=[c for c in features if pd.api.types.is_integer_dtype(df[c]) and df[c].nunique()==2]
cont=[c for c in features if c not in cat+bin_cols]
print('cat', cat)
print('binary', bin_cols)
print('cont', cont)
X_parts=[]
# continuous z
X_cont=(df[cont]-df[cont].mean())/df[cont].std(ddof=0)
X_parts.append(X_cont)
X_parts.append(df[bin_cols].astype(float))
Xd=pd.get_dummies(df[cat].astype(str), prefix=cat, drop_first=True, dtype=float)
X_parts.append(Xd)
X=pd.concat(X_parts,axis=1)
X=sm.add_constant(X)
print('design', X.shape)
for ycol in outcomes:
    y=df[ycol]
    model=sm.OLS(y,X).fit()
    params=model.params.drop('const')
    pvals=model.pvalues.drop('const')
    top=pd.DataFrame({'coef':params,'p':pvals,'t':model.tvalues.drop('const')}).assign(abscoef=lambda x:x.coef.abs()).sort_values('abscoef',ascending=False).head(12)
    print('\\nOUTCOME', ycol, 'R2', round(model.rsquared,3))
    print(top[['coef','p','t']].to_string())
