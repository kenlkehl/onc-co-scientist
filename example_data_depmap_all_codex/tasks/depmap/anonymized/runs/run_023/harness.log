/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
import statsmodels.api as sm
from scipy import stats

df=pd.read_parquet('dataset.parquet')

def interaction(ycol, driver_expr, mod_expr):
    y=df[ycol].to_numpy()
    G=driver_expr.astype(float).to_numpy() if hasattr(driver_expr,'to_numpy') else driver_expr.astype(float)
    H=mod_expr.astype(float).to_numpy() if hasattr(mod_expr,'to_numpy') else mod_expr.astype(float)
    X=sm.add_constant(np.column_stack([G,H,G*H]))
    fit=sm.OLS(y,X).fit()
    g=G.astype(bool); h=H.astype(bool)
    cells=[int((g&h).sum()),int(((~g)&h).sum()),int((g&(~h)).sum()),int(((~g)&(~h)).sum())]
    e_h=float(y[g&h].mean()-y[(~g)&h].mean())
    e_not=float(y[g&(~h)].mean()-y[(~g)&(~h)].mean())
    means={
        'g1h1':float(y[g&h].mean()),'g0h1':float(y[(~g)&h].mean()),
        'g1h0':float(y[g&(~h)].mean()),'g0h0':float(y[(~g)&(~h)].mean())}
    return {'coef':float(fit.params[3]),'p':float(fit.pvalues[3]),'e_h':e_h,'e_not':e_not,'cells':cells,'means':means}

checks=[
('BRAF f009 x skin','dependency_BRAF',df.feature_009==1,df.feature_011=='skin'),
('BRAF f009 x high feature033 q90','dependency_BRAF',df.feature_009==1,df.feature_033>=df.feature_033.quantile(.9)),
('EGFR f022 x feature023 high75','dependency_EGFR',df.feature_022==1,df.feature_023>=df.feature_023.quantile(.75)),
('EGFR f022 x lung','dependency_EGFR',df.feature_022==1,df.feature_011=='lung'),
('ERBB2 f024 x breast','dependency_ERBB2',df.feature_024==1,df.feature_011=='breast'),
('ERBB2 f024 x her2_enriched','dependency_ERBB2',df.feature_024==1,df.feature_010=='her2_enriched'),
('KRAS f014 x pancreatic','dependency_KRAS',df.feature_014==1,df.feature_011=='pancreatic'),
('KRAS f014 x colorectal','dependency_KRAS',df.feature_014==1,df.feature_011=='colorectal'),
('KRAS f014 x feature033 high90','dependency_KRAS',df.feature_014==1,df.feature_033>=df.feature_033.quantile(.9)),
('RIT1 f027 x brain','dependency_RIT1',df.feature_027==1,df.feature_011=='brain'),
('RIT1 f027 x feature023 low25','dependency_RIT1',df.feature_027==1,df.feature_023<=df.feature_023.quantile(.25)),
]
for name,y,g,h in checks:
    r=interaction(y,g,h)
    print('\\n',name)
    print(r)

# group table counts driver by lineage and mean y for driver-positive
for ycol,driver in [('dependency_BRAF','feature_009'),('dependency_EGFR','feature_022'),('dependency_ERBB2','feature_024'),('dependency_KRAS','feature_014'),('dependency_RIT1','feature_027')]:
    print('\\nLINEAGE DRIVER TABLE', ycol, driver)
    tab=[]
    for lin,sub in df.groupby('feature_011'):
        n=len(sub); d=sub[driver].eq(1)
        if d.sum()>0 and (~d).sum()>0:
            eff=sub.loc[d,ycol].mean()-sub.loc[~d,ycol].mean()
            p=stats.ttest_ind(sub.loc[d,ycol],sub.loc[~d,ycol],equal_var=False).pvalue
            tab.append((lin,n,int(d.sum()),float(sub.loc[d,ycol].mean()),float(sub.loc[~d,ycol].mean()),float(eff),float(p)))
    tab=sorted(tab,key=lambda x:x[5])
    for row in tab:
        print(row)
