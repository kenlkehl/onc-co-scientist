def num(x):
    x=float(x)
    if math.isnan(x): return None
    if math.isinf(x): return 0.0 if x<0 else 1e308
    return x

def pt(x):
    x=num(x)
    if x is None: return 'NA'
    if x==0.0: return '<1e-300'
    if x<1e-4: return f'{x:.2e}'
    return f'{x:.4f}'

def hyp(i,t,k='novel'): return {'id':i,'text':t,'kind':k}
def rec(hids,summary,effect,pval=None,code=None,significant=None,**extra):
    if significant is None and pval is not None: significant=bool(num(pval)<0.05)
    r={'hypothesis_ids':hids,'code':code,'result_summary':summary,'p_value':num(pval) if pval is not None else None,'effect_estimate':num(effect) if effect is not None else None,'significant':significant}
