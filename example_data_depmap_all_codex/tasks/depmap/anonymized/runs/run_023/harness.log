/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
import statsmodels.api as sm

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat=[c for c in features if df[c].dtype=='object' or c=='feature_001']
bin_cols=[c for c in features if pd.api.types.is_integer_dtype(df[c]) and df[c].nunique()==2]
cont=[c for c in features if c not in cat+bin_cols]

preds=[]
# categorical levels
for c in cat:
    for val in sorted(df[c].astype(str).unique()):
        m=(df[c].astype(str)==val).to_numpy()
        n=m.sum()
        if 200 <= n <= len(df)-200:
            preds.append({'name':f'{c} == {val}', 'feature':c, 'mask':m, 'n':int(n)})
# binary 1 and maybe 0 for modifiers/search
for c in bin_cols:
    for val in [1,0]:
        m=(df[c].to_numpy()==val)
        n=m.sum()
        if 200 <= n <= len(df)-200:
            preds.append({'name':f'{c} == {val}', 'feature':c, 'mask':m, 'n':int(n)})
# continuous quartile/tenth thresholds
for c in cont:
    vals=df[c]
    qs=[(0.10,'low10','<='),(0.25,'low25','<='),(0.75,'high25','>='),(0.90,'high10','>=')]
    for q,label,op in qs:
        thr=vals.quantile(q)
        if op=='<=': m=(vals<=thr).to_numpy(); name=f'{c} <= q{int(q*100)} ({thr:.3g})'
        else: m=(vals>=thr).to_numpy(); name=f'{c} >= q{int(q*100)} ({thr:.3g})'
        n=m.sum()
        if 200 <= n <= len(df)-200:
            preds.append({'name':name, 'feature':c, 'mask':m, 'n':int(n)})
print('num predicates', len(preds))

def welch(y,m):
    a=y[m]; b=y[~m]
    eff=float(a.mean()-b.mean())
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return eff,float(p),int(m.sum()),float(a.mean()),float(b.mean())

single_results={}
for ycol in outcomes:
    y=df[ycol].to_numpy()
    rows=[]
    for pr in preds:
        eff,p,n,mg,mc=welch(y,pr['mask'])
        rows.append({**{k:pr[k] for k in ['name','feature','n']}, 'effect':eff,'p':p,'mean_group':mg,'mean_comp':mc})
    res=pd.DataFrame(rows).sort_values('effect')
    single_results[ycol]=res
    print('\\nSINGLE', ycol)
    print(res.head(10)[['name','n','mean_group','mean_comp','effect','p']].to_string(index=False))

# pairwise negative subgroup search: only use positive-ish primitive forms to reduce complement redundancy? use all but skip same feature
for ycol in outcomes:
    y=df[ycol].to_numpy()
    rows=[]
    P=preds
    for i in range(len(P)):
        mi=P[i]['mask']
        for j in range(i+1,len(P)):
            if P[i]['feature']==P[j]['feature']:
                continue
            m=mi & P[j]['mask']
            n=int(m.sum())
            if n<300 or n>len(df)-300:
                continue
            eff,p,_,mg,mc=welch(y,m)
            if eff<0: # dependency-enriched only
                rows.append({'rule':P[i]['name']+' AND '+P[j]['name'],'features':(P[i]['feature'],P[j]['feature']),'n':n,'mean_group':mg,'mean_comp':mc,'effect':eff,'p':p})
    prdf=pd.DataFrame(rows).sort_values('effect').head(12)
    print('\\nPAIR', ycol)
    print(prdf[['rule','n','mean_group','mean_comp','effect','p']].to_string(index=False))

# interaction modifiers for most negative single driver, requiring driver not a complement common? just use top single
for ycol in outcomes:
    y=df[ycol].to_numpy()
    top=single_results[ycol].iloc[0]
    gmask=next(pr['mask'] for pr in preds if pr['name']==top['name'])
    rows=[]
    for pr in preds:
        if pr['feature']==top['feature']: continue
        h=pr['mask']
        # ensure 2x2 cells
        cells=[(gmask & h).sum(), ((~gmask)&h).sum(), (gmask&(~h)).sum(), ((~gmask)&(~h)).sum()]
        if min(cells)<200: continue
        G=gmask.astype(float); H=h.astype(float); GH=G*H
        X=sm.add_constant(np.column_stack([G,H,GH]))
        fit=sm.OLS(y,X).fit()
        # driver effect within h vs not h
        e_h=float(y[gmask & h].mean()-y[(~gmask)&h].mean())
        e_not=float(y[gmask & (~h)].mean()-y[(~gmask)&(~h)].mean())
        rows.append({'modifier':pr['name'], 'n_g_h':int(cells[0]), 'driver_effect_in_modifier':e_h,'driver_effect_outside':e_not,'interaction':float(fit.params[3]),'p_interaction':float(fit.pvalues[3])})
    idf=pd.DataFrame(rows).sort_values('interaction').head(8)
    print('\\nINTERACTION_MODIFIERS for', ycol, 'driver', top['name'], 'top_effect', top['effect'])
    print(idf.to_string(index=False))
