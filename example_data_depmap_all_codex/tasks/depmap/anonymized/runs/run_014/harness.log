import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print('shape', df.shape)
print('columns', list(df.columns))
features=[c for c in df.columns if c.startswith('feature_')]
deps=[c for c in df.columns if c.startswith('dependency_')]
print('n_features', len(features), 'deps', deps)
print('dtypes')
print(df.dtypes.to_string())
print('\\nfeature summary')
for c in features:
    s=df[c]
    nun=s.nunique()
    vals=s.value_counts(dropna=False).head(8).to_dict() if nun<=10 else {}
    print(c, 'dtype', s.dtype, 'nunique', nun, 'mean', float(s.mean()) if np.issubdtype(s.dtype, np.number) else None, 'std', float(s.std()) if np.issubdtype(s.dtype, np.number) else None, 'vals', vals)
print('\\ndep summary')
print(df[deps].describe().T.to_string())
print('\\ncorrelations top abs feature dep pearson')
for dep in deps:
    cors=[]
    y=df[dep].to_numpy()
    for f in features:
        x=df[f].to_numpy()
        corr=np.corrcoef(x,y)[0,1]
        cors.append((abs(corr), corr, f))
    cors=sorted(cors, reverse=True)[:10]
    print(dep, [(f, round(corr,4)) for _,corr,f in cors])
