"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command '$env:UV_CACHE_DIR = (Resolve-Path .'"\\.uv-cache).Path; "'$env:UV_PYTHON_INSTALL_DIR = (Resolve-Path .'"\\.uv-python).Path; @'
import pandas as pd
import numpy as np
from scipy import stats

df = pd.read_parquet('dataset.parquet')
features = [c for c in df.columns if c.startswith('feature_')]
outcomes = [c for c in df.columns if c.startswith('dependency_')]
print('shape', df.shape)
print('features', len(features), 'outcomes', len(outcomes))
print('dtypes')
print(df.dtypes.to_string())
print('\\nfeature summaries')
for c in features:
    s=df[c]
    vals=s.unique()
    vals_sorted=np.sort(vals)[:10]
    print(c, 'dtype', s.dtype, 'nunique', s.nunique(), 'mean', float(s.mean()), 'sd', float(s.std()), 'min', float(s.min()), 'max', float(s.max()), 'firstvals', vals_sorted)
print('\\noutcome summaries')
for y in outcomes:
    s=df[y]
    print(y, 'mean', float(s.mean()), 'sd', float(s.std()), 'min', float(s.min()), 'q01', float(s.quantile(.01)), 'q05', float(s.quantile(.05)), 'median', float(s.median()), 'q95', float(s.quantile(.95)), 'max', float(s.max()))

# univariate binary feature mean differences for every outcome
rows=[]
for y in outcomes:
    for f in features:
        vals=set(df[f].dropna().unique().tolist())
        if vals.issubset({0,1,False,True}):
            g1=df.loc[df[f].astype(bool), y]
            g0=df.loc[~df[f].astype(bool), y]
            eff=float(g1.mean()-g0.mean())
            t,p=stats.ttest_ind(g1,g0,equal_var=False)
            rows.append((y,f,eff,float(p),len(g1),float(g1.mean()),float(g0.mean())))
        else:
            r,p=stats.pearsonr(df[f], df[y])
            rows.append((y,f,float(r),float(p),None,None,None))
rows_sorted=sorted(rows,key=lambda x:x[3])
print('\\ntop 80 univariate by p')
for r in rows_sorted[:80]:
    print(r)
