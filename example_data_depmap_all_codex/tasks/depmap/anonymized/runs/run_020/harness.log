import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
q028=df.feature_028.quantile(.75); q016=df.feature_016.quantile(.75)
# interaction full factorial function for binary list, coefficient for product term
def full_interaction(y, vars):
    y=np.asarray(y,float); X=[np.ones(len(y))]; names=['Intercept']
    k=len(vars)
    # include all nonempty subsets
    import itertools
    for r in range(1,k+1):
        for idx in itertools.combinations(range(k),r):
            col=np.ones(len(y),dtype=float)
            nm=[]
            for i in idx:
                col*=vars[i][1].astype(float); nm.append(vars[i][0])
            X.append(col); names.append(':'.join(nm))
    X=np.column_stack(X)
    beta=np.linalg.lstsq(X,y,rcond=None)[0]
    resid=y-X@beta; dof=len(y)-X.shape[1]
    inv=np.linalg.pinv(X.T@X); s2=(resid@resid)/dof
    ses=np.sqrt(np.diag(inv)*s2)
    t=beta[-1]/ses[-1]
    p=2*stats.t.sf(abs(t),dof)
    return names[-1], beta[-1], ses[-1], t, p
# KIF18A four-way: c, f35, f020_zero, f028_high
vars=[('colorectal',df.feature_011.eq('colorectal').to_numpy()),('feature_035_1',df.feature_035.eq(1).to_numpy()),('feature_020_0',df.feature_020.eq(0).to_numpy()),('feature_028_Q75',df.feature_028.ge(q028).to_numpy())]
print('KIF18A 4way', full_interaction(df.dependency_KIF18A, vars))
# Maybe model independent final main effects across all dependencies not needed.
# Joint model for RPL11: feature_018 and feature_031 high interaction controlling feature_003 high and feature_016 high
# Use OLS X intercept f018 f031high f003high f016high f18*f31high
for ycol, vars2, interdesc in [
 ('dependency_RPL11',[('f18',df.feature_018.eq(1).to_numpy()),('f31Q75',df.feature_031.ge(df.feature_031.quantile(.75)).to_numpy()),('f003Q75',df.feature_003.ge(df.feature_003.quantile(.75)).to_numpy()),('f016Q75',df.feature_016.ge(q016).to_numpy())],'f18:f31Q75')
]:
    y=df[ycol].to_numpy(float)
    a=vars2[0][1].astype(float); b=vars2[1][1].astype(float)
    X=[np.ones(len(y)),a,b]
    names=['Intercept','f18','f31Q75']
    for nm,v in vars2[2:]: X.append(v.astype(float)); names.append(nm)
    X.append(a*b); names.append(interdesc)
    X=np.column_stack(X)
    beta=np.linalg.lstsq(X,y,rcond=None)[0]; resid=y-X@beta; dof=len(y)-X.shape[1]
    inv=np.linalg.pinv(X.T@X); s2=(resid@resid)/dof; se=np.sqrt(np.diag(inv)*s2); t=beta[-1]/se[-1]; p=2*stats.t.sf(abs(t),dof)
    print(ycol,names[-1],beta[-1],se[-1],t,p)
