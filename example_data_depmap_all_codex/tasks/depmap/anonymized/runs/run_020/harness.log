import pandas as pd, numpy as np
from scipy import stats

df = pd.read_parquet('dataset.parquet')
y='dependency_KIF18A'
df=df.assign(colorectal=(df.feature_011=='colorectal').astype(int), f028_high=(df.feature_028>=df.feature_028.quantile(.75)).astype(int), f028_medhi=(df.feature_028>=df.feature_028.median()).astype(int))
cols=['colorectal','feature_035','feature_020','f028_high']
