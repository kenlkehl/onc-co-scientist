The dataset has 50,000 rows, 36 anonymized features, and 10 dependency outcomes. Several features are categorical or binary while the rest are continuous, so I’m going to screen both main effects and interaction/subgroup effects rather than treating everything as a single continuous design.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd
import numpy as np
from scipy import stats

df = pd.read_parquet('dataset.parquet')
features = [c for c in df.columns if c.startswith('feature_')]
deps = [c for c in df.columns if c.startswith('dependency_')]
print('Categorical/object levels:')
for c in features:
    if df[c].dtype == 'object' or df[c].nunique() <= 10:
        vc = df[c].value_counts().sort_index()
        print(c, df[c].dtype, 'nunique', df[c].nunique())
        print(vc.to_string())
print('\\nContinuous summaries:')
cont = [c for c in features if df[c].dtype "'!= '"'object' and df[c].nunique() > 10]
print(df[cont].describe().T[['mean','std','min','25%','50%','75%','max']].to_string())

# univariate screen for binary/continuous/categorical levels
records=[]
for y in deps:
    yv = df[y].to_numpy()
    for x in features:
        s=df[x]
        if s.dtype == 'object' or s.nunique() <= 10:
            # category levels vs others if at least 100
            for val, n in s.value_counts().items():
                if n < 100 or n > len(s)-100: continue
                mask = (s==val).to_numpy()
                eff = yv[mask].mean()-yv[~mask].mean()
                t,p=stats.ttest_ind(yv[mask], yv[~mask], equal_var=False)
                records.append((y,x,str(val),n,eff,p,'cat_level'))
        else:
            xv = s.to_numpy().astype(float)
            r,p = stats.pearsonr(xv,yv)
            eff = r*yv.std(ddof=1) # one SD x? no this is per SD x effect? if x standardized, beta=r*sd_y. yes.
            records.append((y,x,'per_SD',len(s),eff,p,'continuous'))
res=pd.DataFrame(records, columns='dep feature level n effect p kind'.split())
print('\\nTop 80 univariate by absolute effect with p<1e-10:')
print(res[res.p<1e-10].assign(abs_eff=lambda d:d.effect.abs()).sort_values('abs_eff', ascending=False).head(80).to_string(index=False))
print('\\nBest per dependency:')
for y in deps:
    sub=res[res.dep==y].assign(abs_eff=lambda d:d.effect.abs()).sort_values('abs_eff', ascending=False).head(12)
    print('\\n',y)
    print(sub.to_string(index=False))
