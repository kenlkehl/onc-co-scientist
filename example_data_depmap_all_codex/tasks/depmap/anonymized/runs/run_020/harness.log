/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from math import isfinite

df = pd.read_parquet('dataset.parquet')
deps=[c for c in df.columns if c.startswith('dependency_')]
features=[c for c in df.columns if c.startswith('feature_')]
# Build predicates
preds=[]
seen=set()
def add(name, mask, desc):
    if name in seen: return
    mask=np.asarray(mask, dtype=bool)
    n=int(mask.sum())
    if n>=100 and n<=len(mask)-100:
        preds.append({'name':name,'mask':mask,'n':n,'desc':desc})
        seen.add(name)
for c in features:
    s=df[c]
    if s.dtype=='object' or s.nunique()<=10:
        for val,n in s.value_counts().items():
            add(f'{c}={val}', s.eq(val).to_numpy(), f'"'`{c}` == {val!r}'"')
    elif s.nunique()==2:
        vals=sorted(s.unique())
        for val in vals:
            add(f'{c}={val}', s.eq(val).to_numpy(), f'"'`{c}` == {val!r}'"')
    else:
        q25=float(s.quantile(.25)); q75=float(s.quantile(.75))
        add(f'{c}>=Q75({q75:.3g})', s.ge(q75).to_numpy(), f'"'`{c}` >= 75th percentile ({q75:.3g})'"')
        add(f'{c}<=Q25({q25:.3g})', s.le(q25).to_numpy(), f'"'`{c}` <= 25th percentile ({q25:.3g})'"')
print('n predicates',len(preds))
# helper for OLS interaction p
def interaction_coef_p(y, a, b):
    # X = intercept, a, b, a*b
    a=a.astype(float); b=b.astype(float); ab=a*b
    X=np.column_stack([np.ones(len(y)), a, b, ab])
    # skip singular
    try:
        XtX=X.T@X
        inv=np.linalg.inv(XtX)
    except np.linalg.LinAlgError:
        return np.nan,np.nan
    beta=inv@(X.T@y)
    resid=y-X@beta
    dof=len(y)-4
    s2=float((resid@resid)/dof)
    se=float((s2*inv[3,3])**0.5)
    if se==0: return beta[3], np.nan
    t=float(beta[3]/se)
    p=2*stats.t.sf(abs(t), dof)
    return float(beta[3]), float(p)

def welch(y, mask):
    m=mask.astype(bool)
    y1=y[m]; y0=y[~m]
    eff=float(y1.mean()-y0.mean())
    t,p=stats.ttest_ind(y1,y0,equal_var=False)
    return eff,float(p),int(m.sum()),float(y1.mean()),float(y0.mean())

all_results={}
for dep in deps:
    y=df[dep].to_numpy(float)
    singles=[]
    for p in preds:
        eff,pv,n,m1,m0=welch(y,p['mask'])
        singles.append({**p,'effect':eff,'p':pv,'mean_in':m1,'mean_out':m0})
    singles_sorted=sorted(singles,key=lambda r:r['effect']) # most negative
    top_single=singles_sorted[0]
    # pair conjunctions systematic
    pairs=[]
    P=len(preds)
    for i in range(P):
        mi=preds[i]['mask']
        for j in range(i+1,P):
            # avoid direct complements? allow but if same feature conflicting skip by checking no n
            m = mi & preds[j]['mask']
            n=int(m.sum())
            if n<500 or n>len(y)-500: continue
            eff,pv,n2,m1,m0=welch(y,m)
            if eff<0:
                pairs.append({'a':preds[i]['name'],'b':preds[j]['name'],'adesc':preds[i]['desc'],'bdesc':preds[j]['desc'],'n':n,'effect':eff,'p':pv,'mean_in':m1,'mean_out':m0})
    pairs_sorted=sorted(pairs,key=lambda r:r['effect'])[:10]
    # interaction with top negative single as driver, all other preds
    d=top_single['mask']
    inter=[]
    for q in preds:
        if q['name']==top_single['name']: continue
        # skip if almost nested/singular by rank function; interaction_coef_p handles singular
        coef,pv=interaction_coef_p(y,d,q['mask'])
        if isfinite(coef) and isfinite(pv):
            inter.append({'driver':top_single['name'],'modifier':q['name'],'moddesc':q['desc'],'coef':coef,'p':pv,'n_both':int((d & q['mask']).sum()),'n_driver':int(d.sum()),'n_mod':q['n']})
    inter_sorted=sorted(inter,key=lambda r:r['coef'])[:8]  # negative means modifier makes driver more negative than additive
    all_results[dep]={'top_single':top_single,'pairs':pairs_sorted,'interactions':inter_sorted}

for dep,r in all_results.items():
    ts=r['top_single']
    print('\\n===',dep,'===')
    print('top single:',ts['name'],'n',ts['n'],'mean_in',round(ts['mean_in'],4),'mean_out',round(ts['mean_out'],4),'effect',round(ts['effect'],4),'p',ts['p'])
    print('top pairs:')
    for z in r['pairs'][:6]:
        print(' ',z['a'],'AND',z['b'],'n',z['n'],'mean_in',round(z['mean_in'],4),'mean_out',round(z['mean_out'],4),'eff',round(z['effect'],4),'p',z['p'])
    print('top interactions with driver',ts['name'])
    for z in r['interactions'][:6]:
        print(' ',z['modifier'],'coef',round(z['coef'],4),'p',z['p'],'n_both',z['n_both'])
