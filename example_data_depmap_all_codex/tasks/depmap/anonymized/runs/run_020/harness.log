/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
N=len(df)
# Derived predicates
q={c: df[c].quantile(v) for c in [] for v in []}
q016=df.feature_016.quantile(.75); q023=df.feature_023.quantile(.75); q028=df.feature_028.quantile(.75); q031=df.feature_031.quantile(.75); q003=df.feature_003.quantile(.75)
print('Q75 feature_016',q016,'feature_023',q023,'feature_028',q028,'feature_031',q031,'feature_003',q003)

def test_mask(ycol, mask):
    y=df[ycol].to_numpy(float); m=np.asarray(mask,bool)
    y1=y[m]; y0=y[~m]
    t,p=stats.ttest_ind(y1,y0,equal_var=False)
    return {'n1':int(m.sum()),'n0':int((~m).sum()),'mean1':float(y1.mean()),'mean0':float(y0.mean()),'effect':float(y1.mean()-y0.mean()),'p':float(p)}

def pearson_sd(ycol, xcol):
    x=df[xcol].to_numpy(float); y=df[ycol].to_numpy(float)
    r,p=stats.pearsonr(x,y)
    eff=float(r*y.std(ddof=1))
    return {'r':float(r),'effect_per_sd_x':eff,'p':float(p)}

def interaction(ycol, a, b):
    y=df[ycol].to_numpy(float); a=np.asarray(a,bool); b=np.asarray(b,bool)
    X=np.column_stack([np.ones(len(y)), a.astype(float), b.astype(float), (a&b).astype(float)])
    beta=np.linalg.lstsq(X,y,rcond=None)[0]
    resid=y-X@beta; dof=len(y)-X.shape[1]
    inv=np.linalg.pinv(X.T@X)
    s2=(resid@resid)/dof
    se=(s2*inv[3,3])**0.5
    t=beta[3]/se
    p=2*stats.t.sf(abs(t),dof)
    # cell means
    cells={}
    for ai in [0,1]:
      for bi in [0,1]:
        m=(a==bool(ai))&(b==bool(bi))
        cells[(ai,bi)]=(int(m.sum()),float(y[m].mean())) if m.sum()>0 else (0,float('nan'))
    return {'coef':float(beta[3]),'p':float(p),'cells':cells}

# Main masks
masks={
 'BRAF_feature_009_1': df.feature_009.eq(1),
 'EGFR_feature_022_1': df.feature_022.eq(1),
 'ERBB2_feature_024_1': df.feature_024.eq(1),
 'KRAS_feature_014_1': df.feature_014.eq(1),
 'RIT1_feature_027_1': df.feature_027.eq(1),
 'POLR2A_feature_016_Q75': df.feature_016.ge(q016),
 'TMED10_feature_016_Q75': df.feature_016.ge(q016),
 'DHX9_feature_016_Q75': df.feature_016.ge(q016),
 'RPL11_feature_018_1': df.feature_018.eq(1),
 'RPL11_feature_003_Q75': df.feature_003.ge(q003),
 'KIF18A_colorectal': df.feature_011.eq('colorectal'),
 'KIF18A_feature_035_1': df.feature_035.eq(1),
}
for label,mask in masks.items():
    dep='dependency_'+label.split('_')[0]
    if label.startswith('POLR2A'): dep='dependency_POLR2A'
