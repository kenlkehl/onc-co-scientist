The main-effect scan found strong expected anchors: specific binary features align with BRAF, EGFR, ERBB2, KRAS, and RIT1 dependency, while KIF18A has a much stronger colorectal/feature_035/feature_028 pattern. I’m now doing an all-outcome two-predicate interaction screen to find subgroup-specific dependency shifts instead of stopping at marginal effects.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outs=[c for c in df.columns if c.startswith('dependency_')]
cat=[c for c in features if df[c].dtype=='object']+['feature_001']
binary=[c for c in features if df[c].nunique()==2 and c not in cat]
cont=[c for c in features if c not in cat and c not in binary]
# binary predicate matrix
preds=[]
for c in cat:
    for lvl in sorted(df[c].unique(), key=lambda x: str(x)):
        m=(df[c]==lvl).to_numpy(dtype=bool)
        if 200 <= m.sum() <= len(df)-200:
            preds.append((f'{c}=={lvl}', c, str(lvl), m))
for c in binary:
    m=(df[c]==1).to_numpy(dtype=bool)
    if 200 <= m.sum() <= len(df)-200:
        preds.append((f'{c}==1', c, '1', m))
for c in cont:
    lo=df[c].quantile(.25); hi=df[c].quantile(.75)
    for label, m in [(f'{c}<=Q1({lo:.3g})', (df[c]<=lo).to_numpy(dtype=bool)), (f'{c}>=Q3({hi:.3g})',(df[c]>=hi).to_numpy(dtype=bool))]:
        if 200 <= m.sum() <= len(df)-200:
            preds.append((label, c, label.split('==')[-1], m))
print('num predicates', len(preds))
N=len(df)
rows=[]
for y in outs:
    yy=df[y].to_numpy()
    for i in range(len(preds)):
        nameA, featA, levA, A=preds[i]
        for j in range(i+1,len(preds)):
            nameB, featB, levB, B=preds[j]
            # skip mutually-exclusive levels of same categorical/feature to avoid n11=0 or tautologies same continuous high/low
            n11=int((A&B).sum()); n10=int((A&~B).sum()); n01=int((~A&B).sum()); n00=N-n11-n10-n01
            if min(n11,n10,n01,n00) < 100: continue
            m11=yy[A&B].mean(); m10=yy[A&~B].mean(); m01=yy[~A&B].mean(); m00=yy[~A&~B].mean()
            inter=m11-m10-m01+m00
            # residual SSE within 4 groups
            sse=((yy[A&B]-m11)**2).sum()+((yy[A&~B]-m10)**2).sum()+((yy[~A&B]-m01)**2).sum()+((yy[~A&~B]-m00)**2).sum()
            dfree=N-4
            mse=sse/dfree
            se=(mse*(1/n11+1/n10+1/n01+1/n00))**0.5
            t=inter/se if se>0 else np.nan
            p=2*stats.t.sf(abs(t), dfree) if np.isfinite(t) else np.nan
            # subgroup extra dependency: m11 vs others
            other=yy[~(A&B)].mean()
            subeff=m11-other
            rows.append((y,nameA,nameB,n11,n10,n01,n00,inter,p,m11,m10,m01,m00,subeff))
res=pd.DataFrame(rows, columns=['outcome','A','B','n11','n10','n01','n00','interaction','p','mean11','mean10','mean01','mean00','subgroup_effect'])
# show top interaction by p and negative interaction with sizable effect
for y in outs:
    sub=res[res.outcome==y].copy()
    sub['abs_inter']=sub.interaction.abs()
    # exclude interactions between redundant feature_011 hematopoietic and feature_004 suspension? leave for discovery
    print('\\n====', y, 'top p interactions')
    print(sub.sort_values('p').head(12).to_string(index=False, float_format=lambda v: f'{v:.4g}'))
    print('---- strongest negative interactions p<1e-6, n11>=300')
    tmp=sub[(sub.p<1e-6)&(sub.n11>=300)].sort_values('interaction').head(12)
    if len(tmp)==0: tmp=sub.sort_values('interaction').head(8)
    print(tmp.to_string(index=False, float_format=lambda v: f'{v:.4g}'))
