/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from pathlib import Path
from math import isfinite

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outs=[c for c in df.columns if c.startswith('dependency_')]
cat=[c for c in features if df[c].dtype=='object']+['feature_001']
binary=[c for c in features if df[c].nunique()==2 and c not in cat]
cont=[c for c in features if c not in cat and c not in binary]
print('types', len(cat), cat, len(binary), binary, len(cont), cont)

records=[]
for y in outs:
    yy=df[y].to_numpy()
    # categorical levels vs rest
    for c in cat:
        for lvl in sorted(df[c].unique(), key=lambda x: str(x)):
            mask=(df[c]==lvl).to_numpy()
            if mask.sum()<20 or (~mask).sum()<20: continue
            a=yy[mask]; b=yy[~mask]
            effect=a.mean()-b.mean()
            t,p=stats.ttest_ind(a,b,equal_var=False)
            records.append((y,c,str(lvl),'level_vs_rest',mask.sum(),effect,p,a.mean(),b.mean()))
    for c in binary:
        mask=(df[c]==1).to_numpy()
        a=yy[mask]; b=yy[~mask]
        effect=a.mean()-b.mean()
        t,p=stats.ttest_ind(a,b,equal_var=False)
        records.append((y,c,'1','binary_1_vs_0',mask.sum(),effect,p,a.mean(),b.mean()))
    for c in cont:
        x=df[c].to_numpy()
        z=(x-x.mean())/x.std(ddof=0)
        slope, intercept, r, p, se=stats.linregress(z, yy)
        records.append((y,c,'per_sd','continuous_slope',len(df),slope,p,np.nan,np.nan))
res=pd.DataFrame(records,columns=['outcome','feature','level','kind','n','effect','p','mean_in','mean_out'])
# top by p and top negative effect for each outcome
for y in outs:
    print('\\n====', y, 'top abs significance')
    sub=res[res.outcome==y].copy()
    sub['abs_effect']=sub.effect.abs()
    print(sub.sort_values('p').head(15).to_string(index=False, float_format=lambda v: f'{v:.3g}'))
    print('---- strongest negative effects')
    print(sub.sort_values('effect').head(12).to_string(index=False, float_format=lambda v: f'{v:.3g}'))
