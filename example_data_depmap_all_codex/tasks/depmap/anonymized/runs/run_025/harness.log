def mask_for(conds):
    m=pd.Series(True,index=df.index)
    parts=[]
    for c,v in conds:
        m &= df[c].eq(v)
        parts.append(f'{c}=={v}')
    return m, ' & '.join(parts)

def show(y, conds):
    m,name=mask_for(conds); n=int(m.sum())
    yy=df[y]
    t,p=stats.ttest_ind(yy[m], yy[~m], equal_var=False)
    print(f'{y:18s} {name:55s} n={n:5d} mean={yy[m].mean(): .4f} other={yy[~m].mean(): .4f} diff={yy[m].mean()-yy[~m].mean(): .4f} p={p:.3g}')
for y,conds in checks: show(y,conds)

# lineages/subtypes stratified means for primary mutation features
primaries={
 'dependency_BRAF':'feature_009',
 'dependency_EGFR':'feature_022',
 'dependency_ERBB2':'feature_024',
 'dependency_KRAS':'feature_014',
 'dependency_RIT1':'feature_027',
}
for y,f in primaries.items():
    print('\\n====', y, f, 'by feature_011')
    for lvl,grp in df.groupby('feature_011'):
        if grp[f].sum()>=50 and (len(grp)-grp[f].sum())>=50:
            m=grp[f].eq(1); yy=grp[y]
            t,p=stats.ttest_ind(yy[m],yy[~m],equal_var=False)
            print(f'{lvl:14s} n1={int(m.sum()):4d} mean1={yy[m].mean(): .4f} mean0={yy[~m].mean(): .4f} diff={yy[m].mean()-yy[~m].mean(): .4f} p={p:.2g}')
    print('by feature_010')
    for lvl,grp in df.groupby('feature_010'):
        if grp[f].sum()>=50 and (len(grp)-grp[f].sum())>=50:
            m=grp[f].eq(1); yy=grp[y]
            t,p=stats.ttest_ind(yy[m],yy[~m],equal_var=False)
            print(f'{lvl:14s} n1={int(m.sum()):4d} mean1={yy[m].mean(): .4f} mean0={yy[~m].mean(): .4f} diff={yy[m].mean()-yy[~m].mean(): .4f} p={p:.2g}')
