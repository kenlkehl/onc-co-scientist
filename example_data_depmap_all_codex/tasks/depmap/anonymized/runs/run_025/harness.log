codex
The heterogeneity screen shows one dominant non-additive structure: `dependency_KIF18A` is concentrated in colorectal lines with `feature_035==1` or high `feature_028`, and `feature_020==1` appears to suppress that dependency. I’m drilling into that subgroup with explicit multi-feature tests now.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
import itertools

df=pd.read_parquet('dataset.parquet')
y='dependency_KIF18A'
# key predicates
preds={
 'colorectal': df['feature_011'].eq('colorectal'),
 'feat035_1': df['feature_035'].eq(1),
 'feat020_1': df['feature_020'].eq(1),
 'feat020_0': df['feature_020'].eq(0),
 'feat028_hi': df['feature_028'].ge(df['feature_028'].quantile(.75)),
 'feat017_hi': df['feature_017'].ge(df['feature_017'].quantile(.75)),
 'feat014_1': df['feature_014'].eq(1),
 'not_applicable': df['feature_010'].eq('not_applicable'),
}
print('thresholds', 'feature_028_q75', df['feature_028'].quantile(.75), 'feature_017_q75', df['feature_017'].quantile(.75))
for name,m in preds.items(): print(name, int(m.sum()), float(df.loc[m,y].mean()), 'vs not', float(df.loc[~m,y].mean()))
print('\\nKey subgroup means')
def show(expr, mask):
    n=int(mask.sum()); mean=float(df.loc[mask,y].mean()) if n else float('nan'); other=float(df.loc[~mask,y].mean()) if n<len(df) else float('nan')
    if n>1 and n<len(df)-1:
        t,p=stats.ttest_ind(df.loc[mask,y],df.loc[~mask,y],equal_var=False)
    else: p=float('nan')
    print(f'{expr:70s} n={n:5d} mean={mean:.4f} other={other:.4f} diff={mean-other:.4f} p={p:.3g}')
show('colorectal & feature_035==1', preds['colorectal']&preds['feat035_1'])
show('colorectal & feature_035==1 & feature_020==0', preds['colorectal']&preds['feat035_1']&preds['feat020_0'])
show('colorectal & feature_035==1 & feature_020==1', preds['colorectal']&preds['feat035_1']&preds['feat020_1'])
show('colorectal & feature_028 high', preds['colorectal']&preds['feat028_hi'])
show('colorectal & feature_028 high & feature_020==0', preds['colorectal']&preds['feat028_hi']&preds['feat020_0'])
show('colorectal & feature_028 high & feature_020==1', preds['colorectal']&preds['feat028_hi']&preds['feat020_1'])
show('feature_035==1 & feature_028 high', preds['feat035_1']&preds['feat028_hi'])
show('feature_035==1 & feature_028 high & feature_020==0', preds['feat035_1']&preds['feat028_hi']&preds['feat020_0'])
show('feature_035==1 & feature_028 high & feature_020==1', preds['feat035_1']&preds['feat028_hi']&preds['feat020_1'])
show('colorectal & feature_035==1 & feature_028 high', preds['colorectal']&preds['feat035_1']&preds['feat028_hi'])
show('colorectal & feature_035==1 & feature_028 high & feature_020==0', preds['colorectal']&preds['feat035_1']&preds['feat028_hi']&preds['feat020_0'])
show('colorectal & feature_035==1 & feature_028 high & feature_020==1', preds['colorectal']&preds['feat035_1']&preds['feat028_hi']&preds['feat020_1'])

# Tab colorectal x 035 x 020 x 028hi
print('\\nFour-way cells: colorectal, feature_035, feature_020, feature_028_hi')
for c, f35, f20, f28 in itertools.product([0,1],[0,1],[0,1],[0,1]):
    mask=(preds['colorectal']==bool(c))&(preds['feat035_1']==bool(f35))&(preds['feat020_1']==bool(f20))&(preds['feat028_hi']==bool(f28))
    n=int(mask.sum())
    if n>=100:
        print(f'colorectal={c} f035={f35} f020={f20} f028hi={f28} n={n:5d} mean={df.loc[mask,y].mean():.4f}')

# Feature correlations/overlap for key predicates
print('\\nOverlap counts')
keys=list(preds.keys())
for a,b in [('colorectal','feat035_1'),('colorectal','feat028_hi'),('feat035_1','feat028_hi'),('colorectal','feat020_1'),('feat035_1','feat020_1'),('feat028_hi','feat020_1')]:
    A=preds[a]; B=preds[b]
    print(a,b,'n11',int((A&B).sum()),'n10',int((A&~B).sum()),'n01',int((~A&B).sum()),'n00',int((~A&~B).sum()))
