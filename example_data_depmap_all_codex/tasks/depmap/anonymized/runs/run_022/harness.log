import pandas as pd, numpy as np
from scipy import stats
from statsmodels.stats.multitest import multipletests
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat=[c for c in features if df[c].dtype=='object' or (df[c].nunique()<=6 and not set(df[c].unique()).issubset({0,1}))]
binary=[c for c in features if set(df[c].unique()).issubset({0,1})]
cont=[c for c in features if c not in cat+binary]
# build predicates
preds=[]
n=len(df)
for c in cat:
    for lvl in sorted(df[c].unique(), key=lambda v: str(v)):
        mask=(df[c].astype(str)==str(lvl)).to_numpy()
        preds.append({'name':f'{c} == {lvl}', 'feature':c, 'mask':mask, 'support':int(mask.sum())})
for c in binary:
    for val in [1,0]:
        mask=(df[c].to_numpy()==val)
        # include complements too but avoid extreme > 95%? feature_021=0 is 95.028%, include maybe too broad? skip > 0.95? complete definitions not helpful. Keep if <=.95 and >=.05? 
        if mask.mean()>=0.03 and mask.mean()<=0.97:
            preds.append({'name':f'{c} == {val}', 'feature':c, 'mask':mask, 'support':int(mask.sum())})
for c in cont:
    x=df[c].to_numpy(float)
    q25,q75=np.quantile(x,[0.25,0.75])
    q10,q90=np.quantile(x,[0.10,0.90])
    for label,mask in [(f'{c} >= Q75 ({q75:.3g})', x>=q75),(f'{c} <= Q25 ({q25:.3g})', x<=q25),(f'{c} >= Q90 ({q90:.3g})', x>=q90),(f'{c} <= Q10 ({q10:.3g})', x<=q10)]:
        if mask.sum()>=500 and (~mask).sum()>=500:
            preds.append({'name':label,'feature':c,'mask':mask,'support':int(mask.sum())})
print('predicate count', len(preds))

def pair_stats(y,A,B):
    A=A.astype(bool); B=B.astype(bool)
    masks=[(~A)&(~B), A&(~B), (~A)&B, A&B]
    counts=np.array([m.sum() for m in masks])
    if (counts<100).any():
        return None
    means=np.array([y[m].mean() for m in masks])
    # residual SSE within four cells
    sse=sum(((y[m]-means[i])**2).sum() for i,m in enumerate(masks))
    df_res=len(y)-4
    sigma2=sse/df_res
    inter=means[3]-means[1]-means[2]+means[0]
    se=(sigma2*(1/counts[3]+1/counts[1]+1/counts[2]+1/counts[0]))**0.5
    t=inter/se if se>0 else np.nan
    p=2*stats.t.sf(abs(t), df_res) if se>0 else np.nan
    sg=A&B
    rest=~sg
    subgroup_effect=y[sg].mean()-y[rest].mean()
    subgroup_p=stats.ttest_ind(y[sg],y[rest],equal_var=False).pvalue
    return inter,p,subgroup_effect,subgroup_p,counts,means

all_pairs=[]
for ycol in outcomes:
    y=df[ycol].to_numpy(float)
    for i,j in combinations(range(len(preds)),2):
        if preds[i]['feature']==preds[j]['feature']:
            continue
        st=pair_stats(y,preds[i]['mask'],preds[j]['mask'])
        if st is None: continue
        inter,p,e_sg,p_sg,counts,means=st
        all_pairs.append((ycol,preds[i]['name'],preds[j]['name'],preds[i]['feature'],preds[j]['feature'],inter,p,e_sg,p_sg,int(counts[3]),means[0],means[1],means[2],means[3]))
pairs=pd.DataFrame(all_pairs,columns=['outcome','pred1','pred2','feature1','feature2','interaction','interaction_p','subgroup_effect','subgroup_p','support','mean00','mean10','mean01','mean11'])
pairs['interaction_q']=multipletests(pairs['interaction_p'].fillna(1), method='fdr_bh')[1]
pairs['subgroup_q']=multipletests(pairs['subgroup_p'].fillna(1), method='fdr_bh')[1]
for ycol in outcomes:
    d=pairs[pairs.outcome==ycol].copy()
    print('\\n==',ycol,'top negative subgroup effects (pair rules) ==')
    print(d.sort_values('subgroup_effect').head(10)[['pred1','pred2','support','mean11','subgroup_effect','subgroup_p','interaction','interaction_p','interaction_q']].to_string(index=False, float_format=lambda x:f'{x:.3g}'))
    print('\\n==',ycol,'top abs interactions ==')
    print(d.reindex(d.interaction.abs().sort_values(ascending=False).index).head(10)[['pred1','pred2','support','mean00','mean10','mean01','mean11','interaction','interaction_p','interaction_q']].to_string(index=False, float_format=lambda x:f'{x:.3g}'))
