import pandas as pd, numpy as np
import statsmodels.api as sm
from statsmodels.stats.multitest import multipletests

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat=[c for c in features if df[c].dtype=='object' or (df[c].nunique()<=6 and not set(df[c].unique()).issubset({0,1}))]
binary=[c for c in features if set(df[c].unique()).issubset({0,1})]
cont=[c for c in features if c not in cat+binary]
Xparts=[]
# dummies for categories drop first
for c in cat:
    dum=pd.get_dummies(df[c].astype(str), prefix=c, drop_first=True, dtype=float)
    Xparts.append(dum)
Xparts.append(df[binary].astype(float))
Z=df[cont].astype(float).copy()
Z=(Z-Z.mean())/Z.std(ddof=0)
Xparts.append(Z)
X=pd.concat(Xparts, axis=1)
X=sm.add_constant(X)
print('X shape', X.shape)
records=[]
for ycol in outcomes:
    model=sm.OLS(df[ycol].to_numpy(), X).fit()
    params=model.params.drop('const')
    pvals=model.pvalues.drop('const')
    for term,b,p in zip(params.index, params.values, pvals.values):
        records.append((ycol,term,b,p,abs(b),model.rsquared))
res=pd.DataFrame(records,columns=['outcome','term','coef','p','abscoef','r2'])
res['q']=multipletests(res['p'].fillna(1), method='fdr_bh')[1]
for ycol in outcomes:
    print('\\n==',ycol,'main-effects adjusted top == R2', res[res.outcome==ycol]['r2'].iloc[0])
    print(res[res.outcome==ycol].sort_values('abscoef', ascending=False).head(12)[['term','coef','p','q']].to_string(index=False, float_format=lambda x:f'{x:.3g}'))
