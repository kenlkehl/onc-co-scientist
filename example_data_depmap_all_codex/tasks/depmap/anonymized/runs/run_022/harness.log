        if np.isnan(eff_valid[i,j]): continue
        print(f'{names[i]} AND {names[j]} | n={int(N11[i,j])} mean={M11[i,j]:.4f} effect={eff_valid[i,j]:.4f} p_sg={p_sg_valid[i,j]:.3g} interaction={inter_valid[i,j]:.4f} p_int={p_inter_valid[i,j]:.3g} q_int={q_inter[i,j]:.3g}')
    print('==', ycol, 'strongest absolute interactions ==')
