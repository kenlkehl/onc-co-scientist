import pandas as pd, numpy as np
from scipy import stats
from statsmodels.stats.multitest import multipletests

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]

def ttest(ycol, mask):
    y=df[ycol].to_numpy(float); m=np.asarray(mask, dtype=bool)
    y1=y[m]; y0=y[~m]
    p=stats.ttest_ind(y1,y0,equal_var=False).pvalue
    return int(m.sum()), float(y1.mean()), float(y0.mean()), float(y1.mean()-y0.mean()), float(p)

def slope(ycol, xcol):
    y=df[ycol].to_numpy(float); x=df[xcol].to_numpy(float); z=(x-x.mean())/x.std(ddof=0)
    r=stats.linregress(z,y)
    return float(r.slope), float(r.pvalue)

def inter2(ycol, maskA, maskB):
    y=df[ycol].to_numpy(float); A=np.asarray(maskA,dtype=bool); B=np.asarray(maskB,dtype=bool); n=len(y)
    masks=[(~A)&(~B), A&(~B), (~A)&B, A&B]
    counts=np.array([m.sum() for m in masks])
    means=np.array([y[m].mean() for m in masks])
    sse=sum(((y[m]-means[i])**2).sum() for i,m in enumerate(masks))
    sigma2=sse/(n-4)
    beta=means[3]-means[1]-means[2]+means[0]
    se=np.sqrt(sigma2*(1/counts).sum())
    p=2*stats.t.sf(abs(beta/se), n-4)
    sg=A&B
    nsg, msg, mrest, eff, psg = ttest(ycol, sg)
    return {'counts':counts.tolist(),'means':means.tolist(),'interaction':float(beta),'interaction_p':float(p),'subgroup_n':nsg,'subgroup_mean':msg,'rest_mean':mrest,'subgroup_effect':eff,'subgroup_p':psg}

