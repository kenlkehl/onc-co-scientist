/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from statsmodels.stats.multitest import multipletests

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat=[c for c in features if df[c].dtype=='object' or df[c].nunique()<=6 and not set(df[c].unique()).issubset({0,1})]
binary=[c for c in features if set(df[c].unique()).issubset({0,1})]
cont=[c for c in features if c not in cat+binary]
print('categorical', cat)
for c in cat:
    print('\\n',c, df[c].value_counts().to_dict())
print('\\nbinary prevalence')
print(df[binary].mean().sort_values(ascending=False).to_string())
print('\\ncontinuous correlations top by outcome')
records=[]
# predicates single-feature levels: binary value 1; categorical each level; cont per SD slope
for ycol in outcomes:
    y=df[ycol].to_numpy()
    # continuous standardized slope via linregress (effect per SD)
    for c in cont:
        x=df[c].to_numpy().astype(float)
        xs=(x-x.mean())/x.std(ddof=0)
        r=stats.linregress(xs,y)
        records.append((ycol,c,'continuous per +1 SD',r.slope,r.pvalue,abs(r.slope)))
    for c in binary:
        m=df[c].to_numpy()==1
        y1=y[m]; y0=y[~m]
        effect=y1.mean()-y0.mean()
        p=stats.ttest_ind(y1,y0,equal_var=False).pvalue
        records.append((ycol,c,'binary 1 vs 0',effect,p,abs(effect)))
    for c in cat:
        for lvl in sorted(df[c].unique(), key=lambda v: str(v)):
            m=(df[c]==lvl).to_numpy()
            if m.sum() < 50 or (~m).sum()<50: continue
            y1=y[m]; y0=y[~m]
            effect=y1.mean()-y0.mean()
            p=stats.ttest_ind(y1,y0,equal_var=False).pvalue
            records.append((ycol,f'{c}={lvl}','level vs rest',effect,p,abs(effect)))
res=pd.DataFrame(records,columns=['outcome','feature','test','effect','p','abs_effect'])
res['q']=multipletests(res['p'].fillna(1),method='fdr_bh')[1]
for ycol in outcomes:
    print('\\n==', ycol, 'top univariate abs effects ==')
    print(res[res.outcome==ycol].sort_values('abs_effect',ascending=False).head(12)[['feature','test','effect','p','q']].to_string(index=False, float_format=lambda x: f'{x:.3g}'))
