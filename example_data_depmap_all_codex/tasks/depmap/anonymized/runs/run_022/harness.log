    q_inter=np.full_like(p_inter_valid, np.nan, dtype=float)
    q_inter[~np.isnan(p_inter_valid)]=q_flat
    print('\\n==', ycol, 'strongest negative subgroup pairs ==')
    flat_idx=np.argsort(eff_valid.ravel())[:8]
