from scipy import stats

df=pd.read_parquet('dataset.parquet')

def ttest(ycol, mask):
 y=df[ycol].to_numpy(float); m=np.asarray(mask,dtype=bool); y1=y[m]; y0=y[~m]
 return {'n':int(m.sum()),'mean':float(y1.mean()),'rest_mean':float(y0.mean()),'effect':float(y1.mean()-y0.mean()),'p':float(stats.ttest_ind(y1,y0,equal_var=False).pvalue)}

def inter2(ycol,A,B):
 y=df[ycol].to_numpy(float); A=np.asarray(A,bool); B=np.asarray(B,bool); n=len(y)
 masks=[(~A)&(~B), A&(~B), (~A)&B, A&B]
 counts=np.array([m.sum() for m in masks]); means=np.array([y[m].mean() for m in masks])
 sse=sum(((y[m]-means[i])**2).sum() for i,m in enumerate(masks))
 sig=sse/(n-4); beta=means[3]-means[1]-means[2]+means[0]
 se=np.sqrt(sig*(1/counts).sum()); p=2*stats.t.sf(abs(beta/se),n-4)
 out=ttest(ycol,A&B); out.update({'counts':counts.tolist(),'means':means.tolist(),'interaction':float(beta),'interaction_p':float(p)})
 return out
q=lambda c,p: df[c].quantile(p)
print('thresholds', {'feature_016_q90':q('feature_016',.9),'feature_017_q90':q('feature_017',.9),'feature_002_q10':q('feature_002',.1),'feature_003_q10':q('feature_003',.1),'feature_023_q90':q('feature_023',.9)})
