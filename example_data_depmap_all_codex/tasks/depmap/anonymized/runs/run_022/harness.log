import pandas as pd, numpy as np
from scipy import stats
from statsmodels.stats.multitest import multipletests

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat=[c for c in features if df[c].dtype=='object' or (df[c].nunique()<=6 and not set(df[c].unique()).issubset({0,1}))]
binary=[c for c in features if set(df[c].unique()).issubset({0,1})]
cont=[c for c in features if c not in cat+binary]
preds=[]
for c in cat:
    for lvl in sorted(df[c].unique(), key=lambda v: str(v)):
        mask=(df[c].astype(str)==str(lvl)).to_numpy()
        if 100 <= mask.sum() <= len(df)-100:
            preds.append((f'{c} == {lvl}', c, mask))
for c in binary:
    mask=(df[c].to_numpy()==1)
    if 100 <= mask.sum() <= len(df)-100:
        preds.append((f'{c} == 1', c, mask))
for c in cont:
    x=df[c].to_numpy(float)
    q25,q75=np.quantile(x,[0.25,0.75])
    preds.append((f'{c} >= Q75 ({q75:.3g})', c, x>=q75))
    preds.append((f'{c} <= Q25 ({q25:.3g})', c, x<=q25))
K=len(preds); n=len(df)
P=np.column_stack([m for _,_,m in preds]).astype(float)
N1=P.sum(axis=0)
N11=P.T@P
names=[p[0] for p in preds]
pfeat=[p[1] for p in preds]
valid_pair=np.ones((K,K), dtype=bool)
for i in range(K):
    for j in range(K):
        if i>=j or pfeat[i]==pfeat[j]:
            valid_pair[i,j]=False
# require all four cells >= 100
N10=N1[:,None]-N11
N01=N1[None,:]-N11
N00=n-N1[:,None]-N1[None,:]+N11
valid_pair &= (N11>=100)&(N10>=100)&(N01>=100)&(N00>=100)
print('predicate count',K,'candidate pairs',int(valid_pair.sum()))
for ycol in outcomes:
    y=df[ycol].to_numpy(float)
    Sy=y.sum(); Sy2=(y*y).sum()
    S1=P.T@y
    S2_1=P.T@(y*y)
    # pair sums via matrix multiplication
    Py=P*y[:,None]
    S11=P.T@Py
    Py2=P*(y*y)[:,None]
    S2_11=P.T@Py2
    S10=S1[:,None]-S11; S01=S1[None,:]-S11; S00=Sy-S1[:,None]-S1[None,:]+S11
    S2_10=S2_1[:,None]-S2_11; S2_01=S2_1[None,:]-S2_11; S2_00=Sy2-S2_1[:,None]-S2_1[None,:]+S2_11
    with np.errstate(invalid='ignore', divide='ignore'):
        M11=S11/N11; M10=S10/N10; M01=S01/N01; M00=S00/N00
        inter=M11-M10-M01+M00
        # residual SSE within cells
        SSE=(S2_11-S11*S11/N11)+(S2_10-S10*S10/N10)+(S2_01-S01*S01/N01)+(S2_00-S00*S00/N00)
        df_res=n-4
        sigma2=SSE/df_res
        se=np.sqrt(sigma2*(1/N11+1/N10+1/N01+1/N00))
        t=inter/se
        p_inter=2*stats.t.sf(np.abs(t), df_res)
        # subgroup vs rest Welch approx
        Nsg=N11; Ssg=S11; S2sg=S2_11
        Nrest=n-Nsg; Srest=Sy-Ssg; S2rest=Sy2-S2sg
        Msg=Ssg/Nsg; Mrest=Srest/Nrest
        eff=Msg-Mrest
        var_sg=(S2sg-Ssg*Ssg/Nsg)/(Nsg-1)
        var_rest=(S2rest-Srest*Srest/Nrest)/(Nrest-1)
        se_w=np.sqrt(var_sg/Nsg+var_rest/Nrest)
        t_w=eff/se_w
        df_w=(var_sg/Nsg+var_rest/Nrest)**2/((var_sg/Nsg)**2/(Nsg-1)+(var_rest/Nrest)**2/(Nrest-1))
        p_sg=2*stats.t.sf(np.abs(t_w), df_w)
    # mask invalid/lower triangle
    inter_valid=np.where(valid_pair, inter, np.nan)
    eff_valid=np.where(valid_pair, eff, np.nan)
    p_inter_valid=np.where(valid_pair, p_inter, np.nan)
    p_sg_valid=np.where(valid_pair, p_sg, np.nan)
