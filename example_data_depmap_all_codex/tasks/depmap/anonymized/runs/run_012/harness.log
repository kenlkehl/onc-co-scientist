from pathlib import Path
import struct, math, statistics, json

# Compact thrift and parquet reader for this local pyarrow/snappy/dictionary parquet.
class CompactReader:
    def __init__(self,b,off=0): self.b=b; self.i=off
    def rb(self): v=self.b[self.i]; self.i+=1; return v
    def read(self,n): v=self.b[self.i:self.i+n]; self.i+=n; return v
    def var(self):
        s=0; res=0
        while True:
            b=self.rb(); res|=(b&0x7f)<<s
            if not (b&0x80): return res
            s+=7
    def zz(self,n): return (n>>1)"'^-(n&1)
    def i16(self): return self.zz(self.var())
    def i32(self): return self.zz(self.var())
    def i64(self): return self.zz(self.var())
    def dbl(self): return struct.unpack('"'<d', self.read(8))[0]
    def bin(self): n=self.var(); return self.read(n)
    def fh(self,last):
        b=self.rb(); t=b&0xf
        if t==0: return 0,0
        d=b>>4
        return (last+d if d else self.i16()),t
    def lh(self):
        b=self.rb(); n=b>>4; t=b&0xf
        if n==15: n=self.var()
        return n,t

def thrift_val(r,t):
    if t==1: return True
    if t==2: return False
    if t==3: return r.rb()
    if t==4: return r.i16()
    if t==5: return r.i32()
    if t==6: return r.i64()
    if t==7: return r.dbl()
    if t==8:
        b=r.bin()
        try: return b.decode('utf-8')
        except UnicodeDecodeError: return b
    if t==9:
        n,et=r.lh(); return [thrift_val(r,et) for _ in range(n)]
    if t==12: return thrift_struct(r)
    raise ValueError(f'thrift type {t} at {r.i}')
def thrift_struct(r):
    out={}; last=0
    while True:
        fid,t=r.fh(last)
        if t==0: break
        out[fid]=thrift_val(r,t); last=fid
    return out

def snappy_decompress(data):
    pos=0; out=bytearray()
    # uncompressed length varint
    shift=0; ulen=0
    while True:
        b=data[pos]; pos+=1; ulen|=(b&0x7f)<<shift
        if not b&0x80: break
        shift+=7
    while pos < len(data):
        tag=data[pos]; pos+=1; typ=tag&3
        if typ==0:
            l=tag>>2
            if l<60:
                l+=1
            else:
                n=l-59
                l=int.from_bytes(data[pos:pos+n],'little')+1; pos+=n
            out.extend(data[pos:pos+l]); pos+=l
        elif typ==1:
            l=((tag>>2)&0x7)+4
            off=((tag & 0xE0)<<3) | data[pos]; pos+=1
            start=len(out)-off
            for k in range(l): out.append(out[start+k])
        elif typ==2:
            l=(tag>>2)+1
            off=int.from_bytes(data[pos:pos+2],'little'); pos+=2
            start=len(out)-off
            for k in range(l): out.append(out[start+k])
        else:
            l=(tag>>2)+1
            off=int.from_bytes(data[pos:pos+4],'little'); pos+=4
            start=len(out)-off
            for k in range(l): out.append(out[start+k])
    if len(out)"'!=ulen:
        raise ValueError((len(out),ulen))
    return bytes(out)

def read_uvar(data,pos):
    s=0; res=0
    while True:
        b=data[pos]; pos+=1; res|=(b&0x7f)<<s
        if not b&0x80: return res,pos
        s+=7

def decode_rle_bitpacked(data,pos,bit_width,count):
    out=[]; mask=(1<<bit_width)-1 if bit_width else 0
    while len(out)<count:
        header,pos=read_uvar(data,pos)
        if header & 1 == 0:
            run=header>>1
            nbytes=(bit_width+7)//8
            val=int.from_bytes(data[pos:pos+nbytes],'"'little') if nbytes else 0
            pos+=nbytes
            take=min(run, count-len(out))
            out.extend([val]*take)
        else:
            groups=header>>1
            for _ in range(groups):
                nbytes=bit_width
                chunk=int.from_bytes(data[pos:pos+nbytes],'little') if nbytes else 0
                pos+=nbytes
                for j in range(8):
                    if len(out)<count:
                        out.append((chunk>>(j*bit_width)) & mask if bit_width else 0)
    return out,pos

def plain_decode(data, typ, n):
    vals=[]; pos=0
    if typ==6:
        for _ in range(n):
            l=int.from_bytes(data[pos:pos+4],'little'); pos+=4
            vals.append(data[pos:pos+l].decode('utf-8')); pos+=l
    elif typ==5:
        vals=list(struct.unpack('<'+'d'*n, data[pos:pos+8*n]))
    elif typ==2:
        vals=list(struct.unpack('<'+'q'*n, data[pos:pos+8*n]))
    else:
        raise ValueError('plain type '+str(typ))
    return vals

def read_page_header(buf,pos):
    r=CompactReader(buf,pos); h=thrift_struct(r); return h,r.i

def read_parquet(path):
    buf=Path(path).read_bytes()
    meta_len=int.from_bytes(buf[-8:-4],'little')
    meta=buf[len(buf)-8-meta_len:len(buf)-8]
    fm=thrift_struct(CompactReader(meta))
    schema=fm[2]
    names=[s[4] for s in schema[1:]]
    types=[s[1] for s in schema[1:]]
    rg=fm[4][0]
    data={}
    for name,typ,col in zip(names,types,rg[1]):
        md=col[3]; total=md[7]; start=md.get(11, md[9]); end=start+total; pos=start
        dictionary=None; values=[]
        while pos<end:
            h,after=read_page_header(buf,pos)
            payload=buf[after:after+h[3]]; pos=after+h[3]
            raw=snappy_decompress(payload) if md[4]==1 else payload
            if h[1]==2:
                dh=h[7]; dictionary=plain_decode(raw, typ, dh[1])
            elif h[1]==0:
                dph=h[5]; n=dph[1]; enc=dph[2]
                p=0
                # optional fields: no repetition levels, one definition level stream.
                # All dataset columns have no nulls, so we can skip the definition-level byte section.
                def_len=int.from_bytes(raw[p:p+4],'little'); p+=4+def_len
                if enc==8: # RLE_DICTIONARY
                    bw=raw[p]; p+=1
                    idx,_=decode_rle_bitpacked(raw,p,bw,n)
                    values.extend(dictionary[i] for i in idx)
                elif enc==0:
                    values.extend(plain_decode(raw[p:], typ, n))
                else:
                    raise ValueError(('encoding',enc,name))
            else:
                raise ValueError(('page type',h[1],name))
        if len(values)"'!=fm[3]:
            raise ValueError((name,len(values),fm[3]))
        data[name]=values
    return data, names, types

data,names,types=read_parquet('"'dataset.parquet')
print('decoded', len(data), len(next(iter(data.values()))))
for name in names[:8]+names[35:]:
    vals=data[name]
    uniq=sorted(set(vals))
    print(name, 'type', types[names.index(name)], 'nuniq', len(uniq), 'sample', uniq[:12], 'minmax', (min(vals),max(vals)) if not isinstance(vals[0],str) else '')
for dep in [c for c in names if c.startswith('dependency_')]:
    vals=data[dep]; m=sum(vals)/len(vals); sd=(sum((x-m)**2 for x in vals)/(len(vals)-1))**0.5
    print(dep, 'mean', round(m,4), 'sd', round(sd,4), 'min', min(vals), 'max', max(vals), 'uniq', len(set(vals)))
