class R:
    def __init__(self,b,off=0): self.b=b; self.i=off
    def rb(self): v=self.b[self.i]; self.i+=1; return v
    def read(self,n): v=self.b[self.i:self.i+n]; self.i+=n; return v
    def var(self):
        s=0; res=0
        while True:
            b=self.rb(); res|=(b&0x7f)<<s
            if not b&0x80: return res
            s+=7
    def zz(self,n): return (n>>1)"'^-(n&1)
    def i16(self): return self.zz(self.var())
    def i32(self): return self.zz(self.var())
    def i64(self): return self.zz(self.var())
    def dbl(self): import struct; return struct.unpack('"'<d', self.read(8))[0]
    def bin(self): n=self.var(); return self.read(n)
    def fh(self,last):
        b=self.rb(); t=b&0xf
        if t==0: return 0,0
        d=b>>4
        return (last+d if d else self.i16()),t
    def lh(self):
        b=self.rb(); n=b>>4; t=b&0xf
        if n==15: n=self.var()
        return n,t

def val(r,t):
    if t==1: return True
    if t==2: return False
    if t==3: return r.rb()
    if t==4: return r.i16()
    if t==5: return r.i32()
    if t==6: return r.i64()
    if t==7: return r.dbl()
    if t==8:
        b=r.bin()
        try: return b.decode()
        except: return b
    if t==9:
        n,et=r.lh(); return [val(r,et) for _ in range(n)]
    if t==12: return st(r)
    raise Exception(t)
def st(r):
    out={}; last=0
    while True:
        fid,t=r.fh(last)
        if t==0: break
        out[fid]=val(r,t); last=fid
    return out
