features=[n for n in names if n.startswith('feature_')]
deps=[n for n in names if n.startswith('dependency_')]
print('FEATURE SUMMARY')
for f in features:
    vals=data[f]; u=sorted(set(vals)); print(f, 'type', types[names.index(f)], 'nuniq', len(u), 'minmax', (min(vals),max(vals)) if not isinstance(vals[0],str) else '', 'sample', u[:8])
# main screens
print('\\nTOP SINGLE PREDICATE DIFFERENCES BY DEP')
for dep in deps:
    y=data[dep]; hits=[]
    for f in features:
        vals=data[f]; u=sorted(set(vals))
        if isinstance(vals[0],str) or len(u)<=12:
            for lev in u:
                res=diff_test(y,[v==lev for v in vals])
                if res: hits.append((abs(res['effect']),dep,f,'=='+str(lev),res))
        else:
            su=sorted(vals); qs=[0.1,0.25,0.75,0.9]
            for q in qs:
                thr=su[int((len(su)-1)*q)]
                mask=[v<=thr for v in vals] if q<0.5 else [v>=thr for v in vals]
                res=diff_test(y,mask)
                if res: hits.append((abs(res['effect']),dep,f,('<=' if q<0.5 else '>=')+str(thr),res))
            c=corr_test(vals,y)
            if c: hits.append((abs(c['slope'])*(max(vals)-min(vals)),dep,f,'linear',c))
    hits=sorted(hits, reverse=True)[:12]
    print('\\n',dep)
    for score,dep,f,pred,res in hits:
        print(f, pred, 'effect', round(res.get('effect',res.get('slope')),4), 'n', res.get('n'), 'p', '%.2g'%res['p'], 'z', round(res['z'],2), 'means', round(res.get('mean',0),3), round(res.get('rest_mean',0),3))
