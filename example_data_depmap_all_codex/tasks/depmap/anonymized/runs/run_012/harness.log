class CompactReader:
    def __init__(self,b): self.b=b; self.i=0
    def read_byte(self):
        v=self.b[self.i]; self.i+=1; return v
    def read(self,n):
        v=self.b[self.i:self.i+n]; self.i+=n; return v
    def read_varint(self):
        shift=0; result=0
        while True:
            b=self.read_byte()
            result |= (b & 0x7f) << shift
            if not (b & 0x80): break
            shift += 7
        return result
    def zz(self,n): return (n>>1) "'^ -(n&1)
    def read_i16(self): return self.zz(self.read_varint())
    def read_i32(self): return self.zz(self.read_varint())
    def read_i64(self): return self.zz(self.read_varint())
    def read_double(self):
        import struct
        return struct.unpack('"'<d', self.read(8))[0]
    def read_binary(self):
        n=self.read_varint(); return self.read(n)
    def read_field_header(self,last):
        b=self.read_byte(); t=b&0x0f
        if t==0: return (0,0)
        delta=(b & 0xf0)>>4
        if delta: fid=last+delta
        else: fid=self.read_i16()
        return fid,t
    def read_list_header(self):
        b=self.read_byte(); size=(b & 0xf0)>>4; et=b&0x0f
        if size==15: size=self.read_varint()
        return size,et

def read_val(r,t):
    if t==1: return True
    if t==2: return False
    if t==3: return r.read_byte()
    if t==4: return r.read_i16()
    if t==5: return r.read_i32()
    if t==6: return r.read_i64()
    if t==7: return r.read_double()
    if t==8:
        b=r.read_binary()
        try: return b.decode('utf-8')
        except: return b
    if t==9:
        n,et=r.read_list_header(); return [read_val(r,et) for _ in range(n)]
    if t==12:
        return read_struct(r)
    raise ValueError('type '+str(t)+' at '+str(r.i))

def read_struct(r):
    out={}; last=0
    while True:
        fid,t=r.read_field_header(last)
        if t==0: break
        out[fid]=read_val(r,t)
        last=fid
    return out

