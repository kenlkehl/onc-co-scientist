def diff_test(y,mask):
    a=[yy for yy,m in zip(y,mask) if m]; b=[yy for yy,m in zip(y,mask) if not m]
    if len(a)<20 or len(b)<20: return None
    ma=mean(a); mb=mean(b); va=var(a); vb=var(b); se=math.sqrt(va/len(a)+vb/len(b))
    z=(ma-mb)/se if se else 0
