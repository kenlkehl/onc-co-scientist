features = [c for c in df.columns if c.startswith('feature_')]
cat_features = [c for c in features if not is_numeric_dtype(df[c])]
num_features = [c for c in features if is_numeric_dtype(df[c])]
binary_features = [c for c in num_features if df[c].nunique() == 2]
discrete_features = [c for c in num_features if 2 < df[c].nunique() <= 10]
cont_features = [c for c in num_features if df[c].nunique() > 10]
X_parts = []
term_names = []
for c in cat_features:
    d = pd.get_dummies(df[c], prefix=c, drop_first=True, dtype=float)
    X_parts.append(d); term_names.extend(list(d.columns))
for c in discrete_features:
    d = pd.get_dummies(df[c].astype(str), prefix=c, drop_first=True, dtype=float)
    X_parts.append(d); term_names.extend(list(d.columns))
for c in binary_features:
    X_parts.append(df[[c]].astype(float)); term_names.append(c)
for c in cont_features:
    s = (df[c] - df[c].mean()) / df[c].std(ddof=0)
    X_parts.append(pd.DataFrame({c + '_per_sd': s})); term_names.append(c + '_per_sd')
X = pd.concat(X_parts, axis=1)
X_sm = sm.add_constant(X.to_numpy())
name_index = {name: i+1 for i, name in enumerate(term_names)}
model_cache = {}
