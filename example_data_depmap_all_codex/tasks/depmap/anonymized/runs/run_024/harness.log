/bin/bash -lc "python - <<'PY'
import pandas as pd
import numpy as np
from scipy import stats
from pandas.api.types import is_numeric_dtype

df=pd.read_parquet('dataset.parquet')
N=len(df)

def mask(expr):
    return expr.to_numpy() if hasattr(expr,'to_numpy') else expr

def welch(ycol, m):
    y=df[ycol].to_numpy(); m=np.asarray(m,dtype=bool)
    a=y[m]; b=y[~m]
    t=stats.ttest_ind(a,b,equal_var=False)
    return {'n':int(m.sum()),'mean':float(a.mean()),'rest_mean':float(b.mean()),'effect':float(a.mean()-b.mean()),'p':float(t.pvalue)}

def did(ycol, a, b):
    y=df[ycol].to_numpy(); a=np.asarray(a,dtype=bool); b=np.asarray(b,dtype=bool)
    cells={}
    for av,bv in [(1,1),(1,0),(0,1),(0,0)]:
        m=(a==bool(av)) & (b==bool(bv))
        yy=y[m]
        cells[(av,bv)]={'n':int(m.sum()),'mean':float(yy.mean()),'var':float(yy.var(ddof=1))}
    d=cells[(1,1)]['mean']-cells[(1,0)]['mean']-cells[(0,1)]['mean']+cells[(0,0)]['mean']
    var=sum(cells[key]['var']/cells[key]['n'] for key in cells)
    p=2*stats.norm.sf(abs(d/(var**0.5)))
    sub=welch(ycol, a & b)
    return {'n11':cells[(1,1)]['n'],'mean11':cells[(1,1)]['mean'],'interaction':float(d),'p_interaction':float(p),'sub_effect':sub['effect'],'sub_p':sub['p'],'rest_mean':sub['rest_mean'],'cells':cells}

def report(name, obj):
    print(name, obj)

# masks
m={}
for val in df['feature_011'].unique(): m[f'feature_011=={val}']=df['feature_011'].eq(val)
for val in df['feature_010'].unique(): m[f'feature_010=={val}']=df['feature_010'].eq(val)
for val in df['feature_004'].unique(): m[f'feature_004=={val}']=df['feature_004'].eq(val)
for c in [c for c in df.columns if c.startswith('feature_') and is_numeric_dtype(df[c]) and df[c].nunique()==2]: m[f'{c}==1']=df[c].eq(1)
for c in [c for c in df.columns if c.startswith('feature_') and is_numeric_dtype(df[c]) and df[c].nunique()>10]:
    m[f'{c}_high']=df[c].ge(df[c].quantile(.75))
    m[f'{c}_low']=df[c].le(df[c].quantile(.25))

single_tests=[
('BRAF feature_009', 'dependency_BRAF', m['feature_009==1']),
('BRAF skin', 'dependency_BRAF', m['feature_011==skin']),
('EGFR feature_022', 'dependency_EGFR', m['feature_022==1']),
('EGFR brain', 'dependency_EGFR', m['feature_011==brain']),
('ERBB2 feature_024', 'dependency_ERBB2', m['feature_024==1']),
('ERBB2 luminal', 'dependency_ERBB2', m['feature_010==luminal']),
('ERBB2 her2_enriched', 'dependency_ERBB2', m['feature_010==her2_enriched']),
('KRAS feature_014', 'dependency_KRAS', m['feature_014==1']),
('KRAS pancreatic', 'dependency_KRAS', m['feature_011==pancreatic']),
('RIT1 feature_027', 'dependency_RIT1', m['feature_027==1']),
('KIF18A colorectal', 'dependency_KIF18A', m['feature_011==colorectal']),
('KIF18A feature_035', 'dependency_KIF18A', m['feature_035==1']),
('KIF18A feature_028_high', 'dependency_KIF18A', m['feature_028_high']),
('KIF18A feature_020', 'dependency_KIF18A', m['feature_020==1']),
('TMED10 feature_016_high', 'dependency_TMED10', m['feature_016_high']),
('DHX9 feature_016_high', 'dependency_DHX9', m['feature_016_high']),
('DHX9 feature_023_high', 'dependency_DHX9', m['feature_023_high']),
('POLR2A feature_016_high', 'dependency_POLR2A', m['feature_016_high']),
('RPL11 feature_018', 'dependency_RPL11', m['feature_018==1']),
('RPL11 feature_003_high', 'dependency_RPL11', m['feature_003_high']),
]
print('SINGLES')
for name,ycol,mm in single_tests:
    r=welch(ycol, mm)
    print(name, f\"n={r['n']} mean={r['mean']:.6f} rest={r['rest_mean']:.6f} effect={r['effect']:.6f} p={r['p']:.6g}\")
print('\\nINTERACTIONS')
inter_tests=[
('BRAF skin & feature_009','dependency_BRAF',m['feature_011==skin'],m['feature_009==1']),
('EGFR feature_022 & feature_023_high','dependency_EGFR',m['feature_022==1'],m['feature_023_high']),
('ERBB2 feature_024 & feature_025_high','dependency_ERBB2',m['feature_024==1'],m['feature_025_high']),
('ERBB2 breast & feature_024','dependency_ERBB2',m['feature_011==breast'],m['feature_024==1']),
('KRAS pancreatic & feature_014','dependency_KRAS',m['feature_011==pancreatic'],m['feature_014==1']),
('RIT1 brain & feature_027','dependency_RIT1',m['feature_011==brain'],m['feature_027==1']),
('KIF18A colorectal & feature_035','dependency_KIF18A',m['feature_011==colorectal'],m['feature_035==1']),
('KIF18A colorectal & feature_028_high','dependency_KIF18A',m['feature_011==colorectal'],m['feature_028_high']),
('KIF18A colorectal & feature_020','dependency_KIF18A',m['feature_011==colorectal'],m['feature_020==1']),
('KIF18A feature_035 & feature_020','dependency_KIF18A',m['feature_035==1'],m['feature_020==1']),
('TMED10 luminal & feature_016_high','dependency_TMED10',m['feature_010==luminal'],m['feature_016_high']),
('TMED10 prostate & feature_016_high','dependency_TMED10',m['feature_011==prostate'],m['feature_016_high']),
('DHX9 squamous & feature_023_high','dependency_DHX9',m['feature_010==squamous'],m['feature_023_high']),
('DHX9 feature_020 & feature_021','dependency_DHX9',m['feature_020==1'],m['feature_021==1']),
('POLR2A adenocarcinoma & feature_016_high','dependency_POLR2A',m['feature_010==adenocarcinoma'],m['feature_016_high']),
('POLR2A breast & feature_030','dependency_POLR2A',m['feature_011==breast'],m['feature_030==1']),
('RPL11 feature_018 & feature_003_high','dependency_RPL11',m['feature_018==1'],m['feature_003_high']),
('RPL11 feature_018 & feature_031_high','dependency_RPL11',m['feature_018==1'],m['feature_031_high']),
]
for name,ycol,a,b in inter_tests:
    r=did(ycol,a,b)
    print(name, f\"n11={r['n11']} mean11={r['mean11']:.6f} rest={r['rest_mean']:.6f} subeffect={r['sub_effect']:.6f} subp={r['sub_p']:.6g} interaction={r['interaction']:.6f} pint={r['p_interaction']:.6g}\")
print('\\nTRIPLES')
triples=[
('KIF18A colorectal & feature_035 & not feature_020', 'dependency_KIF18A', m['feature_011==colorectal'] & m['feature_035==1'] & ~m['feature_020==1']),
('KIF18A colorectal & feature_028_high & not feature_020', 'dependency_KIF18A', m['feature_011==colorectal'] & m['feature_028_high'] & ~m['feature_020==1']),
('KIF18A colorectal & feature_035 & feature_028_high & not feature_020', 'dependency_KIF18A', m['feature_011==colorectal'] & m['feature_035==1'] & m['feature_028_high'] & ~m['feature_020==1']),
('RPL11 feature_018 & feature_003_high & feature_016_high', 'dependency_RPL11', m['feature_018==1'] & m['feature_003_high'] & m['feature_016_high']),
]
for name,ycol,mm in triples:
    r=welch(ycol,mm)
    print(name, f\"n={r['n']} mean={r['mean']:.6f} rest={r['rest_mean']:.6f} effect={r['effect']:.6f} p={r['p']:.6g}\")
