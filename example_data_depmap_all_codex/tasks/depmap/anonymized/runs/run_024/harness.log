    idx = name_index[term]
    coef = float(model.params[idx])
    p = p_json(float(model.pvalues[idx]))
    return {
        'hypothesis_ids': [hid],
        'method': 'Ordinary least squares with all categorical features one-hot encoded, all binary features included, and continuous features standardized',
        'result_summary': f'Adjusted model for {ycol}: "'`{term}` coefficient={coef:+.4f} ({direction_text}), p={p_text(p)}, model R2={model.rsquared:.4f}.'"',
        'effect_estimate': round_float(coef),
        'p_value': p,
        'significant': bool(p < 0.05),
        'term': term,
        'model_r_squared': round_float(model.rsquared),
    }
