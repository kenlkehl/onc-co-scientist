import json
from pathlib import Path
import pandas as pd
import numpy as np
from scipy import stats
from pandas.api.types import is_numeric_dtype
import statsmodels.api as sm

DATASET_ID = 'ds001_depmap'
MODEL_ID = 'gpt-5-codex'
HARNESS_ID = 'codex-cli@local-analysis'
MAX_ITERATIONS = 10

df = pd.read_parquet('dataset.parquet')
N = len(df)

def as_mask(x):
    return x.to_numpy() if hasattr(x, 'to_numpy') else np.asarray(x)

# Predicate masks and thresholds.
m = {}
for val in sorted(df['feature_011'].unique()):
    m[f'feature_011=={val}'] = df['feature_011'].eq(val)
for val in sorted(df['feature_010'].unique()):
    m[f'feature_010=={val}'] = df['feature_010'].eq(val)
for val in sorted(df['feature_004'].unique()):
    m[f'feature_004=={val}'] = df['feature_004'].eq(val)
for val in sorted(df['feature_005'].unique()):
    m[f'feature_005=={val}'] = df['feature_005'].eq(val)
for c in [c for c in df.columns if c.startswith('feature_') and is_numeric_dtype(df[c]) and df[c].nunique() == 2]:
    m[f'{c}==1'] = df[c].eq(1)
thresholds = {}
for c in [c for c in df.columns if c.startswith('feature_') and is_numeric_dtype(df[c]) and df[c].nunique() > 10]:
    q25 = float(df[c].quantile(0.25))
    q75 = float(df[c].quantile(0.75))
    thresholds[f'{c}_low'] = q25
    thresholds[f'{c}_high'] = q75
    m[f'{c}_low'] = df[c].le(q25)
    m[f'{c}_high'] = df[c].ge(q75)

def high_text(c):
    return f'"'`{c}` in the top quartile (>= {thresholds[c + "_high"]:.4g})'"'

def low_text(c):
    return f'"'`{c}` in the bottom quartile (<= {thresholds[c + "_low"]:.4g})'"'

def p_json(p):
    if p is None:
        return None
    if p == 0 or p < 1e-300:
        return 0.0
    return float(p)

def p_text(p):
    if p == 0 or p < 1e-300:
        return '<1e-300'
    if p < 1e-4:
        return f'{p:.2e}'
    return f'{p:.4g}'

def round_float(x):
    return float(np.round(float(x), 6))

def welch_result(ycol, mask):
    y = df[ycol].to_numpy()
    mask = np.asarray(as_mask(mask), dtype=bool)
    a = y[mask]
    b = y[~mask]
    tt = stats.ttest_ind(a, b, equal_var=False)
    return {
        'n': int(mask.sum()),
        'mean': float(a.mean()),
        'rest_mean': float(b.mean()),
        'effect': float(a.mean() - b.mean()),
        'p': p_json(float(tt.pvalue)),
    }

def did_result(ycol, a, b):
    y = df[ycol].to_numpy()
    a = np.asarray(as_mask(a), dtype=bool)
    b = np.asarray(as_mask(b), dtype=bool)
    cells = {}
    for av, bv in [(1,1), (1,0), (0,1), (0,0)]:
        cm = (a == bool(av)) & (b == bool(bv))
        yy = y[cm]
        cells[(av,bv)] = {'n': int(cm.sum()), 'mean': float(yy.mean()), 'var': float(yy.var(ddof=1))}
    interaction = cells[(1,1)]['mean'] - cells[(1,0)]['mean'] - cells[(0,1)]['mean'] + cells[(0,0)]['mean']
    var = sum(cells[k]['var'] / cells[k]['n'] for k in cells)
    p = 2 * stats.norm.sf(abs(interaction / (var ** 0.5)))
    sub = welch_result(ycol, a & b)
    return {
        'n11': cells[(1,1)]['n'],
        'mean11': cells[(1,1)]['mean'],
        'interaction': float(interaction),
        'p_interaction': p_json(float(p)),
        'sub_effect': sub['effect'],
        'sub_p': sub['p'],
        'rest_mean': sub['rest_mean'],
        'cell_means': {f'{k[0]}{k[1]}': cells[k]['mean'] for k in cells},
        'cell_ns': {f'{k[0]}{k[1]}': cells[k]['n'] for k in cells},
    }

def contrast_analysis(hid, ycol, mask, label, method='Welch two-sample t test, subgroup vs complement'):
    r = welch_result(ycol, mask)
    return {
        'hypothesis_ids': [hid],
        'method': method,
        'result_summary': (
            f'{label}: mean {ycol} was {r[\"mean\"]:.4f} in the subgroup (n={r[\"n\"]}) '
            f'vs {r[\"rest_mean\"]:.4f} in all other lines; effect={r[\"effect\"]:+.4f}, p={p_text(r[\"p\"])}.'
        ),
        'effect_estimate': round_float(r['effect']),
        'p_value': r['p'],
        'significant': bool(r['p'] < 0.05),
        'n_subgroup': r['n'],
        'mean_subgroup': round_float(r['mean']),
        'mean_comparator': round_float(r['rest_mean']),
    }

def interaction_analysis(hid, ycol, mask_a, mask_b, label):
    r = did_result(ycol, mask_a, mask_b)
    return {
        'hypothesis_ids': [hid],
        'method': 'Pairwise feature interaction screen; effect is difference-in-differences on dependency score',
        'result_summary': (
            f'{label}: joint subgroup mean {ycol} was {r[\"mean11\"]:.4f} (n={r[\"n11\"]}); '
            f'subgroup-vs-rest effect={r[\"sub_effect\"]:+.4f} (p={p_text(r[\"sub_p\"])}), '
            f'interaction={r[\"interaction\"]:+.4f} (p={p_text(r[\"p_interaction\"])}).'
        ),
        'effect_estimate': round_float(r['interaction']),
        'p_value': r['p_interaction'],
        'significant': bool(r['p_interaction'] < 0.05),
        'n_joint_subgroup': r['n11'],
        'mean_joint_subgroup': round_float(r['mean11']),
        'subgroup_effect_estimate': round_float(r['sub_effect']),
        'subgroup_p_value': r['sub_p'],
        'cell_means': {k: round_float(v) for k, v in r['cell_means'].items()},
        'cell_ns': r['cell_ns'],
    }

iterations = []

