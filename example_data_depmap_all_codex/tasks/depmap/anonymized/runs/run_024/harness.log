import pandas as pd
import numpy as np
from scipy import stats
from pandas.api.types import is_numeric_dtype
from math import isfinite

df = pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
features=[c for c in df.columns if c.startswith('feature_')]
cat_features=[c for c in features if not is_numeric_dtype(df[c])]
num_features=[c for c in features if is_numeric_dtype(df[c])]
binary_features=[c for c in num_features if df[c].nunique()==2]
discrete_features=[c for c in num_features if 2 < df[c].nunique() <= 10]
cont_features=[c for c in num_features if df[c].nunique()>10]

preds=[]
# categorical and discrete one-vs-rest
for c in cat_features:
    for val in sorted(df[c].unique()):
        m=(df[c]==val).to_numpy()
        if 300 <= m.sum() <= len(m)-300:
            preds.append({'name':f'{c}=={val}', 'text':f'"'`{c}` == `{val}`'"', 'feature':c, 'mask':m})
for c in discrete_features:
    for val in sorted(df[c].unique()):
        m=(df[c]==val).to_numpy()
        if 300 <= m.sum() <= len(m)-300:
            preds.append({'name':f'{c}=={val:g}', 'text':f'"'`{c}` == {val:g}'"', 'feature':c, 'mask':m})
# binary
for c in binary_features:
    m=(df[c]==1).to_numpy()
    if 300 <= m.sum() <= len(m)-300:
        preds.append({'name':f'{c}==1', 'text':f'"'`{c}` == 1'"', 'feature':c, 'mask':m})
# continuous high/low quartiles
for c in cont_features:
    q25=df[c].quantile(.25); q75=df[c].quantile(.75)
    for label,op,thr,m in [
        ('high','>=',q75,(df[c]>=q75).to_numpy()),
        ('low','<=',q25,(df[c]<=q25).to_numpy())
    ]:
        if 300 <= m.sum() <= len(m)-300:
            preds.append({'name':f'{c}_{label}', 'text':f'"'`{c}` {op} {thr:.4g}'"', 'feature':c, 'mask':m})
print('predicates', len(preds))

def welch(mask, y):
    a=y[mask]; b=y[~mask]
    effect=float(a.mean()-b.mean())
    tt=stats.ttest_ind(a,b,equal_var=False)
    return effect, float(tt.pvalue), int(mask.sum()), float(a.mean()), float(b.mean())

def did(a,b,y):
    a=a.astype(bool); b=b.astype(bool)
    cells=[]
    for am,bm in [(1,1),(1,0),(0,1),(0,0)]:
        m=(a==bool(am)) & (b==bool(bm))
        n=int(m.sum())
        if n < 300:
            return None
        yy=y[m]
        cells.append((n,float(yy.mean()),float(yy.var(ddof=1))))
    n11,m11,v11=cells[0]; n10,m10,v10=cells[1]; n01,m01,v01=cells[2]; n00,m00,v00=cells[3]
    d=m11-m10-m01+m00
    var=v11/n11+v10/n10+v01/n01+v00/n00
    se=var**0.5 if var>0 else np.nan
    if not isfinite(se) or se==0:
        p=np.nan
    else:
        # large-sample normal approximation is accurate at these cell sizes.
        p=2*stats.norm.sf(abs(d/se))
    subgroup=(a & b)
    eff,p_sub,n_sub,mean_sub,mean_rest=welch(subgroup,y)
    return {'interaction':float(d),'p_interaction':float(p),'n11':n11,'mean11':m11,'subgroup_effect':eff,'p_subgroup':p_sub,'mean_rest':mean_rest,
            'cell_means':(m11,m10,m01,m00),'cell_ns':(n11,n10,n01,n00)}

for ycol in outcomes:
    y=df[ycol].to_numpy()
    singles=[]
    for p in preds:
        eff,pv,n,ma,mb=welch(p['mask'],y)
        singles.append((eff,pv,n,ma,mb,p['name'],p['text'],p['feature']))
    singles_by_dep=sorted(singles, key=lambda r:(r[0], r[1]))
    singles_by_abs=sorted(singles, key=lambda r:abs(r[0]), reverse=True)
    print('\\n====', ycol, 'single most negative contrasts')
    for eff,pv,n,ma,mb,name,text,feat in singles_by_dep[:12]:
        print(f'{name:28s} n={n:5d} mean={ma:+.4f} rest={mb:+.4f} effect={eff:+.4f} p={pv:.3g}')
    print('single largest absolute contrasts')
    for eff,pv,n,ma,mb,name,text,feat in singles_by_abs[:8]:
        print(f'{name:28s} n={n:5d} effect={eff:+.4f} p={pv:.3g}')
    pairs=[]
    for i in range(len(preds)):
        for j in range(i+1,len(preds)):
            if preds[i]['feature']==preds[j]['feature']:
                continue
            r=did(preds[i]['mask'], preds[j]['mask'], y)
            if r is None: continue
            pairs.append((r['interaction'], r['p_interaction'], r['subgroup_effect'], r['p_subgroup'], r['n11'], r['mean11'], r['mean_rest'], preds[i]['name'], preds[j]['name'], r))
    neg_pairs=sorted(pairs, key=lambda r:(r[0], r[1]))
    pos_pairs=sorted(pairs, key=lambda r:(-r[0], r[1]))
    concentrated=sorted([r for r in pairs if r[2] < 0], key=lambda r:(r[2], r[3]))
    print('top negative interactions')
    for inter,pint,eff,psub,n,mean,rest,n1,n2,r in neg_pairs[:10]:
        print(f'{n1:24s} & {n2:24s} n={n:5d} mean11={mean:+.4f} subeff={eff:+.4f} int={inter:+.4f} p_int={pint:.3g} p_sub={psub:.3g}')
    print('top positive interactions')
    for inter,pint,eff,psub,n,mean,rest,n1,n2,r in pos_pairs[:5]:
        print(f'{n1:24s} & {n2:24s} n={n:5d} mean11={mean:+.4f} subeff={eff:+.4f} int={inter:+.4f} p_int={pint:.3g} p_sub={psub:.3g}')
    print('most concentrated negative subgroups')
    for inter,pint,eff,psub,n,mean,rest,n1,n2,r in concentrated[:10]:
        print(f'{n1:24s} & {n2:24s} n={n:5d} mean11={mean:+.4f} rest={rest:+.4f} subeff={eff:+.4f} int={inter:+.4f} p_int={pint:.3g}')
