for c in ['feature_016','feature_026','feature_028','feature_003','feature_023','feature_013','feature_025','feature_015','feature_017','feature_033','feature_031']:
    vals=df[c]
    q[c+'_q75']=float(vals.quantile(.75)); q[c+'_q25']=float(vals.quantile(.25)); q[c+'_q90']=float(vals.quantile(.90)); q[c+'_q10']=float(vals.quantile(.10))
