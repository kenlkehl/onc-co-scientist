'erbb2_f024': ('dependency_ERBB2', \"feature_024==1\", df['feature_024'].eq(1)),
'erbb2_f024_breast_high013': ('dependency_ERBB2', \"feature_024==1 & feature_011==breast & feature_013>=0.519\", df['feature_024'].eq(1)&df['feature_011'].eq('breast')&(df['feature_013']>=q['feature_013_q75'])),
'kras_f014': ('dependency_KRAS', \"feature_014==1\", df['feature_014'].eq(1)),
'kras_f014_high016_low028': ('dependency_KRAS', \"feature_014==1 & feature_016>=1.09 & feature_028<=-0.406\", df['feature_014'].eq(1)&(df['feature_016']>=q['feature_016_q90'])&(df['feature_028']<=q['feature_028_q25'])),
'rit1_f027': ('dependency_RIT1', \"feature_027==1\", df['feature_027'].eq(1)),
'rit1_f027_brain': ('dependency_RIT1', \"feature_027==1 & feature_011==brain\", df['feature_027'].eq(1)&df['feature_011'].eq('brain')),
'kif18a_colorectal': ('dependency_KIF18A', \"feature_011==colorectal\", df['feature_011'].eq('colorectal')),
'kif18a_final': ('dependency_KIF18A', \"feature_011==colorectal & feature_020==0 & feature_028>=1.43\", df['feature_011'].eq('colorectal')&df['feature_020'].eq(0)&(df['feature_028']>=q['feature_028_q90'])),
'tmed10_final': ('dependency_TMED10', \"feature_004==adherent & feature_016>=1.09 & feature_026>=1.15\", df['feature_004'].eq('adherent')&(df['feature_016']>=q['feature_016_q90'])&(df['feature_026']>=q['feature_026_q90'])),
dhx9_final': ('dependency_DHX9', \"feature_015<=2.08 & feature_016>=0.964 & feature_023>=5.67\", (df['feature_015']<=q['feature_015_q10'])&(df['feature_016']>=q['feature_016_q75'])&(df['feature_023']>=q['feature_023_q75'])),
'polr2a_high016': ('dependency_POLR2A', \"feature_016>=1.09\", df['feature_016']>=q['feature_016_q90']),
'polr2a_final': ('dependency_POLR2A', \"feature_005==batch_c & feature_016>=1.09 & feature_018==1\", df['feature_005'].eq('batch_c')&(df['feature_016']>=q['feature_016_q90'])&df['feature_018'].eq(1)),
rpl11_f018': ('dependency_RPL11', \"feature_018==1\", df['feature_018'].eq(1)),
