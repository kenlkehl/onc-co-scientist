/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

pd.set_option('display.max_colwidth', 200)
pd.set_option('display.width', 240)
df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]

# Build predicates: categorical levels, binary values, and continuous quartile/decile extremes.
preds=[]
cat_like=[]
for c in features:
    x=df[c]
    nun=x.nunique()
    if x.dtype=='object' or nun <= 10:
        for val in sorted(x.unique(), key=str):
            mask=(x==val).to_numpy()
            n=mask.sum()
            if 250 <= n <= len(df)-250:
                preds.append({'name':f'{c}=={val}', 'vars':frozenset([c]), 'mask':mask, 'n':int(n), 'kind':'level'})
    else:
        vals=x.astype(float)
        for q,op,label in [(0.75, '>=', 'high_q75'), (0.25, '<=', 'low_q25'), (0.90, '>=', 'high_q90'), (0.10, '<=', 'low_q10')]:
            thr=float(vals.quantile(q))
            if op=='>=':
                mask=(vals>=thr).to_numpy()
                name=f'{c}>={thr:.3g}'
            else:
                mask=(vals<=thr).to_numpy()
                name=f'{c}<={thr:.3g}'
            n=mask.sum()
            if 250 <= n <= len(df)-250:
                preds.append({'name':name, 'vars':frozenset([c]), 'mask':mask, 'n':int(n), 'kind':label})
print('predicates', len(preds))

def eval_mask(y, mask):
    yy=df[y].to_numpy(float)
    n=int(mask.sum())
    if n < 250 or len(mask)-n < 250:
        return None
    a=yy[mask]; b=yy[~mask]
    eff=float(a.mean()-b.mean())
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return {'n':n,'mean_in':float(a.mean()),'mean_out':float(b.mean()),'effect':eff,'p':float(p)}

# For each outcome, do level 1 exhaustive, level 2 exhaustive among top-ish single predicates, level 3 beam.
for y in outcomes:
    singles=[]
    for p in preds:
        r=eval_mask(y,p['mask'])
        if r:
            singles.append({**r,'defs':(p['name'],),'vars':p['vars'],'mask':p['mask']})
    # Top singles by negative effect, plus top by p if negative
    single_df=pd.DataFrame([{k:v for k,v in s.items() if k not in ('mask','vars')} for s in singles]).sort_values('effect')
    candidates=sorted(singles, key=lambda r:(r['effect'], r['p']))[:80]
    # Add strong p negative
    candidates_extra=sorted([s for s in singles if s['effect']<0], key=lambda r:r['p'])[:80]
    cand=[]; seen=set()
    for s in candidates+candidates_extra:
        key=s['defs']
        if key not in seen:
            cand.append(s); seen.add(key)
    pairs=[]
    for i in range(len(cand)):
        for j in range(i+1,len(cand)):
            if cand[i]['vars'] & cand[j]['vars']:
                continue
            mask=cand[i]['mask'] & cand[j]['mask']
            r=eval_mask(y,mask)
            if r:
                pairs.append({**r,'defs':cand[i]['defs']+cand[j]['defs'],'vars':cand[i]['vars']|cand[j]['vars'],'mask':mask})
    # keep beam for triples
    pair_beam=sorted(pairs, key=lambda r:(r['effect'], r['p']))[:100]
    triples=[]
    for base in pair_beam:
        for p in cand:
            if base['vars'] & p['vars']:
                continue
            # avoid duplicate unordered defs
            defs=tuple(sorted(base['defs']+p['defs']))
            mask=base['mask'] & p['mask']
            r=eval_mask(y,mask)
            if r:
                triples.append({**r,'defs':defs,'vars':base['vars']|p['vars'],'mask':mask})
    # dedup triples/pairs
    allres=singles+pairs+triples
    ded={}
    for r in allres:
        key=tuple(sorted(r['defs']))
        old=ded.get(key)
        if old is None or r['effect'] < old['effect']:
            rr={k:v for k,v in r.items() if k not in ('mask','vars')}
            rr['defs']=key
            ded[key]=rr
    table=pd.DataFrame(ded.values())
    table=table.sort_values(['effect','p']).head(15)
    print('\\nOUTCOME',y)
    print(table[['defs','n','mean_in','mean_out','effect','p']].to_string(index=False))
