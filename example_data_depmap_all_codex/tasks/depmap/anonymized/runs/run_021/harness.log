import pandas as pd
import numpy as np
from scipy import stats
try:
    import statsmodels.api as sm
    import statsmodels.formula.api as smf
    print('statsmodels ok')
except Exception as e:
    print('statsmodels unavailable', e)

pd.set_option('display.max_rows', 200)
pd.set_option('display.max_columns', 20)
df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
print('\\ncategory counts')
for c in ['feature_011','feature_010','feature_004','feature_005','feature_001']:
    print('\\n', c)
    print(df[c].value_counts().to_string())

# Main effect screen: categorical levels/binary mean diff vs rest; continuous slope per 1sd via Pearson/OLS
rows=[]
for y in outcomes:
    yy=df[y].astype(float)
    for c in features:
        x=df[c]
        if x.dtype == 'object' or x.nunique() <= 10:
            for val in sorted(x.dropna().unique(), key=str):
                mask=(x==val).to_numpy()
                n1=int(mask.sum()); n0=len(mask)-n1
                if n1 < 100 or n0 < 100: continue
                a=yy[mask]; b=yy[~mask]
                eff=float(a.mean()-b.mean())
                t,p=stats.ttest_ind(a,b,equal_var=False)
                rows.append(dict(outcome=y,feature=c,predicate=f'{c}=={val}',n=n1,effect=eff,p=float(p),kind='level',mean_in=float(a.mean()),mean_out=float(b.mean())))
        else:
            z=(x-x.mean())/x.std(ddof=0)
            slope, intercept, r, p, se = stats.linregress(z, yy)
            rows.append(dict(outcome=y,feature=c,predicate=f'{c} per +1 SD',n=len(df),effect=float(slope),p=float(p),kind='continuous',mean_in=np.nan,mean_out=np.nan))
main=pd.DataFrame(rows)
main['abs_effect']=main['effect'].abs()
main['neg_effect']=-main['effect']
# BH q per all tests
pvals=main['p'].values
order=np.argsort(pvals)
q=np.empty_like(pvals,dtype=float)
prev=1.0
m=len(pvals)
for rank,idx in enumerate(order[::-1], start=1):
    # easier compute from high to low
    pass
# Use standard
qvals=np.empty(m)
sorted_p=pvals[order]
min_q=1.0
for i in range(m-1,-1,-1):
    val=sorted_p[i]*m/(i+1)
    if val < min_q: min_q=val
    qvals[order[i]]=min_q
main['q']=np.minimum(qvals,1.0)
print('\\nTop 12 negative main effects by outcome (q<0.05 sorted effect)')
for y in outcomes:
    sub=main[(main.outcome==y)&(main.effect<0)].sort_values(['effect','p']).head(12)
    print('\\n',y)
    print(sub[['predicate','kind','n','effect','p','q','mean_in','mean_out']].to_string(index=False))
print('\\nTop main effects by p per outcome')
for y in outcomes:
    sub=main[main.outcome==y].sort_values('p').head(10)
    print('\\n',y)
    print(sub[['predicate','kind','n','effect','p','q','mean_in','mean_out']].to_string(index=False))

# Multi-variable one-hot OLS coefficients for all features: y ~ features
# Use pandas get_dummies for categorical object and feature_001 as categorical? maybe keep numeric values? Do both? We'll one-hot object + feature_001
X_parts=[]
cat_cols=['feature_011','feature_010','feature_004','feature_005','feature_001']
cont_bin=[c for c in features if c not in cat_cols]
X=pd.get_dummies(df[cat_cols].astype(str), drop_first=True)
# standardize continuous nonbinary? Keep binary as 0/1, continuous z
for c in cont_bin:
    vals=df[c].astype(float)
    if vals.nunique()>2:
        X[c]=(vals-vals.mean())/vals.std(ddof=0)
    else:
        X[c]=vals
X=sm.add_constant(X.astype(float))
print('\\nMultivariable OLS top coefficients by p')
for y in outcomes:
    model=sm.OLS(df[y].astype(float), X).fit()
    params=model.params.drop('const')
    pvals=model.pvalues.drop('const')
    table=pd.DataFrame({'term':params.index,'coef':params.values,'p':pvals.values})
    table['abscoef']=table.coef.abs(); table['q']=np.nan
    print('\\n', y, 'R2', model.rsquared)
    print(table.sort_values('p').head(12)[['term','coef','p']].to_string(index=False))
