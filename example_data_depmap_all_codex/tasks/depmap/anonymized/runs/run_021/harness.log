d['high033_75']=(d.feature_033>=q['feature_033_q75']).astype(int)
d['adherent']=(d.feature_004=='adherent').astype(int)
d['batch_c']=(d.feature_005=='batch_c').astype(int)
models=[
('BRAF_f009_skin','dependency_BRAF ~ feature_009*skin'),
('EGFR_f022_high016','dependency_EGFR ~ feature_022*high016_90'),
('ERBB2_f024_breast_high013','dependency_ERBB2 ~ feature_024*breast + feature_024*high013_75 + breast*high013_75'),
