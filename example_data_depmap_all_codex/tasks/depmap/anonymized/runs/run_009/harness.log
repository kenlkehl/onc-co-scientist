+  const out = r.readStruct({
+    1: { name: "type", read: readI },
+    2: { name: "uncompressed_page_size", read: readI },
+    3: { name: "compressed_page_size", read: readI },
+    4: { name: "crc", read: readI },
+    5: { name: "data_page_header", read: dataPageHeader },
+    7: { name: "dictionary_page_header", read: dictionaryPageHeader },
+    8: { name: "data_page_header_v2", read: dataPageHeaderV2 },
