+const fs = require("fs");
+const path = require("path");
+
+class Reader {
+  constructor(buf, off = 0) {
+    this.buf = buf;
+    this.off = off;
+  }
+  byte() {
+    return this.buf[this.off++];
+  }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  varintNum() {
+    return Number(this.varint());
+  }
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  zigzagNum() {
+    return Number(this.zigzag(this.varint()));
+  }
+  binary() {
+    const len = this.varintNum();
+    const out = this.buf.slice(this.off, this.off + len);
+    this.off += len;
+    return out;
+  }
+  skipType(t) {
+    switch (t) {
+      case 0:
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.byte();
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.varint();
+        return;
+      case 7:
+        this.off += 8;
+        return;
+      case 8:
+        this.off += this.varintNum();
+        return;
+      case 9:
+      case 10: {
+        const h = this.byte();
+        let len = h >> 4;
+        const et = h & 0x0f;
+        if (len === 15) len = this.varintNum();
+        for (let i = 0; i < len; i++) this.skipType(et);
+        return;
+      }
+      case 11: {
+        const len = this.varintNum();
+        if (len === 0) return;
+        const ktvt = this.byte();
+        const kt = ktvt >> 4;
+        const vt = ktvt & 0x0f;
+        for (let i = 0; i < len; i++) {
+          this.skipType(kt);
+          this.skipType(vt);
+        }
+        return;
+      }
+      case 12:
+        this.readStruct({});
+        return;
+      default:
+        throw new Error(`Unsupported thrift type ${t} at ${this.off}`);
+    }
+  }
+  list(elemReader) {
+    const h = this.byte();
+    let len = h >> 4;
+    const et = h & 0x0f;
+    if (len === 15) len = this.varintNum();
+    const out = [];
+    for (let i = 0; i < len; i++) out.push(elemReader.call(this, et));
+    return out;
+  }
+  readStruct(fieldReaders) {
+    const out = {};
+    let last = 0;
+    while (true) {
+      const h = this.byte();
+      const t = h & 0x0f;
+      if (t === 0) break;
+      let fid = h >> 4;
+      if (fid === 0) fid = this.zigzagNum();
+      else fid = last + fid;
+      last = fid;
+      const reader = fieldReaders[fid];
+      if (reader) out[reader.name] = reader.read.call(this, t);
+      else this.skipType(t);
+    }
+    return out;
+  }
+}
+
+function readI() {
+  return this.zigzagNum();
+}
+function readI64() {
+  return Number(this.zigzag(this.varint()));
+}
+function readStr(t) {
+  if (t !== 8) throw new Error(`Expected string, got thrift type ${t}`);
+  return this.binary().toString("utf8");
+}
+function readBytes(t) {
+  if (t !== 8) throw new Error(`Expected bytes, got thrift type ${t}`);
+  return this.binary();
+}
+function readBool(t) {
+  if (t === 1) return true;
+  if (t === 2) return false;
+  return Boolean(readI.call(this, t));
+}
+const listOf = (f) => function readList(t) {
+  if (t !== 9) throw new Error(`Expected list, got thrift type ${t}`);
+  return this.list(function readElem(et) {
+    return f.call(this, et);
+  });
+};
+
+function schemaElement(t) {
+  if (t !== 12) throw new Error("Expected schema struct");
+  return this.readStruct({
+    1: { name: "type", read: readI },
+    2: { name: "type_length", read: readI },
+    3: { name: "repetition_type", read: readI },
+    4: { name: "name", read: readStr },
+    5: { name: "num_children", read: readI },
+    6: { name: "converted_type", read: readI },
+    7: { name: "scale", read: readI },
+    8: { name: "precision", read: readI },
+    9: { name: "field_id", read: readI },
+  });
+}
+function stats(t) {
+  if (t !== 12) throw new Error("Expected statistics struct");
