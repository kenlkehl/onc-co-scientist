+summaryLines.push(`- dependency_RPL11 was strongest in feature_018 == 1 plus high-feature_016 lines: subgroup-vs-rest effect ${formatNum(selected.rpl11_feature018_feature016_high.pairEffect)}, interaction ${formatNum(selected.rpl11_feature018_feature016_high.effect)}, n=${selected.rpl11_feature018_feature016_high.nBoth}, p ${pString(selected.rpl11_feature018_feature016_high.p)}.`);
+summaryLines.push("");
+summaryLines.push("Systematic dependency-heterogeneity search:");
+for (const dep of depCols) {
+  const best = systematicRows[dep].topHeterogeneity[0];
+  const main = systematicRows[dep].topMain[0];
+  if (best) {
+    summaryLines.push(`- ${dep}: best two-predicate subgroup was ${best.a} AND ${best.b}; subgroup-vs-rest effect ${formatNum(best.pairEffect)}, interaction ${formatNum(best.effect)}, n=${best.nBoth}, p ${pString(best.p)}. Best single predicate was ${main.feature} ${main.level}, effect ${formatNum(main.effect)}, p ${pString(main.p)}.`);
+  } else {
+    summaryLines.push(`- ${dep}: no eligible two-predicate subgroup was found; best single predicate was ${main.feature} ${main.level}, effect ${formatNum(main.effect)}, p ${pString(main.p)}.`);
+  }
+}
+summaryLines.push("");
+summaryLines.push("Overall conclusion:");
+summaryLines.push("The strongest signals are not merely broad main effects. BRAF, EGFR, ERBB2, and KRAS each have a dominant binary feature association, with lineage-style feature_011 levels providing secondary context. KIF18A has a highly specific colorectal plus feature_035 == 1 dependency subgroup. RIT1, DHX9, POLR2A, TMED10, and RPL11 are tied to feature_027, feature_016, feature_018, and related quantitative feature strata, with the systematic search defining the best two-predicate subgroup for every outcome.");
+summaryLines.push("");
+summaryLines.push("Internal profile used during analysis:");
+summaryLines.push(...profileLines);
+
+fs.writeFileSync("transcript.json", `${JSON.stringify(transcript, null, 2)}\n`);
+fs.writeFileSync("analysis_summary.txt", `${summaryLines.join("\n")}\n`);
+
+console.log(JSON.stringify({
+  rows: meta.num_rows,
+  features: featureCols.length,
+  dependencies: depCols.length,
+  wrote: ["transcript.json", "analysis_summary.txt"],
+  selected,
+  systematicRows,
+}, null, 2));

