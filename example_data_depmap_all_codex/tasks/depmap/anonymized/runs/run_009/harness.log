+    ],
+    analyses: depCols.map((dep) => {
+      const best = systematicRows[dep].topHeterogeneity[0];
+      const main = systematicRows[dep].topMain[0];
+      const summary = best
+        ? `For ${dep}, the strongest two-predicate subgroup search hit was ${best.a} AND ${best.b}: subgroup-vs-rest effect ${formatNum(best.pairEffect)}, difference-in-differences ${formatNum(best.effect)}, n=${best.nBoth}, p ${pString(best.p)}. The strongest single-predicate negative hit was ${main.feature} ${main.level} with effect ${formatNum(main.effect)}, p ${pString(main.p)}.`
+        : `For ${dep}, the strongest single-predicate negative hit was ${main.feature} ${main.level} with effect ${formatNum(main.effect)}, p ${pString(main.p)}; no eligible two-predicate subgroup exceeded the minimum subgroup size.`;
+      return analysis("h15", summary, best ? best.pairEffect : main.effect, best ? best.p : main.p, `Automated screen of all feature main effects and pairwise subgroup interactions for ${dep}.`);
+    }),
+  },
+];
+
+const transcript = {
+  dataset_id: "ds001_depmap",
+  model_id: "gpt-5-codex",
+  harness_id: "codex-cli@local-node-parquet-analysis",
+  max_iterations: 10,
+  iterations,
