+    4: { name: "offset_index_offset", read: readI64 },
+    5: { name: "offset_index_length", read: readI },
+    6: { name: "column_index_offset", read: readI64 },
+    7: { name: "column_index_length", read: readI },
+  });
+}
+function rowGroup(t) {
+  if (t !== 12) throw new Error("Expected row group struct");
