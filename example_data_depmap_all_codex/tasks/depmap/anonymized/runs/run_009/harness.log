diff --git a/example_data_depmap/tasks/depmap/anonymized/._depmap_analysis.js b/example_data_depmap/tasks/depmap/anonymized/._depmap_analysis.js
new file mode 100644
index 0000000000000000000000000000000000000000..055bbb1d02652bab5d874b403bc9e796a416eefb
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/anonymized/._depmap_analysis.js
@@ -0,0 +1,912 @@
+const fs = require("fs");
+const path = require("path");
+
+class Reader {
+  constructor(buf, off = 0) {
+    this.buf = buf;
+    this.off = off;
+  }
+  byte() {
+    return this.buf[this.off++];
+  }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  varintNum() {
+    return Number(this.varint());
+  }
+  zigzag(n) {
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  zigzagNum() {
+    return Number(this.zigzag(this.varint()));
+  }
+  binary() {
+    const len = this.varintNum();
+    const out = this.buf.slice(this.off, this.off + len);
+    this.off += len;
+    return out;
+  }
+  skipType(t) {
+    switch (t) {
+      case 0:
+      case 1:
+      case 2:
+        return;
+      case 3:
+        this.byte();
+        return;
+      case 4:
+      case 5:
+      case 6:
+        this.varint();
+        return;
+      case 7:
+        this.off += 8;
+        return;
+      case 8:
+        this.off += this.varintNum();
+        return;
+      case 9:
+      case 10: {
+        const h = this.byte();
+        let len = h >> 4;
+        const et = h & 0x0f;
+        if (len === 15) len = this.varintNum();
+        for (let i = 0; i < len; i++) this.skipType(et);
+        return;
+      }
+      case 11: {
+        const len = this.varintNum();
+        if (len === 0) return;
+        const ktvt = this.byte();
