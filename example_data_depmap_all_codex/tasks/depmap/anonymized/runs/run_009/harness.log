+      if (strongest[i].feature === strongest[j].feature) continue;
+      const inter = interactionDiff(y, strongest[i].mask, strongest[j].mask);
+      if (inter.nBoth < 500) continue;
+      heterogeneity.push({
+        dep,
+        a: strongest[i],
+        b: strongest[j],
+        ...inter,
+      });
+    }
+  }
