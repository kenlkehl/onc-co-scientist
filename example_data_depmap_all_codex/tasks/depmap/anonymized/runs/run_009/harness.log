+    const s = info.summary;
+    profileLines.push(`- ${c}: numeric, mean ${formatNum(s.mean)}, sd ${formatNum(s.sd)}, Q1 ${formatNum(s.q25)}, median ${formatNum(s.median)}, Q3 ${formatNum(s.q75)}.`);
+  }
+}
+profileLines.push("");
+profileLines.push("Dependency profile:");
+for (const dep of depCols) {
+  const s = dependencySummaries[dep];
+  profileLines.push(`- ${dep}: mean ${formatNum(s.mean)}, sd ${formatNum(s.sd)}, min ${formatNum(s.min)}, Q1 ${formatNum(s.q25)}, median ${formatNum(s.median)}, Q3 ${formatNum(s.q75)}, max ${formatNum(s.max)}.`);
+}
+
+const summaryLines = [];
+summaryLines.push("CRISPR dependency map analysis summary for ds001_depmap");
+summaryLines.push("");
+summaryLines.push("I analyzed 50,000 cell-line records with 36 anonymized cell-line features and 10 dependency outcomes. More negative dependency scores indicate stronger dependency after knockout. I used Welch mean comparisons for categorical and quartile-defined numeric subgroups, continuous correlation checks for numeric features, and a systematic pairwise subgroup heterogeneity screen for every dependency outcome.");
+summaryLines.push("");
+summaryLines.push("Main lineage-style effects:");
+summaryLines.push(`- dependency_BRAF was strongly more negative in feature_011 == skin lines: effect ${formatNum(selected.braf_main.effect)}, p ${pString(selected.braf_main.p)}.`);
+summaryLines.push(`- dependency_EGFR was strongly more negative in feature_011 == lung lines: effect ${formatNum(selected.egfr_main.effect)}, p ${pString(selected.egfr_main.p)}.`);
+summaryLines.push(`- dependency_ERBB2 was strongly more negative in feature_011 == breast lines: effect ${formatNum(selected.erbb2_main.effect)}, p ${pString(selected.erbb2_main.p)}.`);
+summaryLines.push(`- dependency_KRAS was more negative in feature_011 == colorectal lines (effect ${formatNum(selected.kras_colorectal.effect)}, p ${pString(selected.kras_colorectal.p)}) and in feature_011 == lung lines (effect ${formatNum(selected.kras_lung.effect)}, p ${pString(selected.kras_lung.p)}).`);
+summaryLines.push("");
+summaryLines.push("Broad dependency program linked to feature_001:");
+summaryLines.push(`- The lowest quartile of feature_001 showed stronger dependency_RIT1 (effect ${formatNum(selected.rit1_low_feature001.effect)}, p ${pString(selected.rit1_low_feature001.p)}), dependency_KIF18A (effect ${formatNum(selected.kif18a_low_feature001.effect)}, p ${pString(selected.kif18a_low_feature001.p)}), dependency_TMED10 (effect ${formatNum(selected.tmed10_low_feature001.effect)}, p ${pString(selected.tmed10_low_feature001.p)}), dependency_DHX9 (effect ${formatNum(selected.dhx9_low_feature001.effect)}, p ${pString(selected.dhx9_low_feature001.p)}), dependency_POLR2A (effect ${formatNum(selected.polr2a_low_feature001.effect)}, p ${pString(selected.polr2a_low_feature001.p)}), and dependency_RPL11 (effect ${formatNum(selected.rpl11_low_feature001.effect)}, p ${pString(selected.rpl11_low_feature001.p)}).`);
+summaryLines.push("");
+summaryLines.push("Interaction and heterogeneity findings:");
+summaryLines.push(`- dependency_BRAF was most concentrated in skin lines with feature_026 in the lowest quartile: subgroup-vs-rest effect ${formatNum(selected.braf_subgroup.pairEffect)}, interaction ${formatNum(selected.braf_subgroup.effect)}, n=${selected.braf_subgroup.nBoth}, p ${pString(selected.braf_subgroup.p)}.`);
+summaryLines.push(`- dependency_ERBB2 was most concentrated in breast lines with feature_026 in the highest quartile: subgroup-vs-rest effect ${formatNum(selected.erbb2_subgroup.pairEffect)}, interaction ${formatNum(selected.erbb2_subgroup.effect)}, n=${selected.erbb2_subgroup.nBoth}, p ${pString(selected.erbb2_subgroup.p)}.`);
+summaryLines.push(`- For dependency_EGFR, high feature_016 attenuated the lung effect: the lung plus high-feature_016 interaction was ${formatNum(selected.egfr_suppress.effect)} while the subgroup-vs-rest effect remained ${formatNum(selected.egfr_suppress.pairEffect)} (n=${selected.egfr_suppress.nBoth}, p ${pString(selected.egfr_suppress.p)}).`);
+summaryLines.push("");
+summaryLines.push("Systematic dependency-heterogeneity search:");
+for (const dep of depCols) {
+  const best = systematicRows[dep].topHeterogeneity[0];
+  const main = systematicRows[dep].topMain[0];
+  if (best) {
+    summaryLines.push(`- ${dep}: best two-predicate subgroup was ${best.a} AND ${best.b}; subgroup-vs-rest effect ${formatNum(best.pairEffect)}, interaction ${formatNum(best.effect)}, n=${best.nBoth}, p ${pString(best.p)}. Best single predicate was ${main.feature} ${main.level}, effect ${formatNum(main.effect)}, p ${pString(main.p)}.`);
+  } else {
+    summaryLines.push(`- ${dep}: no eligible two-predicate subgroup was found; best single predicate was ${main.feature} ${main.level}, effect ${formatNum(main.effect)}, p ${pString(main.p)}.`);
+  }
+}
+summaryLines.push("");
+summaryLines.push("Overall conclusion:");
+summaryLines.push("The dataset contains strong, biologically coherent dependency signals: BRAF dependency is skin-enriched and sharpened by low feature_026; EGFR dependency is lung-enriched but attenuated by high feature_016; ERBB2 dependency is breast-enriched and sharpened by high feature_026; KRAS dependency is enriched in colorectal and lung groups. The remaining dependency outcomes share a broad low-feature_001 vulnerability pattern, consistent with a latent cell-state or screen-feature axis that increases dependency on RIT1, KIF18A, TMED10, DHX9, POLR2A, and RPL11.");
+summaryLines.push("");
+summaryLines.push("Internal profile used during analysis:");
+summaryLines.push(...profileLines);
+
+fs.writeFileSync("transcript.json", `${JSON.stringify(transcript, null, 2)}\n`);
+fs.writeFileSync("analysis_summary.txt", `${summaryLines.join("\n")}\n`);
+
