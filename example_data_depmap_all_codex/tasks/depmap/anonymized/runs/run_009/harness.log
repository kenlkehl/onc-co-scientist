+class Reader {
+  constructor(buf, off = 0) {
+    this.buf = buf;
+    this.off = off;
+  }
+  byte() {
+    return this.buf[this.off++];
+  }
+  varint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const b = this.byte();
+      result |= BigInt(b & 0x7f) << shift;
+      if ((b & 0x80) === 0) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  varintNum() {
+    return Number(this.varint());
+  }
+  zigzag(n) {
