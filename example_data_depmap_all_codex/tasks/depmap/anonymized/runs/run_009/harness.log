+}
+function dataPageHeader(t) {
+  if (t !== 12) throw new Error("Expected data page header struct");
+  return this.readStruct({
+    1: { name: "num_values", read: readI },
+    2: { name: "encoding", read: readI },
+    3: { name: "definition_level_encoding", read: readI },
+    4: { name: "repetition_level_encoding", read: readI },
+    5: { name: "statistics", read: stats },
+  });
+}
+function dataPageHeaderV2(t) {
+  if (t !== 12) throw new Error("Expected data page v2 header struct");
+  return this.readStruct({
+    1: { name: "num_values", read: readI },
+    2: { name: "num_nulls", read: readI },
+    3: { name: "num_rows", read: readI },
+    4: { name: "encoding", read: readI },
+    5: { name: "definition_levels_byte_length", read: readI },
+    6: { name: "repetition_levels_byte_length", read: readI },
+    7: { name: "is_compressed", read: readBool },
+    8: { name: "statistics", read: stats },
+  });
+}
+function dictionaryPageHeader(t) {
+  if (t !== 12) throw new Error("Expected dictionary page header struct");
+  return this.readStruct({
+    1: { name: "num_values", read: readI },
+    2: { name: "encoding", read: readI },
+    3: { name: "is_sorted", read: readBool },
+  });
