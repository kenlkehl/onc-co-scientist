+summaryLines.push(`- dependency_RPL11 was more negative in feature_018 == 1 lines: effect ${formatNum(selected.rpl11_feature018.effect)}, p ${pString(selected.rpl11_feature018.p)}.`);
+summaryLines.push("");
+summaryLines.push("Interaction and heterogeneity findings:");
+summaryLines.push(`- dependency_KIF18A showed the strongest interaction: feature_011 == colorectal plus feature_035 == 1 had subgroup-vs-rest effect ${formatNum(selected.kif18a_colorectal_feature035.pairEffect)}, interaction ${formatNum(selected.kif18a_colorectal_feature035.effect)}, n=${selected.kif18a_colorectal_feature035.nBoth}, p ${pString(selected.kif18a_colorectal_feature035.p)}.`);
+summaryLines.push(`- dependency_RIT1 was sharpened by feature_027 == 1 plus low feature_019: subgroup-vs-rest effect ${formatNum(selected.rit1_feature027_feature019_low.pairEffect)}, interaction ${formatNum(selected.rit1_feature027_feature019_low.effect)}, n=${selected.rit1_feature027_feature019_low.nBoth}, p ${pString(selected.rit1_feature027_feature019_low.p)}.`);
+summaryLines.push(`- dependency_DHX9 was strongest in high-feature_016 plus high-feature_023 lines: subgroup-vs-rest effect ${formatNum(selected.dhx9_feature016_feature023_high.pairEffect)}, interaction ${formatNum(selected.dhx9_feature016_feature023_high.effect)}, n=${selected.dhx9_feature016_feature023_high.nBoth}, p ${pString(selected.dhx9_feature016_feature023_high.p)}.`);
+summaryLines.push(`- dependency_RPL11 was strongest in feature_018 == 1 plus high-feature_016 lines: subgroup-vs-rest effect ${formatNum(selected.rpl11_feature018_feature016_high.pairEffect)}, interaction ${formatNum(selected.rpl11_feature018_feature016_high.effect)}, n=${selected.rpl11_feature018_feature016_high.nBoth}, p ${pString(selected.rpl11_feature018_feature016_high.p)}.`);
+summaryLines.push("");
+summaryLines.push("Systematic dependency-heterogeneity search:");
