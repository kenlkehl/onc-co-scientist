+}
+
+const summaryLines = [];
+summaryLines.push("CRISPR dependency map analysis summary for ds001_depmap");
+summaryLines.push("");
+summaryLines.push("I analyzed 50,000 cell-line records with 36 anonymized cell-line features and 10 dependency outcomes. More negative dependency scores indicate stronger dependency after knockout. I used Welch mean comparisons for categorical and quartile-defined numeric subgroups, continuous correlation checks for numeric features, and a systematic pairwise subgroup heterogeneity screen for every dependency outcome.");
+summaryLines.push("");
+summaryLines.push("Strongest single-feature effects:");
+summaryLines.push(`- dependency_BRAF was most strongly associated with feature_009 == 1: effect ${formatNum(selected.braf_feature009.effect)}, p ${pString(selected.braf_feature009.p)}. feature_011 == skin was a secondary association with effect ${formatNum(selected.braf_skin.effect)}, p ${pString(selected.braf_skin.p)}.`);
+summaryLines.push(`- dependency_EGFR was most strongly associated with feature_022 == 1: effect ${formatNum(selected.egfr_feature022.effect)}, p ${pString(selected.egfr_feature022.p)}. feature_011 == brain was a weaker but significant association with effect ${formatNum(selected.egfr_brain.effect)}, p ${pString(selected.egfr_brain.p)}.`);
+summaryLines.push(`- dependency_ERBB2 was most strongly associated with feature_024 == 1: effect ${formatNum(selected.erbb2_feature024.effect)}, p ${pString(selected.erbb2_feature024.p)}. feature_011 == breast also had more negative scores, effect ${formatNum(selected.erbb2_breast.effect)}, p ${pString(selected.erbb2_breast.p)}.`);
+summaryLines.push(`- dependency_KRAS was most strongly associated with feature_014 == 1: effect ${formatNum(selected.kras_feature014.effect)}, p ${pString(selected.kras_feature014.p)}. feature_011 == pancreatic and feature_011 == colorectal were additional negative associations, effects ${formatNum(selected.kras_pancreatic.effect)} and ${formatNum(selected.kras_colorectal.effect)}.`);
+summaryLines.push("");
+summaryLines.push("Other dependency outcomes:");
+summaryLines.push(`- dependency_RIT1 was more negative in feature_027 == 1 lines: effect ${formatNum(selected.rit1_feature027.effect)}, p ${pString(selected.rit1_feature027.p)}.`);
+summaryLines.push(`- dependency_KIF18A was more negative in feature_011 == colorectal lines: effect ${formatNum(selected.kif18a_colorectal.effect)}, p ${pString(selected.kif18a_colorectal.p)}.`);
+summaryLines.push(`- dependency_TMED10, dependency_DHX9, and dependency_POLR2A were more negative in the highest quartile of feature_016: effects ${formatNum(selected.tmed10_feature016_high.effect)}, ${formatNum(selected.dhx9_feature016_high.effect)}, and ${formatNum(selected.polr2a_feature016_high.effect)}, respectively.`);
+summaryLines.push(`- dependency_RPL11 was more negative in feature_018 == 1 lines: effect ${formatNum(selected.rpl11_feature018.effect)}, p ${pString(selected.rpl11_feature018.p)}.`);
+summaryLines.push("");
+summaryLines.push("Interaction and heterogeneity findings:");
+summaryLines.push(`- dependency_KIF18A showed the strongest interaction: feature_011 == colorectal plus feature_035 == 1 had subgroup-vs-rest effect ${formatNum(selected.kif18a_colorectal_feature035.pairEffect)}, interaction ${formatNum(selected.kif18a_colorectal_feature035.effect)}, n=${selected.kif18a_colorectal_feature035.nBoth}, p ${pString(selected.kif18a_colorectal_feature035.p)}.`);
+summaryLines.push(`- dependency_RIT1 was sharpened by feature_027 == 1 plus low feature_019: subgroup-vs-rest effect ${formatNum(selected.rit1_feature027_feature019_low.pairEffect)}, interaction ${formatNum(selected.rit1_feature027_feature019_low.effect)}, n=${selected.rit1_feature027_feature019_low.nBoth}, p ${pString(selected.rit1_feature027_feature019_low.p)}.`);
+summaryLines.push(`- dependency_DHX9 was strongest in high-feature_016 plus high-feature_023 lines: subgroup-vs-rest effect ${formatNum(selected.dhx9_feature016_feature023_high.pairEffect)}, interaction ${formatNum(selected.dhx9_feature016_feature023_high.effect)}, n=${selected.dhx9_feature016_feature023_high.nBoth}, p ${pString(selected.dhx9_feature016_feature023_high.p)}.`);
+summaryLines.push(`- dependency_RPL11 was strongest in feature_018 == 1 plus high-feature_016 lines: subgroup-vs-rest effect ${formatNum(selected.rpl11_feature018_feature016_high.pairEffect)}, interaction ${formatNum(selected.rpl11_feature018_feature016_high.effect)}, n=${selected.rpl11_feature018_feature016_high.nBoth}, p ${pString(selected.rpl11_feature018_feature016_high.p)}.`);
+summaryLines.push("");
+summaryLines.push("Systematic dependency-heterogeneity search:");
