 inter.sort((a,b)=>Math.abs(b.z)-Math.abs(a.z)); console.log('"'top interactions:'); for(const r of inter.slice(0,8)) console.log(r.a,'AND',r.b,'n11',r.n11,'m11',fmt(r.m11),'intEff',fmt(r.effect),'z',fmt(r.z),'p',r.p.toExponential(2));
