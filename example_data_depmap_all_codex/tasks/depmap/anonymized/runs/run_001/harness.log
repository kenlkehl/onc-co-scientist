class CompactReader { constructor(buf, offset=0, end=buf.length){this.buf=buf;this.pos=offset;this.end=end;this.stack=[0];} readByte(){if(this.pos>=this.end)throw Error('eof '+this.pos);return this.buf[this.pos++];} readVarint(){let shift=0n,res=0n;while(true){const b=this.readByte();res|=BigInt(b&127)<<shift;if("'!(b&128))break;shift+=7n;}return res;} zig(n){return(n>>1n)''^(-(n&1n));} readI32(){return Number(this.zig(this.readVarint()));} readI64(){const x=this.zig(this.readVarint());return Number(x);} readDouble(){const v=this.buf.readDoubleLE(this.pos);this.pos+=8;return v;} readBinary(){const n=Number(this.readVarint());const s=this.buf.slice(this.pos,this.pos+n);this.pos+=n;return s;} readString(){return this.readBinary().toString('"'utf8');} readListHeader(){const b=this.readByte();let size=b>>4;const type=b&15;if(size===15)size=Number(this.readVarint());return{size,type};} readValue(t){switch(t){case 1:return true;case 2:return false;case 3:return this.readByte();case 4:return this.readI32();case 5:return this.readI32();case 6:return this.readI64();case 7:return this.readDouble();case 8:return this.readString();case 9:case 10:{const h=this.readListHeader(),a=[];for(let i=0;i<h.size;i++)a.push(this.readValue(h.type));return a;}case 11:{const size=Number(this.readVarint()),out=[];if("'!size)return out;const types=this.readByte();for(let i=0;i<size;i++)out.push([this.readValue(types>>4),this.readValue(types&15)]);return out;}case 12:return this.readStruct();default:throw Error('"'unknown type '+t+' pos '+this.pos);}} readStruct(){this.stack.push(0);const o={};while(true){const h=this.readByte();const t=h&15;if(t===0)break;const d=h>>4;const fid=d?this.stack[this.stack.length-1]+d:this.readI32();this.stack[this.stack.length-1]=fid;o[fid]=this.readValue(t);}this.stack.pop();return o;} }
function snappyUncompress(input){let ip=0,len=0,shift=0;while(true){const b=input[ip++];len|=(b&127)<<shift;if("'!(b&128))break;shift+=7;}const out=Buffer.allocUnsafe(len);let op=0;while(ip<input.length){const tag=input[ip++],type=tag&3;if(type===0){let l=tag>>2;if(l<60)l+=1;else{const n=l-59;l=0;for(let i=0;i<n;i++)l|=input[ip++]<<(8*i);l+=1;}input.copy(out,op,ip,ip+l);ip+=l;op+=l;}else if(type===1){const l=((tag>>2)&7)+4;const off=((tag&224)<<3)|input[ip++];for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}else if(type===2){const l=(tag>>2)+1;const off=input[ip]|(input[ip+1]<<8);ip+=2;for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}else{const l=(tag>>2)+1;const off=input[ip]|(input[ip+1]<<8)|(input[ip+2]<<16)|(input[ip+3]<<24);ip+=4;for(let i=0;i<l;i++)out[op+i]=out[op-off+i];op+=l;}}if(op!==len)throw Error('"'snappy mismatch');return out;}
function readFooter(buf){const fl=buf.readUInt32LE(buf.length-8);const st=buf.length-8-fl;return new CompactReader(buf,st,buf.length-8).readStruct();}
function readPlain(body,type,count){const vals=[];let p=0;for(let i=0;i<count;i++){if(type===5){vals.push(body.readDoubleLE(p));p+=8;}else if(type===2){vals.push(Number(body.readBigInt64LE(p)));p+=8;}else if(type===1){vals.push(body.readInt32LE(p));p+=4;}else if(type===6){const n=body.readUInt32LE(p);p+=4;vals.push(body.slice(p,p+n).toString('utf8'));p+=n;}else throw Error('plain type '+type);}return vals;}
function readUVar(buf,pos){let shift=0,res=0;while(true){const b=buf[pos.p++];res|=(b&127)<<shift;if("'!(b&128))break;shift+=7;}return res;}
function readHybrid(buf,pos,bitWidth,count){const out=[];const bytesPer=Math.ceil(bitWidth/8);while(out.length<count&&pos.p<buf.length){const header=readUVar(buf,pos);if((header&1)===0){const run=header>>1;let val=0;for(let i=0;i<bytesPer;i++)val|=(buf[pos.p++]||0)<<(8*i);for(let i=0,n=Math.min(run,count-out.length);i<n;i++)out.push(val);}else{const groups=header>>1,nvals=groups*8;let bitPos=0;for(let i=0;i<nvals;i++){let val=0;for(let b=0;b<bitWidth;b++){const byte=buf[pos.p+(bitPos>>3)];if(byte&(1<<(bitPos&7)))val|=1<<b;bitPos++;}if(out.length<count)out.push(val);}pos.p+=Math.ceil(bitPos/8);}}if(out.length!==count)throw Error('"'hybrid count');return out;}
function readColumn(buf,cm,type){const dict=[],values=[];const start=cm[11]??cm[9],end=start+Number(cm[7]);let pos=start;while(pos<end){const pr=new CompactReader(buf,pos);const ph=pr.readStruct();const bodyStart=pr.pos;const comp=Number(ph[3]),uncomp=Number(ph[2]);const body=cm[4]===1?snappyUncompress(buf.slice(bodyStart,bodyStart+comp)):buf.slice(bodyStart,bodyStart+comp);if(body.length"'!==uncomp)throw Error('"'uncomp mismatch');if(ph[1]===2){dict.push(...readPlain(body,type,ph[7][1]));}else if(ph[1]===0){const dh=ph[5],n=dh[1],enc=dh[2];let off=0;const defLen=body.readUInt32LE(off);off+=4+defLen;if(enc===8||enc===2){const bw=body[off++];const idxs=readHybrid(body,{p:off},bw,n);for(const ix of idxs)values.push(dict[ix]);}else if(enc===0){values.push(...readPlain(body.slice(off),type,n));}else throw Error('enc '+enc);}pos=bodyStart+comp;}return values;}
function load(){const file=fs.readFileSync('dataset.parquet');const meta=readFooter(file),cols=meta[4][0][1];const data={};for(const cc of cols){const cm=cc[3],name=cm[3].join('.'),type=cm[1];data[name]=readColumn(file,cm,type);}return data;}

function erf(x){const sign=x<0?-1:1; x=Math.abs(x); const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911; const t=1/(1+p*x); const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x); return sign*y;}
function pNorm2(z){z=Math.abs(z); if("'!isFinite(z))return 1e-300; if(z>37)return 1e-300; const p=1-erf(z/Math.SQRT2); return Math.max(p,1e-300);}
function groupStats(y,mask){let n1=0,n0=0,s1=0,s0=0,ss1=0,ss0=0;for(let i=0;i<y.length;i++){const v=y[i];if(mask[i]){n1++;s1+=v;ss1+=v*v;}else{n0++;s0+=v;ss0+=v*v;}}const m1=s1/n1,m0=s0/n0;const v1=(ss1-s1*s1/n1)/(n1-1),v0=(ss0-s0*s0/n0)/(n0-1);const se=Math.sqrt(v1/n1+v0/n0);const eff=m1-m0;const z=eff/se;return{n1,n0,m1,m0,v1,v0,effect:eff,z,p:pNorm2(z),significant:pNorm2(z)<0.05};}
function corrStats(x,y){const n=x.length;let sx=0,sy=0;for(let i=0;i<n;i++){sx+=x[i];sy+=y[i];}const mx=sx/n,my=sy/n;let sxx=0,syy=0,sxy=0;for(let i=0;i<n;i++){const dx=x[i]-mx,dy=y[i]-my;sxx+=dx*dx;syy+=dy*dy;sxy+=dx*dy;}const slope=sxy/sxx;const r=sxy/Math.sqrt(sxx*syy);const z=Math.abs(r)*Math.sqrt((n-2)/Math.max(1e-12,1-r*r));return{slope,r,z,p:pNorm2(z)};}
function quantile(arr,q){const a=[...arr].sort((x,y)=>x-y);const pos=(a.length-1)*q;const lo=Math.floor(pos),hi=Math.ceil(pos);return lo===hi?a[lo]:a[lo]+(a[hi]-a[lo])*(pos-lo);}
function mean(arr,mask=null){let s=0,n=0;for(let i=0;i<arr.length;i++)if(!mask||mask[i]){s+=arr[i];n++;}return s/n;}
function unique(arr){return [...new Set(arr)];}
function maskFrom(arr,pred){const m=new Uint8Array(arr.length);let n=0;for(let i=0;i<arr.length;i++){if(pred(arr[i],i)){m[i]=1;n++;}}m.n=n;return m;}
function andMask(a,b){const m=new Uint8Array(a.length);let n=0;for(let i=0;i<a.length;i++){if(a[i]&&b[i]){m[i]=1;n++;}}m.n=n;return m;}
function notContradict(a,b){return a.col!==b.col;}
function fmt(x){if(Math.abs(x)<1e-4&&x!==0)return x.toExponential(2);return x.toFixed(4);}
const data=load();const cols=Object.keys(data);const features=cols.filter(c=>c.startsWith('"'feature_'));const outcomes=cols.filter(c=>c.startsWith('dependency_'));const n=data[outcomes[0]].length;
