import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat=[c for c in features if df[c].dtype=='object']
num=[c for c in features if c not in cat]
binary=[c for c in num if df[c].nunique()==2]
continuous=[c for c in num if df[c].nunique()>10]
lowcard=[c for c in num if 2<df[c].nunique()<=10]
print('cat',cat)
print('binary',len(binary),binary)
print('lowcard',lowcard)
print('continuous',len(continuous),continuous)

def welch(mask, y):
    a=y[mask]
    b=y[~mask]
    if len(a)<20 or len(b)<20: return None
    eff=float(np.mean(a)-np.mean(b))
    res=stats.ttest_ind(a,b,equal_var=False)
    return eff, float(res.pvalue), int(mask.sum()), float(np.mean(a)), float(np.mean(b))

# predicates: binary =1, categorical levels, lowcard values, cont high/low quartile
preds=[]
for c in binary:
    m=df[c].astype(bool).to_numpy(); preds.append((f'{c}=1', m, c))
for c in cat:
    for val in sorted(df[c].unique()):
        m=(df[c]==val).to_numpy(); preds.append((f'{c}={val}', m, c))
for c in lowcard:
    for val in sorted(df[c].unique()):
        m=(df[c]==val).to_numpy(); preds.append((f'{c}={val:g}', m, c))
for c in continuous:
    q25=df[c].quantile(.25); q75=df[c].quantile(.75)
    preds.append((f'{c}<=Q1({q25:.3g})', (df[c]<=q25).to_numpy(), c))
    preds.append((f'{c}>=Q3({q75:.3g})', (df[c]>=q75).to_numpy(), c))

print('\\nTOP SINGLE SUBGROUPS')
for ycol in outcomes:
    y=df[ycol].to_numpy()
    rows=[]
    for name,m,c in preds:
        r=welch(m,y)
        if r and r[2]>=200:
            eff,p,n,ma,mb=r
            rows.append((eff,p,name,n,ma,mb))
    rows.sort(key=lambda x:x[0])
    print('\\n',ycol)
    for eff,p,name,n,ma,mb in rows[:12]:
        print(f'{name:32s} n={n:5d} mean={ma: .4f} rest={mb: .4f} diff={eff: .4f} p={p:.2e}')

# top positive too? likely suppressing dependency
print('\\nTOP POSITIVE SINGLE SUBGROUPS')
for ycol in outcomes:
    y=df[ycol].to_numpy(); rows=[]
    for name,m,c in preds:
        r=welch(m,y)
        if r and r[2]>=200:
            eff,p,n,ma,mb=r; rows.append((eff,p,name,n,ma,mb))
    rows.sort(key=lambda x:-x[0])
    print('\\n',ycol)
    for eff,p,name,n,ma,mb in rows[:8]:
        print(f'{name:32s} n={n:5d} mean={ma: .4f} rest={mb: .4f} diff={eff: .4f} p={p:.2e}')

# pairwise intersections among predicates from different source cols, min n 300, max maybe many.
print('\\nTOP PAIR SUBGROUPS')
for ycol in outcomes:
    y=df[ycol].to_numpy(); rows=[]
    for i,j in combinations(range(len(preds)),2):
        n1,m1,c1=preds[i]
        n2,m2,c2=preds[j]
        if c1==c2: continue
        m=m1 & m2
        n=int(m.sum())
        if n<300 or n>25000: continue
        r=welch(m,y)
        if r:
            eff,p,n,ma,mb=r
            rows.append((eff,p,n1,n2,n,ma,mb))
    rows.sort(key=lambda x:x[0])
    print('\\n',ycol)
    for eff,p,n1,n2,n,ma,mb in rows[:15]:
        print(f'{n1} AND {n2} n={n:5d} mean={ma: .4f} rest={mb: .4f} diff={eff: .4f} p={p:.2e}')
