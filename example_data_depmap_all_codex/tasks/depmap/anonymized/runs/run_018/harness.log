import pandas as pd, numpy as np, statsmodels.api as sm
from scipy import stats

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat=['feature_011','feature_010','feature_004','feature_005','feature_001']
binary=[c for c in df.columns if c.startswith('feature_') and df[c].dtype"'!='"'object' and df[c].nunique()==2]
cont=[c for c in df.columns if c.startswith('feature_') and df[c].dtype"'!='"'object' and df[c].nunique()>10]
# standardize continuous
X_parts=[]
X_parts.append(pd.get_dummies(df[cat].astype(str), drop_first=True, dtype=float))
X_parts.append(df[binary].astype(float).reset_index(drop=True))
Z=(df[cont]-df[cont].mean())/df[cont].std(ddof=0)
Z.columns=[c+'_z' for c in cont]
X_parts.append(Z.reset_index(drop=True))
X=pd.concat(X_parts, axis=1)
X=sm.add_constant(X, has_constant='add')
print('design',X.shape)
for ycol in outcomes:
    model=sm.OLS(df[ycol].to_numpy(), X.to_numpy()).fit()
    names=list(X.columns)
    coefs=pd.Series(model.params,index=names)
    pvals=pd.Series(model.pvalues,index=names)
    rows=[]
    for name in names:
        if name=='const': continue
        rows.append((coefs[name],pvals[name],name))
    rows=sorted(rows,key=lambda x:abs(x[0]),reverse=True)
    print('\\n',ycol,'R2',model.rsquared)
    for coef,p,name in rows[:15]:
        print(f'{name:36s} coef={coef: .4f} p={p:.2e}')
