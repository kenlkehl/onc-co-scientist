import json
from pathlib import Path

import numpy as np
import pandas as pd
from scipy import stats
import statsmodels.api as sm

base_dir = Path('.')
df = pd.read_parquet(base_dir / 'dataset.parquet')

q = {c: float(df[c].quantile(0.75)) for c in ['feature_016','feature_028','feature_017','feature_003','feature_023','feature_026']}
q1 = {c: float(df[c].quantile(0.25)) for c in ['feature_016','feature_028','feature_017','feature_003','feature_023','feature_026']}

masks = {
    'f009': df['feature_009'].eq(1),
    'f022': df['feature_022'].eq(1),
    'f024': df['feature_024'].eq(1),
    'f014': df['feature_014'].eq(1),
    'f027': df['feature_027'].eq(1),
    'f035': df['feature_035'].eq(1),
    'f020': df['feature_020'].eq(1),
    'f030': df['feature_030'].eq(1),
    'colorectal': df['feature_011'].eq('colorectal'),
    'skin': df['feature_011'].eq('skin'),
    'brain': df['feature_011'].eq('brain'),
    'pancreatic': df['feature_011'].eq('pancreatic'),
    'breast': df['feature_011'].eq('breast'),
    'hematopoietic': df['feature_011'].eq('hematopoietic'),
    'her2_enriched': df['feature_010'].eq('her2_enriched'),
    'luminal': df['feature_010'].eq('luminal'),
    'prostate': df['feature_011'].eq('prostate'),
    'feature_016_hi': df['feature_016'].ge(q['feature_016']),
    'feature_016_lo': df['feature_016'].le(q1['feature_016']),
    'feature_028_hi': df['feature_028'].ge(q['feature_028']),
    'feature_003_hi': df['feature_003'].ge(q['feature_003']),
    'feature_023_hi': df['feature_023'].ge(q['feature_023']),
    'feature_026_hi': df['feature_026'].ge(q['feature_026']),
}


def clean_float(x):
    if x is None:
        return None
    x = float(x)
    if np.isnan(x) or np.isinf(x):
        return None
    return x


def ptext(p):
    p = clean_float(p)
    if p is None:
        return 'p unavailable'
    if p == 0.0:
        return 'p<1e-300'
    return f'p={p:.2e}'


def f4(x):
    return f'{float(x):.4f}'


def welch_stats(ycol, mask):
    mask = pd.Series(mask, index=df.index).astype(bool)
    a = df.loc[mask, ycol].to_numpy()
    b = df.loc[~mask, ycol].to_numpy()
    t = stats.ttest_ind(a, b, equal_var=False)
    return {
        'n_subgroup': int(mask.sum()),
        'n_comparison': int((~mask).sum()),
        'subgroup_mean': clean_float(a.mean()),
        'comparison_mean': clean_float(b.mean()),
        'effect': clean_float(a.mean() - b.mean()),
        'p': clean_float(t.pvalue),
    }


def two_group_stats(ycol, mask_a, mask_b):
    mask_a = pd.Series(mask_a, index=df.index).astype(bool)
    mask_b = pd.Series(mask_b, index=df.index).astype(bool)
    a = df.loc[mask_a, ycol].to_numpy()
    b = df.loc[mask_b, ycol].to_numpy()
    t = stats.ttest_ind(a, b, equal_var=False)
    return {
        'n_group_a': int(mask_a.sum()),
        'n_group_b': int(mask_b.sum()),
        'group_a_mean': clean_float(a.mean()),
        'group_b_mean': clean_float(b.mean()),
        'effect': clean_float(a.mean() - b.mean()),
        'p': clean_float(t.pvalue),
    }


def interaction_stats(ycol, base_mask, modifier_mask):
    base = pd.Series(base_mask, index=df.index).astype(int).to_numpy()
    mod = pd.Series(modifier_mask, index=df.index).astype(int).to_numpy()
    inter = base * mod
    X = sm.add_constant(pd.DataFrame({'base': base, 'modifier': mod, 'interaction': inter}), has_constant='add')
    fit = sm.OLS(df[ycol].to_numpy(), X.to_numpy()).fit()
    return {
        'effect': clean_float(fit.params[3]),
        'p': clean_float(fit.pvalues[3]),
        'n_base_and_modifier': int(inter.sum()),
        'n_base_without_modifier': int((base * (1 - mod)).sum()),
        'n_modifier_without_base': int(((1 - base) * mod).sum()),
        'n_neither': int(((1 - base) * (1 - mod)).sum()),
    }


def add_welch_analysis(analyses, hypothesis_ids, ycol, mask, label, code, method='Welch two-sample t-test'):
    s = welch_stats(ycol, mask)
    analyses.append({
        'hypothesis_ids': hypothesis_ids,
        'code': code,
        'result_summary': (
            f'{label}: subgroup mean {f4(s[\"subgroup_mean\"])} vs comparison mean {f4(s[\"comparison_mean\"])}, '
            f'effect {f4(s[\"effect\"])} on {ycol}; {ptext(s[\"p\"])}.'
        ),
        'p_value': s['p'],
        'effect_estimate': s['effect'],
        'significant': bool(s['p'] is not None and s['p'] < 0.05),
        'method': method,
        'n_subgroup': s['n_subgroup'],
        'n_comparison': s['n_comparison'],
        'subgroup_mean': s['subgroup_mean'],
        'comparison_mean': s['comparison_mean'],
    })
    return s


def add_two_group_analysis(analyses, hypothesis_ids, ycol, mask_a, mask_b, label, code):
    s = two_group_stats(ycol, mask_a, mask_b)
    analyses.append({
        'hypothesis_ids': hypothesis_ids,
        'code': code,
        'result_summary': (
            f'{label}: group A mean {f4(s[\"group_a_mean\"])} vs group B mean {f4(s[\"group_b_mean\"])}, '
            f'effect {f4(s[\"effect\"])} on {ycol}; {ptext(s[\"p\"])}.'
        ),
        'p_value': s['p'],
        'effect_estimate': s['effect'],
        'significant': bool(s['p'] is not None and s['p'] < 0.05),
        'method': 'Welch two-sample t-test within a fixed subgroup',
        'n_group_a': s['n_group_a'],
        'n_group_b': s['n_group_b'],
        'group_a_mean': s['group_a_mean'],
        'group_b_mean': s['group_b_mean'],
    })
    return s


def add_interaction_analysis(analyses, hypothesis_ids, ycol, base_mask, modifier_mask, label, code, screen=False):
    s = interaction_stats(ycol, base_mask, modifier_mask)
    analyses.append({
        'hypothesis_ids': hypothesis_ids,
        'code': code,
        'result_summary': (
            f'{label}: interaction coefficient {f4(s[\"effect\"])} on {ycol}; {ptext(s[\"p\"])}. '
            f'Cell counts base+modifier/base-only/modifier-only/neither = '
            f'{s[\"n_base_and_modifier\"]}/{s[\"n_base_without_modifier\"]}/{s[\"n_modifier_without_base\"]}/{s[\"n_neither\"]}.'
        ),
        'p_value': s['p'],
        'effect_estimate': s['effect'],
        'significant': bool(s['p'] is not None and s['p'] < 0.05),
        'method': 'OLS interaction model: dependency ~ base + modifier + base:modifier',
        'systematic_screen_result': bool(screen),
        **{k: v for k, v in s.items() if k.startswith('n_')},
    })
    return s


def adjusted_design():
    feature_cols = [c for c in df.columns if c.startswith('feature_')]
    cat = ['feature_011', 'feature_010', 'feature_004', 'feature_005', 'feature_001']
    binary = [c for c in feature_cols if df[c].dtype "'!= '"'object' and df[c].nunique() == 2]
    cont = [c for c in feature_cols if df[c].dtype "'!= '"'object' and df[c].nunique() > 10]
    parts = [pd.get_dummies(df[cat].astype(str), drop_first=True, dtype=float), df[binary].astype(float).reset_index(drop=True)]
    z = (df[cont] - df[cont].mean()) / df[cont].std(ddof=0)
    z.columns = [c + '_z' for c in cont]
    parts.append(z.reset_index(drop=True))
    X = pd.concat(parts, axis=1)
    X = sm.add_constant(X, has_constant='add')
    return X

X_adj = adjusted_design()
adj_cache = {}

def adjusted_coef(ycol, term):
    if ycol not in adj_cache:
        fit = sm.OLS(df[ycol].to_numpy(), X_adj.to_numpy()).fit()
        adj_cache[ycol] = fit
    fit = adj_cache[ycol]
    idx = list(X_adj.columns).index(term)
    return {
        'effect': clean_float(fit.params[idx]),
        'p': clean_float(fit.pvalues[idx]),
        'r_squared': clean_float(fit.rsquared),
    }


def add_adjusted_analysis(analyses, hypothesis_ids, ycol, term, label):
    s = adjusted_coef(ycol, term)
    analyses.append({
        'hypothesis_ids': hypothesis_ids,
        'code': f'sm.OLS(df[{ycol"'!r}], adjusted_design_all_features).fit().params[{term!r}]'"',
        'result_summary': f'{label}: adjusted coefficient {f4(s[\"effect\"])} on {ycol}; {ptext(s[\"p\"])}; model R"'^2={s["r_squared"]:.3f}.'"',
        'p_value': s['p'],
        'effect_estimate': s['effect'],
        'significant': bool(s['p'] is not None and s['p'] < 0.05),
        'method': 'OLS adjusted for categorical lineage/subtype/culture/batch/feature_001, all binary indicators, and standardized continuous features',
        'r_squared': s['r_squared'],
        'adjusted_term': term,
    })
    return s

iterations = []

# Iteration 1
analyses = []
hypotheses = [
    {'id': 'h1', 'text': 'Cell lines with "'`feature_009` equal to 1 have more negative `dependency_BRAF` scores than cell lines with `feature_009` equal to 0.'"', 'kind': 'novel'},
    {'id': 'h2', 'text': 'Cell lines with "'`feature_022` equal to 1 have more negative `dependency_EGFR` scores than cell lines with `feature_022` equal to 0.'"', 'kind': 'novel'},
    {'id': 'h3', 'text': 'Cell lines with "'`feature_024` equal to 1 have more negative `dependency_ERBB2` scores than cell lines with `feature_024` equal to 0.'"', 'kind': 'novel'},
    {'id': 'h4', 'text': 'Cell lines with "'`feature_014` equal to 1 have more negative `dependency_KRAS` scores than cell lines with `feature_014` equal to 0.'"', 'kind': 'novel'},
    {'id': 'h5', 'text': 'Cell lines with "'`feature_027` equal to 1 have more negative `dependency_RIT1` scores than cell lines with `feature_027` equal to 0.'"', 'kind': 'novel'},
]
add_welch_analysis(analyses, ['h1'], 'dependency_BRAF', masks['f009'], '"'`feature_009=1` versus all other lines'"', \"stats.ttest_ind(df.loc[df.feature_009==1,'dependency_BRAF'], df.loc[df.feature_009==0,'dependency_BRAF'], equal_var=False)\")
add_welch_analysis(analyses, ['h2'], 'dependency_EGFR', masks['f022'], '"'`feature_022=1` versus all other lines'"', \"stats.ttest_ind(df.loc[df.feature_022==1,'dependency_EGFR'], df.loc[df.feature_022==0,'dependency_EGFR'], equal_var=False)\")
add_welch_analysis(analyses, ['h3'], 'dependency_ERBB2', masks['f024'], '"'`feature_024=1` versus all other lines'"', \"stats.ttest_ind(df.loc[df.feature_024==1,'dependency_ERBB2'], df.loc[df.feature_024==0,'dependency_ERBB2'], equal_var=False)\")
add_welch_analysis(analyses, ['h4'], 'dependency_KRAS', masks['f014'], '"'`feature_014=1` versus all other lines'"', \"stats.ttest_ind(df.loc[df.feature_014==1,'dependency_KRAS'], df.loc[df.feature_014==0,'dependency_KRAS'], equal_var=False)\")
add_welch_analysis(analyses, ['h5'], 'dependency_RIT1', masks['f027'], '"'`feature_027=1` versus all other lines'"', \"stats.ttest_ind(df.loc[df.feature_027==1,'dependency_RIT1'], df.loc[df.feature_027==0,'dependency_RIT1'], equal_var=False)\")
iterations.append({'index': 1, 'proposed_hypotheses': hypotheses, 'analyses': analyses, 'update': 'Strong binary-feature main effects appeared for BRAF, EGFR, ERBB2, KRAS, and RIT1, motivating lineage and subtype interaction checks.'})

# Iteration 2
analyses = []
hypotheses = [
    {'id': 'h6', 'text': 'The "'`dependency_BRAF` signal is especially concentrated in the subgroup with `feature_009=1` and `feature_011="skin"`, which should have more negative scores than all other cell lines.'"', 'kind': 'refined'},
