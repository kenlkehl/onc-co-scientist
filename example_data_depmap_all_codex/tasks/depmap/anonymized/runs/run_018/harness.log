/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
import statsmodels.api as sm

df=pd.read_parquet('dataset.parquet')

def welch(y, mask):
    a=df.loc[mask,y].to_numpy(); b=df.loc[~mask,y].to_numpy()
    r=stats.ttest_ind(a,b,equal_var=False)
    return {'n':int(mask.sum()),'mean':float(a.mean()),'rest_mean':float(b.mean()),'diff':float(a.mean()-b.mean()),'p':float(r.pvalue)}

def print_w(y, label, mask):
    r=welch(y, mask)
    print(y, label, r)

# thresholds
qs={c:(float(df[c].quantile(.25)),float(df[c].quantile(.75))) for c in ['feature_016','feature_028','feature_017','feature_003','feature_023','feature_026','feature_020'] if c in df}
print('thresholds',qs)
col=(df.feature_011=='colorectal')
f35=df.feature_035==1
f28hi=df.feature_028>=df.feature_028.quantile(.75)
f17hi=df.feature_017>=df.feature_017.quantile(.75)
f20=df.feature_020==1
print('\\nKIF18A subgroup comparisons')
for label,mask in [
    ('colorectal',col),
    ('feature_035=1',f35),
    ('feature_028>=Q3',f28hi),
    ('colorectal & feature_035=1',col&f35),
    ('colorectal & feature_028>=Q3',col&f28hi),
    ('colorectal & feature_035=1 & feature_028>=Q3',col&f35&f28hi),
    ('colorectal & feature_035=1 & feature_028>=Q3 & feature_020=0',col&f35&f28hi&(~f20)),
    ('colorectal & feature_035=1 & feature_028>=Q3 & feature_017>=Q3',col&f35&f28hi&f17hi),
]: print_w('dependency_KIF18A',label,mask)
print('\\nKIF18A means within colorectal by feature_035 and f28hi and f20')
for masklabel, m in [('all colorectal', col),('colorectal f35=1', col&f35),('colorectal f35=0', col&~f35)]:
    for label, sub in [('f28hi=1',f28hi),('f28hi=0',~f28hi),('f20=1',f20),('f20=0',~f20)]:
        mm=m&sub
        print(masklabel,label,'n',int(mm.sum()),'mean',float(df.loc[mm,'dependency_KIF18A'].mean()))

# KIF18A interaction models
def ols_inter(y, terms):
    # terms dict name->array; include all main and selected interactions generated separately
    X=pd.DataFrame(terms)
    X=sm.add_constant(X.astype(float))
    model=sm.OLS(df[y],X).fit()
    print('\\nOLS',y, 'R2',model.rsquared)
    for name,val,p in zip(X.columns,model.params,model.pvalues):
        print(f'{name:30s} coef={val: .4f} p={p:.2e}')

ols_inter('dependency_KIF18A',{
    'colorectal':col.astype(int), 'feature_035':f35.astype(int), 'feature_028_hi':f28hi.astype(int), 'feature_020':f20.astype(int),
    'colorectal_x_feature_035':(col&f35).astype(int),
    'colorectal_x_feature_028_hi':(col&f28hi).astype(int),
    'feature_035_x_feature_028_hi':(f35&f28hi).astype(int),
    'colorectal_x_feature_020':(col&f20).astype(int),
})

print('\\nKRAS/BRAF lineage interactions')
for y,driver,lineages in [('dependency_KRAS',df.feature_014==1,['pancreatic','colorectal','lung','breast']),('dependency_BRAF',df.feature_009==1,['skin','colorectal','lung','hematopoietic']),('dependency_EGFR',df.feature_022==1,['brain','lung','colorectal']),('dependency_ERBB2',df.feature_024==1,['breast','gastric','lung'])]:
    print('\\n',y)
    for lin in lineages:
        l=df.feature_011==lin
        # driver effect within lineage
        if (driver&l).sum()>20 and ((~driver)&l).sum()>20:
            a=df.loc[driver&l,y]; b=df.loc[(~driver)&l,y]
            print(lin,'driver effect within lineage n1/n0',int((driver&l).sum()),int(((~driver)&l).sum()),'diff',float(a.mean()-b.mean()),'means',float(a.mean()),float(b.mean()),'p',float(stats.ttest_ind(a,b,equal_var=False).pvalue))
        # subgroup vs rest
        print_w(y,f'{lin} & driver=1',driver&l)

print('\\nEssential outcome subgroups')
f16hi=df.feature_016>=df.feature_016.quantile(.75)
f16lo=df.feature_016<=df.feature_016.quantile(.25)
f23hi=df.feature_023>=df.feature_023.quantile(.75)
f3hi=df.feature_003>=df.feature_003.quantile(.75)
f18=df.feature_018==1
for y, masks in {
 'dependency_POLR2A':[('feature_016>=Q3',f16hi),('feature_016<=Q1',f16lo)],
 'dependency_DHX9':[('feature_016>=Q3',f16hi),('feature_023>=Q3',f23hi),('feature_016>=Q3 & feature_023>=Q3',f16hi&f23hi)],
 'dependency_TMED10':[('feature_016>=Q3',f16hi),('feature_026>=Q3',df.feature_026>=df.feature_026.quantile(.75)),('feature_016>=Q3 & feature_026>=Q3',f16hi&(df.feature_026>=df.feature_026.quantile(.75)))],
 'dependency_RPL11':[('feature_018=1',f18),('feature_003>=Q3',f3hi),('feature_018=1 & feature_003>=Q3',f18&f3hi),('feature_016>=Q3 & feature_003>=Q3',f16hi&f3hi)]
}.items():
    print('\\n',y)
    for label,mask in masks: print_w(y,label,mask)

# Interaction for RPL11 and DHX9
ols_inter('dependency_RPL11',{'feature_018':f18.astype(int),'feature_003_hi':f3hi.astype(int),'feature_016_hi':f16hi.astype(int),'feature_018_x_feature_003_hi':(f18&f3hi).astype(int),'feature_016_hi_x_feature_003_hi':(f16hi&f3hi).astype(int)})
ols_inter('dependency_DHX9',{'feature_016_hi':f16hi.astype(int),'feature_023_hi':f23hi.astype(int),'feature_018':f18.astype(int),'feature_016_hi_x_feature_023_hi':(f16hi&f23hi).astype(int),'feature_016_hi_x_feature_018':(f16hi&f18).astype(int)})
