import pandas as pd, numpy as np, statsmodels.api as sm
from scipy import stats

df=pd.read_parquet('dataset.parquet')
# Build candidate predicates for interaction screen
preds=[]
# categorical levels
for c in ['feature_011','feature_010','feature_004','feature_005']:
    for val in sorted(df[c].unique()):
        m=(df[c]==val).to_numpy().astype(int)
        if 300 <= m.sum() <= 49700: preds.append((f'{c}={val}',m,c))
# lowcard values
for val in sorted(df.feature_001.unique()):
    m=(df.feature_001==val).to_numpy().astype(int)
    preds.append((f'feature_001={val:g}',m,'feature_001'))
# binaries
for c in [c for c in df.columns if c.startswith('feature_') and df[c].dtype"'!='"'object' and df[c].nunique()==2]:
    m=(df[c]==1).to_numpy().astype(int)
    preds.append((f'{c}=1',m,c))
# continuous quartiles high and low
for c in [c for c in df.columns if c.startswith('feature_') and df[c].dtype"'!='"'object' and df[c].nunique()>10]:
    q1=df[c].quantile(.25); q3=df[c].quantile(.75)
    preds.append((f'{c}<=Q1({q1:.3g})',(df[c]<=q1).to_numpy().astype(int),c))
    preds.append((f'{c}>=Q3({q3:.3g})',(df[c]>=q3).to_numpy().astype(int),c))

base_defs={
 'dependency_BRAF':('feature_009=1',(df.feature_009==1).to_numpy().astype(int),'feature_009'),
 'dependency_EGFR':('feature_022=1',(df.feature_022==1).to_numpy().astype(int),'feature_022'),
 'dependency_ERBB2':('feature_024=1',(df.feature_024==1).to_numpy().astype(int),'feature_024'),
 'dependency_KRAS':('feature_014=1',(df.feature_014==1).to_numpy().astype(int),'feature_014'),
 'dependency_RIT1':('feature_027=1',(df.feature_027==1).to_numpy().astype(int),'feature_027'),
 'dependency_KIF18A':('feature_011=colorectal',(df.feature_011=='colorectal').to_numpy().astype(int),'feature_011'),
 'dependency_TMED10':('feature_016>=Q3(0.964)',(df.feature_016>=df.feature_016.quantile(.75)).to_numpy().astype(int),'feature_016'),
 'dependency_DHX9':('feature_016>=Q3(0.964)',(df.feature_016>=df.feature_016.quantile(.75)).to_numpy().astype(int),'feature_016'),
 'dependency_POLR2A':('feature_016>=Q3(0.964)',(df.feature_016>=df.feature_016.quantile(.75)).to_numpy().astype(int),'feature_016'),
 'dependency_RPL11':('feature_003>=Q3(0.428)',(df.feature_003>=df.feature_003.quantile(.75)).to_numpy().astype(int),'feature_003'),
}
print('Interaction screen top terms: coefficient is base x modifier in y ~ base + modifier + base:modifier')
for ycol,(bname,b,bcol) in base_defs.items():
    y=df[ycol].to_numpy()
    rows=[]
    for name,m,col in preds:
        if col==bcol or np.array_equal(m,b) or np.array_equal(m,1-b): continue
        inter=b*m
        n11=int(inter.sum()); n10=int((b*(1-m)).sum()); n01=int(((1-b)*m).sum()); n00=int(((1-b)*(1-m)).sum())
        if min(n11,n10,n01,n00)<100: continue
        X=np.column_stack([np.ones(len(y)), b, m, inter])
        try:
            mod=sm.OLS(y,X).fit()
        except Exception:
            continue
        rows.append((mod.params[3], mod.pvalues[3], name, n11, n10, n01, n00))
    rows=sorted(rows,key=lambda x:x[0])
    print('\\n',ycol,'base',bname)
    print('most negative interactions')
    for coef,p,name,n11,n10,n01,n00 in rows[:8]:
        print(f'{name:34s} coef={coef: .4f} p={p:.2e} cells {n11}/{n10}/{n01}/{n00}')
    print('most positive interactions')
    for coef,p,name,n11,n10,n01,n00 in rows[-8:][::-1]:
        print(f'{name:34s} coef={coef: .4f} p={p:.2e} cells {n11}/{n10}/{n01}/{n00}')
