The feature matrix has a mix of lineage-like categories, binary flags, and continuous measurements. I’m going to combine main-effect screens with exhaustive subgroup scans so every dependency outcome gets both direct and heterogeneity checks.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations
from math import isfinite

df=pd.read_parquet('dataset.parquet')
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat_features=[c for c in features if df[c].dtype=='object']
# treat low-card numeric as categorical
lowcard=[c for c in features if df[c].dtype"'!='"'object' and df[c].nunique()<=6]
bin_features=[c for c in features if df[c].dtype"'!='"'object' and set(df[c].unique()).issubset({0,1})]
cont_features=[c for c in features if c not in cat_features+lowcard and c not in bin_features]
print('cats',cat_features,'lowcard',lowcard,'bin',len(bin_features),bin_features,'cont',len(cont_features),cont_features)

def welch(y,mask):
    a=y[mask]
    b=y[~mask]
    if len(a)<2 or len(b)<2: return np.nan,np.nan,len(a),len(b),np.nan,np.nan
    effect=a.mean()-b.mean()
    p=stats.ttest_ind(a,b,equal_var=False).pvalue
    return effect,p,len(a),len(b),a.mean(),b.mean()

# create predicate masks
preds=[]
for c in cat_features:
    for lev in sorted(df[c].unique()):
        m=(df[c]==lev).to_numpy()
        preds.append((f'{c} == {lev}', c, str(lev), m))
for c in lowcard:
    for lev in sorted(df[c].unique()):
        m=(df[c]==lev).to_numpy()
        preds.append((f'{c} == {lev:g}', c, str(lev), m))
for c in bin_features:
    m=(df[c]==1).to_numpy()
    preds.append((f'{c} == 1', c, '1', m))
for c in cont_features:
    q25=df[c].quantile(.25); q75=df[c].quantile(.75)
    preds.append((f'{c} <= Q1 ({q25:.3g})', c, 'low', (df[c]<=q25).to_numpy()))
    preds.append((f'{c} >= Q3 ({q75:.3g})', c, 'high', (df[c]>=q75).to_numpy()))
print('predicates',len(preds))

# main univariate: continuous slopes and predicate differences
for out in outcomes:
    y=df[out].to_numpy()
    rec=[]
    # predicate diff
    for name,c,v,m in preds:
        n=m.sum()
        if n<200 or n>len(df)-200: continue
        eff,p,n1,n0,ma,mb=welch(y,m)
        rec.append((p,eff,name,n1,ma,mb,'group'))
    # continuous slope per SD
    for c in cont_features:
        x=df[c].to_numpy().astype(float)
        xs=(x-x.mean())/x.std(ddof=0)
        slope, intercept, r, p, se=stats.linregress(xs,y)
        rec.append((p,slope,f'{c} per +1 SD',len(df),np.nan,np.nan,'slope'))
    rec=sorted([r for r in rec if np.isfinite(r[0])], key=lambda r:r[0])
    print('\\nMAIN',out)
    for p,eff,name,n,ma,mb,typ in rec[:12]:
        if typ=='group':
            print(f'  {name:32s} n={n:5d} eff={eff:+.4f} mean={ma:+.4f} other={mb:+.4f} p={p:.2e}')
        else:
            print(f'  {name:32s} slope={eff:+.4f} p={p:.2e}')

# Pairwise/triple subgroup search with no same feature conflict.
def bh_q(pvals):
    p=np.array(pvals,float); n=len(p)
    order=np.argsort(p); q=np.empty(n,float); prev=1.0
    for idx in order[::-1]:
        rank=np.where(order==idx)[0][0]+1
    # efficient
    sortedp=p[order]
    adj=sortedp*n/np.arange(1,n+1)
    adj=np.minimum.accumulate(adj[::-1])[::-1]
    q[order]=np.minimum(adj,1.0)
    return q

for out in outcomes:
    y=df[out].to_numpy()
    rows=[]
    # singles and pairs
    for i,(n1,f1,v1,m1) in enumerate(preds):
        n=m1.sum()
        if 300<=n<=len(df)-300:
            eff,p,_,_,ma,mb=welch(y,m1)
            rows.append({'defs':(n1,), 'features':(f1,), 'mask':m1, 'n':int(n), 'eff':eff,'p':p,'mean':ma,'other':mb})
    for i,j in combinations(range(len(preds)),2):
        n1,f1,v1,m1=preds[i]; n2,f2,v2,m2=preds[j]
        if f1==f2: continue
        m=m1 & m2; n=m.sum()
        if n<300 or n>len(df)-300: continue
        eff,p,_,_,ma,mb=welch(y,m)
        if np.isfinite(p):
            rows.append({'defs':(n1,n2), 'features':(f1,f2), 'mask':m, 'n':int(n), 'eff':eff,'p':p,'mean':ma,'other':mb})
    # extend top 150 negative rows to triples
    seeds=sorted(rows, key=lambda r:(r['eff'], r['p']))[:150]
    seen=set(tuple(sorted(r['defs'])) for r in rows)
    for r in seeds:
        for name,f,v,m0 in preds:
            if f in r['features']: continue
            defs=tuple(sorted(r['defs']+(name,)))
            if defs in seen: continue
            seen.add(defs)
            m=r['mask'] & m0; n=m.sum()
            if n<300 or n>len(df)-300: continue
            eff,p,_,_,ma,mb=welch(y,m)
            if np.isfinite(p):
                rows.append({'defs':defs, 'features':r['features']+(f,), 'mask':m, 'n':int(n), 'eff':eff,'p':p,'mean':ma,'other':mb})
    rows=[r for r in rows if np.isfinite(r['p'])]
    qs=bh_q([r['p'] for r in rows])
    for r,q in zip(rows,qs): r['q']=q
    # rank by strong mean lower and significance, prefer effects not tiny and not only batch
    neg=sorted(rows, key=lambda r:(r['eff'], r['q']))
    print('\\nSUBGROUP',out,'searched',len(rows))
    for r in neg[:15]:
        print(f\"  n={r['n']:5d} eff={r['eff']:+.4f} mean={r['mean']:+.4f} other={r['other']:+.4f} p={r['p']:.1e} q={r['q']:.1e} :: \" + ' AND '.join(r['defs']))
