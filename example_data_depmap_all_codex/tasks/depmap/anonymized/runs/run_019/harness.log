import json
from pathlib import Path
import pandas as pd
import numpy as np
from scipy import stats

base = Path('.')
df = pd.read_parquet(base / 'dataset.parquet')
N = len(df)

def pformat(p):
    if p == 0 or p < 1e-300:
        return '<1e-300'
    return f'{p:.3g}'

def welch(outcome, mask):
    m = np.asarray(mask, dtype=bool)
    y = df[outcome].to_numpy(float)
    a = y[m]
    b = y[~m]
    res = stats.ttest_ind(a, b, equal_var=False)
    return {
        'n': int(m.sum()),
        'group_mean': float(a.mean()),
        'comparator_mean': float(b.mean()),
        'effect': float(a.mean() - b.mean()),
        'p': float(res.pvalue),
    }

def subset_contrast(outcome, mask_a, mask_b):
    a = df.loc[mask_a, outcome].to_numpy(float)
    b = df.loc[mask_b, outcome].to_numpy(float)
    res = stats.ttest_ind(a, b, equal_var=False)
    return {
        'n': int(len(a)),
        'comparator_n': int(len(b)),
        'group_mean': float(a.mean()),
        'comparator_mean': float(b.mean()),
        'effect': float(a.mean() - b.mean()),
        'p': float(res.pvalue),
    }

def ols_term(outcome, terms, term_name):
    names = ['Intercept'] + list(terms.keys())
    X = np.column_stack([np.ones(N)] + [np.asarray(v, dtype=float) for v in terms.values()])
    y = df[outcome].to_numpy(float)
    beta = np.linalg.lstsq(X, y, rcond=None)[0]
    resid = y - X @ beta
    n, p = X.shape
    rank = np.linalg.matrix_rank(X)
    dfree = n - rank
    s2 = float(resid @ resid / dfree)
    cov = np.linalg.pinv(X.T @ X) * s2
    se = np.sqrt(np.maximum(np.diag(cov), 0))
    t = beta / se
    pv = 2 * stats.t.sf(np.abs(t), dfree)
    i = names.index(term_name)
    return {
        'effect': float(beta[i]),
        'se': float(se[i]),
        'p': float(pv[i]),
        'df': int(dfree),
    }

def adjusted_design():
    features = [c for c in df.columns if c.startswith('feature_')]
    cat = [c for c in features if df[c].dtype == 'object' and c "'!= '"'feature_004']
    bin_f = [c for c in features if df[c].dtype "'!= '"'object' and set(df[c].unique()).issubset({0, 1})]
    cont = [c for c in features if df[c].dtype "'!= '"'object' and c "'!= '"'feature_001' and c not in bin_f]
    X_parts = [np.ones(N)]
    names = ['Intercept']
    for c in cat:
        vals = sorted(df[c].unique())
        for v in vals[1:]:
            names.append(f'{c}={v}')
            X_parts.append(df[c].eq(v).to_numpy(float))
    for v in sorted(df['feature_001'].unique())[1:]:
        names.append(f'feature_001={v:g}')
        X_parts.append(df['feature_001'].eq(v).to_numpy(float))
    for c in bin_f:
        names.append(c)
        X_parts.append(df[c].to_numpy(float))
    for c in cont:
        x = df[c].to_numpy(float)
        names.append(f'{c}_z')
        X_parts.append((x - x.mean()) / x.std(ddof=0))
    return np.column_stack(X_parts), names

X_adj, adj_names = adjusted_design()
adj_rank = np.linalg.matrix_rank(X_adj)

def adjusted_term(outcome, term_name):
    y = df[outcome].to_numpy(float)
    beta = np.linalg.lstsq(X_adj, y, rcond=None)[0]
    resid = y - X_adj @ beta
    dfree = N - adj_rank
    s2 = float(resid @ resid / dfree)
    cov = np.linalg.pinv(X_adj.T @ X_adj) * s2
    se = np.sqrt(np.maximum(np.diag(cov), 0))
    t = beta / se
    pv = 2 * stats.t.sf(np.abs(t), dfree)
    i = adj_names.index(term_name)
    return {'effect': float(beta[i]), 'se': float(se[i]), 'p': float(pv[i]), 'df': int(dfree)}

def make_analysis(hids, method, summary, result, extra=None):
    rec = {
        'hypothesis_ids': hids,
        'method': method,
        'result_summary': summary,
        'effect_estimate': result.get('effect'),
        'p_value': result.get('p'),
        'significant': bool(result.get('p') is not None and result.get('p') < 0.05),
    }
    for key in ['n', 'comparator_n', 'group_mean', 'comparator_mean', 'se', 'df']:
