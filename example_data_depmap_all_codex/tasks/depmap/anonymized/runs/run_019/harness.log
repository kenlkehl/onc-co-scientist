import pandas as pd
import numpy as np
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print(df.shape)
print(df.dtypes.to_string())
print('\\nFirst rows:')
print(df.head().to_string())
features=[c for c in df.columns if c.startswith('feature_')]
outcomes=[c for c in df.columns if c.startswith('dependency_')]
print('\\nFeature unique counts/prevalence:')
for c in features:
    vals=df[c].unique()
    print(c, df[c].dtype, len(vals), sorted(vals)[:10], 'mean=', float(df[c].mean()) if np.issubdtype(df[c].dtype, np.number) else None)
print('\\nOutcome summary:')
print(df[outcomes].describe().T.to_string())
print('\\nOutcome correlations:')
print(df[outcomes].corr().round(3).to_string())
