/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]

def welch(out, mask):
    y=df[out].to_numpy(); m=np.asarray(mask,bool)
    a=y[m]; b=y[~m]
    t=stats.ttest_ind(a,b,equal_var=False)
    return dict(outcome=out,n=int(m.sum()),mean=float(a.mean()),other_mean=float(b.mean()),effect=float(a.mean()-b.mean()),p=float(t.pvalue))

def print_w(name,out,mask):
    r=welch(out,mask)
    print(f\"{name:55s} {out:20s} n={r['n']:5d} mean={r['mean']:+.6f} other={r['other_mean']:+.6f} eff={r['effect']:+.6f} p={r['p']:.4e}\")

def ols_coef(y, X, names, term):
    y=np.asarray(y,float); X=np.asarray(X,float)
    beta=np.linalg.lstsq(X,y,rcond=None)[0]
    resid=y-X@beta
    n,p=X.shape
    s2=float(resid@resid/(n-p))
    XtX_inv=np.linalg.inv(X.T@X)
    se=np.sqrt(np.diag(XtX_inv)*s2)
    t=beta/se
    pv=2*stats.t.sf(np.abs(t), n-p)
    idx=names.index(term)
    return dict(term=term,beta=float(beta[idx]),se=float(se[idx]),t=float(t[idx]),p=float(pv[idx]),df=int(n-p))

def interaction(out, terms, term_name):
    # terms dict bool/float vectors, include intercept automatically
    names=['Intercept']+list(terms.keys())
    X=[np.ones(len(df))]+[np.asarray(v,float) for v in terms.values()]
    res=ols_coef(df[out].to_numpy(), np.column_stack(X), names, term_name)
    print(f\"OLS {out:20s} {term_name:35s} beta={res['beta']:+.6f} se={res['se']:.6f} p={res['p']:.4e}\")
    return res

q=lambda c,p: df[c].quantile(p)
high016=df['feature_016']>=q('feature_016',.75)
low016=df['feature_016']<=q('feature_016',.25)
high026=df['feature_026']>=q('feature_026',.75)
high028=df['feature_028']>=q('feature_028',.75)
low017=df['feature_017']<=q('feature_017',.25)
high017=df['feature_017']>=q('feature_017',.75)
high023=df['feature_023']>=q('feature_023',.75)
low023=df['feature_023']<=q('feature_023',.25)
high031=df['feature_031']>=q('feature_031',.75)
high003=df['feature_003']>=q('feature_003',.75)
col=df['feature_011'].eq('colorectal')
skin=df['feature_011'].eq('skin')
brain=df['feature_011'].eq('brain')
panc=df['feature_011'].eq('pancreatic')
squam=df['feature_010'].eq('squamous')

print('Quantiles:')
for c in ['feature_016','feature_026','feature_028','feature_017','feature_023','feature_031','feature_003']:
    print(c,'q25',q(c,.25),'q75',q(c,.75))
print('\\nSelected Welch tests:')
sel=[
('feature_009 == 1','dependency_BRAF',df.feature_009.eq(1)),
('skin lineage','dependency_BRAF',skin),
('feature_009 == 1 AND skin','dependency_BRAF',df.feature_009.eq(1)&skin),
('feature_022 == 1','dependency_EGFR',df.feature_022.eq(1)),
('feature_022 == 1 AND high feature_016','dependency_EGFR',df.feature_022.eq(1)&high016),
('feature_024 == 1','dependency_ERBB2',df.feature_024.eq(1)),
('feature_024 == 1 AND high feature_026','dependency_ERBB2',df.feature_024.eq(1)&high026),
('feature_014 == 1','dependency_KRAS',df.feature_014.eq(1)),
('feature_014 == 1 AND pancreatic','dependency_KRAS',df.feature_014.eq(1)&panc),
('feature_027 == 1','dependency_RIT1',df.feature_027.eq(1)),
('feature_027 == 1 AND brain','dependency_RIT1',df.feature_027.eq(1)&brain),
('colorectal','dependency_KIF18A',col),
('feature_035 == 1','dependency_KIF18A',df.feature_035.eq(1)),
('high feature_028','dependency_KIF18A',high028),
('colorectal AND feature_035 == 1','dependency_KIF18A',col&df.feature_035.eq(1)),
('colorectal AND feature_035 == 1 AND high feature_028','dependency_KIF18A',col&df.feature_035.eq(1)&high028),
('high feature_016','dependency_TMED10',high016),
('high feature_016 AND feature_027 == 1 AND low feature_017','dependency_TMED10',high016&df.feature_027.eq(1)&low017),
('high feature_016','dependency_DHX9',high016),
('high feature_023','dependency_DHX9',high023),
('squamous AND high feature_023 AND feature_029 == 0','dependency_DHX9',squam&high023&df.feature_029.eq(0)),
('high feature_016','dependency_POLR2A',high016),
('skin AND high feature_016 AND high feature_026','dependency_POLR2A',skin&high016&high026),
('feature_018 == 1','dependency_RPL11',df.feature_018.eq(1)),
('high feature_003','dependency_RPL11',high003),
('feature_018 == 1 AND high feature_016 AND high feature_031','dependency_RPL11',df.feature_018.eq(1)&high016&high031),
]
for name,out,mask in sel:
    print_w(name,out,mask)

print('\\nWithin-subgroup contrasts:')
# within colorectal KIF18A, both features vs rest colorectal
m_base=col; m_en=col & df.feature_035.eq(1)&high028
a=df.loc[m_en,'dependency_KIF18A']; b=df.loc[m_base & ~m_en,'dependency_KIF18A']
print(f\"KIF18A within colorectal enabled n={len(a)} vs other colorectal n={len(b)} mean={a.mean():+.6f} other={b.mean():+.6f} eff={a.mean()-b.mean():+.6f} p={stats.ttest_ind(a,b,equal_var=False).pvalue:.4e}\")
# feature035 only within colorectal high028? high028 only within colorectal f035?
for desc,maskA,maskB in [
    ('feature_035 effect inside colorectal & high028', col&high028&df.feature_035.eq(1), col&high028&df.feature_035.eq(0)),
    ('high028 effect inside colorectal & feature_035=1', col&df.feature_035.eq(1)&high028, col&df.feature_035.eq(1)&~high028),
    ('colorectal effect inside feature_035=1 & high028', col&df.feature_035.eq(1)&high028, (~col)&df.feature_035.eq(1)&high028),
]:
    a=df.loc[maskA,'dependency_KIF18A']; b=df.loc[maskB,'dependency_KIF18A']
    print(f\"{desc}: n={len(a)} vs {len(b)} mean={a.mean():+.6f} other={b.mean():+.6f} eff={a.mean()-b.mean():+.6f} p={stats.ttest_ind(a,b,equal_var=False).pvalue:.4e}\")

print('\\nInteraction OLS:')
# two-way selected interactions include all lower terms
interaction('dependency_EGFR',{
    'feature_022':df.feature_022.eq(1), 'high016':high016, 'feature_022:high016':df.feature_022.eq(1)&high016}, 'feature_022:high016')
interaction('dependency_ERBB2',{
    'feature_024':df.feature_024.eq(1), 'high026':high026, 'feature_024:high026':df.feature_024.eq(1)&high026}, 'feature_024:high026')
interaction('dependency_KRAS',{
    'feature_014':df.feature_014.eq(1), 'pancreatic':panc, 'feature_014:pancreatic':df.feature_014.eq(1)&panc}, 'feature_014:pancreatic')
interaction('dependency_RIT1',{
    'feature_027':df.feature_027.eq(1), 'brain':brain, 'feature_027:brain':df.feature_027.eq(1)&brain}, 'feature_027:brain')
# 3-way KIF18A
A=col; B=df.feature_035.eq(1); C=high028
terms={'colorectal':A, 'feature_035':B, 'high028':C, 'colorectal:feature_035':A&B, 'colorectal:high028':A&C, 'feature_035:high028':B&C, 'colorectal:feature_035:high028':A&B&C}
interaction('dependency_KIF18A',terms,'colorectal:feature_035:high028')
# process interactions
A=high016; B=df.feature_027.eq(1); C=low017
interaction('dependency_TMED10',{'high016':A,'feature_027':B,'low017':C,'high016:feature_027':A&B,'high016:low017':A&C,'feature_027:low017':B&C,'high016:feature_027:low017':A&B&C},'high016:feature_027:low017')
A=high016; B=high023
interaction('dependency_DHX9',{'high016':A,'high023':B,'high016:high023':A&B},'high016:high023')
A=high016; B=high026; C=skin
interaction('dependency_POLR2A',{'high016':A,'high026':B,'skin':C,'high016:high026':A&B,'high016:skin':A&C,'high026:skin':B&C,'high016:high026:skin':A&B&C},'high016:high026:skin')
A=df.feature_018.eq(1); B=high016; C=high031
interaction('dependency_RPL11',{'feature_018':A,'high016':B,'high031':C,'feature_018:high016':A&B,'feature_018:high031':A&C,'high016:high031':B&C,'feature_018:high016:high031':A&B&C},'feature_018:high016:high031')

# adjusted full main-effects model key coefficients (with continuous standardized and categorical dummies)
print('\\nAdjusted key coefficients in all-main-effect model:')
features=[c for c in df.columns if c.startswith('feature_')]
cat=[c for c in features if df[c].dtype=='object']
lowcard=[c for c in features if df[c].dtype"'!='"'object' and df[c].nunique()<=6]
bin_f=[c for c in features if df[c].dtype"'!='"'object' and set(df[c].unique()).issubset({0,1})]
cont=[c for c in features if c not in cat+lowcard and c not in bin_f]
# avoid duplicate bin lowcard: treat feature_001 categorical, binary as binary, cont as cont
X_parts=[]; names=['Intercept']; X_parts.append(np.ones(len(df)))
for c in cat:
    vals=sorted(df[c].unique())
