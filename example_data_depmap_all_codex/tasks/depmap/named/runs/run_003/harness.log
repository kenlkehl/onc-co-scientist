function ttestMask(y, mask){let n1=0,n0=0,s1=0,s0=0,ss1=0,ss0=0;for(let i=0;i<y.length;i++){if(mask[i]){n1++;s1+=y[i];ss1+=y[i]*y[i];}else{n0++;s0+=y[i];ss0+=y[i]*y[i];}} if(n1<20||n0<20) return null;let m1=s1/n1,m0=s0/n0,v1=(ss1-s1*s1/n1)/(n1-1),v0=(ss0-s0*s0/n0)/(n0-1),se=Math.sqrt(v1/n1+v0/n0),z=(m1-m0)/se;return {effect:m1-m0,p:pnorm2(z),z,n1,n0,m1,m0};}
function slopeTest(y,x){let n=y.length,sx=0,sy=0,sxx=0,sxy=0;for(let i=0;i<n;i++){sx+=x[i];sy+=y[i];sxx+=x[i]*x[i];sxy+=x[i]*y[i];}let mx=sx/n,my=sy/n,Sxx=sxx-sx*sx/n,Sxy=sxy-sx*sy/n,b=Sxy/Sxx,a=my-b*mx,sse=0;for(let i=0;i<n;i++){let r=y[i]-a-b*x[i];sse+=r*r;}let se=Math.sqrt((sse/(n-2))/Sxx),z=b/se;return {effect:b,p:pnorm2(z),z};}
function unique(a){return Array.from(new Set(a));}
function quantile(a,q){let b=Array.from(a).sort((x,y)=>x-y);let pos=(b.length-1)*q,lo=Math.floor(pos),hi=Math.ceil(pos);return lo===hi?b[lo]:b[lo]+(b[hi]-b[lo])*(pos-lo);}
