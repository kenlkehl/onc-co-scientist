function erf(x){const sign=x<0?-1:1; x=Math.abs(x); const a1=0.254829592,a2=-0.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=0.3275911; const t=1/(1+p*x); const y=1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x); return sign*y;}
function pFromZ(z){const cdf=0.5*(1+erf(z/Math.SQRT2)); return Math.max(0, Math.min(1, 2*(1-cdf)));}
function corr(x,y){let sx=0,sy=0,sxx=0,syy=0,sxy=0; for(let i=0;i<N;i++){const a=x[i],b=y[i];sx+=a;sy+=b;sxx+=a*a;syy+=b*b;sxy+=a*b;} const cov=sxy-sx*sy/N; const vx=sxx-sx*sx/N, vy=syy-sy*sy/N; return cov/Math.sqrt(vx*vy);}
function slopeStats(x,y){const r=corr(x,y); let sx=0,sy=0,sxx=0,sxy=0; for(let i=0;i<N;i++){sx+=x[i];sy+=y[i];sxx+=x[i]*x[i];sxy+=x[i]*y[i];} const slope=(sxy-sx*sy/N)/(sxx-sx*sx/N); const t=r*Math.sqrt((N-2)/(1-r*r)); return {slope,r,t,p:pFromZ(Math.abs(t))};}
function unique(arr){return [...new Set(arr)];}
