/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from pathlib import Path

df=pd.read_parquet('dataset.parquet')
outs=[c for c in df.columns if c.startswith('dependency_')]
cat=['lineage','lineage_subtype','culture_type','screen_batch','media_serum_pct']
binary=[c for c in df.columns if df[c].dropna().isin([0,1]).all() and c not in []]
# exclude outcomes? already floats
binary=[c for c in binary if not c.startswith('dependency_')]
cont=[c for c in df.columns if c not in outs+cat+binary+['cell_line_id']]
print('binary', binary)
print('cont', cont)
print('\\nTop univariate binary effects (mean 1 - mean 0):')
for out in outs:
    rows=[]
    y=df[out].to_numpy()
    for b in binary:
        x=df[b].to_numpy().astype(bool)
        n1=x.sum(); n0=len(x)-n1
        m1=y[x].mean(); m0=y[~x].mean()
        t,p=stats.ttest_ind(y[x], y[~x], equal_var=False)
        rows.append((abs(m1-m0), m1-m0, p, b, n1, m1, m0))
    rows=sorted(rows, reverse=True)[:8]
    print('\\n',out)
    for absd,d,p,b,n,m1,m0 in rows:
        print(f'{b:20s} n={n:5d} diff={d:+.4f} m1={m1:+.4f} m0={m0:+.4f} p={p:.2e}')
print('\\nTop continuous correlations/slope per SD:')
for out in outs:
    y=df[out].to_numpy()
    rows=[]
    for c in cont:
        x=df[c].to_numpy()
        r,p=stats.pearsonr(x,y)
        beta=np.cov((x-x.mean())/x.std(ddof=0), y, ddof=0)[0,1]/np.var((x-x.mean())/x.std(ddof=0))
        rows.append((abs(beta), beta, r, p, c))
    print('\\n',out)
    for _,beta,r,p,c in sorted(rows, reverse=True)[:8]:
        print(f'{c:32s} beta_per_sd={beta:+.4f} r={r:+.3f} p={p:.2e}')
print('\\nTop categorical group-vs-rest effects:')
for out in outs:
    y=df[out]
    rows=[]
    for c in cat:
        for val in sorted(df[c].unique()):
            mask=df[c].eq(val).to_numpy()
            if mask.sum()<50 or (~mask).sum()<50: continue
            d=y[mask].mean()-y[~mask].mean()
            t,p=stats.ttest_ind(y[mask], y[~mask], equal_var=False)
            rows.append((abs(d), d, p, c, val, mask.sum(), y[mask].mean(), y[~mask].mean()))
    print('\\n',out)
    for _,d,p,c,val,n,m1,m0 in sorted(rows, reverse=True)[:10]:
        print(f'{c}={val:18s} n={n:5d} diff={d:+.4f} m={m1:+.4f} rest={m0:+.4f} p={p:.2e}')
