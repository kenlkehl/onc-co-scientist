codex
Several canonical main effects are obvious, but the weak TMED10/POLR2A signals need more careful probing. I’m now fitting adjusted linear models so the transcript separates biological marker effects from lineage and screen covariates.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
import statsmodels.formula.api as smf

df=pd.read_parquet('dataset.parquet')
outs=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
for c in cont:
    df[c+'_z']=(df[c]-df[c].mean())/df[c].std(ddof=0)
# Omit lineage_subtype? includes not_applicable/lineage coupling; include lineage, subtype, culture, screen, serum.
terms = binary + [c+'_z' for c in cont] + ['C(lineage)','C(lineage_subtype)','C(culture_type)','C(screen_batch)','C(media_serum_pct)']
formula_rhs=' + '.join(terms)
for out in outs:
    model=smf.ols(f'{out} ~ {formula_rhs}', data=df).fit()
    rows=[]
    for name,beta,p in zip(model.params.index, model.params.values, model.pvalues.values):
        if name=='Intercept': continue
        rows.append((abs(beta), beta, p, name))
    print('\\n###',out,'R2',model.rsquared)
    for _,beta,p,name in sorted(rows, reverse=True)[:16]:
        print(f'{name:45s} beta={beta:+.4f} p={p:.2e}')
