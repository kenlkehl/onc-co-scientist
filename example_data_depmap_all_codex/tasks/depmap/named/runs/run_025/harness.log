/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
outs=[c for c in df.columns if c.startswith('dependency_')]
cat=['lineage','lineage_subtype','culture_type','screen_batch','media_serum_pct']
print('Top categorical group-vs-rest effects:')
for out in outs:
    y=df[out]
    rows=[]
    for c in cat:
        for val in sorted(df[c].unique()):
            mask=df[c].eq(val).to_numpy()
            if mask.sum()<50 or (~mask).sum()<50: continue
            d=y[mask].mean()-y[~mask].mean()
            t,p=stats.ttest_ind(y[mask], y[~mask], equal_var=False)
            rows.append((abs(d), d, p, c, str(val), mask.sum(), y[mask].mean(), y[~mask].mean()))
    print('\\n',out)
    for _,d,p,c,val,n,m1,m0 in sorted(rows, reverse=True)[:12]:
        print(f'{c}={val:18s} n={n:5d} diff={d:+.4f} m={m1:+.4f} rest={m0:+.4f} p={p:.2e}')
