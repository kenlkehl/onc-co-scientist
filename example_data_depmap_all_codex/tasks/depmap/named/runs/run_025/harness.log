import pandas as pd, numpy as np
from scipy import stats
import statsmodels.formula.api as smf

df=pd.read_parquet('dataset.parquet')
outs=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
# Candidate modifiers as binary masks
mods=[]
source=[]
for b in binary:
    mods.append((f'{b}=1', df[b].eq(1).to_numpy(), b))
for c in ['lineage','lineage_subtype','culture_type','screen_batch','media_serum_pct']:
    for val in sorted(df[c].unique()):
        mods.append((f'{c}={val}', df[c].eq(val).to_numpy(), c))
for c in cont:
    q25,q75=df[c].quantile([0.25,0.75])
    mods.append((f'{c}>=Q75({q75:.3g})', df[c].ge(q75).to_numpy(), c))
    mods.append((f'{c}<=Q25({q25:.3g})', df[c].le(q25).to_numpy(), c))

drivers={
 'dependency_BRAF': ('braf_v600e', df['braf_v600e'].eq(1).to_numpy()),
 'dependency_EGFR': ('egfr_amplification', df['egfr_amplification'].eq(1).to_numpy()),
 'dependency_ERBB2': ('erbb2_amplification', df['erbb2_amplification'].eq(1).to_numpy()),
 'dependency_KRAS': ('kras_mutation', df['kras_mutation'].eq(1).to_numpy()),
 'dependency_RIT1': ('nf1_loss', df['nf1_loss'].eq(1).to_numpy()),
 'dependency_KIF18A': ('apc_mutation', df['apc_mutation'].eq(1).to_numpy()),
 'dependency_TMED10': ('nf1_loss', df['nf1_loss'].eq(1).to_numpy()),
 'dependency_DHX9': ('myc_amplification', df['myc_amplification'].eq(1).to_numpy()),
 'dependency_POLR2A': ('growth_rate_high', df['growth_rate_doublings_per_day'].ge(df['growth_rate_doublings_per_day'].quantile(.75)).to_numpy()),
 'dependency_RPL11': ('myc_amplification', df['myc_amplification'].eq(1).to_numpy()),
}
print('Driver interaction screen. effect = driver effect inside modifier minus outside; negative means driver has stronger dependency inside modifier.')
for out,(drv_name,d) in drivers.items():
    y=df[out].to_numpy()
    rows=[]
    for name,m,src in mods:
        if src==drv_name or name.startswith(drv_name+'='): continue
        # need all four cells with >=50
        cells=[d&m, (~d)&m, d&(~m), (~d)&(~m)]
        ns=[int(c.sum()) for c in cells]
        if min(ns)<50: continue
        eff_in=y[d&m].mean()-y[(~d)&m].mean()
        eff_out=y[d&(~m)].mean()-y[(~d)&(~m)].mean()
        inter=eff_in-eff_out
        # quick OLS p for interaction with binary variables via scipy linear regression? Use statsmodels for top later; approximate Welch contrast se
        vars_=[y[c].var(ddof=1) for c in cells]
        se=(vars_[0]/ns[0]+vars_[1]/ns[1]+vars_[2]/ns[2]+vars_[3]/ns[3])**0.5
        z=inter/se if se>0 else np.nan
        p=2*stats.norm.sf(abs(z)) if se>0 else np.nan
        rows.append((abs(inter), inter, p, name, ns, eff_in, eff_out, y[d&m].mean()))
    print('\\n###',out,'driver',drv_name)
    for _,inter,p,name,ns,eff_in,eff_out,mean_dm in sorted(rows, reverse=True)[:12]:
        print(f'{name:38s} ns={ns} inter={inter:+.4f} p={p:.2e} eff_in={eff_in:+.4f} eff_out={eff_out:+.4f} mean_driver_mod={mean_dm:+.4f}')
