The interaction screen found strong KIF18A APC-by-colorectal/WNT effects and weaker modifiers elsewhere. I’m widening this into a subgroup search over single and paired predicates for every dependency outcome, then using targeted triplets where a paired subgroup looks incomplete.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
outs=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
# Predicate list: include biologically interpretable positives/negatives and quartile extremes.
preds=[]
def add(name, mask, base):
    mask=np.asarray(mask, dtype=bool)
    n=int(mask.sum())
    if 100 <= n <= len(df)-100:
        preds.append({'name':name,'mask':mask,'base':base,'n':n})
for b in binary:
    add(f'{b}=1', df[b].eq(1), b)
    add(f'{b}=0', df[b].eq(0), b)
for c in ['lineage','lineage_subtype','culture_type','screen_batch','media_serum_pct']:
    for val in sorted(df[c].unique()):
        add(f'{c}={val}', df[c].eq(val), c)
for c in cont:
    q25,q75=df[c].quantile([0.25,0.75])
    add(f'{c}>=Q75({q75:.3g})', df[c].ge(q75), c)
    add(f'{c}<=Q25({q25:.3g})', df[c].le(q25), c)
N=len(df)
print('predicates',len(preds))

def welch(y, mask):
    a=y[mask]; b=y[~mask]
    d=float(a.mean()-b.mean())
    if len(a)<2 or len(b)<2: return d, np.nan
    _,p=stats.ttest_ind(a,b,equal_var=False)
    return d,float(p)
# Precompute non-conflicting pairs
pairs=[]
for i,j in combinations(range(len(preds)),2):
    if preds[i]['base']==preds[j]['base']: continue
    m=preds[i]['mask'] & preds[j]['mask']
    n=int(m.sum())
    if 100 <= n <= N-100:
        pairs.append((i,j,m,n))
print('pairs',len(pairs))
# Print top single/pair subgroups for each outcome by most negative mean difference vs complement.
for out in outs:
    y=df[out].to_numpy()
    rows=[]
    for i,pred in enumerate(preds):
        d,p=welch(y,pred['mask'])
        rows.append((d,p,pred['n'],pred['name'],y[pred['mask']].mean(),'single', (i,)))
    for i,j,m,n in pairs:
        d,p=welch(y,m)
        rows.append((d,p,n,preds[i]['name']+' & '+preds[j]['name'],y[m].mean(),'pair',(i,j)))
    rows=sorted(rows, key=lambda x:x[0])
    print('\\n###',out,'top negative single/pair subgroup-vs-rest')
    for d,p,n,name,mean,kind,idx in rows[:18]:
        print(f'{kind:6s} n={n:5d} mean={mean:+.4f} diff={d:+.4f} p={p:.2e} :: {name}')
    # targeted triples: combine top 120 pair predicates with one more compatible predicate; rank only if improves mean negativity and support >=100
    triples=[]
    top_pairs=[r for r in rows if r[5]=='pair'][:120]
    seen=set()
    for d0,p0,n0,name0,mean0,kind,idxs in top_pairs:
        i,j=idxs
        base_set={preds[i]['base'],preds[j]['base']}
        base_mask=preds[i]['mask'] & preds[j]['mask']
        for k in range(len(preds)):
            if k in idxs or preds[k]['base'] in base_set: continue
            ids=tuple(sorted((i,j,k)))
            if ids in seen: continue
            seen.add(ids)
            m=base_mask & preds[k]['mask']
            n=int(m.sum())
            if 100 <= n <= N-100:
                d,p=welch(y,m)
                triples.append((d,p,n,' & '.join(preds[t]['name'] for t in ids),y[m].mean(),ids))
    triples=sorted(triples,key=lambda x:x[0])[:12]
    print('--- targeted triples')
    for d,p,n,name,mean,ids in triples:
        print(f'triple n={n:5d} mean={mean:+.4f} diff={d:+.4f} p={p:.2e} :: {name}')
