/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
import statsmodels.api as sm

df=pd.read_parquet('dataset.parquet')
# thresholds
thresholds={}
for c in ['growth_rate_doublings_per_day','wnt_activity_score','rnaseq_ASCL2_log2_tpm','rnaseq_MYC_log2_tpm','copy_number_8q24','stemness_score','ploidy']:
    thresholds[c+'_q75']=float(df[c].quantile(.75))
    thresholds[c+'_q25']=float(df[c].quantile(.25))
print('thresholds')
for k,v in thresholds.items(): print(k, f'{v:.6g}')

def fmt_p(p):
    if p==0: return '0.000e+00'
    return f'{p:.3e}'

def mean_diff(name, ycol, mask):
    y=df[ycol].to_numpy(); m=np.asarray(mask,bool)
    d=float(y[m].mean()-y[~m].mean())
    _,p=stats.ttest_ind(y[m],y[~m],equal_var=False)
    print(f'{name:45s} {ycol:18s} n={m.sum():5d} mean={y[m].mean():+.6f} rest={y[~m].mean():+.6f} diff={d:+.6f} p={fmt_p(float(p))}')
    return d,float(p),int(m.sum()),float(y[m].mean()),float(y[~m].mean())

def cont_slope(name,ycol,xcol):
    y=df[ycol].to_numpy(); x=df[xcol].to_numpy(); z=(x-x.mean())/x.std(ddof=0)
    slope,inter,r,p,se=stats.linregress(z,y)
    print(f'{name:45s} {ycol:18s} slope_per_sd={slope:+.6f} r={r:+.6f} p={fmt_p(float(p))}')
    return float(slope),float(p)

def interaction(name,ycol,D,M):
    y=df[ycol].to_numpy(); d=np.asarray(D,bool).astype(float); m=np.asarray(M,bool).astype(float)
    X=np.column_stack([np.ones(len(y)),d,m,d*m])
    model=sm.OLS(y,X).fit()
    beta=float(model.params[3]); p=float(model.pvalues[3])
    # cell means and driver effects
    Db=np.asarray(D,bool); Mb=np.asarray(M,bool)
    eff_in=float(y[Db & Mb].mean()-y[(~Db)&Mb].mean())
    eff_out=float(y[Db & (~Mb)].mean()-y[(~Db)&(~Mb)].mean())
    print(f'{name:45s} {ycol:18s} inter={beta:+.6f} p={fmt_p(p)} eff_in={eff_in:+.6f} eff_out={eff_out:+.6f} ns={[int((Db&Mb).sum()),int(((~Db)&Mb).sum()),int((Db&(~Mb)).sum()),int(((~Db)&(~Mb)).sum())]}')
    return beta,p,eff_in,eff_out

print('\\nmain and subgroup tests')
# main effects
mean_diff('BRAF V600E', 'dependency_BRAF', df.braf_v600e.eq(1))
mean_diff('EGFR amplification', 'dependency_EGFR', df.egfr_amplification.eq(1))
mean_diff('ERBB2 amplification', 'dependency_ERBB2', df.erbb2_amplification.eq(1))
mean_diff('KRAS mutation', 'dependency_KRAS', df.kras_mutation.eq(1))
mean_diff('NF1 loss', 'dependency_RIT1', df.nf1_loss.eq(1))
mean_diff('APC mutation', 'dependency_KIF18A', df.apc_mutation.eq(1))
mean_diff('MYC amplification', 'dependency_RPL11', df.myc_amplification.eq(1))
mean_diff('high copy_number_8q24', 'dependency_RPL11', df.copy_number_8q24.ge(thresholds['copy_number_8q24_q75']))
cont_slope('growth slope POLR2A','dependency_POLR2A','growth_rate_doublings_per_day')
cont_slope('growth slope TMED10','dependency_TMED10','growth_rate_doublings_per_day')
cont_slope('MYC expression slope DHX9','dependency_DHX9','rnaseq_MYC_log2_tpm')
cont_slope('WNT slope KIF18A','dependency_KIF18A','wnt_activity_score')

print('\\ninteraction/refinement tests')
interaction('BRAF x skin','dependency_BRAF',df.braf_v600e.eq(1),df.lineage.eq('skin'))
interaction('ERBB2 amp x HER2 subtype','dependency_ERBB2',df.erbb2_amplification.eq(1),df.lineage_subtype.eq('her2_enriched'))
interaction('KRAS mutation x pancreatic','dependency_KRAS',df.kras_mutation.eq(1),df.lineage.eq('pancreatic'))
interaction('RIT1 NF1 loss x brain','dependency_RIT1',df.nf1_loss.eq(1),df.lineage.eq('brain'))
interaction('KIF18A APC x colorectal','dependency_KIF18A',df.apc_mutation.eq(1),df.lineage.eq('colorectal'))
interaction('KIF18A APC x SMAD4 loss','dependency_KIF18A',df.apc_mutation.eq(1),df.smad4_loss.eq(1))
interaction('TMED10 NF1 x low ASCL2','dependency_TMED10',df.nf1_loss.eq(1),df.rnaseq_ASCL2_log2_tpm.le(thresholds['rnaseq_ASCL2_log2_tpm_q25']))
interaction('DHX9 high MYC expr x high growth','dependency_DHX9',df.rnaseq_MYC_log2_tpm.ge(thresholds['rnaseq_MYC_log2_tpm_q75']),df.growth_rate_doublings_per_day.ge(thresholds['growth_rate_doublings_per_day_q75']))
interaction('POLR2A high growth x HER2 subtype','dependency_POLR2A',df.growth_rate_doublings_per_day.ge(thresholds['growth_rate_doublings_per_day_q75']),df.lineage_subtype.eq('her2_enriched'))
interaction('RPL11 MYC amp x high growth','dependency_RPL11',df.myc_amplification.eq(1),df.growth_rate_doublings_per_day.ge(thresholds['growth_rate_doublings_per_day_q75']))
interaction('RPL11 MYC amp x high stemness','dependency_RPL11',df.myc_amplification.eq(1),df.stemness_score.ge(thresholds['stemness_score_q75']))

print('\\ncomplete subgroups')
mean_diff('BRAF final braf_v600e=1','dependency_BRAF',df.braf_v600e.eq(1))
mean_diff('EGFR final egfr_amp=1','dependency_EGFR',df.egfr_amplification.eq(1))
mean_diff('ERBB2 final amp & HER2 subtype','dependency_ERBB2',df.erbb2_amplification.eq(1)&df.lineage_subtype.eq('her2_enriched'))
mean_diff('KRAS final kras_mut=1','dependency_KRAS',df.kras_mutation.eq(1))
mean_diff('RIT1 final NF1 loss brain','dependency_RIT1',df.nf1_loss.eq(1)&df.lineage.eq('brain'))
wnt_high=df.wnt_activity_score.ge(thresholds['wnt_activity_score_q75'])
ascl2_high=df.rnaseq_ASCL2_log2_tpm.ge(thresholds['rnaseq_ASCL2_log2_tpm_q75'])
mean_diff('KIF18A APC colorectal WNT high','dependency_KIF18A',df.apc_mutation.eq(1)&df.lineage.eq('colorectal')&wnt_high)
mean_diff('KIF18A APC colorectal SMAD4 intact WNT high','dependency_KIF18A',df.apc_mutation.eq(1)&df.lineage.eq('colorectal')&wnt_high&df.smad4_loss.eq(0))
mean_diff('KIF18A APC colorectal WNT high ASCL2 high','dependency_KIF18A',df.apc_mutation.eq(1)&df.lineage.eq('colorectal')&wnt_high&ascl2_high)
mean_diff('KIF18A APC colorectal WNT high SMAD4 loss','dependency_KIF18A',df.apc_mutation.eq(1)&df.lineage.eq('colorectal')&wnt_high&df.smad4_loss.eq(1))
mean_diff('TMED10 NF1 high_growth low_ASCL2','dependency_TMED10',df.nf1_loss.eq(1)&df.growth_rate_doublings_per_day.ge(thresholds['growth_rate_doublings_per_day_q75'])&df.rnaseq_ASCL2_log2_tpm.le(thresholds['rnaseq_ASCL2_log2_tpm_q25']))
mean_diff('DHX9 high_MYC high_growth','dependency_DHX9',df.rnaseq_MYC_log2_tpm.ge(thresholds['rnaseq_MYC_log2_tpm_q75'])&df.growth_rate_doublings_per_day.ge(thresholds['growth_rate_doublings_per_day_q75']))
mean_diff('DHX9 squamous low_ploidy high_MYC','dependency_DHX9',df.lineage_subtype.eq('squamous')&df.ploidy.le(thresholds['ploidy_q25'])&df.rnaseq_MYC_log2_tpm.ge(thresholds['rnaseq_MYC_log2_tpm_q75']))
mean_diff('POLR2A high_growth','dependency_POLR2A',df.growth_rate_doublings_per_day.ge(thresholds['growth_rate_doublings_per_day_q75']))
mean_diff('POLR2A HER2 subtype high_growth','dependency_POLR2A',df.lineage_subtype.eq('her2_enriched')&df.growth_rate_doublings_per_day.ge(thresholds['growth_rate_doublings_per_day_q75']))
mean_diff('RPL11 MYC_amp high_growth','dependency_RPL11',df.myc_amplification.eq(1)&df.growth_rate_doublings_per_day.ge(thresholds['growth_rate_doublings_per_day_q75']))
mean_diff('RPL11 MYC_amp high_copy8q24','dependency_RPL11',df.myc_amplification.eq(1)&df.copy_number_8q24.ge(thresholds['copy_number_8q24_q75']))
