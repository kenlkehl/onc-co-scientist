import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
q=lambda c,p: df[c].quantile(p)
q75={c:q(c,.75) for c in df.select_dtypes('number').columns}
q25={c:q(c,.25) for c in df.select_dtypes('number').columns}

def wt(mask,y, name=''):
    a=df.loc[mask,y]; b=df.loc[~mask,y]
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return dict(name=name,n=int(mask.sum()),mean=float(a.mean()),rest=float(b.mean()),effect=float(a.mean()-b.mean()),p=float(p),t=float(t))

def two(mask1, mask2, y, name=''):
    a=df.loc[mask1,y]; b=df.loc[mask2,y]
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return dict(name=name,n1=int(mask1.sum()),n2=int(mask2.sum()),mean1=float(a.mean()),mean2=float(b.mean()),effect=float(a.mean()-b.mean()),p=float(p),t=float(t))

def pr(d):
    print(d['name'])
    print({k:(f'{v:.6g}' if isinstance(v,float) else v) for k,v in d.items() if k"'!='"'name'})

# Driver main effects
for y,mask,name in [
    ('dependency_BRAF', df.braf_v600e==1, 'BRAF: braf_v600e=1 vs 0'),
    ('dependency_EGFR', df.egfr_amplification==1, 'EGFR: egfr_amplification=1 vs 0'),
    ('dependency_ERBB2', df.erbb2_amplification==1, 'ERBB2: erbb2_amplification=1 vs 0'),
    ('dependency_KRAS', df.kras_mutation==1, 'KRAS: kras_mutation=1 vs 0'),
    ('dependency_RIT1', df.nf1_loss==1, 'RIT1: nf1_loss=1 vs 0')]:
    pr(wt(mask,y,name))
print('\\nInteractions/within-driver contrasts')
# BRAF skin within braf; effect skin mutant minus non-skin mutant
pr(two((df.braf_v600e==1)&(df.lineage=='skin'), (df.braf_v600e==1)&(df.lineage"'!='"'skin'), 'dependency_BRAF','BRAF V600E skin vs non-skin among mutants'))
# EGFR brain among amp
pr(two((df.egfr_amplification==1)&(df.lineage=='brain'), (df.egfr_amplification==1)&(df.lineage"'!='"'brain'), 'dependency_EGFR','EGFR-amplified brain vs non-brain among amplified'))
# EGFR high growth among amp
pr(two((df.egfr_amplification==1)&(df.growth_rate_doublings_per_day>=q75['growth_rate_doublings_per_day']), (df.egfr_amplification==1)&(df.growth_rate_doublings_per_day<q75['growth_rate_doublings_per_day']), 'dependency_EGFR','EGFR-amplified high-growth vs lower-growth among amplified'))
# ERBB2 breast/gastric/her2 among amp
pr(two((df.erbb2_amplification==1)&(df.lineage.isin(['breast','gastric'])), (df.erbb2_amplification==1)&(~df.lineage.isin(['breast','gastric'])), 'dependency_ERBB2','ERBB2-amplified breast/gastric vs other lineages among amplified'))
pr(two((df.erbb2_amplification==1)&(df.lineage_subtype=='her2_enriched'), (df.erbb2_amplification==1)&(df.lineage_subtype"'!='"'her2_enriched'), 'dependency_ERBB2','ERBB2-amplified HER2-enriched subtype vs other subtypes among amplified'))
# KRAS pancreatic/colorectal among mutant
pr(two((df.kras_mutation==1)&(df.lineage=='pancreatic'), (df.kras_mutation==1)&(df.lineage"'!='"'pancreatic'), 'dependency_KRAS','KRAS-mutant pancreatic vs non-pancreatic among mutants'))
pr(two((df.kras_mutation==1)&(df.lineage.isin(['pancreatic','colorectal'])), (df.kras_mutation==1)&(~df.lineage.isin(['pancreatic','colorectal'])), 'dependency_KRAS','KRAS-mutant pancreatic/colorectal vs other lineages among mutants'))
# RIT1 NF1 + low MYC
pr(wt((df.nf1_loss==1)&(df.rnaseq_MYC_log2_tpm<=q25['rnaseq_MYC_log2_tpm']),'dependency_RIT1','RIT1: NF1-loss and low MYC expression subgroup vs rest'))
pr(two((df.nf1_loss==1)&(df.rnaseq_MYC_log2_tpm<=q25['rnaseq_MYC_log2_tpm']), (df.nf1_loss==1)&(df.rnaseq_MYC_log2_tpm>q25['rnaseq_MYC_log2_tpm']), 'dependency_RIT1','RIT1: low vs higher MYC among NF1-loss'))
# KIF18A subgroups
wnt_hi=df.wnt_activity_score>=q75['wnt_activity_score']
ascl2_hi=df.rnaseq_ASCL2_log2_tpm>=q75['rnaseq_ASCL2_log2_tpm']
col=df.lineage=='colorectal'
apc=df.apc_mutation==1
smad4_zero=df.smad4_loss==0
smad4_one=df.smad4_loss==1
for mask,name in [
    (col,'KIF18A: colorectal lineage'),
    (apc,'KIF18A: APC mutation'),
    (col & apc,'KIF18A: colorectal and APC mutation'),
    (col & apc & wnt_hi,'KIF18A: colorectal, APC mutation, WNT high'),
    (col & apc & smad4_zero,'KIF18A: colorectal, APC mutation, SMAD4 intact'),
    (col & apc & wnt_hi & smad4_zero,'KIF18A: colorectal, APC mutation, WNT high, SMAD4 intact')]:
    pr(wt(mask,'dependency_KIF18A',name))
pr(two(col&apc&wnt_hi&smad4_one, col&apc&wnt_hi&smad4_zero, 'dependency_KIF18A','KIF18A: SMAD4 loss vs intact within colorectal/APC/WNT-high'))
pr(two(col&apc&wnt_hi, col&apc&(~wnt_hi), 'dependency_KIF18A','KIF18A: WNT high vs not high within colorectal/APC'))
# TMED10
high_growth=df.growth_rate_doublings_per_day>=q75['growth_rate_doublings_per_day']
high_cas9=df.cas9_activity_score>=q75['cas9_activity_score']
pr(wt(high_growth,'dependency_TMED10','TMED10: high growth rate q75 vs rest'))
pr(wt(high_growth & high_cas9,'dependency_TMED10','TMED10: high growth and high Cas9 subgroup'))
# MYC/growth outcomes
myc_amp=df.myc_amplification==1
myc_expr_hi=df.rnaseq_MYC_log2_tpm>=q75['rnaseq_MYC_log2_tpm']
cn8_hi=df.copy_number_8q24>=q75['copy_number_8q24']
cn9_low=df.copy_number_9p21<=q25['copy_number_9p21']
ifn_hi=df.ifn_gamma_signature>=q75['ifn_gamma_signature']
for y in ['dependency_DHX9','dependency_POLR2A','dependency_RPL11']:
    print('\\n',y)
    for mask,name in [
        (myc_amp, 'MYC amplification'),
        (myc_expr_hi, 'MYC expression high q75'),
        (cn8_hi, '8q24 copy-number high q75'),
        (high_growth, 'growth high q75'),
        (high_growth & myc_expr_hi, 'growth high and MYC expression high'),
        (high_growth & myc_amp, 'growth high and MYC amplification'),
        (cn8_hi & myc_amp, '8q24 high and MYC amplification'),
        (high_growth & cn9_low & ifn_hi, 'growth high, 9p21 low, IFN high')]:
        pr(wt(mask,y,f'{y}: {name}'))
