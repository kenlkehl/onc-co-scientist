import pandas as pd, numpy as np
from scipy import stats
from numpy.linalg import pinv

df=pd.read_parquet('dataset.parquet')
q75={c:df[c].quantile(.75) for c in df.select_dtypes('number').columns}
q25={c:df[c].quantile(.25) for c in df.select_dtypes('number').columns}
base_cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden']
base_cats=['lineage','culture_type','screen_batch']

def ols_coef(y, indicator, ind_name, extra=None):
    parts=[pd.Series(1.0,index=df.index,name='Intercept'), pd.Series(indicator.astype(float),index=df.index,name=ind_name)]
    for c in base_cats:
        parts.append(pd.get_dummies(df[c],prefix=c,drop_first=True,dtype=float))
    cont=(df[base_cont]-df[base_cont].mean())/df[base_cont].std()
    cont.columns=[c+'_perSD' for c in base_cont]
    parts.append(cont)
    if extra is not None:
        parts.extend(extra)
    X=pd.concat(parts,axis=1)
    Xv=X.to_numpy(float); yv=df[y].to_numpy(float)
    inv=pinv(Xv.T@Xv); beta=inv@(Xv.T@yv); resid=yv-Xv@beta
    rank=np.linalg.matrix_rank(Xv); dof=len(yv)-rank
    sigma2=(resid@resid)/dof
    se=np.sqrt(np.diag(inv)*sigma2)
    idx=list(X.columns).index(ind_name)
    t=beta[idx]/se[idx]
    p=2*stats.t.sf(abs(t),dof)
    return float(beta[idx]),float(se[idx]),float(t),float(p),dof

