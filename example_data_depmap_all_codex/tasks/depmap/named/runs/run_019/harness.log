cat_cols=['lineage','lineage_subtype','culture_type','screen_batch']
cont_cols=[c for c in df.columns if c not in ['cell_line_id']+cat_cols+bin_cols+outcomes]
# design: intercept + dummies + binary + standardized continuous
X_parts=[pd.Series(1.0,index=df.index,name='Intercept')]
for c in cat_cols:
    X_parts.append(pd.get_dummies(df[c], prefix=c, drop_first=True, dtype=float))
X_parts.append(df[bin_cols].astype(float))
cont_std=(df[cont_cols]-df[cont_cols].mean())/df[cont_cols].std()
cont_std.columns=[c+'_perSD' for c in cont_cols]
X_parts.append(cont_std)
X=pd.concat(X_parts,axis=1)
cols=list(X.columns)
Xv=X.to_numpy(float)
XtX_inv=pinv(Xv.T@Xv)
rank=np.linalg.matrix_rank(Xv)
df_res=Xv.shape[0]-rank
print('design',Xv.shape,'rank',rank,'df',df_res)
for y in outcomes:
    yv=df[y].to_numpy(float)
    beta=XtX_inv@(Xv.T@yv)
    resid=yv-Xv@beta
    sigma2=(resid@resid)/df_res
    se=np.sqrt(np.diag(XtX_inv)*sigma2)
    t=beta/se
    p=2*stats.t.sf(np.abs(t),df_res)
    rows=[]
    for name,b,pp in zip(cols,beta,p):
        if name"'!='"'Intercept':
            rows.append((b,pp,name))
    # strongest negative significant in molecular/categorical/cont
    rows_neg=sorted(rows,key=lambda x:x[0])[:12]
    rows_abs=sorted(rows,key=lambda x:abs(x[0]),reverse=True)[:12]
    print('\\nADJUSTED',y,'R2',1-(resid@resid)/(((yv-yv.mean())@(yv-yv.mean()))))
    print('Most negative coefficients:')
    for b,pp,name in rows_neg:
        print(f'{name:36s} beta={b: .4f} p={pp:.2e}')
    print('Largest absolute coefficients:')
    for b,pp,name in rows_abs[:8]:
        print(f'{name:36s} beta={b: .4f} p={pp:.2e}')
