import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
bin_cols=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cat_cols=['lineage','lineage_subtype','culture_type']
cont_cols=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
# create predicates
preds=[]
for f in bin_cols:
    preds.append((f'"'`{f}` = 1'"', df[f].to_numpy()==1, {f:1}))
    # add selected absence predicates likely suppressors
    if f in ['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','smad4_loss','apc_mutation','myc_amplification','nf1_loss']:
        preds.append((f'"'`{f}` = 0'"', df[f].to_numpy()==0, {f:0}))
for c in cat_cols:
    for lev in sorted(df[c].unique()):
        preds.append((f'"'`{c}` = {lev}'"', (df[c].to_numpy()==lev), {c:lev}))
for f in cont_cols:
    q25=df[f].quantile(.25); q75=df[f].quantile(.75)
    preds.append((f'"'`{f}` >= q75 ({q75:.3g})'"', df[f].to_numpy()>=q75, {f:'hi'}))
    preds.append((f'"'`{f}` <= q25 ({q25:.3g})'"', df[f].to_numpy()<=q25, {f:'lo'}))

def compatible(meta1, meta2):
    d={}
    for meta in [meta1, meta2]:
        for k,v in meta.items():
            if k in d and d[k]"'!=v: return False
            d[k]=v
    return True

def combine_meta(metas):
    d={}
    for meta in metas:
        for k,v in meta.items():
            if k in d and d[k]!=v: return None
            d[k]=v
    return d

# Precompute candidate combinations by beam expansion based on each outcome separately
min_n=500
max_n=25000
for y in outcomes:
    yv=df[y].to_numpy()
    all_results=[]
    current=[]
    # single
    for name,mask,meta in preds:
        n=int(mask.sum())
        if min_n<=n<=max_n and n<len(df)-min_n:
            a=yv[mask]; b=yv[~mask]
            t,p=stats.ttest_ind(a,b,equal_var=False)
            eff=a.mean()-b.mean()
            all_results.append((eff,p,abs(t),n,a.mean(),b.mean(),name,mask,meta))
            current.append((eff,p,abs(t),n,a.mean(),b.mean(),name,mask,meta))
    # beam take strongest negative and strongest absolute? For negative dependency top negative effect/t
    beam=sorted(current,key=lambda x:(x[0],-x[2]))[:50]
    for depth in [2,3]:
        new=[]
        seen=set()
        for rec in beam:
            _,_,_,_,_,_,name,mask,meta=rec
            for pname,pmask,pmeta in preds:
                newmeta=combine_meta([meta,pmeta])
                if newmeta is None: continue
                newname=name+'"' AND '+pname
                key=tuple(sorted(newname.split(' AND ')))
                if key in seen: continue
                seen.add(key)
                cmask=mask & pmask
                n=int(cmask.sum())
                if min_n<=n<=max_n and n<len(df)-min_n:
                    a=yv[cmask]; b=yv[~cmask]
                    t,p=stats.ttest_ind(a,b,equal_var=False)
                    eff=a.mean()-b.mean()
                    rec2=(eff,p,abs(t),n,a.mean(),b.mean(),' AND '.join(key),cmask,newmeta)
                    new.append(rec2); all_results.append(rec2)
        beam=sorted(new,key=lambda x:(x[0],-x[2]))[:80]
    # Print top negative by effect and top by t among negative effects
    print('\\n###',y)
    print('Top negative subgroup effects:')
    for eff,p,tabs,n,mg,mc,name,_,_ in sorted(all_results,key=lambda x:x[0])[:12]:
        print(f'eff={eff: .4f} p={p:.2e} t={tabs:.1f} n={n:5d} mean={mg:.4f} rest={mc:.4f} :: {name}')
    print('Top negative subgroup t-statistics:')
    neg=[r for r in all_results if r[0]<0]
    for eff,p,tabs,n,mg,mc,name,_,_ in sorted(neg,key=lambda x:x[2], reverse=True)[:12]:
        print(f'eff={eff: .4f} p={p:.2e} t={tabs:.1f} n={n:5d} mean={mg:.4f} rest={mc:.4f} :: {name}')
