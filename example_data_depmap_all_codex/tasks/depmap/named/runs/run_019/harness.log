/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
bin_cols=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cat_cols=['lineage','lineage_subtype','culture_type','screen_batch']
cont_cols=[c for c in df.columns if c not in ['cell_line_id']+cat_cols+bin_cols+outcomes]
print('TOP BINARY DIFFERENCES (mean feature=1 minus feature=0; negative stronger dependency)')
for y in outcomes:
    rows=[]
    for f in bin_cols:
        a=df.loc[df[f]==1,y]; b=df.loc[df[f]==0,y]
        t,p=stats.ttest_ind(a,b,equal_var=False)
        rows.append((a.mean()-b.mean(),p,f,a.mean(),b.mean(),len(a)))
    rows=sorted(rows,key=lambda x:x[0])[:8]
    print('\\n',y)
    for eff,p,f,ma,mb,n in rows:
        print(f'{f:22s} eff={eff: .4f} p={p:.2e} mean1={ma:.4f} mean0={mb:.4f} n1={n}')
print('\\nTOP CONTINUOUS CORRELATIONS (negative corr means higher feature stronger dependency)')
for y in outcomes:
    rows=[]
    for f in cont_cols:
        r,p=stats.pearsonr(df[f],df[y])
        # effect per 1 SD feature = slope * sd feature = r * sd_y
        eff=r*df[y].std()
        rows.append((eff,p,f,r))
    rows=sorted(rows,key=lambda x:x[0])[:8]
    print('\\n',y)
    for eff,p,f,r in rows:
        print(f'{f:30s} perSD={eff: .4f} r={r:.3f} p={p:.2e}')
print('\\nTOP LINEAGE MEANS (lineage mean minus rest; negative stronger dependency)')
for y in outcomes:
    rows=[]
    for lev in sorted(df['lineage'].unique()):
        m1=df.loc[df.lineage==lev,y].mean(); m0=df.loc[df.lineage"'!=lev,y].mean()
        t,p=stats.ttest_ind(df.loc[df.lineage==lev,y],df.loc[df.lineage!=lev,y],equal_var=False)
        rows.append((m1-m0,p,lev,m1,m0, (df.lineage==lev).sum()))
    rows=sorted(rows,key=lambda x:x[0])[:5]
    print('"'\\n',y)
    for eff,p,lev,m1,m0,n in rows:
        print(f'{lev:16s} eff={eff: .4f} p={p:.2e} mean={m1:.4f} rest={m0:.4f} n={n}')
