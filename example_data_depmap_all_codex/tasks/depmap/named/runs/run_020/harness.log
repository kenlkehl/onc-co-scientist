import pandas as pd, numpy as np
from scipy import stats
import statsmodels.api as sm

df=pd.read_parquet('dataset.parquet')

def subgroup_table(out, driver_col, modifiers):
    y=df[out].values
    d=df[driver_col].values.astype(bool)
    print('\\n', out, 'driver', driver_col)
    for name,mask in modifiers:
        for label,m in [('mod',mask),('notmod',~mask)]:
            dd=d&m; nd=(~d)&m
            if dd.sum()<50 or nd.sum()<50: continue
            eff=y[dd].mean()-y[nd].mean(); t,p=stats.ttest_ind(y[dd],y[nd],equal_var=False)
            print(f'  {name:35s} {label:6s}: n_driver={dd.sum():5d} n_non={nd.sum():5d} driver_mean={y[dd].mean():+.4f} non_mean={y[nd].mean():+.4f} driver_diff={eff:+.4f} p={p:.1e}')
    # simple interaction regressions
    print('  interaction terms')
    for name,mask in modifiers:
        m=mask.astype(int); di=d.astype(int)
        X=sm.add_constant(pd.DataFrame({'driver':di,'mod':m,'int':di*m}))
        fit=sm.OLS(y,X).fit()
        print(f'    {name:35s} int_coef={fit.params[\"int\"]:+.4f} p={fit.pvalues[\"int\"]:.1e}')

q=lambda c: df[c].quantile(.75)
mods_common=[('lineage=skin',(df.lineage=='skin').values),('lineage=brain',(df.lineage=='brain').values),('lineage=breast',(df.lineage=='breast').values),('lineage=gastric',(df.lineage=='gastric').values),('lineage=pancreatic',(df.lineage=='pancreatic').values),('lineage=colorectal',(df.lineage=='colorectal').values),('lineage_subtype=her2_enriched',(df.lineage_subtype=='her2_enriched').values),('lineage_subtype=luminal',(df.lineage_subtype=='luminal').values),('growth_high',(df.growth_rate_doublings_per_day>=q('growth_rate_doublings_per_day')).values)]
subgroup_table('dependency_BRAF','braf_v600e',[mods_common[0],mods_common[5],mods_common[-1],('pik3ca_mutation=1',df.pik3ca_mutation.values.astype(bool))])
subgroup_table('dependency_EGFR','egfr_amplification',[mods_common[1],('lineage=lung',(df.lineage=='lung').values),mods_common[-1],('rnaseq_MYC_high',(df.rnaseq_MYC_log2_tpm>=q('rnaseq_MYC_log2_tpm')).values),('lineage_subtype=luminal',(df.lineage_subtype=='luminal').values)])
subgroup_table('dependency_ERBB2','erbb2_amplification',[mods_common[2],mods_common[3],mods_common[6],mods_common[7],mods_common[-1],('cas9_high',(df.cas9_activity_score>=q('cas9_activity_score')).values)])
subgroup_table('dependency_KRAS','kras_mutation',[mods_common[4],mods_common[5],('smad4_loss=1',df.smad4_loss.values.astype(bool)),('apc_mutation=1',df.apc_mutation.values.astype(bool)),mods_common[-1]])
