import pandas as pd, numpy as np
from scipy import stats
import statsmodels.api as sm

df=pd.read_parquet('dataset.parquet')
y=df['dependency_KIF18A'].values
col=(df['lineage']=='colorectal').values
apc=df['apc_mutation'].values.astype(bool)
smad=df['smad4_loss'].values.astype(bool)
wnt_hi=(df['wnt_activity_score']>=df['wnt_activity_score'].quantile(.75)).values
ascl2_hi=(df['rnaseq_ASCL2_log2_tpm']>=df['rnaseq_ASCL2_log2_tpm'].quantile(.75)).values
kras=df['kras_mutation'].values.astype(bool)
msi=df['msi_high'].values.astype(bool)

def report(name, mask):
    a=y[mask]; b=y[~mask]
    t,p=stats.ttest_ind(a,b,equal_var=False)
    print(f'{name:70s} n={mask.sum():5d} mean={a.mean():+.4f} rest={b.mean():+.4f} diff={a.mean()-b.mean():+.4f} p={p:.2e}')
print('KIF18A subgroup definitions vs rest')
for name,mask in [
    ('colorectal', col),
    ('colorectal & APC_mut', col&apc),
    ('colorectal & APC_mut & SMAD4_loss=0', col&apc&~smad),
    ('colorectal & APC_mut & SMAD4_loss=1', col&apc&smad),
    ('colorectal & WNT_high', col&wnt_hi),
    ('colorectal & WNT_high & SMAD4_loss=0', col&wnt_hi&~smad),
    ('colorectal & WNT_high & APC_mut & SMAD4_loss=0', col&wnt_hi&apc&~smad),
    ('colorectal & APC_mut & WNT_high & ASCL2_high & SMAD4_loss=0', col&apc&wnt_hi&ascl2_hi&~smad),
    ('APC_mut & WNT_high & SMAD4_loss=0', apc&wnt_hi&~smad),
    ('APC_mut & WNT_high & SMAD4_loss=0 & non-colorectal', (~col)&apc&wnt_hi&~smad),
    ('colorectal & APC_mut & SMAD4_loss=0 & KRAS_mut', col&apc&~smad&kras),
    ('colorectal & APC_mut & SMAD4_loss=0 & KRAS_wt', col&apc&~smad&~kras),
    ('colorectal & APC_mut & SMAD4_loss=0 & MSI_high=0', col&apc&~smad&~msi),
]:
    report(name,mask)

print('\\nWithin colorectal cross-tab means')
for a in [0,1]:
  for s in [0,1]:
    for wh in [0,1]:
      mask=col & (apc==bool(a)) & (smad==bool(s)) & (wnt_hi==bool(wh))
      if mask.sum()>20:
        print(f'APC={a} SMAD4_loss={s} WNT_high={wh}: n={mask.sum():4d} mean={y[mask].mean():+.4f}')

print('\\nOLS KIF18A with interactions: zWNT, colorectal, APC, SMAD4')
z=(df['wnt_activity_score']-df['wnt_activity_score'].mean())/df['wnt_activity_score'].std(ddof=0)
X=pd.DataFrame({'const':1,'colorectal':col.astype(int),'apc':apc.astype(int),'smad4':smad.astype(int),'zWNT':z,
                'col_apc':col.astype(int)*apc.astype(int),'col_smad4':col.astype(int)*smad.astype(int),'col_zWNT':col.astype(int)*z,
                'apc_smad4':apc.astype(int)*smad.astype(int),'apc_zWNT':apc.astype(int)*z,
                'col_apc_smad4':col.astype(int)*apc.astype(int)*smad.astype(int),
                'col_apc_zWNT':col.astype(int)*apc.astype(int)*z})
model=sm.OLS(y,X).fit()
for term in ['colorectal','apc','smad4','zWNT','col_apc','col_smad4','col_zWNT','apc_smad4','apc_zWNT','col_apc_smad4','col_apc_zWNT']:
    print(f'{term:15s} coef={model.params[term]:+.4f} p={model.pvalues[term]:.2e}')
print('R2',model.rsquared)
