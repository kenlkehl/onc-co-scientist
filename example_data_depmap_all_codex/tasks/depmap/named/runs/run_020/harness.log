import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cats=['lineage','lineage_subtype','culture_type','screen_batch']

print('TOP BINARY EFFECTS (feature=1 minus 0; more negative means stronger dep in feature=1)')
for y in outcomes:
    rows=[]
    for x in binary:
        a=df.loc[df[x]==1,y].values; b=df.loc[df[x]==0,y].values
        eff=a.mean()-b.mean(); t,p=stats.ttest_ind(a,b,equal_var=False)
        rows.append((abs(eff),eff,p,x,a.mean(),b.mean(),len(a)))
    print('\\n',y)
    for _,eff,p,x,ma,mb,n in sorted(rows, reverse=True)[:8]:
        print(f'{x:22s} diff={eff:+.4f} p={p:.2e} mean1={ma:.4f} mean0={mb:.4f} n1={n}')

print('\\nTOP CONTINUOUS EFFECTS (slope per 1 SD increase)')
for y in outcomes:
    rows=[]
    yy=df[y].values
    for x in cont:
        xx=df[x].values
        z=(xx-xx.mean())/xx.std(ddof=0)
        slope,inter,r,p,se=stats.linregress(z,yy)
        rows.append((abs(slope),slope,p,x,r))
    print('\\n',y)
    for _,slope,p,x,r in sorted(rows, reverse=True)[:8]:
        print(f'{x:30s} slope_sd={slope:+.4f} r={r:+.3f} p={p:.2e}')

print('\\nTOP CATEGORY CONTRASTS (level vs rest)')
for y in outcomes:
    rows=[]
    for x in cats:
        for level,n in df[x].value_counts().items():
            a=df.loc[df[x]==level,y].values; b=df.loc[df[x]"'!=level,y].values
            eff=a.mean()-b.mean(); t,p=stats.ttest_ind(a,b,equal_var=False)
            rows.append((abs(eff),eff,p,x,level,a.mean(),b.mean(),len(a)))
    print('"'\\n', y)
    for _,eff,p,x,l,ma,mb,n in sorted(rows, reverse=True)[:8]:
        print(f'{x}={l:16s} diff={eff:+.4f} p={p:.2e} mean_level={ma:.4f} mean_rest={mb:.4f} n={n}')
