codex
The pairwise subgroup search confirms that some outcomes are driven by a single molecular event, while others are broader growth or MYC/WNT programs. I’m checking whether those driver effects are actually modified inside the driver-positive subsets, because that is where suppressor/enabler predicates can be stated cleanly.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
# candidate predicate masks for modifiers
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cats=['lineage','lineage_subtype','culture_type','screen_batch']
mods=[]
for x in binary:
    mods.append((f'{x}=1', x, df[x].values.astype(bool)))
    mods.append((f'{x}=0', x, ~df[x].values.astype(bool)))
for x in cats:
    for level in sorted(df[x].unique()):
        mods.append((f'{x}={level}', x, df[x].values==level))
for x in cont:
    q25,q75=df[x].quantile([0.25,0.75])
    mods.append((f'{x}>=Q75({q75:.3g})', x, df[x].values>=q75))
    mods.append((f'{x}<=Q25({q25:.3g})', x, df[x].values<=q25))

q75={x:df[x].quantile(0.75) for x in cont}
drivers={
 'dependency_BRAF': ('braf_v600e=1', df['braf_v600e'].values.astype(bool), 'braf_v600e'),
 'dependency_EGFR': ('egfr_amplification=1', df['egfr_amplification'].values.astype(bool), 'egfr_amplification'),
 'dependency_ERBB2': ('erbb2_amplification=1', df['erbb2_amplification'].values.astype(bool), 'erbb2_amplification'),
 'dependency_KRAS': ('kras_mutation=1', df['kras_mutation'].values.astype(bool), 'kras_mutation'),
 'dependency_RIT1': ('nf1_loss=1', df['nf1_loss'].values.astype(bool), 'nf1_loss'),
 'dependency_KIF18A': ('lineage=colorectal', (df['lineage'].values=='colorectal'), 'lineage'),
 'dependency_TMED10': (f'growth_rate_doublings_per_day>=Q75({q75[\"growth_rate_doublings_per_day\"]:.3g})', df['growth_rate_doublings_per_day'].values>=q75['growth_rate_doublings_per_day'], 'growth_rate_doublings_per_day'),
 'dependency_DHX9': (f'rnaseq_MYC_log2_tpm>=Q75({q75[\"rnaseq_MYC_log2_tpm\"]:.3g})', df['rnaseq_MYC_log2_tpm'].values>=q75['rnaseq_MYC_log2_tpm'], 'rnaseq_MYC_log2_tpm'),
 'dependency_POLR2A': (f'growth_rate_doublings_per_day>=Q75({q75[\"growth_rate_doublings_per_day\"]:.3g})', df['growth_rate_doublings_per_day'].values>=q75['growth_rate_doublings_per_day'], 'growth_rate_doublings_per_day'),
 'dependency_RPL11': ('myc_amplification=1', df['myc_amplification'].values.astype(bool), 'myc_amplification'),
}

def safe_t(a,b):
    if len(a)<100 or len(b)<100: return None
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return float(a.mean()-b.mean()), float(p), float(a.mean()), float(b.mean()), len(a), len(b)

print('WITHIN-DRIVER MODIFIER SEARCH')
for out,(dname,dmask,dvar) in drivers.items():
    y=df[out].values
    rows=[]
    for mname,mvar,mmask in mods:
        if mvar==dvar: continue
        within=dmask
        a=y[within & mmask]
        b=y[within & ~mmask]
        r=safe_t(a,b)
        if not r: continue
        eff,p,ma,mb,n1,n0=r
        # driver effect among modifier positive and negative
        r_pos=safe_t(y[dmask & mmask], y[(~dmask)&mmask])
        r_neg=safe_t(y[dmask & ~mmask], y[(~dmask)&(~mmask)])
        int_eff=None
        if r_pos and r_neg:
            int_eff=r_pos[0]-r_neg[0]
        rows.append((eff,p,ma,mb,n1,n0,mname,int_eff))
    print('\\n##',out,'driver',dname,'n_driver',int(dmask.sum()))
    print('Modifiers making driver-positive group MORE negative:')
    for eff,p,ma,mb,n1,n0,mname,int_eff in sorted(rows, key=lambda x:x[0])[:10]:
        print(f'  {mname:70s} n_mod={n1:5d} n_non={n0:5d} mean_mod={ma:+.4f} mean_non={mb:+.4f} within_diff={eff:+.4f} p={p:.1e} interaction_delta={int_eff if int_eff is not None else float(\"nan\"):+.4f}')
    print('Modifiers making driver-positive group LESS negative:')
    for eff,p,ma,mb,n1,n0,mname,int_eff in sorted(rows, key=lambda x:x[0], reverse=True)[:6]:
        print(f'  {mname:70s} n_mod={n1:5d} n_non={n0:5d} mean_mod={ma:+.4f} mean_non={mb:+.4f} within_diff={eff:+.4f} p={p:.1e} interaction_delta={int_eff if int_eff is not None else float(\"nan\"):+.4f}')
