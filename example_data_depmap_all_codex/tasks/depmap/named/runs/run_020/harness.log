/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cats=['lineage','lineage_subtype','culture_type','screen_batch']
# predicates: name, var, kind, mask
preds=[]
for x in binary:
    preds.append((f'{x}=1', x, 'binary1', df[x].values.astype(bool)))
    # include absence for common suppressors
    preds.append((f'{x}=0', x, 'binary0', ~df[x].values.astype(bool)))
for x in cats:
    for level in df[x].unique():
        preds.append((f'{x}={level}', x, 'cat', (df[x].values==level)))
for x in cont:
    q25,q75=df[x].quantile([0.25,0.75])
    preds.append((f'{x}>=Q75({q75:.3g})', x, 'high', (df[x].values>=q75)))
    preds.append((f'{x}<=Q25({q25:.3g})', x, 'low', (df[x].values<=q25)))

def welch(y,mask):
    n=mask.sum(); nr=(~mask).sum()
    if n<300 or nr<300: return None
    a=y[mask]; b=y[~mask]
    eff=float(a.mean()-b.mean())
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return eff,float(p),float(a.mean()),float(b.mean()),int(n)

print('SYSTEMATIC SINGLE AND PAIRWISE SUBGROUP SEARCH')
for out in outcomes:
    y=df[out].values
    singles=[]
    for name,var,kind,mask in preds:
        r=welch(y,mask)
        if r:
            eff,p,ma,mb,n=r
            singles.append((eff,p,ma,mb,n,name,var))
    pairs=[]
    # only pair predicates from different variables and not enormous all-common pairs? allow, min n=300
    for (name1,var1,kind1,m1),(name2,var2,kind2,m2) in combinations(preds,2):
        if var1==var2: continue
        mask=m1 & m2
        n=int(mask.sum())
        if n<300 or n>30000: continue
        r=welch(y,mask)
        if r:
            eff,p,ma,mb,n=r
            pairs.append((eff,p,ma,mb,n,name1+' AND '+name2,var1,var2))
    print('\\n##', out)
    print('Top negative single predicates vs rest:')
    for eff,p,ma,mb,n,name,var in sorted(singles, key=lambda x:x[0])[:8]:
        print(f'  {name:70s} n={n:5d} mean={ma:+.4f} rest={mb:+.4f} diff={eff:+.4f} p={p:.1e}')
    print('Top negative pair predicates vs rest:')
    for eff,p,ma,mb,n,name,v1,v2 in sorted(pairs, key=lambda x:x[0])[:10]:
        print(f'  {name:100s} n={n:5d} mean={ma:+.4f} rest={mb:+.4f} diff={eff:+.4f} p={p:.1e}')
