import json
from pathlib import Path
import numpy as np
import pandas as pd
from scipy import stats
import statsmodels.api as sm

wd = Path('.')
df = pd.read_parquet(wd / 'dataset.parquet')
N = len(df)

# Common thresholds from the observed dataset.
q75_growth = float(df['growth_rate_doublings_per_day'].quantile(0.75))
q75_wnt = float(df['wnt_activity_score'].quantile(0.75))
q75_myc_rna = float(df['rnaseq_MYC_log2_tpm'].quantile(0.75))
q75_cn8q24 = float(df['copy_number_8q24'].quantile(0.75))


def pnum(p):
    if np.isnan(p):
        return None
    return float(p)


def fmt_p(p):
    if p is None or np.isnan(p):
        return 'NA'
    if p == 0:
        return '<1e-300'
    if p < 1e-3:
        return f'{p:.2e}'
    return f'{p:.3g}'


def welch(out, mask_a, mask_b=None):
    mask_a = np.asarray(mask_a, dtype=bool)
    if mask_b is None:
        mask_b = ~mask_a
    else:
        mask_b = np.asarray(mask_b, dtype=bool)
    a = df.loc[mask_a, out].astype(float).to_numpy()
    b = df.loc[mask_b, out].astype(float).to_numpy()
    t, p = stats.ttest_ind(a, b, equal_var=False)
    return {
        'effect': float(a.mean() - b.mean()),
        'p': pnum(p),
        'mean_a': float(a.mean()),
        'mean_b': float(b.mean()),
        'n_a': int(len(a)),
        'n_b': int(len(b)),
    }


def bin_mask(col):
    return df[col].astype(bool).to_numpy()


def cat_mask(col, val):
    return (df[col] == val).to_numpy()


def high_mask(col, q):
    return (df[col] >= q).to_numpy()


def low_mask(col, q):
    return (df[col] <= q).to_numpy()


def ols_interaction(out, driver_mask, modifier_mask):
    y = df[out].astype(float).to_numpy()
    d = np.asarray(driver_mask, dtype=int)
    m = np.asarray(modifier_mask, dtype=int)
    X = pd.DataFrame({'const': 1.0, 'driver': d, 'modifier': m, 'interaction': d * m})
    fit = sm.OLS(y, X).fit()
    return {
        'effect': float(fit.params['interaction']),
        'p': pnum(fit.pvalues['interaction']),
    }


def adjusted_driver(out, driver_col):
    y = df[out].astype(float)
    X = pd.DataFrame({driver_col: df[driver_col].astype(float),
                      'cas9_activity_score': df['cas9_activity_score'].astype(float),
                      'growth_rate_doublings_per_day': df['growth_rate_doublings_per_day'].astype(float)})
    dummies = pd.get_dummies(df[['lineage', 'culture_type', 'screen_batch']], drop_first=True, dtype=float)
    X = pd.concat([X, dummies], axis=1)
    X = sm.add_constant(X)
    fit = sm.OLS(y, X).fit()
    return {'effect': float(fit.params[driver_col]), 'p': pnum(fit.pvalues[driver_col]), 'r2': float(fit.rsquared)}


def analysis(hids, res, summary, method):
    rec = {
        'hypothesis_ids': hids if isinstance(hids, list) else [hids],
        'result_summary': summary,
        'p_value': res['p'],
        'effect_estimate': res['effect'],
        'significant': (res['p'] is not None and res['p'] < 0.05),
        'method': method,
    }
    for key in ['mean_a', 'mean_b', 'n_a', 'n_b', 'r2']:
        if key in res:
            rec[key] = res[key]
    return rec


def hyp(hid, text, kind='novel'):
    return {'id': hid, 'text': text, 'kind': kind}

# Masks.
braf = bin_mask('braf_v600e')
egfr = bin_mask('egfr_amplification')
erbb2 = bin_mask('erbb2_amplification')
kras = bin_mask('kras_mutation')
nf1 = bin_mask('nf1_loss')
myc_amp = bin_mask('myc_amplification')
apc = bin_mask('apc_mutation')
smad4 = bin_mask('smad4_loss')
colorectal = cat_mask('lineage', 'colorectal')
skin = cat_mask('lineage', 'skin')
brain = cat_mask('lineage', 'brain')
pancreatic = cat_mask('lineage', 'pancreatic')
her2_enriched = cat_mask('lineage_subtype', 'her2_enriched')
luminal = cat_mask('lineage_subtype', 'luminal')
basal = cat_mask('lineage_subtype', 'basal')
growth_hi = high_mask('growth_rate_doublings_per_day', q75_growth)
wnt_hi = high_mask('wnt_activity_score', q75_wnt)
myc_rna_hi = high_mask('rnaseq_MYC_log2_tpm', q75_myc_rna)
cn8q24_hi = high_mask('copy_number_8q24', q75_cn8q24)

