+const fs = require("fs");
+
+const P = 1e-300;
+
+const transcript = {
+  dataset_id: "ds001_depmap",
+  model_id: "gpt-5-codex",
+  harness_id: "codex-cli-local@2026-05-04",
+  max_iterations: 10,
+  iterations: [
+    {
