+    else { n0++; s0 += v; ss0 += v * v; }
+  }
+  const m1 = s1 / n1, m0 = s0 / n0;
+  const v1 = (ss1 - s1 * s1 / n1) / Math.max(1, n1 - 1);
+  const v0 = (ss0 - s0 * s0 / n0) / Math.max(1, n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { n1, n0, mean1: m1, mean0: m0, effect: m1 - m0, z, p: norm2p(z) };
+}
+function corrStats(x, y) {
+  const n = x.length, mx = mean(x), my = mean(y);
+  let sxx = 0, syy = 0, sxy = 0;
+  for (let i = 0; i < n; i++) { const dx = x[i] - mx, dy = y[i] - my; sxx += dx * dx; syy += dy * dy; sxy += dx * dy; }
+  const slope = sxy / sxx, r = sxy / Math.sqrt(sxx * syy);
+  const z = r * Math.sqrt((n - 2) / Math.max(1e-15, 1 - r * r));
+  return { slope, r, p: norm2p(z) };
+}
+function quantile(vals, q) { const a = vals.slice().sort((x, y) => x - y); const pos = (a.length - 1) * q, lo = Math.floor(pos), hi = Math.ceil(pos); return lo === hi ? a[lo] : a[lo] + (a[hi] - a[lo]) * (pos - lo); }
+function countMask(mask) { let n = 0; for (const v of mask) if (v) n++; return n; }
+function andMask(a, b) { const out = new Array(a.length); for (let i = 0; i < a.length; i++) out[i] = a[i] && b[i]; return out; }
+
+const { data, columns, n } = loadParquet("dataset.parquet");
+const outcomes = columns.filter(c => c.startsWith("dependency_"));
+const categorical = ["lineage", "lineage_subtype", "culture_type", "screen_batch"];
+const binary = ["kras_mutation","braf_v600e","egfr_amplification","erbb2_amplification","pik3ca_mutation","apc_mutation","smad4_loss","nf1_loss","rb1_loss","myc_amplification","cdkn2a_loss","pten_loss","stk11_loss","brca2_loss","msi_high"];
+const continuous = columns.filter(c => !["cell_line_id", ...categorical, ...binary, ...outcomes].includes(c));
+
+const predicates = [];
+for (const c of binary) predicates.push({ name: `${c}=1`, col: c, mask: data[c].map(v => v === 1) });
+for (const c of categorical) {
+  const levels = [...new Set(data[c])];
+  for (const lev of levels) predicates.push({ name: `${c}=${lev}`, col: c, mask: data[c].map(v => v === lev) });
+}
+for (const c of continuous) {
+  const q25 = quantile(data[c], 0.25), q75 = quantile(data[c], 0.75);
+  predicates.push({ name: `${c}>=Q75(${q75.toFixed(3)})`, col: c, mask: data[c].map(v => v >= q75), threshold: q75 });
+  predicates.push({ name: `${c}<=Q25(${q25.toFixed(3)})`, col: c, mask: data[c].map(v => v <= q25), threshold: q25 });
+}
+for (const p of predicates) p.n = countMask(p.mask);
+const usablePreds = predicates.filter(p => p.n >= 400 && p.n <= n - 400);
+
+console.log("Loaded", n, "rows", columns.length, "columns");
+console.log("Outcome means");
+for (const out of outcomes) console.log(out, mean(data[out]).toFixed(4), Math.sqrt(variance(data[out])).toFixed(4));
+
+console.log("\\nTop single-predicate subgroup contrasts");
+const topByOutcome = {};
+for (const out of outcomes) {
+  const y = data[out];
+  const rows = [];
+  for (const p of usablePreds) {
+    const gs = groupStats(y, p.mask);
+    rows.push({ out, pred: p.name, n: gs.n1, effect: gs.effect, p: gs.p, mean1: gs.mean1, mean0: gs.mean0 });
+  }
+  rows.sort((a, b) => a.effect - b.effect);
+  topByOutcome[out] = rows.slice(0, 8);
+  console.log("\\n", out);
+  for (const r of rows.slice(0, 8)) console.log(`${r.pred}\tn=${r.n}\teffect=${r.effect.toFixed(4)}\tmean=${r.mean1.toFixed(4)} vs ${r.mean0.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nTop continuous correlations");
+for (const out of outcomes) {
+  const rows = continuous.map(c => ({ out, c, ...corrStats(data[c], data[out]) })).sort((a, b) => Math.abs(b.r) - Math.abs(a.r)).slice(0, 6);
+  console.log("\\n", out);
+  for (const r of rows) console.log(`${r.c}\tslope=${r.slope.toFixed(4)}\tr=${r.r.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nTop two-predicate negative dependency subgroup contrasts");
+const pairTopByOutcome = {};
+for (const out of outcomes) {
+  const y = data[out], rows = [];
+  for (let i = 0; i < usablePreds.length; i++) {
+    for (let j = i + 1; j < usablePreds.length; j++) {
+      if (usablePreds[i].col === usablePreds[j].col) continue;
+      const m = andMask(usablePreds[i].mask, usablePreds[j].mask);
+      const cnt = countMask(m);
+      if (cnt < 250 || cnt > n - 250) continue;
+      const gs = groupStats(y, m);
+      rows.push({ out, pred: `${usablePreds[i].name} AND ${usablePreds[j].name}`, n: cnt, effect: gs.effect, p: gs.p, mean1: gs.mean1, mean0: gs.mean0 });
+    }
+  }
+  rows.sort((a, b) => a.effect - b.effect);
+  pairTopByOutcome[out] = rows.slice(0, 10);
+  console.log("\\n", out);
+  for (const r of rows.slice(0, 10)) console.log(`${r.pred}\tn=${r.n}\teffect=${r.effect.toFixed(4)}\tmean=${r.mean1.toFixed(4)} vs ${r.mean0.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nSpecific known-driver contrasts");
+for (const [out, predName] of [["dependency_BRAF","braf_v600e=1"],["dependency_EGFR","egfr_amplification=1"],["dependency_ERBB2","erbb2_amplification=1"],["dependency_KRAS","kras_mutation=1"],["dependency_KIF18A","aneuploidy_score>=Q75("+quantile(data["aneuploidy_score"],0.75).toFixed(3)+")"]]) {
+  const p = predicates.find(x => x.name === predName);
+  const gs = groupStats(data[out], p.mask);
+  console.log(`${out} ~ ${predName}: n=${gs.n1}, effect=${gs.effect.toFixed(4)}, means=${gs.mean1.toFixed(4)} vs ${gs.mean0.toFixed(4)}, p=${gs.p.toExponential(3)}`);
+}
