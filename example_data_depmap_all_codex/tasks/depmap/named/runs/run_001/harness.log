+      const defLen = pg.data.readUInt32LE(0);
+      const afterDef = 4 + defLen;
+      const bitWidth = pg.data[afterDef];
+      const ids = decodeHybrid(pg.data, bitWidth, n, afterDef + 1);
+      for (const id of ids) out.push(dict[id]);
+      offset = pg.next;
+    }
