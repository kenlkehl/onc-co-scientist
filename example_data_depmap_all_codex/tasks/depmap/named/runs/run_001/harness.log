+    if (type === CT.TRUE) return true;
+    if (type === CT.FALSE) return false;
+    if (type === CT.BYTE) { const b = this.byte(); return b > 127 ? b - 256 : b; }
+    if (type === CT.I16 || type === CT.I32) return this.zigzag();
+    if (type === CT.I64) return Number(this.zigzagBig());
+    if (type === CT.DOUBLE) return this.double();
+    if (type === CT.FLOAT) return this.float();
+    if (type === CT.BINARY) return this.binary().toString("utf8");
+    if (type === CT.STRUCT) return this.struct();
+    if (type === CT.LIST || type === CT.SET) { const { size, elemType } = this.listHeader(); const a = []; for (let i = 0; i < size; i++) a.push(this.readValue(elemType)); return a; }
+    if (type === CT.MAP) { const size = this.varint(); if (size === 0) return []; const kv = this.byte(); const kt = kv >> 4, vt = kv & 0x0f; const a = []; for (let i = 0; i < size; i++) a.push([this.readValue(kt), this.readValue(vt)]); return a; }
+    throw new Error(`unsupported compact type ${type}`);
+  }
+  struct() { const obj = {}; let last = 0; while (true) { const hb = this.byte(); const type = hb & 0x0f; if (type === CT.STOP) break; const delta = hb >> 4; const fid = delta === 0 ? this.zigzag() : last + delta; last = fid; obj[fid] = this.readValue(type); } return obj; }
+}
+
+function snappy(buf) {
+  let ip = 0, len = 0, shift = 0;
+  while (true) { const c = buf[ip++]; len |= (c & 0x7f) << shift; if ((c & 0x80) === 0) break; shift += 7; }
