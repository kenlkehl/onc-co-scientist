+        { id: "h33", text: "The final best-supported subgroup for `dependency_KRAS` is `kras_mutation=1`, with more negative `dependency_KRAS` than `kras_mutation=0`.", kind: "refined" },
+        { id: "h34", text: "The final best-supported subgroup for `dependency_RIT1` is `nf1_loss=1`, especially `nf1_loss=1` and `lineage=brain`, with more negative `dependency_RIT1` than other lines.", kind: "refined" },
+        { id: "h35", text: "The final best-supported subgroup for `dependency_KIF18A` is `lineage=colorectal`, `apc_mutation=1`, and `wnt_activity_score>=0.819`, with more negative `dependency_KIF18A` than all other lines.", kind: "refined" },
+        { id: "h36", text: "The final best-supported subgroup for `dependency_TMED10` is high `growth_rate_doublings_per_day` (>=0.964), with more negative `dependency_TMED10` than slower-growing lines.", kind: "refined" },
+        { id: "h37", text: "The final best-supported subgroup for `dependency_DHX9` is high `growth_rate_doublings_per_day` combined with high `rnaseq_MYC_log2_tpm` (>=5.669), with more negative `dependency_DHX9` than all other lines.", kind: "refined" },
+        { id: "h38", text: "The final best-supported subgroup for `dependency_POLR2A` is high `growth_rate_doublings_per_day` (>=0.964), with more negative `dependency_POLR2A` than slower-growing lines.", kind: "refined" },
+        { id: "h39", text: "The final best-supported subgroup for `dependency_RPL11` is `myc_amplification=1` combined with high `growth_rate_doublings_per_day` (>=0.964), with more negative `dependency_RPL11` than all other lines.", kind: "refined" }
+      ],
+      analyses: [
+        { hypothesis_ids: ["h30"], code: "Final selected subgroup contrast for dependency_BRAF.", result_summary: "Final BRAF subgroup `braf_v600e=1`: effect -0.5552, means -0.8047 versus -0.2495.", p_value: P, effect_estimate: -0.5552, significant: true },
+        { hypothesis_ids: ["h31"], code: "Final selected subgroup contrast for dependency_EGFR.", result_summary: "Final EGFR subgroup `egfr_amplification=1`: effect -0.3486, means -0.6010 versus -0.2524.", p_value: P, effect_estimate: -0.3486, significant: true },
+        { hypothesis_ids: ["h32"], code: "Final selected subgroup contrast for dependency_ERBB2.", result_summary: "Final ERBB2 subgroup `erbb2_amplification=1`: effect -0.4321, means -0.6856 versus -0.2535.", p_value: P, effect_estimate: -0.4321, significant: true },
+        { hypothesis_ids: ["h33"], code: "Final selected subgroup contrast for dependency_KRAS.", result_summary: "Final KRAS subgroup `kras_mutation=1`: effect -0.3075, means -0.5594 versus -0.2520.", p_value: P, effect_estimate: -0.3075, significant: true },
+        { hypothesis_ids: ["h34"], code: "Final selected subgroup contrasts for dependency_RIT1.", result_summary: "Final RIT1 broad subgroup `nf1_loss=1`: effect -0.0955; refined `nf1_loss=1`/brain subgroup effect -0.1397.", p_value: P, effect_estimate: -0.0955, significant: true },
+        { hypothesis_ids: ["h35"], code: "Final selected three-predicate subgroup contrast for dependency_KIF18A.", result_summary: "Final KIF18A subgroup `lineage=colorectal`, `apc_mutation=1`, `wnt_activity_score>=0.819`: effect -0.8589, means -1.1119 versus -0.2530.", p_value: P, effect_estimate: -0.8589, significant: true },
+        { hypothesis_ids: ["h36"], code: "Final selected subgroup contrast for dependency_TMED10.", result_summary: "Final TMED10 subgroup high `growth_rate_doublings_per_day`: effect -0.0369, means -0.2816 versus -0.2447.", p_value: P, effect_estimate: -0.0369, significant: true },
+        { hypothesis_ids: ["h37"], code: "Final selected two-predicate subgroup contrast for dependency_DHX9.", result_summary: "Final DHX9 subgroup high growth plus high `rnaseq_MYC_log2_tpm`: effect -0.0595, means -0.3892 versus -0.3297.", p_value: P, effect_estimate: -0.0595, significant: true },
