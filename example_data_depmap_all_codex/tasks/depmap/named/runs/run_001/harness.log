+}
+function quantile(vals, q) { const a = vals.slice().sort((x, y) => x - y); const pos = (a.length - 1) * q, lo = Math.floor(pos), hi = Math.ceil(pos); return lo === hi ? a[lo] : a[lo] + (a[hi] - a[lo]) * (pos - lo); }
+function countMask(mask) { let n = 0; for (const v of mask) if (v) n++; return n; }
+function andMask(a, b) { const out = new Array(a.length); for (let i = 0; i < a.length; i++) out[i] = a[i] && b[i]; return out; }
+
+const { data, columns, n } = loadParquet("dataset.parquet");
+const outcomes = columns.filter(c => c.startsWith("dependency_"));
+const categorical = ["lineage", "lineage_subtype", "culture_type", "screen_batch"];
+const binary = ["kras_mutation","braf_v600e","egfr_amplification","erbb2_amplification","pik3ca_mutation","apc_mutation","smad4_loss","nf1_loss","rb1_loss","myc_amplification","cdkn2a_loss","pten_loss","stk11_loss","brca2_loss","msi_high"];
+const continuous = columns.filter(c => !["cell_line_id", ...categorical, ...binary, ...outcomes].includes(c));
+
+const predicates = [];
+for (const c of binary) predicates.push({ name: `${c}=1`, col: c, mask: data[c].map(v => v === 1) });
+for (const c of categorical) {
+  const levels = [...new Set(data[c])];
+  for (const lev of levels) predicates.push({ name: `${c}=${lev}`, col: c, mask: data[c].map(v => v === lev) });
+}
+for (const c of continuous) {
+  const q25 = quantile(data[c], 0.25), q75 = quantile(data[c], 0.75);
+  predicates.push({ name: `${c}>=Q75(${q75.toFixed(3)})`, col: c, mask: data[c].map(v => v >= q75), threshold: q75 });
+  predicates.push({ name: `${c}<=Q25(${q25.toFixed(3)})`, col: c, mask: data[c].map(v => v <= q25), threshold: q25 });
+}
+for (const p of predicates) p.n = countMask(p.mask);
+const usablePreds = predicates.filter(p => p.n >= 400 && p.n <= n - 400);
+
+console.log("Loaded", n, "rows", columns.length, "columns");
+console.log("Outcome means");
+for (const out of outcomes) console.log(out, mean(data[out]).toFixed(4), Math.sqrt(variance(data[out])).toFixed(4));
+
+console.log("\\nTop single-predicate subgroup contrasts");
+const topByOutcome = {};
+for (const out of outcomes) {
+  const y = data[out];
+  const rows = [];
+  for (const p of usablePreds) {
+    const gs = groupStats(y, p.mask);
+    rows.push({ out, pred: p.name, n: gs.n1, effect: gs.effect, p: gs.p, mean1: gs.mean1, mean0: gs.mean0 });
+  }
+  rows.sort((a, b) => a.effect - b.effect);
+  topByOutcome[out] = rows.slice(0, 8);
+  console.log("\\n", out);
+  for (const r of rows.slice(0, 8)) console.log(`${r.pred}\tn=${r.n}\teffect=${r.effect.toFixed(4)}\tmean=${r.mean1.toFixed(4)} vs ${r.mean0.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nTop continuous correlations");
+for (const out of outcomes) {
+  const rows = continuous.map(c => ({ out, c, ...corrStats(data[c], data[out]) })).sort((a, b) => Math.abs(b.r) - Math.abs(a.r)).slice(0, 6);
+  console.log("\\n", out);
+  for (const r of rows) console.log(`${r.c}\tslope=${r.slope.toFixed(4)}\tr=${r.r.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nTop two-predicate negative dependency subgroup contrasts");
+const pairTopByOutcome = {};
+for (const out of outcomes) {
+  const y = data[out], rows = [];
+  for (let i = 0; i < usablePreds.length; i++) {
+    for (let j = i + 1; j < usablePreds.length; j++) {
+      if (usablePreds[i].col === usablePreds[j].col) continue;
+      const m = andMask(usablePreds[i].mask, usablePreds[j].mask);
+      const cnt = countMask(m);
+      if (cnt < 250 || cnt > n - 250) continue;
+      const gs = groupStats(y, m);
+      rows.push({ out, pred: `${usablePreds[i].name} AND ${usablePreds[j].name}`, n: cnt, effect: gs.effect, p: gs.p, mean1: gs.mean1, mean0: gs.mean0 });
+    }
+  }
+  rows.sort((a, b) => a.effect - b.effect);
+  pairTopByOutcome[out] = rows.slice(0, 10);
+  console.log("\\n", out);
+  for (const r of rows.slice(0, 10)) console.log(`${r.pred}\tn=${r.n}\teffect=${r.effect.toFixed(4)}\tmean=${r.mean1.toFixed(4)} vs ${r.mean0.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nSpecific known-driver contrasts");
+for (const [out, predName] of [["dependency_BRAF","braf_v600e=1"],["dependency_EGFR","egfr_amplification=1"],["dependency_ERBB2","erbb2_amplification=1"],["dependency_KRAS","kras_mutation=1"],["dependency_KIF18A","aneuploidy_score>=Q75("+quantile(data["aneuploidy_score"],0.75).toFixed(3)+")"]]) {
+  const p = predicates.find(x => x.name === predName);
+  const gs = groupStats(data[out], p.mask);
+  console.log(`${out} ~ ${predName}: n=${gs.n1}, effect=${gs.effect.toFixed(4)}, means=${gs.mean1.toFixed(4)} vs ${gs.mean0.toFixed(4)}, p=${gs.p.toExponential(3)}`);
+}
+
+console.log("\\nKIF18A colorectal/APC/WNT/ASCL2 drill-down");
+const qWnt = quantile(data["wnt_activity_score"], 0.75);
+const qAscl2 = quantile(data["rnaseq_ASCL2_log2_tpm"], 0.75);
+const masks = {
+  colorectal: data.lineage.map(v => v === "colorectal"),
+  apc: data.apc_mutation.map(v => v === 1),
+  highWnt: data.wnt_activity_score.map(v => v >= qWnt),
+  highAscl2: data.rnaseq_ASCL2_log2_tpm.map(v => v >= qAscl2),
+};
+function comboMask(keys) {
+  const out = new Array(n).fill(true);
+  for (const k of keys) {
+    const neg = k.startsWith("!");
+    const key = neg ? k.slice(1) : k;
+    for (let i = 0; i < n; i++) out[i] = out[i] && (neg ? !masks[key][i] : masks[key][i]);
+  }
+  return out;
+}
+const defs = [
+  ["colorectal"], ["!colorectal"],
+  ["colorectal","apc"], ["colorectal","!apc"],
+  ["colorectal","highWnt"], ["colorectal","!highWnt"],
+  ["colorectal","apc","highWnt"], ["colorectal","apc","!highWnt"], ["colorectal","!apc","highWnt"], ["colorectal","!apc","!highWnt"],
+  ["colorectal","apc","highWnt","highAscl2"], ["colorectal","apc","highWnt","!highAscl2"],
+  ["!colorectal","apc","highWnt"], ["!colorectal","!apc","highWnt"],
+];
+for (const d of defs) {
+  const m = comboMask(d);
+  const cnt = countMask(m);
+  if (cnt === 0) continue;
+  const gs = groupStats(data.dependency_KIF18A, m);
+  console.log(`${d.join(" AND ")}\tn=${cnt}\tmean=${gs.mean1.toFixed(4)}\trest=${gs.mean0.toFixed(4)}\teffect=${gs.effect.toFixed(4)}\tp=${gs.p.toExponential(2)}`);
+}
+
+console.log("\\nKIF18A top three-predicate subgroups");
+const kifRows = [];
+for (let i = 0; i < usablePreds.length; i++) {
+  for (let j = i + 1; j < usablePreds.length; j++) {
+    if (usablePreds[i].col === usablePreds[j].col) continue;
+    const ij = andMask(usablePreds[i].mask, usablePreds[j].mask);
+    const nij = countMask(ij);
+    if (nij < 250) continue;
+    for (let k = j + 1; k < usablePreds.length; k++) {
+      if (usablePreds[k].col === usablePreds[i].col || usablePreds[k].col === usablePreds[j].col) continue;
+      const m = andMask(ij, usablePreds[k].mask);
+      const cnt = countMask(m);
+      if (cnt < 200 || cnt > n - 200) continue;
+      const gs = groupStats(data.dependency_KIF18A, m);
+      kifRows.push({ pred: `${usablePreds[i].name} AND ${usablePreds[j].name} AND ${usablePreds[k].name}`, n: cnt, ...gs });
+    }
+  }
+}
+kifRows.sort((a, b) => a.effect - b.effect);
+for (const r of kifRows.slice(0, 12)) console.log(`${r.pred}\tn=${r.n}\teffect=${r.effect.toFixed(4)}\tmean=${r.mean1.toFixed(4)} vs ${r.mean0.toFixed(4)}\tp=${r.p.toExponential(2)}`);
diff --git a/example_data_depmap/tasks/depmap/named/parquet_probe.js b/example_data_depmap/tasks/depmap/named/parquet_probe.js
new file mode 100644
index 0000000000000000000000000000000000000000..8fbf22f30da25ef38d72a0b9fedf190b1d256600
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/named/parquet_probe.js
@@ -0,0 +1,309 @@
+const fs = require("fs");
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+  FLOAT: 13,
+};
+
+class Compact {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.off = offset;
+    this.end = end;
+  }
+  byte() {
+    return this.buf[this.off++];
+  }
+  varintBig() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      out |= (b & 0x7fn) << shift;
+      if ((b & 0x80n) === 0n) return out;
+      shift += 7n;
+    }
+  }
+  varint() {
+    return Number(this.varintBig());
+  }
+  zigzagBig() {
+    const n = this.varintBig();
+    return (n >> 1n) ^ (-(n & 1n));
+  }
+  zigzag() {
+    return Number(this.zigzagBig());
+  }
+  double() {
+    const v = this.buf.readDoubleLE(this.off);
+    this.off += 8;
+    return v;
+  }
+  float() {
+    const v = this.buf.readFloatLE(this.off);
+    this.off += 4;
+    return v;
+  }
+  binary() {
+    const n = this.varint();
+    const out = this.buf.slice(this.off, this.off + n);
+    this.off += n;
+    return out;
+  }
+  listHeader() {
+    const b = this.byte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = this.varint();
+    return { size, elemType };
+  }
+  readValue(type) {
+    if (type === CT.TRUE) return true;
+    if (type === CT.FALSE) return false;
+    if (type === CT.BYTE) {
+      const b = this.byte();
+      return b > 127 ? b - 256 : b;
+    }
+    if (type === CT.I16 || type === CT.I32) return this.zigzag();
+    if (type === CT.I64) return Number(this.zigzagBig());
+    if (type === CT.DOUBLE) return this.double();
+    if (type === CT.FLOAT) return this.float();
+    if (type === CT.BINARY) return this.binary().toString("utf8");
+    if (type === CT.STRUCT) return this.struct();
+    if (type === CT.LIST || type === CT.SET) {
+      const { size, elemType } = this.listHeader();
+      const a = [];
+      for (let i = 0; i < size; i++) a.push(this.readValue(elemType));
+      return a;
+    }
+    if (type === CT.MAP) {
+      const size = this.varint();
+      if (size === 0) return [];
+      const kv = this.byte();
+      const kt = kv >> 4;
+      const vt = kv & 0x0f;
+      const a = [];
+      for (let i = 0; i < size; i++) a.push([this.readValue(kt), this.readValue(vt)]);
+      return a;
+    }
+    throw new Error(`unsupported compact type ${type} at ${this.off}`);
+  }
+  struct() {
+    const obj = {};
+    let last = 0;
+    while (true) {
+      const hb = this.byte();
+      const type = hb & 0x0f;
+      if (type === CT.STOP) break;
+      const delta = hb >> 4;
+      const fid = delta === 0 ? this.zigzag() : last + delta;
+      last = fid;
+      obj[fid] = this.readValue(type);
+    }
+    return obj;
+  }
+}
+
+const b = fs.readFileSync("dataset.parquet");
+const metadataLen = b.readUInt32LE(b.length - 8);
+const metadataStart = b.length - 8 - metadataLen;
+const meta = new Compact(b, metadataStart, b.length - 8).struct();
+
+const typeNames = ["BOOLEAN", "INT32", "INT64", "INT96", "FLOAT", "DOUBLE", "BYTE_ARRAY", "FIXED_LEN_BYTE_ARRAY"];
+const codecNames = ["UNCOMPRESSED", "SNAPPY", "GZIP", "LZO", "BROTLI", "LZ4", "ZSTD", "LZ4_RAW"];
+const encodingNames = ["PLAIN", "PLAIN_DICTIONARY", "PLAIN_DICTIONARY_OLD", "RLE", "BIT_PACKED", "DELTA_BINARY_PACKED", "DELTA_LENGTH_BYTE_ARRAY", "DELTA_BYTE_ARRAY", "RLE_DICTIONARY", "BYTE_STREAM_SPLIT"];
+
+function snappy(buf) {
+  let ip = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const c = buf[ip++];
+    len |= (c & 0x7f) << shift;
+    if ((c & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (ip < buf.length) {
+    const tag = buf[ip++];
+    const typ = tag & 3;
+    if (typ === 0) {
+      let n = tag >> 2;
+      if (n < 60) {
+        n += 1;
+      } else {
+        const bytes = n - 59;
+        n = 0;
+        for (let i = 0; i < bytes; i++) n |= buf[ip++] << (8 * i);
+        n += 1;
+      }
+      buf.copy(out, op, ip, ip + n);
+      ip += n;
+      op += n;
+    } else {
+      let n, off;
+      if (typ === 1) {
+        n = ((tag >> 2) & 0x7) + 4;
+        off = ((tag & 0xe0) << 3) | buf[ip++];
+      } else if (typ === 2) {
+        n = (tag >> 2) + 1;
+        off = buf.readUInt16LE(ip);
+        ip += 2;
+      } else {
+        n = (tag >> 2) + 1;
+        off = buf.readUInt32LE(ip);
+        ip += 4;
+      }
+      for (let i = 0; i < n; i++) out[op + i] = out[op - off + i];
+      op += n;
+    }
+  }
+  if (op !== len) throw new Error(`snappy length mismatch ${op} != ${len}`);
+  return out;
+}
+
+function pageAt(offset) {
+  const p = new Compact(b, offset);
+  const header = p.struct();
+  const body = b.slice(p.off, p.off + header[3]);
+  return { header, headerBytes: p.off - offset, compressed: body, data: snappy(body), next: p.off + header[3] };
+}
+
+function decodePlainDict(data, type, n) {
+  const out = [];
+  let off = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === "BYTE_ARRAY") {
+      const len = data.readUInt32LE(off);
+      off += 4;
+      out.push(data.slice(off, off + len).toString("utf8"));
+      off += len;
+    } else if (type === "DOUBLE") {
+      out.push(data.readDoubleLE(off));
+      off += 8;
+    } else if (type === "INT64") {
+      out.push(Number(data.readBigInt64LE(off)));
+      off += 8;
+    } else {
+      throw new Error(`unsupported dict type ${type}`);
+    }
+  }
+  return out;
+}
+
+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let out = 0;
+  while (true) {
+    const c = buf[state.off++];
+    out |= (c & 0x7f) << shift;
+    if ((c & 0x80) === 0) return out;
+    shift += 7;
+  }
+}
+
+function decodeHybrid(buf, bitWidth, count, start = 0) {
+  const st = { off: start };
+  const values = [];
+  const mask = bitWidth === 32 ? 0xffffffff : (1 << bitWidth) - 1;
+  const byteWidth = Math.ceil(bitWidth / 8);
+  while (values.length < count) {
+    const header = readVarintFrom(buf, st);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      let val = 0;
+      for (let i = 0; i < byteWidth; i++) val |= buf[st.off++] << (8 * i);
+      for (let i = 0; i < run && values.length < count; i++) values.push(val);
+    } else {
+      const groups = header >> 1;
+      const run = groups * 8;
+      let acc = 0;
+      let bits = 0;
+      for (let i = 0; i < run; i++) {
+        while (bits < bitWidth) {
+          acc |= buf[st.off++] << bits;
+          bits += 8;
+        }
+        if (values.length < count) values.push(acc & mask);
+        acc >>= bitWidth;
+        bits -= bitWidth;
+      }
+    }
+  }
+  return { values, offset: st.off };
+}
+
+function readColumn(colIndex) {
+  const md = rg[1][colIndex][3];
+  const name = md[3][0];
+  const type = typeNames[md[1]];
+  const dictPage = pageAt(md[11]);
+  const dict = decodePlainDict(dictPage.data, type, dictPage.header[7][1]);
+  let offset = dictPage.next;
+  const out = [];
+  while (out.length < md[5]) {
+    const pg = pageAt(offset);
+    if (pg.header[1] !== 0) throw new Error(`unexpected page type ${pg.header[1]} for ${name}`);
+    const dh = pg.header[5];
+    const n = dh[1];
+    const defLen = pg.data.readUInt32LE(0);
+    const afterDef = 4 + defLen;
+    const bitWidth = pg.data[afterDef];
+    const decoded = decodeHybrid(pg.data, bitWidth, n, afterDef + 1).values;
+    for (const id of decoded) out.push(dict[id]);
+    offset = pg.next;
+  }
+  return out;
+}
+
+console.log("version", meta[1], "numRows", meta[3], "rowGroups", meta[4].length);
+const schema = meta[2];
+console.log("schema");
+for (let i = 0; i < schema.length; i++) {
+  console.log(i, JSON.stringify({ name: schema[i][4], type: typeNames[schema[i][1]], repetition: schema[i][3], children: schema[i][5], converted: schema[i][6] }));
+}
+const rg = meta[4][0];
+console.log("rowgroup rows", rg[3], "cols", rg[1].length);
+for (let i = 0; i < rg[1].length; i++) {
+  const cc = rg[1][i];
+  const md = cc[3];
+  console.log(i, JSON.stringify({
+    path: md[3],
+    type: typeNames[md[1]],
+    codec: codecNames[md[4]],
+    enc: md[2].map(x => encodingNames[x] || x),
+    num_values: md[5],
+    comp: md[7],
+    uncomp: md[6],
+    data: md[9],
+    dict: md[11] || null,
+  }));
+}
+
+for (const i of [1, 6, 11, 37, 42]) {
+  const md = rg[1][i][3];
+  const dp = pageAt(md[9]);
+  const dict = pageAt(md[11]);
+  console.log("probePage", i, md[3][0], "dictHeader", dict.header, "dictDataLen", dict.data.length, "dataHeader", dp.header, "dataLen", dp.data.length, "firstData", Array.from(dp.data.slice(0, 24)));
+}
+
+for (const i of [1, 2, 11, 26, 37, 42]) {
+  const vals = readColumn(i);
+  const name = rg[1][i][3][3][0];
+  const head = vals.slice(0, 8);
+  const uniq = new Set(vals).size;
+  console.log("decoded", i, name, "n", vals.length, "unique", uniq, "head", JSON.stringify(head));
+}
