import pandas as pd
from pathlib import Path
p=Path('dataset.parquet')
df=pd.read_parquet(p)
print(df.shape)
print(list(df.columns))
print(df.dtypes.to_string())
print('\\nLineage counts')
print(df['lineage'].value_counts().to_string())
print('\\nLineage subtype top')
print(df['lineage_subtype'].value_counts().head(20).to_string())
print('\\nBinary feature prevalences')
bin_cols=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
print(df[bin_cols].mean().sort_values(ascending=False).to_string())
outcomes=[c for c in df.columns if c.startswith('dependency_')]
print('\\nOutcome summaries')
print(df[outcomes].describe().T[['mean','std','min','25%','50%','75%','max']].to_string())
print('\\nContinuous correlations with dependencies')
cont=[c for c in df.columns if c not in ['cell_line_id','lineage','lineage_subtype','culture_type','screen_batch']+bin_cols+outcomes]
corr=df[cont+outcomes].corr().loc[cont,outcomes]
for out in outcomes:
    print('\\n',out)
    print(corr[out].abs().sort_values(ascending=False).head(10).to_string())
