+const topByOutcome = {};
+for (const out of outcomes) {
+  const y = data[out];
+  const rows = [];
+  for (const p of usablePreds) {
+    const gs = groupStats(y, p.mask);
+    rows.push({ out, pred: p.name, n: gs.n1, effect: gs.effect, p: gs.p, mean1: gs.mean1, mean0: gs.mean0 });
+  }
+  rows.sort((a, b) => a.effect - b.effect);
+  topByOutcome[out] = rows.slice(0, 8);
+  console.log("\\n", out);
+  for (const r of rows.slice(0, 8)) console.log(`${r.pred}\tn=${r.n}\teffect=${r.effect.toFixed(4)}\tmean=${r.mean1.toFixed(4)} vs ${r.mean0.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nTop continuous correlations");
+for (const out of outcomes) {
+  const rows = continuous.map(c => ({ out, c, ...corrStats(data[c], data[out]) })).sort((a, b) => Math.abs(b.r) - Math.abs(a.r)).slice(0, 6);
+  console.log("\\n", out);
+  for (const r of rows) console.log(`${r.c}\tslope=${r.slope.toFixed(4)}\tr=${r.r.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nTop two-predicate negative dependency subgroup contrasts");
+const pairTopByOutcome = {};
+for (const out of outcomes) {
+  const y = data[out], rows = [];
+  for (let i = 0; i < usablePreds.length; i++) {
+    for (let j = i + 1; j < usablePreds.length; j++) {
+      if (usablePreds[i].col === usablePreds[j].col) continue;
+      const m = andMask(usablePreds[i].mask, usablePreds[j].mask);
+      const cnt = countMask(m);
+      if (cnt < 250 || cnt > n - 250) continue;
+      const gs = groupStats(y, m);
+      rows.push({ out, pred: `${usablePreds[i].name} AND ${usablePreds[j].name}`, n: cnt, effect: gs.effect, p: gs.p, mean1: gs.mean1, mean0: gs.mean0 });
+    }
+  }
+  rows.sort((a, b) => a.effect - b.effect);
+  pairTopByOutcome[out] = rows.slice(0, 10);
+  console.log("\\n", out);
+  for (const r of rows.slice(0, 10)) console.log(`${r.pred}\tn=${r.n}\teffect=${r.effect.toFixed(4)}\tmean=${r.mean1.toFixed(4)} vs ${r.mean0.toFixed(4)}\tp=${r.p.toExponential(2)}`);
+}
+
+console.log("\\nSpecific known-driver contrasts");
+for (const [out, predName] of [["dependency_BRAF","braf_v600e=1"],["dependency_EGFR","egfr_amplification=1"],["dependency_ERBB2","erbb2_amplification=1"],["dependency_KRAS","kras_mutation=1"],["dependency_KIF18A","aneuploidy_score>=Q75("+quantile(data["aneuploidy_score"],0.75).toFixed(3)+")"]]) {
+  const p = predicates.find(x => x.name === predName);
+  const gs = groupStats(data[out], p.mask);
+  console.log(`${out} ~ ${predName}: n=${gs.n1}, effect=${gs.effect.toFixed(4)}, means=${gs.mean1.toFixed(4)} vs ${gs.mean0.toFixed(4)}, p=${gs.p.toExponential(3)}`);
+}
+
+console.log("\\nKIF18A colorectal/APC/WNT/ASCL2 drill-down");
+const qWnt = quantile(data["wnt_activity_score"], 0.75);
+const qAscl2 = quantile(data["rnaseq_ASCL2_log2_tpm"], 0.75);
+const masks = {
+  colorectal: data.lineage.map(v => v === "colorectal"),
+  apc: data.apc_mutation.map(v => v === 1),
+  highWnt: data.wnt_activity_score.map(v => v >= qWnt),
+  highAscl2: data.rnaseq_ASCL2_log2_tpm.map(v => v >= qAscl2),
+};
+function comboMask(keys) {
+  const out = new Array(n).fill(true);
+  for (const k of keys) {
+    const neg = k.startsWith("!");
+    const key = neg ? k.slice(1) : k;
+    for (let i = 0; i < n; i++) out[i] = out[i] && (neg ? !masks[key][i] : masks[key][i]);
+  }
+  return out;
+}
+const defs = [
+  ["colorectal"], ["!colorectal"],
+  ["colorectal","apc"], ["colorectal","!apc"],
+  ["colorectal","highWnt"], ["colorectal","!highWnt"],
+  ["colorectal","apc","highWnt"], ["colorectal","apc","!highWnt"], ["colorectal","!apc","highWnt"], ["colorectal","!apc","!highWnt"],
+  ["colorectal","apc","highWnt","highAscl2"], ["colorectal","apc","highWnt","!highAscl2"],
+  ["!colorectal","apc","highWnt"], ["!colorectal","!apc","highWnt"],
+];
+for (const d of defs) {
+  const m = comboMask(d);
+  const cnt = countMask(m);
+  if (cnt === 0) continue;
+  const gs = groupStats(data.dependency_KIF18A, m);
+  console.log(`${d.join(" AND ")}\tn=${cnt}\tmean=${gs.mean1.toFixed(4)}\trest=${gs.mean0.toFixed(4)}\teffect=${gs.effect.toFixed(4)}\tp=${gs.p.toExponential(2)}`);
+}
+
+console.log("\\nKIF18A top three-predicate subgroups");
+const kifRows = [];
+for (let i = 0; i < usablePreds.length; i++) {
+  for (let j = i + 1; j < usablePreds.length; j++) {
+    if (usablePreds[i].col === usablePreds[j].col) continue;
+    const ij = andMask(usablePreds[i].mask, usablePreds[j].mask);
+    const nij = countMask(ij);
+    if (nij < 250) continue;
+    for (let k = j + 1; k < usablePreds.length; k++) {
+      if (usablePreds[k].col === usablePreds[i].col || usablePreds[k].col === usablePreds[j].col) continue;
+      const m = andMask(ij, usablePreds[k].mask);
+      const cnt = countMask(m);
+      if (cnt < 200 || cnt > n - 200) continue;
+      const gs = groupStats(data.dependency_KIF18A, m);
+      kifRows.push({ pred: `${usablePreds[i].name} AND ${usablePreds[j].name} AND ${usablePreds[k].name}`, n: cnt, ...gs });
+    }
+  }
+}
+kifRows.sort((a, b) => a.effect - b.effect);
+for (const r of kifRows.slice(0, 12)) console.log(`${r.pred}\tn=${r.n}\teffect=${r.effect.toFixed(4)}\tmean=${r.mean1.toFixed(4)} vs ${r.mean0.toFixed(4)}\tp=${r.p.toExponential(2)}`);
