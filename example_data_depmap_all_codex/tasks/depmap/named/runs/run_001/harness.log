+        { hypothesis_ids: ["h2"], code: "Two-sample mean contrast of dependency_EGFR by egfr_amplification.", result_summary: "`dependency_EGFR` averaged -0.6010 in `egfr_amplification=1` lines (n=3880) versus -0.2524 otherwise; the signed difference was -0.3486.", p_value: P, effect_estimate: -0.3486, significant: true },
+        { hypothesis_ids: ["h3"], code: "Two-sample mean contrast of dependency_ERBB2 by erbb2_amplification.", result_summary: "`dependency_ERBB2` averaged -0.6856 in `erbb2_amplification=1` lines (n=4890) versus -0.2535 otherwise; the signed difference was -0.4321.", p_value: P, effect_estimate: -0.4321, significant: true },
+        { hypothesis_ids: ["h4"], code: "Two-sample mean contrast of dependency_KRAS by kras_mutation.", result_summary: "`dependency_KRAS` averaged -0.5594 in `kras_mutation=1` lines (n=11842) versus -0.2520 otherwise; the signed difference was -0.3075.", p_value: P, effect_estimate: -0.3075, significant: true }
+      ]
+    },
+    {
+      index: 2,
+      proposed_hypotheses: [
+        { id: "h5", text: "Skin-lineage cell lines have more negative `dependency_BRAF` scores than non-skin cell lines, consistent with enrichment for BRAF-pathway dependence.", kind: "refined" },
+        { id: "h6", text: "Pancreatic-lineage cell lines have more negative `dependency_KRAS` scores than non-pancreatic cell lines, beyond the screen-wide average.", kind: "refined" },
+        { id: "h7", text: "Brain-lineage cell lines have more negative `dependency_EGFR` scores than non-brain cell lines.", kind: "refined" }
+      ],
+      analyses: [
+        { hypothesis_ids: ["h5"], code: "Lineage subgroup contrast for dependency_BRAF: lineage == 'skin' versus all other lineages.", result_summary: "`dependency_BRAF` was -0.4721 in skin lines (n=4935) versus -0.2938 in all other lines; effect -0.1783.", p_value: P, effect_estimate: -0.1783, significant: true },
+        { hypothesis_ids: ["h6"], code: "Lineage subgroup contrast for dependency_KRAS: lineage == 'pancreatic' versus all other lineages.", result_summary: "`dependency_KRAS` was -0.4260 in pancreatic lines (n=5102) versus -0.3133 in all other lines; effect -0.1127.", p_value: P, effect_estimate: -0.1127, significant: true },
+        { hypothesis_ids: ["h7"], code: "Lineage subgroup contrast for dependency_EGFR: lineage == 'brain' versus all other lineages.", result_summary: "`dependency_EGFR` was -0.3307 in brain lines (n=3565) versus -0.2755 in all other lines; effect -0.0552.", p_value: 1.11e-16, effect_estimate: -0.0552, significant: true }
+      ]
+    },
+    {
+      index: 3,
