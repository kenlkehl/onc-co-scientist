new file mode 100644
index 0000000000000000000000000000000000000000..8fbf22f30da25ef38d72a0b9fedf190b1d256600
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/named/parquet_probe.js
@@ -0,0 +1,309 @@
+const fs = require("fs");
+
+const CT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+  FLOAT: 13,
+};
+
+class Compact {
+  constructor(buf, offset = 0, end = buf.length) {
+    this.buf = buf;
+    this.off = offset;
+    this.end = end;
+  }
+  byte() {
+    return this.buf[this.off++];
+  }
+  varintBig() {
+    let shift = 0n;
+    let out = 0n;
+    while (true) {
+      const b = BigInt(this.byte());
+      out |= (b & 0x7fn) << shift;
