index 0000000000000000000000000000000000000000..40121187c7fe9b51d5b930a326c72d751b2441e5
--- /dev/null
+++ b/example_data_depmap/tasks/depmap/named/depmap_analysis_work.js
@@ -0,0 +1,279 @@
+const fs = require("fs");
+
+const CT = { STOP: 0, TRUE: 1, FALSE: 2, BYTE: 3, I16: 4, I32: 5, I64: 6, DOUBLE: 7, BINARY: 8, LIST: 9, SET: 10, MAP: 11, STRUCT: 12, FLOAT: 13 };
+class Compact {
+  constructor(buf, offset = 0) { this.buf = buf; this.off = offset; }
+  byte() { return this.buf[this.off++]; }
+  varintBig() { let shift = 0n, out = 0n; while (true) { const b = BigInt(this.byte()); out |= (b & 0x7fn) << shift; if ((b & 0x80n) === 0n) return out; shift += 7n; } }
+  varint() { return Number(this.varintBig()); }
+  zigzagBig() { const n = this.varintBig(); return (n >> 1n) ^ (-(n & 1n)); }
+  zigzag() { return Number(this.zigzagBig()); }
+  double() { const v = this.buf.readDoubleLE(this.off); this.off += 8; return v; }
+  float() { const v = this.buf.readFloatLE(this.off); this.off += 4; return v; }
+  binary() { const n = this.varint(); const out = this.buf.slice(this.off, this.off + n); this.off += n; return out; }
+  listHeader() { const b = this.byte(); let size = b >> 4; const elemType = b & 0x0f; if (size === 15) size = this.varint(); return { size, elemType }; }
+  readValue(type) {
+    if (type === CT.TRUE) return true;
+    if (type === CT.FALSE) return false;
+    if (type === CT.BYTE) { const b = this.byte(); return b > 127 ? b - 256 : b; }
+    if (type === CT.I16 || type === CT.I32) return this.zigzag();
+    if (type === CT.I64) return Number(this.zigzagBig());
+    if (type === CT.DOUBLE) return this.double();
+    if (type === CT.FLOAT) return this.float();
+    if (type === CT.BINARY) return this.binary().toString("utf8");
+    if (type === CT.STRUCT) return this.struct();
+    if (type === CT.LIST || type === CT.SET) { const { size, elemType } = this.listHeader(); const a = []; for (let i = 0; i < size; i++) a.push(this.readValue(elemType)); return a; }
+    if (type === CT.MAP) { const size = this.varint(); if (size === 0) return []; const kv = this.byte(); const kt = kv >> 4, vt = kv & 0x0f; const a = []; for (let i = 0; i < size; i++) a.push([this.readValue(kt), this.readValue(vt)]); return a; }
+    throw new Error(`unsupported compact type ${type}`);
+  }
+  struct() { const obj = {}; let last = 0; while (true) { const hb = this.byte(); const type = hb & 0x0f; if (type === CT.STOP) break; const delta = hb >> 4; const fid = delta === 0 ? this.zigzag() : last + delta; last = fid; obj[fid] = this.readValue(type); } return obj; }
+}
+
+function snappy(buf) {
+  let ip = 0, len = 0, shift = 0;
+  while (true) { const c = buf[ip++]; len |= (c & 0x7f) << shift; if ((c & 0x80) === 0) break; shift += 7; }
+  const out = Buffer.allocUnsafe(len); let op = 0;
+  while (ip < buf.length) {
+    const tag = buf[ip++], typ = tag & 3;
+    if (typ === 0) {
+      let n = tag >> 2;
+      if (n < 60) n += 1; else { const bytes = n - 59; n = 0; for (let i = 0; i < bytes; i++) n |= buf[ip++] << (8 * i); n += 1; }
+      buf.copy(out, op, ip, ip + n); ip += n; op += n;
+    } else {
+      let n, off;
+      if (typ === 1) { n = ((tag >> 2) & 0x7) + 4; off = ((tag & 0xe0) << 3) | buf[ip++]; }
+      else if (typ === 2) { n = (tag >> 2) + 1; off = buf.readUInt16LE(ip); ip += 2; }
+      else { n = (tag >> 2) + 1; off = buf.readUInt32LE(ip); ip += 4; }
+      for (let i = 0; i < n; i++) out[op + i] = out[op - off + i];
+      op += n;
+    }
+  }
+  return out;
+}
+
+function readVarintFrom(buf, state) { let shift = 0, out = 0; while (true) { const c = buf[state.off++]; out |= (c & 0x7f) << shift; if ((c & 0x80) === 0) return out; shift += 7; } }
+function decodeHybrid(buf, bitWidth, count, start = 0) {
+  const st = { off: start }, values = [], mask = bitWidth === 32 ? 0xffffffff : (1 << bitWidth) - 1, byteWidth = Math.ceil(bitWidth / 8);
+  while (values.length < count) {
+    const header = readVarintFrom(buf, st);
+    if ((header & 1) === 0) {
+      const run = header >> 1; let val = 0;
+      for (let i = 0; i < byteWidth; i++) val |= buf[st.off++] << (8 * i);
+      for (let i = 0; i < run && values.length < count; i++) values.push(val);
+    } else {
+      const run = (header >> 1) * 8; let acc = 0, bits = 0;
+      for (let i = 0; i < run; i++) {
