+        { hypothesis_ids: ["h9"], code: "Top-quartile subgroup contrast for growth_rate_doublings_per_day on dependency_TMED10.", result_summary: "`dependency_TMED10` was -0.2816 in high-growth lines (n=12577) versus -0.2447 in other lines; effect -0.0369.", p_value: P, effect_estimate: -0.0369, significant: true },
