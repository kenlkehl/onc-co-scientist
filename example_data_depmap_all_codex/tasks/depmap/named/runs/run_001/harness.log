+    const n = this.varint();
+    const out = this.buf.slice(this.off, this.off + n);
+    this.off += n;
+    return out;
+  }
+  listHeader() {
+    const b = this.byte();
+    let size = b >> 4;
+    const elemType = b & 0x0f;
+    if (size === 15) size = this.varint();
+    return { size, elemType };
+  }
+  readValue(type) {
+    if (type === CT.TRUE) return true;
+    if (type === CT.FALSE) return false;
+    if (type === CT.BYTE) {
+      const b = this.byte();
+      return b > 127 ? b - 256 : b;
+    }
+    if (type === CT.I16 || type === CT.I32) return this.zigzag();
+    if (type === CT.I64) return Number(this.zigzagBig());
+    if (type === CT.DOUBLE) return this.double();
+    if (type === CT.FLOAT) return this.float();
+    if (type === CT.BINARY) return this.binary().toString("utf8");
+    if (type === CT.STRUCT) return this.struct();
+    if (type === CT.LIST || type === CT.SET) {
+      const { size, elemType } = this.listHeader();
+      const a = [];
+      for (let i = 0; i < size; i++) a.push(this.readValue(elemType));
+      return a;
+    }
+    if (type === CT.MAP) {
+      const size = this.varint();
+      if (size === 0) return [];
+      const kv = this.byte();
+      const kt = kv >> 4;
+      const vt = kv & 0x0f;
+      const a = [];
+      for (let i = 0; i < size; i++) a.push([this.readValue(kt), this.readValue(vt)]);
+      return a;
+    }
+    throw new Error(`unsupported compact type ${type} at ${this.off}`);
+  }
+  struct() {
+    const obj = {};
+    let last = 0;
+    while (true) {
+      const hb = this.byte();
+      const type = hb & 0x0f;
+      if (type === CT.STOP) break;
+      const delta = hb >> 4;
+      const fid = delta === 0 ? this.zigzag() : last + delta;
+      last = fid;
+      obj[fid] = this.readValue(type);
+    }
+    return obj;
+  }
+}
+
+const b = fs.readFileSync("dataset.parquet");
+const metadataLen = b.readUInt32LE(b.length - 8);
+const metadataStart = b.length - 8 - metadataLen;
+const meta = new Compact(b, metadataStart, b.length - 8).struct();
+
+const typeNames = ["BOOLEAN", "INT32", "INT64", "INT96", "FLOAT", "DOUBLE", "BYTE_ARRAY", "FIXED_LEN_BYTE_ARRAY"];
+const codecNames = ["UNCOMPRESSED", "SNAPPY", "GZIP", "LZO", "BROTLI", "LZ4", "ZSTD", "LZ4_RAW"];
+const encodingNames = ["PLAIN", "PLAIN_DICTIONARY", "PLAIN_DICTIONARY_OLD", "RLE", "BIT_PACKED", "DELTA_BINARY_PACKED", "DELTA_LENGTH_BYTE_ARRAY", "DELTA_BYTE_ARRAY", "RLE_DICTIONARY", "BYTE_STREAM_SPLIT"];
+
+function snappy(buf) {
+  let ip = 0;
+  let len = 0;
+  let shift = 0;
+  while (true) {
+    const c = buf[ip++];
+    len |= (c & 0x7f) << shift;
+    if ((c & 0x80) === 0) break;
+    shift += 7;
+  }
+  const out = Buffer.allocUnsafe(len);
+  let op = 0;
+  while (ip < buf.length) {
+    const tag = buf[ip++];
+    const typ = tag & 3;
+    if (typ === 0) {
+      let n = tag >> 2;
+      if (n < 60) {
+        n += 1;
+      } else {
+        const bytes = n - 59;
+        n = 0;
+        for (let i = 0; i < bytes; i++) n |= buf[ip++] << (8 * i);
+        n += 1;
+      }
+      buf.copy(out, op, ip, ip + n);
+      ip += n;
+      op += n;
+    } else {
+      let n, off;
+      if (typ === 1) {
+        n = ((tag >> 2) & 0x7) + 4;
+        off = ((tag & 0xe0) << 3) | buf[ip++];
+      } else if (typ === 2) {
+        n = (tag >> 2) + 1;
+        off = buf.readUInt16LE(ip);
+        ip += 2;
+      } else {
+        n = (tag >> 2) + 1;
+        off = buf.readUInt32LE(ip);
+        ip += 4;
+      }
+      for (let i = 0; i < n; i++) out[op + i] = out[op - off + i];
+      op += n;
+    }
+  }
+  if (op !== len) throw new Error(`snappy length mismatch ${op} != ${len}`);
+  return out;
+}
+
+function pageAt(offset) {
+  const p = new Compact(b, offset);
+  const header = p.struct();
+  const body = b.slice(p.off, p.off + header[3]);
+  return { header, headerBytes: p.off - offset, compressed: body, data: snappy(body), next: p.off + header[3] };
+}
+
+function decodePlainDict(data, type, n) {
+  const out = [];
+  let off = 0;
+  for (let i = 0; i < n; i++) {
+    if (type === "BYTE_ARRAY") {
+      const len = data.readUInt32LE(off);
+      off += 4;
+      out.push(data.slice(off, off + len).toString("utf8"));
+      off += len;
+    } else if (type === "DOUBLE") {
+      out.push(data.readDoubleLE(off));
+      off += 8;
+    } else if (type === "INT64") {
+      out.push(Number(data.readBigInt64LE(off)));
+      off += 8;
+    } else {
+      throw new Error(`unsupported dict type ${type}`);
+    }
+  }
+  return out;
+}
+
+function readVarintFrom(buf, state) {
+  let shift = 0;
+  let out = 0;
+  while (true) {
+    const c = buf[state.off++];
+    out |= (c & 0x7f) << shift;
+    if ((c & 0x80) === 0) return out;
+    shift += 7;
+  }
+}
+
+function decodeHybrid(buf, bitWidth, count, start = 0) {
+  const st = { off: start };
+  const values = [];
+  const mask = bitWidth === 32 ? 0xffffffff : (1 << bitWidth) - 1;
+  const byteWidth = Math.ceil(bitWidth / 8);
+  while (values.length < count) {
+    const header = readVarintFrom(buf, st);
+    if ((header & 1) === 0) {
+      const run = header >> 1;
+      let val = 0;
+      for (let i = 0; i < byteWidth; i++) val |= buf[st.off++] << (8 * i);
+      for (let i = 0; i < run && values.length < count; i++) values.push(val);
+    } else {
+      const groups = header >> 1;
+      const run = groups * 8;
+      let acc = 0;
+      let bits = 0;
+      for (let i = 0; i < run; i++) {
+        while (bits < bitWidth) {
+          acc |= buf[st.off++] << bits;
+          bits += 8;
+        }
+        if (values.length < count) values.push(acc & mask);
+        acc >>= bitWidth;
+        bits -= bitWidth;
+      }
+    }
+  }
+  return { values, offset: st.off };
+}
+
+function readColumn(colIndex) {
+  const md = rg[1][colIndex][3];
+  const name = md[3][0];
+  const type = typeNames[md[1]];
+  const dictPage = pageAt(md[11]);
+  const dict = decodePlainDict(dictPage.data, type, dictPage.header[7][1]);
+  let offset = dictPage.next;
+  const out = [];
+  while (out.length < md[5]) {
+    const pg = pageAt(offset);
+    if (pg.header[1] !== 0) throw new Error(`unexpected page type ${pg.header[1]} for ${name}`);
+    const dh = pg.header[5];
+    const n = dh[1];
+    const defLen = pg.data.readUInt32LE(0);
+    const afterDef = 4 + defLen;
+    const bitWidth = pg.data[afterDef];
+    const decoded = decodeHybrid(pg.data, bitWidth, n, afterDef + 1).values;
+    for (const id of decoded) out.push(dict[id]);
+    offset = pg.next;
+  }
+  return out;
+}
+
+console.log("version", meta[1], "numRows", meta[3], "rowGroups", meta[4].length);
+const schema = meta[2];
+console.log("schema");
+for (let i = 0; i < schema.length; i++) {
+  console.log(i, JSON.stringify({ name: schema[i][4], type: typeNames[schema[i][1]], repetition: schema[i][3], children: schema[i][5], converted: schema[i][6] }));
+}
+const rg = meta[4][0];
+console.log("rowgroup rows", rg[3], "cols", rg[1].length);
+for (let i = 0; i < rg[1].length; i++) {
+  const cc = rg[1][i];
+  const md = cc[3];
+  console.log(i, JSON.stringify({
+    path: md[3],
+    type: typeNames[md[1]],
+    codec: codecNames[md[4]],
+    enc: md[2].map(x => encodingNames[x] || x),
+    num_values: md[5],
+    comp: md[7],
+    uncomp: md[6],
+    data: md[9],
+    dict: md[11] || null,
+  }));
+}
+
+for (const i of [1, 6, 11, 37, 42]) {
+  const md = rg[1][i][3];
+  const dp = pageAt(md[9]);
+  const dict = pageAt(md[11]);
+  console.log("probePage", i, md[3][0], "dictHeader", dict.header, "dictDataLen", dict.data.length, "dataHeader", dp.header, "dataLen", dp.data.length, "firstData", Array.from(dp.data.slice(0, 24)));
+}
+
+for (const i of [1, 2, 11, 26, 37, 42]) {
+  const vals = readColumn(i);
+  const name = rg[1][i][3][3][0];
+  const head = vals.slice(0, 8);
+  const uniq = new Set(vals).size;
+  console.log("decoded", i, name, "n", vals.length, "unique", uniq, "head", JSON.stringify(head));
+}
