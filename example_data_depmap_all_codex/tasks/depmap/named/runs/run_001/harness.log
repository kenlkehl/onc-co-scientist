+        { hypothesis_ids: ["h34"], code: "Final selected subgroup contrasts for dependency_RIT1.", result_summary: "Final RIT1 broad subgroup `nf1_loss=1`: effect -0.0955; refined `nf1_loss=1`/brain subgroup effect -0.1397.", p_value: P, effect_estimate: -0.0955, significant: true },
+        { hypothesis_ids: ["h35"], code: "Final selected three-predicate subgroup contrast for dependency_KIF18A.", result_summary: "Final KIF18A subgroup `lineage=colorectal`, `apc_mutation=1`, `wnt_activity_score>=0.819`: effect -0.8589, means -1.1119 versus -0.2530.", p_value: P, effect_estimate: -0.8589, significant: true },
