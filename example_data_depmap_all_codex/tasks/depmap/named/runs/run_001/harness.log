+        { hypothesis_ids: ["h39"], code: "Final selected two-predicate subgroup contrast for dependency_RPL11.", result_summary: "Final RPL11 subgroup `myc_amplification=1` plus high growth: effect -0.1303, means -0.3936 versus -0.2632.", p_value: P, effect_estimate: -0.1303, significant: true }
+      ]
+    }
+  ],
+  final_dependency_subgroups: {
+    dependency_BRAF: "`braf_v600e=1` (effect -0.5552)",
+    dependency_EGFR: "`egfr_amplification=1` (effect -0.3486)",
+    dependency_ERBB2: "`erbb2_amplification=1` (effect -0.4321)",
+    dependency_KRAS: "`kras_mutation=1` (effect -0.3075)",
+    dependency_RIT1: "`nf1_loss=1`, strongest in `nf1_loss=1` and `lineage=brain` (broad effect -0.0955; refined effect -0.1397)",
+    dependency_KIF18A: "`lineage=colorectal`, `apc_mutation=1`, and `wnt_activity_score>=0.819` (effect -0.8589)",
+    dependency_TMED10: "`growth_rate_doublings_per_day>=0.964` (effect -0.0369)",
