/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat_cols=['lineage','lineage_subtype','culture_type','screen_batch']
bin_cols=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont_cols=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']

print('Unadjusted binary mean differences (mean in positive - negative; negative means stronger dependency):')
for out in outcomes:
    rows=[]
    for col in bin_cols:
        a=df.loc[df[col]==1,out].values; b=df.loc[df[col]==0,out].values
        diff=a.mean()-b.mean()
        t,p=stats.ttest_ind(a,b,equal_var=False)
        rows.append((diff,p,col,a.mean(),b.mean(),len(a)))
    rows=sorted(rows,key=lambda x:x[0])[:8]
    print('\\n',out)
    for diff,p,col,ma,mb,n in rows:
        print(f'{col:20s} diff={diff:+.4f} p={p:.2e} mean1={ma:+.3f} mean0={mb:+.3f} n={n}')

print('\\nCategorical level contrasts vs all others (most negative per outcome):')
for out in outcomes:
    rows=[]
    for col in cat_cols:
        for lvl,sub in df.groupby(col):
            mask=df[col].eq(lvl)
            if mask.sum()<200: continue
            a=df.loc[mask,out].values; b=df.loc[~mask,out].values
            diff=a.mean()-b.mean(); t,p=stats.ttest_ind(a,b,equal_var=False)
            rows.append((diff,p,f'{col}={lvl}',a.mean(),b.mean(),mask.sum()))
    rows=sorted(rows,key=lambda x:x[0])[:8]
    print('\\n',out)
    for diff,p,pred,ma,mb,n in rows:
        print(f'{pred:35s} diff={diff:+.4f} p={p:.2e} mean1={ma:+.3f} mean0={mb:+.3f} n={n}')

print('\\nContinuous correlations (negative strongest):')
for out in outcomes:
    rows=[]
    y=df[out].values
    for col in cont_cols:
        r,p=stats.pearsonr(df[col].values,y)
        slope=np.cov(df[col].values,y,bias=True)[0,1]/np.var(df[col].values)
        rows.append((r,p,slope,col))
    rows=sorted(rows,key=lambda x:x[0])[:8]
    print('\\n',out)
    for r,p,slope,col in rows:
        print(f'{col:30s} r={r:+.3f} slope={slope:+.4f} p={p:.2e}')
