The full interaction screen finished. The strongest nontrivial interaction by far is `dependency_KIF18A` with `lineage=colorectal` plus `apc_mutation` or high `wnt_activity_score`; several other dependencies are mostly single-driver or proliferation-associated rather than clean lineage-gated effects.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
q={c:{'q25':df[c].quantile(.25),'q75':df[c].quantile(.75)} for c in ['growth_rate_doublings_per_day','wnt_activity_score','rnaseq_MYC_log2_tpm','copy_number_8q24','rnaseq_ASCL2_log2_tpm','cas9_activity_score']}
print('quantiles',q)

def welch(out, mask, base=None):
    y=df[out]
    if base is None:
        base=np.ones(len(df), dtype=bool)
    mask=np.asarray(mask) & base
    comp=np.asarray(~np.asarray(mask)) & base
    a=y[mask].values; b=y[comp].values
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return dict(out=out,n1=len(a),n0=len(b),mean1=a.mean(),mean0=b.mean(),effect=a.mean()-b.mean(),p=p)

def print_res(label,res):
    print(f'{label}: n1={res[\"n1\"]} n0={res[\"n0\"]} mean1={res[\"mean1\"]:.6f} mean0={res[\"mean0\"]:.6f} effect={res[\"effect\"]:.6f} p={res[\"p\"]:.3e}')

# main effects
print('\\nMAIN')
for label,out,mask in [
 ('BRAF_V600E -> BRAF','dependency_BRAF',df.braf_v600e==1),
 ('EGFR_amp -> EGFR','dependency_EGFR',df.egfr_amplification==1),
 ('ERBB2_amp -> ERBB2','dependency_ERBB2',df.erbb2_amplification==1),
 ('KRAS_mut -> KRAS','dependency_KRAS',df.kras_mutation==1),
 ('NF1_loss -> RIT1','dependency_RIT1',df.nf1_loss==1),
 ('Colorectal -> KIF18A','dependency_KIF18A',df.lineage.eq('colorectal')),
 ('APC_mut -> KIF18A','dependency_KIF18A',df.apc_mutation==1),
 ('High_WNT -> KIF18A','dependency_KIF18A',df.wnt_activity_score>=q['wnt_activity_score']['q75']),
 ('MYC_amp -> RPL11','dependency_RPL11',df.myc_amplification==1),
 ('High_8q24 -> RPL11','dependency_RPL11',df.copy_number_8q24>=q['copy_number_8q24']['q75']),
 ('High_MYC_RNA -> DHX9','dependency_DHX9',df.rnaseq_MYC_log2_tpm>=q['rnaseq_MYC_log2_tpm']['q75']),
 ('High_growth -> POLR2A','dependency_POLR2A',df.growth_rate_doublings_per_day>=q['growth_rate_doublings_per_day']['q75']),
 ('High_growth -> TMED10','dependency_TMED10',df.growth_rate_doublings_per_day>=q['growth_rate_doublings_per_day']['q75']),
 ('NF1_loss -> TMED10','dependency_TMED10',df.nf1_loss==1),
]: print_res(label, welch(out,mask))

# lineage within driver positive
print('\\nWITHIN DRIVER')
for label,out,base,mask in [
 ('BRAF_V600E skin vs non-skin','dependency_BRAF',df.braf_v600e==1,df.lineage.eq('skin')),
 ('ERBB2_amp HER2_enriched vs other','dependency_ERBB2',df.erbb2_amplification==1,df.lineage_subtype.eq('her2_enriched')),
 ('KRAS_mut pancreatic vs other','dependency_KRAS',df.kras_mutation==1,df.lineage.eq('pancreatic')),
 ('EGFR_amp brain vs other','dependency_EGFR',df.egfr_amplification==1,df.lineage.eq('brain')),
 ('NF1_loss brain vs other','dependency_RIT1',df.nf1_loss==1,df.lineage.eq('brain')),
]: print_res(label, welch(out,mask,base=base.values))

# interaction saturated binary
def interaction(out,A,B):
