/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
cat_cols=['lineage','lineage_subtype','culture_type','screen_batch']
bin_cols=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont_cols=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']

preds=[]
# categorical levels
for col in cat_cols:
    for lvl in sorted(df[col].unique()):
        m=(df[col].values==lvl)
        preds.append((f'{col}={lvl}', m))
# binary true predicates
for col in bin_cols:
    preds.append((f'{col}=1', df[col].values.astype(bool)))
# continuous quartiles hi/lo
for col in cont_cols:
    x=df[col]
    q25=x.quantile(.25); q75=x.quantile(.75)
    preds.append((f'{col}>=Q75({q75:.3g})', (x.values>=q75)))
    preds.append((f'{col}<=Q25({q25:.3g})', (x.values<=q25)))

n=len(df)
print('num predicates',len(preds))

def welch(y,mask):
    a=y[mask]; b=y[~mask]
    if len(a)<50 or len(b)<50: return None
    diff=a.mean()-b.mean()
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return diff,p,a.mean(),b.mean(),len(a)

print('\\nSingle-predicate strongest negative subgroup scan:')
for out in outcomes:
    y=df[out].values
    rows=[]
    for name,m in preds:
        r=welch(y,m)
        if r: rows.append((r[0],r[1],name,r[2],r[3],r[4]))
    for diff,p,name,ma,mb,nn in sorted(rows,key=lambda x:x[0])[:10]:
        print(f'{out:18s} {name:45s} diff={diff:+.4f} p={p:.1e} mean={ma:+.3f} rest={mb:+.3f} n={nn}')
    print('---')

print('\\nPair-predicate strongest negative subgroup scan:')
for out in outcomes:
    y=df[out].values
    rows=[]
    for i,(n1,m1) in enumerate(preds):
        for n2,m2 in preds[i+1:]:
            m=m1 & m2
            nn=int(m.sum())
            if nn<200 or nn>n-200: continue
            r=welch(y,m)
            if r: rows.append((r[0],r[1],f'{n1} AND {n2}',r[2],r[3],r[4]))
    rows=sorted(rows,key=lambda x:x[0])[:10]
    for diff,p,name,ma,mb,nn in rows:
        print(f'{out:18s} {name:95s} diff={diff:+.4f} p={p:.1e} mean={ma:+.3f} rest={mb:+.3f} n={nn}')
    print('---')

# interaction synergy screening for pairs of predicates (binary OLS interaction)
print('\\nPair interaction screening by most negative interaction coefficient:')
for out in outcomes:
    y=df[out].values
    rows=[]
    for i,(n1,m1) in enumerate(preds):
        A=m1.astype(int)
        for n2,m2 in preds[i+1:]:
            B=m2.astype(int)
            cells=[((A==a)&(B==b)).sum() for a in (0,1) for b in (0,1)]
            if min(cells)<100: continue
            m00=y[(A==0)&(B==0)]; m01=y[(A==0)&(B==1)]; m10=y[(A==1)&(B==0)]; m11=y[(A==1)&(B==1)]
            means=[m00.mean(),m01.mean(),m10.mean(),m11.mean()]
            inter=means[3]-means[2]-means[1]+means[0]
            # OLS SE for interaction in saturated binary model: mse * sum(1/ncell)
            resid=np.concatenate([m00-means[0],m01-means[1],m10-means[2],m11-means[3]])
            dfree=n-4
            mse=(resid@resid)/dfree
            se=(mse*sum(1/c for c in cells))**0.5
            t=inter/se
            p=2*stats.t.sf(abs(t),dfree)
            rows.append((inter,p,f'{n1} x {n2}',means,cells))
    rows=sorted(rows,key=lambda x:x[0])[:10]
    for inter,p,name,means,cells in rows:
        print(f'{out:18s} {name:95s} inter={inter:+.4f} p={p:.1e} means00/01/10/11={[round(v,3) for v in means]} cells={cells}')
    print('---')
