/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
batch=pd.get_dummies(df.screen_batch, drop_first=True, dtype=float)
culture=pd.get_dummies(df.culture_type, drop_first=True, dtype=float)

def ols(out, terms):
    y=df[out].values.astype(float)
    cols=[np.ones(len(df))]; names=['intercept']
    for name,arr in terms:
        cols.append(np.asarray(arr,dtype=float)); names.append(name)
    X=np.column_stack(cols)
    beta,*_=np.linalg.lstsq(X,y,rcond=None)
    resid=y-X@beta; n,p=X.shape; sigma2=(resid@resid)/(n-p)
    se=np.sqrt(np.diag(np.linalg.inv(X.T@X))*sigma2); pv=2*stats.t.sf(np.abs(beta/se),n-p)
    return {names[i]:(beta[i],se[i],pv[i]) for i in range(len(names))}
base=[]
for c in ['growth_rate_doublings_per_day','cas9_activity_score','media_serum_pct']:
    base.append((c+'_z',(df[c]-df[c].mean())/df[c].std()))
for col in batch.columns: base.append(('screen_batch_'+str(col),batch[col]))
for col in culture.columns: base.append(('culture_type_'+str(col),culture[col]))
for out in ['dependency_POLR2A','dependency_TMED10','dependency_DHX9','dependency_RPL11']:
    res=ols(out,base)
    print(out)
    for term in ['growth_rate_doublings_per_day_z','cas9_activity_score_z','media_serum_pct_z']:
        b,se,p=res[term]; print(f' {term}: beta={b:.6f} se={se:.6f} p={p:.3e}')
