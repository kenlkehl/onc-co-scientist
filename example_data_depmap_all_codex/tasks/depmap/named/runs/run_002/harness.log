   h=s.b(); n=h>>4; et=h&15
   if n==15: n=s.vi()
   return [s.val(et) for _ in range(n)]
  if t==11:
   n=s.vi();
   if n==0: return {}
   h=s.b(); kt=h>>4; vt=h&15
   return {s.val(kt):s.val(vt) for _ in range(n)}
  if t==12: return s.struct()
  raise Exception(t)
 def struct(s):
