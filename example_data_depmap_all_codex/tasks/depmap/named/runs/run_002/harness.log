class TReader:
    def __init__(self,d,off=0): self.d=d; self.i=off
    def b(self): x=self.d[self.i]; self.i+=1; return x
    def vi(self):
        sh=0; r=0
        while True:
            x=self.b(); r|=(x&127)<<sh
            if not (x&128): return r
            sh+=7
    def zz(self,n): return (n>>1)"'^-(n&1)
    def iv(self): return self.zz(self.vi())
    def bin(self):
        n=self.vi(); b=self.d[self.i:self.i+n]; self.i+=n
        try: return b.decode('"'utf-8')
        except: return b
    def val(self,t):
        if t==1: return True
        if t==2: return False
        if t in (3,4,5,6): return self.iv()
