# Minimal local Parquet reader for this task bundle: compact Thrift footer, Snappy pages,
# dictionary-encoded required/defined scalar columns.
CT_STOP=0; CT_BOOLEAN_TRUE=1; CT_BOOLEAN_FALSE=2; CT_BYTE=3; CT_I16=4; CT_I32=5; CT_I64=6; CT_DOUBLE=7; CT_BINARY=8; CT_LIST=9; CT_SET=10; CT_MAP=11; CT_STRUCT=12; CT_FLOAT=13
class TReader:
    def __init__(self,d,off=0): self.d=d; self.i=off
    def b(self): x=self.d[self.i]; self.i+=1; return x
    def vi(self):
        sh=0; r=0
        while True:
            x=self.b(); r|=(x&127)<<sh
            if not (x&128): return r
            sh += 7
    def zz(self,n): return (n>>1)"'^-(n&1)
    def iv(self): return self.zz(self.vi())
    def bin(self):
        n=self.vi(); b=self.d[self.i:self.i+n]; self.i+=n
        try: return b.decode('"'utf-8')
        except UnicodeDecodeError: return b
    def val(self,t):
        if t==CT_BOOLEAN_TRUE: return True
        if t==CT_BOOLEAN_FALSE: return False
        if t in (CT_BYTE,CT_I16,CT_I32,CT_I64): return self.iv()
        if t==CT_DOUBLE:
            v=struct.unpack('<d', self.d[self.i:self.i+8])[0]; self.i+=8; return v
        if t==CT_FLOAT:
            v=struct.unpack('<f', self.d[self.i:self.i+4])[0]; self.i+=4; return v
        if t==CT_BINARY: return self.bin()
        if t in (CT_LIST,CT_SET):
            h=self.b(); n=h>>4; et=h&15
            if n==15: n=self.vi()
            return [self.val(et) for _ in range(n)]
        if t==CT_MAP:
            n=self.vi()
            if n==0: return {}
            h=self.b(); kt=h>>4; vt=h&15
            return {self.val(kt): self.val(vt) for _ in range(n)}
        if t==CT_STRUCT: return self.struct()
        raise ValueError((t,self.i))
    def struct(self):
        out={}; last=0
        while True:
            h=self.b(); t=h&15; delta=h>>4
            if t==CT_STOP: return out
            fid=last+delta if delta else self.iv(); last=fid
            out[fid]=self.val(t)

def snappy_decompress(data):
    i=0; out_len=0; shift=0
    while True:
        b=data[i]; i+=1; out_len |= (b&0x7f)<<shift
        if not (b&0x80): break
        shift += 7
    out=bytearray()
    while i < len(data):
        tag=data[i]; i+=1; typ=tag&3
        if typ==0:
            l=tag>>2
            if l<60: length=l+1
            else:
                n=l-59; length=int.from_bytes(data[i:i+n],'little')+1; i+=n
            out.extend(data[i:i+length]); i+=length
        elif typ==1:
            length=((tag>>2)&7)+4; offset=((tag&0xe0)<<3)|data[i]; i+=1
            for _ in range(length): out.append(out[-offset])
        elif typ==2:
            length=(tag>>2)+1; offset=int.from_bytes(data[i:i+2],'little'); i+=2
            for _ in range(length): out.append(out[-offset])
        else:
            length=(tag>>2)+1; offset=int.from_bytes(data[i:i+4],'little'); i+=4
            for _ in range(length): out.append(out[-offset])
    if len(out) "'!= out_len:
        raise ValueError(f'"'snappy length mismatch {len(out)} "'!= {out_len}'"')
    return bytes(out)

def read_plain(buf, phys, n):
    if phys == 6:
        vals=[]; i=0
        for _ in range(n):
            ln=int.from_bytes(buf[i:i+4],'little'); i+=4
            vals.append(buf[i:i+ln].decode('utf-8')); i+=ln
        return vals
    if phys == 5:
        return list(struct.unpack('<' + 'd'*n, buf[:8*n]))
    if phys == 2:
        return list(struct.unpack('<' + 'q'*n, buf[:8*n]))
    raise NotImplementedError(phys)

def decode_rle_bp(buf, bit_width, nvals):
    vals=[]; i=0; width_bytes=(bit_width+7)//8; mask=(1<<bit_width)-1 if bit_width else 0
    while len(vals) < nvals and i < len(buf):
        header=0; shift=0
        while True:
            b=buf[i]; i+=1; header |= (b&127)<<shift
            if not (b&128): break
            shift += 7
        if header & 1:
            groups=header>>1
            for _ in range(groups):
                chunk=buf[i:i+bit_width]; i += bit_width
                acc=int.from_bytes(chunk,'little') if bit_width else 0
                for j in range(8):
                    if len(vals) < nvals:
                        vals.append((acc>>(j*bit_width)) & mask if bit_width else 0)
        else:
            run=header>>1
            val=int.from_bytes(buf[i:i+width_bytes],'little') if width_bytes else 0; i += width_bytes
            vals.extend([val] * min(run, nvals-len(vals)))
    return vals

def read_col(file_bytes, md, phys):
    rr=TReader(file_bytes, md[11]); header=rr.struct(); body=file_bytes[rr.i:rr.i+header[3]]
    decoded=snappy_decompress(body) if md[4] == 1 else body
    dictionary=read_plain(decoded, phys, header[7][1])
    vals=[]; off=md[9]; total=md[5]
    while len(vals) < total:
        rr=TReader(file_bytes, off); header=rr.struct(); start=rr.i
        body=file_bytes[start:start+header[3]]
        decoded=snappy_decompress(body) if md[4] == 1 else body
        page_n=header[5][1]
        j=0
        def_len=int.from_bytes(decoded[j:j+4], 'little'); j += 4 + def_len
        bit_width=decoded[j]; j += 1
        ids=decode_rle_bp(decoded[j:], bit_width, page_n)
        vals.extend(dictionary[k] for k in ids[:page_n])
        off=start+header[3]
    return vals[:total]

def load_table(path):
    b=Path(path).read_bytes()
    footer_len=int.from_bytes(b[-8:-4], 'little')
    meta=TReader(b, len(b)-8-footer_len).struct()
    schema=meta[2]; row_group=meta[4][0]
    cols={}
    for idx,se in enumerate(schema[1:]):
        cols[se[4]] = read_col(b, row_group[1][idx][3], se[1])
    return cols

# Statistical helpers use large-sample normal approximations for p-values.
def p_from_z(z): return math.erfc(abs(z)/math.sqrt(2.0))
def mean(v): return sum(v)/len(v)
def quantile(v, q):
    xs=sorted(v); pos=(len(xs)-1)*q; lo=int(math.floor(pos)); hi=int(math.ceil(pos))
    return xs[lo] if lo == hi else xs[lo]*(hi-pos)+xs[hi]*(pos-lo)
def welch_from_sums(s1, ss1, n1, s0, ss0, n0):
    m1=s1/n1; m0=s0/n0
    v1=(ss1-s1*s1/n1)/(n1-1); v0=(ss0-s0*s0/n0)/(n0-1)
    se=math.sqrt(max(v1/n1 + v0/n0, 1e-300))
    z=(m1-m0)/se
    return {'mean_in':m1, 'mean_out':m0, 'effect':m1-m0, 'z':z, 'p':p_from_z(z), 'n_in':n1, 'n_out':n0}
def contrast(y, mask, subset=None):
    s1=ss1=n1=s0=ss0=n0=0
    if subset is None:
        iterable=zip(y, mask)
    else:
        iterable=((yi,mi) for yi,mi,si in zip(y,mask,subset) if si)
    for yi,mi in iterable:
        if mi:
            n1+=1; s1+=yi; ss1+=yi*yi
        else:
            n0+=1; s0+=yi; ss0+=yi*yi
    return welch_from_sums(s1, ss1, n1, s0, ss0, n0)
def slope_test(x,y):
    n=len(x); mx=mean(x); my=mean(y)
    sxx=sum((a-mx)*(a-mx) for a in x); sxy=sum((a-mx)*(b-my) for a,b in zip(x,y))
    beta=sxy/sxx; alpha=my-beta*mx
