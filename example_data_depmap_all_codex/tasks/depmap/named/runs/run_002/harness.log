+from pathlib import Path
+import json
+import math
+import struct
+
+
+CT_STOP = 0
+CT_BOOLEAN_TRUE = 1
+CT_BOOLEAN_FALSE = 2
+CT_BYTE = 3
+CT_I16 = 4
+CT_I32 = 5
+CT_I64 = 6
+CT_DOUBLE = 7
+CT_BINARY = 8
+CT_LIST = 9
+CT_SET = 10
+CT_MAP = 11
+CT_STRUCT = 12
+CT_FLOAT = 13
+
+
+class TReader:
+    def __init__(self, data, offset=0):
+        self.data = data
+        self.i = offset
+
+    def byte(self):
+        value = self.data[self.i]
+        self.i += 1
+        return value
+
+    def varint(self):
+        shift = 0
+        result = 0
+        while True:
+            value = self.byte()
+            result |= (value & 0x7F) << shift
+            if not (value & 0x80):
+                return result
+            shift += 7
+
+    @staticmethod
+    def zigzag(value):
+        return (value >> 1) ^ -(value & 1)
+
+    def int_value(self):
+        return self.zigzag(self.varint())
+
+    def binary(self):
+        length = self.varint()
+        value = self.data[self.i:self.i + length]
+        self.i += length
+        try:
+            return value.decode("utf-8")
+        except UnicodeDecodeError:
+            return value
+
+    def value(self, thrift_type):
+        if thrift_type == CT_BOOLEAN_TRUE:
+            return True
+        if thrift_type == CT_BOOLEAN_FALSE:
+            return False
+        if thrift_type in (CT_BYTE, CT_I16, CT_I32, CT_I64):
+            return self.int_value()
+        if thrift_type == CT_DOUBLE:
+            value = struct.unpack("<d", self.data[self.i:self.i + 8])[0]
+            self.i += 8
+            return value
+        if thrift_type == CT_FLOAT:
+            value = struct.unpack("<f", self.data[self.i:self.i + 4])[0]
+            self.i += 4
+            return value
+        if thrift_type == CT_BINARY:
+            return self.binary()
+        if thrift_type in (CT_LIST, CT_SET):
+            header = self.byte()
+            size = header >> 4
+            element_type = header & 15
+            if size == 15:
+                size = self.varint()
+            return [self.value(element_type) for _ in range(size)]
+        if thrift_type == CT_MAP:
+            size = self.varint()
+            if size == 0:
+                return {}
+            header = self.byte()
+            key_type = header >> 4
+            value_type = header & 15
+            return {self.value(key_type): self.value(value_type) for _ in range(size)}
+        if thrift_type == CT_STRUCT:
+            return self.struct()
+        raise ValueError((thrift_type, self.i))
+
+    def struct(self):
+        output = {}
+        last_field = 0
+        while True:
+            header = self.byte()
+            thrift_type = header & 15
+            delta = header >> 4
+            if thrift_type == CT_STOP:
+                return output
+            field_id = last_field + delta if delta else self.int_value()
+            last_field = field_id
+            output[field_id] = self.value(thrift_type)
+
+
+def snappy_decompress(data):
+    i = 0
+    shift = 0
+    out_len = 0
+    while True:
+        value = data[i]
+        i += 1
+        out_len |= (value & 0x7F) << shift
+        if not (value & 0x80):
+            break
+        shift += 7
+
+    output = bytearray()
+    while i < len(data):
+        tag = data[i]
+        i += 1
+        tag_type = tag & 3
+        if tag_type == 0:
+            literal = tag >> 2
+            if literal < 60:
+                length = literal + 1
+            else:
+                n_bytes = literal - 59
+                length = int.from_bytes(data[i:i + n_bytes], "little") + 1
+                i += n_bytes
+            output.extend(data[i:i + length])
+            i += length
+        elif tag_type == 1:
+            length = ((tag >> 2) & 7) + 4
+            offset = ((tag & 0xE0) << 3) | data[i]
+            i += 1
+            for _ in range(length):
+                output.append(output[-offset])
+        elif tag_type == 2:
+            length = (tag >> 2) + 1
+            offset = int.from_bytes(data[i:i + 2], "little")
+            i += 2
+            for _ in range(length):
+                output.append(output[-offset])
+        else:
+            length = (tag >> 2) + 1
+            offset = int.from_bytes(data[i:i + 4], "little")
+            i += 4
+            for _ in range(length):
+                output.append(output[-offset])
+
+    if len(output) != out_len:
+        raise ValueError(f"Snappy length mismatch {len(output)} != {out_len}")
+    return bytes(output)
+
+
+def read_plain(buffer, physical_type, n_values):
+    if physical_type == 6:
+        values = []
+        i = 0
+        for _ in range(n_values):
+            length = int.from_bytes(buffer[i:i + 4], "little")
+            i += 4
+            values.append(buffer[i:i + length].decode("utf-8"))
+            i += length
+        return values
+    if physical_type == 5:
+        return list(struct.unpack("<" + "d" * n_values, buffer[:8 * n_values]))
+    if physical_type == 2:
+        return list(struct.unpack("<" + "q" * n_values, buffer[:8 * n_values]))
+    raise NotImplementedError(physical_type)
+
+
+def decode_rle_bitpacked(buffer, bit_width, n_values):
+    values = []
+    i = 0
+    width_bytes = (bit_width + 7) // 8
+    mask = (1 << bit_width) - 1 if bit_width else 0
+    while len(values) < n_values and i < len(buffer):
+        header = 0
+        shift = 0
+        while True:
+            value = buffer[i]
+            i += 1
+            header |= (value & 127) << shift
+            if not (value & 128):
+                break
+            shift += 7
+        if header & 1:
+            groups = header >> 1
+            for _ in range(groups):
+                chunk = buffer[i:i + bit_width]
+                i += bit_width
+                packed = int.from_bytes(chunk, "little") if bit_width else 0
+                for j in range(8):
+                    if len(values) < n_values:
+                        values.append((packed >> (j * bit_width)) & mask if bit_width else 0)
+        else:
+            run = header >> 1
+            value = int.from_bytes(buffer[i:i + width_bytes], "little") if width_bytes else 0
+            i += width_bytes
+            values.extend([value] * min(run, n_values - len(values)))
+    return values
+
+
+def read_column(file_bytes, column_meta, physical_type):
+    reader = TReader(file_bytes, column_meta[11])
+    header = reader.struct()
+    body = file_bytes[reader.i:reader.i + header[3]]
+    decoded = snappy_decompress(body) if column_meta[4] == 1 else body
+    dictionary = read_plain(decoded, physical_type, header[7][1])
+    values = []
+    offset = column_meta[9]
+    total = column_meta[5]
+    while len(values) < total:
+        reader = TReader(file_bytes, offset)
+        header = reader.struct()
+        start = reader.i
+        body = file_bytes[start:start + header[3]]
+        decoded = snappy_decompress(body) if column_meta[4] == 1 else body
+        page_n = header[5][1]
+        j = 0
+        def_len = int.from_bytes(decoded[j:j + 4], "little")
+        j += 4 + def_len
+        bit_width = decoded[j]
+        j += 1
+        ids = decode_rle_bitpacked(decoded[j:], bit_width, page_n)
+        values.extend(dictionary[index] for index in ids[:page_n])
+        offset = start + header[3]
+    return values[:total]
+
+
+def load_table(path):
+    file_bytes = Path(path).read_bytes()
+    footer_len = int.from_bytes(file_bytes[-8:-4], "little")
+    metadata = TReader(file_bytes, len(file_bytes) - 8 - footer_len).struct()
+    schema = metadata[2]
+    row_group = metadata[4][0]
+    columns = {}
+    for index, schema_element in enumerate(schema[1:]):
+        columns[schema_element[4]] = read_column(
+            file_bytes,
+            row_group[1][index][3],
+            schema_element[1],
+        )
+    return columns
+
+
+def mean(values):
+    return sum(values) / len(values)
+
+
+def quantile(values, q):
+    ordered = sorted(values)
+    position = (len(ordered) - 1) * q
+    low = int(math.floor(position))
+    high = int(math.ceil(position))
+    if low == high:
+        return ordered[low]
+    return ordered[low] * (high - position) + ordered[high] * (position - low)
+
+
+def p_from_z(z_score):
+    return math.erfc(abs(z_score) / math.sqrt(2.0))
+
+
+def welch_from_sums(s1, ss1, n1, s0, ss0, n0):
+    m1 = s1 / n1
+    m0 = s0 / n0
+    v1 = (ss1 - s1 * s1 / n1) / (n1 - 1)
+    v0 = (ss0 - s0 * s0 / n0) / (n0 - 1)
+    se = math.sqrt(max(v1 / n1 + v0 / n0, 1e-300))
+    z_score = (m1 - m0) / se
+    return {
+        "mean_in": m1,
+        "mean_out": m0,
+        "effect": m1 - m0,
+        "z": z_score,
+        "p": p_from_z(z_score),
+        "n_in": n1,
+        "n_out": n0,
+    }
+
+
+def contrast(y, mask, subset=None):
+    s1 = ss1 = n1 = s0 = ss0 = n0 = 0
+    if subset is None:
+        iterator = zip(y, mask)
+    else:
+        iterator = ((yi, mi) for yi, mi, si in zip(y, mask, subset) if si)
+    for yi, mi in iterator:
+        if mi:
+            n1 += 1
+            s1 += yi
+            ss1 += yi * yi
+        else:
+            n0 += 1
+            s0 += yi
+            ss0 += yi * yi
+    return welch_from_sums(s1, ss1, n1, s0, ss0, n0)
+
+
+def slope_test(x, y):
+    n = len(x)
+    mx = mean(x)
+    my = mean(y)
+    sxx = sum((xi - mx) * (xi - mx) for xi in x)
+    sxy = sum((xi - mx) * (yi - my) for xi, yi in zip(x, y))
+    beta = sxy / sxx
+    alpha = my - beta * mx
+    rss = sum((yi - alpha - beta * xi) ** 2 for xi, yi in zip(x, y))
+    se = math.sqrt((rss / (n - 2)) / sxx)
+    z_score = beta / se
+    return {"effect": beta, "z": z_score, "p": p_from_z(z_score)}
+
+
+def invert_matrix(matrix):
+    n = len(matrix)
+    augmented = [
+        row[:] + [1.0 if i == j else 0.0 for j in range(n)]
+        for i, row in enumerate(matrix)
+    ]
+    for col in range(n):
+        pivot = max(range(col, n), key=lambda r: abs(augmented[r][col]))
+        if abs(augmented[pivot][col]) < 1e-12:
+            raise ValueError("singular matrix")
+        augmented[col], augmented[pivot] = augmented[pivot], augmented[col]
+        scale = augmented[col][col]
+        for j in range(2 * n):
+            augmented[col][j] /= scale
+        for r in range(n):
+            if r == col:
+                continue
+            factor = augmented[r][col]
+            if factor:
+                for j in range(2 * n):
+                    augmented[r][j] -= factor * augmented[col][j]
+    return [row[n:] for row in augmented]
+
+
+def ols_target(y, predictors, target):
+    names = ["intercept"] + [name for name, _ in predictors]
+    k = len(names)
+    xtx = [[0.0] * k for _ in range(k)]
+    xty = [0.0] * k
+    rows = []
+    for i, yi in enumerate(y):
+        row = [1.0] + [float(values[i]) for _, values in predictors]
+        rows.append(row)
+        for a in range(k):
+            xty[a] += row[a] * yi
+            for b in range(a, k):
+                xtx[a][b] += row[a] * row[b]
+    for a in range(k):
+        for b in range(a):
+            xtx[a][b] = xtx[b][a]
+    inverse = invert_matrix(xtx)
+    beta = [sum(inverse[i][j] * xty[j] for j in range(k)) for i in range(k)]
+    rss = 0.0
+    for row, yi in zip(rows, y):
+        pred = sum(beta[j] * row[j] for j in range(k))
+        rss += (yi - pred) ** 2
+    sigma2 = rss / (len(y) - k)
+    idx = names.index(target)
+    se = math.sqrt(max(sigma2 * inverse[idx][idx], 1e-300))
+    z_score = beta[idx] / se
+    return {"effect": beta[idx], "z": z_score, "p": p_from_z(z_score)}
+
+
+def mask_eq(values, target):
+    return [value == target for value in values]
+
+
+def mask_ge(values, threshold):
+    return [value >= threshold for value in values]
+
+
+def mask_le(values, threshold):
+    return [value <= threshold for value in values]
+
+
+def mand(*masks):
+    return [all(values) for values in zip(*masks)]
+
+
+def mnot(mask):
+    return [not value for value in mask]
+
+
+def as_num(mask):
+    return [1 if value else 0 for value in mask]
+
+
+def pfmt(p_value):
+    return "p<1e-300" if p_value == 0.0 else f"p={p_value:.2e}"
+
+
+def add_analysis(hypothesis_ids, stat, result_summary, method):
+    return {
+        "hypothesis_ids": hypothesis_ids,
+        "code": method,
+        "result_summary": result_summary,
+        "p_value": stat["p"],
+        "effect_estimate": stat["effect"],
+        "significant": stat["p"] < 0.05,
+        "n_in": stat.get("n_in"),
+        "n_out": stat.get("n_out"),
+        "mean_in": stat.get("mean_in"),
+        "mean_out": stat.get("mean_out"),
+        "z_score": stat.get("z"),
+    }
+
+
+def hyp(hypothesis_id, text, kind="novel"):
+    return {"id": hypothesis_id, "text": text, "kind": kind}
+
+
+def main():
+    df = load_table("dataset.parquet")
+    n_rows = len(df["cell_line_id"])
+    outcomes = [column for column in df if column.startswith("dependency_")]
+    lineages = sorted(set(df["lineage"]))
+    lineage_preds = [
+        (f"lineage_{lineage}", as_num(mask_eq(df["lineage"], lineage)))
+        for lineage in lineages[1:]
+    ]
+
+    growth_q75 = quantile(df["growth_rate_doublings_per_day"], 0.75)
+    cas9_q75 = quantile(df["cas9_activity_score"], 0.75)
+    wnt_q75 = quantile(df["wnt_activity_score"], 0.75)
+    cn8_q75 = quantile(df["copy_number_8q24"], 0.75)
+    ifn_q75 = quantile(df["ifn_gamma_signature"], 0.75)
+    slfn_q75 = quantile(df["rnaseq_SLFN11_log2_tpm"], 0.75)
+    myc_rna_q75 = quantile(df["rnaseq_MYC_log2_tpm"], 0.75)
+    serum_q25 = quantile(df["media_serum_pct"], 0.25)
+    aneu_q25 = quantile(df["aneuploidy_score"], 0.25)
+    mutburden_q25 = quantile(df["mutation_burden"], 0.25)
+
+    m_braf = mask_eq(df["braf_v600e"], 1)
+    m_egfr = mask_eq(df["egfr_amplification"], 1)
+    m_erbb2 = mask_eq(df["erbb2_amplification"], 1)
+    m_kras = mask_eq(df["kras_mutation"], 1)
+    m_nf1 = mask_eq(df["nf1_loss"], 1)
+    m_myc = mask_eq(df["myc_amplification"], 1)
+    m_apc = mask_eq(df["apc_mutation"], 1)
+    m_stk11 = mask_eq(df["stk11_loss"], 1)
+    m_col = mask_eq(df["lineage"], "colorectal")
+    m_breast = mask_eq(df["lineage"], "breast")
+    m_ovarian = mask_eq(df["lineage"], "ovarian")
+    m_pancreatic = mask_eq(df["lineage"], "pancreatic")
+    m_lung = mask_eq(df["lineage"], "lung")
+    m_squamous = mask_eq(df["lineage_subtype"], "squamous")
+    m_growth_hi = mask_ge(df["growth_rate_doublings_per_day"], growth_q75)
+    m_wnt_hi = mask_ge(df["wnt_activity_score"], wnt_q75)
+    m_cn8_hi = mask_ge(df["copy_number_8q24"], cn8_q75)
+    m_ifn_hi = mask_ge(df["ifn_gamma_signature"], ifn_q75)
+    m_slfn_hi = mask_ge(df["rnaseq_SLFN11_log2_tpm"], slfn_q75)
+    m_myc_rna_hi = mask_ge(df["rnaseq_MYC_log2_tpm"], myc_rna_q75)
+    m_serum_lo = mask_le(df["media_serum_pct"], serum_q25)
+    m_aneu_lo = mask_le(df["aneuploidy_score"], aneu_q25)
+    m_mutburden_lo = mask_le(df["mutation_burden"], mutburden_q25)
+
+    m_col_apc = mand(m_col, m_apc)
+    m_kif_complete = mand(m_col, m_apc, m_wnt_hi)
+    m_high_wnt_not_complete = mand(m_wnt_hi, mnot(m_kif_complete))
+    m_rpl11_pair = mand(m_myc, m_cn8_hi)
+
+    st = {
+        "braf": contrast(df["dependency_BRAF"], m_braf),
+        "egfr": contrast(df["dependency_EGFR"], m_egfr),
+        "erbb2": contrast(df["dependency_ERBB2"], m_erbb2),
+        "kras": contrast(df["dependency_KRAS"], m_kras),
+        "rit1_nf1": contrast(df["dependency_RIT1"], m_nf1),
+        "rpl11_pair": contrast(df["dependency_RPL11"], m_rpl11_pair),
+        "dhx9_myc": contrast(df["dependency_DHX9"], m_myc),
+        "kif_col": contrast(df["dependency_KIF18A"], m_col),
+        "kif_apc": contrast(df["dependency_KIF18A"], m_apc),
+        "kif_wnt_hi": contrast(df["dependency_KIF18A"], m_wnt_hi),
+        "kif_complete": contrast(df["dependency_KIF18A"], m_kif_complete),
+        "kif_wnt_within_col_apc": contrast(df["dependency_KIF18A"], m_wnt_hi, subset=m_col_apc),
+        "kif_complete_vs_high_wnt_not": contrast(
+            df["dependency_KIF18A"],
+            m_kif_complete,
+            subset=[a or b for a, b in zip(m_kif_complete, m_high_wnt_not_complete)],
+        ),
+        "polr2a_growth_hi": contrast(df["dependency_POLR2A"], m_growth_hi),
+        "tmed10_growth_hi": contrast(df["dependency_TMED10"], m_growth_hi),
+        "dhx9_growth_hi": contrast(df["dependency_DHX9"], m_growth_hi),
+        "braf_pair": contrast(df["dependency_BRAF"], mand(m_braf, m_growth_hi)),
+        "egfr_triple": contrast(df["dependency_EGFR"], mand(m_egfr, m_growth_hi, m_cn8_hi)),
+        "erbb2_triple": contrast(df["dependency_ERBB2"], mand(m_erbb2, m_breast, m_ifn_hi)),
+        "kras_triple": contrast(df["dependency_KRAS"], mand(m_kras, m_growth_hi, m_stk11)),
+        "rit1_triple": contrast(df["dependency_RIT1"], mand(m_nf1, m_aneu_lo, m_mutburden_lo)),
+        "tmed10_triple": contrast(df["dependency_TMED10"], mand(m_growth_hi, m_ovarian, m_slfn_hi)),
+        "dhx9_triple": contrast(df["dependency_DHX9"], mand(m_myc_rna_hi, m_serum_lo, m_squamous)),
+        "polr2a_triple": contrast(df["dependency_POLR2A"], mand(m_growth_hi, m_lung, m_slfn_hi)),
+        "rpl11_triple": contrast(df["dependency_RPL11"], mand(m_myc, m_growth_hi, m_pancreatic)),
+    }
+    st["braf_adj"] = ols_target(
+        df["dependency_BRAF"],
+        [("braf_v600e", as_num(m_braf)), ("growth_rate_doublings_per_day", df["growth_rate_doublings_per_day"]), ("cas9_activity_score", df["cas9_activity_score"])] + lineage_preds,
+        "braf_v600e",
+    )
+    st["egfr_adj"] = ols_target(
+        df["dependency_EGFR"],
+        [("egfr_amplification", as_num(m_egfr)), ("growth_rate_doublings_per_day", df["growth_rate_doublings_per_day"]), ("cas9_activity_score", df["cas9_activity_score"])] + lineage_preds,
+        "egfr_amplification",
+    )
+    st["erbb2_adj"] = ols_target(
+        df["dependency_ERBB2"],
+        [("erbb2_amplification", as_num(m_erbb2)), ("growth_rate_doublings_per_day", df["growth_rate_doublings_per_day"]), ("cas9_activity_score", df["cas9_activity_score"])] + lineage_preds,
+        "erbb2_amplification",
+    )
+    st["kras_adj"] = ols_target(
+        df["dependency_KRAS"],
+        [("kras_mutation", as_num(m_kras)), ("growth_rate_doublings_per_day", df["growth_rate_doublings_per_day"]), ("cas9_activity_score", df["cas9_activity_score"])] + lineage_preds,
+        "kras_mutation",
+    )
+    st["rit1_adj"] = ols_target(
+        df["dependency_RIT1"],
+        [("nf1_loss", as_num(m_nf1)), ("growth_rate_doublings_per_day", df["growth_rate_doublings_per_day"]), ("cas9_activity_score", df["cas9_activity_score"])] + lineage_preds,
+        "nf1_loss",
+    )
+    col_num = as_num(m_col)
+    apc_num = as_num(m_apc)
+    wnt_num = as_num(m_wnt_hi)
+    st["kif_threeway_adj"] = ols_target(
+        df["dependency_KIF18A"],
+        [
+            ("colorectal", col_num),
+            ("apc_mutation", apc_num),
+            ("wnt_high", wnt_num),
+            ("colorectal_apc", as_num(mand(m_col, m_apc))),
+            ("colorectal_wnt_high", as_num(mand(m_col, m_wnt_hi))),
+            ("apc_wnt_high", as_num(mand(m_apc, m_wnt_hi))),
+            ("colorectal_apc_wnt_high", as_num(m_kif_complete)),
+            ("growth_rate_doublings_per_day", df["growth_rate_doublings_per_day"]),
+            ("cas9_activity_score", df["cas9_activity_score"]),
+        ],
+        "colorectal_apc_wnt_high",
+    )
+    st["rpl11_pair_adj"] = ols_target(
+        df["dependency_RPL11"],
+        [
+            ("myc_amplification", as_num(m_myc)),
+            ("copy_number_8q24_high", as_num(m_cn8_hi)),
+            ("myc_amp_x_cn8_high", as_num(m_rpl11_pair)),
+            ("growth_rate_doublings_per_day", df["growth_rate_doublings_per_day"]),
+            ("cas9_activity_score", df["cas9_activity_score"]),
+        ],
+        "myc_amp_x_cn8_high",
+    )
+    st["polr2a_growth_slope"] = slope_test(df["growth_rate_doublings_per_day"], df["dependency_POLR2A"])
+    st["tmed10_growth_slope"] = slope_test(df["growth_rate_doublings_per_day"], df["dependency_TMED10"])
+    st["dhx9_growth_slope"] = slope_test(df["growth_rate_doublings_per_day"], df["dependency_DHX9"])
+
+    method_contrast = "Welch two-sample contrast of the named subgroup versus its complement; p-values use a large-sample normal approximation."
+    method_subset = "Welch two-sample contrast within the stated subset; p-values use a large-sample normal approximation."
+    method_ols = "Ordinary least squares with the stated predictors; p-values use a large-sample normal approximation for the coefficient z-score."
+    iterations = []
+
+    def add_iteration(index, hypotheses, analyses):
+        iterations.append({"index": index, "proposed_hypotheses": hypotheses, "analyses": analyses})
+
+    add_iteration(1, [
+        hyp("h1", "Cell lines with `braf_v600e == 1` have more negative `dependency_BRAF` scores than cell lines with `braf_v600e == 0`."),
+        hyp("h2", "Cell lines with `egfr_amplification == 1` have more negative `dependency_EGFR` scores than cell lines without EGFR amplification."),
+        hyp("h3", "Cell lines with `erbb2_amplification == 1` have more negative `dependency_ERBB2` scores than cell lines without ERBB2 amplification."),
+        hyp("h4", "Cell lines with `kras_mutation == 1` have more negative `dependency_KRAS` scores than cell lines without KRAS mutation."),
+    ], [
+        add_analysis(["h1"], st["braf"], f"`braf_v600e == 1` lines had mean `dependency_BRAF` {st['braf']['mean_in']:.3f} vs {st['braf']['mean_out']:.3f}; effect {st['braf']['effect']:.3f} ({pfmt(st['braf']['p'])}).", method_contrast),
+        add_analysis(["h2"], st["egfr"], f"`egfr_amplification == 1` lines had mean `dependency_EGFR` {st['egfr']['mean_in']:.3f} vs {st['egfr']['mean_out']:.3f}; effect {st['egfr']['effect']:.3f} ({pfmt(st['egfr']['p'])}).", method_contrast),
+        add_analysis(["h3"], st["erbb2"], f"`erbb2_amplification == 1` lines had mean `dependency_ERBB2` {st['erbb2']['mean_in']:.3f} vs {st['erbb2']['mean_out']:.3f}; effect {st['erbb2']['effect']:.3f} ({pfmt(st['erbb2']['p'])}).", method_contrast),
+        add_analysis(["h4"], st["kras"], f"`kras_mutation == 1` lines had mean `dependency_KRAS` {st['kras']['mean_in']:.3f} vs {st['kras']['mean_out']:.3f}; effect {st['kras']['effect']:.3f} ({pfmt(st['kras']['p'])}).", method_contrast),
+    ])
+    add_iteration(2, [
+        hyp("h5", "Cell lines with `nf1_loss == 1` have more negative `dependency_RIT1` scores than cell lines without NF1 loss."),
+        hyp("h6", f"Cell lines with `myc_amplification == 1` and `copy_number_8q24 >= {cn8_q75:.3f}` have more negative `dependency_RPL11` scores than other cell lines."),
