+        add_analysis(["h38"], st["polr2a_growth_slope"], f"Growth-rate slopes were negative for POLR2A ({st['polr2a_growth_slope']['effect']:.3f}), TMED10 ({st['tmed10_growth_slope']['effect']:.3f}), and DHX9 ({st['dhx9_growth_slope']['effect']:.3f}); exploratory subgroup hits for TMED10 and DHX9 were much smaller than the KIF18A and canonical driver effects.", "Synthesis of continuous growth-rate models and exploratory subgroup screens."),
