The Parquet file is standard `PAR1` and its footer is locally readable. Since the normal data libraries are not runnable in this sandbox, I’m using a small local-only Parquet decoder path to inspect the metadata and then the data pages.
exec
"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command 'Remove-Item Env:VIRTUAL_ENV -ErrorAction SilentlyContinue; $env:UV_CACHE_DIR='"'C:\\Users\\klkehl\\AppData\\Local\\Temp\\uv-cache-ocs'; @'
from pathlib import Path
from pprint import pprint

CT_STOP=0; CT_BOOLEAN_TRUE=1; CT_BOOLEAN_FALSE=2; CT_BYTE=3; CT_I16=4; CT_I32=5; CT_I64=6; CT_DOUBLE=7; CT_BINARY=8; CT_LIST=9; CT_SET=10; CT_MAP=11; CT_STRUCT=12; CT_FLOAT=13
class CompactReader:
    def __init__(self, data): self.data=data; self.i=0
    def read_byte(self): b=self.data[self.i]; self.i+=1; return b
    def read_varint(self):
        shift=0; result=0
        while True:
            b=self.read_byte(); result |= (b & 0x7f) << shift
            if not (b & 0x80): break
            shift += 7
        return result
    def zigzag(self,n): return (n >> 1) "'^ -(n & 1)
    def read_int(self): return self.zigzag(self.read_varint())
    def read_binary(self):
        n=self.read_varint(); b=self.data[self.i:self.i+n]; self.i+=n
        try: return b.decode('"'utf-8')
        except UnicodeDecodeError: return b
    def read_val(self,t):
        import struct
        if t==CT_BOOLEAN_TRUE: return True
        if t==CT_BOOLEAN_FALSE: return False
        if t in (CT_BYTE, CT_I16, CT_I32, CT_I64): return self.read_int()
        if t==CT_DOUBLE:
            v=struct.unpack('<d', self.data[self.i:self.i+8])[0]; self.i+=8; return v
        if t==CT_FLOAT:
            v=struct.unpack('<f', self.data[self.i:self.i+4])[0]; self.i+=4; return v
        if t==CT_BINARY: return self.read_binary()
        if t in (CT_LIST, CT_SET):
            hb=self.read_byte(); size=hb>>4; et=hb&0x0f
            if size==15: size=self.read_varint()
            return [self.read_val(et) for _ in range(size)]
        if t==CT_MAP:
            size=self.read_varint()
            if size==0: return {}
            ktvt=self.read_byte(); kt=ktvt>>4; vt=ktvt&0xf
            return {self.read_val(kt): self.read_val(vt) for _ in range(size)}
        if t==CT_STRUCT: return self.read_struct()
        raise ValueError(('type',t,'pos',self.i))
    def read_struct(self):
        out={}; last=0
        while True:
            hb=self.read_byte(); t=hb&0x0f; delta=hb>>4
            if t==CT_STOP: break
            if delta: fid=last+delta
            else: fid=self.read_int()
            last=fid
            out[fid]=self.read_val(t)
        return out

b=Path('dataset.parquet').read_bytes(); fl=int.from_bytes(b[-8:-4],'little'); foot=b[len(b)-8-fl:len(b)-8]
