allcols=list(cols)
outcomes=[c for c in allcols if c.startswith('dependency_')]
cat=['lineage','lineage_subtype','culture_type','screen_batch']
binary=[c for c in allcols if c not in outcomes+cat+['cell_line_id'] and set(cols[c]) <= {0,1}]
numeric=[c for c in allcols if c not in outcomes+cat+binary+['cell_line_id']]
print('binary', binary)
print('numeric', numeric)

print('\\nOUTCOME MEANS')
for y in outcomes:
    print(y, mean(cols[y]), min(cols[y]), max(cols[y]))

# Main effect rankings
for y in outcomes:
    yv=cols[y]
    hits=[]
    for f in binary:
        r=contrast(yv, [v==1 for v in cols[f]])
        if r: hits.append((abs(r['effect']), r['effect'], r['p'], f, r['n_in'], r['mean_in'], r['mean_out']))
    for f in numeric:
        r=slope_test(cols[f], yv)
        if r: hits.append((abs(r['effect']), r['effect'], r['p'], f, None, None, None))
    for f in cat:
        counts=Counter(cols[f])
        for val,nc in counts.items():
            if nc>=500:
                r=contrast(yv, [v==val for v in cols[f]])
                if r: hits.append((abs(r['effect']), r['effect'], r['p'], f+'='+str(val), r['n_in'], r['mean_in'], r['mean_out']))
    hits.sort(reverse=True)
    print('\\nTOP MAIN', y)
    for h in hits[:12]: print(h)

# Build predicates
preds=[]
for f in binary:
    vals=cols[f]
    n1=sum(1 for v in vals if v==1); n0=len(vals)-n1
    if n1>=200: preds.append((f+' == 1', [v==1 for v in vals], f, 'binary1'))
    if n0>=200: preds.append((f+' == 0', [v==0 for v in vals], f, 'binary0'))
for f in cat:
    counts=Counter(cols[f])
    for val,nc in counts.items():
        if nc>=500: preds.append((f+\" == '\"+str(val)+\"'\", [v==val for v in cols[f]], f, 'cat'))
for f in numeric:
    vals=cols[f]; q25=quantile(vals,0.25); q75=quantile(vals,0.75)
    preds.append((f+' >= Q75 %.4g'%q75, [v>=q75 for v in vals], f, 'num_hi'))
    preds.append((f+' <= Q25 %.4g'%q25, [v<=q25 for v in vals], f, 'num_lo'))
print('predicates', len(preds))
# Single and pair subgroup search
for y in outcomes:
    yv=cols[y]
    singles=[]
    for desc,mask,f,typ in preds:
        r=contrast(yv, mask)
        if r and 250 <= r['n_in'] <= 30000:
            singles.append((r['effect'], r['p'], desc, r['n_in'], r['mean_in'], r['mean_out'], mask, f))
    singles.sort(key=lambda x: x[0]) # most negative
    print('\\nSUBGROUP SINGLES', y)
    for x in singles[:15]: print(x[:6])
    # pair search among 25 best negative singles + a few strong positives? skip same feature
    cand=singles[:30]
    pairs=[]
    for i in range(len(cand)):
        for j in range(i+1,len(cand)):
            if cand[i][7]==cand[j][7]: continue
            mask=[a and b for a,b in zip(cand[i][6], cand[j][6])]
            n_in=sum(mask)
            if n_in<250 or n_in>25000: continue
            r=contrast(yv, mask)
            if r: pairs.append((r['effect'], r['p'], cand[i][2]+' AND '+cand[j][2], r['n_in'], r['mean_in'], r['mean_out']))
    pairs.sort(key=lambda x:x[0])
    print('SUBGROUP PAIRS', y)
    for x in pairs[:15]: print(x)

# Specific triple search for outcomes using top pair plus third from top singles
for y in outcomes:
    yv=cols[y]
    singles=[]
    for desc,mask,f,typ in preds:
        r=contrast(yv, mask)
        if r and 250 <= r['n_in'] <= 30000:
            singles.append((r['effect'], desc, mask, f))
    singles.sort(key=lambda x:x[0])
    cand=singles[:20]
    triples=[]
    for a,b2,c in itertools.combinations(range(len(cand)),3):
        if len({cand[a][3],cand[b2][3],cand[c][3]})<3: continue
        mask=[x and yb and z for x,yb,z in zip(cand[a][2],cand[b2][2],cand[c][2])]
        n=sum(mask)
        if n<200 or n>15000: continue
        r=contrast(yv,mask)
        if r: triples.append((r['effect'], r['p'], cand[a][1]+' AND '+cand[b2][1]+' AND '+cand[c][1], r['n_in'], r['mean_in'], r['mean_out']))
    triples.sort(key=lambda x:x[0])
    print('\\nSUBGROUP TRIPLES', y)
    for x in triples[:8]: print(x)
