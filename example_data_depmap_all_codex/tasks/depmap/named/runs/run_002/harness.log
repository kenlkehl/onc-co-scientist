st['kif_threeway_adj']=ols_target(df['dependency_KIF18A'], [('colorectal', col_num), ('apc_mutation', apc_num), ('wnt_high', wnt_num), ('colorectal_apc', col_apc_num), ('colorectal_wnt_high', col_wnt_num), ('apc_wnt_high', apc_wnt_num), ('colorectal_apc_wnt_high', complete_num), ('growth_rate_doublings_per_day', df['growth_rate_doublings_per_day']), ('cas9_activity_score', df['cas9_activity_score'])], 'colorectal_apc_wnt_high')
st['rpl11_pair_adj']=ols_target(df['dependency_RPL11'], [('myc_amplification', as_num(m_myc)), ('copy_number_8q24_high', as_num(m_cn8_hi)), ('myc_amp_x_cn8_high', as_num(m_rpl11_pair)), ('growth_rate_doublings_per_day', df['growth_rate_doublings_per_day']), ('cas9_activity_score', df['cas9_activity_score'])], 'myc_amp_x_cn8_high')
st['polr2a_growth_slope']=slope_test(df['growth_rate_doublings_per_day'], df['dependency_POLR2A'])
st['tmed10_growth_slope']=slope_test(df['growth_rate_doublings_per_day'], df['dependency_TMED10'])
st['dhx9_growth_slope']=slope_test(df['growth_rate_doublings_per_day'], df['dependency_DHX9'])

