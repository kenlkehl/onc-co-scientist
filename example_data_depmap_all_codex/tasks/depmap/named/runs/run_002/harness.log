 def b(s): x=s.d[s.i]; s.i+=1; return x
 def vi(s):
  sh=0; r=0
  while 1:
   x=s.b(); r|=(x&127)<<sh
   if not x&128: return r
   sh+=7
 def zz(s,n): return (n>>1)"'^-(n&1)
 def iv(s): return s.zz(s.vi())
 def bin(s):
  n=s.vi(); b=s.d[s.i:s.i+n]; s.i+=n
  try: return b.decode()
  except: return b
 def val(s,t):
  import struct
  if t==1: return True
  if t==2: return False
  if t in (3,4,5,6): return s.iv()
  if t==7:
   v=struct.unpack('"'<d',s.d[s.i:s.i+8])[0]; s.i+=8; return v
  if t==13:
   v=struct.unpack('<f',s.d[s.i:s.i+4])[0]; s.i+=4; return v
  if t==8: return s.bin()
