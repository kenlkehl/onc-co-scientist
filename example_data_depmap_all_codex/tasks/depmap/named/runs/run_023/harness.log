import pandas as pd, numpy as np
from scipy import stats
from statsmodels.stats.multitest import multipletests
import statsmodels.formula.api as smf

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cat=['lineage','lineage_subtype','culture_type','screen_batch']
print('Unadjusted binary mean differences (feature=1 - 0), top abs per outcome')
for y in outcomes:
    rows=[]
    for x in binary:
        g1=df.loc[df[x]==1,y]; g0=df.loc[df[x]==0,y]
        eff=g1.mean()-g0.mean()
        t,p=stats.ttest_ind(g1,g0,equal_var=False)
        rows.append((x, eff, p, g1.mean(), g0.mean(), len(g1)))
    rows=sorted(rows,key=lambda r:abs(r[1]), reverse=True)[:8]
    print('\\n',y)
    for r in rows:
        print('%20s eff=% .4f p=%.3g mean1=%.3f mean0=%.3f n1=%d'%r)
print('\\nContinuous Pearson correlations top abs per outcome')
for y in outcomes:
    rows=[]
    for x in cont:
        r,p=stats.pearsonr(df[x],df[y])
        # effect per SD of x
        eff=np.polyfit((df[x]-df[x].mean())/df[x].std(), df[y], 1)[0]
        rows.append((x, r, eff, p))
    rows=sorted(rows,key=lambda r:abs(r[1]), reverse=True)[:8]
    print('\\n',y)
    for x,r,eff,p in rows:
        print('%28s r=% .3f eff_per_sd=% .4f p=%.3g'%(x,r,eff,p))
print('\\nLineage means lowest per outcome')
for y in outcomes:
    means=df.groupby('lineage')[y].agg(['mean','size']).sort_values('mean')
    print('\\n',y)
    print(means.head(5).to_string())
