qs={x:(df.loc[disc,x].quantile(.25), df.loc[disc,x].quantile(.75)) for x in ['rnaseq_SLFN11_log2_tpm','rnaseq_MYC_log2_tpm','growth_rate_doublings_per_day','mutation_burden','aneuploidy_score','emt_score','wnt_activity_score','ploidy','copy_number_8q24','rnaseq_AXL_log2_tpm','hypoxia_score','cas9_activity_score']}
# definitions from subgroup search, plus simpler drivers
def eval_def(y, name, mask):
    yy=df[y].values; m=mask & valid; c=valid & ~mask
    t,p=stats.ttest_ind(yy[m], yy[c], equal_var=False)
    print(y, name, 'n',m.sum(),'mean',yy[m].mean(),'comp',yy[c].mean(),'eff',yy[m].mean()-yy[c].mean(),'p',p)

def within(y, base_name, base, sub_name, sub):
    yy=df[y].values; b=base & valid
    a=b & sub; c=b & ~sub
    t,p=stats.ttest_ind(yy[a], yy[c], equal_var=False)
    print('within',y,base_name,sub_name,'n1',a.sum(),'mean1',yy[a].mean(),'n0',c.sum(),'mean0',yy[c].mean(),'diff',yy[a].mean()-yy[c].mean(),'p',p)
# RIT1
mask_nf1=df['nf1_loss'].eq(1).values
mask_rit=mask_nf1 & df['media_serum_pct'].ge(10).values & df['rnaseq_SLFN11_log2_tpm'].le(qs['rnaseq_SLFN11_log2_tpm'][0]).values
eval_def('dependency_RIT1','nf1_loss=1',mask_nf1)
eval_def('dependency_RIT1','nf1_loss=1 & media_serum_pct>=10 & SLFN11<=Q1',mask_rit)
within('dependency_RIT1','nf1_loss=1',mask_nf1,'media_serum>=10 & SLFN11<=Q1', df['media_serum_pct'].ge(10).values & df['rnaseq_SLFN11_log2_tpm'].le(qs['rnaseq_SLFN11_log2_tpm'][0]).values)
# RPL11 simpler
mask_myc=df['myc_amplification'].eq(1).values
mask_copy=df['copy_number_8q24'].ge(qs['copy_number_8q24'][1]).values
eval_def('dependency_RPL11','myc_amplification=1',mask_myc)
eval_def('dependency_RPL11','copy_number_8q24>=Q3',mask_copy)
mask_rpl=mask_myc & df['growth_rate_doublings_per_day'].ge(qs['growth_rate_doublings_per_day'][1]).values & df['ploidy'].ge(qs['ploidy'][1]).values
eval_def('dependency_RPL11','myc_amplification=1 & growth>=Q3 & ploidy>=Q3',mask_rpl)
within('dependency_RPL11','myc_amplification=1',mask_myc,'growth>=Q3 & ploidy>=Q3',df['growth_rate_doublings_per_day'].ge(qs['growth_rate_doublings_per_day'][1]).values & df['ploidy'].ge(qs['ploidy'][1]).values)
# DHX9
mask_mychigh=df['rnaseq_MYC_log2_tpm'].ge(qs['rnaseq_MYC_log2_tpm'][1]).values
mask_dhx=df['growth_rate_doublings_per_day'].ge(qs['growth_rate_doublings_per_day'][1]).values & mask_mychigh & df['rnaseq_AXL_log2_tpm'].le(qs['rnaseq_AXL_log2_tpm'][0]).values
eval_def('dependency_DHX9','rnaseq_MYC>=Q3',mask_mychigh)
