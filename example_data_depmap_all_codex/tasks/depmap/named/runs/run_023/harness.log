import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations
from statsmodels.stats.multitest import multipletests

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cat=['lineage','lineage_subtype','culture_type','screen_batch']
# deterministic split: even integer suffix discovery, odd validation
ids=df['cell_line_id'].str.extract(r'(\\d+)"'$'"')[0].astype(int)
disc=(ids % 2 == 0).values
valid=~disc
# predicates based on discovery quantiles
preds=[]
def add(var, desc, mask):
    preds.append({'var':var,'desc':desc,'mask':mask.astype(bool)})
for x in binary:
    add(x, f'{x}=1', (df[x].values==1))
    add(x, f'{x}=0', (df[x].values==0))
for x in cat:
    for val in sorted(df[x].unique()):
        add(x, f'{x}={val}', (df[x].values==val))
for x in cont:
    q25=df.loc[disc,x].quantile(0.25)
    q75=df.loc[disc,x].quantile(0.75)
    add(x, f'{x}<=Q1({q25:.3g})', (df[x].values<=q25))
    add(x, f'{x}>=Q3({q75:.3g})', (df[x].values>=q75))

# eligible single predicates min/max counts
n_disc=disc.sum(); n_valid=valid.sum()
min_disc=250; min_valid=250; max_frac=0.6
valid_single=[]
for i,p in enumerate(preds):
    nd=(p['mask'] & disc).sum(); nv=(p['mask'] & valid).sum()
    if nd>=min_disc and nv>=min_valid and nd<=max_frac*n_disc and nv<=max_frac*n_valid:
        valid_single.append(i)

print('predicates', len(preds), 'eligible singles', len(valid_single), 'disc/valid', n_disc, n_valid)

def compatible(indices):
    vars_seen={}
    for i in indices:
        v=preds[i]['var']
        # disallow multiple predicates on same variable for simple complete definitions
        if v in vars_seen: return False
        vars_seen[v]=1
    return True

all_results=[]
for y in outcomes:
    yv=df[y].values
    # score singles and pairs on discovery
    cands=[]
    for i in valid_single:
        m=preds[i]['mask'] & disc
        nr=m.sum()
        if nr<min_disc: continue
        eff=yv[m].mean()-yv[disc & ~preds[i]['mask']].mean()
        cands.append((eff, (i,), nr))
    for i,j in combinations(valid_single,2):
        if not compatible((i,j)): continue
        mask=preds[i]['mask'] & preds[j]['mask']
        nr=(mask & disc).sum(); nv=(mask & valid).sum()
        if nr<min_disc or nv<min_valid: continue
        if nr>max_frac*n_disc or nv>max_frac*n_valid: continue
        eff=yv[mask & disc].mean()-yv[disc & ~mask].mean()
        cands.append((eff, (i,j), nr))
    # expand top negative pairs/singles to triples
    top_seed=sorted(cands, key=lambda z:z[0])[:200]
    seen={tuple(sorted(idx)) for _,idx,_ in cands}
    for eff0,idxs,nr0 in top_seed:
        for k in valid_single:
            tup=tuple(sorted(set(idxs+(k,))))
            if len(tup)"'!=len(idxs)+1 or len(tup)>3 or tup in seen or not compatible(tup): continue
            mask=np.ones(len(df), dtype=bool)
            for ii in tup: mask &= preds[ii]['"'mask']
            nr=(mask & disc).sum(); nv=(mask & valid).sum()
            if nr<min_disc or nv<min_valid: continue
            if nr>max_frac*n_disc or nv>max_frac*n_valid: continue
            eff=yv[mask & disc].mean()-yv[disc & ~mask].mean()
            cands.append((eff,tup,nr)); seen.add(tup)
    # select best more-negative effect on discovery
    cands_sorted=sorted(cands, key=lambda z:z[0])
    # validation test for top 10 candidates
    val_rows=[]
    for eff_disc,idxs,nr in cands_sorted[:10]:
        mask=np.ones(len(df), dtype=bool)
        for ii in idxs: mask &= preds[ii]['mask']
        mv=mask & valid; cv=valid & ~mask
        eff_val=yv[mv].mean()-yv[cv].mean()
        t,p=stats.ttest_ind(yv[mv], yv[cv], equal_var=False)
        val_rows.append({'outcome':y,'defs':[preds[ii]['desc'] for ii in idxs], 'vars':[preds[ii]['var'] for ii in idxs], 'n_disc':int((mask&disc).sum()), 'n_valid':int(mv.sum()), 'mean_sub_val':float(yv[mv].mean()), 'mean_comp_val':float(yv[cv].mean()), 'eff_disc':float(eff_disc), 'eff_val':float(eff_val), 'p_val':float(p)})
    best=val_rows[0]
    all_results.append(best)
    print('\\n', y, 'best')
    print('  ', ' AND '.join(best['defs']))
    print('  n_valid',best['n_valid'],'mean_sub',round(best['mean_sub_val'],4),'mean_comp',round(best['mean_comp_val'],4),'eff_val',round(best['eff_val'],4),'p',best['p_val'])
    print('  top candidates:')
    for r in val_rows[:5]:
        print('   ', ' & '.join(r['defs']), 'n',r['n_valid'],'eff_val',round(r['eff_val'],4),'p',f\"{r['p_val']:.2g}\")
# FDR over best validations
_,q,_,_=multipletests([r['p_val'] for r in all_results], method='fdr_bh')
print('\\nBest validation q-values')
for r,qq in zip(all_results,q):
    print(r['outcome'], 'q', qq, 'defs:', ' & '.join(r['defs']))
