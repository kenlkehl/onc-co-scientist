within('dependency_DHX9','MYC>=Q3',mask_mychigh,'growth>=Q3 & AXL<=Q1',df['growth_rate_doublings_per_day'].ge(qs['growth_rate_doublings_per_day'][1]).values & df['rnaseq_AXL_log2_tpm'].le(qs['rnaseq_AXL_log2_tpm'][0]).values)
# POLR2A
mask_growth=df['growth_rate_doublings_per_day'].ge(qs['growth_rate_doublings_per_day'][1]).values
mask_pol=df['cdkn2a_loss'].eq(1).values & mask_growth & df['aneuploidy_score'].le(qs['aneuploidy_score'][0]).values
eval_def('dependency_POLR2A','growth_rate>=Q3',mask_growth)
eval_def('dependency_POLR2A','cdkn2a_loss=1 & growth>=Q3 & aneuploidy<=Q1',mask_pol)
within('dependency_POLR2A','growth>=Q3',mask_growth,'cdkn2a_loss=1 & aneuploidy<=Q1',df['cdkn2a_loss'].eq(1).values & df['aneuploidy_score'].le(qs['aneuploidy_score'][0]).values)
# TMED10
