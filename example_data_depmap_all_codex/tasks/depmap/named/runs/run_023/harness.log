/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
import statsmodels.formula.api as smf
from statsmodels.stats.multitest import multipletests

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
# make z columns for continuous covariates
work=df.copy()
for c in cont:
    work[c+'_z']=(work[c]-work[c].mean())/work[c].std()
terms=binary+[c+'_z' for c in cont]+['C(lineage)','C(lineage_subtype)','C(culture_type)','C(screen_batch)']
formula_rhs=' + '.join(terms)
allrows=[]
for y in outcomes:
    model=smf.ols(f'{y} ~ {formula_rhs}', data=work).fit()
    for name,coef,p in zip(model.params.index, model.params.values, model.pvalues.values):
        if name=='Intercept': continue
        allrows.append({'outcome':y,'term':name,'coef':coef,'p':p})
# BH within all main-effect coefficients
pvals=[r['p'] for r in allrows]
_,q,_,_=multipletests(pvals, method='fdr_bh')
for r,qq in zip(allrows,q): r['q']=qq
for y in outcomes:
    rows=[r for r in allrows if r['outcome']==y]
    rows=sorted(rows,key=lambda r:abs(r['coef']), reverse=True)[:12]
    print('\\n',y)
    for r in rows:
        print(f\"{r['term']:<42} coef={r['coef']: .4f} p={r['p']:.3g} q={r['q']:.3g}\")
