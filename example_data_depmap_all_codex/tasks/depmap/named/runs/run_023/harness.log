/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from statsmodels.stats.multitest import multipletests

df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cat=['lineage','lineage_subtype','culture_type','screen_batch']
# encoded main matrix
parts=[]; labels=[]; basevar=[]
# intercept
parts.append(np.ones((len(df),1))); labels.append('Intercept'); basevar.append('Intercept')
for x in binary:
    parts.append(df[[x]].astype(float).values); labels.append(x); basevar.append(x)
for x in cont:
    z=((df[x]-df[x].mean())/df[x].std()).values.reshape(-1,1)
    parts.append(z); labels.append(x+'_z'); basevar.append(x)
for x in cat:
    d=pd.get_dummies(df[x], prefix=x, drop_first=True, dtype=float)
    parts.append(d.values); labels.extend(d.columns.tolist()); basevar.extend([x]*d.shape[1])
X=np.column_stack(parts)
# QR for residualization
Q,R=np.linalg.qr(X, mode='reduced')

def resid(A):
    return A - Q @ (Q.T @ A)
# feature matrix for possible modifiers includes non-intercept encoded main columns
F=X[:,1:]
flabels=labels[1:]
fbase=basevar[1:]
# map drivers to encoded vector and base var
zcols={}
for x in binary:
