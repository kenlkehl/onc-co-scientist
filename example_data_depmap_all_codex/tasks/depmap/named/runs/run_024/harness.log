        {'id': 'h6', 'text': 'The "'`egfr_amplification` effect on `dependency_EGFR` is more negative in `lineage="brain"` than in non-brain lineages.'"', 'kind': 'refined'},
        {'id': 'h7', 'text': 'The "'`erbb2_amplification` effect on `dependency_ERBB2` is more negative in `lineage` equal to `breast` or `gastric` than in other lineages.'"', 'kind': 'refined'},
        {'id': 'h8', 'text': 'The "'`kras_mutation` effect on `dependency_KRAS` is more negative in `lineage="pancreatic"` than in non-pancreatic lineages.'"', 'kind': 'refined'},
    ],
