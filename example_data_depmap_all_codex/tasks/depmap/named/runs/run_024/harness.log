        analysis(['h6'], ols_term('EGFR lineage interaction', 'dependency_EGFR ~ egfr_amplification + I(lineage==\"brain\") + egfr_amplification:I(lineage==\"brain\") + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)', 'egfr_amplification:I(lineage == \"brain\")[T.True]'), 'OLS interaction model adjusted for growth rate, Cas9 activity, and screen batch'),
