from scipy import stats
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LinearRegression
from sklearn.tree import DecisionTreeRegressor, export_text
import statsmodels.formula.api as smf

df=pd.read_parquet('dataset.parquet')
deps=[c for c in df.columns if c.startswith('dependency_')]
bin_features=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont_features=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cat_features=['lineage','lineage_subtype','culture_type','screen_batch']
print('Univariate binary effects: mean(1)-mean(0), p')
for dep in deps:
    vals=[]
    for f in bin_features:
        a=df.loc[df[f]==1,dep]; b=df.loc[df[f]==0,dep]
        t,p=stats.ttest_ind(a,b,equal_var=False)
        vals.append((abs(a.mean()-b.mean()), f, a.mean()-b.mean(), p, a.mean(), b.mean(), len(a)))
    print('\\n',dep)
    for _,f,e,p,m1,m0,n1 in sorted(vals, reverse=True)[:8]:
        print(f'{f:20s} diff={e: .4f} p={p:.1e} mean1={m1:.4f} mean0={m0:.4f} n1={n1}')
print('\\nContinuous correlations: slope per SD x, p')
for dep in deps:
    vals=[]
    for f in cont_features:
        x=(df[f]-df[f].mean())/df[f].std()
        res=stats.linregress(x,df[dep])
        vals.append((abs(res.slope), f, res.slope, res.pvalue, res.rvalue))
    print('\\n',dep)
    for _,f,s,p,r in sorted(vals, reverse=True)[:8]:
        print(f'{f:28s} slope={s: .4f} r={r:.3f} p={p:.1e}')
print('\\nCategorical lineage/subtype/culture/batch diffs vs rest top')
for dep in deps:
    vals=[]
    for f in cat_features:
        for lev,count in df[f].value_counts().items():
            if count<200: continue
            mask=df[f]==lev
            e=df.loc[mask,dep].mean()-df.loc[~mask,dep].mean()
            t,p=stats.ttest_ind(df.loc[mask,dep],df.loc[~mask,dep],equal_var=False)
            vals.append((abs(e), f, lev, e, p, count, df.loc[mask,dep].mean()))
    print('\\n',dep)
    for _,f,lev,e,p,n,m in sorted(vals, reverse=True)[:8]:
        print(f'{f}={lev:20s} diff={e: .4f} p={p:.1e} n={n} mean={m:.4f}')
