import pandas as pd, numpy as np, itertools, math
from scipy import stats
import statsmodels.formula.api as smf

df=pd.read_parquet('dataset.parquet')
deps=[c for c in df.columns if c.startswith('dependency_')]
bin_features=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont_features=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']

# effect by lineage for selected driver-feature pairs
pairs=[('dependency_BRAF','braf_v600e'),('dependency_EGFR','egfr_amplification'),('dependency_ERBB2','erbb2_amplification'),('dependency_KRAS','kras_mutation'),('dependency_RIT1','nf1_loss'),('dependency_KIF18A','apc_mutation'),('dependency_RPL11','myc_amplification')]
print('Driver effect by lineage: effect=mean(feature1)-mean(feature0)')
for dep,feat in pairs:
    print('\\n',dep, feat)
    rows=[]
    for lin,sub in df.groupby('lineage'):
        if sub[feat].sum()<50 or (sub[feat]==0).sum()<50: continue
        a=sub.loc[sub[feat]==1,dep]; b=sub.loc[sub[feat]==0,dep]
        t,p=stats.ttest_ind(a,b,equal_var=False)
        rows.append((a.mean()-b.mean(),lin,p,len(a),a.mean(),b.mean()))
    for e,lin,p,n,m1,m0 in sorted(rows):
        print(f'{lin:14s} diff={e: .4f} p={p:.1e} n1={n} mean1={m1:.4f} mean0={m0:.4f}')

# selected OLS interaction models with covariates. quote not needed simple names.
print('\\nSelected interaction models')
models=[
('BRAF_braf_skin','dependency_BRAF ~ braf_v600e + I(lineage==\"skin\") + braf_v600e:I(lineage==\"skin\") + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
('EGFR_amp_brain','dependency_EGFR ~ egfr_amplification + I(lineage==\"brain\") + egfr_amplification:I(lineage==\"brain\") + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
('ERBB2_amp_breast_gastric','dependency_ERBB2 ~ erbb2_amplification + I((lineage==\"breast\") | (lineage==\"gastric\")) + erbb2_amplification:I((lineage==\"breast\") | (lineage==\"gastric\")) + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
('KRAS_mut_pancreatic','dependency_KRAS ~ kras_mutation + I(lineage==\"pancreatic\") + kras_mutation:I(lineage==\"pancreatic\") + smad4_loss + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
('KRAS_mut_smad4','dependency_KRAS ~ kras_mutation + smad4_loss + kras_mutation:smad4_loss + I(lineage==\"pancreatic\") + C(screen_batch) + growth_rate_doublings_per_day + cas9_activity_score'),
('RIT1_nf1_lung','dependency_RIT1 ~ nf1_loss + I(lineage==\"lung\") + nf1_loss:I(lineage==\"lung\") + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
('KIF18A_apc_smad4','dependency_KIF18A ~ apc_mutation + smad4_loss + apc_mutation:smad4_loss + wnt_activity_score + I(lineage==\"colorectal\") + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
('KIF18A_wnt_colorectal','dependency_KIF18A ~ wnt_activity_score + I(lineage==\"colorectal\") + wnt_activity_score:I(lineage==\"colorectal\") + apc_mutation + smad4_loss + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
('DHX9_myc_expr_amp','dependency_DHX9 ~ rnaseq_MYC_log2_tpm + myc_amplification + rnaseq_MYC_log2_tpm:myc_amplification + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
('POLR2A_growth_myc','dependency_POLR2A ~ growth_rate_doublings_per_day + rnaseq_MYC_log2_tpm + growth_rate_doublings_per_day:rnaseq_MYC_log2_tpm + cas9_activity_score + C(screen_batch)'),
('RPL11_8q_myc','dependency_RPL11 ~ copy_number_8q24 + myc_amplification + copy_number_8q24:myc_amplification + growth_rate_doublings_per_day + cas9_activity_score + C(screen_batch)'),
]
for name,formula in models:
    try:
        m=smf.ols(formula, data=df).fit()
        print('\\n'+name)
        for term in m.params.index:
            if ':' in term or term in formula.split('~')[1]:
                pass
        for term,coef in m.params.items():
            if term=='Intercept' or term.startswith('C(screen_batch)'): continue
            print(f'{term:70s} coef={coef: .5f} p={m.pvalues[term]:.2e}')
        print(f'R2={m.rsquared:.3f}')
    except Exception as e:
        print(name, 'ERR', e)

# systematic subgroup screen.
predicates=[]
# binary both states for suppressor/enabler definitions
for f in bin_features:
    predicates.append((f'{f}=1', df[f].eq(1).values))
    predicates.append((f'{f}=0', df[f].eq(0).values))
# categorical levels with enough support, exclude not_applicable for subtype maybe include lineages
for f in ['lineage','lineage_subtype','culture_type','screen_batch']:
    for lev,n in df[f].value_counts().items():
        if n>=500 and not (f=='lineage_subtype' and lev=='not_applicable'):
            predicates.append((f'{f}={lev}', df[f].eq(lev).values))
# continuous high/low quartiles
for f in cont_features:
    q25=df[f].quantile(.25); q75=df[f].quantile(.75)
    predicates.append((f'{f}>=Q75({q75:.3g})', df[f].ge(q75).values))
    predicates.append((f'{f}<=Q25({q25:.3g})', df[f].le(q25).values))

def test_mask(y,mask):
    n=int(mask.sum()); n0=len(mask)-n
    if n<500 or n0<500: return None
    a=y[mask]; b=y[~mask]
    e=float(a.mean()-b.mean())
    t,p=stats.ttest_ind(a,b,equal_var=False)
    return e,float(p),n,float(a.mean()),float(b.mean())

print('\\nSystematic subgroup screen top negative single/pair/triple')
for dep in deps:
    y=df[dep].values
    singles=[]
    for name,mask in predicates:
        r=test_mask(y,mask)
        if r: singles.append((r[0],r[1],r[2],name,r[3],r[4]))
    top_s=sorted(singles)[:8]
    pair_candidates=top_s[:12] + sorted(singles, key=lambda x: x[1])[:12]
    # unique masks by name
    cand_names=[]; cand=[]
    for rec in pair_candidates:
        nm=rec[3]
        if nm not in cand_names:
            cand_names.append(nm)
            cand.append(next(p for p in predicates if p[0]==nm))
    pairs_out=[]
    for (n1,m1),(n2,m2) in itertools.combinations(cand,2):
        # skip contradiction same variable both states / same categorical var maybe parse prefix before =
        v1=n1.split('=')[0].split('>')[0].split('<')[0]
        v2=n2.split('=')[0].split('>')[0].split('<')[0]
        if v1==v2: continue
        r=test_mask(y,m1 & m2)
        if r: pairs_out.append((r[0],r[1],r[2],n1+' & '+n2,r[3],r[4]))
    top_p=sorted(pairs_out)[:8]
    # triples from top pair components plus top singles
    triple_out=[]
    cand2=[]
    for rec in (top_p[:8]+top_s[:8]):
        for part in rec[3].split(' & '):
            if part not in [x[0] for x in cand2]:
                cand2.append(next(p for p in predicates if p[0]==part))
    for combo in itertools.combinations(cand2,3):
        names=[c[0] for c in combo]
        vars_=[n.split('=')[0].split('>')[0].split('<')[0] for n in names]
        if len(set(vars_))<3: continue
        mask=combo[0][1] & combo[1][1] & combo[2][1]
        r=test_mask(y,mask)
        if r: triple_out.append((r[0],r[1],r[2],' & '.join(names),r[3],r[4]))
    top_t=sorted(triple_out)[:8]
    print('\\n'+dep)
    print('Singles')
    for e,p,n,name,m,rest in top_s[:5]: print(f'{name:80s} diff={e: .4f} p={p:.1e} n={n} mean={m:.4f} rest={rest:.4f}')
    print('Pairs')
    for e,p,n,name,m,rest in top_p[:5]: print(f'{name:80s} diff={e: .4f} p={p:.1e} n={n} mean={m:.4f} rest={rest:.4f}')
    print('Triples')
    for e,p,n,name,m,rest in top_t[:5]: print(f'{name:80s} diff={e: .4f} p={p:.1e} n={n} mean={m:.4f} rest={rest:.4f}')
