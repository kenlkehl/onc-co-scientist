import json
from pathlib import Path

import pandas as pd
from scipy import stats
import statsmodels.formula.api as smf

base = Path('.')
df = pd.read_parquet(base / 'dataset.parquet')

q = {
    'wnt_q75': float(df['wnt_activity_score'].quantile(0.75)),
    'ascl2_q75': float(df['rnaseq_ASCL2_log2_tpm'].quantile(0.75)),
    'growth_q75': float(df['growth_rate_doublings_per_day'].quantile(0.75)),
    'myc_expr_q75': float(df['rnaseq_MYC_log2_tpm'].quantile(0.75)),
    'cn8q_q75': float(df['copy_number_8q24'].quantile(0.75)),
    'cas9_q75': float(df['cas9_activity_score'].quantile(0.75)),
}

def ptxt(p):
    if p == 0 or p < 1e-300:
        return 'p<1e-300'
    if p < 0.001:
        return f'p={p:.2e}'
    return f'p={p:.3g}'

def fnum(x, nd=4):
    return f'{x:.{nd}f}'

def welch_mask(dep, mask, group_label, rest_label='all other lines'):
    a = df.loc[mask, dep]
    b = df.loc[~mask, dep]
    t, p = stats.ttest_ind(a, b, equal_var=False)
    effect = float(a.mean() - b.mean())
    return {
        'effect': effect,
        'p': float(p),
        'n_group': int(len(a)),
        'n_rest': int(len(b)),
        'mean_group': float(a.mean()),
        'mean_rest': float(b.mean()),
        'summary': f'{group_label}: mean {dep}={a.mean():.4f} (n={len(a)}) vs {rest_label} mean={b.mean():.4f}; difference={effect:.4f}; Welch t-test {ptxt(float(p))}.'
    }

def welch_two_masks(dep, mask_a, mask_b, label_a, label_b):
    a = df.loc[mask_a, dep]
    b = df.loc[mask_b, dep]
    t, p = stats.ttest_ind(a, b, equal_var=False)
    effect = float(a.mean() - b.mean())
    return {
        'effect': effect,
        'p': float(p),
        'n_group': int(len(a)),
        'n_reference': int(len(b)),
        'mean_group': float(a.mean()),
        'mean_reference': float(b.mean()),
        'summary': f'{label_a}: mean {dep}={a.mean():.4f} (n={len(a)}) vs {label_b} mean={b.mean():.4f} (n={len(b)}); difference={effect:.4f}; Welch t-test {ptxt(float(p))}.'
    }

def ols_term(name, formula, term, extra_summary=''):
    m = smf.ols(formula, data=df).fit()
    coef = float(m.params[term])
    p = float(m.pvalues[term])
    r2 = float(m.rsquared)
    tail = f' {extra_summary}' if extra_summary else ''
    return {
        'effect': coef,
        'p': p,
        'r2': r2,
        'summary': f'{name}: OLS term "'`{term}` coefficient={coef:.5f} on the dependency score scale, {ptxt(p)}, model R''^2={r2:.3f}.{tail}'"',
        'formula': formula,
        'term': term,
    }

def analysis(hids, result, method, code=None, extra=None):
    rec = {
        'hypothesis_ids': hids,
        'method': method,
        'result_summary': result['summary'],
        'p_value': result['p'],
        'effect_estimate': result['effect'],
        'significant': bool(result['p'] < 0.05),
    }
    if code:
        rec['code'] = code
    if extra:
        rec.update(extra)
    for k in ['n_group', 'n_rest', 'n_reference', 'mean_group', 'mean_rest', 'mean_reference', 'r2', 'formula', 'term']:
        if k in result:
            rec[k] = result[k]
    return rec

# Common masks
m = {}
m['braf'] = df['braf_v600e'].eq(1)
m['egfr_amp'] = df['egfr_amplification'].eq(1)
m['erbb2_amp'] = df['erbb2_amplification'].eq(1)
m['kras'] = df['kras_mutation'].eq(1)
m['nf1'] = df['nf1_loss'].eq(1)
m['skin'] = df['lineage'].eq('skin')
m['brain'] = df['lineage'].eq('brain')
m['breast_gastric'] = df['lineage'].isin(['breast', 'gastric'])
m['pancreatic'] = df['lineage'].eq('pancreatic')
m['colorectal'] = df['lineage'].eq('colorectal')
m['apc'] = df['apc_mutation'].eq(1)
m['smad4'] = df['smad4_loss'].eq(1)
m['smad4_intact'] = df['smad4_loss'].eq(0)
m['high_wnt'] = df['wnt_activity_score'].ge(q['wnt_q75'])
m['high_ascl2'] = df['rnaseq_ASCL2_log2_tpm'].ge(q['ascl2_q75'])
m['high_growth'] = df['growth_rate_doublings_per_day'].ge(q['growth_q75'])
m['high_myc_expr'] = df['rnaseq_MYC_log2_tpm'].ge(q['myc_expr_q75'])
m['high_cn8q'] = df['copy_number_8q24'].ge(q['cn8q_q75'])
m['myc_amp'] = df['myc_amplification'].eq(1)
m['stk11_intact'] = df['stk11_loss'].eq(0)
m['lung'] = df['lineage'].eq('lung')

kif18a_complete = m['colorectal'] & m['apc'] & m['high_wnt'] & m['smad4_intact']
kif18a_complete_ascl2 = kif18a_complete & m['high_ascl2']
rpl11_complete = m['myc_amp'] & m['high_growth'] & m['high_myc_expr'] & m['high_cn8q']
dhx9_complete = m['high_growth'] & m['high_myc_expr']
polr2a_complete = m['high_growth'] & m['lung'] & m['high_cn8q']
tmed10_complete = m['high_growth'] & m['nf1'] & m['stk11_intact']

iterations = []

iterations.append({
    'index': 1,
    'proposed_hypotheses': [
        {'id': 'h1', 'text': 'Cell lines with "'`braf_v600e=1` have more negative `dependency_BRAF` scores than cell lines with `braf_v600e=0`.'"', 'kind': 'novel'},
        {'id': 'h2', 'text': 'Cell lines with "'`egfr_amplification=1` have more negative `dependency_EGFR` scores than cell lines with `egfr_amplification=0`.'"', 'kind': 'novel'},
        {'id': 'h3', 'text': 'Cell lines with "'`erbb2_amplification=1` have more negative `dependency_ERBB2` scores than cell lines with `erbb2_amplification=0`.'"', 'kind': 'novel'},
        {'id': 'h4', 'text': 'Cell lines with "'`kras_mutation=1` have more negative `dependency_KRAS` scores than cell lines with `kras_mutation=0`.'"', 'kind': 'novel'},
    ],
    'analyses': [
        analysis(['h1'], welch_mask('dependency_BRAF', m['braf'], '"'`braf_v600e=1`'"'), 'Welch two-sample t-test'),
        analysis(['h2'], welch_mask('dependency_EGFR', m['egfr_amp'], '"'`egfr_amplification=1`'"'), 'Welch two-sample t-test'),
        analysis(['h3'], welch_mask('dependency_ERBB2', m['erbb2_amp'], '"'`erbb2_amplification=1`'"'), 'Welch two-sample t-test'),
        analysis(['h4'], welch_mask('dependency_KRAS', m['kras'], '"'`kras_mutation=1`'"'), 'Welch two-sample t-test'),
    ],
    'update': 'Matched oncogene-driver dependencies were strongly supported, motivating lineage-interaction tests to distinguish true subgroup specificity from driver enrichment.',
})

iterations.append({
    'index': 2,
    'proposed_hypotheses': [
