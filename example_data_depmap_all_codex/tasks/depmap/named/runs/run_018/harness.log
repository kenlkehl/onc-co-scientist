cont = ['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cat = ['lineage','lineage_subtype','culture_type','screen_batch']

# Derived flags used in hypotheses.
thresholds = {}
for c in ['wnt_activity_score','rnaseq_MYC_log2_tpm','copy_number_8q24','growth_rate_doublings_per_day','rnaseq_ASCL2_log2_tpm']:
    thresholds[c+'_q75'] = float(df[c].quantile(.75))
    df[c+'_high_q75'] = (df[c] >= df[c].quantile(.75)).astype(int)
for flag, vals in {
    'colorectal': ['colorectal'],
    'skin': ['skin'],
    'brain': ['brain'],
    'breast_or_gastric': ['breast','gastric'],
    'pancreatic_or_colorectal': ['pancreatic','colorectal'],
}.items():
    df[flag] = df['lineage'].isin(vals).astype(int)

base = 'C(lineage)+C(culture_type)+C(screen_batch)+media_serum_pct+cas9_activity_score+growth_rate_doublings_per_day'
base_no_lin = 'C(culture_type)+C(screen_batch)+media_serum_pct+cas9_activity_score+growth_rate_doublings_per_day'

def fnum(x):
    x = float(x)
    if np.isnan(x):
        return None
    if abs(x) < 1e-300:
        return 0.0
    return x

def ols_coef(y, term, formula):
    m = smf.ols(formula, df).fit()
    return fnum(m.params[term]), fnum(m.pvalues[term]), float(m.rsquared)

def tdiff(y, mask):
    a = df.loc[mask, y]
    b = df.loc[~mask, y]
    t, p = stats.ttest_ind(a, b, equal_var=False)
    return {
        'n_in': int(mask.sum()),
        'mean_in': fnum(a.mean()),
        'mean_out': fnum(b.mean()),
        'effect': fnum(a.mean() - b.mean()),
        'p': fnum(p),
    }

def tdiff_between(y, mask_a, mask_b):
    a = df.loc[mask_a, y]
    b = df.loc[mask_b, y]
    t, p = stats.ttest_ind(a, b, equal_var=False)
    return {
        'n_a': int(mask_a.sum()),
        'n_b': int(mask_b.sum()),
        'mean_a': fnum(a.mean()),
        'mean_b': fnum(b.mean()),
        'effect': fnum(a.mean() - b.mean()),
        'p': fnum(p),
    }

# Core model results.
main_results = {}
for key, y, x in [
    ('BRAF_main','dependency_BRAF','braf_v600e'),
    ('EGFR_main','dependency_EGFR','egfr_amplification'),
    ('ERBB2_main','dependency_ERBB2','erbb2_amplification'),
    ('KRAS_main','dependency_KRAS','kras_mutation'),
    ('RIT1_main','dependency_RIT1','nf1_loss'),
    ('TMED10_growth','dependency_TMED10','growth_rate_doublings_per_day'),
    ('POLR2A_growth','dependency_POLR2A','growth_rate_doublings_per_day'),
]:
    coef, p, r2 = ols_coef(y, x, f'{y} ~ {x} + {base}')
    main_results[key] = (coef, p, r2)

# Specific interactions.
interaction_specs = {
    'BRAF_skin': ('dependency_BRAF','braf_v600e','skin'),
    'EGFR_brain': ('dependency_EGFR','egfr_amplification','brain'),
    'ERBB2_breast_gastric': ('dependency_ERBB2','erbb2_amplification','breast_or_gastric'),
    'KRAS_pancreatic_colorectal': ('dependency_KRAS','kras_mutation','pancreatic_or_colorectal'),
    'RIT1_brain': ('dependency_RIT1','nf1_loss','brain'),
}
interactions = {}
for key, (y, x, z) in interaction_specs.items():
    term = f'{x}:{z}'
    coef, p, r2 = ols_coef(y, term, f'{y} ~ {x} * {z} + {base_no_lin}')
    interactions[key] = (coef, p, r2)

# KIF18A models.
kif_apc = ols_coef('dependency_KIF18A', 'apc_mutation', f'dependency_KIF18A ~ apc_mutation + {base}')
kif_wnt = ols_coef('dependency_KIF18A', 'wnt_activity_score', f'dependency_KIF18A ~ wnt_activity_score + {base}')
col = df['lineage'].eq('colorectal')
core = col & df['apc_mutation'].eq(1) & df['wnt_activity_score_high_q75'].eq(1) & df['smad4_loss'].eq(0)
core_smad_loss = col & df['apc_mutation'].eq(1) & df['wnt_activity_score_high_q75'].eq(1) & df['smad4_loss'].eq(1)
core_smad_intact = col & df['apc_mutation'].eq(1) & df['wnt_activity_score_high_q75'].eq(1) & df['smad4_loss'].eq(0)
kif_core = tdiff('dependency_KIF18A', core)
kif_smad = tdiff_between('dependency_KIF18A', core_smad_loss, core_smad_intact)
col_df = df[df['lineage'].eq('colorectal')].copy()
kif_model = smf.ols('dependency_KIF18A ~ apc_mutation * wnt_activity_score_high_q75 * smad4_loss + media_serum_pct+cas9_activity_score+growth_rate_doublings_per_day+C(culture_type)+C(screen_batch)', col_df).fit()
kif_apc_wnt_inter = (fnum(kif_model.params['apc_mutation:wnt_activity_score_high_q75']), fnum(kif_model.pvalues['apc_mutation:wnt_activity_score_high_q75']))
kif_threeway = (fnum(kif_model.params['apc_mutation:wnt_activity_score_high_q75:smad4_loss']), fnum(kif_model.pvalues['apc_mutation:wnt_activity_score_high_q75:smad4_loss']))

# RPL11 and DHX9 refinement.
rpl_cn_high = tdiff('dependency_RPL11', df['copy_number_8q24_high_q75'].eq(1))
rpl_myc_amp = tdiff('dependency_RPL11', df['myc_amplification'].eq(1))
rpl_cn = ols_coef('dependency_RPL11', 'copy_number_8q24', f'dependency_RPL11 ~ copy_number_8q24 + {base}')
rpl_adj_cn = ols_coef('dependency_RPL11', 'copy_number_8q24', f'dependency_RPL11 ~ myc_amplification + copy_number_8q24 + rnaseq_MYC_log2_tpm + {base}')
rpl_adj_amp = ols_coef('dependency_RPL11', 'myc_amplification', f'dependency_RPL11 ~ myc_amplification + copy_number_8q24 + rnaseq_MYC_log2_tpm + {base}')

dhx_myc_high = tdiff('dependency_DHX9', df['rnaseq_MYC_log2_tpm_high_q75'].eq(1))
dhx_expr = ols_coef('dependency_DHX9', 'rnaseq_MYC_log2_tpm', f'dependency_DHX9 ~ rnaseq_MYC_log2_tpm + {base}')
dhx_adj_expr = ols_coef('dependency_DHX9', 'rnaseq_MYC_log2_tpm', f'dependency_DHX9 ~ myc_amplification + rnaseq_MYC_log2_tpm + copy_number_8q24 + {base}')
dhx_adj_amp = ols_coef('dependency_DHX9', 'myc_amplification', f'dependency_DHX9 ~ myc_amplification + rnaseq_MYC_log2_tpm + copy_number_8q24 + {base}')

pol_growth_high = tdiff('dependency_POLR2A', df['growth_rate_doublings_per_day_high_q75'].eq(1))
tmed_growth_high = tdiff('dependency_TMED10', df['growth_rate_doublings_per_day_high_q75'].eq(1))
tmed_nf1 = tdiff('dependency_TMED10', df['nf1_loss'].eq(1))

# Systematic heterogeneity screen: one-feature indicators with binary, categorical levels, and continuous quartiles.
indicators = []
for x in binary:
    indicators.append((f'{x}=1', df[x].astype(bool)))
for x in cat:
    for lev in df[x].value_counts().index:
        indicators.append((f'{x}={lev}', df[x].eq(lev)))
for x in cont:
    q25 = df[x].quantile(.25)
    q75 = df[x].quantile(.75)
    indicators.append((f'{x}>=Q75({q75:.3g})', df[x] >= q75))
    indicators.append((f'{x}<=Q25({q25:.3g})', df[x] <= q25))

screen = {}
for y in outcomes:
    rows = []
    for name, mask in indicators:
        n = int(mask.sum())
