import pandas as pd, numpy as np
from scipy import stats
import statsmodels.formula.api as smf

pd.set_option('display.max_rows', 200)
df=pd.read_parquet('dataset.parquet')
outcomes=[c for c in df.columns if c.startswith('dependency_')]
binary=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cat=['lineage','lineage_subtype','culture_type','screen_batch']
print('Unadjusted binary differences (feature=1 minus 0), sorted by abs effect per outcome top 10')
for y in outcomes:
    rows=[]
    for x in binary:
        a=df.loc[df[x]==1,y]; b=df.loc[df[x]==0,y]
        t,p=stats.ttest_ind(a,b,equal_var=False)
        rows.append((x,a.mean()-b.mean(),p,a.mean(),b.mean(),len(a)))
    rows=sorted(rows,key=lambda r:abs(r[1]),reverse=True)[:10]
    print('\\n',y)
    for r in rows:
        print('%-22s diff=% .4f p=%.3g mean1=%.3f mean0=%.3f n1=%d'%r)
print('\\nContinuous correlations top 10 by abs r per outcome')
for y in outcomes:
    rows=[]
    for x in cont:
        r,p=stats.pearsonr(df[x],df[y])
        slope,inter,r2,p2,se=stats.linregress(df[x],df[y])
        rows.append((x,r,slope,p))
    rows=sorted(rows,key=lambda r:abs(r[1]),reverse=True)[:10]
    print('\\n',y)
    for x,r,s,p in rows:
        print('%-30s r=% .4f slope=% .4f p=%.3g'%(x,r,s,p))
print('\\nLineage means: min max per outcome')
for y in outcomes:
    means=df.groupby('lineage')[y].mean().sort_values()
    print('\\n',y)
    print(means.to_string())
