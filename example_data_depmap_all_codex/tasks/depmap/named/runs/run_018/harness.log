cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
cat=['lineage','lineage_subtype','culture_type','screen_batch']
indicators=[]
for x in binary:
    indicators.append((x+'=1', df[x].astype(bool)))
for x in cat:
    for lev,n in df[x].value_counts().items():
        indicators.append((f'{x}={lev}', df[x].eq(lev)))
for x in cont:
    q25=df[x].quantile(.25); q75=df[x].quantile(.75)
    indicators.append((f'{x}>=Q75({q75:.3g})', df[x]>=q75))
    indicators.append((f'{x}<=Q25({q25:.3g})', df[x]<=q25))
print('candidate indicators', len(indicators))
for y in outcomes:
    rows=[]
    for name,mask in indicators:
        n=int(mask.sum()); n0=len(mask)-n
        if n<500 or n0<500: continue
        a=df.loc[mask,y]; b=df.loc[~mask,y]
        diff=a.mean()-b.mean()
        t,p=stats.ttest_ind(a,b,equal_var=False)
        rows.append([name,n,diff,p,a.mean(),b.mean()])
    ps=[r[3] for r in rows]
    qs=multipletests(ps, method='fdr_bh')[1]
    for r,q in zip(rows,qs): r.append(q)
    neg=sorted(rows,key=lambda r:r[2])[:8]
    absrows=sorted(rows,key=lambda r:abs(r[2]), reverse=True)[:8]
    print('\\n###',y,'top negative subgroup mean differences')
    for name,n,diff,p,m1,m0,q in neg:
        print(f'{name:45s} n={n:5d} diff={diff: .4f} mean_in={m1:.3f} mean_out={m0:.3f} p={p:.3g} q={q:.3g}')
    print('top abs:')
    for name,n,diff,p,m1,m0,q in absrows:
        print(f'{name:45s} n={n:5d} diff={diff: .4f} p={p:.3g} q={q:.3g}')
