    if significant is None:
        significant = (p is not None and p < 0.05)
    rec = {'hypothesis_ids': hids, 'result_summary': summary, 'p_value': fnum(p) if p is not None else None, 'effect_estimate': fnum(effect) if effect is not None else None, 'significant': bool(significant) if significant is not None else None}
    if code:
        rec['code'] = code
    rec.update(extra)
    return rec

