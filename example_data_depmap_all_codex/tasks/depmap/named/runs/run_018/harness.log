import pandas as pd, numpy as np
from scipy import stats
import statsmodels.formula.api as smf
import statsmodels.api as sm
from statsmodels.stats.anova import anova_lm

df=pd.read_parquet('dataset.parquet')
# add useful flags
q = {c: df[c].quantile(.75) for c in ['wnt_activity_score','rnaseq_MYC_log2_tpm','copy_number_8q24','growth_rate_doublings_per_day','cas9_activity_score','rnaseq_ASCL2_log2_tpm']}
for c,v in q.items(): df[c+'_high_q75']=(df[c]>=v).astype(int)
q25 = {c: df[c].quantile(.25) for c in ['wnt_activity_score','rnaseq_MYC_log2_tpm','growth_rate_doublings_per_day']}
for c,v in q25.items(): df[c+'_low_q25']=(df[c]<=v).astype(int)
df['colorectal']=(df.lineage=='colorectal').astype(int)
df['skin']=(df.lineage=='skin').astype(int)
df['brain']=(df.lineage=='brain').astype(int)
df['breast']=(df.lineage=='breast').astype(int)
df['gastric']=(df.lineage=='gastric').astype(int)
df['pancreatic']=(df.lineage=='pancreatic').astype(int)
df['luminal']=(df.lineage_subtype=='luminal').astype(int)
df['her2_enriched']=(df.lineage_subtype=='her2_enriched').astype(int)
base = 'C(lineage)+C(culture_type)+C(screen_batch)+media_serum_pct+cas9_activity_score+growth_rate_doublings_per_day'
print('Q75 thresholds:', q)

def fit_print(y,x,extra='', label=''):
    f=f'{y} ~ {x} + {base}' + ((' + '+extra) if extra else '')
    m=smf.ols(f,df).fit()
    print('\\nMODEL', label or f'{y}~{x}')
    print('n',int(m.nobs),'r2',m.rsquared)
    for term in x.split('+'):
        term=term.strip()
        if term in m.params:
            print(term,'coef',m.params[term],'p',m.pvalues[term])
    return m

main=[('dependency_BRAF','braf_v600e'),('dependency_EGFR','egfr_amplification'),('dependency_ERBB2','erbb2_amplification'),('dependency_KRAS','kras_mutation'),('dependency_RIT1','nf1_loss'),('dependency_DHX9','myc_amplification'),('dependency_RPL11','myc_amplification'),('dependency_POLR2A','growth_rate_doublings_per_day'),('dependency_TMED10','growth_rate_doublings_per_day')]
for y,x in main:
    fit_print(y,x)

print('\\nKIF18A models')
for x in ['colorectal','apc_mutation','wnt_activity_score','rnaseq_ASCL2_log2_tpm','smad4_loss']:
    m=smf.ols(f'dependency_KIF18A ~ {x} + {base}',df).fit()
    print(x, 'coef', m.params.get(x), 'p', m.pvalues.get(x), 'r2',m.rsquared)
# Multi-feature KIF18A model
m=smf.ols(f'dependency_KIF18A ~ colorectal + apc_mutation + wnt_activity_score + rnaseq_ASCL2_log2_tpm + smad4_loss + colorectal:apc_mutation + apc_mutation:smad4_loss + {base}',df).fit()
print('\\nKIF18A multivariable interaction')
for term in ['colorectal','apc_mutation','wnt_activity_score','rnaseq_ASCL2_log2_tpm','smad4_loss','colorectal:apc_mutation','apc_mutation:smad4_loss']:
    print(term,'coef',m.params.get(term),'p',m.pvalues.get(term))
print('r2',m.rsquared)

# Interactions with lineage global F: compare reduced/full for primary alteration
def interaction_global(y, x, withvar):
    reduced=smf.ols(f'{y} ~ {x} + C({withvar}) + C(culture_type)+C(screen_batch)+media_serum_pct+cas9_activity_score+growth_rate_doublings_per_day',df).fit()
    full=smf.ols(f'{y} ~ {x} * C({withvar}) + C(culture_type)+C(screen_batch)+media_serum_pct+cas9_activity_score+growth_rate_doublings_per_day',df).fit()
    tab=anova_lm(reduced, full)
    print('\\nINTERACTION', y, x, 'by', withvar)
    print(tab.to_string())
interaction_global('dependency_BRAF','braf_v600e','lineage')
interaction_global('dependency_EGFR','egfr_amplification','lineage')
interaction_global('dependency_ERBB2','erbb2_amplification','lineage')
interaction_global('dependency_KRAS','kras_mutation','lineage')
interaction_global('dependency_RIT1','nf1_loss','lineage')

# Per lineage feature effects for primary alterations
for y,x in [('dependency_BRAF','braf_v600e'),('dependency_EGFR','egfr_amplification'),('dependency_ERBB2','erbb2_amplification'),('dependency_KRAS','kras_mutation'),('dependency_RIT1','nf1_loss')]:
    print('\\nPER-LINEAGE',y,x)
    for lin,g in df.groupby('lineage'):
        if g[x].nunique()<2 or g[x].sum()<50 or (len(g)-g[x].sum())<50:
            continue
        a=g.loc[g[x]==1,y]; b=g.loc[g[x]==0,y]
        t,p=stats.ttest_ind(a,b,equal_var=False)
        print(f'{lin:14s} n1={len(a):5d} n0={len(b):5d} diff={a.mean()-b.mean(): .4f} mean1={a.mean():.3f} mean0={b.mean():.3f} p={p:.3g}')

# Specific subgroup definitions. Compare subgroup vs complement and within key group.
subgroups={
 'KIF18A_colorectal_apc_wnt_high_smad4_intact': (df.colorectal.eq(1)&df.apc_mutation.eq(1)&df.wnt_activity_score_high_q75.eq(1)&df.smad4_loss.eq(0), 'dependency_KIF18A'),
 'KIF18A_colorectal_apc_smad4_loss': (df.colorectal.eq(1)&df.apc_mutation.eq(1)&df.smad4_loss.eq(1), 'dependency_KIF18A'),
 'RPL11_myc_amp_cn8q24_high': (df.myc_amplification.eq(1)&df.copy_number_8q24_high_q75.eq(1), 'dependency_RPL11'),
 'DHX9_myc_amp_myc_expr_high': (df.myc_amplification.eq(1)&df.rnaseq_MYC_log2_tpm_high_q75.eq(1), 'dependency_DHX9'),
 'POLR2A_growth_high': (df.growth_rate_doublings_per_day_high_q75.eq(1), 'dependency_POLR2A'),
 'TMED10_growth_high': (df.growth_rate_doublings_per_day_high_q75.eq(1), 'dependency_TMED10'),
}
print('\\nSPECIFIC SUBGROUPS vs complement')
for name,(mask,y) in subgroups.items():
    a=df.loc[mask,y]; b=df.loc[~mask,y]
    t,p=stats.ttest_ind(a,b,equal_var=False)
    print(f'{name:45s} y={y} n={len(a):5d} diff={a.mean()-b.mean(): .4f} mean_in={a.mean():.4f} mean_out={b.mean():.4f} p={p:.3g}')

# KIF18A combo table
print('\\nKIF18A colorectal/APC/WNT/SMAD4 table')
for smad in [0,1]:
    for apc in [0,1]:
        for wnt in [0,1]:
            mask=(df.colorectal.eq(1)&df.apc_mutation.eq(apc)&df.wnt_activity_score_high_q75.eq(wnt)&df.smad4_loss.eq(smad))
            if mask.sum()>0:
                print('colorectal apc',apc,'wnt_hi',wnt,'smad4_loss',smad,'n',int(mask.sum()),'mean',df.loc[mask,'dependency_KIF18A'].mean())

# RPL11 combo table
print('\\nRPL11 MYC amp/cn8q24 table')
for amp in [0,1]:
    for cn in [0,1]:
        mask=(df.myc_amplification.eq(amp)&df.copy_number_8q24_high_q75.eq(cn))
        print('myc_amp',amp,'cn8q24_hi',cn,'n',int(mask.sum()),'mean',df.loc[mask,'dependency_RPL11'].mean())

# DHX9 table
print('\\nDHX9 MYC amp/expr high table')
for amp in [0,1]:
    for expr in [0,1]:
        mask=(df.myc_amplification.eq(amp)&df.rnaseq_MYC_log2_tpm_high_q75.eq(expr))
        print('myc_amp',amp,'myc_expr_hi',expr,'n',int(mask.sum()),'mean',df.loc[mask,'dependency_DHX9'].mean())
