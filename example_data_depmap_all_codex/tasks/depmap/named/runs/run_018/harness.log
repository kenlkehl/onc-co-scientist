        t, p = stats.ttest_ind(a, b, equal_var=False)
        rows.append({'indicator': name, 'n': n, 'effect': fnum(a.mean()-b.mean()), 'mean_in': fnum(a.mean()), 'mean_out': fnum(b.mean()), 'p': fnum(p)})
    qs = multipletests([r['p'] for r in rows], method='fdr_bh')[1]
    for r, qv in zip(rows, qs):
