import struct, math, json, statistics
from pathlib import Path
from collections import defaultdict, Counter
# --- minimal parquet reader for this Arrow/Snappy/dictionary file ---
CT_STOP=0; CT_TRUE=1; CT_FALSE=2; CT_BYTE=3; CT_I16=4; CT_I32=5; CT_I64=6; CT_DOUBLE=7; CT_BINARY=8; CT_LIST=9; CT_SET=10; CT_MAP=11; CT_STRUCT=12
def zz(n): return (n>>1)"'^-(n&1)
class Compact:
    def __init__(self,b,i=0): self.b=b; self.i=i
    def rb(self): v=self.b[self.i]; self.i+=1; return v
    def rv(self):
        s=0; r=0
        while True:
            x=self.rb(); r|=(x&127)<<s
            if not x&128: return r
            s+=7
    def ri(self): return zz(self.rv())
    def rd(self): v=struct.unpack_from('"'<d', self.b, self.i)[0]; self.i+=8; return v
    def bin(self):
        n=self.rv(); x=self.b[self.i:self.i+n]; self.i+=n
        try: return x.decode('utf-8')
        except UnicodeDecodeError: return bytes(x)
    def lh(self):
        x=self.rb(); n=x>>4; t=x&15
        if n==15: n=self.rv()
        return n,t
    def val(self,t):
        if t==CT_TRUE: return True
        if t==CT_FALSE: return False
        if t==CT_BYTE: return struct.unpack('b', bytes([self.rb()]))[0]
        if t in (CT_I16, CT_I32, CT_I64): return self.ri()
        if t==CT_DOUBLE: return self.rd()
        if t==CT_BINARY: return self.bin()
        if t==CT_STRUCT: return self.struct()
        if t in (CT_LIST, CT_SET):
            n,et=self.lh(); return [self.val(et) for _ in range(n)]
        if t==CT_MAP:
            n=self.rv()
            if n==0: return {}
            ktvt=self.rb(); kt=ktvt>>4; vt=ktvt&15
            return {self.val(kt): self.val(vt) for _ in range(n)}
        raise ValueError(t)
    def struct(self):
        out={}; last=0
        while True:
            h=self.rb(); t=h&15; d=h>>4
            if t==CT_STOP: break
            fid=last+d if d else self.ri(); last=fid; out[fid]=self.val(t)
        return out

def snappy_decode(data):
    i=0; shift=0; expected=0
    while True:
        x=data[i]; i+=1; expected |= (x&127)<<shift
        if not x&128: break
        shift += 7
    out=bytearray(); n=len(data)
    while i<n:
        token=data[i]; i+=1; tag=token&3
        if tag==0:
            l=token>>2
            if l<60: l+=1
            else:
                nb=l-59; l=int.from_bytes(data[i:i+nb], 'little')+1; i+=nb
            out.extend(data[i:i+l]); i+=l
        elif tag==1:
            l=((token>>2)&7)+4; off=((token & 0xE0)<<3) | data[i]; i+=1
            start=len(out)-off
            for k in range(l): out.append(out[start+k])
        elif tag==2:
            l=(token>>2)+1; off=int.from_bytes(data[i:i+2], 'little'); i+=2
            start=len(out)-off
            for k in range(l): out.append(out[start+k])
        else:
            l=(token>>2)+1; off=int.from_bytes(data[i:i+4], 'little'); i+=4
            start=len(out)-off
            for k in range(l): out.append(out[start+k])
    if len(out)"'!=expected:
        raise ValueError(f'"'snappy length {len(out)} "'!= {expected}'"')
    return bytes(out)

def read_varint_buf(buf, pos):
    s=0; r=0
    while True:
        x=buf[pos]; pos+=1; r|=(x&127)<<s
        if not x&128: return r,pos
        s+=7

def decode_rle_bitpacked(buf, pos, bit_width, nvals):
    vals=[]; n=len(buf); byte_width=(bit_width+7)//8
    while len(vals)<nvals and pos<n:
        header,pos=read_varint_buf(buf,pos)
        if header & 1:
            groups=header>>1; total=groups*8; bits=0; bitpos=0
            nbytes=(total*bit_width + 7)//8
            chunk=buf[pos:pos+nbytes]; pos+=nbytes
            # load chunk as little-endian integer for simple extraction
            acc=int.from_bytes(chunk, 'little')
            mask=(1<<bit_width)-1 if bit_width else 0
            for j in range(total):
                if len(vals)>=nvals: break
                vals.append((acc >> (j*bit_width)) & mask)
        else:
            run=header>>1
            v=int.from_bytes(buf[pos:pos+byte_width], 'little') if byte_width else 0
            pos+=byte_width
            take=min(run, nvals-len(vals))
            vals.extend([v]*take)
    if len(vals)"'!=nvals:
        raise ValueError(f'"'needed {nvals}, got {len(vals)}, bw {bit_width}')
    return vals,pos

