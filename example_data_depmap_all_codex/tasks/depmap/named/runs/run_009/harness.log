def groupdiff(mask,y):
 n=len(y); n1=sum(1 for v in mask if v); n0=n-n1
 s1=s0=ss1=ss0=0.0
 for m,v in zip(mask,y):
  if m: s1+=v; ss1+=v*v
  else: s0+=v; ss0+=v*v
