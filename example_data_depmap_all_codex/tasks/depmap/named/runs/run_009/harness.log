import struct, json
from pathlib import Path

CT_STOP=0; CT_TRUE=1; CT_FALSE=2; CT_BYTE=3; CT_I16=4; CT_I32=5; CT_I64=6; CT_DOUBLE=7; CT_BINARY=8; CT_LIST=9; CT_SET=10; CT_MAP=11; CT_STRUCT=12

def zz(n): return (n >> 1) "'^ -(n & 1)
class Compact:
    def __init__(self,b): self.b=b; self.i=0
    def read_byte(self): v=self.b[self.i]; self.i+=1; return v
    def read_varint(self):
        shift=0; res=0
        while True:
            x=self.read_byte(); res |= (x & 0x7f) << shift
            if not (x & 0x80): break
            shift += 7
        return res
    def read_i16(self): return zz(self.read_varint())
    def read_i32(self): return zz(self.read_varint())
    def read_i64(self): return zz(self.read_varint())
    def read_double(self):
        v=struct.unpack_from('"'<d', self.b, self.i)[0]; self.i+=8; return v
    def read_binary(self):
        n=self.read_varint(); s=self.b[self.i:self.i+n]; self.i+=n
        try: return s.decode('utf-8')
        except UnicodeDecodeError: return bytes(s)
    def read_list_header(self):
        x=self.read_byte(); size=x>>4; et=x&0xf
        if size==15: size=self.read_varint()
        return size, et
    def read_value(self, ctype):
        if ctype==CT_TRUE: return True
        if ctype==CT_FALSE: return False
        if ctype==CT_BYTE: return struct.unpack('b', bytes([self.read_byte()]))[0]
        if ctype==CT_I16: return self.read_i16()
        if ctype==CT_I32: return self.read_i32()
        if ctype==CT_I64: return self.read_i64()
        if ctype==CT_DOUBLE: return self.read_double()
        if ctype==CT_BINARY: return self.read_binary()
        if ctype==CT_STRUCT: return self.read_struct()
        if ctype in (CT_LIST, CT_SET):
            n, et=self.read_list_header(); return [self.read_value(et) for _ in range(n)]
        if ctype==CT_MAP:
            n=self.read_varint()
            if n==0: return {}
            ktvt=self.read_byte(); kt=ktvt>>4; vt=ktvt&0xf
            return {self.read_value(kt): self.read_value(vt) for _ in range(n)}
        raise ValueError(('unknown ctype', ctype, 'at', self.i))
    def skip(self, ctype): self.read_value(ctype)
    def read_struct(self):
        out={}; last=0
        while True:
            h=self.read_byte(); ctype=h&0xf; delta=h>>4
            if ctype==CT_STOP: break
            if delta: fid=last+delta
            else: fid=self.read_i16()
            last=fid
            out[fid]=self.read_value(ctype)
        return out

