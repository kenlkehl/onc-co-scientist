 v1=(ss1-s1*s1/n1)/(n1-1) if n1>1 else 0
 v0=(ss0-s0*s0/n0)/(n0-1) if n0>1 else 0
 eff=m1-m0; se=math.sqrt(v1/n1+v0/n0) if n1>1 and n0>1 else float('inf')
 z=eff/se if se else 0.0; p=math.erfc(abs(z)/math.sqrt(2))
 return dict(n=n1, mean_in=m1, mean_out=m0, effect=eff, z=z, p=max(p,0.0))
