def ana(hids, summary, effect, p, significant=None, method=None, n=None):
    d={\"hypothesis_ids\": hids, \"result_summary\": summary, \"p_value\": p, \"effect_estimate\": effect, \"significant\": (p < 0.05 if significant is None and p is not None else significant)}
    if method: d[\"method\"] = method
    if n is not None: d[\"n_in_subgroup\"] = n
    return d

