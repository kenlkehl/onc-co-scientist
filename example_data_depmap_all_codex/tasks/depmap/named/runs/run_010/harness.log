class Reader {
  constructor(buf, pos=0, end=buf.length){this.buf=buf; this.pos=pos; this.end=end;}
  readVarint(){let shift=0n, result=0n; while(true){const b=this.buf[this.pos++]; result|=BigInt(b&0x7f)<<shift; if((b&0x80)===0) break; shift+=7n;} return result;}
  zig(n){return (n>>1n)"'^(-(n&1n));}
  readI32(){return Number(this.zig(this.readVarint()));}
  readI64(){return this.zig(this.readVarint());}
  readBinary(){const len=Number(this.readVarint()); const s=this.buf.slice(this.pos,this.pos+len); this.pos+=len; return s.toString('"'utf8');}
  readDouble(){const v=this.buf.readDoubleLE(this.pos); this.pos+=8; return v;}
