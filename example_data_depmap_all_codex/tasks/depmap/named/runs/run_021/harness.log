/bin/bash -c "env PYTHONNOUSERSITE=1 python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats

np.set_printoptions(precision=4, suppress=True)
df = pd.read_parquet('dataset.parquet')
outcomes = [c for c in df.columns if c.startswith('dependency_')]
binary = ['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont = ['cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']

# build covariate matrices
def dummies(cols):
    mats=[]; names=[]
    for col in cols:
        dm = pd.get_dummies(df[col].astype(str), prefix=col, drop_first=True, dtype=float)
        mats.append(dm.to_numpy())
        names.extend(dm.columns.tolist())
    return (np.column_stack(mats) if mats else np.empty((len(df),0))), names

def z(s):
    a = df[s].to_numpy(dtype=float)
    return (a - a.mean())/a.std(ddof=0)
base_screen_cat, _ = dummies(['screen_batch','culture_type','media_serum_pct'])
base_screen = np.column_stack([np.ones(len(df)), base_screen_cat, z('cas9_activity_score'), z('growth_rate_doublings_per_day')])
line_dum, _ = dummies(['lineage'])
base_lineage = np.column_stack([base_screen, line_dum])

def ols_coef(y, x, C):
    y = np.asarray(y, float); x = np.asarray(x, float)
    # residualize against C
    beta_y, *_ = np.linalg.lstsq(C, y, rcond=None)
    ry = y - C @ beta_y
    beta_x, *_ = np.linalg.lstsq(C, x, rcond=None)
    rx = x - C @ beta_x
    denom = float(rx @ rx)
    if denom < 1e-12:
        return np.nan, np.nan, np.nan
    coef = float(rx @ ry / denom)
    resid = ry - coef * rx
    dfree = len(y) - C.shape[1] - 1
    sigma2 = float(resid @ resid / dfree)
    se = (sigma2 / denom) ** 0.5
    t = coef / se
    p = float(2 * stats.t.sf(abs(t), dfree))
    return coef, p, se

print('=== adjusted molecular/continuous main effects (base includes lineage + screen/culture/media/cas9/growth) ===')
for ycol in outcomes:
    rows=[]
    y = df[ycol].to_numpy(float)
    for f in binary:
        coef,p,se=ols_coef(y, df[f].to_numpy(float), base_lineage)
        rows.append((abs(coef), coef,p,f,'binary'))
    for f in cont:
        x=z(f)
        coef,p,se=ols_coef(y, x, base_lineage)
        rows.append((abs(coef), coef,p,f,'per_sd'))
    rows.sort(reverse=True)
    print('\\n', ycol)
    for _,coef,p,f,kind in rows[:8]:
        print(f'{f:28s} {kind:8s} coef={coef: .4f} p={p:.3g}')

print('\\n=== adjusted lineage/subtype effects (base screen only) ===')
for ycol in outcomes:
    rows=[]; y=df[ycol].to_numpy(float)
    for val in sorted(df['lineage'].unique()):
        coef,p,se=ols_coef(y, (df['lineage']==val).astype(float).to_numpy(), base_screen)
        rows.append((abs(coef), coef,p,'lineage='+val))
    for val in sorted([v for v in df['lineage_subtype'].unique() if v"'!='"'not_applicable']):
        coef,p,se=ols_coef(y, (df['lineage_subtype']==val).astype(float).to_numpy(), base_screen)
        rows.append((abs(coef), coef,p,'subtype='+val))
    rows.sort(reverse=True)
    print('\\n', ycol)
    for _,coef,p,name in rows[:8]:
        print(f'{name:28s} coef={coef: .4f} p={p:.3g}')

# subgroup predicates
preds=[]
for val in sorted(df['lineage'].unique()):
    preds.append((f'lineage == {val}', (df['lineage']==val).to_numpy()))
for val in sorted([v for v in df['lineage_subtype'].unique() if v"'!='"'not_applicable']):
    preds.append((f'lineage_subtype == {val}', (df['lineage_subtype']==val).to_numpy()))
for val in sorted(df['culture_type'].unique()):
    preds.append((f'culture_type == {val}', (df['culture_type']==val).to_numpy()))
for val in sorted(df['media_serum_pct'].unique()):
    preds.append((f'media_serum_pct == {val:g}', (df['media_serum_pct']==val).to_numpy()))
