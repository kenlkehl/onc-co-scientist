for val in sorted(df['lineage'].unique()): preds.append((f'lineage={val}', (df['lineage']==val).to_numpy(), 'lineage'))
for val in sorted([v for v in df['lineage_subtype'].unique() if v"'!='"'not_applicable']): preds.append((f'lineage_subtype={val}', (df['lineage_subtype']==val).to_numpy(), 'subtype'))
for val in sorted(df['culture_type'].unique()): preds.append((f'culture_type={val}', (df['culture_type']==val).to_numpy(), 'culture'))
for val in sorted(df['media_serum_pct'].unique()): preds.append((f'media_serum_pct={val:g}', (df['media_serum_pct']==val).to_numpy(), 'media'))
for f in binary: preds.append((f'{f}=1', df[f].to_numpy(bool), 'binary'))
for f in [c for c in cont if c "'!= '"'media_serum_pct']:
    q75=float(df[f].quantile(.75)); q25=float(df[f].quantile(.25))
    preds.append((f'{f}>=Q75({q75:.4g})', (df[f]>=q75).to_numpy(), 'cont_hi'))
