            coef,p,se=ols_coef(y, mask.astype(float), base_screen)
            if coef < 0: rows.append((coef,p,n,name))
    # pairwise, min n 300, max not too high
    for i,(n1,m1) in enumerate(preds):
        for n2,m2 in preds[i+1:]:
            m=m1 & m2
            n=int(m.sum())
            if n < 300 or n > len(df)-300: continue
            # skip if pair equals either predicate almost exactly
            if n == int(m1.sum()) or n == int(m2.sum()):
                continue
            coef,p,se=ols_coef(y, m.astype(float), base_screen)
            if coef < 0:
                rows.append((coef,p,n,n1+' AND '+n2))
    rows.sort(key=lambda r: r[0])
    print('\\n', ycol)
    for coef,p,n,name in rows[:12]:
        print(f'n={n:5d} coef={coef: .4f} p={p:.3g} :: {name}')
