import pandas as pd, numpy as np
from scipy import stats

df = pd.read_parquet('dataset.parquet')
N=len(df)
outcomes = [c for c in df.columns if c.startswith('dependency_')]

def zcol(c):
    a=df[c].to_numpy(float); return (a-a.mean())/a.std(ddof=0)

def dummies(cols):
    mats=[]; names=[]
    for col in cols:
        dm=pd.get_dummies(df[col].astype(str), prefix=col, drop_first=True, dtype=float)
        mats.append(dm.to_numpy(float)); names+=dm.columns.tolist()
    return (np.column_stack(mats) if mats else np.empty((N,0))), names
screen_media, _ = dummies(['screen_batch','media_serum_pct'])
screen_culture_media, _ = dummies(['screen_batch','culture_type','media_serum_pct'])
lineage_dm, _ = dummies(['lineage'])
base_screen = np.column_stack([np.ones(N), screen_media, zcol('cas9_activity_score'), zcol('growth_rate_doublings_per_day')])
base_no_growth = np.column_stack([np.ones(N), screen_culture_media, lineage_dm, zcol('cas9_activity_score')])
base_mol = np.column_stack([np.ones(N), screen_culture_media, lineage_dm, zcol('cas9_activity_score'), zcol('growth_rate_doublings_per_day')])
base_no_lineage = np.column_stack([np.ones(N), screen_media, zcol('cas9_activity_score'), zcol('growth_rate_doublings_per_day')])

def ols(y, X):
    y=np.asarray(y,float); X=np.asarray(X,float)
    coef, *_=np.linalg.lstsq(X,y,rcond=None)
    resid=y-X@coef
    rank=np.linalg.matrix_rank(X)
    dfree=len(y)-rank
    sigma2=float(resid@resid/dfree)
    XtX_inv=np.linalg.pinv(X.T@X)
    se=np.sqrt(np.diag(XtX_inv)*sigma2)
    t=coef/se
    p=2*stats.t.sf(np.abs(t), dfree)
    return coef,se,p,dfree,rank

def single_adj(ycol, x, base, name):
    X=np.column_stack([base, x.astype(float)])
    c,se,p,_,_=ols(df[ycol].to_numpy(float), X)
    print(f'{name}: {ycol} coef={c[-1]:.6g} se={se[-1]:.4g} p={p[-1]:.3g}')
    return c[-1],p[-1]

print('=== targeted adjusted main effects ===')
single_adj('dependency_BRAF', df['braf_v600e'].to_numpy(), base_mol, 'BRAF v600e adjusted for lineage/screen')
single_adj('dependency_EGFR', df['egfr_amplification'].to_numpy(), base_mol, 'EGFR amp adjusted')
single_adj('dependency_ERBB2', df['erbb2_amplification'].to_numpy(), base_mol, 'ERBB2 amp adjusted')
single_adj('dependency_KRAS', df['kras_mutation'].to_numpy(), base_mol, 'KRAS mutation adjusted')
single_adj('dependency_RIT1', df['nf1_loss'].to_numpy(), base_mol, 'NF1 loss adjusted')
single_adj('dependency_KIF18A', df['apc_mutation'].to_numpy(), base_mol, 'APC mutation adjusted')
single_adj('dependency_KIF18A', zcol('wnt_activity_score'), base_mol, 'WNT per SD adjusted')
single_adj('dependency_RPL11', df['myc_amplification'].to_numpy(), base_mol, 'MYC amp adjusted')
single_adj('dependency_DHX9', zcol('rnaseq_MYC_log2_tpm'), base_mol, 'MYC RNA per SD adjusted')
single_adj('dependency_POLR2A', (df['growth_rate_doublings_per_day']>=df['growth_rate_doublings_per_day'].quantile(.75)).to_numpy(), base_no_growth, 'High growth adjusted no growth')
single_adj('dependency_TMED10', (df['growth_rate_doublings_per_day']>=df['growth_rate_doublings_per_day'].quantile(.75)).to_numpy(), base_no_growth, 'High growth adjusted no growth')

print('\\n=== direct subgroup tests (Welch and adjusted indicator) ===')
def subgroup(ycol, mask, name, base=base_no_lineage):
    y=df[ycol].to_numpy(float); m=mask.astype(bool)
    eff=float(y[m].mean()-y[~m].mean())
    p=float(stats.ttest_ind(y[m],y[~m],equal_var=False).pvalue)
    c,padj=single_adj(ycol, m.astype(float), base, 'adjusted '+name)
    print(f'{name}: n={int(m.sum())}, mean_in={y[m].mean():.4f}, mean_out={y[~m].mean():.4f}, Welch_eff={eff:.4f}, Welch_p={p:.3g}, adj_coef={c:.4f}, adj_p={padj:.3g}')

high_growth = (df['growth_rate_doublings_per_day']>=df['growth_rate_doublings_per_day'].quantile(.75)).to_numpy()
high_wnt = (df['wnt_activity_score']>=df['wnt_activity_score'].quantile(.75)).to_numpy()
high_myc_rna = (df['rnaseq_MYC_log2_tpm']>=df['rnaseq_MYC_log2_tpm'].quantile(.75)).to_numpy()
high_8q24 = (df['copy_number_8q24']>=df['copy_number_8q24'].quantile(.75)).to_numpy()
skin=(df['lineage']=='skin').to_numpy(); pancreatic=(df['lineage']=='pancreatic').to_numpy(); colorectal=(df['lineage']=='colorectal').to_numpy(); brain=(df['lineage']=='brain').to_numpy(); prostate=(df['lineage']=='prostate').to_numpy(); luminal=(df['lineage_subtype']=='luminal').to_numpy()
subgroup('dependency_BRAF', (df['braf_v600e'].to_numpy(bool) & skin), 'BRAF V600E & skin', base_no_lineage)
subgroup('dependency_EGFR', (df['egfr_amplification'].to_numpy(bool) & brain), 'EGFR amp & brain', base_no_lineage)
subgroup('dependency_ERBB2', (df['erbb2_amplification'].to_numpy(bool) & df['lineage'].eq('breast').to_numpy()), 'ERBB2 amp & breast', base_no_lineage)
subgroup('dependency_KRAS', (df['kras_mutation'].to_numpy(bool) & pancreatic), 'KRAS mutant & pancreatic', base_no_lineage)
subgroup('dependency_RIT1', (df['nf1_loss'].to_numpy(bool) & brain), 'NF1 loss & brain', base_no_lineage)
subgroup('dependency_KIF18A', (colorectal & df['apc_mutation'].to_numpy(bool) & high_wnt), 'colorectal & APC mutation & high WNT', base_no_lineage)
subgroup('dependency_TMED10', (prostate & high_growth), 'prostate & high growth', base_no_lineage)
subgroup('dependency_DHX9', (high_growth & high_myc_rna), 'high growth & high MYC RNA', base_no_lineage)
subgroup('dependency_POLR2A', high_growth, 'high growth', base_no_lineage)
subgroup('dependency_RPL11', (df['myc_amplification'].to_numpy(bool) & high_growth), 'MYC amplification & high growth', base_no_lineage)

print('\\n=== interactions ===')
def interaction(ycol, a, b, base, name):
    a=a.astype(float); b=b.astype(float); inter=a*b
    X=np.column_stack([base,a,b,inter])
    c,se,p,_,_=ols(df[ycol].to_numpy(float), X)
    print(f'{name}: {ycol} a={c[-3]:.4f} p_a={p[-3]:.3g}; b={c[-2]:.4f} p_b={p[-2]:.3g}; interaction={c[-1]:.4f} p_int={p[-1]:.3g}')

interaction('dependency_BRAF', df['braf_v600e'].to_numpy(), skin, base_screen, 'BRAF V600E x skin')
interaction('dependency_KRAS', df['kras_mutation'].to_numpy(), pancreatic, base_screen, 'KRAS mutation x pancreatic')
interaction('dependency_RIT1', df['nf1_loss'].to_numpy(), brain, base_screen, 'NF1 loss x brain')
interaction('dependency_KIF18A', df['apc_mutation'].to_numpy(), high_wnt, base_no_lineage, 'APC mutation x high WNT (no lineage control)')
interaction('dependency_KIF18A', df['apc_mutation'].to_numpy(), colorectal, base_screen, 'APC mutation x colorectal')
interaction('dependency_KIF18A', (colorectal & df['apc_mutation'].to_numpy(bool) & high_wnt).astype(float), df['smad4_loss'].to_numpy(), base_screen, 'KIF18A triple subgroup x SMAD4 loss')
interaction('dependency_RPL11', df['myc_amplification'].to_numpy(), high_growth, base_no_lineage, 'MYC amp x high growth')
interaction('dependency_DHX9', high_myc_rna, high_growth, base_no_lineage, 'High MYC RNA x high growth')
interaction('dependency_TMED10', prostate, high_growth, base_no_lineage, 'Prostate x high growth')

print('\\n=== within-subgroup contrasts ===')
def within(ycol, subset, feature, name):
    y=df.loc[subset, ycol].to_numpy(float); f=np.asarray(feature)[subset].astype(bool)
    eff=float(y[f].mean()-y[~f].mean())
    p=float(stats.ttest_ind(y[f],y[~f],equal_var=False).pvalue)
    print(f'{name}: n={len(y)}, n_pos={int(f.sum())}, eff={eff:.4f}, p={p:.3g}, mean_pos={y[f].mean():.4f}, mean_neg={y[~f].mean():.4f}')

within('dependency_KIF18A', (colorectal & df['apc_mutation'].to_numpy(bool) & high_wnt), df['smad4_loss'].to_numpy(), 'SMAD4 loss within colorectal/APC/high-WNT KIF18A subgroup')
within('dependency_BRAF', df['braf_v600e'].to_numpy(bool), skin, 'Skin vs non-skin among BRAF V600E')
within('dependency_KRAS', df['kras_mutation'].to_numpy(bool), pancreatic, 'Pancreatic vs non-pancreatic among KRAS mutants')
within('dependency_RIT1', df['nf1_loss'].to_numpy(bool), brain, 'Brain vs non-brain among NF1-loss')
