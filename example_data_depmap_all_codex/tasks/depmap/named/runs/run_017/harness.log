/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from pathlib import Path

df=pd.read_parquet('dataset.parquet')
outs=[c for c in df.columns if c.startswith('dependency_')]
cat=['lineage','lineage_subtype','culture_type','screen_batch']
bin_cols=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']

for y in outs:
    print('\\n###', y, 'overall', df[y].mean())
    rows=[]
    for col in bin_cols:
        m1=df.loc[df[col]==1,y].mean(); m0=df.loc[df[col]==0,y].mean(); n1=int(df[col].sum())
        t,p=stats.ttest_ind(df.loc[df[col]==1,y], df.loc[df[col]==0,y], equal_var=False)
        rows.append((m1-m0,p,col,n1,m1,m0))
    rows.sort(key=lambda x:x[0])
    print('binary more negative top')
    for r in rows[:8]: print('%s diff=%+.4f p=%.1e n1=%d m1=%.3f m0=%.3f'% (r[2],r[0],r[1],r[3],r[4],r[5]))
    print('binary more positive top')
    for r in rows[-4:]: print('%s diff=%+.4f p=%.1e n1=%d m1=%.3f m0=%.3f'% (r[2],r[0],r[1],r[3],r[4],r[5]))
    crows=[]
    for col in cont:
        slope, intercept, rr, p, se = stats.linregress(df[col], df[y])
        crows.append((slope,p,col,rr))
    crows.sort(key=lambda x:x[0])
    print('cont negative slopes')
    for r in crows[:8]: print('%s slope=%+.4f p=%.1e r=%.3f'% (r[2],r[0],r[1],r[3]))
    print('cont positive slopes')
    for r in crows[-4:]: print('%s slope=%+.4f p=%.1e r=%.3f'% (r[2],r[0],r[1],r[3]))
    gr=[]
    for col in cat:
        for lev,sub in df.groupby(col):
            mask=(df[col]==lev); n=mask.sum()
            if n<100: continue
            diff=df.loc[mask,y].mean()-df.loc[~mask,y].mean()
