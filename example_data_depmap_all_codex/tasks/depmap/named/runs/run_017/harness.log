import pandas as pd, numpy as np
from scipy import stats

df=pd.read_parquet('dataset.parquet')
q={c:df[c].quantile(.75) for c in ['wnt_activity_score','growth_rate_doublings_per_day','rnaseq_MYC_log2_tpm','copy_number_8q24','stemness_score','cas9_activity_score']}
q25={c:df[c].quantile(.25) for c in ['emt_score']}

def report(y, label, mask):
    mask=np.asarray(mask)
    t,p=stats.ttest_ind(df.loc[mask,y], df.loc[~mask,y], equal_var=False)
    print(label, 'n', mask.sum(), 'mean', df.loc[mask,y].mean(), 'comp', df.loc[~mask,y].mean(), 'diff', df.loc[mask,y].mean()-df.loc[~mask,y].mean(), 'p', p)

report('dependency_KIF18A','colorectal & APC & SMAD4 intact & WNT Q75', (df.lineage.eq('colorectal') & df.apc_mutation.eq(1)&df.smad4_loss.eq(0)&(df.wnt_activity_score>=q['wnt_activity_score'])))
report('dependency_KIF18A','colorectal & APC & SMAD4 intact & WNT >= median', (df.lineage.eq('colorectal') & df.apc_mutation.eq(1)&df.smad4_loss.eq(0)&(df.wnt_activity_score>=df.wnt_activity_score.quantile(.5))))
report('dependency_KIF18A','colorectal & APC & WNT Q75 & SMAD4 loss', (df.lineage.eq('colorectal') & df.apc_mutation.eq(1)&df.smad4_loss.eq(1)&(df.wnt_activity_score>=q['wnt_activity_score'])))
report('dependency_KIF18A','colorectal & APC & SMAD4 intact', (df.lineage.eq('colorectal') & df.apc_mutation.eq(1)&df.smad4_loss.eq(0)))
# Complete subgroup for EGFR maybe amp + brain?
report('dependency_EGFR','EGFR amp & brain', (df.egfr_amplification.eq(1)&df.lineage.eq('brain')))
report('dependency_EGFR','EGFR amp & not brain', (df.egfr_amplification.eq(1)&~df.lineage.eq('brain')))
# ERBB2 amp & breast her2
report('dependency_ERBB2','ERBB2 amp & HER2-enriched breast', (df.erbb2_amplification.eq(1)&df.lineage_subtype.eq('her2_enriched')))
report('dependency_ERBB2','ERBB2 amp & other subtype', (df.erbb2_amplification.eq(1)&~df.lineage_subtype.eq('her2_enriched')))
# BRAF mutation & NF1 intact maybe no strong diff
report('dependency_BRAF','BRAF V600E & NF1 intact', (df.braf_v600e.eq(1)&df.nf1_loss.eq(0)))
report('dependency_BRAF','BRAF V600E & NF1 loss', (df.braf_v600e.eq(1)&df.nf1_loss.eq(1)))
# KRAS mut SMAD4 intact vs loss
report('dependency_KRAS','KRAS mut & SMAD4 intact', (df.kras_mutation.eq(1)&df.smad4_loss.eq(0)))
report('dependency_KRAS','KRAS mut & SMAD4 loss', (df.kras_mutation.eq(1)&df.smad4_loss.eq(1)))
# RPL11 myc/copy/growth/stemness
report('dependency_RPL11','MYC amplified & high growth', (df.myc_amplification.eq(1)&(df.growth_rate_doublings_per_day>=q['growth_rate_doublings_per_day'])))
report('dependency_RPL11','MYC amplified & high stemness', (df.myc_amplification.eq(1)&(df.stemness_score>=q['stemness_score'])))
# DHX9 high MYC/squamous/growth
report('dependency_DHX9','high MYC RNA & high growth', ((df.rnaseq_MYC_log2_tpm>=q['rnaseq_MYC_log2_tpm'])&(df.growth_rate_doublings_per_day>=q['growth_rate_doublings_per_day'])))
report('dependency_DHX9','squamous & high MYC RNA', (df.lineage_subtype.eq('squamous')&(df.rnaseq_MYC_log2_tpm>=q['rnaseq_MYC_log2_tpm'])))
# TMED10 after not likely
report('dependency_TMED10','high growth & high Cas9', ((df.growth_rate_doublings_per_day>=q['growth_rate_doublings_per_day'])&(df.cas9_activity_score>=q['cas9_activity_score'])))
# POLR2A high growth high Cas9 lung adeno
report('dependency_POLR2A','high growth & lung adenocarcinoma', ((df.growth_rate_doublings_per_day>=q['growth_rate_doublings_per_day'])&(df.lineage.eq('lung'))&(df.lineage_subtype.eq('adenocarcinoma'))))
report('dependency_POLR2A','high growth & high Cas9', ((df.growth_rate_doublings_per_day>=q['growth_rate_doublings_per_day'])&(df.cas9_activity_score>=q['cas9_activity_score'])))
