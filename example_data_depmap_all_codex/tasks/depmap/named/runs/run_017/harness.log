/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
import statsmodels.api as sm

df=pd.read_parquet('dataset.parquet')
# Define helper
def summarize_group(y, preds):
    mask=np.ones(len(df), dtype=bool)
    name=[]
    for pred, val in preds:
        if isinstance(val, tuple):
            op,thr=val
            if op=='>=': m=df[pred]>=thr; name.append(f'{pred}>={thr:.3g}')
            elif op=='<=': m=df[pred]<=thr; name.append(f'{pred}<={thr:.3g}')
        else:
            m=df[pred].eq(val); name.append(f'{pred}={val}')
        mask &= np.asarray(m)
    comp=~mask
    t,p=stats.ttest_ind(df.loc[mask,y], df.loc[comp,y], equal_var=False)
    print(' AND '.join(name), 'n', mask.sum(), 'mean', df.loc[mask,y].mean(), 'comp', df.loc[comp,y].mean(), 'diff', df.loc[mask,y].mean()-df.loc[comp,y].mean(), 'p', p)

print('KIF18A detailed')
for preds in [
    [('lineage','colorectal')], [('apc_mutation',1)], [('lineage','colorectal'),('apc_mutation',1)],
    [('lineage','colorectal'),('apc_mutation',1),('smad4_loss',0)], [('lineage','colorectal'),('apc_mutation',1),('smad4_loss',1)],
    [('lineage','colorectal'),('apc_mutation',1),('kras_mutation',1)], [('lineage','colorectal'),('apc_mutation',1),('kras_mutation',0)],
    [('lineage','colorectal'),('apc_mutation',1),('msi_high',1)], [('lineage','colorectal'),('apc_mutation',1),('msi_high',0)],
]: summarize_group('dependency_KIF18A', preds)
print('\\nMean table lineage col, apc, smad4')
print(df.assign(is_col=df.lineage.eq('colorectal')).groupby(['is_col','apc_mutation','smad4_loss'])['dependency_KIF18A'].agg(['count','mean','std']).to_string())
print('\\nWNT quartile within colorectal/apc')
q75=df.wnt_activity_score.quantile(.75); q50=df.wnt_activity_score.quantile(.5); q25=df.wnt_activity_score.quantile(.25)
for thresh in [q25,q50,q75]:
    summarize_group('dependency_KIF18A',[('lineage','colorectal'),('apc_mutation',1),('wnt_activity_score',('>=',thresh))])
print('\\nKIF18A regression in colorectal: outcome ~ apc + wnt + smad4 + apc:smad4 + apc:wnt')
sub=df[df.lineage.eq('colorectal')].copy()
sub['apc_wnt']=sub.apc_mutation*sub.wnt_activity_score
sub['apc_smad4']=sub.apc_mutation*sub.smad4_loss
X=sm.add_constant(sub[['apc_mutation','wnt_activity_score','smad4_loss','apc_wnt','apc_smad4','growth_rate_doublings_per_day','cas9_activity_score']])
fit=sm.OLS(sub.dependency_KIF18A, X).fit()
print(fit.summary().tables[1])

print('\\nBRAF detailed')
for preds in [[('braf_v600e',1)],[('braf_v600e',1),('lineage','skin')],[('braf_v600e',1),('nf1_loss',0)],[('braf_v600e',1),('nf1_loss',1)],[('braf_v600e',1),('lineage','skin'),('nf1_loss',0)],[('braf_v600e',1),('lineage','skin'),('nf1_loss',1)]]:
    summarize_group('dependency_BRAF', preds)
print(df.groupby(['braf_v600e','nf1_loss'])['dependency_BRAF'].agg(['count','mean']).to_string())
print(df[df.braf_v600e.eq(1)].groupby('lineage')['dependency_BRAF'].agg(['count','mean']).sort_values('mean').to_string())

print('\\nEGFR detailed')
for preds in [[('egfr_amplification',1)],[('egfr_amplification',1),('lineage','brain')],[('egfr_amplification',1),('lineage','lung')],[('egfr_amplification',1),('emt_score',('<=',q25))],[('egfr_amplification',1),('emt_score',('>=',q75))]]:
    summarize_group('dependency_EGFR', preds)
print(df[df.egfr_amplification.eq(1)].groupby('lineage')['dependency_EGFR'].agg(['count','mean']).sort_values('mean').to_string())

print('\\nERBB2 detailed')
for preds in [[('erbb2_amplification',1)],[('erbb2_amplification',1),('lineage','breast')],[('erbb2_amplification',1),('lineage_subtype','her2_enriched')],[('erbb2_amplification',1),('lineage_subtype','luminal')],[('erbb2_amplification',1),('lineage','gastric')]]:
    summarize_group('dependency_ERBB2', preds)
print(df[df.erbb2_amplification.eq(1)].groupby(['lineage','lineage_subtype'])['dependency_ERBB2'].agg(['count','mean']).sort_values('mean').head(20).to_string())

print('\\nKRAS detailed')
for preds in [[('kras_mutation',1)],[('kras_mutation',1),('lineage','pancreatic')],[('kras_mutation',1),('lineage','colorectal')],[('kras_mutation',1),('stk11_loss',1)],[('kras_mutation',1),('smad4_loss',1)],[('kras_mutation',1),('smad4_loss',0)]]:
    summarize_group('dependency_KRAS', preds)
print(df[df.kras_mutation.eq(1)].groupby('lineage')['dependency_KRAS'].agg(['count','mean']).sort_values('mean').to_string())
print(df.groupby(['kras_mutation','lineage'])['dependency_KRAS'].agg(['count','mean']).sort_values('mean').head(20).to_string())

print('\\nRIT1 detailed')
for preds in [[('nf1_loss',1)],[('nf1_loss',1),('lineage','brain')],[('nf1_loss',1),('lineage','pancreatic')],[('nf1_loss',1),('myc_amplification',1)],[('nf1_loss',1),('kras_mutation',0)],[('nf1_loss',1),('kras_mutation',1)]]:
    summarize_group('dependency_RIT1', preds)
print(df[df.nf1_loss.eq(1)].groupby('lineage')['dependency_RIT1'].agg(['count','mean']).sort_values('mean').to_string())

print('\\nTMED10 detailed')
for preds in [[('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75)))],[('nf1_loss',1)],[('lineage_subtype','luminal')],[('nf1_loss',1),('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75)))],[('lineage_subtype','luminal'),('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75)))]]:
    summarize_group('dependency_TMED10', preds)

print('\\nDHX9 detailed')
for preds in [[('rnaseq_MYC_log2_tpm',('>=',df.rnaseq_MYC_log2_tpm.quantile(.75)))],[('myc_amplification',1)],[('myc_amplification',1),('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75)))],[('lineage_subtype','squamous'),('rnaseq_MYC_log2_tpm',('>=',df.rnaseq_MYC_log2_tpm.quantile(.75)))] ]:
    summarize_group('dependency_DHX9', preds)

print('\\nPOLR2A detailed')
for preds in [[('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75)))],[('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75))),('lineage','lung')],[('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75))),('lineage_subtype','adenocarcinoma')],[('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75))),('cas9_activity_score',('>=',df.cas9_activity_score.quantile(.75)))] ]:
    summarize_group('dependency_POLR2A', preds)

print('\\nRPL11 detailed')
for preds in [[('myc_amplification',1)],[('copy_number_8q24',('>=',df.copy_number_8q24.quantile(.75)))],[('myc_amplification',1),('growth_rate_doublings_per_day',('>=',df.growth_rate_doublings_per_day.quantile(.75)))],[('myc_amplification',1),('copy_number_8q24',('>=',df.copy_number_8q24.quantile(.75)))],[('myc_amplification',1),('stemness_score',('>=',df.stemness_score.quantile(.75)))] ]:
    summarize_group('dependency_RPL11', preds)
