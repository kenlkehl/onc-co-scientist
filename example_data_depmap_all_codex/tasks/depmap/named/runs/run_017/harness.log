The first pass shows several expected drivers with very large effects: `braf_v600e` for BRAF, `egfr_amplification` for EGFR, `erbb2_amplification` for ERBB2, `kras_mutation` for KRAS, `nf1_loss` for RIT1, `apc_mutation`/WNT for KIF18A, and MYC/8q24 features for DHX9/RPL11. I’m now checking interactions and multi-feature subgroups, including weaker or negative-control-looking outcomes like TMED10 and POLR2A.
exec
/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
from scipy import stats
from itertools import combinations

df=pd.read_parquet('dataset.parquet')
outs=[c for c in df.columns if c.startswith('dependency_')]
base_features=[]
bin_cols=['kras_mutation','braf_v600e','egfr_amplification','erbb2_amplification','pik3ca_mutation','apc_mutation','smad4_loss','nf1_loss','rb1_loss','myc_amplification','cdkn2a_loss','pten_loss','stk11_loss','brca2_loss','msi_high']
for col in bin_cols:
    base_features.append((col, df[col].astype(bool)))
for col in ['lineage','lineage_subtype','culture_type','screen_batch']:
    for lev in sorted(df[col].unique()):
        mask=(df[col]==lev)
        if mask.sum()>=500:
            base_features.append((f'{col}={lev}', mask))
cont=['media_serum_pct','cas9_activity_score','growth_rate_doublings_per_day','ploidy','aneuploidy_score','mutation_burden','wnt_activity_score','emt_score','stemness_score','ifn_gamma_signature','hypoxia_score','copy_number_8q24','copy_number_9p21','rnaseq_MYC_log2_tpm','rnaseq_AXL_log2_tpm','rnaseq_SLFN11_log2_tpm','rnaseq_ASCL2_log2_tpm']
for col in cont:
    q25=df[col].quantile(.25); q75=df[col].quantile(.75)
    base_features.append((f'{col}>=Q75({q75:.3g})', df[col]>=q75))
    base_features.append((f'{col}<=Q25({q25:.3g})', df[col]<=q25))

# Single and pair subgroups, n>=500 and <=45k; rank by mean vs complement negative diff and p
for y in outs:
    print('\\n### subgroup search', y, 'overall', df[y].mean())
    records=[]
    for name,mask in base_features:
        n=int(mask.sum())
        if n<500 or n>49500: continue
        m=df.loc[mask,y].mean(); mo=df.loc[~mask,y].mean(); diff=m-mo
        t,p=stats.ttest_ind(df.loc[mask,y],df.loc[~mask,y],equal_var=False)
        records.append((diff,p,n,name,m,mo))
    records.sort(key=lambda x:(x[0], x[1]))
    print('singles most negative')
    for diff,p,n,name,m,mo in records[:12]: print(f'{name:45s} n={n:5d} mean={m:+.4f} comp={mo:+.4f} diff={diff:+.4f} p={p:.1e}')
    pair_records=[]
    # To reduce pair combinations, use top 35 singles by negative diff plus known binary/levels? use all? 64 choose 2 =2016 ok
    feats=base_features
    for i in range(len(feats)):
        n1,m1=feats[i]
        for j in range(i+1,len(feats)):
            n2,m2=feats[j]
            mask=m1 & m2
            n=int(mask.sum())
            if n<300 or n>25000: continue
            comp=~mask
            m=df.loc[mask,y].mean(); mo=df.loc[comp,y].mean(); diff=m-mo
            # Welch p only for fairly strong diff to save? all okay
            t,p=stats.ttest_ind(df.loc[mask,y],df.loc[comp,y],equal_var=False)
            pair_records.append((diff,p,n,n1,n2,m,mo))
    pair_records.sort(key=lambda x:(x[0],x[1]))
    print('pairs most negative')
    for diff,p,n,n1,n2,m,mo in pair_records[:15]: print(f'{n1} AND {n2:35s} n={n:5d} mean={m:+.4f} comp={mo:+.4f} diff={diff:+.4f} p={p:.1e}')
