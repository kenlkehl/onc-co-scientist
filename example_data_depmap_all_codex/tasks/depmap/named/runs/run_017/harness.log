df=pd.read_parquet('dataset.parquet')
base_no_growth='C(lineage)+C(culture_type)+C(screen_batch)+cas9_activity_score'
base_no_cas9='C(lineage)+C(culture_type)+C(screen_batch)+growth_rate_doublings_per_day'
