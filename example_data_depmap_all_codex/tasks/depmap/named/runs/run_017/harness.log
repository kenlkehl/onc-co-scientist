/bin/bash -lc "python - <<'PY'
import pandas as pd, numpy as np
import statsmodels.formula.api as smf
from scipy import stats

df=pd.read_parquet('dataset.parquet')
df['high_growth']=(df.growth_rate_doublings_per_day>=df.growth_rate_doublings_per_day.quantile(.75)).astype(int)
df['high_cas9']=(df.cas9_activity_score>=df.cas9_activity_score.quantile(.75)).astype(int)
df['high_wnt']=(df.wnt_activity_score>=df.wnt_activity_score.quantile(.75)).astype(int)
df['high_myc_rna']=(df.rnaseq_MYC_log2_tpm>=df.rnaseq_MYC_log2_tpm.quantile(.75)).astype(int)
df['high_8q24']=(df.copy_number_8q24>=df.copy_number_8q24.quantile(.75)).astype(int)
df['high_stemness']=(df.stemness_score>=df.stemness_score.quantile(.75)).astype(int)
df['brain_lineage']=(df.lineage=='brain').astype(int)
df['skin_lineage']=(df.lineage=='skin').astype(int)
df['her2_subtype']=(df.lineage_subtype=='her2_enriched').astype(int)
df['colorectal']=(df.lineage=='colorectal').astype(int)
df['lung_adeno']=((df.lineage=='lung') & (df.lineage_subtype=='adenocarcinoma')).astype(int)
df['kif18a_final_subgroup']=((df.lineage=='colorectal') & (df.apc_mutation==1) & (df.smad4_loss==0) & (df.wnt_activity_score>=df.wnt_activity_score.quantile(.75))).astype(int)
df['rpl11_final_subgroup']=((df.myc_amplification==1)&(df.growth_rate_doublings_per_day>=df.growth_rate_doublings_per_day.quantile(.75))).astype(int)
df['dhx9_final_subgroup']=((df.rnaseq_MYC_log2_tpm>=df.rnaseq_MYC_log2_tpm.quantile(.75))&(df.growth_rate_doublings_per_day>=df.growth_rate_doublings_per_day.quantile(.75))).astype(int)
df['polr2a_final_subgroup']=((df.growth_rate_doublings_per_day>=df.growth_rate_doublings_per_day.quantile(.75))&(df.lineage=='lung')&(df.lineage_subtype=='adenocarcinoma')).astype(int)
df['tmed10_final_subgroup']=((df.growth_rate_doublings_per_day>=df.growth_rate_doublings_per_day.quantile(.75))&(df.cas9_activity_score>=df.cas9_activity_score.quantile(.75))).astype(int)
base='C(lineage)+C(culture_type)+C(screen_batch)+cas9_activity_score+growth_rate_doublings_per_day'

def fit_print(label, formula, terms):
    print('\\n###',label)
    fit=smf.ols(formula, data=df).fit()
    for term in terms:
        print(term, 'coef', fit.params.get(term), 'p', fit.pvalues.get(term))
    print('nobs', int(fit.nobs), 'rsq', fit.rsquared)

fit_print('main drivers adjusted', f'dependency_BRAF ~ braf_v600e + {base}', ['braf_v600e'])
fit_print('egfr adjusted', f'dependency_EGFR ~ egfr_amplification + {base}', ['egfr_amplification'])
fit_print('erbb2 adjusted', f'dependency_ERBB2 ~ erbb2_amplification + {base}', ['erbb2_amplification'])
fit_print('kras adjusted', f'dependency_KRAS ~ kras_mutation + {base}', ['kras_mutation'])
fit_print('rit1 adjusted', f'dependency_RIT1 ~ nf1_loss + {base}', ['nf1_loss'])
fit_print('kif18a apc/wnt/smad4 adjusted', 'dependency_KIF18A ~ colorectal*apc_mutation*smad4_loss + colorectal*apc_mutation*high_wnt + C(lineage)+C(culture_type)+C(screen_batch)+cas9_activity_score+growth_rate_doublings_per_day', ['colorectal:apc_mutation:smad4_loss','colorectal:apc_mutation:high_wnt'])
fit_print('kif18a final subgroup adjusted', f'dependency_KIF18A ~ kif18a_final_subgroup + {base}', ['kif18a_final_subgroup'])
fit_print('rpl11 adjusted', f'dependency_RPL11 ~ myc_amplification + high_8q24 + high_growth + {base}', ['myc_amplification','high_8q24','high_growth'])
fit_print('dhx9 adjusted', f'dependency_DHX9 ~ high_myc_rna + myc_amplification + high_growth + {base}', ['high_myc_rna','myc_amplification','high_growth'])
fit_print('polr2a adjusted', f'dependency_POLR2A ~ high_growth + high_cas9 + {base}', ['high_growth','high_cas9'])
fit_print('tmed10 adjusted', f'dependency_TMED10 ~ high_growth + high_cas9 + {base}', ['high_growth','high_cas9'])
# final subgroups adjusted
for y,sg in [('dependency_BRAF','braf_v600e'),('dependency_EGFR','egfr_amplification'),('dependency_ERBB2','erbb2_amplification'),('dependency_KRAS','kras_mutation'),('dependency_RIT1','nf1_loss'),('dependency_KIF18A','kif18a_final_subgroup'),('dependency_DHX9','dhx9_final_subgroup'),('dependency_POLR2A','polr2a_final_subgroup'),('dependency_RPL11','rpl11_final_subgroup'),('dependency_TMED10','tmed10_final_subgroup')]:
    fit=smf.ols(f'{y} ~ {sg} + {base}', data=df).fit()
    print('FINAL', y, sg, fit.params[sg], fit.pvalues[sg])
# interactions
fit_print('BRAF NF1 interaction adjusted', f'dependency_BRAF ~ braf_v600e*nf1_loss + {base}', ['braf_v600e','braf_v600e:nf1_loss'])
fit_print('EGFR brain interaction adjusted', f'dependency_EGFR ~ egfr_amplification*brain_lineage + {base}', ['egfr_amplification','egfr_amplification:brain_lineage'])
fit_print('ERBB2 HER2 subtype interaction adjusted', f'dependency_ERBB2 ~ erbb2_amplification*her2_subtype + {base}', ['erbb2_amplification','erbb2_amplification:her2_subtype'])
fit_print('KRAS colorectal/pancreatic interactions adjusted', f'dependency_KRAS ~ kras_mutation*colorectal + kras_mutation*C(lineage) + C(culture_type)+C(screen_batch)+cas9_activity_score+growth_rate_doublings_per_day', ['kras_mutation','kras_mutation:colorectal'])
# Better KRAS with pancreatic indicator separately
# Print coefs for lineage interactions terms
fit=smf.ols(f'dependency_KRAS ~ kras_mutation*C(lineage) + C(culture_type)+C(screen_batch)+cas9_activity_score+growth_rate_doublings_per_day', data=df).fit()
print('\\n### KRAS lineage interaction terms')
for term in fit.params.index:
    if 'kras_mutation:C(lineage)' in term:
        print(term, fit.params[term], fit.pvalues[term])
fit_print('RIT1 brain interaction adjusted', f'dependency_RIT1 ~ nf1_loss*brain_lineage + {base}', ['nf1_loss','nf1_loss:brain_lineage'])
fit_print('RPL11 growth interaction adjusted', f'dependency_RPL11 ~ myc_amplification*high_growth + high_8q24 + {base}', ['myc_amplification','myc_amplification:high_growth','high_8q24'])
fit_print('DHX9 MYC-growth interaction adjusted', f'dependency_DHX9 ~ high_myc_rna*high_growth + myc_amplification + {base}', ['high_myc_rna','high_myc_rna:high_growth','myc_amplification'])
