@@ -0,0 +1,538 @@
+const fs = require("fs");
+
+const parquetPath = "dataset.parquet";
+const bytes = fs.readFileSync(parquetPath);
+
+const COMPACT = {
+  STOP: 0,
+  TRUE: 1,
+  FALSE: 2,
+  BYTE: 3,
+  I16: 4,
+  I32: 5,
+  I64: 6,
+  DOUBLE: 7,
+  BINARY: 8,
+  LIST: 9,
+  SET: 10,
+  MAP: 11,
+  STRUCT: 12,
+  FLOAT: 13,
+};
+
+function compactReader(buffer, start) {
+  let pos = start;
+  function readByte() {
+    return buffer[pos++];
+  }
+  function readVarint() {
+    let shift = 0n;
+    let result = 0n;
+    while (true) {
+      const value = BigInt(readByte());
+      result |= (value & 0x7fn) << shift;
+      if ((value & 0x80n) === 0n) break;
+      shift += 7n;
+    }
+    return result;
+  }
+  function zigZag(value) {
+    return (value >> 1n) ^ -(value & 1n);
+  }
+  function readInt() {
+    return Number(zigZag(readVarint()));
+  }
+  function readUInt() {
+    return Number(readVarint());
+  }
+  function readI64() {
+    return Number(zigZag(readVarint()));
+  }
+  function readBinary() {
+    const len = readUInt();
+    const out = buffer.subarray(pos, pos + len).toString("utf8");
+    pos += len;
+    return out;
+  }
+  function readList() {
+    const header = readByte();
+    let size = header >> 4;
+    const elementType = header & 0x0f;
+    if (size === 15) size = readUInt();
+    const out = [];
+    for (let i = 0; i < size; i++) out.push(readValue(elementType));
+    return out;
+  }
+  function readMap() {
+    const size = readUInt();
+    if (size === 0) return [];
+    const header = readByte();
+    const keyType = header >> 4;
+    const valueType = header & 0x0f;
+    const out = [];
+    for (let i = 0; i < size; i++) out.push([readValue(keyType), readValue(valueType)]);
+    return out;
+  }
+  function readStruct() {
+    let lastField = 0;
+    const out = {};
+    while (true) {
+      const header = readByte();
+      const type = header & 0x0f;
+      if (type === COMPACT.STOP) break;
+      const delta = header >> 4;
+      const fieldId = delta === 0 ? readInt() : lastField + delta;
+      lastField = fieldId;
+      if (type === COMPACT.TRUE) out[fieldId] = true;
+      else if (type === COMPACT.FALSE) out[fieldId] = false;
+      else out[fieldId] = readValue(type);
+    }
