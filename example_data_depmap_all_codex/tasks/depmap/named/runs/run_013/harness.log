+    const tag = input[pos++];
+    const type = tag & 3;
+    if (type === 0) {
+      let length = tag >> 2;
+      if (length < 60) {
+        length += 1;
+      } else {
+        const bytesForLength = length - 59;
+        length = 0;
+        for (let i = 0; i < bytesForLength; i++) length |= input[pos++] << (8 * i);
+        length += 1;
+      }
+      input.copy(out, outPos, pos, pos + length);
+      pos += length;
+      outPos += length;
+    } else {
+      let length;
+      let offset;
+      if (type === 1) {
+        length = ((tag >> 2) & 7) + 4;
+        offset = ((tag & 0xe0) << 3) | input[pos++];
+      } else if (type === 2) {
+        length = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8);
+        pos += 2;
+      } else {
+        length = (tag >> 2) + 1;
+        offset = input[pos] | (input[pos + 1] << 8) | (input[pos + 2] << 16) | (input[pos + 3] << 24);
+        pos += 4;
+      }
+      for (let i = 0; i < length; i++) out[outPos + i] = out[outPos - offset + i];
+      outPos += length;
+    }
+  }
+  if (outPos !== expectedLength) throw new Error(`Snappy length mismatch ${outPos} != ${expectedLength}`);
+  return out;
+}
+
+function decodeHybrid(buffer, start, bitWidth, count, end = buffer.length) {
+  let pos = start;
+  const out = [];
+  const valueBytes = Math.ceil(bitWidth / 8);
+  while (out.length < count && pos < end) {
+    let header = 0;
+    let shift = 0;
+    while (true) {
+      const value = buffer[pos++];
+      header |= (value & 0x7f) << shift;
+      if ((value & 0x80) === 0) break;
+      shift += 7;
+    }
+    if ((header & 1) === 0) {
+      const runLength = header >> 1;
+      let value = 0;
+      for (let i = 0; i < valueBytes; i++) value |= buffer[pos++] << (8 * i);
+      for (let i = 0; i < runLength && out.length < count; i++) out.push(value);
+    } else {
+      const groups = header >> 1;
+      const totalValues = groups * 8;
+      let bitBuffer = 0;
+      let bits = 0;
+      for (let i = 0; i < totalValues; i++) {
+        while (bits < bitWidth) {
+          bitBuffer |= buffer[pos++] << bits;
+          bits += 8;
+        }
+        if (out.length < count) out.push(bitBuffer & ((1 << bitWidth) - 1));
+        bitBuffer >>= bitWidth;
+        bits -= bitWidth;
+      }
+    }
+  }
+  return { values: out, pos };
+}
+
+function readParquet() {
+  const footerLength = bytes.readUInt32LE(bytes.length - 8);
+  const footerStart = bytes.length - 8 - footerLength;
+  const metadata = compactReader(bytes, footerStart).readStruct();
+  const schema = metadata[2];
+  const rowGroup = metadata[4][0];
+  const names = schema.slice(1).map((entry) => entry[4]);
+  const physicalTypes = schema.slice(1).map((entry) => entry[1]);
+  const columns = {};
+  for (let ci = 0; ci < rowGroup[1].length; ci++) {
+    const chunk = rowGroup[1][ci];
+    const meta = chunk[3];
+    const name = meta[3].join(".");
+    const physicalType = physicalTypes[ci];
+    const targetN = meta[5];
+    let pageOffset = meta[11] ?? meta[9];
+    let dictionary = null;
+    const values = [];
+    while (values.length < targetN || dictionary === null) {
+      const headerReader = compactReader(bytes, pageOffset);
+      const pageHeader = headerReader.readStruct();
+      const payloadStart = headerReader.pos;
+      const payloadEnd = payloadStart + pageHeader[3];
+      const payload = snappyUncompress(bytes.subarray(payloadStart, payloadEnd));
+      pageOffset = payloadEnd;
+      if (pageHeader[1] === 2) {
+        const dictN = pageHeader[7][1];
+        dictionary = [];
+        let pos = 0;
+        for (let i = 0; i < dictN; i++) {
+          if (physicalType === 6) {
+            const len = payload.readInt32LE(pos);
+            pos += 4;
+            dictionary.push(payload.subarray(pos, pos + len).toString("utf8"));
+            pos += len;
+          } else if (physicalType === 5) {
+            dictionary.push(payload.readDoubleLE(pos));
+            pos += 8;
+          } else if (physicalType === 2) {
+            dictionary.push(Number(payload.readBigInt64LE(pos)));
+            pos += 8;
+          } else {
+            throw new Error(`Unsupported dictionary physical type ${physicalType} for ${name}`);
+          }
+        }
+      } else if (pageHeader[1] === 0) {
+        const pageN = pageHeader[5][1];
+        let pos = 0;
+        const defByteLength = payload.readUInt32LE(pos);
+        pos += 4 + defByteLength;
+        const bitWidth = payload[pos++];
+        const decoded = decodeHybrid(payload, pos, bitWidth, pageN);
+        for (const id of decoded.values) values.push(dictionary[id]);
+      } else {
+        throw new Error(`Unsupported page type ${pageHeader[1]} for ${name}`);
+      }
+    }
+    columns[name] = values.slice(0, targetN);
+  }
+  return { names, columns, n: metadata[3] };
+}
+
+function mean(arr, mask = null) {
+  let s = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask === null || mask[i]) {
+      s += arr[i];
+      n++;
+    }
+  }
+  return s / n;
+}
+
+function variance(arr, mask = null, mu = null) {
+  if (mu === null) mu = mean(arr, mask);
+  let ss = 0;
+  let n = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask === null || mask[i]) {
+      const d = arr[i] - mu;
+      ss += d * d;
+      n++;
+    }
+  }
+  return ss / Math.max(1, n - 1);
+}
+
+function erf(x) {
+  const sign = x < 0 ? -1 : 1;
+  x = Math.abs(x);
+  const a1 = 0.254829592;
+  const a2 = -0.284496736;
+  const a3 = 1.421413741;
+  const a4 = -1.453152027;
+  const a5 = 1.061405429;
+  const p = 0.3275911;
+  const t = 1 / (1 + p * x);
+  const y = 1 - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * Math.exp(-x * x);
+  return sign * y;
+}
+
+function normalTwoSidedP(z) {
+  const az = Math.abs(z);
+  if (az > 37) return 1e-300;
+  return Math.max(1e-300, 2 * (1 - (0.5 * (1 + erf(az / Math.SQRT2)))));
+}
+
+function twoGroup(arr, mask) {
+  let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+  for (let i = 0; i < arr.length; i++) {
+    if (mask[i]) {
+      n1++;
+      s1 += arr[i];
+      ss1 += arr[i] * arr[i];
+    } else {
+      n0++;
+      s0 += arr[i];
+      ss0 += arr[i] * arr[i];
+    }
+  }
+  const m1 = s1 / n1, m0 = s0 / n0;
+  const v1 = (ss1 - (s1 * s1) / n1) / Math.max(1, n1 - 1);
+  const v0 = (ss0 - (s0 * s0) / n0) / Math.max(1, n0 - 1);
+  const se = Math.sqrt(v1 / n1 + v0 / n0);
+  const z = (m1 - m0) / se;
+  return { effect: m1 - m0, p: normalTwoSidedP(z), z, m1, m0, n1, n0 };
+}
+
+function pearson(arrX, arrY) {
+  const n = arrX.length;
+  let sx = 0, sy = 0, sxx = 0, syy = 0, sxy = 0;
+  for (let i = 0; i < n; i++) {
+    const x = arrX[i], y = arrY[i];
+    sx += x; sy += y; sxx += x * x; syy += y * y; sxy += x * y;
+  }
+  const cov = sxy - sx * sy / n;
+  const vx = sxx - sx * sx / n;
+  const vy = syy - sy * sy / n;
+  const r = cov / Math.sqrt(vx * vy);
+  const z = r * Math.sqrt((n - 2) / Math.max(1e-12, 1 - r * r));
+  return { r, slope: cov / vx, p: normalTwoSidedP(z), z };
+}
+
+function quantile(arr, q) {
+  const copy = [...arr].sort((a, b) => a - b);
+  const idx = Math.min(copy.length - 1, Math.max(0, Math.floor(q * (copy.length - 1))));
+  return copy[idx];
+}
+
+function unique(arr) {
+  return [...new Set(arr)];
+}
+
+function main() {
+  const { columns, n } = readParquet();
+  const outcomes = Object.keys(columns).filter((c) => c.startsWith("dependency_"));
+  const categorical = ["lineage", "lineage_subtype", "culture_type", "screen_batch"];
+  const continuous = [
+    "media_serum_pct", "cas9_activity_score", "growth_rate_doublings_per_day", "ploidy",
+    "aneuploidy_score", "mutation_burden", "wnt_activity_score", "emt_score",
+    "stemness_score", "ifn_gamma_signature", "hypoxia_score", "copy_number_8q24",
+    "copy_number_9p21", "rnaseq_MYC_log2_tpm", "rnaseq_AXL_log2_tpm",
+    "rnaseq_SLFN11_log2_tpm", "rnaseq_ASCL2_log2_tpm",
+  ];
+  const binary = [
+    "kras_mutation", "braf_v600e", "egfr_amplification", "erbb2_amplification",
+    "pik3ca_mutation", "apc_mutation", "smad4_loss", "nf1_loss", "rb1_loss",
+    "myc_amplification", "cdkn2a_loss", "pten_loss", "stk11_loss", "brca2_loss", "msi_high",
+  ];
+
+  console.log(JSON.stringify({ n, outcomes }, null, 2));
+  for (const yName of outcomes) {
+    const y = columns[yName];
+    const hits = [];
+    for (const xName of continuous) {
+      const r = pearson(columns[xName], y);
+      hits.push({ type: "cont", feature: xName, effect: r.slope, r: r.r, p: r.p, z: r.z });
+      const q75 = quantile(columns[xName], 0.75);
+      const mask = columns[xName].map((v) => v >= q75);
+      const tg = twoGroup(y, mask);
+      hits.push({ type: "q75", feature: `${xName}>=${q75.toFixed(4)}`, effect: tg.effect, p: tg.p, z: tg.z, n1: tg.n1, m1: tg.m1, m0: tg.m0 });
+    }
+    for (const xName of binary) {
+      const mask = columns[xName].map((v) => v === 1);
+      const tg = twoGroup(y, mask);
+      hits.push({ type: "bin", feature: xName, effect: tg.effect, p: tg.p, z: tg.z, n1: tg.n1, m1: tg.m1, m0: tg.m0 });
+    }
+    for (const xName of categorical) {
+      for (const value of unique(columns[xName])) {
+        const mask = columns[xName].map((v) => v === value);
+        const n1 = mask.reduce((a, b) => a + (b ? 1 : 0), 0);
+        if (n1 < 250 || n1 > n - 250) continue;
+        const tg = twoGroup(y, mask);
+        hits.push({ type: "cat", feature: `${xName}=${value}`, effect: tg.effect, p: tg.p, z: tg.z, n1: tg.n1, m1: tg.m1, m0: tg.m0 });
+      }
+    }
+    hits.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    console.log("\\nOUTCOME", yName, "mean", mean(y).toFixed(4), "sd", Math.sqrt(variance(y)).toFixed(4));
+    console.log(hits.slice(0, 18).map((h) => ({
+      t: h.type,
+      f: h.feature,
+      eff: +h.effect.toFixed(4),
+      r: h.r === undefined ? undefined : +h.r.toFixed(4),
+      z: +h.z.toFixed(2),
+      p: h.p,
+      n1: h.n1,
+      m1: h.m1 === undefined ? undefined : +h.m1.toFixed(4),
+      m0: h.m0 === undefined ? undefined : +h.m0.toFixed(4),
+    })));
+  }
+
+  const candidatePredicates = [];
+  for (const xName of binary) {
+    const base = columns[xName];
+    candidatePredicates.push({ label: `${xName}=1`, mask: base.map((v) => v === 1) });
+    candidatePredicates.push({ label: `${xName}=0`, mask: base.map((v) => v === 0) });
+  }
+  for (const xName of categorical) {
+    for (const value of unique(columns[xName])) {
+      candidatePredicates.push({ label: `${xName}=${value}`, mask: columns[xName].map((v) => v === value) });
+    }
+  }
+  for (const xName of continuous) {
+    const q10 = quantile(columns[xName], 0.10);
+    const q25 = quantile(columns[xName], 0.25);
+    const q75 = quantile(columns[xName], 0.75);
+    const q90 = quantile(columns[xName], 0.90);
+    candidatePredicates.push({ label: `${xName}>=q75(${q75.toFixed(3)})`, mask: columns[xName].map((v) => v >= q75) });
+    candidatePredicates.push({ label: `${xName}>=q90(${q90.toFixed(3)})`, mask: columns[xName].map((v) => v >= q90) });
+    candidatePredicates.push({ label: `${xName}<=q25(${q25.toFixed(3)})`, mask: columns[xName].map((v) => v <= q25) });
+    candidatePredicates.push({ label: `${xName}<=q10(${q10.toFixed(3)})`, mask: columns[xName].map((v) => v <= q10) });
+  }
+
+  function andMask(a, b) {
+    const out = new Array(a.length);
+    for (let i = 0; i < a.length; i++) out[i] = a[i] && b[i];
+    return out;
+  }
+  function validMask(mask, minN = 300) {
+    let c = 0;
+    for (const v of mask) if (v) c++;
+    return c >= minN && c <= n - minN;
+  }
+  function scoreMask(y, mask, label) {
+    if (!validMask(mask)) return null;
+    const tg = twoGroup(y, mask);
+    return { label, effect: tg.effect, z: tg.z, p: tg.p, n1: tg.n1, m1: tg.m1, m0: tg.m0 };
+  }
+
+  for (const yName of outcomes) {
+    const y = columns[yName];
+    const singles = candidatePredicates.map((c) => scoreMask(y, c.mask, c.label)).filter(Boolean);
+    singles.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    const seeds = singles.slice(0, 28).map((s) => candidatePredicates.find((c) => c.label === s.label));
+    const combos = [];
+    for (let i = 0; i < seeds.length; i++) {
+      for (let j = i + 1; j < seeds.length; j++) {
+        const m = andMask(seeds[i].mask, seeds[j].mask);
+        const s = scoreMask(y, m, `${seeds[i].label} & ${seeds[j].label}`);
+        if (s) combos.push(s);
+      }
+    }
+    combos.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    const tripleSeeds = seeds.slice(0, 18);
+    const triples = [];
+    for (let i = 0; i < tripleSeeds.length; i++) {
+      for (let j = i + 1; j < tripleSeeds.length; j++) {
+        const ij = andMask(tripleSeeds[i].mask, tripleSeeds[j].mask);
+        for (let k = j + 1; k < tripleSeeds.length; k++) {
+          const m = andMask(ij, tripleSeeds[k].mask);
+          const s = scoreMask(y, m, `${tripleSeeds[i].label} & ${tripleSeeds[j].label} & ${tripleSeeds[k].label}`);
+          if (s) triples.push(s);
+        }
+      }
+    }
+    triples.sort((a, b) => Math.abs(b.z) - Math.abs(a.z));
+    console.log("\\nSUBGROUP SEARCH", yName);
+    console.log("single", singles.slice(0, 10).map((s) => ({ label: s.label, eff: +s.effect.toFixed(4), z: +s.z.toFixed(2), p: s.p, n: s.n1, m: +s.m1.toFixed(4), bg: +s.m0.toFixed(4) })));
+    console.log("pairs", combos.slice(0, 10).map((s) => ({ label: s.label, eff: +s.effect.toFixed(4), z: +s.z.toFixed(2), p: s.p, n: s.n1, m: +s.m1.toFixed(4), bg: +s.m0.toFixed(4) })));
+    console.log("triples", triples.slice(0, 10).map((s) => ({ label: s.label, eff: +s.effect.toFixed(4), z: +s.z.toFixed(2), p: s.p, n: s.n1, m: +s.m1.toFixed(4), bg: +s.m0.toFixed(4) })));
+  }
+
+  function printContrast(label, yName, mask) {
+    const out = twoGroup(columns[yName], mask);
+    console.log("TARGET", label, {
+      outcome: yName,
+      effect: +out.effect.toFixed(6),
+      p: out.p,
+      z: +out.z.toFixed(3),
+      n1: out.n1,
+      n0: out.n0,
+      mean1: +out.m1.toFixed(6),
+      mean0: +out.m0.toFixed(6),
+    });
+  }
+  function printSubsetContrast(label, yName, groupMask, subsetMask) {
+    const y = columns[yName];
+    let n1 = 0, n0 = 0, s1 = 0, s0 = 0, ss1 = 0, ss0 = 0;
+    for (let i = 0; i < y.length; i++) {
+      if (!subsetMask[i]) continue;
+      if (groupMask[i]) {
+        n1++; s1 += y[i]; ss1 += y[i] * y[i];
+      } else {
+        n0++; s0 += y[i]; ss0 += y[i] * y[i];
+      }
+    }
+    const m1 = s1 / n1, m0 = s0 / n0;
+    const v1 = (ss1 - s1 * s1 / n1) / Math.max(1, n1 - 1);
+    const v0 = (ss0 - s0 * s0 / n0) / Math.max(1, n0 - 1);
+    const z = (m1 - m0) / Math.sqrt(v1 / n1 + v0 / n0);
+    console.log("SUBSET_TARGET", label, {
+      outcome: yName,
+      effect: +(m1 - m0).toFixed(6),
+      p: normalTwoSidedP(z),
+      z: +z.toFixed(3),
+      n1,
+      n0,
+      mean1: +m1.toFixed(6),
+      mean0: +m0.toFixed(6),
+    });
+  }
+  const q = {};
+  for (const name of continuous) q[name] = {
+    q75: quantile(columns[name], 0.75),
+    q90: quantile(columns[name], 0.90),
+  };
+  const mCol = columns.lineage.map((v) => v === "colorectal");
+  const mWnt90 = columns.wnt_activity_score.map((v) => v >= q.wnt_activity_score.q90);
+  const mWnt75 = columns.wnt_activity_score.map((v) => v >= q.wnt_activity_score.q75);
+  const mSmad0 = columns.smad4_loss.map((v) => v === 0);
+  const mSmad1 = columns.smad4_loss.map((v) => v === 1);
+  const mApc1 = columns.apc_mutation.map((v) => v === 1);
+  const mAscl2Hi = columns.rnaseq_ASCL2_log2_tpm.map((v) => v >= q.rnaseq_ASCL2_log2_tpm.q75);
+  printContrast("KIF18A colorectal_and_WNT90_and_SMAD4_intact", "dependency_KIF18A", andMask(andMask(mCol, mWnt90), mSmad0));
+  printContrast("KIF18A colorectal_and_WNT90_and_SMAD4_loss", "dependency_KIF18A", andMask(andMask(mCol, mWnt90), mSmad1));
+  printContrast("KIF18A colorectal_and_APC_and_WNT75_and_SMAD4_intact", "dependency_KIF18A", andMask(andMask(andMask(mCol, mApc1), mWnt75), mSmad0));
+  printContrast("KIF18A colorectal_and_APC_and_WNT75_and_ASCL2hi", "dependency_KIF18A", andMask(andMask(andMask(mCol, mApc1), mWnt75), mAscl2Hi));
+  printContrast("KIF18A colorectal_and_APC_and_WNT75_and_SMAD4intact_and_ASCL2hi", "dependency_KIF18A", andMask(andMask(andMask(andMask(mCol, mApc1), mWnt75), mSmad0), mAscl2Hi));
+  printSubsetContrast("KIF18A among colorectal_WNT90: SMAD4_intact_vs_loss", "dependency_KIF18A", mSmad0, andMask(mCol, mWnt90));
+  printSubsetContrast("KIF18A among colorectal_APC_WNT75: SMAD4_intact_vs_loss", "dependency_KIF18A", mSmad0, andMask(andMask(mCol, mApc1), mWnt75));
+  printSubsetContrast("KIF18A among WNT90_SMAD4intact: colorectal_vs_other", "dependency_KIF18A", mCol, andMask(mWnt90, mSmad0));
+  printSubsetContrast("KIF18A among colorectal_SMAD4intact: WNT90_vs_lower", "dependency_KIF18A", mWnt90, andMask(mCol, mSmad0));
+}
+
+main();
