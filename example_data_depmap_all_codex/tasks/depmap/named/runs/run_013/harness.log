+function snappyUncompress(input) {
+  let pos = 0;
+  function readVarint() {
+    let result = 0;
+    let shift = 0;
+    while (true) {
+      const value = input[pos++];
+      result |= (value & 0x7f) << shift;
+      if ((value & 0x80) === 0) return result;
+      shift += 7;
