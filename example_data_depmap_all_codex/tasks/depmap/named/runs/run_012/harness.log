import pandas as pd
from pathlib import Path
from scipy import stats
import numpy as np

p = Path('dataset.parquet')
df = pd.read_parquet(p)
print('shape', df.shape)
print('columns')
for c in df.columns:
    print(c, df[c].dtype, df[c].nunique())

outs = [c for c in df.columns if c.startswith('dependency_')]
features = [c for c in df.columns if c not in outs and c "'!= '"'cell_line_id']
print('outcomes', outs)

print('\\nOutcome summaries')
print(df[outs].describe().T[['mean','std','min','25%','50%','75%','max']].to_string())

cat = [c for c in features if df[c].dtype == 'object' or df[c].nunique() <= 12]
num = [c for c in features if c not in cat]
print('\\nCategorical/binary features')
for c in cat:
    vc = df[c].value_counts().head(20)
    print('\\n', c, df[c].nunique())
    print(vc.to_string())
print('\\nNumeric features', num)

records=[]
for out in outs:
    y=df[out]
    for c in num:
        r,pv=stats.pearsonr(df[c], y)
        records.append((out,c,'pearson',r,pv))
    for c in cat:
        vals = df[c]
        if vals.nunique()==2:
            means=y.groupby(vals).mean().sort_values()
            level=means.index[0]
            effect=means.iloc[0]-y[vals"'!=level].mean()
            _,pv=stats.ttest_ind(y[vals==level], y[vals!=level], equal_var=False)
            records.append((out,f'"'{c}={level} vs rest','group_lowest',effect,pv))
        else:
            means=y.groupby(vals).mean().sort_values()
            level=means.index[0]
            effect=means.iloc[0]-y[vals"'!=level].mean()
            group=y[vals==level]
            rest=y[vals!=level]
            _,pv=stats.ttest_ind(group, rest, equal_var=False)
            records.append((out,f'"'{c}={level} vs rest','group_lowest',effect,pv))
            level2=means.index[-1]
            effect2=means.iloc[-1]-y[vals"'!=level2].mean()
            group2=y[vals==level2]; rest2=y[vals!=level2]
            _,pv2=stats.ttest_ind(group2, rest2, equal_var=False)
            records.append((out,f'"'{c}={level2} vs rest','group_highest',effect2,pv2))

recs=pd.DataFrame(records, columns=['outcome','feature','test','effect','p'])
print('\\nTop main effects by p')
print(recs.sort_values('p').head(100).to_string(index=False))
